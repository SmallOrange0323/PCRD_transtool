        "voice": "vo_adv_1055003_026"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好溫暖啊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n牽著手走在一起，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "原來是這麼幸福的事。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "明明只是看著就很幸福了……",
        "unit_id": 105511,
        "voice": "vo_adv_1055003_027"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n如果感受了這種溫暖後……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "會變得更想靠近呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 105511,
        "voice": "vo_adv_1055003_028"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩的身邊",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n一定多的是比我可愛的女孩子，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n像我這種沒什麼特色的人……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "反正……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唉……",
        "unit_id": 105511,
        "voice": "vo_adv_1055003_029"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果能像這樣",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一直找不到路就好了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣的時光，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果能永遠持續下去就……",
        "unit_id": 105511
    },
