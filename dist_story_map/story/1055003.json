    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "原來如此。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是因為想買的特價品一個人只能買一個……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說、",
