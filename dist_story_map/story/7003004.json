[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "話說回來，",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈和{player}\n你們兩個是怎麼相識的？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我和秀才呢，",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是在點心舖相識的～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才真的是厲害地不得了呢！",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n還能精通折扣百分比的計算，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當時的秀才真的是不折不扣的秀才啊～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那，",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "望望你呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是因為遇上粉絲追逐多虧他才獲救。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過{player}，",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n他居然不知道我是偶像……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那時候，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還真有趣。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "蛤啊！？",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那還真是不行啊～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "居然不認識望望，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真不敢相信。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈。",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是就因為這個契機，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就意識到自己還努力得不夠……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n相識之後，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我對他滿懷感激之情。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和{player}在一起，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n感覺能做回原來的自己……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我懂我懂～！",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我只要",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才在一起",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n感覺時間好像一下子就過去了呢。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "到底是為什麼呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈也是一樣的嗎！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也是這麼覺得！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n果然還是在一起的時間最快樂了吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸，",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是說了什麼不得了的話……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也覺得是這樣！",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然我和望望，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的超合拍的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴、",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鈴奈，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "別說了啦～！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也就是說秀才",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不管是對我或望望而言都是最重要的――",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊…………",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…………",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "最、",
        "unit_id": 101611,
        "voice": "vo_adv_7003004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "最重要的……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊啊、",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "笑死了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底，",
        "unit_id": 102911,
        "voice": "vo_adv_7003004_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是什麼呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哈哈、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人的乾笑聲，在塔中回蕩著。"
    }
