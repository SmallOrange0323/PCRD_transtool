    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "怎麼了怎麼了～？",
        "unit_id": 106711,
        "voice": "vo_adv_7029004_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳果然",
