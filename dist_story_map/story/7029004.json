        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106412,
        "voice": "vo_adv_7029004_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這件事的話，",
