    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接下來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這附近的敵人看起來都已經打倒了，",
