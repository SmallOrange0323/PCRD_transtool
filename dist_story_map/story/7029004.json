    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "從剛剛開始",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐就一直在邀請我。",
