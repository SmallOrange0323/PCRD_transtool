        "name": "帆稀",
        "words": "嗯。",
        "unit_id": 106711,
        "voice": "vo_adv_7029004_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n而且，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "普通平凡的幸福結局是不夠的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是為了最棒的幸福結局。",
