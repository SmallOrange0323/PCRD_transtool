        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711,
        "voice": "vo_adv_7029004_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為雪菲有些地方就是沒辦法讓人丟下不管呢～",
