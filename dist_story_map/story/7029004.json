        "type": "dialogue",
        "name": "帆稀",
        "words": "想找的東西也沒找到呢。",
        "unit_id": 106711,
        "voice": "vo_adv_7029004_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我以為在這附近可以找到的～",
