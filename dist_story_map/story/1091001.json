    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在離情人節只剩幾天的某一天。\n城裡充滿著慶祝的氣氛，\n靜流與璃乃來到了鬧區的某間舶來品店。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳要做情人節巧克力嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸！？",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　為什麼突然問我！！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然是要做給哥哥啊。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對呢～",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟很可愛嘛，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n大家都會想送他巧克力呢～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我懂我懂！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我這次也想幫{player}弟弟",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "做巧克力呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和惠理子一起。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "惠、",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "惠理子嗎！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n惠理子是指那個",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "人稱「破壞者」的惠理子吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼會做那種事……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "祕密♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和她的比賽我絕對不能輸。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是女性之間的戰爭呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "比、",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "比賽是指什麼啊……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我只有不好的預感……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後啊，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也想讓{player}看看",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們兩個人做巧克力的模樣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然還是",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要穿得可愛點，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這樣{player}弟弟也會開心吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以我今天是來挑選在料理時要穿的衣服的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總之，",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳是想得到選衣服的建議，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以今天找我來的吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "交給我吧！",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我會幫姐姐選出讓妳最耀眼奪目的衣服的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我還能幫妳修改呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔～",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真可靠！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "　",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要給{player}弟弟巧克力的事要保密喔？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為是驚喜，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "被發現就沒意義了嘛。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了～",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n別看我這樣，我口風很緊喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "俗話說「禍從口入，謹言身心」嘛。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對身體不好的東西",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "千萬不要亂吃啊♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳要說的是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「禍從口出，謹言慎行」吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果是那樣的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們來這裡的事，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也不能讓哥哥知道吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要偷偷地，",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "悄悄地……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼了嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在那邊的人……",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是哥哥。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦！？",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼{player}弟弟會來這裡！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "似乎是來打工呢……",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥他從事很多不同的工作。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呀！？",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "　什麼時候到身後的？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "馬上就被發現了呢……",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過難得{player}弟弟也在，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我來試探一下他對衣服的喜好吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸欸，{player}弟弟。",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你覺得姐姐做料理時，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n穿什麼衣服比較適合？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這問題不會太直接了嗎！？",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "容易活動的衣服？",
