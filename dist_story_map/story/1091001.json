    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我當然也是覺得容易活動會比較好，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟是要做料理嘛？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "穿著運動服做料理\n實在是不可愛呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有沒有什麼好點子呢～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "傳統的衣服啊……",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喏，璃乃，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳覺得烹飪罩衫如何呢？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "穿那個好像老奶奶一樣耶……",
        "unit_id": 101112,
        "voice": "vo_adv_1091001_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "老、",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "老奶奶……！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "穿上烹飪罩衫的話，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就超越「姐姐」",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n變成「奶奶」了嗎……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要拿推薦的商品出來嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911,
        "voice": "vo_adv_1091001_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是圍裙！",
