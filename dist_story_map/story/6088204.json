    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽的朋友秋乃小姐……",
        "unit_id": 121311,
        "voice": "vo_adv_6088204_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是個精力充沛的人，真厲害。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要是我",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也能變得更像秋乃小姐一點的話就好了……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃、",
        "unit_id": 121311,
        "voice": "vo_adv_6088204_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想想喔……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咳咳。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "喔～呵呵呵！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我是",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀育幼院的胡桃！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好的，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天也要開開心心地做生意喔！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感覺好像",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有點怪怪的。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "累積許多迷失方向的經驗",
        "unit_id": 121311,
        "voice": "vo_adv_6088204_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "才能蛻變成了不起的大人，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你是這個意思吧？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "正因為有各種迷失方向的經驗，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "才造就了今日了不起的秋乃小姐。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也會努力的！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒、",
        "unit_id": 121311,
        "voice": "vo_adv_6088204_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒辦法啦。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "光是準備物產展和舞台就讓我焦頭爛額了，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n更多的工作我應付不來。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唉～",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "秋乃小姐",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "跟咲戀媽媽都好厲害喔。",
        "unit_id": 121311
    }
