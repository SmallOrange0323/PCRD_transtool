        "voice": "vo_adv_5084606_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不管是沉睡的理由，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是叫不醒的原因都不清楚，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n根本無計可施了嘛……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100512,
        "voice": "vo_adv_5084606_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "無論面對什麼逆境，英雄都不會放棄的……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "每當我快被挫折給打敗時，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個人總是會在身邊支持我……！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以，",
        "unit_id": 100512,
        "voice": "vo_adv_5084606_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這次支持你的任務就交給我來吧……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我一定會幫助你的……！",
        "unit_id": 100512
    }
]