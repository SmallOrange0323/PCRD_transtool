    {
        "type": "dialogue",
        "name": "客人",
        "words": "那隻貓",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_017"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "逃跑的速度太快，我完全抓不到。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n所以我才會",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "叫那傢伙幻影貓啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "原來如此，",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是這麼一回事啊喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "所以抱歉啦。",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_019"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我把錢放這囉。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "貓咪們",
        "words": "喵～？",
        "unit_id": 1,
        "voice": "vo_adv_1251003_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊啊，",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "他回去了喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "話說回來，真是嚇了我一跳喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓的幻影貓……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……好，我決定了喵！",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就由我來抓捕幻影貓喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然有為非作歹的貓，我就無法置之不理，",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n最重要的是，身為正牌的幻影貓，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不能放過牠！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的嗎喵！",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那真令人安心喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那我們走喵～！",
        "unit_id": 125111
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "歡迎光臨",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_025"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "今天也有進新鮮的魚……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n這不是珠希小姐嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "妳是來買魚的嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看起來非常好吃，我都流口水了，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但不是的喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是來抓捕幻影貓的喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "咦……",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_027"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "你們……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "為什麼？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n哎呀，雖然我求之不得，但",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "我覺得",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "大概不可能喔……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "幻影貓可是個靈敏得不得了的傢伙啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_028"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "在我以為牠已經叼著魚逃走的下一個瞬間，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "牠就會有如幻影般……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "呃，魚不見了！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵──",
        "unit_id": 1711,
        "voice": "vo_adv_1251003_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那邊的屋頂上叼著魚的貓……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那孩子就是幻影貓喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "沒、",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_031"
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "沒錯！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "雖然是敵人，但身手真讓人佩服……！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "\n你這傢伙，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "魚販",
        "words": "給我站住～～！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當然喵！",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那{player}就從右邊繞過去夾擊喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好驚人的速度喵……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我竟然讓牠逃了喵……！",
        "unit_id": 125111
    },
    {
