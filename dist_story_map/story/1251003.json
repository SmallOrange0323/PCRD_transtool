    {
        "type": "dialogue",
        "name": "客人",
        "words": "不、",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_010"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "不是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "看見貓咪們的身影，總覺得很喪氣啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "雖然我非常喜歡這裡的咖啡，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "但得暫時停止來這裡了呢……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "覺得喪氣是怎麼回事喵？",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為客人",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你是常客喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你至今",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一直都很喜愛貓咪的喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_012"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我原本是非常喜歡貓的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "但最近",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "卻變成心理陰影了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "……這一切",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_013"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "全都是那傢伙的錯！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "可恨的幻影貓混帳啊！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是我的錯！！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不對……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼回事喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "嗯……？",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_015"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "珠希小姐為什麼那麼不安？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我在講的是貓的事啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我們店是魚店，",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_016"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "但最近這陣子幾乎每天",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n都有商品的魚被偷走了啊……",
        "unit_id": 1411
