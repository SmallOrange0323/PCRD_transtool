    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這似乎能成為人氣商品喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們店也很歡迎帶貓來的客人喵。",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就想，準備貓用的菜單大概也不錯吧喵～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "貓咪們",
        "words": "嗚喵～～～～♪",
        "unit_id": 1,
        "voice": "vo_adv_1251003_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哎呀，喝太多了喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……木天蓼牛奶似乎太有魅力了喵。",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在有貓咪活動的咖啡廳",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "使用這個菜單，可能會是個失敗喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "……唉。",
        "unit_id": 1411,
        "voice": "vo_adv_1251003_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……",
        "unit_id": 125111,
        "voice": "vo_adv_1251003_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼了喵？這位客人。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n身體不太舒服嗎喵？",
        "unit_id": 125111
