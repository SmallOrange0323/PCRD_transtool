[
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "熟睡……♪",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃～？",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咕噥",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n欸嘿嘿，偶已經粗不下了……♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，什麼？",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總之給我起來，璃乃？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不能睡在這種有魔物到處亂晃的地方呀，會死掉的呦？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳再不快點起來的話，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就要親弟弟了♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我就說禁止偷跑……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，醒來了。",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "早安，璃乃♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼啊，早安……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "奇、奇怪？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這是哪裡？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "冷靜一下～",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n妳是不是睡昏頭了，所以弄不清楚狀況……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡到處都有魔物蠢蠢欲動，所以別太吵了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果發出太大聲響，會把魔物引過來的。",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然也不是我們無法對付的強大魔物，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過我們的體力也有限。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……？",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請等一下，",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我試著回想看看。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我記得今天是與靜流姐一起……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "收集能作為會長圍裙的材料吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在店家買材料太貴，",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我又沒什麼零用錢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "於是就決定打倒魔物，",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n收集可以作為材料的東西。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n比如可以製作毛皮、線、染料之類的原料……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後靜流姐與哥哥就陪我去了對吧。",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "應該說，",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥似乎因為工作的關係，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也在收集相同的材料……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我就請他帶我去可以",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有效率地狩獵魔物的地方。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "結果，",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不知為何靜流姐也跟來了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "本來難得可以和哥哥單獨去野餐的～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "虧我還很期待呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是說好禁止偷跑嗎，璃乃。",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且收集材料還是人多比較有效率啊。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，這麼說也沒錯～……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過為了收集材料，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥帶我去的地方應該是平原吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為什麼我們會跑到",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這樣的洞穴裡來呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，這就是令人想不透的地方。",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n景色在不知不覺間突兀地改變，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等察覺到時，就已經身處這麼陰暗潮濕的地方了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大概是會長用了之前那個不明所以的能力……",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我想她是用了『物件變更』。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "景色雖然改變了，出現的魔物卻是一樣的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，是會長？",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是，她為什麼要做這種事？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不清楚……",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我哪知道那個人在想些什麼，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只是不太希望這單純是她無厘頭的惡作劇。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起那個，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我從剛才就一直連絡會長，卻都沒回應……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以我們必須靠自己離開這個洞穴了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來這座洞窟就像迷宮一般，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n只有我的話也應付不了那麼多魔物……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以璃乃要好好清醒過來，一起加入戰鬥喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的，",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "畢竟哥哥幾乎沒有戰鬥能力嘛。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "必須由我和靜流姐",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n來保護哥哥才行。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n還能順便從打倒的魔物身上剝取材料，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是一舉兩刀♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是『兩得』～",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "順帶一提，因為弟弟昏倒了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以我必須背著他行動。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在這孩子清醒前，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果璃乃妳能替我對付魔物就太好了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "奇怪？",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥他也和我一樣是睡著了吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯……被會長的『物件變更』牽連到的人類，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n體力上似乎會承受很大的負擔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不習慣的話，就會受到打擊而失去意識。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃也是【拉比林斯】的成員之一，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n而且今後一定還會不斷發生類似的事……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以不早點習慣是不行的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的。",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總之，我已經開始習慣靜流姐在給忠告時",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所施展的頭錘了……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐比魔物還可怕。",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是認真這麼覺得。",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喘……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總、總算脫離洞穴了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真吃力呢～",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我也累死了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "結果弟弟",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_041"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一直沒醒來。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "實在沒辦法，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只好用繩子把弟弟跟我綁在一起，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就這樣背著他戰鬥了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥沒事吧？",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，不會是死了吧……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我認為姑且算是還活著，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可以感覺到心跳。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "話說，奇怪？",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_045"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡是……有會長的可麗餅店，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是蘭德索爾的廣場吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼離開洞穴後，會跑到這個地方來？",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_046"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n等等，這兩者的連貫性太奇怪了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道是會長又隨便改變地形了？",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正確答案～",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n靜流真優秀呢。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，會長又用那副超花俏的打扮做生意……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_049"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "客人會怕得不敢接近吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過請放心。",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我現在正在替您縫製圍裙！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為在洞穴裡打倒大量的魔物……",
        "unit_id": 101112,
        "voice": "vo_adv_3006003_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以收集到充足的材料，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是不幸中的大幸♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，原來那才是妳們的目的呀？",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我還以為妳們兩個一定是沒聽我的話……",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n懷疑妳們是不是輕率地與少年接觸了呢～？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總覺得妳們似乎都瞞著我，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n常常與少年約會……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然我懂妳們的心情，但別這麼做喔。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很抱歉，但在準備萬全之前，要請妳們忍耐一下。",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不然的話，我可不知道會發生什麼不妥的事。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳們兩個似乎都已經與少年接觸過了……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "事到如今要妳們當作不認識他，也是強人所難吧～？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以……我只好改變想法，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n決定觀察一下少年與你們接觸時的反應。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個計畫",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n本來是打算要過一陣子後再實行的。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我稍微施展了『物件變更』，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n把大家關進迷宮裡，觀察你們的動向。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "順便煽動一下魔物，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n看看少年的反應如何。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是一個簡單的實驗♪",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過……妳們兩個實在太優秀了，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年都還在昏睡狀態，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳們就輕易的攻破地牢了。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我真是有點失算了，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n下次就設計地稍微困難一點吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會長……",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_064"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "實驗是怎麼一回事？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果讓弟弟暴露在危險之中，",
        "unit_id": 104911,
        "voice": "vo_adv_3006003_065"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就算是會長我也不會饒恕呦？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我知道～",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "實驗會控制在沒有危險的範圍內，所以放心吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "情況真的很危急的時候，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我是打算讓妳們脫逃的。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果遇到最糟糕的情況，我也會出馬。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只是，我也不是萬能的神明。",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並非所有的事情我都知道。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以必須要調查、觀察、做實驗，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n以便掌握各種資訊。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "今後妳們如果還想與少年接觸，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我就會像這次一樣不斷地將妳們捲進實驗裡。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這一點就要請妳們諒解了。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為這樣比起從遠處觀望，",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n更能夠獲得有用的資料～♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "比起那個，大家餓不餓呀？",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我做了新口味的可麗餅，你們吃完再走吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n客人都不來，剩下好多食材呢～♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再這樣下去的話，在查明世界之謎的真相前",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們的門面可麗餅店就會先倒掉了……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了【拉比林斯】的存續，盡量吃吧♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "放心吧。",
        "unit_id": 106813,
        "voice": "vo_adv_3006003_074"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n命運已經開始圍繞著那位少年運轉……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以忍耐和等待的時間，必定也不會太久了。",
        "unit_id": 106813
    }
]