[
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "嗯……",
        "unit_id": 191911,
        "voice": "vo_adv_9003505_000"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n公主殿下你們",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "趕上了啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "陛下！",
        "unit_id": 104711,
        "voice": "vo_adv_9003505_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "純小姐！",
        "unit_id": 105811,
        "voice": "vo_adv_9003505_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有各位！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思我們來晚了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "太好了──",
        "unit_id": 100511,
        "voice": "vo_adv_9003505_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳們平安無事呢！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來妳們也沒事，",
        "unit_id": 100311,
        "voice": "vo_adv_9003505_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡的防守要是被突破就危險了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真不愧是【王宮騎士團】。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "本來只靠我們幾個",
        "unit_id": 103711,
        "voice": "vo_adv_9003505_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "撐得很辛苦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過後來出現了意外的幫手……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘿嘿，",
        "unit_id": 106511,
        "voice": "vo_adv_9003505_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多虧有我們幫忙啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要好～好感謝我們喔？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯！",
        "unit_id": 106611,
        "voice": "vo_adv_9003505_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n只要給我們這國家一年的稅金來答謝這件事就這麼算了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇啊～♪",
        "unit_id": 106711,
        "voice": "vo_adv_9003505_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n祈梨妳呀，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "太客氣了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這、",
        "unit_id": 105811,
        "voice": "vo_adv_9003505_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這實在很為難……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會被小凱留和克蕾琪塔小姐罵的～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……哎呀哎呀。",
        "unit_id": 191911,
        "voice": "vo_adv_9003505_010"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n儘管有人數優勢，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "想不到妳們居然擊退了贊恩。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "真教人吃驚啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個叫贊恩的男人",
        "unit_id": 100311,
        "voice": "vo_adv_9003505_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的很強……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算我們在那裡敗給他",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也一點都不奇怪。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "當然……",
        "unit_id": 191911,
        "voice": "vo_adv_9003505_012"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "妳們也",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "不可能全身而退。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n與他一戰是不是相對地消耗了不少力量呢？",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這一點你應該也差不多！",
        "unit_id": 105811,
        "voice": "vo_adv_9003505_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為純小姐她們也與你一戰了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……【憤怒‧軍團】",
        "unit_id": 100311,
        "voice": "vo_adv_9003505_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "阿澤爾德。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這是第三次",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與你交鋒了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次就來",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做個了斷吧！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "是啊，",
        "unit_id": 191911,
        "voice": "vo_adv_9003505_015"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "這一戰沒有下回了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n究竟誰能站到最後──",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "一決勝負吧！",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──呵呵♪",
        "unit_id": 106711,
        "voice": "vo_adv_9003505_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n嘉夜、祈梨，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再加把勁吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們的目標是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "坐收漁翁之利",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜、祈梨",
        "words": "了解！",
        "unit_id": 1,
        "voice": "vo_adv_9003505_017"
    }
