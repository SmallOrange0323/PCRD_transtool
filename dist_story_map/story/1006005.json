    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受到茜里的拜託，\n一同前往洞窟探索。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝哥哥願意幫忙。",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里又接獲公會長指派的任務……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是姊姊今天好像有什麼重要的事情……",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里自己一個人來的話又覺得害怕，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥能一起來，我好高興～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這次任務的內容嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只是去拿在洞窟深處的特別魔石喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這個洞窟裡不會出現魔物，",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以不會有危險喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然不會有危險……",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "裡、裡面很暗呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可能有點恐怖……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀阿阿阿阿",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊、對不起……",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可、可是，茜里會害怕……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真是，哥哥這個色狼！",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n現在不是在講那種事的時候啦！",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有、有聲響……！",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，好像有什麼東西喔！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……咦？只是水聲……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好險……剛太突然了，害我嚇一跳。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過哥哥真是，",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n又大又壯的……太厲害了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣的話茜里就能安心了呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥說這個姿勢很難走路是嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對、對耶。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然茜里還想這樣下去，那我放開囉……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那、那個……哥哥，",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里覺得害怕，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能不能牽著哥哥的手？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太棒了～",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嘿嘿，這樣的話茜里就安心了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，我們快點把任務完成吧！",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，我們來到最裡面了喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯，魔石……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，在這裡！",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們只要把這個帶回去就行了呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "魔、魔物！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里聽說這個洞窟裡是沒有魔物的說！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……怎、怎麼辦？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥、哥哥在做什麼……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要抱著我逃跑！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可、可是……這個是公主抱……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……不是，不是不可以。",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n反而茜里覺得很高興……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里把自己全部託付給哥哥了，",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n……哥哥要溫柔對待我喔？",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "逃到這裡的話，就能放心了呢。",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里不知道會有魔物出現，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以嚇了一跳呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是被哥哥這樣公主抱……",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里剛剛心跳加速了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥真是積極呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在哥哥的懷抱裡，我覺得非常放心……",
        "unit_id": 100611,
        "voice": "vo_adv_1006005_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "希望能一直被哥哥抱著……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "欸……那兩個人是什麼關係？",
        "unit_id": 411,
        "voice": "vo_adv_1006005_023"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "在這大白天裡竟然這麼光明正大……",
        "unit_id": 511,
        "voice": "vo_adv_1006005_024"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n最近的年輕人，真是的！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "他們讓附近的人們產生很大的誤解，\n也招來了許多異樣的眼光。"
    }
]