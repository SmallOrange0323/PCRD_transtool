[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「七冠」……",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在哪裡聽過這個名字？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有聽過嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n每當提及尤絲蒂亞娜這號人物時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都會出現這個名字呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "記得當時，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像也是被問",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「是否有聽過『七冠』呢？」。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "原來如此……",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若真是如此，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼我的料想似乎是正確的呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "於這個世界中……",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n似乎有著七名",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n能夠自由操使",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "神明般奇蹟之力的存在。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他們被稱為『七冠』，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是擁有著不可思議力量的人們。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而這些，也是我從一位自稱為『七冠』的，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n「某位人物」那聽來的……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然對於是否真的有這樣離奇的存在，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n至今仍舊還是半信半疑就是了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「某位人物」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這正是重點。",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那位人物，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n正是預見了這次",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大量破壞魔法會如何肆虐破壞的存在……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然我也經由占卜，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有了將會有什麼災害發生的預感。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而她正是與我接觸，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並且提出了警告的人物。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那便是自稱為『七冠』的其中一人、",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難以理解的存在……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖不知道本名究竟為何，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但對方報上了似似花",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個名號。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "從外貌看來年紀與我相仿，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "甚至更為年幼，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是一名惹人憐愛的女孩子。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她身著奇妙的裝扮，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但言行舉止卻比外表給人的感覺更加沉著穩重……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總之，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她散發著一股莊嚴又成熟的風範。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她居住在附近一個像是研究所的設施，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n偶爾會跟我們進行一些交易。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她有時也會委託我們一些事，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n比如說",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫她取得稀有的礦物",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或是動植物。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而作為委託的回報，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她會提供我們想要的情報。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她似乎不只擁有豐富的知識，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n甚至還能行使一般來說近乎不可能、",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如同奇蹟般的力量。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "譬如說，徹底分解自己再重新構築，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n讓自己變身成一個完全不同的存在。",
        "unit_id": 103111
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n她似乎相當擅長像那樣，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓自己化為完全不同的樣貌。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她還曾對妾身會能改變外表年齡之事很有興趣，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而從頭到腳把妾身的事情都問過了一遍呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "順帶先說一下。",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n於妾身的城裡所秘藏的古文書中，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也有記載著『七冠』這個名稱。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因內容缺漏不少，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就連妾身至今也仍無法徹底讀解明白吶。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但在那古文書之中，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也有記載著",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似似花",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這個名字喔。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "以相當獨特的筆法所寫下，所以相當地難以判讀，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但確實是寫作",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "「似似花」的樣子。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而這字詞的念法，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似乎就是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似似花呢。",
        "unit_id": 104412
    },
    {
        "type": "still",
        "still": "200700801"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這本，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是妾身說的那本古文書。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n看看也無妨。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "其他能夠證實為『七冠』的名字還有，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n「晶」",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "、「真那」、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "「拉基尼卡東」、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "「克莉絲提娜」……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "順帶一提，這個叫「真那」的傢伙，好像就是",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "「尤絲蒂亞娜」的樣子。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而這也是，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從似似花那裡所聽來的情報吶。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_2007008_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才是不是有提到了「克莉絲提娜」？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會，就是那位",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「克莉絲提娜」吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n難不成有什麼線索嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過嘛，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也不是個多麼稀奇的名字呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n與你們所知道的那傢伙，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也不能確定是否為同一個人吶？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔呣……",
        "unit_id": 105812,
        "voice": "vo_adv_2007008_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這麼說起來「那個男人」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像有稱呼克莉絲提娜為七冠來著？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有這個「拉基尼卡東」，",
        "unit_id": 105812,
        "voice": "vo_adv_2007008_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不就是那個穿著奇裝異服的男人嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這我也不清楚……",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總之，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個預言了大量破壞魔法的人，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就是那位名為似似花的人物。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我認為比起我，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你們或許更需要和她談上幾句唷。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不管怎麼說，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也像是個挺重要的人物呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要到達她所在的研究所，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n除了使用這個城內的移轉魔方陣以外別無他法。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也因此，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "才會特地將大家都叫來了這個地方。",
        "unit_id": 103111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "此外，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個魔方陣只有伊莉亞能夠使用。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因此，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我認為必須要取得伊莉亞的許可。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那玩意兒相當不安定，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也儘可能不想去動它呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但若是為了",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就沒辦法了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而且你們還替妾身安撫了憤怒到失控的宮子呢，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "必須得報答這份恩情。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n若是有必要，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身能夠幫你們啟動魔方陣喔。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是呢……",
        "unit_id": 105812,
        "voice": "vo_adv_2007008_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n若能和那位叫似似花的人接觸的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也許能得到我們所需要的重要情報也說不定呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你們，",
        "unit_id": 105812,
        "voice": "vo_adv_2007008_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "告訴了我們這些相當有幫助的事情。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒有的事。",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n畢竟這裡的每一個人，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都承蒙過{player}的關照呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你們似乎背負著什麼非常重要的使命……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n感覺就像是，身處於一個足以撼動",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "整個世界的洪流之中呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這對於世界上的所有生物來說，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可都不是事不關己。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n若能夠幫上你們的一點小忙，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我覺得很榮幸。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不能再重演",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "任何悲劇。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "光是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "牧場遭受到傷害這件事，至今我都還感到十分愧疚。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若我能好好提出預言，",
        "unit_id": 103111,
        "voice": "vo_adv_2007008_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n更加積極且強烈地警告的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可能就……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是忍的責任吶。",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_045"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是嘛……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n的確希望能避免悲劇的重演呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喜悅與幸福越多，",
        "unit_id": 104412,
        "voice": "vo_adv_2007008_046"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而哀戚與傷痛越少才是最好的。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是活得很長的妾身，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所透徹的其中一項真理唷。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_2007008_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了嗎、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳的臉色，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有點不太好呢……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒事……",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下沒有問題。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不必擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這究竟是怎麼回事呢……",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n古文書上記載的『七冠』之名中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有個再熟悉不過的名字。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是、",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "長老的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下父親的名字呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因是個罕見的姓名，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也不太可能是同名同姓的他人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說來。",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這上頭的這位克莉絲提娜，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若就是前些日子突擊【哞哞自衛隊】的人物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "女人似乎見到在下時，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像也有了異樣的反應呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這與在下的父親，說不定為『七冠』之一的這個事實，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許有什麼關聯嗎？ ",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是窩在神殿之中便能得到愛梅斯大人的諭示，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這方面也令人相當在意……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是什麼呢？",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n毫無原因的突然感到不安呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊唔。",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼了嗎？主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請別冷不防地，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就摸起人家的頭好嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……唔嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問您剛才說了什麼嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是非常抱歉。",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n心不在焉的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有聽進您的那一番話。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不需要擔心，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下沒有什麼事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只是最近這些日子以來的疲勞感，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不小心表現出來了而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不必擔心。",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下無論何時都做好了萬全準備。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是為了主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管得粉身碎骨都在所不惜。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這條未來的路上……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不管是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "知曉了多麼令人不快的真相與事實也一樣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與主人您一塊度過的每日每夜中，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n獲得的這些溫暖的幸福感……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對不會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "成為謊言。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為不可能",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像沒發生過一樣呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣的吧，",
        "unit_id": 105913,
        "voice": "vo_adv_2007008_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的主人。",
        "unit_id": 105913
    }
]