    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【new generations】的各位……",
        "unit_id": 105913,
        "voice": "vo_adv_5035003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n自從那個叫做快閃演唱會的結束之後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就一直處於低迷狀態。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "三位都",
        "unit_id": 105812,
        "voice": "vo_adv_5035003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常沮喪呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該、",
        "unit_id": 106012,
        "voice": "vo_adv_5035003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我\n想一笑置之造成反效果了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事啦，",
        "unit_id": 105812,
        "voice": "vo_adv_5035003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要多吃一點，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃得飽飽的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "心情就會好起來了唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳只要吃飽就沒事了，",
        "unit_id": 106012,
        "voice": "vo_adv_5035003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真是好解決啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_5035003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管一般人沒有像貪吃佩可小姐那樣極端……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但以生物的本質，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要填飽肚子自然就能放鬆也是事實。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "村莊裡的人們，",
        "unit_id": 105913,
        "voice": "vo_adv_5035003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也分給了在下等人一些食材……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就來做些能暖和身子的食物吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～",
        "unit_id": 105812,
        "voice": "vo_adv_5035003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好耶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也一起幫忙♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……唉。",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_011"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n……完全",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "沒有表演好呢……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……嗯。",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_012"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "該不會，",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_013"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我們……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "根本就不適合當偶像吧……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……或許。",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_014"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "所以，",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_015"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要怎麼做？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "妳問要怎麼做",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_016"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是……？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要放棄嗎？",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_017"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "　放棄當偶像。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n我們要這樣就結束了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_018"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_019"
    },
    {
        "type": "dialogue",
        "name": "皮喵太",
        "words": "……皮喵……",
        "unit_id": 4411,
        "voice": "vo_adv_5035003_020"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……！",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_021"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "島村村……！",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_022"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "嗯，",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_023"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "未央！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不會放棄唷！",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_024"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n我不會",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "放棄當偶像的！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是呀！",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_025"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我們還只是",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "稍微失敗了一次而已嘛！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "真的是──",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_026"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "超不甘心的──！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n我對自己很不甘心啊！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "下次絕對絕～對，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "要做得更好！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "嗯！",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_027"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "還有就是對不起，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "小凜。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n明明是我們兩個把小凜牽扯進來的，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "竟然先說喪氣話了！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "唉。",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_028"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "真的是。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不過嘛……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "呵呵……",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_029"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "太好了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果妳們真的要放棄，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n接下來我就得要一個人繼續當偶像了呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "澀凜凜……！？",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_030"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我當然也一樣，",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_031"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "覺得很害羞",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "也覺得很害怕，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n很想要轉身逃走……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但是願意",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_032"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "來看我們的村民們，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n看著我們……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "為我們拍手了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n雖然可能只是禮貌",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "或是為了安慰我們……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但就算是這樣——",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……嗯。",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_033"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n雖然那時候腦袋裡一片空白，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "所以沒有辦法好好地感受……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但是，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那真是一件很棒的事呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯，",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_034"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "沒錯……！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……嗯～～！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "　",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "該怎麼說呢！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n感覺",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "躍躍欲試……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好想快點再一次登台呀！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是的，",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_035"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我也這麼想！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……嗯。",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_036"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n下一次，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "一定要做得更好。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "皮喵太",
        "words": "皮喵！",
        "unit_id": 4411,
        "voice": "vo_adv_5035003_037"
    },
    {
        "type": "dialogue",
        "name": "皮喵太",
        "words": "\n皮喵皮喵喵喵～！！",
        "unit_id": 4411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "皮喵太？",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_038"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n突然間，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是怎麼了呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "皮喵，",
        "unit_id": 112611,
        "voice": "vo_adv_5035003_039"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "怎麼突然這麼興奮啊？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不過，",
        "unit_id": 112511,
        "voice": "vo_adv_5035003_040"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "看起來是很開心……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "的樣子吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊，",
        "unit_id": 112411,
        "voice": "vo_adv_5035003_041"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "大家。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106012,
        "voice": "vo_adv_5035003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明練習不夠就讓她們去辦快閃演唱會的也是你，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還說什麼很高興妳們振作起來了——",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒人這樣搞的吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "長的一臉可愛……",
        "unit_id": 106012,
        "voice": "vo_adv_5035003_043"
    },
