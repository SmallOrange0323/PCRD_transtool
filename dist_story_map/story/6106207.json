    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "にゃっふっふ、",
        "unit_id": 107911,
        "voice": "vo_adv_6106207_000"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お店も千客万来でいい調子にゃ♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n猫従業員たちも楽しく働いてるにゃ～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "がんばってるモニカにお礼をしたいけど……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "何がいいかにゃ？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫パンチのごとくストレートにゃ！",
        "unit_id": 107911,
        "voice": "vo_adv_6106207_001"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "……カフェのお仕事は楽しいし、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "モニカと力を合わせて、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nこれからもがんばるにゃ。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "もちろん、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キミも一緒に、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "だにゃ♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "ナイスアイデアなのにゃ！　",
        "unit_id": 107911,
        "voice": "vo_adv_6106207_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫のおなかを吸えば",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n健康にいい気がするだけじゃなく、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "さまざまな問題が解決はしないけど",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n全部どうでもよくなるのにゃ！　",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "思うさま堪能させてあげるにゃ～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "うにゃぁ！？　",
        "unit_id": 107911,
        "voice": "vo_adv_6106207_003"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "あたし一人でお店を回すってことかにゃ！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "うう、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "でも、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "モニカがへとへとになってお店がお休みになっちゃったら",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n本末転倒なのにゃ……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "上等にゃ！　",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "その話、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "乗ってやるにゃー！",
        "unit_id": 107911
    }
]