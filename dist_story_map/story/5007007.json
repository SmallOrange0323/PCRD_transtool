    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "傑克你也不准碰布丁！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "一個人獨佔也太狡猾了！",
        "unit_id": 10511,
        "voice": "vo_adv_5007007_042"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "\n分一點幸福給我嘛！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吃布丁的幸福，",
        "unit_id": 108211,
        "voice": "vo_adv_5007007_043"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是宮子的特權來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你只能享受別的樂趣！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子，",
        "unit_id": 108111,
        "voice": "vo_adv_5007007_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他對妳提出交換條件時，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n妳不是說和我一起吃布丁才會幸福嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔……",
        "unit_id": 108211,
        "voice": "vo_adv_5007007_045"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳聽到了嗎～？　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是，這個布丁是……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍，妳有點壞心喔。",
        "unit_id": 108211,
        "voice": "vo_adv_5007007_046"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼，",
        "unit_id": 108111,
        "voice": "vo_adv_5007007_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳是討厭我嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不是的～！　",
        "unit_id": 108211,
        "voice": "vo_adv_5007007_048"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家最喜歡妳了～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳又故意說這些壞心眼的話～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵呵，",
        "unit_id": 108111,
        "voice": "vo_adv_5007007_049"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為妳當時說的話讓我太高興了，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n忍不住想逗妳一下。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我、我收回那些話～！",
        "unit_id": 108211,
        "voice": "vo_adv_5007007_050"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁都是宮子一個人的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "好～",
        "unit_id": 10511,
        "voice": "vo_adv_5007007_051"
    },
    {
        "type": "dialogue",
        "name": "傑克",
        "words": "既然這樣那我只用蠻力來搶了！",
        "unit_id": 10511
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "住～手～來～的～！",
        "unit_id": 108211,
        "voice": "vo_adv_5007007_052"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 108111,
        "voice": "vo_adv_5007007_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有很多呢！",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不用搶也吃得到喔。",
        "unit_id": 108111
    }
