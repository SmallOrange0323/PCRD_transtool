[
    {
        "type": "dialogue",
        "name": "嘉夜、祈梨",
        "words": "喝啊！\n嘿──！",
        "unit_id": 1,
        "voice": "vo_adv_9003509_000"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "唔……！",
        "unit_id": 191911,
        "voice": "vo_adv_9003509_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵。",
        "unit_id": 106711,
        "voice": "vo_adv_9003509_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你差不多沒有退路了呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "……哎呀哎呀。",
        "unit_id": 191911,
        "voice": "vo_adv_9003509_003"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "本沒打算捲入消耗戰的……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "真無奈啊。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "萬能人偶",
        "words": "「嗡──嗡──」",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哇哇！",
        "unit_id": 100511,
        "voice": "vo_adv_9003509_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n它們",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "又出現了！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "萬能人偶──",
        "unit_id": 191911,
        "voice": "vo_adv_9003509_005"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "耗費了我這麼多心血，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "應該能爭取到一些時間吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n且讓我重整旗鼓囉。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，大叔！",
        "unit_id": 106511,
        "voice": "vo_adv_9003509_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明才打到一半，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你是想逃嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才",
        "unit_id": 100312,
        "voice": "vo_adv_9003509_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經說了要做個了斷吧……！？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我當然",
        "unit_id": 191911,
        "voice": "vo_adv_9003509_008"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "也想分出勝負。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n但戰鬥",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "比預期的延長了許多……",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "所以我想",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "先用餐休息片刻。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105811,
        "voice": "vo_adv_9003509_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那很不錯呢……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "純、智",
        "words": "陛下！",
        "unit_id": 1,
        "voice": "vo_adv_9003509_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開、",
        "unit_id": 105811,
        "voice": "vo_adv_9003509_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開玩笑的啦～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵呵。",
        "unit_id": 191911,
        "voice": "vo_adv_9003509_012"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n那麼，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "容我先失陪了。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊──！",
        "unit_id": 100511,
        "voice": "vo_adv_9003509_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "等等～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別追了，茉莉！",
        "unit_id": 104711,
        "voice": "vo_adv_9003509_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n智也是！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純？",
        "unit_id": 103711,
        "voice": "vo_adv_9003509_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想我們應該",
        "unit_id": 104711,
        "voice": "vo_adv_9003509_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "留最低限度的兵力在這裡……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並派其他人趕往",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "城裡遭受攻擊的地方救援。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n您覺得好嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "陛下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然！",
        "unit_id": 105811,
        "voice": "vo_adv_9003509_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃飯休息的事",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會先忍耐……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快去幫助大家吧！",
        "unit_id": 105811
    }
]