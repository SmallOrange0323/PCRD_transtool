[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "炎熱夏日的某天，\n{player}在散步的途中受到真步邀請，\n於是來到了【哞哞自衛隊】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "暫時不要亂動唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳在做什麼，",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n幹嘛用類似繩子的東西把{player}綁起來啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "別說那種",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會讓人誤會的話唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這不是繩子",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是捲尺。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚嗚嗚…",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "…",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在測量尺寸啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以是",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳又要做衣服了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在這麼熱的天氣裡啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還真是勤勞。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒錯唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這和",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "天氣冷熱",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一點關係都沒有。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你可要有心裡準備，{player}。",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n公主做的衣服雖然的確是一流的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但那是……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "輕飄飄",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的風格。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "輕飄飄的",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是很可愛嗎。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴卻",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一次也沒穿過我做的衣服。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是壞心眼。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚嗚嗚嗚嗚嗚……",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為我",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不適合穿那種類型啦……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊！？",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不、絕對不行！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那種事……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓優衣穿給你看吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有什麼關係呢，",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳就穿給我們看嘛。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生也",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說想看妳穿唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快住手，公主！",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　別想脫我衣服啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你把頭給我轉過去！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚嗚嗚嗚嗚嗚嗚嗚嗚～！",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想去海邊呀～！",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔哇，嚇我一跳！？",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳從剛才就在喃喃自語，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "突然間是怎麼啦香織！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我再也忍不下去啦～！",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你們看外面～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　連日頭都在閃耀光芒了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們卻宅在房間無所事事，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣太可惜啦～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最近",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都是室內的警衛工作，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以讓香織",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "累積了不少壓力呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "想在大海盡情地游泳～！",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n想在沙灘上到處奔跑～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n哪裡都好我想要跳舞～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等，",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "最後那個妳不是一直都在做嘛……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們就出發吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實啊。",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也覺得大家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最近應該都累了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "正想說和大家一起去旅行呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的假的，",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這可是超級大驚喜啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步，",
        "unit_id": 101711,
        "voice": "vo_adv_5021000_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最喜歡妳了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且，",
        "unit_id": 101011,
        "voice": "vo_adv_5021000_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "偶爾也該讓那些孩子們",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "出來透透氣才行呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……那些孩子們？",
        "unit_id": 104311,
        "voice": "vo_adv_5021000_027"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣香織的願望實現了，\n【哞哞自衛隊】一行人決定去海邊遊玩。"
    }
]