        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "剛才的戰鬥應該已經讓它不能動了才對……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然不知道那種反應是什麼，",
        "unit_id": 109111,
        "voice": "vo_adv_5011321_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但好像變得比剛才更加兇暴了。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請妳們兩位多加小心。",
        "unit_id": 109011,
        "voice": "vo_adv_5011321_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "敵人的樣子跟剛才不一樣了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那尾巴的動作……",
        "unit_id": 109111,
        "voice": "vo_adv_5011321_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有點討厭的感覺呢。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "或許是在準備什麼新的攻擊方式。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n小心一點來迎擊魔物吧！",
        "unit_id": 109111
