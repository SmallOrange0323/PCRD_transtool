[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是美美與{player}去散步時所發生的事――"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "和哥哥一起散步真是開心呢～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_000"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n要一步一步、一步一步地走～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？美美好像踢到什麼東西……",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_001"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……哇、哇啊！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚嗚，跌倒了……",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n嗚哇～好痛呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥是在幫美美秀秀嗎～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇！",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n哥哥的手讓美美非常安心呢～♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～♪謝謝你，哥哥！",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美已經沒事了喔～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……美美是因為被掉落的樹枝絆到，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n所以才跌倒了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美得再小心一點才行……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美常常跌倒，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n也很容易迷路說……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "真想成為更穩重的大姐姐呀～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "比如說……",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_008"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "想變成像禊啦，或是鏡華那樣！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n因為她們兩個都比美美還穩重。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "她們說「美美不再穩重一點是不行的喲！」，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_009"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美總是惹她們生氣～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "耶嘿嘿。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是啊～♪",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_010"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n不知道像不像？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "才、才不是～！美美剛才是在學鏡華～",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_011"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "禊是～那個那個……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美～！妳再慢吞吞的就要丟下妳了呦～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_012"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "是類似這種感覺～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "她們兩人在美美有困難時都會來幫忙，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_013"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n是美美非常重要的朋友呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美最喜歡禊和鏡華了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？哥哥問美美是喜歡她們哪一點啊……？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這個嘛～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "禊她呢～",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_015"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n雖然有點愛惡作劇……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不過美美喜歡她開朗、活力十足～總是很開心這一點！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……哥哥問她活力十足的樣子是？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_016"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "唔～嗯、唔～嗯……啊！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那麼，美美就像剛剛那樣試著模仿看看～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "我是禊喔！啊哈哈～",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_017"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好、好呀，禊要來捉弄一下哥哥囉～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "繫蝴蝶結在他的頭上，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_018"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n縫蕾絲在他的衣服上，要讓他變得輕飄飄又可愛～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦，哥哥說如果是禊的話，大概會惡作劇得更誇張～？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "她會用什麼惡作劇呢？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "像是挖洞啦、水盆砸下來……？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_020"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚……美美不會那種惡作劇啦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n想變成像禊那樣好難呦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_021"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這次換問鏡華？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華呀～她很溫柔又聰明～",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_022"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n雖然有點愛生氣，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "但她生氣都是為了美美好，所以美美最喜歡她了！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥問說是什麼感覺啊？那個，那個……",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_023"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "我是鏡華。紅蘿蔔很好吃喔。",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_024"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n而且能夠補充營養。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "還有……還有～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_025"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "兔子先生非常可愛。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "貓先生與松鼠先生也是，大家都很可愛喔。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……感、感覺如何～？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_026"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n像不像鏡華呢？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～真的嗎～？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_027"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美真開心～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不、不對！",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_028"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不是這樣啦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美不是在問可不可愛，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n而是在問學得像不像啦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "咦！？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_029"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那、那種事美美不知道啦～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不過，如果是鏡華的話，應該能回答哥哥……",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_030"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美是想像鏡華那樣，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_031"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n說一些很有學問的話題……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n可是就是做不好～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "看來美美似乎也不可能",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_032"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n變成像鏡華一樣了……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "……咦？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_033"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n哥哥……你說保持原樣就好，是怎麼意思啊？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美一直這樣是不行的啦～",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_034"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "因為美美完全沒有任何優點！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥說美美也有許多優點……？",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_035"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "真的嗎？哪裡哪裡～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美很溫柔……",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_036"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n總是笑臉迎人……",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n很珍惜動物？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "原來如此～",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_037"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美也有優點呀～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥，你很了解美美呢！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美被哥哥稱讚之後，",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_038"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n就覺得保持現在這個樣子也沒關係了～",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿～謝謝哥哥～！",
        "unit_id": 102011,
        "voice": "vo_adv_1020007_039"
    },
    {
