        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈！",
        "unit_id": 191611,
        "voice": "vo_adv_2101013_012"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n看來已經讓七冠的蘿莉老太婆給您預習過了嘛，",
        "unit_id": 191611
    },
