        "name": "優衣",
        "words": "卡里莎！",
        "unit_id": 100211,
        "voice": "vo_adv_2101013_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你剛剛……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說了你的目標是我對吧。",
