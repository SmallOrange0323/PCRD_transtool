        "name": "卡里莎",
        "words": "\n哈哈～！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n真爽呀～",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "聽到雜魚的求饒！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
