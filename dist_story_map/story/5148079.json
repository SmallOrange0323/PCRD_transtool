    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "確實……",
        "unit_id": 131611,
        "voice": "vo_adv_5148079_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n仔細確認照片的話，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就能發現跟我不同，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n涅婭小姐的臀部攻擊非常俐落純熟。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是扭腰的角度不同嗎……？",
        "unit_id": 131611,
        "voice": "vo_adv_5148079_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
