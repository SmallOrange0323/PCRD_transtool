        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "大家都用屁股在戰鬥嘛？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不，",
        "unit_id": 131611,
        "voice": "vo_adv_5148079_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "大家絕對不是在開玩笑。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是為了順便鍛鍊下半身，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n所以才變成用臀部戰鬥……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "應該",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是那樣。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 131611,
        "voice": "vo_adv_5148079_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n雖然親眼看了照片之後，",
        "unit_id": 131611
    },
