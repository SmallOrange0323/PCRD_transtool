        "name": "怜",
        "words": "呦。",
        "unit_id": 108911,
        "voice": "vo_adv_5010401_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有你一起陪我們戰鬥的話就覺得很放心。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "簡直是以一擋百呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就麻煩你囉。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在可說是，",
        "unit_id": 108911,
        "voice": "vo_adv_5010401_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在和難纏的對手交戰中。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n無論是日和還是優衣，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要知道有你在一起的話就很安心。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這場戰鬥結束後如果還有需要我的地方，",
        "unit_id": 108911,
        "voice": "vo_adv_5010401_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n別客氣直接告訴我。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會很樂意助你一臂之力唷。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，走吧。",
        "unit_id": 108911,
        "voice": "vo_adv_5010401_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了守護大家的新年！",
        "unit_id": 108911
    }
]