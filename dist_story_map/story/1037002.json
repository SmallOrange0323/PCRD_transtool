[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}～！\n這邊這邊♪",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n謝謝你答應我的邀請。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過像這樣遲到會被扣分唷～",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不可以讓女孩子等你喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天輪到你打掃啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你現在是住【咲戀育幼院】，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n需要用幫忙家事來抵住宿費吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果是那樣的話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那也沒辦法呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天讓我等的部分，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可要好好地補償我唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以用平輩的口氣跟你說話嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我真的很不會",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說些拘謹的話……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但你看起來年紀比我大，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n好像必須用敬語呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣啊。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n謝啦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那我就用平輩的方式說話囉♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}，\n你說你不太能分辨「平輩的口氣」有什麼差異……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼說來你喪失記憶了嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到要說明這個也挺難的嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我想想喔。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在這個國家，有個風俗是在跟值得尊敬的年長者說話的時候，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n需要用比較鄭重的口吻說話。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個嘛……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "人生在世本來就有很多麻煩的習慣得面對嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來你鍥而不捨呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我現在13歲唷～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還算是小孩子。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我還是得跟你說一聲，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n像這樣問女孩子的年齡，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可是相當失禮的唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然{player}你說現在喪失了記憶，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n忘了這種禮儀也是沒辦法的事。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不用跟我道歉啦……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為像這樣教導一個什麼都不知道的人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n感覺還滿有趣的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果是喪失記憶的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就算我沒有好好遵守禮儀，應該也不會發現吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會把你當平輩來說話唷。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要我很拘謹地說些「您好」、「請」之類的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會讓我渾身不自在的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n今天特地把你叫出來，真抱歉呢。\n{player}。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為之前約好了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n改天要好好地聊一聊嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你還記得這個約定，我好開心唷。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然{player}你說你喪失記憶了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不過，是不是在那之後發生的事情就不會忘記了啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n以某個時期為分水嶺，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在那之前的事情都從腦袋裡消失無蹤之類的感覺嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "從那之後……",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n來到這城市以後發生的事情，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你全都記得啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼說來，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你還記得",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們在很早以前就曾見過面了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是在「職業介紹所」",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有稍微聊了一下呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在那之後，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n明明過了一段時間，你卻還記得，我好開心唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是不是因為我很可愛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以遇到我的時候，就把我烙印在腦中了呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈……",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你這樣若無其事地說「對啊」還點頭，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "反而讓我很害羞啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "明明我只是在跟你開玩笑的說～",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n結果像是反過來換我被你捉弄了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真不甘心呢。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "本來",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是我在捉弄大人的立場說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "該說是{player}的節奏很獨特嗎，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為不知道你在想什麼，所以很難跟你胡扯呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然這樣",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也滿有趣的啦……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然調查{player}這個人，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是我身為【王宮騎士團】一員的任務……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是他純真到帶著這種企圖跟他接觸，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n會讓我湧出一股罪惡感的程度啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼大家，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要對這麼無害的人刻意警戒成這樣呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "算了，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只要再多深入一點……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我應該也能",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "理解其中的原因吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就讓我用不成熟的作法，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來試探一下你吧……\n{player}。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n啊，抱歉呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一直盯著你看。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為{player}你是帥哥，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n一不小心就看呆了♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你聽不懂「帥哥」是什麼意思啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像這樣喪失記憶的狀態下，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "實在很難捉弄你呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n原本是想說些讓你害羞的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n分散注意力的說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "該說是諸事不順呢，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還是說這麼做很不像我呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀真是的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我都變得怪怪的了啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼呢。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只要跟{player}你聊天，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就覺得好像",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是在逗小寶寶玩呢……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n反正還有時間嘛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就來好好地悠閒的聊一聊吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那可以先點個",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "飲料跟吃的嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天早上，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在進行【王宮騎士團】的戰鬥訓練時……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "被長官狠狠地鍛鍊了一下，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以我肚子很餓呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果{player}也還沒吃的話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我請客，你就盡量點吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聽說這間餐廳的食物很好吃唷，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然也反應在價格上了啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為這一餐算是任務的一部分，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以帳單可以拿去報帳吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以跟這個有趣的男人聊天，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_049"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n加上還能吃到好吃的料理……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就工作來說，還真是愜意呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我明明是為了想跟強敵搏命戰鬥，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n才進到【王宮騎士團】的說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好吧算了～",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "反正也很開心嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你說就算看著菜單上寫的字，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也不知道內容是什麼嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那也是因為記憶喪失的關係吧，",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_053"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真拿你沒辦法……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那我就",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一個個說明給你聽吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的。",
        "unit_id": 103711,
        "voice": "vo_adv_1037002_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你真的很需要別人照顧呢，\n{player}……♪",
        "unit_id": 103711
    }
]