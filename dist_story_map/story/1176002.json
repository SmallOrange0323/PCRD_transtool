        "unit_id": 1412,
        "voice": "vo_adv_1176002_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "原來妳還具備中藥知識。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "既然這樣，一開始就直接告訴我……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我沒有什麼中藥知識呀，",
        "unit_id": 117611,
        "voice": "vo_adv_1176002_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我只是查了這邊的資料，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "確認過功效而已。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦，咦咦？",
        "unit_id": 1412,
        "voice": "vo_adv_1176002_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在這麼短短幾天之內？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那不是應該很費工夫嗎……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不會呀，",
        "unit_id": 117611,
        "voice": "vo_adv_1176002_035"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這點小事",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "費不了什麼工夫，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為這一切",
