    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 117611,
        "voice": "vo_adv_1176002_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過是不同的種類。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這些中藥似乎也有美容的功效，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以我們就採回來了。",
