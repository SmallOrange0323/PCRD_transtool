        "unit_id": 1412,
        "voice": "vo_adv_1176002_030"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝謝你們！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n真不愧是將軍和他的夥伴！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "話說，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那邊的草也是中藥嗎？",
