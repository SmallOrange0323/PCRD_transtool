        "voice": "vo_adv_1176002_038"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我要趕快試試採回來的中藥。",
