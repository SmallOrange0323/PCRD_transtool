    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好了好了，",
        "unit_id": 117611,
        "voice": "vo_adv_1176002_040"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那種事不重要！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n事不宜遲，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "先從這種中藥開始煎吧！",
