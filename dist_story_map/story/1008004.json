[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那是{player}和雪\n一起去買東西時發生的事──"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "快點快點。",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n接下來是那一間店唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有很多很多東西要買呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛過頭的我，有著讓人們欣賞我各式各樣造型的使命呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，太可愛也很辛苦呢……",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比起這個，讓你替我提東西，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n反倒算是獎賞了──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇！",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼啊，這道光……好刺眼！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔哇～！",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_004"
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼………………",
        "unit_id": 1,
        "voice": "vo_adv_1008004_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊哈哈，嚇了一跳吧？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這是給你耳朵的禮物唷。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就是來自可愛的我的，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呼・氣♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，因為在",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n令人意外的地方發現你，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就不禁讓我想捉弄一下呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要我別這樣？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，明明就很開心。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你害羞啦。真可愛♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了。機會難得，",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就特別讓你陪我約會吧。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯！",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n能夠和我一起約會，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你可以感到與有榮焉唷。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不不，是肯定會感到與有榮焉呢。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n因為你可是能夠獨佔可愛的我呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好了，走吧♪",
        "unit_id": 100831
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯────！",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n今天買了很多東西呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也很開心嗎？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯嗯，我想不問也知道就是了♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……欸？東西很重？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒辦法呢，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n楚楚可憐的我和提東西這件事很不相襯對吧？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一想到萬一東西砸到腳出現瘀青的話……",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就覺得好可怕，怕到我晚上只能睡八小時的程度唷。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒有錯呢，我可是很注重睡眠的唷。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是可愛的我出現黑眼圈，",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就是國家的損失……不對，是人類的危機呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說出那種話好嗎？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是放我一個人待在街上，",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n可是會讓我立刻被搭訕的！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "欸欸，這位小姐！",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_020"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n妳真可愛呢！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "我們是時尚雜誌，",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_021"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n「Cuticle」的工作人員，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "妳現在有空嗎？",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，還以為是搭訕，原來是取材呀。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你知道Cuticle嗎？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是在女高中生族群中熱門度第一的時尚雜誌唷。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "現在我們正在街上找",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_023"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n可愛的女孩子來作人物速寫，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "請務必至少讓我們拍一張照片！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然OK呀！",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美貌是全人類的共同財產呢。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就連我本人都沒有權利拒絕呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來吧，",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "立刻開始拍攝吧！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "把我滿溢出來的魅力，",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n毫無保留地拍下來吧。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "那就讓我們多拍幾張囉！",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "盡量按快門吧。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這可是千載難逢能夠拍我的機會呢！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──五分鐘後。"
    },
    {
        "type": "still",
        "still": "100800401"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "很好，妳真的很棒哦！",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_030"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n不但可愛，還很會擺姿勢！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，我已經習慣被人拍了呢。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n擺可愛的姿勢也是我擅長的。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過本來我就是不管擺什麼姿勢都很可愛的呀♪",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_032"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "嗯……妳的可愛和妳的自信名符其實哦！",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_033"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n再來，再讓我多拍一點！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "欸，你看那個模特兒，",
        "unit_id": 1231,
        "voice": "vo_adv_1008004_034"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n非常可愛對吧！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "真的啊！",
        "unit_id": 1131,
        "voice": "vo_adv_1008004_035"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "那個站在旁邊的人會是男朋友嗎？",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那個得意的表情……難道說，就是所謂的男友臉色嗎？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_036"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛的我有男朋友什麼的……",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_037"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不，如果是你，說不定還不壞……",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……只是開玩笑的唷。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_038"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，難道你期待了一下嗎？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "咦？不是男朋友？",
        "unit_id": 1231,
        "voice": "vo_adv_1008004_039"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n啊，被你們聽到了啊……不好意思。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，明明不用急著否認也沒關係的。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_040"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你還真是個容易害羞的人呢♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──十分鐘後。"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "太棒了！我還是第一次見識到這種模特兒哦！",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_041"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再來再來。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_042"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這個姿勢放在封面！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，這個就用在海報上如何？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "這個姿勢很好哦！",
        "unit_id": 1031,
        "voice": "vo_adv_1008004_043"
    },
    {
        "type": "dialogue",
        "name": "雜誌攝影師",
        "words": "\n表情也超棒！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼這次換這種姿勢如何呢？",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_044"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我想非常能夠",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n表現出我的纖細度！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "呀──！",
        "unit_id": 1231,
        "voice": "vo_adv_1008004_045"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n好可愛！",
        "unit_id": 1231
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──三個小時後。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_046"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n還有這種姿勢唷♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣會不會太美了呢？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "流浪貓",
        "words": "喵────",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有這種姿勢，或是這種姿勢。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_047"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管什麼姿勢，都非常適合我呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "已經不能說是「我很可愛」……",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n而是我成為可愛這個詞本身了呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和我刊載在同一個雜誌上的\n模特兒真可憐呢。",
        "unit_id": 100831,
        "voice": "vo_adv_1008004_049"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，我真是造孽……",
        "unit_id": 100831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你做了個好「夢」嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和雪的「記憶碎片」",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的「夢」唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很懷念嗎？嗯，還不清楚啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了還原世界的真實面貌，",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你和許多女孩在一起的「夢」做得越多……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯嗯？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個表情……",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雪說了",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他是男孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你真的不懂啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「那邊」的雪，",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有「這邊」的雪也是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然都是男孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也是女孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以雪才會比可愛的外表還要可愛不是嗎♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好面對心意吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不論是自己的心意，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或是雪的心意，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明白了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1008004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見囉～ ♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔～嗯……？",
