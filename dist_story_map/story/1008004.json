    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？這裡是……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了……",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_059"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我和你一起來買東西……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不知不覺就睡著了啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸？你也睡到剛剛嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_060"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n竟然兩個人一起睡覺……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，有一點害羞呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過還真是開心的夢呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008004_061"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n把我的可愛保留在好幾張相片裡……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
