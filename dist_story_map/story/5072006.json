    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "朝陽升起，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n終於到了夏日演唱會當天。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n今天是個舉辦演唱會的大好日子！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多虧有你們帶回來的藥，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n以及{player}的照顧，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我已經完全康復了！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "甚至",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "比平時還來得有朝氣呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太好了，",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是說啊。",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n妳能恢復活力是再好不過了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝妳們。",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n託紡希和千歌的福，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我才能站上舞台。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這段時間給妳們添的麻煩、",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們對我的擔憂，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n以及",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為我貼心設想的心意。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這些我全部都會在舞台上回報給妳們的。",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也請{player}",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "坐在特等席上好好欣賞我們的演出吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們將會展現出至今為止最為耀眼的一面！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n紡希！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們走吧！",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "擄獲觀眾們的心吧！",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_010"
    },
    {
        "type": "background",
        "background": "501360"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5072006_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位～",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓你們久等了～♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5072006_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沐浴在夏日豔陽下，",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "伴著廣闊的大海──",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天就請大家全心全意地",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "投入我們的演唱會，好好享受一番吧！",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "501363"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "慈樂之音，登台！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_016"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "哇──！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_017"
    },
    {
        "type": "still",
        "still": "507200601"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──各位！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n玩得開心嗎──？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "慈樂之音最棒了───！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵，",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "重頭戲",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在才要開始喔。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "請轉向這邊──！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好～的♪",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所有人我都看得見喔──♪",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "觀眾3",
        "words": "哇啊啊啊───！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_023"
    },
    {
        "type": "dialogue",
        "name": "觀眾3",
        "words": "\n幸虧有來參加這場演唱會～～～～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再大聲一點！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請盡情地喊叫吧，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可別輸給我們了！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣一來，",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們的歌聲，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n也會更有力地傳達給大家……！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "相信大家都很期待",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們卯足全力的演出吧？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你強而有力的聲援♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n視線可別從我身上移開喔──♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……呵呵♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "充滿熱情的聲援。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我會",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "誠心地為你歌唱。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但願你能夠聽見……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "潛藏在這首歌中的思念。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你不用喊得那麼大聲，我也聽得見啦！",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n呃、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咳咳。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛才的話就當我沒說吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "哇──！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_030"
    },
    {
        "type": "background",
        "background": "501363"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──看得還開心嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_5072006_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是當然的。",
        "unit_id": 107111,
        "voice": "vo_adv_5072006_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有我擔任製作人……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為慈樂之音她們",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了超越自己的極限，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "平時就付出了許多努力。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次的演唱會帶來了前所未有的盛況。",
        "unit_id": 107111,
        "voice": "vo_adv_5072006_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她們就快要觸及頂尖偶像的頂端了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話雖如此……",
        "unit_id": 107111,
        "voice": "vo_adv_5072006_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這盛況之熱絡似乎",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有點超乎我的想像。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當然，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是再好不過的事……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過，現場氣氛越是熱絡，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想來潑冷水的傢伙也會變多。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慈樂之音的試煉，",
        "unit_id": 107111,
        "voice": "vo_adv_5072006_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n或許現在才正要開始──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好啦，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家一起來炒熱氣氛吧♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n下一首歌曲是──",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_037"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "魔、",
        "unit_id": 1,
        "voice": "vo_adv_5072006_038"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "魔物！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "而、",
        "unit_id": 1,
        "voice": "vo_adv_5072006_039"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "而且",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "不是只有一、兩隻！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n是一大群魔物！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "各位觀眾，",
        "unit_id": 1,
        "voice": "vo_adv_5072006_040"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "請別慌張！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n我們會",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "立即處理──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾3",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_5072006_041"
    },
    {
        "type": "dialogue",
        "name": "觀眾3",
        "words": "別亂推擠啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾3",
        "words": "\n會場人數這麼多怎麼可能動得了啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾4",
        "words": "這下該怎麼辦……！？",
        "unit_id": 1,
        "voice": "vo_adv_5072006_042"
    },
    {
        "type": "dialogue",
        "name": "觀眾4",
        "words": "\n難得的演唱會就要泡湯了……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "……啊……",
        "unit_id": 1,
        "voice": "vo_adv_5072006_043"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5072006_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是上次",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被我趕跑的魔物的首領",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吧……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "它是來",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討上次的債吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然如此，它的目標應該就是這個舞台了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "魔物　",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 15111
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這讓我想起了",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們的首場演唱會呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n那個時候，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們與觀眾們同心合力",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "擊退了魔物。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，這次的演唱會",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_049"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "遠超乎當時的規模。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就算要觀眾們去避難，以現場人數來看，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只會讓大家陷入混亂吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……妳要怎麼做呢？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…………",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_050"
    },
    {
        "type": "still",
        "still": "507200102"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一旦站上舞台，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n無論遇到什麼樣的狀況，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都要讓全部的人展露笑容。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我還記得",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當時的誓言。",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "501363"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們是慈樂之音。",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n只要我們站在舞台上，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n該怎麼做哪還需要猶豫呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_054"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯！",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好的！",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_057"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們上吧！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_058"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n──誰都不許來擾亂",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "屬於我們的舞台！",
        "unit_id": 117211
    },
    {
        "type": "background",
        "background": "501363"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哈啊、",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_059"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哈啊……！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_060"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼啊……",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我已經",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_062"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把力氣都用光了……",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊，",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_063"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "用盡全身力量……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我已經",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "動不了啦……！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還沒有結束喔。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n會場的大家都還在等著我們。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳們",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "側耳仔細聽吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "安可！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_066"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "\n安可！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "\n安可！！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_067"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我聽到了。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n呼喚著我們的聲音。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖說只有一個人",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒跟上節奏，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n胡亂地大吼大叫的。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希，",
        "unit_id": 117311,
        "voice": "vo_adv_5072006_069"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳聽得出來啊？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n在這片盛大的歡呼聲中。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啥！？",
        "unit_id": 117411,
        "voice": "vo_adv_5072006_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳別再鬧我了啦！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看來妳們",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_071"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都還很有活力嘛。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……還行嗎？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "是的！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_072"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_073"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們走吧！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n回到屬於我們的舞台上！",
        "unit_id": 117211
    },
    {
        "type": "still",
        "still": "507200602"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝大家的安可！",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_074"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "哇───────！",
        "unit_id": 1,
        "voice": "vo_adv_5072006_075"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們看，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_076"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n大家都展露出了笑容。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這幅光景，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_077"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "單靠我一個人是無法實現的。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這是由千歌、紡希和我，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們三個人合力實現的",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最棒的一瞬間。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好啦，",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_078"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就讓我們加把勁，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "超越這一瞬間吧。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "邁向",
        "unit_id": 117211,
        "voice": "vo_adv_5072006_079"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "光輝燦爛的未來──！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "慈樂之音的三人在舞台上綻放耀眼光芒。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這場夏日音樂會，在慈樂之音今後也將持續下去的活動中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n刻畫下了無可取代的歷史軌跡。"
    },
    {
        "type": "still",
        "still": "end"
    }
]