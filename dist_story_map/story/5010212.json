[
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 108711,
        "voice": "vo_adv_5010212_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚哇――！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和沒事吧！？　",
        "unit_id": 108811,
        "voice": "vo_adv_5010212_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這是",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什麼？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "地毯嗎？",
        "unit_id": 108711,
        "voice": "vo_adv_5010212_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該不是吧？　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "黑色的霧……？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可惡！　",
        "unit_id": 108911,
        "voice": "vo_adv_5010212_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "周遭一片漆黑！　",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼都看不到！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "快看！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010212_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "霧開始散了唷！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道說……",
        "unit_id": 108911,
        "voice": "vo_adv_5010212_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在融合嗎……？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像被什麼東西吸了過去！　",
        "unit_id": 108811,
        "voice": "vo_adv_5010212_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個是……！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……怎麼可能。",
        "unit_id": 108911,
        "voice": "vo_adv_5010212_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個是……！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……你們兩個快看。",
        "unit_id": 108711,
        "voice": "vo_adv_5010212_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不就是鏡餅嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎！　",
        "unit_id": 108911,
        "voice": "vo_adv_5010212_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這就是祭司說過的……！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "無法預料的情況……！",
        "unit_id": 108811,
        "voice": "vo_adv_5010212_010"
    }
]