[
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀！？",
        "unit_id": 112111,
        "voice": "vo_adv_5031321_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n出現和我們長得一模一樣的人了！？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然很可怕，",
        "unit_id": 111811,
        "voice": "vo_adv_5031321_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過現在的我們",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該能跟它們對抗！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說的是。",
        "unit_id": 111911,
        "voice": "vo_adv_5031321_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "公會競速賽",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只是與他人競爭，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也是和自己的戰鬥。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對克服了那些事的我們來說，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒有跨越不了的壁壘。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說得好，可蘿仔。",
        "unit_id": 112011,
        "voice": "vo_adv_5031321_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就速速解決，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓那傢伙乖乖聽話吧！",
        "unit_id": 112011
    }
]