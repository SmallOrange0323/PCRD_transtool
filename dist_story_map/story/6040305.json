[
    {
        "type": "background",
        "background": "500995"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為小栞一直都負責牧場的警備工作，",
        "unit_id": 105211,
        "voice": "vo_adv_6040305_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一旦有個萬一的時候，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞真的很可靠呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "什、",
        "unit_id": 105211,
        "voice": "vo_adv_6040305_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "什麼？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "　怎麼突然這麼說。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嚇我一跳。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我沒有辦法勝任牧場的警衛啦……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "曾經有可疑人士",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n看到我就逃跑了呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她拉弓的身姿非常帥氣呢。",
        "unit_id": 105211,
        "voice": "vo_adv_6040305_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也想要像那樣戰鬥看看。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我不會用弓箭就是了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞不擅長的近身戰",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就由我來負責支援吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是啊。",
        "unit_id": 105211,
        "voice": "vo_adv_6040305_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她的身體的確比較虛弱，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但這也讓她成了一個能夠為有同樣處境的人們著想的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "溫柔孩子呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "得再多告訴小栞",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一些她的優點呢。",
        "unit_id": 105211
    }
]