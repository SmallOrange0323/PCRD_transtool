[
    {
        "type": "background",
        "background": "501260"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦──",
        "unit_id": 116211,
        "voice": "vo_adv_5064425_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "討伐了30隻巨大優妮藝品，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不賴嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "關鍵字？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那什麼，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我有點聽不懂。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊──",
        "unit_id": 116211,
        "voice": "vo_adv_5064425_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該不會是那個？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這麼說來，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那兩個人好像有講過什麼。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n記得是",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼「社」",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還是「們」來著的……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也不太清楚，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你就都拿去吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啥？",
        "unit_id": 116211,
        "voice": "vo_adv_5064425_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦、突然幹嘛？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好恐怖。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這人是怎樣？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "突然自信滿滿地講了奇怪的單字還一臉得意，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好恐怖。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼？",
        "unit_id": 116211,
        "voice": "vo_adv_5064425_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "禮物？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "給你？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 116211,
        "voice": "vo_adv_5064425_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "阿姨就給你這把殺手筆劍吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "如何，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣你滿足了嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "恭喜恭喜～",
        "unit_id": 116211
    }
]