[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}～",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這裡這裡！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我找到水果囉～♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我的眼睛很好吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在練劍術的時候，比起靠腕力來壓制對手，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我比較擅長觀察對手肌肉的動作，找出破綻進攻呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我的眼睛很好啊。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你要誇獎我也可以唷？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇哇，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要摸我的頭說「好孩子」啦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們年紀沒差那麼多，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n希望你不要把我當成小孩子呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然說",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "13歲，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n一般來說，的確是個還沒長大的小孩就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n進行得還算順利呢，{player}。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是要收集能用來製作研磨劑的植物，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而{player}是要收集水果跟香菇。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們的目的差不多，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且還可以互相幫忙。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}，\n雖然你在森林裡就讓我覺得很不可思議了……",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "實在沒想到",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你會來森林收集食材。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要太深入的話是還好，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但這座森林還是有魔物出沒，蠻危險的唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是說你居然在過著自給自足的生活……",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼缺錢嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然有在打工賺錢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但買了生活用品等等之後，錢一下就用光了？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以逼不得已，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n只好每天都像這樣來森林裡找東西吃？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那還真是",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "辛苦你了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n佩服",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "佩服♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n與其說是在扶養家庭，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不如說家裡有個像是妹妹一樣的孩子……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你也得為了那孩子，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想辦法賺到生活費啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為那孩子還小，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n實在很不想讓她出來工作是嗎。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我懂喔。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "小孩子就應該悠閒地",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "開心玩樂對吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你說我也還是個孩子，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n應該去玩才對……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我是不會說",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你太雞婆啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過你不用擔心喔，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是我自己選的道路。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我是",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在道場長大的孩子。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從未經世事時就開始鍛鍊了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也想為世人貢獻這身技術。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "若不是為了守護某人，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "或者為了派上用場而使用的話……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "劍術就會",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "僅僅淪為暴力了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n其實對於這身傳承自祖先的技術感到很自豪唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以我才會加入【王宮騎士團】，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n成為正義的一方。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這也是為了成為一個不愧於天，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n能為自己感到自豪的人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我還是一個",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只會耍嘴皮子的小孩子啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不論有什麼遠大的理想，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要是沒有足夠的實力或是沒做出成果，那就不過是個大話而已。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以呢，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n直到達到自己的理想高度之前，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我想不斷提升自己。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是為了達成這目的……",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我才每天都很努力地鍛鍊呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你有時候會提出很難的問題呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喪失記憶之後，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不了解的單字跟概念好像也不少呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n抱歉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我也很想向你說明……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我還不是一個成熟的大人，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可以很有自信地告訴你「正義是什麼」。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也很期待有一天，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n能夠找出這個答案呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n即使一邊聊天，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們兩個的進度也都還不錯呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "籃子裡",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "已經裝滿了食材跟其他採集品呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是再多的話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也會比較難帶回去……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那就到此告一段落，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "回鎮上去吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是太陽下山的話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "魔物們也會變得比較活躍嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然說在一定範圍內我是有辦法處理的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但還是想避免無謂的殺生。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……呀！？",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我沒事！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "發出奇怪的聲音！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不用在意唷！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "糟糕！",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n褲子快要滑掉了……！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n為什麼會這樣啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n啊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是因為那個要用來當研磨劑材料的植物害的嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那植物分泌出來的液體，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可以用來使金屬融化進而容易打磨。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只要好好地調整份量，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就可以當成是很好的研磨劑來使用。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不過剛才採集的那些植物上所分泌的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是原液。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到才一會兒功夫，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n扣住褲子的零件就被融掉了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是我這輩子最大的失誤啊！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n沒料到會有這種事情！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為邊和{player}聊天邊做事的關係，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以完全沒發現自己的裝備快被融化了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗚嗚。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "果然還是太嫩了啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_049"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒問題的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n只要用手壓住的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n褲子應該是不會滑掉……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這樣我就沒有手可以拿籃子了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼辦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}，你說什麼？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我沒事啊。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n完全沒有任何問題！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_053"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你要連我的籃子",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一起幫忙拿嗎……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為多虧了我，所以發現了很多食材，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這是一點小小的謝禮……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且拿這個籃子",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也可以鍛鍊一下肌肉？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你這樣真的幫了我大忙。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n明明你就沒有拜託我呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "覺得有點不好意思啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}……\n是發現了我身陷危機，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_056"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以很貼心地提出說要幫忙吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他果然",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_057"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "超溫柔的……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不對，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_058"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就這樣看來他也不是別有用心呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像就只是很普通地，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把心中想的事情說了出來而已。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是太天然呆了嗎，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_059"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不過，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我覺得他啊……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是這一點可愛呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "欸嘿嘿。",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_060"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "籃子就麻煩你囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那至少讓我走在前面，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_061"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "先幫你找條好走的路。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一起分工合作吧，{player}。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以的話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037006_062"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "以後也是……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "永永遠遠。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果可以像這樣，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "互相扶持彼此就好了呢。",
        "unit_id": 103711
    }
