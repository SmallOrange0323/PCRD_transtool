    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受苑所託而來到郊外的森林。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n彩羽則在那邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以至今沒有看過的認真模樣在揮刀。"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "4997、",
        "unit_id": 132411,
        "voice": "vo_adv_1324002_000"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "4998、",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "4999……",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "5000！！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "呼……",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "咦，",
        "unit_id": 132411,
        "voice": "vo_adv_1324002_001"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "怎麼了嗎，",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "難道說你是來見彩羽的？",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "喔～",
        "unit_id": 132411,
        "voice": "vo_adv_1324002_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是便當！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "太好了！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "小香腸有做成章魚的樣子！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n那麼，",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "上午的練習到此為止！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈也一起吃吧！",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_003"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這邊的蔬菜區就交給你了！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……咦，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "要均衡地吃才行？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哎呀哎呀，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "你說了像小苑會說的話呢～♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那麼就雙手合十！",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_004"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "我要開動了～♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚哦～",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_005"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好好吃～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……啊！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽的臉頰掉了！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那麼接下來，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "要派遣彩羽臉頰探索隊去找。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "找到了。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "我說啊～",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_006"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈知道嗎？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n好好吃飯、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好好睡覺。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這對於變強",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是很重要的喔？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這是",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "成為最強劍士的第一步呢♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_007"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "非常喜歡！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "欸欸，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "你來問彩羽！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n「對彩羽來說劍術是什麼？」",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哈哈，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_008"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "真傷腦筋呢。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "雖然很常被人這麼問，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n但是我沒有明確去定義它。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不過，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "硬要說的話……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "應該是",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "一百億隻",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "鍬形蟲吧。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "開玩笑的～！",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_009"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊哈哈！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽啊，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "會做很多練習，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "然後絕對會！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "成為世界上最強的劍士♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "理由？",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_010"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那個啊～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是因為彩羽非常喜歡劍術！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n在最喜歡的事物上成為第一名，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "很帥氣吧♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "呼～",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_011"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "午休",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "結束～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "開始午後的練習～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n欸欸，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "也來看彩羽的練習吧。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那麼，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_012"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "接下來要開始抓蟲了喔。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n能找到",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "稀有的昆蟲嗎～？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n如果可以的話希望是速度快的昆蟲呢！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘖嘖嘖……",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_013"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈真天真啊。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n這也是實打實的練習喔！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "追趕動作快的昆蟲，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "可以作為提升速度的訓練對吧？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "變成小苑的身體，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_014"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "雖然可以揮舞大把的刀，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n可是要迅速移動高大的身體，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "還挺困難的。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不可以跟小苑",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "說她的身體很重喔！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "但是，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_015"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "提升速度是變成最強的近路，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "所以要加油才行呢！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_016"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "安靜。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "你看，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那邊！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n停在那棵樹上的昆蟲，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "你有看到嗎？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是雷霆音速鍬形蟲喔！！",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_017"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "還是第一次看到本尊！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n牠飛行的速度非常快，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n還沒有人在正面對決中",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "抓住牠過喔！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "要是能抓到牠，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_018"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "可能可以接近世界最強一步！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "樣的話，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就只能去抓了呢！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽的網子",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_019"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不會讓任何蟲子逃走……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "音速鍬形蟲，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "等著吧！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘿呀！！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_020"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "抓到了……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "咦，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是殘影！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚喔──",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_021"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好快！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "真不愧是世界第一呢！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘿嘿，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "熱血沸騰起來了──！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "給我等著吧，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_022"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "雷霆音速鍬形蟲！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n彩羽絕對會抓住你的！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘿！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "呀！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "可惡──",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_023"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "真不愧是音速！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "但是，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "捉蟲現在才要正式開始喔！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n彩羽絕──對，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "會抓到你的──！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "一次不行的話，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_024"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不管是十次、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "一百次、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "一千次",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "還是一億萬次都會不斷抓的！！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n接招接招接招──！！！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚哇，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_025"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好危險！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "差點撞到樹了……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "難道說彩羽",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "正在被牠玩弄？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "呼、",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_026"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "呼……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗚──",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好不甘心！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n完全抓不到啊──！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_027"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就是說啊。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "可是，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "光靠速度",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "抓不到牠……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不能只是隨意揮舞",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "網子……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "師傅",
        "words": "彩羽還沒有",
        "unit_id": 1,
        "voice": "vo_adv_1324002_028"
    },
    {
        "type": "dialogue",
        "name": "師傅",
        "words": "找到屬於自己的劍法呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "師傅",
        "words": "\n在沒找到的狀態下，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "師傅",
        "words": "光是胡亂揮舞，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "師傅",
        "words": "是不會變強的喔。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_029"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "跟師父……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "跟彩羽的爺爺",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "說了一樣的話。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽是不是沒跟姑丈說過啊。",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_030"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n爺爺",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是彩羽的師父，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是個非常強的劍士！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "總有一天",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "要超過爺爺，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這是彩羽的夢想！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_031"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "他一定能輕易抓到牠。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "師父很厲害喔，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "就算是在飛的蟲子，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "他也能用筷子夾住。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "他不只很快，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_032"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "還非常安靜。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不是",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "「咻啪啪啪！」",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "而是「咻……」",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "的感覺。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n就算在旁邊看，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "也不知道他是怎麼動的。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……對耶！",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_033"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "會靜靜地",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "「咻」地動，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不是因為師父很安靜！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n而是因為靜靜地行動所以不會繞遠路！！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不管是劍法，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "還是心都是。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不是有速度就好。",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_034"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n要是不更確實地",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "理解刃尖揮向的地方，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n就會變成只是在胡亂揮舞而已！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "姑丈，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_035"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好像稍微明白了！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n不管是師父說的話，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "還是姑丈說的話！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_036"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "交給彩羽吧！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "為了",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "「咻」地靜靜動作，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "要讓心",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "跟呼吸",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "全部都靜下來……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好～好看著對手……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "集中在網子上……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "雖然小姑娘也挺行的，",
        "unit_id": 1,
        "voice": "vo_adv_1324002_037"
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "但是追不上我……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "\n就算是在她揮網之後，也能夠輕鬆躲開啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽要上了喔，",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_038"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "音速鍬形蟲。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n……下次彩羽絕對不會讓你逃掉。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "又學不會教訓直接衝過來了嗎……",
        "unit_id": 1,
        "voice": "vo_adv_1324002_039"
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "不過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "時候差不多了吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "\n我就等她接近到極限之後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "華麗地迴避！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "\n然後就那樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "順勢離開吧……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "集中精神……",
        "unit_id": 132412,
        "voice": "vo_adv_1324002_040"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "用全身去察覺氣息……",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n將網子直接帶到",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "鍬形蟲要前往的地方。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n不可以焦急。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "也不繞遠路。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "靜靜地，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "筆直地。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "還沒，",
        "unit_id": 1,
        "voice": "vo_adv_1324002_041"
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "還不用逃跑沒關係……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
        "words": "怎麼啦，小姑娘，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "音速鍬形蟲",
