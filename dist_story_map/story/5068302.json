[
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "唔唔……？",
        "unit_id": 14912,
        "voice": "vo_adv_5068302_000"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n妳們也真是煩人啊……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 116713,
        "voice": "vo_adv_5068302_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們當然不會放棄……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為我們不想讓孩子們感到害怕！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且……",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "做出這種事的，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "居然是由我們製作出來的玩具……",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這怎麼可以視而不見呢……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒錯！",
        "unit_id": 116911,
        "voice": "vo_adv_5068302_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們工作是為了",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "孩子們的笑容。",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我們一點也不想看到",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "他們哭泣的模樣！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "明明是和我一起玩，",
        "unit_id": 14912,
        "voice": "vo_adv_5068302_003"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "小孩子卻會哭……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "嗎……？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n……我還以為妳們想說什麼，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "別笑死人了！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我可是",
        "unit_id": 14912,
        "voice": "vo_adv_5068302_004"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "史上最棒的玩具！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "跟我一起玩的小孩子，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n肯定是每一個都會發出愉快的笑聲！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "絕對是這樣！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看來它還沒有冷靜下來呢……！",
        "unit_id": 116911,
        "voice": "vo_adv_5068302_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "它現在很情緒化，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "千萬不可以大意喔！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好、",
        "unit_id": 116713,
        "voice": "vo_adv_5068302_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "若是為了玩具王，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "無論多少次，我都會挺身戰鬥……！",
        "unit_id": 116713
    }
]