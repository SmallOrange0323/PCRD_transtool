[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊緒在月光學院的教完課，\n和{player}一起放學。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "習慣上課的感覺了嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要是有不懂的事情，儘管問我。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我來回答――",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "欸～欸～",
        "unit_id": 411,
        "voice": "vo_adv_1018003_002"
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "\n人家想吃冰淇淋～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "情侶（男）",
        "words": "真拿妳沒辦法。",
        "unit_id": 311,
        "voice": "vo_adv_1018003_003"
    },
    {
        "type": "dialogue",
        "name": "情侶（男）",
        "words": "\n那分一半喔？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "…………",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，抱、抱歉！",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不小心發起呆來……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真羨慕剛剛的情侶呢。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我念的是魔族的女子學校，",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以沒能夠好好享受學生生活。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在回想起來……",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n覺得應該要更加享受學生生活才對。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很憧憬放學路上買點心吃，",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n和男生約會",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？什麼意思？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你願意和我來場放學後的約會嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那就麻煩你吧。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為了謝謝你陪我，我請你吃個東西。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果有想吃的東西，告訴我喔？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！那邊的冰淇淋店，",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n牛奶非常濃厚，很好吃喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "去那間店好嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那我去買喔。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "久等了。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這是你的冰淇淋。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸，怎麼了？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我看起來很開心？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被你發現了呀？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為這正所謂放學後的買點心對吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "實現一個夢想了。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n都是托你的福唷。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個冰淇淋是用來答謝你幫我實現夢想的。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "趕快吃吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不快點吃會融化的――",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好、好冰……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n冰淇淋已經開始融化了呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯、嗯嗯！",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n冰淇淋滴到胸部了……！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗚……",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這樣會黏答答的～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸，你可以幫我擦嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n拜託了，不擦掉的話會流到衣服裡面去。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你看，現在我雙手都拿著冰淇淋……",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n沒辦法自己擦啦～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "樂意至極？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然不大懂……但麻煩你了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以才很困擾呀。",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好啦，快幫我擦～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵、",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵……！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好癢喔……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，擦好了嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你，幫了大忙。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好，",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那讓我們重新開動吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這一個是你的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸，什麼？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只要把冰淇淋給你的話，剛剛我就能自己擦了？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這麼說起來，的確是耶……",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是少根筋。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "……你、你、你在做什麼！",
        "unit_id": 1,
        "voice": "vo_adv_1018003_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀？",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你們是我班上的……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "竟然摸我們伊緒的胸、胸、胸部！",
        "unit_id": 1,
        "voice": "vo_adv_1018003_033"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n不可原諒！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "要處極刑！",
        "unit_id": 1,
        "voice": "vo_adv_1018003_034"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n快抓住那傢伙ー！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "別讓他跑掉！",
        "unit_id": 1,
        "voice": "vo_adv_1018003_035"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n快追ー！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1018003_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n看來已經交到朋友了呢！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n男孩子真是有活力呢～",
        "unit_id": 101811
    }
]