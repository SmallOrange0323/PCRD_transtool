        "voice": "vo_adv_5096000_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一個盤子，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "希望能抽中呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不好意思～！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n剛剛",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我在餐廳領到了抽獎券，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請問這是抽什麼的？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
