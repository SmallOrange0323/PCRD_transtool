        "words": "比賽將由四人為一組的小隊，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n挑戰在沙灘上舉行的各種遊戲！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n",
        "unit_id": 1011
    },
    {
