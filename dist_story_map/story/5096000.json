    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天，{player}受到【破曉之星】的三人邀請，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n去協助她們處理委託。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你今天來幫忙！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "多虧了你，處理起來非常輕鬆呢～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "非常輕鬆……",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是我的錯覺，那很抱歉，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但也發生了相當驚險的場面吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……有、",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有嗎……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣。",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n幫日和回想起當時的狀況吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想想，",
        "unit_id": 100213,
        "voice": "vo_adv_5096000_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當時",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "走在前面的日和，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n中了藤蔓陷阱",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "差點摔跤，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然後……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚哇啊啊啊～！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對不起──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我沒有忘記，所以饒了我吧～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n其實",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "非常非常辛苦的──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的……",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "脫離危機的過程",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確很輕鬆。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為有騎士先生",
        "unit_id": 100213,
        "voice": "vo_adv_5096000_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "強化日和，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我和怜",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要對周圍保持警戒",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就行了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對呀對呀！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n從那之後",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就一口氣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "轟轟烈烈地",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "扭轉戰況了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "狀態萬全時的我們可不會輸。",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是說呀！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n只要結局好",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就一切都好……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果他不在場，情況就危險了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "別認為事情總是會像那樣順利。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "懂了嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣嗎……",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會小心的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為今天",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有騎士先生同行，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我總覺得很開心……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "意思是說妳當時開心過頭了是吧。",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就沒辦法了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不會再多說什麼了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好耶～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜妳也……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我也",
        "unit_id": 100213,
        "voice": "vo_adv_5096000_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒發現陷阱，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們當時似乎都一樣",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "開心過頭了呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生也是嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來大家都是這樣……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很開心吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能夠再次像這樣冒險真好。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n下次",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會在接到看起來不會遇到陷阱的委託時邀請你的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！？",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳果然在生氣～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵呵。",
        "unit_id": 100213,
        "voice": "vo_adv_5096000_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n別捉弄日和了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就到此為止吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們向管理協會報告完畢後，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n去吃午餐吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是的～！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜好壞心眼～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你也說說她啊──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與前往管理協會報告委託結果的日和一行人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在鬧區愉快地用了餐──"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝招待！",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_022"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "下次請再度光臨。",
        "unit_id": 1,
        "voice": "vo_adv_5096000_023"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "對了，客人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請收下這張抽獎券。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n只要交給那位男性，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "就可以抽獎一次。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──要不要抽獎呢～？",
        "unit_id": 1011,
        "voice": "vo_adv_5096000_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只要有抽獎券，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "任何人都有機會！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只要轉動這台抽獎機就可以了～！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100311,
        "voice": "vo_adv_5096000_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們拿去用了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抽獎內容是什麼呢？",
        "unit_id": 100111,
        "voice": "vo_adv_5096000_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "抽中頭獎",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會送盤子之類的嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "之前剛好打破了",
