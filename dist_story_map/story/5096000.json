        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
        "words": "\n請在搭乘開往島嶼的船班之前，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性工作人員",
