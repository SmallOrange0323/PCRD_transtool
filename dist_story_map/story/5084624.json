[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉……",
        "unit_id": 102511,
        "voice": "vo_adv_5084624_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那一位竟然會醒不過來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n究竟是發生了什麼事呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總覺得好奇怪。",
        "unit_id": 102511,
        "voice": "vo_adv_5084624_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n光是那一位不在，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我竟然就會感到這麼寂寞。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "他就只是一直在睡覺罷了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就只是那樣……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……之前也有過這種事呢。",
        "unit_id": 102511,
        "voice": "vo_adv_5084624_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n在瑪爾傑海岸失去意識的我身邊，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你也安穩地沉睡著。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "結果",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……接、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "接吻跟人工呼吸都沒做到就是了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請像那個時候一樣，",
        "unit_id": 102511,
        "voice": "vo_adv_5084624_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "快點醒過來喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一直睡覺對身體是有害的喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐和孩子們也",
        "unit_id": 102511,
        "voice": "vo_adv_5084624_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "都很擔心",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拜託你了喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會相信你，並等著你的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "直到你甦醒之前，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會一直等著。",
        "unit_id": 102511
    }
]