[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812,
        "voice": "vo_adv_2006011_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n狀況好像突然起了很大的變化，有點跟不太上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們該怎麼做才好呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就算繼續待在這裡也幫不上忙，",
        "unit_id": 105812,
        "voice": "vo_adv_2006011_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要不要去幫忙她們驅趕魔物？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "根據魔物的種類不同，",
        "unit_id": 105812,
        "voice": "vo_adv_2006011_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有些可以打倒之後拿來做料理呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟這裡是受災地，",
        "unit_id": 105812,
        "voice": "vo_adv_2006011_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想食材還是多準備一點比較好嘛♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐總是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在想著這些呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也過去吧，",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難得都來到這裡了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就一起為苦於重建作業的牧場人們盡一份心力吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n{player}！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你平安無事啊～、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這一位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也是您認識的人嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯。",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n感覺好像很頻繁地",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在各個地方遇到你呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦，奇怪？",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳是精靈族對吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個，我們有在什麼地方見過面嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有。",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下並沒有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和這附近的精靈族有所往來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是住在北方部族的",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n長老之女……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "名叫可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "噫，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "長老之女不是很偉大嗎。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種時候我該怎麼做來著……？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "能、",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "能與住在遠地的同胞相遇，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在下倍感光榮～？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不需要這麼正式的和在下打招呼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您真是一位很有禮貌的人呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀～，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為我父母對這方面要求很嚴嘛～……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但出社會這麼久，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n對這方面的禮俗就漸漸忘記了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我在【墨丘利財團】工作，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n名字叫做優花梨。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "請多多指教，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可可蘿。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下平常在城鎮中很少有機會見到其他精靈族，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以有點不安……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果您願意和在下好好相處的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會非常開心的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣啊。",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，好好相處吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果是可可蘿這樣的小孩子的話……",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n應該不至於露出什麼醜態吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼？",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒有，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我在自言自語……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但先別在這邊聊天了，趕快出發吧，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n還有很多事情要忙呢～♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯嗯。",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n在忙碌的時候就得打起精神來才行喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們【墨丘利財團】……",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n今天也要為了拯救深陷世界惡意的人們，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大展身手助大家一臂之力喵～♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒錯，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們要一起做到最完美。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n目擊到魔物的地方是在哪裡呢？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要來計算最短路徑。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太感謝了～",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想想，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是在那座山那邊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好像是受到昨天大爆炸的影響，土石崩塌，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n地底的魔物巢穴因此露了出來的樣子？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "休眠中的魔物們似乎就因此開始作亂了呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而其中一群，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "正朝著牧場逼近。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其他的魔物也受到刺激，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n脾氣變得很暴躁呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～。",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要是處理得不好，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n魔物們又會大肆作亂呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "該怎麼辦呢喵～，",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n雖然想斬草必先除根是最為基本的。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但根據魔物的種類與數量，",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n光靠我們可能無法與之抗衡就是了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦呵呵呵呵！",
        "unit_id": 1,
        "voice": "vo_adv_2006011_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請放心吧，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就由我來解決這件事情吧♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呃……",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_036"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n妳已經回來了啊，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "秋乃。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳還是一如既往，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不會錯過自己能表現的機會呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵～♪",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只要有這飛空艇在，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n無論要去哪裡，一下就會到囉！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但好像太過操勞，",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n動力裝置出了點問題就是了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那是借來的對吧，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_039"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳可不要弄壞了哦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就我們的經營狀況看來，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n可沒辦法賠償哦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "光是要讓飛空艇飛一趟，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_040"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所需的花費就能蓋一棟房子了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請放心！",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_041"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因為這既是飛行測試，而且又是我家的私有物，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以不會收費的哦～？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只是真的弄壞的話，",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還是免不了被父親大人狠狠地教訓一頓就是了♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總之，",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我聽到你們剛才說的話了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這艘飛空艇上也裝有很多魔法兵器，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就用這些來把魔物們的巢穴給一掃而空吧♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，因為我沒有魔法的知識，只有我一個人是沒辦法用的。",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_044"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可以請優花梨一起搭上飛空艇來進行操作嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬跟珠希，",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_045"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請負責掃蕩我們打漏的魔物！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不要指揮大家啦。",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_046"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這的確是一個不壞的作戰。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只是那些魔物們",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_047"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也不是說真的做了什麼壞事。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n應該不需要把牠們全數殲滅呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只要用煙霧把牠們燻出來，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_048"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n然後趕跑就好了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_049"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳人還真好呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是效率的問題。",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_050"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "根據魔物的種類不同，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_051"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n牠們各自有著獨自的聯絡管道……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要是有同族被殺害，那股怨恨會一直存在著。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就算現在沒事，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_052"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不久的將來又會為了報復而來，使得牧場受害。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但如果只是趕跑牠們的話，",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_053"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n會讓牠們覺得「這邊很危險」便遠離這邊，事情就解決了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我平常不是都有叮嚀妳，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "做事之前要先想好後果吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵。",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_054"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算我沒想，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n美冬也會替我想嘛。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因為我們可是一個",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_055"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n會彼此幫忙彼此的超棒公會呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦呵呵呵呵♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只有妳單方面的給我們找麻煩啦。",
        "unit_id": 104811,
        "voice": "vo_adv_2006011_056"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……算了，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我們趕快開始行動吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "ＯＫ。",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_057"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n秋乃～，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可以請妳把繩梯放下來嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這麼高的話，",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_058"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n也沒辦法用跳的跳上去嘛！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 103211,
        "voice": "vo_adv_2006011_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說得也是呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真對不起呢，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我每次都忘記這種最重要的事情！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒關係。",
        "unit_id": 103411,
        "voice": "vo_adv_2006011_060"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不管是誰，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n都會有不小心失誤的時候嘛♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好了。",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那這樣我們就在地面上",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n對付那些被燻出來的魔物們喵～。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你們就跟我們一起走吧喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓的嗅覺意外地很發達哦喵，",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_063"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以可以很正確地找到魔物的位置喵～♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一直做事務類的工作也讓我累積了不少壓力，",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_064"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "偶爾也要到郊外好好發洩一下喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是這股氣勢喵！",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一起加油吧喵～，{player}！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n耶耶，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哦～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不對不對，",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_066"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你沒聽美冬是怎麼說的嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不可以解決牠們喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要讓牠們害怕趕跑就好了喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺你特別有幹勁呢喵，{player}。",
        "unit_id": 104611,
        "voice": "vo_adv_2006011_067"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但小心別做了白工，還讓自己受傷哦喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……總覺得你不適合可怕的表情喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 105812,
        "voice": "vo_adv_2006011_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也要打起精神上囉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n至少不能扯【墨丘利財團】",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那些人的後腿♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過到頭來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還是一如往常，情況變得相當混亂呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2006011_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該說是已經習慣了嗎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下總覺得有些樂在其中……♪",
        "unit_id": 105913
    }
]