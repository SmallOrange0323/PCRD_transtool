    {
        "type": "dialogue",
        "name": "旁白",
        "words": "大江戶町的健康檢查順利吸引人潮後過了幾天……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪和{player}每天都十分忙碌。"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "早安，{player}，",
        "unit_id": 117611,
        "voice": "vo_adv_1176004_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n今天也拿出活力與美麗！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "幫忙健康檢查……",
        "unit_id": 117611
