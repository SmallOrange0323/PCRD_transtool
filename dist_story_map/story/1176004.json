    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯？",
        "unit_id": 117611,
        "voice": "vo_adv_1176004_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你怎麼了？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n用這麼炙熱的眼神看著我。",
        "unit_id": 117611
