    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難不成，",
        "unit_id": 117611,
        "voice": "vo_adv_1176004_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你發燒了？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n先來這邊坐下，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "快過來。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來，",
