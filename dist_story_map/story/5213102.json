    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生，",
        "unit_id": 133111,
        "voice": "vo_adv_5213102_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "請您小心。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那種果實",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "如果不小心用手直接觸碰，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n強烈的酸性",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "會把皮膚溶蝕掉。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n在吉歐‧尼布爾黑爾那邊，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那股氣味",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "似乎很受殭屍們喜愛。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不需要過度恐懼喔。",
        "unit_id": 133111,
        "voice": "vo_adv_5213102_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "只要先把前置處理做好，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n就能用清晰銳利的酸味，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "以及水潤清新的香氣，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "將料理襯托得更出色，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n同時也能讓心情與思考，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "變得清爽明朗……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "應該會是這樣。",
        "unit_id": 133111
    }
]