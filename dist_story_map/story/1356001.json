[
    {
        "type": "background",
        "background": "501652"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不行……",
        "unit_id": 135614,
        "voice": "vo_adv_1356001_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n無論怎麼掙扎，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "還是無法阻止世界重置……！",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "快停下……",
        "unit_id": 135614,
        "voice": "vo_adv_1356001_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "到底要持續戰鬥到何時，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我們才能抵達未來……！",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "客人，",
        "unit_id": 1,
        "voice": "vo_adv_1356001_002"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "客人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n妳在睡夢中一直呻吟，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "沒事吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n妳看，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "就快到蘭德索爾囉。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……！",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這裡是……？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "是正在前往蘭德索爾的馬車上哦。",
        "unit_id": 1,
        "voice": "vo_adv_1356001_004"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "看來妳剛才做了個很可怕的夢呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n如果沒在外旅行過，的確會覺得馬車晃來晃去很難受，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "也許妳累了吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n就快到了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "等下車之後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "妳再好好休息吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_005"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝你。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……又是、",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那場夢……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不斷反覆的世界重置，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "已經結束。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我們──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "已經能朝著各自的未來前進。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n明明大家都靠著自己的力量開始向前邁進了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "明明如此……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我卻還在",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "未來的面前，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n裹足不前嗎……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真是、",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "沒出息呢……",
        "unit_id": 135612
    },
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}完成委託的工作後，\n回到公會小屋時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看到志那都在門前來回踱步的身影。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "看來是沒人在呢……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "要不要確認看看？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不過，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "若開門的是陌生人……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我該說什麼才好。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我有自信無法流利地",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "說出簡單扼要的自我介紹。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "萬一",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "弄錯地址……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那可不只是",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "丟人現眼而已。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我該先替自己挖好墳再拜訪嗎？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "或者",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "直接放棄，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "打道回府呢。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不對，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這時要是突然掉頭離開，反而更可疑……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怎麼會",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這麼的沒出息呢，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "哇啊！？",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_013"
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_014"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "非常棒。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我和厄莉絲及埃拉",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也能一起悠哉地交談……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是一場",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "極具意義的旅行。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "而且，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_015"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這邊的世界裡",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "名為東國的城鎮，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "對我而言也很新鮮。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n能造訪與熟悉城鎮相仿的",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不同地方，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n是一次很難得的",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "體驗。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那時，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_016"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怜跟你為何會感到不可思議，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n現在，我也能明白箇中原由了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "進入正題。",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我買了伴手禮來。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "若你願意收下，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我會很高興的。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_018"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我不知道選什麼才好，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "所以店員為我推薦了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n聽說是必買伴手禮。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "可是，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我個人也",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "極力推薦。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "聽說這些是工匠精心製作的物品，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_019"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "作為伴手禮",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "非常有價值和意義……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n你也能用於每天的修行上。",
        "unit_id": 135612
    },
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_020"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我想在回去之前，稍微看看蘭德索爾。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "自從上次來訪之後，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這裡應該有不少改變了吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "即使沒有改變，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那時我也沒能慢慢欣賞……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在這裡，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_021"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我想學習",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "今後向未來前行所需──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n讓我們的世界",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "變得更美好的方法，並帶回去。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不需要多宏大，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就算是微小的線索也好。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "所謂未來，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_022"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是從這種小事情一點一點累積，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這一點我們也已經學會了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "所以，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你不介意的話……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n願意稍微陪我",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "逛逛城鎮嗎？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_023"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝你。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真是的，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我總是受到你的幫助……",
        "unit_id": 135612
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "大街上的人潮",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_024"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "和熱鬧的聲音……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然以前也曾感受過，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但這裡果然是個充滿活力的地方呢。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "而且，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "往來的人群也慢慢地產生了變化。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "狗頭人奶奶",
        "words": "哎呀，",
        "unit_id": 9111,
        "voice": "vo_adv_1356001_025"
    },
    {
        "type": "dialogue",
        "name": "狗頭人奶奶",
        "words": "這張掛毯真漂亮。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "狗頭人奶奶",
        "words": "\n我要不要當作伴手禮",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "狗頭人奶奶",
        "words": "買回去呢？",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "攤販商人",
        "words": "請務必買下！",
        "unit_id": 1411,
        "voice": "vo_adv_1356001_026"
    },
    {
        "type": "dialogue",
        "name": "攤販商人",
        "words": "\n要是我家的商品也能在背面世界大受歡迎，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "攤販商人",
        "words": "我會非常高興喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我從厄莉絲那裡聽說了。",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_027"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原來如此，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "他們──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "能夠接受文化及種族的差異，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_028"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n彼此攜手合作",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這也是",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "跨越輪迴後，所能得到的其中一個未來……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "竟然能柔軟地應對如此劇烈的變化，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_029"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n蘭德索爾人民的堅強",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真令我驚訝。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不對，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這點我的世界也是一樣吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "即使得知自己的處境，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_030"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "仍沒有陷入絕望，\n勇敢面對，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "願意",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "跟隨著我。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "大家的內心遠比我想像地",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "來得堅強吧……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "然而，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_031"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我不能只是欽佩大家……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n世界取回未來的現在，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我必須要身先士卒，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n引導他們。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "得更全力以赴才行。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不需要擔心我。",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_032"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我已經失去管理者的立場，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n而且世界的問題",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也都解決了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_033"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你真敏銳呢。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不對，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是我的表情一目瞭然了嗎？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "無論如何……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_034"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "繼續隱瞞也沒用是嗎。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不介意的話，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "稍微聽我說說吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然我想這話題一點都不有趣──",
        "unit_id": 135612
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "明明多虧你們的協助，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_035"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "一切都已經劃下句點。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "明明如此──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我現在還是",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "偶爾會夢到。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n無法阻止的重置光景。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那時的絕望",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_036"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不斷歷歷在目地復甦……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然醒來後會發現只是一場夢，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n但心裡仍會亂成一團，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "無法恢復平靜。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "肯定是我……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_037"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "還沒完全接受，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我們已經從逃離那副處境的現實吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就算我獨自一人裹足不前，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_038"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "世界也早已開始前進。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "若無法調整心態，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我只會漸漸追不上大家。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n若真能就此作罷，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我還能釋懷自己的職責已經告一段落，但……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我今後，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_039"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "仍得引導仰慕我的眾多人民才行。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n每次夢醒，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我都會不禁思考。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "自己是否有那個、",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "資格……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_040"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "抱歉，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "{player}。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n對你來說，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這話題就算聽了，也不曉得該如何回答吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你可以忘了它。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "咦？",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_041"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "現在？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "到底要做什──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "慢著。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n等等我，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "萬一走散就傷腦筋了……！",
        "unit_id": 135612
    },
    {
        "type": "background",
        "background": "502600"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}帶著志那都前往的地方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n是位在森林中，建於某座湖上的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "小棧橋。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這裡是……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_042"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "釣場？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原來如此……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在對面的店，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也能借到釣魚用具吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我懂了。",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_043"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你打算邀請我釣魚吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "有時候要做些自己喜歡的事情，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "散散心。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你是要這麼對我說吧？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……原來如此，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_044"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你說得對。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n最近，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我都沒有度過可謂散心的時光。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "看來我",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不擅長像這樣休息。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "咦？",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_045"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是對面的店家有賣吧……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "莫非，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你是從某人那裡聽來的嗎？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那個，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "感到很煩惱時的事……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原、",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_046"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原來是這樣啊……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然我不像埃拉那樣，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "平時就會喝麥酒。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不過既然如此，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我就享用了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝你。",
        "unit_id": 135612
    },
    {
        "type": "still",
        "still": "135600101"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……呵呵。",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_047"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真是寧靜啊。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n釣魚時，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "必須連內心都要保持平靜，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "甚至要與自然同化。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n想要有收穫的想法、焦慮",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "及煩心事都要拋諸一旁。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "而且，麥酒也……",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_048"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不錯喝。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "以我的個性，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_049"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在熱鬧的場合反而會感到緊張，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n所以",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不太敢踏進店內……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這樣啊，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原來也能在這種地方享受呢。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝你邀請我，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_050"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "{player}。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n只有我自己",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "肯定想不到",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "能用這種方式度過……",
        "unit_id": 135611
    },
    {
        "type": "still",
        "still": "135600102"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "呵呵。",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_051"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "心情稍微變輕鬆了點。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n你說得沒錯，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "麥酒好像對煩惱很有效。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n感覺輕飄飄的……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然魚完全不肯上鉤。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "抱歉，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_052"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你不必擔心。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我沒事。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不會做出造成你困擾的事……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_053"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_054"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "仔細想想……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n你就是擔心我，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "才會帶我到這裡吧。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "一邊向你吐露內心的脆弱……",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_055"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "一邊說",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我沒事，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也毫無說服力啊。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n直到剛才，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我大概並非沒事吧。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "可是，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_056"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "現在。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我感覺",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "稍微卸下了肩頭的重擔。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這毫無疑問是",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你的功勞喔。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我身為世界的管理者，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_057"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "背負著莫大的責任。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n因為我有與其相符的力量，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "才得以發揮。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但是，面對重置，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_058"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "得知世界的真相……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我經歷了",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "很長一段時間的戰鬥。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n在這",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "漫長的戰鬥中，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我也無法阻止自己內心逐漸消磨。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "無論是得知的真相，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_059"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "還是懷抱的苦惱，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我都不能向大家吐露。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n只能故作冷靜，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "有時候裝作無情。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n只能一個人",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "孤軍奮戰。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_060"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這樣啊……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "無法依賴他人的孤獨。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n仔細想想，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這才是",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "最令人難受的。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n到頭來──",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "連那樣的脆弱，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我都無法克服。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "很沒出息吧？",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_061"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……這樣啊。",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_062"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那麼，我……",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "託你的福，",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "變得堅強了吧。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝你，",
        "unit_id": 135611,
        "voice": "vo_adv_1356001_063"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "願意聽我說話。",
        "unit_id": 135611
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n感覺心情稍微舒暢了點……",
        "unit_id": 135611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正當{player}準備出門工作時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n志那都來打招呼了。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "早安，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_064"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "{player}。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我想說",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在回去之前……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "再來跟你問候一聲。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "昨晚，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_065"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我久違地好好睡上一覺了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "讓我再一次",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "向你道謝吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_066"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好啊，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "到時，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "請你再陪陪我吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我也要",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "聽聽你的心事才行。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "即使居住的世界不同，",
        "unit_id": 135612,
        "voice": "vo_adv_1356001_067"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我們仍然是朋友。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n近期，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我希望你也能來我們的世界看看。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……大家",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "應該都很想見見你。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以比昨天更開朗的聲音向{player}告別，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n志那都回到了自己的世界。"
    }
