[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哎呀，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_000"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是感激不盡！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "得救了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n這一次，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "連我都以為我要死了啊！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如此大恩擇日必報！",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_001"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "然而，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如今仍有件十萬火急之事得處理，在這先失禮了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等一下等一下。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你要去哪啦……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你的傷勢比看起來的嚴重多了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要先處理好才行。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在照顧我的【拉比林斯】所在的據點那裡，",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有治療用的設施。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不好意思，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_004"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但我可沒那種餘裕了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n似似花大人被人擄走了，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n不論眼前有什麼阻礙，我都得去救出那位大人才行！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這是我",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_005"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "身為那位大人的騎士的責任！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不！這已經是命運了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以我才說",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不給你治療不行啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你這樣子，還沒走個三步就倒在路旁啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真是的！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "給我安份一點！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……？",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_007"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "唔？",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_008"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n到處都有著沒見過的面孔呢，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你們是？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "等等、以禮節來說，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_009"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "應由我先報上名號！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n鄙人乃真軌！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "是侍奉偉大的『七冠』之一的似似花大人，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_010"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "高潔又認真的騎士……☆",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還、",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是位開朗至極的人呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n某種程度，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎還能看到點貪吃佩可小姐的影子呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_2007013_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我看起來有這麼胡鬧嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "各位，",
        "unit_id": 103111,
        "voice": "vo_adv_2007013_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請稍微安靜一下。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n啊啊，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "已經觀察到爆炸了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那邊那位……",
        "unit_id": 103111,
        "voice": "vo_adv_2007013_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我記得是叫",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "矛依未吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如她所言，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n研究所所在的地下遺跡，已經毀滅了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若我們還留在那，",
        "unit_id": 103111,
        "voice": "vo_adv_2007013_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在可真是危險了呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "能夠像這樣安全的逃離，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是太好了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "去的時機也太不巧了吧～",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會去那裡啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_2007013_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在各種因緣際會之下……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們決定",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要讓{player}一行人\n與似似花會面。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為我們跟似似花有過交流，",
        "unit_id": 103111,
        "voice": "vo_adv_2007013_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以就由我們代為引薦。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嗯！",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_019"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n一如以往，你們這一群人還是怪有趣的呢，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不錯不錯☆",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這人也好不到哪去吶。",
        "unit_id": 104412,
        "voice": "vo_adv_2007013_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但到底發生了什麼事？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似似花竟然會被綁走……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那傢伙，可是個超越常理的存在吶。",
        "unit_id": 104412,
        "voice": "vo_adv_2007013_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n可不覺得她是個這麼輕易就能誘拐走的貨色啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "妳說的沒錯。",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_022"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n似似花大人不但待在那防禦如同銅獎鐵壁般的研究所內，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n她本人更是掌握著無與倫比的力量。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "當然，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_023"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "還有我在一旁護衛著。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "然而，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "對方投入了數百、甚至上千人的軍隊……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n實在是難以抵抗。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人有變身的能力，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_024"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n或許她改變姿態，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "成功逃脫了敵人的追趕也說不定。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但，當時卻被一發攻擊魔法的冷箭給擊中了，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_025"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n也因此受了重傷……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不禁令人擔憂大人她的安危。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊啊！",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_026"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但是似似花大人！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n在那種局面下，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "仍舊憂心著我的傷勢！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不會變身，又沒辦法擺脫追跡逃離的我，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_027"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n在大人身邊也只是礙手礙腳……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "「趁我去吸引敵軍注意時，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_028"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "趕緊滾到哪邊去……」",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "當時似似花大人她，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如此冷淡地說道。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "然而！",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_029"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n這就是，似似花大人所流露的那難以捉摸的溫柔！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "大人她即使要犧牲自己，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_030"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "也要讓我能夠繼續活下去！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n除此之外，我沒辦法想到更好的解釋了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "而在那之後，我便躲到了開始暴走的魔力爐旁，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_031"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n即使身體一邊被火焰燃燒，我仍發自內心作誓！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "必定要將那位至善慈藹、惹人愛憐的似似花大人給救出！",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_032"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n就算以此條小命為代價也無妨！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "因此，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_033"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n我已經沒有什麼多餘的時間能在這浪費了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "對於救了這條小命之恩深深感謝，有朝一日必定報答。",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_034"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n但",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "現在，仍得先走一步――失禮了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "綁架了似似花大人的，",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_035"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "明顯是王宮的軍隊。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n總而言之就先殺進王宮內，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "然後大鬧一波後將大人奪回！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊，這簡直就像是，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "拯救那被囚禁的公主的騎士物語……☆",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "腦子冷靜一點。",
        "unit_id": 107311,
        "voice": "vo_adv_2007013_036"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n這麼輕率就採取行動，不過也只是白白去送死而已唷。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "在前幾天……因為我用",
        "unit_id": 107311,
        "voice": "vo_adv_2007013_037"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "空間跳躍闖入的關係，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n王宮警備的等級現在更上升了不少。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "若現在你闖進去，",
        "unit_id": 107311,
        "voice": "vo_adv_2007013_038"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不出幾秒就會被衛兵給逮住了呢。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n最糟的情形，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "你當場就被殺了也說不定。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不會要你現在得做出理智的判斷，",
        "unit_id": 107311,
        "voice": "vo_adv_2007013_039"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "但也至少平復一下心情再說。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嗯嗯……",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_040"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n在你身上能感受到",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不可思議的氣息呢，究竟是？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n總覺得，散發出了和似似花大人一樣的氛圍。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他叫拉基拉基。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "用空間跳躍把你們全員給救出的就是這傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n要感激人家一下唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基的空間跳躍，在使用上有人數的限制。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以現在這裡只有我們兩個而已。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大吾、克莉絲提娜，",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有拉比林斯達……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n「晶」，他們都在安全的地方。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真軌，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這些名字你有印象嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嗯？",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_044"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": " ",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不好意思，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n雖然我很擅長記人的長相和名字啦。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但是老實說，我連妳是誰都不知道呢……",
        "unit_id": 191011,
        "voice": "vo_adv_2007013_045"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "迷人的小姐啊。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊……",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你也",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把以前的事情全都忘了啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "若是那個，",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總是做好周全準備的策士似似花的話……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或許早就預料到世界的再構築，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "並且也做好因應的對策了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n本來還有些期待，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說不定那傢伙還記得些什麼的呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但本人不在這，",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也無法確認。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可惡，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管要做什麼都被搶先了一步的感覺。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎，算了吧。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管怎樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在這種地方說話也不是辦法。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這附近有【拉比林斯】的其中一個據點，",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總之先到那裡好好休息一下吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真軌，你也過來。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……{player}你們呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要怎麼辦？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔～呣。",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下一行人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在也沒頭沒尾的……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且還有許多令人在意的地方，",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若不嫌麻煩，還請讓我們隨之同行。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟還有",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很多事情想問你們呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下也是這麼想。",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總是不會否定在下的意見呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "偶爾，",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也可以提出自身的主張和要求呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論主人您的願望為何，都會伴您走到最後一刻的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您說的是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天真的很累人呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好想鑽進那溫暖的棉被中，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好給它睡個一覺呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要先移動到個安全的場所後再休憩一番，",
        "unit_id": 105911,
        "voice": "vo_adv_2007013_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n順便問問",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "事情原委……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您意下如何呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "矛依未小姐？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "OK。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_058"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這邊也早想跟你們",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n找個機會坐下好好聊聊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，跟我來。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "往這啦，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "往這♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿。",
        "unit_id": 106112,
        "voice": "vo_adv_2007013_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n大家一塊來思考，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n該怎麼樣把這荒唐該死的膠著狀況給打破吧♪",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200099901"
    }
]