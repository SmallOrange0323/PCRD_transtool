    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我希望牠可以吃得更開心，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是不是要稍微做點變化呢～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此～",
        "unit_id": 117711,
        "voice": "vo_adv_6076104_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "狗狗",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "最喜歡骨頭了～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真有你的！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是個好主意～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我馬上來",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "試做看看！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n當骨骨開口笑完成後，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "再請你來試吃看看～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "開口笑的甜味加上",
        "unit_id": 117711,
        "voice": "vo_adv_6076104_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "肉乾的鹹味，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n究竟會變成什麼樣的味道，真難以想像～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感覺是個有趣的點子～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果你還有想到其他的點子，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "儘管跟我說喔～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這倒也是！",
        "unit_id": 117711,
        "voice": "vo_adv_6076104_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為",
        "unit_id": 117711
