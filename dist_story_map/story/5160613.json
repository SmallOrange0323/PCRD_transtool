[
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天，梅杜莎、莫妮卡、咲戀被涅妃‧涅羅傳喚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她們前往了鬼岩城塞。"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "莫妮卡閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_5160613_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "咲戀閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n有勞各位來這裡了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對了，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "順帶一提，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "梅杜莎，汝也是啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不要把人叫過來，",
        "unit_id": 133612,
        "voice": "vo_adv_5160613_001"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "卻當成順便的對待啦。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "並不是那麼閒的啊。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "要是是無聊的原因的話，我不會放過妳喔！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請別在意，",
        "unit_id": 133212,
        "voice": "vo_adv_5160613_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "涅妃‧涅羅閣下。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n因為我們只是閒過頭了，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而在隨意逛著祭典而已。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對吧，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "梅杜莎？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那、",
        "unit_id": 133612,
        "voice": "vo_adv_5160613_003"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那種事情不用說出來也沒關係吧！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "因為涅妃‧涅羅的錯，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "讓我變得要暫時住在蘭德索爾了，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我才沒有想著",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "要在那之前，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "把「這邊」刻劃進腦子裡之類的事情喔！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5160613_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "明明是蜿蜒之蛇的化身，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是個耿直的女孩。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家要做的事情非常簡單明瞭。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家想依照蘭德索爾歡慶新年的慣例，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n賞賜被稱「壓歲錢」的寶物",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "給恁們。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦，",
        "unit_id": 133512,
        "voice": "vo_adv_5160613_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "壓、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "壓歲錢！？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然妳的心意讓我很高興，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是我們已經",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不是能拿壓歲錢的年齡……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是、",
        "unit_id": 133212,
        "voice": "vo_adv_5160613_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然我看起來是這樣，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是我姑且",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是大人了……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "咦──",
        "unit_id": 133612,
        "voice": "vo_adv_5160613_007"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那不是很好嗎，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "妳們就收下吧。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正如蛇之么女所言。",
        "unit_id": 129711,
        "voice": "vo_adv_5160613_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家很清楚恁們",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是有身分的人。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但是此次，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是兼具了替華音她闖的禍的賠禮。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如果能趁此機會報恩的話，",
        "unit_id": 129711,
        "voice": "vo_adv_5160613_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家也能保住面子。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n而且自古以來，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就有著客氣過頭反而失禮，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "謙讓也要看情況的這種金句良言。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n莫妮卡閣下、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "咲戀閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "誠摯地希望",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁們能笑納。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但、",
        "unit_id": 133512,
        "voice": "vo_adv_5160613_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是說啊……",
        "unit_id": 133212,
        "voice": "vo_adv_5160613_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我很感謝妳的好意……",
        "unit_id": 133512,
        "voice": "vo_adv_5160613_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是從他國的重要人士那裡收壓歲錢，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣好嗎。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我這次",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "姑且是作為純的代理來的。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "收賄",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不會發展成外交問題嗎？　",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "直接從一國的公主",
        "unit_id": 133212,
        "voice": "vo_adv_5160613_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那邊收下獎勵……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "根據情況",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "或許能換新武器，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也可能可以替咖啡廳進新商品啊……！？　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不對不對不對。",
        "unit_id": 133212,
        "voice": "vo_adv_5160613_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不可以期待過頭。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就算涅妃‧涅羅閣下",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再怎麼慷慨，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那也只是壓歲錢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "光是接下來一段時間內的",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "點心能變豪華，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就已經很充分了吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "妳們在煩惱什麼啊？",
        "unit_id": 133612,
        "voice": "vo_adv_5160613_015"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "妳們不要的話我就全部收下了喔。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "停手，梅杜莎啊。",
        "unit_id": 129711,
        "voice": "vo_adv_5160613_016"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不要貪心。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝的那一份在這裡。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n可千萬別浪費了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "哼～",
        "unit_id": 133612,
        "voice": "vo_adv_5160613_017"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "還挺漂亮的呢。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "好吧，",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我就忍耐只拿一個吧。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那、",
        "unit_id": 133212,
        "voice": "vo_adv_5160613_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個啊……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "涅、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "涅妃‧涅羅閣下？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "金色的球體是……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正如奴家所說的──",
        "unit_id": 129711,
        "voice": "vo_adv_5160613_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那是壓歲錢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這是把從吉歐‧格黑納地下",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n挖掘出來的礦石",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "鎔鑄壓型，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
