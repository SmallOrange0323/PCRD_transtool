        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸欸欸，美咲！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要不要去哪裡玩呀？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "現在不是玩樂的時候，鈴奈！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n妳給",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我來看這個！這個！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼什麼？\n公佈欄有什麼嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n啊，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有新公告耶。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸……？\n「廢校通知。",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "月光學院將在一年後廢校」？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是什麼鬼，好笑～",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n真的有廢校這種事情喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？『月光學院』",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該不會…………",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是這裡",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "！\n是我們的學校啦！！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸！？\n我們學校會消失嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那、那會很困擾耶……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太可惡了！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊……要廢校呀……",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶吶，",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們努力一下的話，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不知道能不能成功阻止廢校喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼可能做得到！\n我們",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只是學生，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n所以妳說能做些什麼呢？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……？\n",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "比如說社團之類的？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在社團表現超活躍，",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓我們學校變得超有名，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n說不定就不會廢校了呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……嗯，這個點子是還可以。",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，鈴奈有參加什麼社團嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊……\n人家",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒有參加社團。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n美咲",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也是，沒參加任何社團。",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊～……\n如果是模特兒的話，",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家還算是小有名氣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個和學校無關吧！",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～～",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那增加想入學的人就好了不是嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n學生變多的話，就不能廢校了吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "或許有可能，\n不過",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要如何增加學生呢？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然是那個呀",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "！\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "只要宣傳說",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n來這間學校頭腦就會變聰明～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……鈴奈。\n妳來說說看，九九乘法表七的部分？",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個只是小菜一碟♪",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n７×１是……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？多少來著的？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "臨時叫妳說就說不出來吧！\n由鈴奈來宣傳",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "「來這間學校就會變聰明」",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就沒什麼說服力！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃……\n",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那美咲呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n成績和人家也差不多吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就不用了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為我身為一位淑女，記住大人成熟的樣子才比較重要！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "淑女……？大人……？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，大人的美咲覺得",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n要怎麼做才能阻止廢校呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是大人的話，這種小事應該很清楚吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我當然知道！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這是肯定的吧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個……就是……",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對、對了！就是錢！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n一定是錢不夠才要廢校！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是嗎？\n",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那把人家的零用錢給學校就可以解決嗎！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "憑我們那麼點零用錢，\n怎麼可能經營得起學校啦！",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～\n那要怎麼辦才好呢？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要說該怎麼做才好呢……",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎、怎麼辦……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "廢校的話，我們會變怎樣呢？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "大概，會被編列到別家學校吧？",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_035"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說不定我們",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n會在不同的學校……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～！？\n",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那樣很討厭耶！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家想和美咲在同一間學校！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這、這也是沒辦法的事！",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_037"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n美咲也不要啊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "美，美咲也……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "…………",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_038"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸，妳們呀，",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "該不會是這所學校的學生？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯？\n是的……",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_041"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過妳是？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "初次見面。我叫伊緒。",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_042"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明天開始我代替",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n休產假的老師來這裡教課唷。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天是來打聲招呼的……\n可是因為迷路，結果已經下課了……",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸……\n",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可以告訴我妳們的名字嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家叫鈴奈。",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_045"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……我是美咲。",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "鈴奈和美咲呀。",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_047"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今後多多指教喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n叫我伊緒就好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我可能……也教不到畢業，",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是我會努力做好老師的工作的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我看也不需要努力了吧？\n",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_049"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為這所學校已經決定要廢校了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿～這樣啊。",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_050"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_051"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？廢校！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我可沒聽說耶！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是嗎？\n可能因為是代課老師，所以沒告訴妳吧？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_052"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼廢校，那可不好呀！",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_053"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我直接去和學院長抗議！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼什麼，感覺超有趣的！",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_054"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也要去～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那麼，我也一起去吧！",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_055"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只有鈴奈實在幫不上什麼忙。",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "學院長！\n廢校是怎麼一回事！？",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_056"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "那、那是……",
        "unit_id": 1511,
        "voice": "vo_adv_3015001_057"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這個就由我來為您說明囉。",
        "unit_id": 190811,
        "voice": "vo_adv_3015001_058"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸……",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_059"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳是？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是【公會管理協會】的職員，叫做花凜。",
        "unit_id": 190811,
        "voice": "vo_adv_3015001_060"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我今天從營運這所月光學院的【公會管理協會】\n前來說明廢校的理由。",
        "unit_id": 190811,
        "voice": "vo_adv_3015001_061"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為什麼我們的學校要消失呢？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_062"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不論是什麼理由，人家覺得很生氣！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對嘛、",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_063"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對嘛！到底是什麼理由？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "學生太少了？沒有錢？還是……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "廢校的理由只有一個。",
        "unit_id": 190811,
        "voice": "vo_adv_3015001_064"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n原因就是這所學院的學生，學力越來越差。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "鈴奈・美咲",
        "words": "……咦？",
        "voice": "vo_adv_3015001_065"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "和其他學校比起來，成績明顯地低落，",
        "unit_id": 190811,
        "voice": "vo_adv_3015001_066"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n而被管理協會視為問題。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們認為如果只有這種程度的話，不如廢校好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚嗚……理、理由是成績的話……",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_067"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我實在無法反駁。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我們的成績是特別差的……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們大概是\n這間學校頭腦最差的吧……？",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_068"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？是嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_069"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那我來教妳們兩個念書！",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_070"
    },
    {
        "type": "dialogue",
        "name": "鈴奈・美咲",
        "words": "蛤？",
        "voice": "vo_adv_3015001_071"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "問題就在成績不好是吧？\n",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_072"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣的話，只要這所學校的學生",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n達到蘭德索爾最好的成績就好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我來讓這兩個人的成績，",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_073"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n達到蘭德索爾第一！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈・美咲",
        "words": "欸～～～～～～！",
        "voice": "vo_adv_3015001_074"
    },
    {
        "type": "dialogue",
        "name": "鈴奈・美咲",
        "words": "？"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要我們在蘭德索爾拿到第一！？",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_075"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n不不",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不，絕對不可能！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我明白了。\n",
        "unit_id": 190811,
        "voice": "vo_adv_3015001_076"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼如果達到這個條件的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就取消廢校這件事情。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了，決定了呢！",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_077"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "月光學院還有一線生機呢！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，等一下馬上開始",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_078"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n課後輔導喔！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明天開始每天早上也要補習喔！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～\n人家不想那麼認真念書～",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_079"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我早上也想過得悠閒一點。\n姐姐說過，睡眠不足對皮膚不好……",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_080"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是為了保護這所學校呀！\n要好",
        "unit_id": 101811,
        "voice": "vo_adv_3015001_081"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好念書才行！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃……\n學校消失的話的確也很討厭……",
        "unit_id": 101611,
        "voice": "vo_adv_3015001_082"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然是沒辦法的事……\n",
        "unit_id": 105011,
        "voice": "vo_adv_3015001_083"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可、可是～～～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是鈴奈和美咲\n就這麼不甘不願地接受伊緒的特別輔導了。"
    }
]