    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我好像有點明白",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
