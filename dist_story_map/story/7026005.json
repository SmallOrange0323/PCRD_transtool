    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦！？",
        "unit_id": 104033,
        "voice": "vo_adv_7026005_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n大哥哥！？",
