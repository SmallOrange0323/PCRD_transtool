        "voice": "vo_adv_7026005_014"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "說了同一句話呢！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大姐姐也",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "喜歡玩偶嗎？",
        "unit_id": 111431
