        "voice": "vo_adv_7026005_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我能不能也成為它們的同伴呢……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說笑的啦。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "即便有在從事BB團的活動，",
        "unit_id": 104033,
        "voice": "vo_adv_7026005_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我到現在依然沒交到朋友。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我明白這是在逃避現實，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但還是……",
        "unit_id": 104033
    },
