    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是一群迷你模型玩偶！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我都不知道這種地方有玩偶專賣店！",
