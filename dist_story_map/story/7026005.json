        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那邊是一群在開茶會的玩偶，",
        "unit_id": 104033,
        "voice": "vo_adv_7026005_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這邊的是在開時裝秀？　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "感覺玩具的世界好像還挺好玩的……",
