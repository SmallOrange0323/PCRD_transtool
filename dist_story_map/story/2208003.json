[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萊拉耶爾一行人來到吉歐‧格黑納，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n已過去數日──"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……（盯）。",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_000"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "嗯？",
        "unit_id": 50611,
        "voice": "vo_adv_2208003_001"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "總覺得一直有人盯著我看……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n原來是來自另一個世界的小姑娘啊。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊，",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_002"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "對不起！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我居然",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這樣冒昧地盯著不認識的人看……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "沒關係啦。",
        "unit_id": 50611,
        "voice": "vo_adv_2208003_003"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "在妳們的世界裡，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n像我這種模樣的人很少見吧？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那倒沒有……",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_004"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "其實我們的世界裡",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也有會走路的貓人。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "他也是很想來的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但他得工作守門……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "哦？",
        "unit_id": 50611,
        "voice": "vo_adv_2208003_005"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "是個什麼樣的人呀？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "帥貓嗎？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "呃……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "不光是臉，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "全身都毛茸茸的？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "那種的不是我的菜耶～",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "哈哈！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……唉。",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_006"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊。",
        "unit_id": 127812,
        "voice": "vo_adv_2208003_007"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n想家啦？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不是啦。",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_008"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n不過……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "吉歐‧尼布爾黑爾",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_009"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "的公主",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "什麼時候才會來呢……？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n萊拉耶爾殿下",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也不能離開帕菲之城",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "太久呀……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "嗯，",
        "unit_id": 127812,
        "voice": "vo_adv_2208003_010"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "是沒錯啦。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "聽說目前還沒有固定的往返路線，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n難免需要多一點時間。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……嗯……",
        "unit_id": 127712,
        "voice": "vo_adv_2208003_011"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "不過……",
        "unit_id": 127812,
        "voice": "vo_adv_2208003_012"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n確實",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "是有點無聊了呢。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──接著，當天晚上……"
    },
    {
        "type": "background",
        "background": "502171"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接到了涅妃‧涅羅的祕密傳喚。"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──我帶他來了。",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_013"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n皇女。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "辛苦了。",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_014"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_015"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n有勞汝",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "深夜走這一遭。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而，",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_016"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "出現了一些先兆。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n需要先私下告訴汝。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "迴避耳目",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_017"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不是為了別的。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此「四世界公主會議」──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在開始之前，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "事態已經有些可疑。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "坦白",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_018"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "告訴汝吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家的妹妹",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "已無消無息數日。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "橫跨世界和世界的通訊魔法，",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "本是無稽之談。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n但那傢伙",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正特別擅長這種伎倆。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……唔，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "叫什麼來著……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──我記得",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_020"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "好像是叫「傳話人」",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "之類的。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是、",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_021"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家再三叮囑要用那個名為「傳話人」的妖術，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n定期",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "匯報消息，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──難道不是去閒晃了嗎？",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_022"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n像以往那樣。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若吉歐‧尼布爾黑爾的世界裡",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_023"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n四處都是幼兒，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n倒有幾分可能，但……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅，",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_024"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "念出這封信。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "字字句句",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "都要清清楚楚且富含情感，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "讓騎士閣下聽清楚。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "「致姐姐。",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_025"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "得到小薇歐莉特啦──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n等我喝個茶再回去哦──」……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這是──",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_026"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "涅婭小姐",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "傳來的……訊息",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "嗎？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "吉歐‧尼布爾黑爾的──",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_027"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "公主的",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "名字……？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恐怕",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_028"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n這「訊息」是在",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "萊拉耶爾公主一行人到來前送抵的……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在那之後，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吾妹就失去了",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一切消息。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼──",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_029"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n有可能是在回來吉歐‧格黑納的路上，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n碰到了",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "什麼意外",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "也說不定。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若遲遲毫無音信，",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_030"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n或許就需如此考慮。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但就目前線索而言，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恐怕只會是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「救人不成",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "反把自己賠上了」。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼──",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_031"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "您打算怎麼做呢？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "萊拉耶爾公主一行人",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_032"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也無法在此久留。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "眼下只能不湊齊「四個世界」，",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_033"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n僅由三世界的公主進行會議了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此決定，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "最快明日便召開會議吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──了解。",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_034"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "愚妹讓汝擔心，",
        "unit_id": 129711,
        "voice": "vo_adv_2208003_035"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在過意不去。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但她是個",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "即便跌倒都不忘拾把沙​的姑娘。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n無論何等形式，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家認為她總有一日仍會回到此地……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "倒不如說──",
        "unit_id": 129612,
        "voice": "vo_adv_2208003_036"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n希望那個叫卡里莎的吵鬧小孩，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n沒給那邊的公主",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "添麻煩……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "501790"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_037"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "回來了嗎？",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_038"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "傳令的。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……是的。",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_039"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……呼……",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_040"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "竟敢在吾面前",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_041"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "嘆氣。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n妳可真夠膽呀？",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "芙蕾雅？",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "這……",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_042"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "讓您看見不像樣的一面……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我深感抱歉。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "唔嗯──",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_043"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "妳臉色不太好呢。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n穿越世界",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "耗費太多力量了嗎？",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n妳可別太逞強了。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……真沒想到您會這麼說。",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_044"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "看來之前獲得的「鳳凰的權能」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n您已經順利消化了。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "呵呵。",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_045"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n當然──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾很快將會",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_046"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "展示出來。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n不光是對妳，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "要讓這個吉歐‧格黑納的所有人都見識見識，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n如何使用真正的「絲線」──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "嘻嘻。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "哈哈哈哈……",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我很期待，",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_047"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "到時候",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_048"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "妳也得幹活。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n別忘了做好準備。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是──",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_049"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_050"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "無所謂",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_051"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我本來就很",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "能幹。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "辛辛苦苦地",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_052"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "回收了鳳凰的羽毛，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n用皇家裝備當作誘餌",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "釣出了一批盜賊。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "而後……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "為了得到公主‧尤絲蒂亞娜等人的「人質」，",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_053"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我前往吉歐‧尼布爾黑爾……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "攻略了「宮殿」。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "然後，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "回程的路上……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……啊，",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_054"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "女士。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n有一件事情要報告。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "說吧。",
        "unit_id": 136013,
        "voice": "vo_adv_2208003_055"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "結束了吉歐‧尼布爾黑爾的工作後，我在回程的路上，",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_056"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n發現了",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "應該是正要前往吉歐‧格黑納的",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n公主‧薇歐莉特，於是──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我暗殺了她。",
        "unit_id": 193711,
        "voice": "vo_adv_2208003_057"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "如果她們與其他世界聯手，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n事情肯定只會變得更加棘手──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "502290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──不久之前。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "背面世界「吉歐‧尼布爾黑爾」的公主"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與她的守護騎士一同出行。"
    },
    {
        "type": "still",
        "still": "220800301"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "──呵呵……",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_058"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "居然在別人身後想著想著自己笑出來。",
        "unit_id": 133012,
        "voice": "vo_adv_2208003_059"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這樣很不禮貌的哦，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "菫。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "對不起，",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_060"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "可是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那位叫涅婭小姐的",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_061"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "黑暗精靈……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是史萊姆姑娘。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n還有",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "她的隨從卡里莎，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "非常有活力的男孩……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "來自名為吉歐‧格黑納的世界",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_062"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "的那兩位。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "都是非常愉快活潑的客人，所以……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呵呵。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "他們作為",
        "unit_id": 133012,
        "voice": "vo_adv_2208003_063"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "使者有些吵鬧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但作為搞笑藝人",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "還是滿合適的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只不過。",
        "unit_id": 133012,
        "voice": "vo_adv_2208003_064"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n可以信任",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "他們到什麼程度呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n居然還打造了連接異世界的「門」。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……真是的。",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_065"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n剎鬼和格蕾斯，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "妳們都太多疑了吧？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n他們看起來",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "像是邪惡的存在嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "看起來也不像什麼善類啊。",
        "unit_id": 133012,
        "voice": "vo_adv_2208003_066"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "而且，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如果要做「門」的話，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n直接做在我們城堡的附近",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不是更好嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "妳說得對……",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_067"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "從巨鯨城出來",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還要穿越",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "遺灰沙漠",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是有點遠了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不過……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……竟然",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_068"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "能從這個黑暗的陰影世界，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "走進",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "有光線照耀的世界……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "真是意外。",
        "unit_id": 133012,
        "voice": "vo_adv_2208003_069"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n膽小的妳",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "居然會被那種憧憬所驅使。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "事情不會那麼順利。",
        "unit_id": 133012,
        "voice": "vo_adv_2208003_070"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這妳也明白的吧？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n菫。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……呵呵。",
        "unit_id": 133111,
        "voice": "vo_adv_2208003_071"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "今天的格蕾斯",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真是愛操心呢。",
