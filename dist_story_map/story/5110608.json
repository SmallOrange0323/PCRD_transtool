[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆與尾狗刀在公會小屋裡到處搜索，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n最後總算找到了跳躍王。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂，",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "教授！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n總算找到你了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "呼，",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你還真是神出鬼沒。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n害我們找得那麼辛苦。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "找我做什麼？",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_002"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n我",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "可不像你們那樣閒來無事喔？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們才沒有閒來無事！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們今天是來找你客訴的。",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我們要客訴。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "哦？",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_005"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "找我客訴？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "真有趣。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "那我就聽你們說吧。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "不過，",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_006"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "如果內容只是些無聊小事……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "你們應該知道下場吧？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "怎麼可能會是無聊小事！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我們所遇到的，是很迫切的問題！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "呃，",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "因為是客訴，也不可能會是什麼有趣的事啦。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們要說的，是關於大吾的事！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_009"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n為什麼他可以那樣",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "到處找人打架啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也不管我們正在執行任務，就衝來找我們打架。",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n可以讓他收斂一點嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "原來如此……",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_011"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "所以，你們就跑來向我抱怨嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "不過，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "我只能說，找我抱怨也是沒用的。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "為什麼啊？",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_012"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n他不是你的公主騎士嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "因為他也會向",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_013"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "身為七冠的我提出挑戰。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n我根本制止不了他。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你不管管的話我們也會很困擾的～！",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_014"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n就是那個，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "監護人……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "什麼的？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳想說",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這是監護人的責任嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n嗯，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嚴格說來，這有點不太一樣。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "希望你可以再好好地教育他。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "你們應該也知道，",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_016"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "這是不可能的吧？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "已經沒有人",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "可以教育他了。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "可是，",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_017"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "像他那樣的傢伙，為什麼可以被選為公主騎士啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "正好相反。",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_018"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "如果不是像他那樣的人選，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n無法勝任",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "公主騎士的職務。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "所謂的公主騎士，",
        "unit_id": 107311,
        "voice": "vo_adv_5110608_019"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n就是這麼特別的存在。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "到頭來",
        "unit_id": 106114,
        "voice": "vo_adv_5110608_020"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "還是白跑了一趟嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唉……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒辦法了。",
        "unit_id": 106211,
        "voice": "vo_adv_5110608_021"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "今後也只能隨便敷衍他，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "想辦法把他趕走了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆與尾狗刀深深地感到一股徒勞感襲來，不禁無力地嘆了一口氣。"
    }
]