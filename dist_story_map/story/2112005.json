    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "面對誓約女君",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "打正面接近戰實在太強人所難了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真希望能有辦法請她們退回去，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n或是我這邊主動離開……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵──",
        "unit_id": 107012,
        "voice": "vo_adv_2112005_062"
    },
    {
        "type": "background",
        "background": "500993"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "！",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_063"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "非常遺憾，",
        "unit_id": 107012,
        "voice": "vo_adv_2112005_064"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我不會給妳機會撤退的。",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……有變貌大妃堵在後頭，",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然會變成這樣嘛～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若是一般人，",
        "unit_id": 107012,
        "voice": "vo_adv_2112005_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或許會認為……",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳不會拋下夥伴逃走。",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而以你的能力，",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就算要將那座牧場連同建築物一同移到地下避難也並非難事。",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂，",
        "unit_id": 107112,
        "voice": "vo_adv_2112005_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n難得的一次饗宴，",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可不想看到那麼無聊的謝幕方式啊。",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唉。",
        "unit_id": 107112,
        "voice": "vo_adv_2112005_068"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要是沒有洗腦魔法的限制，",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也不可能發生二對一這種不解風情的序幕就是了。",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "…………",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_069"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好了。",
        "unit_id": 107012,
        "voice": "vo_adv_2112005_070"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n時間有限，",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n閒聊的部分",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就到此為止吧。",
        "unit_id": 107012
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我同意。",
        "unit_id": 107112,
        "voice": "vo_adv_2112005_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "差不多也該到",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我大肆享受的時候了……♪",
        "unit_id": 107112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "前衛有克莉絲，",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n後衛是似似花。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一位七冠就已經非常難以應付了，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這次還是兩位。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "兩人身上都中了洗腦魔法，",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n想來是很難設計讓她們互相傷害了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再考慮到接下來的事，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也不能夠將魔力全數用盡。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且，",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_074"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年那邊也……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀──",
        "unit_id": 106811,
        "voice": "vo_adv_2112005_075"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "糟糕了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這下子……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可不妙啊。",
        "unit_id": 106811
    }
]