[
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不可思議的，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "意識與意識連結的夢中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n出現在{player}和雪菲面前的是──"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……許久不見了。",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_000"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n大約是從你像幼童一般的那時候以來了吧。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n{player}。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這個人",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……我們是第一次",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_002"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "像這樣交談呢。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n龍人族的少女，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "雪菲。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我是米奈娃。",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_003"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n是由聯合國直屬的網路保護團體，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n「WISDOM」所製作出來的",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "人工智慧。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "人工、",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "智慧……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然，",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不太明白怎麼回事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "先說「初次見面妳好」，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是的。",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_006"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n初次見面妳好。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "然後，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_007"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "{player}……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n看來你接受了我的請託，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "在幫忙收集索爾魔珠呢。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n非常感謝你。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "收集索爾魔珠……？",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_008"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是的。",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_009"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n那個寶珠",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "不在阿斯特朗的管理者權限內，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n是非常重要",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "的道具。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "只是……",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_010"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你們幾位",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n在尋找的時候，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "似乎借用了七冠等人的力量。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我必須先行警告，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_011"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n對於七冠等人，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "絕對不能真心信任。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "她們這些人",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_012"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "無一例外，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "都是利己主義",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "且傲慢。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "簡直就像",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "暴君一樣。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "對我進行程式設計時，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_013"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "要求我學習人類、",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "認知人類，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n接近人類",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n同時，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "卻又從未停止企圖",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "去利用我的性能。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "所以我期望，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_014"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是由你來行動，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "將我救出來。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n其他人都不行，{player}。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n必須是你。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是的。",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_015"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n心靈純淨的你，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "想必不會有什麼",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "邪惡的願望。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這一點，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我非常清楚。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳說的救出",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是什麼意思？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n夢境以外的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "米奈娃小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是在哪裡呀？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我目前，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_017"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是在厄莉絲的根據地……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "「漆黑薔薇」裡。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n最裡頭，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "就是囚禁我的地方。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "那裡是──",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_018"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "距離「世界背面」",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "無限接近的地方。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n不是能夠輕易接近的位置。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "畢竟就連擁有無數「眼」的",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_019"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "霸瞳皇帝，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n也沒能夠一路",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "走到最後。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n只不過……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "{player}。\n你，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_020"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "應該已經明白。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "該用什麼方法，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "才能連結兩相隔絕的世界之間的阻隔。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是說，",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "通訊魔法之類的嗎……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "非常遺憾地，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_022"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我只能說這些推測有所偏差。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "不過……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "答案已經等於在你的手上了，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n想必不需要花多少勞力，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你就能找到正確答案。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "比起這些，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_023"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "現在更應該檢討的，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是與各位敵對的",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "那位女性……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "厄莉絲的事。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "厄莉絲……",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_024"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "她的性能具備絕對優勢，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_025"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "戰力差距令人絕望。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n不論各位再怎麼利用計謀，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "也是毫無勝算。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這可能性，",
        "unit_id": 191112,
        "voice": "vo_adv_2112005_026"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "幾乎等於不存在哦？",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n就像在沙漠裡尋找一粒砂金般有勇無謀，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n你有決心",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "因此讓身邊的人們犧牲嗎？",
        "unit_id": 191112
    },
    {
        "type": "background",
        "background": "500158"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而出現犧牲，",
        "unit_id": 106812,
        "voice": "vo_adv_2112005_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就代表著，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要捨棄什麼人的性命。",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可、",
        "unit_id": 106412,
        "voice": "vo_adv_2112005_028"
    },
    {
