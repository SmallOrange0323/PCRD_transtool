[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為夏天時會變得虛弱，所以就要把整個世界變冷！？",
        "unit_id": 106011,
        "voice": "vo_adv_5207301_000"
    },
    {
        "type": "dialogue",
