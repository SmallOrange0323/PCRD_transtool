    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為了璃亞和安涅默涅小姐的",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "旅途安寧，",
