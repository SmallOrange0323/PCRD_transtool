        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別開玩笑了，誰會允許啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貓咪可不擅長應對寒冷！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是！",
