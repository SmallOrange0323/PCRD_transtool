[
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104715,
        "voice": "vo_adv_6094302_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是我多心了嗎？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我好像感受到其他客人的視線……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我已經穿著野營用的鎧甲了，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但在度假設施裡果然太小題大作了嗎。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n假設少年會接納我……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他又會如何評價我呢？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喔喔……",
        "unit_id": 104715,
        "voice": "vo_adv_6094302_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我居然有",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如此靈活的想法？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果是少年，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他應該也會對我提出這種點子。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我趕緊去",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "尋找追加的葉子吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "愈來愈有趣了呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104715,
        "voice": "vo_adv_6094302_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我似乎看見少年如此對我說的樣子了。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n他一定會發現",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也很講究配色吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……我是不是有點期待過高了？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………嗯。",
        "unit_id": 104715,
        "voice": "vo_adv_6094302_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是他，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或許會察覺吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這身鎧甲擁有的機能美……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "以及莫名可愛的迷彩花紋的魅力……！",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若真是這樣……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就可以幫他準備和我成對的裝備了。",
        "unit_id": 104715
    }
]