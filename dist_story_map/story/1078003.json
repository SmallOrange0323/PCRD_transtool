    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾個小時後。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "游夠了游夠了……♪",
        "unit_id": 107811
    },
    {
        "type": "still",
        "still": "107800301"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼～",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一開始以為只是廉價的窮困旅行，所以心情才很差，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到還挺有趣的……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "努力早點把工作做完，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特地挪出時間來也是值得了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n離開擁擠的城鎮，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來到海邊悠閒渡過，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也挺不錯的。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是出乎意料的是，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔力消耗太多了……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到不只是我，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n居然連{player}和可蘿仔都不會游泳。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了讓那些傢伙在水中散步，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我還為他們施加了特別的原創魔法……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個魔法",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還在開發階段，所以魔力消耗的效率很差。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在魔力用盡，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全身都累翻了……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過算了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔她們好像玩得很開心。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能累積善行，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺不錯。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n希望四天三夜",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能就這個樣子平穩地度過。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留～！",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我買了飲料回來囉☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留用魔法手環收納？",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的那些妳帶來的飲料好像喝完了，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我去買了新的來！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看妳看！",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大概中午後那邊的海之家就開店了，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那裡有賣炒麵或是熱帶飲料之類的哦～！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧♪",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "107800302"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噓……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔睡著了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以別吵吵鬧鬧的嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼、",
        "unit_id": 107611,
        "voice": "vo_adv_1078003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是失禮了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在小凱留的膝枕上睡覺呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真可愛的睡臉……♪",
        "unit_id": 107511
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀啊～",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "臉頰好Q彈。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來戳戳看吧～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "戳戳♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不住手。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她不習慣海邊，所以累了吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n讓她好好休息吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯唔……",
        "unit_id": 107611,
        "voice": "vo_adv_1078003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n唔唔，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哈嗚？",
        "unit_id": 107611,
        "voice": "vo_adv_1078003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇怪？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡著了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看，吵醒她了……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n抱歉喔，可蘿仔，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳可以再繼續睡喔？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼、",
        "unit_id": 107611,
        "voice": "vo_adv_1078003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼欸？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "睡在凱留小姐的膝蓋上……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下真是太失禮了！",
        "unit_id": 107611,
        "voice": "vo_adv_1078003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很討厭肢體接觸吧……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒關係，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小鬼不需要介意啦……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是被妳們碰，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不覺得討厭啊。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦！",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我聽到囉！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也要不客氣地好好抱抱妳了～！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱抱♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "抱歉。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要訂正一下，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳和平常一樣讓人覺得很煩，別碰我。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好過份！？",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留比起剛見面時，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經變得相當黏我們了～♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這個樣子的話，",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要再過個幾個月，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肯定就會自己主動纏上來抱抱了……！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等那個時候到來的話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會盡情給妳抱抱的哦♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種未來永遠不會來啦，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "白癡佩可！？",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡貪吃佩可的簡稱。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把暱稱再做變化的話，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就會變得莫名其妙了耶～？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過說真的，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳能像這樣和人開玩笑，我好開心。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛見面那時候的小凱留，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "偶爾會讓人感覺很可怕呢。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是這樣嗎……",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得和你們相遇以後，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n自己並沒有那麼大的改變啊。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳變了喔，",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變很多。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧，{player}♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦……",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你也和貪吃佩可一起去買飲料了？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "辛苦了～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把給我的貢品獻上來吧♪",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我讓可蘿仔睡在大腿上，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以動不了……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也沒辦法到遮陽傘下去避難，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只好直接曬在大太陽底下，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺都快脫水了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "動作快點。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別在那裡發呆，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把飲料拿給我。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n很好很好，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咕嚕咕嚕。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "水份浸染了全身……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像這樣子在海邊喝著熱帶飲料，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都讓人快忘了這裡是附近的海灘呢♪",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦噗！？",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在做什麼啦，你這個大混蛋！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心我宰了你喔……！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你偶爾會做些意義不明的舉動耶。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為記憶喪失而沒有常識，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你別以為這種藉口會一直都有用哦！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……什麼？",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為我說快脫水了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是擔心才用水淋我？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊……",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你淋在我身上的這個，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是礦泉水吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你不只買了熱帶飲料，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也買了普通的水嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確，",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "水淋過灼熱的肌膚後，是變涼快了……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但可以的話，真希望能普通地喝水～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只是因為你是擔心我，所以又不好抱怨。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1078003_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感情好是不錯……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但已經休息足夠了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要趁天還亮著時，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再稍微游一下呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小孩子真有精神呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "走吧走吧，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大海在呼喚我們囉……☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n抱歉，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想再休息一下。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們去就好了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會在這裡看著。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？",
        "unit_id": 107511,
        "voice": "vo_adv_1078003_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣感覺就像把人排除在外一樣，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有點討厭的感覺耶？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不會覺得",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "自己被排除在外啦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快去快去。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和你們前衛不一樣，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔法師體力很差的，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且我魔力也用光很累了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事的。",
        "unit_id": 107811,
        "voice": "vo_adv_1078003_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我再休息一下，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就會去和你們會合了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "老實說，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也還想再多享受大海啊……♪",
        "unit_id": 107811
    }
]