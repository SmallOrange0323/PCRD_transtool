[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……某天下午。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n咲戀與流夏在討論關於今天晚上的菜單。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "絕對應該做漢堡排！",
        "unit_id": 127512,
        "voice": "vo_adv_5128092_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這傢伙明天要去進行漫長的冒險，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該準備能夠好好填飽肚子的東西！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不對，",
        "unit_id": 127612,
        "voice": "vo_adv_5128092_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該做鹽烤魚和味噌湯！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "吃漢堡排感覺會消化不良啊，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "做清淡點的東西才比較安心吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我的漢堡排",
        "unit_id": 127512,
        "voice": "vo_adv_5128092_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是在育幼院也有很多人愛吃的",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n豆腐漢堡排，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不需要擔心會消化不良。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n流夏的料理",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對於年輕男生來說反而會吃不飽吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔……",
        "unit_id": 127612,
        "voice": "vo_adv_5128092_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來這招啊……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就把鹽烤改成照燒！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這是我在食堂賺旅費時，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "學會的祕藏料理！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來妳不打算退讓呢。",
        "unit_id": 127512,
        "voice": "vo_adv_5128092_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……那麼，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就由你來決定好了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你今晚想吃誰的料理？",
        "unit_id": 127612,
        "voice": "vo_adv_5128092_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n大家願賭服輸，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不需要有所顧慮。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "照、",
        "unit_id": 127512,
        "voice": "vo_adv_5128092_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "照燒豆腐漢堡排……？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可沒有做過什麼照燒醬啊……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我雖然會做照燒醬，",
        "unit_id": 127612,
        "voice": "vo_adv_5128092_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是我沒有用豆腐做過漢堡排……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀、流夏",
        "words": "……啊。",
        "unit_id": 1,
        "voice": "vo_adv_5128092_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來是這麼回事啊。",
        "unit_id": 127612,
        "voice": "vo_adv_5128092_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "提出這道料理也是挺機靈的嘛。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "流夏。",
        "unit_id": 127512,
        "voice": "vo_adv_5128092_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果不介意，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以請妳教我做照燒醬嗎？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咲戀妳",
        "unit_id": 127612,
        "voice": "vo_adv_5128092_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也教我怎麼做",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "豆腐漢堡排吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們互相教對方的話，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺在想菜單時也會比較輕鬆呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，咲戀和流夏同心協力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n完成了好吃的照燒豆腐漢堡排。"
    }
]