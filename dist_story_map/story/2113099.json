[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在黑天使們的闇影襲擊阿斯特朗各處的不久之前──"
    },
    {
        "type": "still",
        "still": "211309901"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……我、",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們來到森林邊陲了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一路上好像",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "都沒有魔物的蹤影呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對啊……",
        "unit_id": 101512,
        "voice": "vo_adv_2113099_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n希望被迫參與戰鬥的孩子們",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都可以順利逃走。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【森林守衛】的各位，",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝妳們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "護送我們到村外。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然是很想",
        "unit_id": 101211,
        "voice": "vo_adv_2113099_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "跟著你們到蘭德索爾啦～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但是小初音",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "已經睏到不行了………………",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "邊睡邊飛……",
        "unit_id": 106012,
        "voice": "vo_adv_2113099_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這到底是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼操作……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不可以一直戳正在睡覺的人喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……可可蘿。",
        "unit_id": 101512,
        "voice": "vo_adv_2113099_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那個，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "關於……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n長老的事……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……謝謝您的",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不要緊的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟這不是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "永遠的分離。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是、",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話雖如此……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「精靈族之村的長老」不在的情況下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n村莊的防護會變得很脆弱，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下很擔心……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……既然如此～",
        "unit_id": 101211,
        "voice": "vo_adv_2113099_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n村子就交給",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音一行人保護吧………………",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_2113099_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說得沒錯。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "守護精靈之森、",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "動物們與村民，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n是我們【森林守衛】的使命。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對吧，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小碧？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒、",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我會盡全力加油",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不要扯大家後腿的……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……是關於",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雪菲的事情……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "身為資深邊緣人的我",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可以理解。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n雖然因為性格或是境遇，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "人們成為邊緣人的原因可能有百百種，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但那個人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一定會有想要脫離邊緣的念頭……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_2113099_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所、",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雪菲現在一定，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n正在努力想辦法",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "回到各位的身邊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……！",
        "unit_id": 104011,
        "voice": "vo_adv_2113099_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起對不起！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我居然說出這麼自以為是的話……！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不。",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n謝謝妳。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定就是像碧說的這樣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……沒錯。",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果她是為了我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才離開，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那她一定也會",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了我們……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而回來的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒錯沒錯，",
        "unit_id": 101211,
        "voice": "vo_adv_2113099_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就是那樣………………",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀～",
        "unit_id": 101512,
        "voice": "vo_adv_2113099_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n初音真是的。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個，",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【森林守衛】的各位。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "？",
        "unit_id": 1,
        "voice": "vo_adv_2113099_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在不久的將來，",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說不定會有一場",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大規模的戰爭。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到時候……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們還可以借助",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位的力量嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「嗯嗯，當然♪」\n「包在我身上！」\n「呼嚕～！」",
        "unit_id": 1,
        "voice": "vo_adv_2113099_027"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖經了一番波折，",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但眼下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "索爾魔珠全部收集完了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著便是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……跟彌勒",
        "unit_id": 106012,
        "voice": "vo_adv_2113099_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的戰鬥吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他說要在索爾之塔",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交換人質……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道他會拿去做什麼壞事，",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且索爾魔珠對拉比林斯達小姐的計畫來說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不可或缺的道具。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不能就這麼輕易地交給他……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n說不定彌勒那邊",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會設下陷阱。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們也應想好對策。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳有什麼計畫嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這雖",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稱不上計畫。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但日和小姐她們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對愛梅斯大人而言，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是很有緣分的人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拜託她們幫忙",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是最好的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對耶！",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果是【破曉之星】的大家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該也會很瞭解塔的內部情況。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此外，",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許還有其他人也與彌勒勢不兩立。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於已經決定好交換人質的日期前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在有限的時間內",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盡量增強戰力……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是這樣吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──總而言之，",
        "unit_id": 106012,
        "voice": "vo_adv_2113099_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們要把彌勒狠狠打飛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n救出人質。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "執行拉比林斯達小姐的計畫，",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或想辦法阻止厄莉絲小姐……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們要解決這個世界的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "問題。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後",
        "unit_id": 105812,
        "voice": "vo_adv_2113099_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還要跟小雪菲一起，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再次",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "圍繞著同一張餐桌吃飯。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2113099_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們走吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會引導您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到最後一刻……！",
        "unit_id": 105913
    }
]