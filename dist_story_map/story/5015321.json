[
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "喔，",
        "unit_id": 11412,
        "voice": "vo_adv_5015321_000"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "看來是打倒了冒牌貨了呢。",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n就稱讚妳們一下吧！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……",
        "unit_id": 109611,
        "voice": "vo_adv_5015321_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n才不會因為那種東西就退縮！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖、",
        "unit_id": 109511,
        "voice": "vo_adv_5015321_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然的確陷入了苦戰……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "那接下來換這個！",
        "unit_id": 11412,
        "voice": "vo_adv_5015321_003"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n來吧，平民們，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "去撿吧！！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什、",
        "unit_id": 105311,
        "voice": "vo_adv_5015321_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n它剛剛丟了什麼東西出來……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個是",
        "unit_id": 109611,
        "voice": "vo_adv_5015321_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "小判！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n放在那邊的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是招財貓之王！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不論哪個，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都是不得了的高級品！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "在這麼多你們絕對拿不到的高級品面前，",
        "unit_id": 11412,
        "voice": "vo_adv_5015321_006"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n絕對無法保持冷靜！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n來，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "展現出你們身為人的慾望！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼……",
        "unit_id": 105311,
        "voice": "vo_adv_5015321_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種東西",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n對我這個榮耀的軍人怎麼可能行得通……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊，",
        "unit_id": 109611,
        "voice": "vo_adv_5015321_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個箱子裝的該不會是",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "黃金最中餅！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n因為是最高級的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "東國甜點所以很出名，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n連我都",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒有吃過！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……………………唔，",
        "unit_id": 105311,
        "voice": "vo_adv_5015321_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼可能……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "行得通…………",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 109511,
        "voice": "vo_adv_5015321_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花雖然沒有",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "特別想要的東西，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過實在是無法放過",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這股被人",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "丟東西的快感！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哼，",
        "unit_id": 109611,
        "voice": "vo_adv_5015321_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳們兩個",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都給我振作一點！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然如此，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就讓妮諾",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來當你的對手！",
        "unit_id": 109611
    }
]