[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真琴跟{player}一邊解決海邊遊客的困擾，\n一邊繼續巡邏。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呼。",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "海灘的狀況",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "終於穩定下來了呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "連喘息的空閒都沒有。",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然知道會很忙碌，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒想到會忙到這種程度。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到現在還沒有出現溺水的人，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n或者傷患之類的，也算是好事。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果在海邊發生意外",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可是攸關生命呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們沒有出場機會",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才是真正的好事啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這麼說起來，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "游泳的技術怎麼樣啊？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對了，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之前跟公主她們一起去海邊的時候，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你好像差點溺水吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯嗯，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是說，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "幾乎不會游泳對吧？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底是怎樣的程度，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你游給我看一下吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n原來如此呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要自稱是海岸巡守員，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有點不夠呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那是哪來的自信啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n去拿東西？　",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是什麼啊……？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "密技？",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　什麼啊？密技是指什麼？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n喂，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你要跑去哪裡啊？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊……",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我還以為你這麼有自信",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是有什麼祕密呢。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來是游泳圈啊！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且好像還很得意啊？",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n嗯？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　有這個就不會溺水了？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}覺得沒問題的話，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是沒有什麼不好啦……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過呢，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是真的發生什麼事情，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是先讓我去救人吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你可不要逞強啊。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "海邊的意外",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是發生二次災害可是很恐怖的。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "二次災害就是呢，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要去救人的傢伙結果自己",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也溺水了，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之類的吧。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是適得其反的意思啦。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　你問我適得其反的意思是？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個……",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊這個對話就是二次災害啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不對，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然有點不一樣啊！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總之呢――",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_020"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "小孩！",
        "unit_id": 1,
        "voice": "vo_adv_1104003_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "　有小孩子溺水了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "快點走吧！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "溺水的人在哪裡！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在那邊！",
        "unit_id": 1,
        "voice": "vo_adv_1104003_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼一個小孩子在那麼遠的地方！？",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是被海流沖走的嗎！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等等，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "馬上過去！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}在這裡等著，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽懂了吧！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚喔喔――！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很好，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "趕上了！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇、",
        "unit_id": 113,
        "voice": "vo_adv_1104003_031"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我來救你了！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_032"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "冷靜一點，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好好抓住我。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "呼、",
        "unit_id": 113,
        "voice": "vo_adv_1104003_033"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "呼……！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要亂動，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好好抓住我喔。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好了，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_035"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到岸邊了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "已經沒事了。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "冷靜下來，深呼吸。",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有沒有哪裡會痛呢？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……姊姊。",
        "unit_id": 113,
        "voice": "vo_adv_1104003_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦？",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_037"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　怎麼了？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "姊姊她……",
        "unit_id": 113,
        "voice": "vo_adv_1104003_038"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "跟我在一起……！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n拜託……",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "快去",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "救救姊姊！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "？",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_039"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "漂到更遠去了……！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_040"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我等著……！",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_041"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還差一點……",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡，",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "接連著游泳",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "果然還是有點辛苦啊……！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "！",
        "unit_id": 213,
        "voice": "vo_adv_1104003_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒事",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_044"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吧……！？",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "……",
        "unit_id": 213,
        "voice": "vo_adv_1104003_045"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "糟糕，",
        "unit_id": 110411,
        "voice": "vo_adv_1104003_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這孩子差不多快不行了……！",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 110411
    },
    {
        "type": "dialogue",
        "name": "真琴",
