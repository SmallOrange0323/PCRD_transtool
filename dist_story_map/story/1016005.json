[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那是在{player}買東西的時候――"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，是秀才！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在做什麼呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在買東西嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，原來是幫別人跑腿呀。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看你在這邊東張西望，怎麼了嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……不知道店在哪裡嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原來如此。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼人家來幫你吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "首先要去哪裡呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "水果攤？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "水果攤的話，不就在那邊嗎。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n簡單～簡單～",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看，就是這裡喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n要買什麼？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "蘋果 3 個？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": " 咦，不覺得有點少嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看嘛，一個 70 盧幣對吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這麼便宜，多買一些不好嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃，最大的是 9……",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n因為 7x9=46，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以買 9 個也才 460 盧幣喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～才沒那回事呢。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n七九四十六……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "七九四六，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家還記得！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家就說買多一點才划算嘛！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就買吧。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不好意思～請給人家 9 個蘋果～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好的好的，蘋果 9 個對吧。",
        "unit_id": 1411,
        "voice": "vo_adv_1016005_011"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n總共 630盧幣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "騙人！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "630……真的假的！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "來，這是找零。",
        "unit_id": 1411,
        "voice": "vo_adv_1016005_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "多謝惠顧～",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "…………抱歉。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家算錯了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n九九乘法的七的部分不太會背。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……你願意原諒人家啊？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才真的超溫柔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是錢還夠嗎？還有東西要買吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "錢不夠買剩下的東西……？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊……嗯～該怎麼辦？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "招客",
        "words": "我們是本日新開幕的賭場！",
        "unit_id": 311,
        "voice": "vo_adv_1016005_017"
    },
    {
        "type": "dialogue",
        "name": "招客",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "招客",
        "words": "歡迎大家來試試手氣！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才，就是那個，那個！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "盧幣不夠的話，只要讓它變多就好了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我就知道秀才一定會贊成！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就這麼決定囉！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "安～啦，安～啦！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們肯定能行的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是這樣，",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n趕快朝賭場出～發吧！",
        "unit_id": 101611
    },
    {
        "type": "still",
        "still": "101600501"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了～！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n又中了大獎～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家今天簡直有如神助！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也高興一點嘛～！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n大賺了一筆喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然不太明白，不過賭場還真簡單呢？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "隨便下注個數字，就會不斷中獎！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂喂喂，秀才！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "機會難得，就多賺一些錢吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看你一副躍躍欲試呢！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就用這股氣勢中獎吧～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "膽怯可不好喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "放手一搏吧～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼接下來全部押在黑 4 上面喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n因為人家是 4 月出生。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，輪盤轉了！",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "４來吧！４來吧！４來吧～！",
        "unit_id": 101611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……抱歉。",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在最後的最後失手了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "籌碼全部沒了，",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這樣也不能買東西了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果人家沒有貪心的話……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也玩得超開心喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然中大獎也很開心，",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但最後竟然失手了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！超好笑～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～可是怎麼辦？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n已經沒辦法再繼續買東西了對吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？只要退貨就可以了？",
        "unit_id": 101611,
        "voice": "vo_adv_1016005_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，原來如此。只要把蘋果退還給水果攤就好了嘛！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不愧是秀才，真聰明～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人邊向老闆道歉邊退貨，\n總算買完了東西。"
    }
]