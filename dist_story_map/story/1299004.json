[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天，{player}受惠理子所託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來幫忙她的工作。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "謝謝您來幫我，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "多虧如此才能夠順利地進行。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一回神，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才發現教官的職責我也得心應手了許多。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被稱為「破壞者」的我，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如今竟然成了教導他人的角色，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "若沒有和您相遇，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "實在是完全無法想像呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當初聽到深月很正經地在大江戶當醫生時，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我還笑了出來。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但我也沒有資格說別人呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您那樂於助人的想法，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n雖然不多，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但我也有些理解了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "多虧如此，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我對您有了更深的理解。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "與此同時，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我對您的愛也同樣，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "變得更深了！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您果然很了不起，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "仔細一看，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您背後甚至還散發著光芒呢！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是多麼耀眼的光芒……",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "天啊，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我被您的愛以及溫柔所包裹著！",
        "unit_id": 129911
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當天上完課後，{player}正要回家。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時──"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓您久等了，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n今天也辛苦了，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "尤其是撐過了第五堂的體育課呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對了，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在連假之前，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "每個科目都出了很多作業吧？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "考慮到您的情況，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該是打算在連假期間完成吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難得的假期卻要被作業給淹沒實在太可惜了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哦？",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您很在意我除了課表外，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "連作業量都掌握得一清二楚嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這只是些細微末節的問題。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因此呢，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在開始我會片刻不離地指導您。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "由我親自",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "手把手教到您會──",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "已經全部寫完了？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這、",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣啊。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真不愧是您。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那、",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "之前的考卷今天發回來了吧？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要確實複習答錯的地方──",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是考試的答案？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "居、",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "居然",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "每科都考這麼高！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "答錯的地方也都是粗心，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而不是理解不夠……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n真、",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是厲害呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "能聽您這麼說，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的努力也有回報了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看到您成長，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "並變得出色真是令人開心。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "作為伴侶，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是無可比擬的幸福。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "胸口",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這股悶悶的感覺是什麼呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n難道是我",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "感到寂寞嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "即使沒有我的幫助，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您也獨自成長了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "總有一天，這位大人的心思會轉移，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "變得不再需要我吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……光是想像就覺得心如刀割。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我真是的，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然因為預料外的事，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n而變得有些負面。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天就先調整一下，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "重新規劃連假的計畫──",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要說有時間的話",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是有呢……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什麼？",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那是什麼意……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大、",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n竟然那樣",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "突然抓起我的手……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "天啊，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會被帶去哪裡呢！",
        "unit_id": 102731
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請問，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡是……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "遊樂中心，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對吧？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要來這做什……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是這個嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「不死生存者」……",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "用槍來射擊敵人的遊戲啊。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我沒有玩過。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不如說我幾乎沒來過幾次",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "遊樂中心。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您還真是積極呢。",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "包括考試和作業，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您終於打算",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要和我攜手前進了嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊！",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "距離命運的邂逅已過了數個年頭，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們終於走到這一步了！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n而這也能理解為",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是我們兩人首次共事。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您跟我來吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然我是第一次玩，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "簡單來說",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就是要攻擊敵人對吧？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就讓我親手發射禮炮，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "開創我們的未來吧！",
        "unit_id": 102731
    },
    {
        "type": "still",
        "still": "129900401"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……奇、",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "奇怪？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "完全",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "射不中呢……？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n看來好像是壞掉了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對了，現在想起來，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那個女店員",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n好像在對{player}大人送秋波呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "恐怕是她對機器動了手腳，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "打算讓我蒙羞吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n既然妳打算這麼做，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那我就徹底毀了妳……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…失禮了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有點興奮過頭了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n很抱歉，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "能請您從頭開始教我嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "準心？",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來如此，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是指這個吧……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "打中了！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您看到了嗎？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我打倒那個討厭的活死人了！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這樣一來",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就能幫上您的忙……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "奇怪，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "又射不出子彈了！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "換、",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "換彈？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來如此，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要往畫面外射擊就能裝填子彈了呀。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣就又能戰鬥了！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "剛剛那是一般市民……？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "Game over了……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唔，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這些臭屍體……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看我使用不習慣的武器就這麼地放肆呢……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果是在阿斯特朗的話我就把你們搗成肉醬了……",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是可恨，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是可恨真是可恨……！",
        "unit_id": 102731
    },
    {
        "type": "still",
        "still": "129900402"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人……",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好的，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那就拜託您了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "身為您的伴侶，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n可不能就這麼落魄地結束。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然剛才輸了，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n但只要了解機制，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "屍體什麼的根本不是我的對手！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看我把你們的頭全部射穿。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "！",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "馬上就解決了敵人的攻勢……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n謝謝您，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "總覺得您看起來比平常更出色呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖說是遊戲，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但您認真",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "又勇猛的身姿，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是太優秀了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "像這樣被保護著，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "意外地感覺不錯呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n嘻嘻，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "遊樂中心裡",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還有很多其他遊戲吧？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "能和您一起玩，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一定會很開心吧。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n請一定",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也要教我其他的遊戲。",
        "unit_id": 102731
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "──從格鬥遊戲玩到賽車遊戲，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_043"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "接著是節奏遊戲和夾娃娃機。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "最後，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "兩人在回家路上買了可麗餅來吃。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "若是沒有和您相遇，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_044"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這些事我永遠不會了解。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n實在太開心了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我啊，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "通常自己一個人就能完成大部分的事，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所以很少有機會向別人請教。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_046"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "向別人學習會讓世界更開闊。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n也是有這種事的呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一直以來，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_047"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管您的意願如何，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n為了您好，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我一直都在指導您。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我一點也不覺得那樣是錯的，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_048"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也沒有感到後悔。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但現在我發現到，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣的行動，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有點太片面了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然自稱是伴侶，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_049"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就不能只有我自己感到開心。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "必須也讓您學得開心才行。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_050"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您真的",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是很溫柔的人呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果是真正相愛的兩人，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "互相學習各種事情，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n並加深對彼此的理解，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一定也是必要的。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天能向您學習，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n真的讓我非常非常開心。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_052"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過──",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了不讓好不容易拉上來的成績又掉下去，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n有必要定期來讀書。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "剛好明天開始是連假，",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_053"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "正適合兩個人一起度過呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會既深入",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "又甜蜜地",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "徹底指導您的。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "敬請期待。",
        "unit_id": 102731,
        "voice": "vo_adv_1299004_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 102731
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1299004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看到了很有意思的東西呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "惠理子啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1299004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看她平常既兇狠，能力又好，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以很容易忘了她其實也只是個十幾歲的女孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論她多強、多優秀，",
        "unit_id": 190011,
        "voice": "vo_adv_1299004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也絕對不是完美的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道惠理子的強大與恐怖，",
        "unit_id": 190011,
        "voice": "vo_adv_1299004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "同時也曉得她的弱點，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻還願意待在她身邊的人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該並不多。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我本以為這是盲目的信仰所產生的瘋狂之愛，",
        "unit_id": 190011,
        "voice": "vo_adv_1299004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但看來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子還是相當地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有眼光呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你今後還會遇到很多折騰的事，",
        "unit_id": 190011,
        "voice": "vo_adv_1299004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就好好加油吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見～",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯……",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_061"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唉呀，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我竟然在外面",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "打瞌睡了，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看來我不知不覺間似乎累積了很多疲勞呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_062"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "夢境裡真是太美好了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為夢中的您教會了我很多事情！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_063"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您這番話可真奇怪呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "完全偏離重點了喔，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我很不擅長與人交流。",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_064"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n能稱得上是夥伴的就只有公會的大家而已。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過這並沒有什麼好困擾的，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_065"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n因為一直以來我都是靠自己去解決各種事情。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然而，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_066"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我遇見了您，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "並選擇為您盡心盡力，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n結果讓我累積了很多的經驗。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而您之前說過，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_067"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "希望我多與人交流。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這句話的意思，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我現在也明白了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "藉由接觸您和公會夥伴以外的人，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_068"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會讓我產生新的想法，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "能得到過去的我",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "無法想像的意外體悟。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在指導他人的同時，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_069"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我自己也學到了很多。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n讓我注意到這點的，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不是他人，正是您啊。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也就是說，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_070"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您不僅是我最愛的人，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n更是最優秀的教官。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今後不會再遇到",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_071"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和您一樣的人。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所以我決定，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要一輩子陪伴在您的左右。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "往後也要請您長久地指教了，",
        "unit_id": 129911,
        "voice": "vo_adv_1299004_072"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 129911
    }
]