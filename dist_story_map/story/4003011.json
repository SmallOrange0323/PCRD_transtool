    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是但是，",
        "unit_id": 105812,
        "voice": "vo_adv_4003011_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可是公會管理協會的委託呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我認為應該是正確的情報唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "龍呀……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底會是什麼味道呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等……",
        "unit_id": 106012,
        "voice": "vo_adv_4003011_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為好像能吃到龍肉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳才接下這個委託吧！？",
        "unit_id": 106012
