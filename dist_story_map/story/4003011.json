    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一旦要對戰的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只憑在下等人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒問題嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對嘛對嘛！　",
        "unit_id": 106012,
        "voice": "vo_adv_4003011_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實在太胡來了！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題的啦～",
        "unit_id": 105812,
        "voice": "vo_adv_4003011_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只是稍微作個調查，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果可以順便獲得點肉就好！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不行了。",
        "unit_id": 106012,
        "voice": "vo_adv_4003011_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟變成這樣的貪吃佩可說什麼都沒用。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又不是一定會跟龍對戰……",
        "unit_id": 106012
