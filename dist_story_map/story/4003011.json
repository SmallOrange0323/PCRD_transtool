        "voice": "vo_adv_4003011_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
