        "voice": "vo_adv_4003011_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是龍的棲息地吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
