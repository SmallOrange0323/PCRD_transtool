    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來保護妳們吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_4003011_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說起來",
        "unit_id": 106012,
        "voice": "vo_adv_4003011_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在接受花凜委託的當時，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就已經有什麼未知的陷阱吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個委託，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會有什麼內幕吧？",
