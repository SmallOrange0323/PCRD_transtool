        "voice": "vo_adv_4003011_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果竟然變成這樣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我早就猜想到了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗚……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請保佑",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們不要和龍對戰！",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500900"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼～，",
