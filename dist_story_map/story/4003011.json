        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有人目擊到狂暴的龍……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以是龍的調查，",
        "unit_id": 106012,
        "voice": "vo_adv_4003011_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果看起來有危險的話就將其排除……",
