        "voice": "vo_adv_4003011_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總之就是要調查而已！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
