        "voice": "vo_adv_1276001_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所謂的設置",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是指釣具的組成。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n像是要使用",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "多粗和多長",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的魚線，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "以及魚鉤大小",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
