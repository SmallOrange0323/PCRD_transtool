        "voice": "vo_adv_1276001_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣事情就好辦了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想問的",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是關於設置。",
        "unit_id": 127612
