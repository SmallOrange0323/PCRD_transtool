        "voice": "vo_adv_1276001_016"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n走，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我們去和那邊的人們打聽看看吧。",
