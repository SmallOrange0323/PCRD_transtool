    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束在薩拉薩利亞的冒險，{player}與流夏在居住處"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n悠閒地度過回國前的這段時間時，精靈前來拜訪兩人。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼～",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是和平呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能讓我們",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "作為食客自由自在地過著，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是太感謝了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "流夏姐姐雖然這麼說，",
        "unit_id": 5313,
        "voice": "vo_adv_1276001_001"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "但是妳看起來好像很無聊……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我看起來很無聊嗎？",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的確，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是覺得生活能再稍微有一點刺激呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比如說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像是這種的……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "那是",
        "unit_id": 5313,
        "voice": "vo_adv_1276001_003"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "什麼動作？",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "果然看得出來嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "畢竟",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我和小哥認識很久了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每個土地都有當地的魚種，",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "根據不同魚種，會有各式各樣的釣法。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我至今只要是旅行過的地方，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "無論是哪裡我都會去釣一次魚。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然這麼說，",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是這裡本身並沒有水域。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來也只能放棄了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這裡有綠洲啊……",
        "unit_id": 5313,
        "voice": "vo_adv_1276001_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那裡與其說是這塊土地，",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不如說是被搬過來的地方吧。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "況且，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那裡現在對薩拉薩利亞的人們來說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是很重要的水域不是嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要我帶著玩樂的心情去釣魚，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺實在不太好意思。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "原來如此……",
        "unit_id": 5313,
        "voice": "vo_adv_1276001_009"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n如果是這樣的話，那麼還是別在那邊釣魚比較好。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "嗯……",
        "unit_id": 5313,
        "voice": "vo_adv_1276001_010"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "既然這樣，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這種的妳覺得如何？",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這張紙是什麼？",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我看看，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "傳統魚法……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "流沙釣？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這裡的沙漠",
        "unit_id": 5313,
        "voice": "vo_adv_1276001_012"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "有魔物潛伏在沙中。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "所以",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我試著把那些魔物",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "當成是要捕獲的魚。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你還是一樣這麼亂來呢。",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣的話，也不會對環境造成問題，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還能夠驅除魔物啊……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不錯嘛，",
        "unit_id": 127612,
        "voice": "vo_adv_1276001_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我喜歡。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我就來試試看吧！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也會和我一起來吧？",
        "unit_id": 127612
    },
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流夏與{player}和精靈一同前往了市場。"
    },
