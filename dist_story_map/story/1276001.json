        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然說是傳統，應該有制定出什麼方法吧？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "那當然！",
