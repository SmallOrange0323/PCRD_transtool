    {
        "type": "dialogue",
        "name": "男性",
        "words": "這不是嘉夜嗎！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哎呀，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那時候真是幫大忙了呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不用放在心上啦。",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但如果又有土地開發商帶打手來找碴的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n要馬上跟我說唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "當然！",
        "unit_id": 1411,
        "voice": "vo_adv_1065001_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那位是？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實他呢，",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "剛剛要送食材到大叔的店時，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "途中被捲入打架現場啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n大叔委託的食材，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多少稍微有點損傷了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳說什麼？",
        "unit_id": 1411,
        "voice": "vo_adv_1065001_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是什麼東西，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以讓我看看嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真傷腦筋。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣的話今天沒辦法付你酬勞呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我想也是……",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_035"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "食材的款項，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就由我這個事主來賠償吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n所以，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能不能先付給他酬勞呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔……",
        "unit_id": 1411,
        "voice": "vo_adv_1065001_036"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真沒辦法，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "今天看在嘉夜的份上，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我就付給你酬勞吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的嗎！？",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_037"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不愧是大叔！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個給你。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "食材的費用。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不用了不用了。",
        "unit_id": 1411,
        "voice": "vo_adv_1065001_038"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雞蛋的話再買就行。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "作為交換，之後店裡出事的話，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以麻煩妳幫忙解決吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當然！",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "作為今天的謝禮，我會給大叔超級優惠的價格！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管怎樣的對手，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我都絕對不會輸的！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哎呀～",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大叔人真好，幫了大忙。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不但給你酬勞，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "連賠償也免了呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "報答我？",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就說不用啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n而且說到底，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是我跟那個混蛋把你捲進來。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了……",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果你覺得過意不去的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "下次幫我找個工作吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "送貨！？",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n雖然平常有在鍛鍊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我對腰力跟腿力是還滿有自信的啦……",
