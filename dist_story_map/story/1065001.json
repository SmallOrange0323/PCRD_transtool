        "voice": "vo_adv_1065001_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管什麼架都會去打的打手。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不管是怎樣的對手，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也不管有多少人。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果你遇到不得不和別人戰鬥的狀況，",
