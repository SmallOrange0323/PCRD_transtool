    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊───不對啦，",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是指那種的啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說的工作是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "找人打架唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打架。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是個根據酬勞不同，",
