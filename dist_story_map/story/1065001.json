        "voice": "vo_adv_1065001_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n到時候要找我商量喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且你看起來不太擅長打架，",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_048"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種合作模式很適合我們吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我常常在這附近，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "隨時都可以來找我唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔！",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "太專心聊天，沒想到已經這麼晚了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "差不多該回去了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再見啦。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喲，",
        "unit_id": 106511,
        "voice": "vo_adv_1065001_050"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這不是{player}嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n難不成，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是要我幫忙你",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "送貨的工作嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說說而已，",
