        "voice": "vo_adv_1065001_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可惜有點不太對。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過偶爾跟魔物打架，",
