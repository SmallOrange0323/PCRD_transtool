[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在慈樂之音巡演中的某個夏日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n紡希利用下次公演前的休息日，來到了某處海邊。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～～～！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "天氣真好！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天是個適合衝浪的好日子呢！！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是小望和千歌她們也能一起來就好了。",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但她們有其他行程，這也沒辦法……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來，騎士先生也是，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n特別幹勁十足地出門去了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才不在意那個人的行程呢！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n沒錯，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一點也不在意！！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我今天要盡情地享受休假！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "向著大海！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "出發！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你怎麼會在這裡！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咦？",
        "unit_id": 113,
        "voice": "vo_adv_1174002_006"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是大哥哥認識的人嗎？",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大姐姐",
        "unit_id": 213,
        "voice": "vo_adv_1174002_007"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "長得好眼熟呀……",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "對了！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是慈樂之音的──",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊～～～！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我常常被人這麼說呢！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚嗚……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起喔。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我被經紀人再三叮囑",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n出去玩時不能暴露身分……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "說得也是……",
        "unit_id": 213,
        "voice": "vo_adv_1174002_010"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "偶像怎麼可能出現在這裡嘛。",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是啊就是啊！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以，你們三個人在這裡做什麼？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們呀，",
        "unit_id": 213,
        "voice": "vo_adv_1174002_012"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n在和大哥哥",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "一起練習游泳唷！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大哥哥一大早就自己一個人跑來練習，",
        "unit_id": 113,
        "voice": "vo_adv_1174002_013"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我們實在看不下去才來當他的教練！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一大早！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n話說騎士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來你不會游泳啊！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嘿嘿！",
        "unit_id": 113,
        "voice": "vo_adv_1174002_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這是特訓的成果呢！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n可是，",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我們也差不多該回去了。",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不過，",
        "unit_id": 213,
        "voice": "vo_adv_1174002_016"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "既然朋友來了，就沒問題了吧！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說我嗎！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是能夠教他啦……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……",
        "unit_id": 113,
        "voice": "vo_adv_1174002_018"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "哦",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "，",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "看來有戲喔。",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n這不正是大哥哥的好機會嗎……",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大哥哥他",
        "unit_id": 113,
        "voice": "vo_adv_1174002_019"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "超級溫柔的喔！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n如果選他當男朋友，",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "他一定會非常珍惜妳的！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "男男男、",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "男朋友！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不不不！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我這輩子都沒有那種打算啦！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大哥哥，",
        "unit_id": 213,
        "voice": "vo_adv_1174002_021"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們會為你加油的！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "掰掰──！！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "走掉了……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說回來，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說完那種話之後留下我們兩人獨處……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n氣氛超級尷尬啊……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得你還是自己練習比較好！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我要去衝浪了，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請你好好加油吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉～",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只是像這樣躺在衝浪板上……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺和待在宿舍裡無所事事沒什麼兩樣嘛。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不擅長游泳對吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n今天的浪有點高，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他沒問題吧？　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看到人了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他自己一個人在練習呢……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……正、",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正好有點口渴了，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n去海之家的路上順便和他打聲招呼──",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呀──！",
        "unit_id": 1,
        "voice": "vo_adv_1174002_029"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "海裡有個巨大的魔物──！！",
        "unit_id": 1,
        "voice": "vo_adv_1174002_030"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n大家",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "快上岸避難！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這裡怎麼會出現魔物！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n留在海裡的人呢！？　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……還有很多！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我得引開那傢伙的注意，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為大家爭取時間……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喂喂！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我在這裡唷──！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來比比看",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "誰的速度更快吧！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚哇哇哇……！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明體型龐大移動速度卻非常快！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這下遲早會被他追上吧！？　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你怎麼站在崖上！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這道光……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "力量湧出來了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有了這股力量，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我一個人也能把它打飛……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生真是的，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總在最關鍵的時刻出現。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……害我不由得",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "萌生了一股安心感。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你要在那裡仔細看著",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的活躍表現唷！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喝呀呀呀！！",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_039"
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "它朝這裡倒下來了！？　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊啊啊啊！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼都看不到……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在怎麼樣了……？　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽見了騎士先生的聲音……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不用叫那麼大聲",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也能聽見啦……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就說了──",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_044"
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我聽得見……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼在岸邊……？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我有點搞不清楚現在的狀況……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那位少年跳下海",
        "unit_id": 312,
        "voice": "vo_adv_1174002_048"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "把妳救起來了喔。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你明明不太會游泳，是怎麼辦到的……？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "看起來確實不太會呢。",
        "unit_id": 312,
        "voice": "vo_adv_1174002_050"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n然而，他卻把繩子捆在自己身上，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n又將繩子的一端交給我們，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "拜託我們「收到信號後就拉他上來」……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "他勉強靠著自己游了過去，",
        "unit_id": 312,
        "voice": "vo_adv_1174002_051"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "再由",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "這裡的所有人一起把你們拉回來。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n……真是",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "太亂來了。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不過，",
        "unit_id": 312,
        "voice": "vo_adv_1174002_052"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "幸好大家都沒事。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那麼，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我去找人過來，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "你們在這裡等一下！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以你的臉色才這麼蒼白啊。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且眼睛也有點紅……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "都是因為我……",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……對喔。",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種時候",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不應該道歉。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該要說「謝謝你救了我」，",
        "unit_id": 117411,
        "voice": "vo_adv_1174002_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希傳達了發自內心的感謝，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看著這樣的她，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}也露出了笑容。"
    }
]