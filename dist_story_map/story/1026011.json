        "voice": "vo_adv_1026011_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "做得很好哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴總是懶～洋洋的，",
        "unit_id": 190011,
        "voice": "vo_adv_1026011_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像省電模式一樣，所以很難看出來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但她有時也會不小心勉強自己呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你正確察覺到的小細節，一般人絕對注意不到。",
        "unit_id": 190011,
        "voice": "vo_adv_1026011_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你真的很認真地在看著鈴呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴雖然嘴上說很麻煩，",
        "unit_id": 190011,
        "voice": "vo_adv_1026011_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但好像還滿開心的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算獨自一人做不到，",
        "unit_id": 190011,
        "voice": "vo_adv_1026011_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但兩人一起就能做到的事應該有很多吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今後也繼續守護她吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1026011_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
