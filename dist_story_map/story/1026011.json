    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴順利獲得想找的飲料，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與{player}一起走在往伊麗莎白牧場的路上。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "被魔物襲擊的人們都沒事，",
        "unit_id": 102611,
        "voice": "vo_adv_1026011_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還獲得了大量的飲料，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可喜可賀、可喜可賀。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611,
        "voice": "vo_adv_1026011_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有點工作過度了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你背我一下嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在這期間，",
        "unit_id": 102611,
        "voice": "vo_adv_1026011_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會好好睡一覺……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸？",
        "unit_id": 102611,
        "voice": "vo_adv_1026011_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你是為了不讓我睡才發光的嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我、",
        "unit_id": 102611,
        "voice": "vo_adv_1026011_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道了啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我走！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會乖乖",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "自己走的～～！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然努力來上學了，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但果然還是很累……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在保健室睡一下就回家吧……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不好意思～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我身體有點不舒服，請讓我在這裡休息……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒人在嗎？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉呀，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我自己隨便找張床躺下吧。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼啊～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "鬆鬆軟軟的棉被～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不管是",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哪裡的棉被，都令人心情平靜呢～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是心之故鄉～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "晚安～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明是為了不被他發現才溜出來的……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太敏銳了吧……",
        "unit_id": 102632
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是是，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我在喔。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在人家難得要睡了的時候過來，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎樣啊？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "別直接叫我鈴啦。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n被人聽到",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "會很不好意思吧。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "叫我森近……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……啊。",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我擅自跑掉了，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對不起。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我想說",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不能連在學校也給你添麻煩",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "以後我會",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先跟你說一聲的。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……雖然不知道還有沒有下次。",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說回來，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都已經來學校了，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還偷懶是",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不行的吧。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好、好，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我回教室……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是了…………",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你不是來帶我回教室的嗎？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那是～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為還不習慣上學，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難免啦。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我覺得",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你其實沒有必要……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有必要……",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼擔心我……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好奇怪喔？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要是平時的我",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該會很開心地躺回被窩。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼會想要繼續加油呢……",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我看起來有那麼難受嗎……",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我自己是感覺不出來……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但你很了解我，既然你都那麼說了，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "或許……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的是這樣吧？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇～～！？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不用拉我的手，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我自己也會去啦！",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎樣啦。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "和平常不一樣……",
        "unit_id": 102632
    },
    {
        "type": "still",
        "still": "102601101"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚…………",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然很感謝你讓我休息，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但不要把我當小孩子對待啦。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟你同年紀喔。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是同班同學，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你知道吧。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你還要繼續把我當成小孩子啊～？",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說回來，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你不認為我是在偷懶呢。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我實在太～懶散了，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "以至於連我自己，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都不曉得這",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算不算在偷懶……",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這雖然是半開玩笑，",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我今天很不像我，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像太勉強自己了。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不該做自己不習慣的事的～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你有阻止我真是幫了大忙。",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你該不會比我自己",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還要了解我吧？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有人能巧妙地為我管理健康，真是幫大忙了～",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n今後你也要繼續確實地守護我喔。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n拜託你了。",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "………………嗯？",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但這麼一來，",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不就不能偷懶了？",
        "unit_id": 102632
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣也很麻煩啊～",
        "unit_id": 102632,
        "voice": "vo_adv_1026011_036"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你啊，",
