    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就說是連夢中的事也",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一起道謝就好。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n畢竟我總是",
