        "unit_id": 190011,
        "voice": "vo_adv_1156004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的是讓人看了很心急。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是弄個不好，我看就一輩子都是那樣了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明雙方應該都有意思，",
        "unit_id": 190011,
        "voice": "vo_adv_1156004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想法卻總是錯身而過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n彷彿心意相通那天永遠不會到來似的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就看的人來說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是還挺有趣的就是了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……開玩笑的啦，",
        "unit_id": 190011,
        "voice": "vo_adv_1156004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一步一步慢慢來也好，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你就跟優衣好好面對彼此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "努力和對方心意相通吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這也是為了那孩子好喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "懂嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，",
        "unit_id": 190011,
        "voice": "vo_adv_1156004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這下就跨出得到家人同意的第一步了呢♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然一起買東西、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一起並肩回家，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這些事前練習都很順利，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你可以稍微主動一點喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1156004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦。",
        "unit_id": 190011
    },
    {
