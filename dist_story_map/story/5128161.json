    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "もっと、",
        "unit_id": 5313,
        "voice": "vo_adv_5128061_000"
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "サレンおねえちゃんやルカおねえさんと",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\nイチャイチャするべきだと思います。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "おにいさんたちは、",
        "unit_id": 5313,
        "voice": "vo_adv_5128061_001"
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "サレンおねえちゃんたちと夫婦を装って",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\n入国の許可をもらったわけなんですけど……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "それにしては",
        "unit_id": 5313,
        "voice": "vo_adv_5128061_002"
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "雰囲気がぎこちない",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "というか。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "怪しまれるのも時間の問題な気がするんです。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "ちょっとズルかもしれませんけど、",
        "unit_id": 5313,
        "voice": "vo_adv_5128061_003"
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\nボクの力で",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "「幻の結婚生活」を見せてあげますね。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "やっぱり、",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "実際にそういう生活を経験してないのが原因だと思うので。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "これから見るのは、",
        "unit_id": 5313,
        "voice": "vo_adv_5128061_004"
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "全部夢に過ぎませんけれど……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\n愛し合う人との素敵な日々を楽しんで、",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "今後の参考にしてください。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "お二人にも、",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "異国の子ども",
        "words": "同じ夢を見せておきますから。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "こうして不思議な力によって、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n{player}は結婚生活の夢を見るのだった……"
    }
]