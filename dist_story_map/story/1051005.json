[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "走在路上的{player}遇見了深月。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你好……",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，你臉色怎麼這麼差。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你還好嗎……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為工作睡眠不足……？",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是哦，辛苦你了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過你的身體同時也是我的實驗品，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我不接受你這樣亂用哦……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "開玩笑的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我正好有個正在開發的魔法，就用這個來幫你復原吧。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼了？",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊啊，沒關係。不用怕哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個魔法很安全。因為最初的實驗品就在這裡。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我最近怎麼也提不起勁來，",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才想著靠魔法解決，所以最近都在研究這個魔法呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "抑制使人感到疲勞的原因，同時也促使身體復原。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "做出這個魔法公式可是相當麻煩的哦……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，似乎在說明的時候，你已經復原不少了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "稍微活動一下身體看看。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……看吧？沒原來那麼累吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "消除疲勞的魔法看來是開發成功了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，能率直地道謝是件好事呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼就特別附送你另一個魔法？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不用慌張。這魔法不會要你命的啦。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說不定反而會讓你更有精神哦？ ",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要開始了唷！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──汝，從即刻起化為魅惑眾人之萬人迷！",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "剛才的魔法會促進費洛蒙的分泌，並且讓效果加倍唷。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "女性會更容易對你產生好感，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n然後變成瘋狂地追求你的女粉絲哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼了……？為什麼我沒有變？",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對我沒效果是當然的唷。因為……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我已經，喜歡上你了……",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……說笑而已♪",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我裝戴了特製的魔法道具所以沒問題哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "不、不好意思！ ",
        "unit_id": 411,
        "voice": "vo_adv_1051005_015"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "可以借我一點時間嗎！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看吧看吧。馬上就生效了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_016"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我對你一見鍾情了！",
        "unit_id": 411,
        "voice": "vo_adv_1051005_017"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n請和我交往！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎樣？很厲害吧，這個魔法！",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "實驗毫不拖泥帶水馬上成功了呢♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "請等一下！",
        "unit_id": 311,
        "voice": "vo_adv_1051005_019"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n是我先對他一見鍾情的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "你是誰啊！不對，這根本不重要。",
        "unit_id": 411,
        "voice": "vo_adv_1051005_020"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "反正這個人愛的是我！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，輕輕鬆鬆就上鉤了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n突然成了受歡迎的人物，你的感想如何？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "能擄獲他芳心的人，只、有、我♪",
        "unit_id": 1411,
        "voice": "vo_adv_1051005_022"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我不會把他讓給任何人的唷！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……令人意外。何止兩個人甚至三個人都有可能。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n好像從那邊也有一大群人衝過來呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "別逃啊──！成為我的戀人──！",
        "unit_id": 411,
        "voice": "vo_adv_1051005_024"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "你們快讓開！",
        "unit_id": 1411,
        "voice": "vo_adv_1051005_025"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n能和親愛的合而為一的只有我！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "你們很礙事！快讓開！",
        "unit_id": 1211,
        "voice": "vo_adv_1051005_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "人好多！效果比想像中還要好呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "連帶著對男性也有效果。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來能取得有趣的數據呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不行唷。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看著你四處亂竄，我覺得很有趣呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你應該還撐得下去吧？",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n再讓我更開心一點。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，這樣不就收集不到數據了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要繼續下去哦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒關係的。你能撐下去的。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_031"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來吧，為我出盡全力吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "您是要去哪裡？請等我一下！",
        "unit_id": 411,
        "voice": "vo_adv_1051005_032"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "怎能讓你逃走！我不會再離開你了！",
        "unit_id": 311,
        "voice": "vo_adv_1051005_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想知道這個魔法還能持續多久呢，",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你可以繼續再逃下去嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "靠你了哦～！",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "請等一下──！",
        "unit_id": 411,
        "voice": "vo_adv_1051005_035"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "嗯嗯～！別逃得這麼快～！",
        "unit_id": 1411,
        "voice": "vo_adv_1051005_036"
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "你要去哪裡！快點到我的懷抱裡！",
        "unit_id": 311,
        "voice": "vo_adv_1051005_037"
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "這……呼……",
        "unit_id": 1211,
        "voice": "vo_adv_1051005_038"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "你越是逃走，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n越是燃起我心中熊熊慾火呢……！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "歡迎回來。平安逃回來了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "魔法的效果也還在……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "實驗大成功了唷！謝謝♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "抓到你了──！",
        "unit_id": 1411,
        "voice": "vo_adv_1051005_040"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "終於追上你了，親愛的♪",
        "unit_id": 1411,
        "voice": "vo_adv_1051005_041"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那麼作為愛情的誓約，我們馬上來個舌吻吧……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也是呢。雖然現在正精彩，不過這樣下去就超出實驗範疇呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n現在就給你解開……汝輩於此刻自魔法之楔解放！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "……哎呀。我真是的，做了什麼……？",
        "unit_id": 1411,
        "voice": "vo_adv_1051005_043"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "請問您是……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "討厭，已經這麼晚了嗎？要快點去買東西才行！",
        "unit_id": 411,
        "voice": "vo_adv_1051005_044"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大家恢復正常，開始散去了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_045"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n要是再遲了點你的貞操就不保了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "幸好我即刻救援。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為什麼呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051005_046"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "無論對方是誰，看見你快要被親上去的時候，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我就覺得想要立刻解除魔法……",
