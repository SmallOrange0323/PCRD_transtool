[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "…………",
        "unit_id": 118111,
        "voice": "vo_adv_2102005_000"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……因為",
        "unit_id": 118111,
        "voice": "vo_adv_2102005_001"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "會死掉的。",
        "unit_id": 118111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咦？",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……消失",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不見了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n方才的那位女性，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是誰呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然按照過去往例，",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她也是主人所認識的人嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這、",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這真是非常失禮了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是主人您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍然有並不相識的女性呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍微安心了許多。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回歸正題……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請讓在下再一次",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鄭重地向您道歉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n竟然讓主人您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獨自一人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您的力量，",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在要對抗盯上了蘭德索爾的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n全新惡勢力之下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是殺手鐧的樣子……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據情況的變化，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許極有可能會被直接盯上也說不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從今以後，",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必須比以往",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更加片刻不離身地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n守護主人才行呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實相當地擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐想要守護這座城鎮的心情，",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下非常能感同身受……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若有什麼是在下能夠做到的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "勢必會助上一臂之力。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一想到若又因此",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n導致主人您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遭遇到什麼難以預料的危險。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下就",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的非常地恐懼。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不想要再一次經歷，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同那樣的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果像當時一樣，",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "他再次受到致命傷的話……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那麼這一次少年可就沒救囉。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n奇蹟不會發生第二次更不會有第三次……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我希望這事妳能放在心上。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……拉比林斯達小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨。",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這一次的重逢可還真快呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇蹟",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會有第二次與第三次……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說的對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若又得讓主人再次遭受到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "第二次、\n第三次那種對待的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下可絕不容許。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……除此之外。",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n方才，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也一直想著得把這件事傳達給您才行……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的非常地抱歉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦？",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那個。",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是之前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在『那邊的世界』中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉比林斯達小姐所委於在下的事情。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了能使大家",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到『那邊的世界』……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了能使大家想起遺忘了的真實，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請向更多的人傳達出去的這件事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻什麼都",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還來不及辦到就……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳說那個啊～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n沒事沒事，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳別在意。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不用急，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就讓我們鍥而不捨地走下去吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "反而",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳竟然還記得我當時拜託妳的那件事情，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並且這麼真誠地像這樣面對我來表達自己的心情，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這一點還讓我比較高興呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但畢竟",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳還有著一個比任何事都更加重要的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n一個需要守護的人嘛。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下所持有的力量，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在太過於渺小了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在與霸瞳皇帝之戰中……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下根本沒有派上任何用場。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至近乎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "差一點就要失去主人了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而接下來",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盯上蘭德索爾的敵人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n聽聞似乎是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位霸瞳皇帝窮盡全力備戰才得以面對的存在。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次是否還能夠守護住呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n守護住比任何事情",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都更加重要的主人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呵呵。",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳真是個",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "溫柔的孩子呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n究竟是少年的影響呢，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『那個人』給了孩子正確的教育呢……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼。",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我就偷偷的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "告訴妳一件『好事』吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "根據我的推測。",
        "unit_id": 106812,
        "voice": "vo_adv_2102005_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年那股全新的力量……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若想要使用那股『公主型態』之力，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n對妳們這一邊來說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "重要的條件有兩個。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……您說條件",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "首先第一個……",
