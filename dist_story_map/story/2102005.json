        "voice": "vo_adv_2102005_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是『打倒了七冠等級的敵人。』",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你想嘛。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n打倒強敵了",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就能升等，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這也算世間常態了對吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那……",
        "unit_id": 105913,
        "voice": "vo_adv_2102005_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "另一個呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那個嘛……",
