    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "真是不得了的人呢……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "那個，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "可以再問你一次嗎？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "她平時",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "是怎樣的人呢？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "呵呵，",
        "unit_id": 112211,
        "voice": "vo_adv_6033107_001"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "聽你這麼說，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "感覺你們感情很好呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這樣的話，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "跟靜流小姐相反，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "要不要讓我成為你的妹妹呢？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "哥哥♪　",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我開玩笑的……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "忘掉吧。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "討厭，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "快、",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "快給我忘記！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "嗯，",
        "unit_id": 112211,
        "voice": "vo_adv_6033107_002"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "果然完全不知所以然呢！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n不過話說，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你也不知道到底有沒有血緣關係吧？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "姐姐就是姐姐，所以應該是姐姐？　",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "嗯。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "到底在說什麼呀？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "原來如此，",
        "unit_id": 112211,
        "voice": "vo_adv_6033107_003"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "睡在你的旁邊……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不對，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "等等。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n助手先生，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "該、",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "該不會你，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "就那樣子接受了吧！？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "嗯……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "是應該跟你",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "好好來談談",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "危機意識這件事了呢！",
        "unit_id": 112211
    }
