    {
        "type": "dialogue",
        "name": "栞",
        "words": "集訓終於來到最後一天……",
        "unit_id": 125414,
        "voice": "vo_adv_5116451_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的是",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "發生了不少事呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很慶幸",
        "unit_id": 125414,
        "voice": "vo_adv_5116451_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "自己有來參加這個集訓。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我重新明白到……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "自己想珍惜的人、",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "想珍惜的事物，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "究竟是什麼。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以，",
        "unit_id": 125414,
        "voice": "vo_adv_5116451_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首先想要對那個在等著我、",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "等著我們回家的人，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說聲：「我回來了。」",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 125313,
        "voice": "vo_adv_5116451_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是。",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想要與等候我們回去的夥伴們",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n分享這次集訓的種種經歷。",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，栞小姐，",
        "unit_id": 125313,
        "voice": "vo_adv_5116451_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "集訓還沒有結束喔。",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到今天的最後一刻為止，",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都要保持專注。",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要確實地完成任務，",
        "unit_id": 125313,
        "voice": "vo_adv_5116451_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才是獨當一面的遊俠。",
        "unit_id": 125313
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵……",
        "unit_id": 125414,
        "voice": "vo_adv_5116451_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒錯。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n直到最後一刻",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都不可大意呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這是為了讓我們",
        "unit_id": 125414,
        "voice": "vo_adv_5116451_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能夠抬頭挺胸地說出",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「我回來了」這句話。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天也一起加油吧。",
        "unit_id": 125414
    }
]