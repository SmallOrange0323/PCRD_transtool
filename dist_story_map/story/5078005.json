    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這種",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "詭異的氣氛真是令人欲罷不能～",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "流口水………",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "對空花的妄想",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "大有幫助～！",
