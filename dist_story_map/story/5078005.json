        "voice": "vo_adv_5078005_002"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "椅子坐起來舒服嗎？",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n太硬的話",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "隨時都可以坐到姐姐膝蓋上哦？",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "反正弟弟",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "是這座城堡的主人，",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "想做什麼都儘管說沒關係哦♪",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "那個～",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "對了，",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_004"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "要不要蓋一間圖書室啊。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n畢竟學生們也需要地方唸書嘛。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n裡頭還得放些酸酸甜甜的少女漫畫……",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "呵呵呵♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "圖、",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_005"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "圖書室！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n裡面",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "擺什麼書都可以嗎？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這樣的話那我，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花也",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "有書想放在裡頭……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "哎呀，",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_006"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "當然很歡迎囉♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "唔，",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_007"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "我感覺到了不健全的氣息！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n空花，",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "先讓姐姐看看",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "妳想擺進去的是什麼書籍吧？",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n我要檢查看看",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "會不會對弟弟造成不好的影響。",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "方便打擾一下嗎～？",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_008"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "說、",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_009"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "說什麼不健全啦，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "靜流妳誤會了～！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "那是把少女漫畫的內容",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "表現得稍微大膽一些，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n閱讀起來",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "會讓身體變得火熱的",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "愛與希望與慾望的故事～！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "有那種書啊？",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_010"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "那搞不好我也想讀讀看呢。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n閱讀起來會讓身體變得火熱，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "那到底會是什麼樣的書呢。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "妳說呢，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "靜流？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "……",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_011"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "弟弟，",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n絕對不准看那邊的詭異老師和變態受虐狂喔！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n因為她們不健全！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "只有姐姐我",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "才是健全的！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "喂喂有聽見嗎？",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_012"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "妳們聽得見",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我的聲音對吧？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "靜流",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_013"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "是不是對我們抱有誤會……？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "我說，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "你應該懂我們對吧？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n我們是",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "健全的對吧？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "我就說吧？",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_014"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "這孩子分得很清楚的。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "靜流妳也",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "仔細看著我……♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n我很健全吧……♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "太近了太近了太近了！",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_015"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n弟弟，",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "這位老師靠得太近了啦！？",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n這樣沒問題嗎！？",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "應該很有問題吧！？",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "妳看吧！",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_016"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n弟弟他",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "雖然猶豫很久",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "但還是開口這麼說了！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "那、",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_017"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "那是因為黑暗力量的關係……！",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "對了，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "平常的我",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "是很認真的老師對吧？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n不會魅惑人的對吧？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "被指名道姓了！？",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_018"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n虐待狂先生",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "對空花指名道姓了是嗎！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "那麼，",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_019"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "「空花嘛」……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "的這句話之後",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "要接的是什麼？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n空花",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "真的非常在意～！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "不管罵得有多難聽",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花都願意接受～♪",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "……或許是不健全呢。",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_020"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "就是說啊。",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_021"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "真是的──！",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_022"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n大家",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "聽我說好嗎！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "？",
        "unit_id": 1,
        "voice": "vo_adv_5078005_023"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "各位最近",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_024"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "一直待在基地裡，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "每天自由隨性地生活著！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "是不是把",
        "unit_id": 4211
    },
    {
