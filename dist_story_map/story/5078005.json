        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "都在搖晃……！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "大、",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_068"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "大家小心點！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n這傢伙的黑暗力量……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "和過去完全不同！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n到底是怎麼得到這股力量的……！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "反逆獸 ",
        "words": "我只是從頭再做一次一樣的事罷了！",
        "unit_id": 15312,
        "voice": "vo_adv_5078005_069"
    },
    {
        "type": "dialogue",
        "name": "反逆獸 ",
        "words": "\n隱藏起來，",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸 ",
        "words": "蓄積黑暗力量！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸 ",
        "words": "\n畢竟隱藏氣息是我的專長！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "就算如此，",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_070"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "這股高漲的力量是……！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n你到底是",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "怎麼獲得這麼龐大的力量……！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "這方面",
        "unit_id": 15312,
        "voice": "vo_adv_5078005_071"
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "我還得感謝各位！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "\n多虧這座基地聚集的黑暗力量，",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "\n我才能成長到如此地步──！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "難不成是躲在基地裡，",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_072"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "將我們的力量……！？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "偷偷從空花一行人",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_073"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "身上吸取了力量是嗎！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "做法很狡猾……",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_074"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "也很聰明呢……！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "因為妳們的黑暗力量太強大了！",
        "unit_id": 15312,
        "voice": "vo_adv_5078005_075"
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "\n放養",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "再加以利用才是最好的辦法！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "多虧妳們，",
        "unit_id": 15312,
        "voice": "vo_adv_5078005_076"
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "我才能夠",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "變得這麼強……！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "人們",
        "words": "黑暗之王……",
        "unit_id": 1,
        "voice": "vo_adv_5078005_077"
    },
    {
        "type": "dialogue",
        "name": "人們",
        "words": "萬歲……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "接下來我要打倒妳們，",
        "unit_id": 15312,
        "voice": "vo_adv_5078005_078"
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "將這座基地納入囊中！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "\n嘰────嘰嘰嘰嘰！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "對方不愧是敢於現身……！",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_079"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "騎士大人！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "在沒有魔法少女的狀況下是沒有勝算的！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n現在該逃──",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "就是說啊，",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_080"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "摩拉。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n不好意思，雖然不是魔法少女，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n不過這裡有我們在。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_081"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "也能夠戰鬥……！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n我想讓忘記了受虐的人們，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n想起這件事有多麼舒服……！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "就算是黑暗力量",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_082"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "我也會運用自如的。",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n只要弟弟陪在我身旁。",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "各位……！",
        "unit_id": 4211,
        "voice": "vo_adv_5078005_083"
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "挺有膽量的！",
        "unit_id": 15312,
        "voice": "vo_adv_5078005_084"
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "\n不過",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "妳們一直以來對我的阻礙……",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "\n對我的反抗……",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "我一定會讓妳們後悔……！",
        "unit_id": 15312
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "彼此彼此。",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_085"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n搶走我的可愛學生們這件事……",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "我不會原諒你的。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "讓黑暗老師",
        "unit_id": 101812,
        "voice": "vo_adv_5078005_086"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "好好教育你！",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "不管你變得多麼強大，",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_087"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花的心靈都不會動搖！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "黑暗被虐狂，",
        "unit_id": 104512,
        "voice": "vo_adv_5078005_088"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "會讓你極樂升天！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "你讓我重要的弟弟受苦。",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_089"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "\n我戰鬥理由",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "有這一點就足夠了！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "由黑暗姐姐",
        "unit_id": 120017,
        "voice": "vo_adv_5078005_090"
    },
    {
        "type": "dialogue",
        "name": "黑暗靜流",
        "words": "來懲罰你！",
        "unit_id": 120017
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "是啊！\n好！\n嗯！",
        "unit_id": 1,
        "voice": "vo_adv_5078005_091"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與反逆獸的決戰",
        "unit_id": 1,
        "voice": "vo_adv_5078005_092"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "終於開始了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n同樣的黑暗力量互相角力。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這場戰鬥的勝負關鍵，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "並不僅只有愛與希望……！",
        "unit_id": 1
    }
]