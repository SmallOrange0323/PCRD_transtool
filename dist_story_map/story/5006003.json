[
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面……\n感受到異狀而進入『王宮』內的純，\n目擊到了不可思議的景象。"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "你、",
        "unit_id": 711,
        "voice": "vo_adv_5006003_000"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "你要幹嘛？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n為何突然攻擊，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "該不會是要謀反？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "嗚呀啊啊啊啊啊！！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……這是",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "什麼狀況？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團（NIGHTMARE）】的成員正在\n刀劍相向……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "互相殘殺嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好好的同伴，怎麼會變成這樣？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……唔？",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不是說可能會有危險，叫你先回去了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你能聽進年長者的話。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你好好反省。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果你受了傷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我會一直很愧疚的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然這麼說很任性……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但希望你能為了我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好好珍惜自己的身體。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很高興能有你這份心意，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但這是沒有必要的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為這是我的工作，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我本來就知道它的危險性。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n再說你也只是個",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身處和平的善良市民而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……哎呀，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看來我沒有閒功夫可以悠哉聊天。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "到處都有暴徒橫行，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不應該任意移動才是。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "快來躲在我身後。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然還不清楚現在的情形，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但得先制止正在戰鬥的大家。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們幾個！　",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是在鬧什麼？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n立刻",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "停止戰鬥！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在充滿高貴之人的『王宮』中",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大聲喧鬧又胡言亂語，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這可是會遺臭萬年的！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "啊啊啊，",
        "unit_id": 712,
        "voice": "vo_adv_5006003_012"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "團長！　",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "團長是正常的吧？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n這、這傢伙，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "不知為何突然襲擊我……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "噫呀！？",
        "unit_id": 712
    },
    {
        "type": "still",
        "still": "500600301"
    },
    {
        "type": "dialogue",
        "name": "純？",
        "words": "…………",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呣？",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_013"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "嗯，",
        "unit_id": 712,
        "voice": "vo_adv_5006003_014"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "奇怪？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n有兩個團長……？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "咿！？",
        "unit_id": 712,
        "voice": "vo_adv_5006003_015"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "危險！",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你別光害怕站著不動，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "至少得做出抵抗啊！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "平時是為了什麼而做那些嚴格訓練，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不就是為了應付這種緊急狀況嗎！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "是、是的！",
        "unit_id": 712,
        "voice": "vo_adv_5006003_018"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "\n抱歉，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "但是",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士隊長",
        "words": "完全搞不清楚狀況……！？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不也一樣嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但也不能不處理吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "保護『王宮』內的安全，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是我們【王宮騎士團（NIGHTMARE）】最優先的事項。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "牢騷等結束再說！",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團（NIGHTMARE）】的全員，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若能理解我說的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就趕緊準備應付狀況。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了正義和和平，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "盡你們最大的力量！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈☆",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你還是一如往常的認真優等生形象，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n淨說些無聊的話呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲提娜副團長！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在這種混亂的情形下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就別露出一副理所當然的樣子啦，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還是你早知道會這樣？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，只是偶然呢。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是這混亂的情況吸引我來的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我正跟『陛下』一起享受喝茶時光，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n被這情況打擾到，挺火大的喲。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你這傢伙，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "神智清醒嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "常有人這樣問我。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但說實在，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底有沒有理智是由誰來評斷的呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "又該用什麼標準來評斷呢？",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說不定連神都無法判別呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "非神的我們，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也只能以自己的標準……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n基於自己的正義感行動而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這就是【王宮騎士團（NIGHTMARE）】的規矩吧？團長♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說的也是。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n太好了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲很冷靜呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我已經說過很多次了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以叫我『克莉絲』的只有我朋友！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且我也只是隨便說說的，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你把他當真害我覺得怪不好意思的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是愚蠢呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "虧我還很開心能和不擅言談的團長閒話呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果要模仿，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就該學得像一點呀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "完全沒有讓人稱讚的價值呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊真讓人不悅！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那劍法和動作，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一點都不俐落，太空洞了！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不像樣！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n簡直就是個笑話呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果你打算以這種程度模仿團長的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不過是光有外表罷了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可是對連我都認同的團長，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不，應該說是對騎士的",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "天大侮辱！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會奪下你的首級，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以就一邊親吻地板，一邊為你的不敬懺悔吧！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "純？",
        "words": "──呱喔喔喔喔喔！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唔，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒什麼手感。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚哇……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看到和自己外貌相同的人的頭被砍下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還真的不太舒服呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有，克莉絲，",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不可以在不知對方來歷的情況下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就不由分說地殺了對方。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……還真是善良。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是話說回來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺對方也不是能用一般方式來對付的角色？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 104714
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……復活了？",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n明明就把頭也砍下了說？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 713
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而且還聚集了更多詭異的傢伙呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底是怎麼回事，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然好像不是很強……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但搞不清楚身分，也夠讓人覺得恐怖了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不知道，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就像惡夢一樣呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該不會是那個，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近傳言中的『闇影』？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是那個長得幾乎跟現實中存在的人一樣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n類似魔物一樣",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的東西嘛……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我也和他們交戰過幾次，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但覺得好像不太一樣？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過也僅止於直覺就是了。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要用能殺死一般人的攻擊去對付『闇影』，通常就能打倒他們了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這些傢伙就算頭都落地了，手腳也都飛了還是像沒事一樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n剛剛稍微看到了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "鎧甲裡可是空的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『闇影』雖然曖昧不明，但至少擁有類似肉體的身軀，",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n剛剛那些傢伙則好像是只有表面一般。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真無趣呢。",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還想一邊享受切進肉體的手感，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一邊在悲鳴中享受戰鬥的歡愉的說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還真不懂克莉絲的興趣呢……",
        "unit_id": 104711,
        "voice": "vo_adv_5006003_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果不是『闇影』的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼那些傢伙到底來者何人？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "誰知道呢？",
        "unit_id": 107111,
        "voice": "vo_adv_5006003_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我也不是學者才不知道呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也沒什麼興趣就是了。",
        "unit_id": 107111
    }
]