    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霞跟{player}在海邊盡情玩耍後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再一次試著打聽出事件的情報。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呼～",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "吃得好飽。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生的豬排蓋飯",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "味道又如何呢？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就開始偵訊吧。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你也差不多該說出口了吧？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你在搬運的貨物……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "究竟是什麼？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就連對我也不能說嗎？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "抱歉抱歉。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不是想造成你的困擾。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你是想說",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "保密義務嗎？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你也懂一些很艱深的詞呢。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等等，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這應該是我教你的……？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……唔。",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然作為偵探的助手，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "堅決守護委託人祕密的想法",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是非常正確的……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是我很擔心啊。",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n想說助手先生會不會",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n跟危險的事情扯上關係……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你是個很純真的人，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算有人想利用你這單純的個性也不奇怪。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒問題，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是嗎……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再繼續問下去也不是辦法。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我並非不相信助手先生……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但果然",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是會擔心。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣的話，只能著手調查",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n身為交易對象的那群男人──",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "欸嘿嘿。",
        "unit_id": 911,
        "voice": "vo_adv_1157003_011"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "嗨，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "小哥。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔！？",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_012"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "你還在這附近閒晃啊。",
        "unit_id": 811,
        "voice": "vo_adv_1157003_013"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "嘻嘻嘻……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是剛才的男人們……！　",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_014"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "這下正好。",
        "unit_id": 911,
        "voice": "vo_adv_1157003_015"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n我們又有事情要拜託你了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "可以聽一下嗎……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "放心，",
        "unit_id": 811,
        "voice": "vo_adv_1157003_016"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "只是件簡單的工作。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "\n這是最後一次了，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "拜託啦……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等、",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等一下！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這可不行！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "啊？",
        "unit_id": 911,
        "voice": "vo_adv_1157003_018"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n小姑娘有什麼事嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是一位偵探。",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是活躍於蘭德索爾的……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "優秀偵探。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "妳說是偵探……！？",
        "unit_id": 811,
        "voice": "vo_adv_1157003_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然表明身分會有危險，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但只要能讓他們因此不對助手先生出手的話……！　",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "哦，",
        "unit_id": 911,
        "voice": "vo_adv_1157003_022"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "原來是偵探啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n這下正好！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "我說小哥，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "你能不能跟這位偵探小姑娘",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n一起幫我找個東西？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼！",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不可以，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這樣太危險了！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "妳說危險～？",
        "unit_id": 811,
        "voice": "vo_adv_1157003_024"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "嘻嘻嘻……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "或許是",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "這樣沒錯啦。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "對啊，",
        "unit_id": 911,
        "voice": "vo_adv_1157003_025"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "雖然有點危險……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n但這位偵探不是很厲害嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "那應該很輕鬆吧……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這兩個男人難不成……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n打算把已經沒用且礙事的助手先生，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n還有打聽太多事情的我給解決掉嗎……！？　",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……助手先生打算接下這份委託。",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我不能放著不管……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我知道了，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就這麼辦吧。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也會一起去。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "答應我這是你們最後一次利用助手先生了。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "沒問題，",
        "unit_id": 911,
        "voice": "vo_adv_1157003_029"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "我答應妳……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "\n這就是最後了……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要肯聽話就沒有其他用處了，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是這個意思嗎……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n真是狡猾……！　",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好、",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好的。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "放心吧。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我一定會保護你……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "拜託你們囉，",
        "unit_id": 911,
        "voice": "vo_adv_1157003_032"
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "欸嘿嘿……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "兩個人要同心協力……",
        "unit_id": 811,
        "voice": "vo_adv_1157003_033"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "嘻嘻嘻……！",
        "unit_id": 811
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想想……",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他們委託的物品……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是棲息在這附近的魔物身上的爪子，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對吧。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他們說只要在沙灘上找就會有，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n沒有必要戰鬥……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但不能掉以輕心。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可不要放鬆戒備了。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "找到委託的東西後，",
        "unit_id": 115711,
        "voice": "vo_adv_1157003_036"
    },
    {
        "type": "dialogue",
