[
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我回來了～♪",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鈴莓～在嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會談稍微延長了呢，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n原本想回自己的大屋，但看來要明天才回得去了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天就在這邊過夜囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正，明天也要到蘭德索爾辦些瑣碎的事情嘛。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是為了睡覺而趕回位於深山的大屋，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n挺浪費馬車費用的呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要節省一點呢～",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【咲戀育幼院】也可能會用到錢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓？",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不在嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚呀，是！",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我現在就過去，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請稍等一下～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "抱歉，我剛剛在收衣服！",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "歡迎回來，大小姐～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……呀嗚！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "危險啊！",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "小心一點嘛，真是冒失呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有沒有受傷啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，是的！",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鈴莓今天也很有精神，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有精神是我唯一的優點♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說什麼有『有精神』啊……",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n已經深夜了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這麼吵鬧會影響鄰居的呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……啊～",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這邊的地板有起伏呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以才會踢到呢，真是危險呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n請專人……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不，這種程度的話我應該能自己想辦法吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "事不宜遲，趕緊開工吧。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在工程結束之前，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n記得告誡小朋友們不要靠近這裡呦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，大小姐！",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那種程度的問題，稍後我來處理就好了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n話說，您起碼先換件衣服～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也是呢～",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算想要進行作業，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也不能用槌子之類敲敲打打製造噪音。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "留在明天做吧。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼啊（呵欠聲）♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈，",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐打了個大哈欠。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您應該很累了吧……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呦，我真是不端莊呢……",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n抱歉失禮了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓，今天的狀況如何呢？",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n抱歉呢，把育幼院的管理全交給妳。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "直到所有工作整理出頭緒，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我都要在蘭德索爾和大屋來來回回，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "即使如此，我也不能把小朋友們放著不管對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是啊。",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐十分忙碌呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這裡就交給鈴莓吧，",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我老是犯迷糊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "孩子們都很乖巧聽話，",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以還算沒問題♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯呀。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們家的小孩們，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都是好孩子……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不會的。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了讓這些好孩子們能笑容滿面，安心的生活……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我每天都會努力的呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～我現在充滿鬥志了呢。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有沒有什麼可以給我做的？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有沒有，",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐請休息吧～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "～……♪",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n下、下一個是噗吉……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喔嗚。",
        "unit_id": 2111,
        "voice": "vo_adv_3003001_028"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我是技術員，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n會讓你噫噫的叫喔』。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n噫噫……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呦？",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說妳們呀，現在已經是好孩子睡覺的時間了喔～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們還在做什麼呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇，啊……",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀嗚，那個……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噫，對、對不……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『喔。\n咲戀大小姐現在剛回來啊。",
        "unit_id": 2111,
        "voice": "vo_adv_3003001_032"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n每天都辛苦你了呢？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "歡迎回來～",
        "unit_id": 102311,
        "voice": "vo_adv_3003001_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咲戀媽媽♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "歡、歡迎、回來！",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咲、咲咲咲、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要叫我『媽媽』啦……",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我還只有十七歲喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我不在意就是囉……",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "兩位好呀，我回來了♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『哎呀，",
        "unit_id": 2111,
        "voice": "vo_adv_3003001_037"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n把我給忘記了，會令我很困擾喔。』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n噗吉，我回來了喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起這個，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n大家坐在地板上做什麼啊？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果是在做什麼壞事的話，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那我要處罰妳們了呦～♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇，噫！",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很、很癢啊！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽……哈哈♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你看，我們在玩玩具！",
        "unit_id": 102311,
        "voice": "vo_adv_3003001_042"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "超開心的，現在在育幼院裡很流行的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個，這個像積木似的東西♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊……",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是疊疊樂呀，真令人懷念呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n以前我經常玩的，為何有這個呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "生活日用品的話，應該是一應俱全都買齊了，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但這種東西，我不記得我有買過呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是、是鈴莓姐姐……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n說說、說『大家一起玩吧』……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓？",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是這樣嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，是的。",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "育幼院終於將床等各種物品備齊了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但孩子們卻沒有什麼事可做……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以我準備了玩具、繪本等東西。",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其中大部分是我的舊物品，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不足的部分我用零用錢買齊了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這、這樣不行嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我並沒有動用到【咲戀育幼院】的錢……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當然不會不行呀，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一點都不會。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "倒不如說，為何要自掏腰包呢？",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這樣的支出應該歸在【咲戀育幼院】",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n的營運資金裡不是嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "收據呢，有拿嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，咦？",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這個嘛～……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不管買什麼東西都一定要記得拿收據，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我不是一直都這樣交代嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大概的金額就可以了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n待會把支出金額彙總一下吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也是呢，繪本之類的是必要的。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這裡是為了給小朋友生活的地方嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真失策～忘記了這重要的事呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "多謝妳，鈴莓。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然妳很冒失，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但總是留意到一些重要的事情呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "乖～乖～♪",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哇？",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐，請、請饒了我吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n竟然在孩子們面前！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊！好奸詐喔！",
        "unit_id": 102311,
        "voice": "vo_adv_3003001_060"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咲戀媽媽～我也是乖孩子，摸摸我的頭吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也給噗吉，還有胡桃摸頭吧♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，呀？",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_061"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我、我也有……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當然呦，大家都是好孩子～♪",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我愛著你們喔，給妳們抱抱☆",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇、呀……",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_063"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "疊＊樂，倒了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不如也讓我加入吧。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很會玩呦～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種集中精神的玩意♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "當然，我不會輸的！",
        "unit_id": 102311,
        "voice": "vo_adv_3003001_065"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果我贏的話就要摸摸我的頭喔，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要更常回家喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就、就是啊……",
        "unit_id": 102111,
        "voice": "vo_adv_3003001_066"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n覺、覺得很……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "寂寞！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我很清楚，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我的歸宿就在這裡呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以開口說出「我回來了」，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_068"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是相當幸福的事情呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吶，",
        "unit_id": 102811,
        "voice": "vo_adv_3003001_069"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鈴莓也是這樣想吧♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_070"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是這樣沒錯啦～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以，",
        "unit_id": 102511,
        "voice": "vo_adv_3003001_071"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n總之請大小姐去休息吧～！",
        "unit_id": 102511
    }
]