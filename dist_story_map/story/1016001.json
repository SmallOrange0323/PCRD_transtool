    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}到零食店時，\n先到的客人正在抱頭苦思。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是什麼！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "醋昆布口味的美味棒什麼的，超好笑～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，這邊的糖球也超可愛～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好～",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "決定了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "全部都買下來。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天是特價日對吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "1500盧幣打八折是……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那樣的話，是多少錢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該怎麼計算才好呢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……不知道錢夠不夠？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n現在手頭還滿吃緊的呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶，",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那邊的人！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "來幫人家一下嘛。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣的話，是多少錢？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "幫人家算算？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃？只要從1500中扣掉 20％……？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "百分比什麼的，人家才不懂呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "扣掉20盧幣就行了嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是不懂那個才拜託你呀。",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶，好不好？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n幫人家計算一下嘛。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼？紙和筆……",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要紙筆的話，人家有喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拿去，這樣就可以了吧？你要用來做什麼呢？",
        "unit_id": 101611
    },
    {
        "type": "still",
        "still": "101600101"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喔～寫了滿滿的數字！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是叫算式嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像學者！好有趣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……吶，還沒好嗎～？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n計算這個有那麼難嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n難不成正在苦戰中？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，算出來了嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是多少錢？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "1200盧幣？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了～那樣的話應該就可以買了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你真的超厲害的耶！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "百分比這種計算也會，超厲害的不是嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的話，就算用上一輩子也算不出來。",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然還是你厲害！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然要多稱讚你一些！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家心裡正不斷大力讚美你喔！",
        "unit_id": 101611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你難不成……是香才？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃？你不知道嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說到香才，就是香才呀！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為，不就是那樣寫的嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像是什麼才之類的，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺像那樣的字？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才……？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那個字，是讀作秀才嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不愧是秀才！知道的真多～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，今後就叫你秀才囉！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，叫人家鈴奈就可以了喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才這個稱呼感覺還挺不錯的，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n今後也請多指教囉～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，在這邊等一下喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家買完這個點心就回來。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "久等啦～",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n跟秀才說的一樣，是1200盧幣喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "錢也足夠，真的幫了大忙～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拿去，",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個糖果給你！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是剛剛買的。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是人家給你的謝禮。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個是人家推薦的口味！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家覺得秀才一定也會喜歡的。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓人家來餵你好了？",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "來，張～嘴……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "啊，那是！",
        "unit_id": 411,
        "voice": "vo_adv_1016001_028"
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "那不是超級名模鈴奈嗎！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "呀～！是鈴奈～！",
        "unit_id": 1211,
        "voice": "vo_adv_1016001_029"
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "\n好可愛～！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "糟糕，臉被認出來了！",
        "unit_id": 101611,
        "voice": "vo_adv_1016001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼秀才，下次見囉！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "下次見面會再好好地感謝你！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴奈一面被眾多女性粉絲窮追不捨，\n一面逃了出去。"
    }
]