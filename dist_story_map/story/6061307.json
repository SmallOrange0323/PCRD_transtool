[
    {
        "type": "background",
        "background": "500662"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好～了，",
        "unit_id": 115911,
        "voice": "vo_adv_6061307_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣任務就結束了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然遇到不少事，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但我們能做的都做了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也辛苦了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n回到鎮上後",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就好好休息吧。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 115911,
        "voice": "vo_adv_6061307_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你不是差點就沒命了嗎……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像你那樣",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在苦中也能作樂的地方，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我也很想向你學習呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔、",
        "unit_id": 115911,
        "voice": "vo_adv_6061307_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔喔。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這種稱呼方式以後就聽不到了呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說我的課程很棒？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "下次再有機會你要繼續學嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓真琴老師來教你！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 115911,
        "voice": "vo_adv_6061307_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你怎麼露出看似很惋惜的表情啊……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然你這麼說，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我可以只穿給你一個人看。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要對公主保密喔？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不然她八成又會做新的禮服了。",
        "unit_id": 115911
    }
]