    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "放尊重點！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "YO在那邊拿我說嘴！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
