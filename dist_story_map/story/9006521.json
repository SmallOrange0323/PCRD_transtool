        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很眼熟的難搞傢伙",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "居然手牽手搞合作。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n簡直是復活的強敵",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "夢幻同台。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是在演劇場版喔？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "巨大優妮藝品",
        "unit_id": 110911,
        "voice": "vo_adv_9006521_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "加上巨大優妮機器人──",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "本來聽說是討伐魔物，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但現在根本是優妮祭典嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不要擅自舉辦敗壞人名聲的祭典。",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我再重申一次，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那兩次事件我也是受害者。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "先不管那個，",
        "unit_id": 110811,
        "voice": "vo_adv_9006521_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼這兩個傢伙又學不乖復活了啊？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聽學長說，",
        "unit_id": 110911,
        "voice": "vo_adv_9006521_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好像是個年齡不明，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "叫作彌勒的斯文大叔，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n到處復活已經終結的災難。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呵～",
        "unit_id": 110811,
        "voice": "vo_adv_9006521_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真好笑，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那不是糟透了嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我可是一點都不想再見到這兩個傢伙。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "吵死了～",
        "unit_id": 13211,
        "voice": "vo_adv_9006521_007"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "禿頭。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n妳以為我們想看到妳們啊，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "三個白癡。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啥？",
        "unit_id": 110811,
        "voice": "vo_adv_9006521_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你說什麼？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "再說一次？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你這破銅爛鐵醜八怪，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "信不信我拿廢油灌你？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你被資源回收之後，個性還是一樣渣啊？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "它的個性，",
        "unit_id": 110911,
        "voice": "vo_adv_9006521_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像是照克蘿依學姐設定的說。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各位──！",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n對、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起我來晚了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也要加入戰鬥──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧！？",
        "unit_id": 110911,
        "voice": "vo_adv_9006521_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，不行，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳現在過來的話……！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "聊天功能──",
        "unit_id": 13211,
        "voice": "vo_adv_9006521_012"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "目標，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "碧。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "糟了，",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "碧，快做好準備！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n它們的聲波攻擊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會透過聽覺侵蝕目標的神經系統！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無情的咒語會打擊心靈，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓妳瞬間喪失自我！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什麼！？",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n它它它、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它們會對我說什麼！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "公會走失兒童。",
        "unit_id": 13211,
        "voice": "vo_adv_9006521_015"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "【森林守衛】看家組。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "自虐和當笑柄是妳的精神安定劑。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n拚命三郎過氣諧星。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "妄想半裸露營者。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n每天舉辦無觀眾無轉播，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "演給無機物看的個人Live。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不管用……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你說的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一點",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "都不在意……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "糟糕！",
