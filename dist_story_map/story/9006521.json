        "type": "dialogue",
        "name": "碧",
        "words": "YO聽你老生常談重講一遍！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "膩得像盤培根蛋麵，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吃個幾口留你顏面！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "Yeah！",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是嗆爆了！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算是它們，這下子也回不了嘴──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "妳說妳邊緣？",
        "unit_id": 13211,
        "voice": "vo_adv_9006521_028"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "我聽妳在嘴！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "角色賣點早就崩毀！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n那間校舍？",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "那座工廠？",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "諒妳不敢Call人過來大團圓！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "認知障礙根本是無病呻吟！",
        "unit_id": 13211,
        "voice": "vo_adv_9006521_029"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "「沒朋友」只是方便妳找藉口逃避！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n缺乏的其實是手段和骨氣！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "一旦承認就得結束掰掰邊緣這個假議題！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n伸手就能抓住的蜃樓泡影！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "跨出那一步的勇氣到底在哪裡？",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "妳這屁孩就跟妳的名字一樣屁！",
        "unit_id": 13211,
        "voice": "vo_adv_9006521_030"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "所謂孤獨才不是妳自認為有的病！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n裝死躺平還好意思自號孤寂！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "只會裝熟最好拿得出認真的勇氣！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n「想交朋友」嘴巴說說怎麼可能有戲！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "勸妳早點放棄一輩子龜森林裡！",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊啊啊啊啊啊啊──────！",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不、",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不妙！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n碧的腦波波動進入危險區域……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n由於存在證明遭到否定，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她正在喪失內在的自我！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_9006521_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳乘著好像很有一回事的節奏都說了些什麼啊！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣太超過了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳還是不是人啊！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "又不是我，",
        "unit_id": 110811,
        "voice": "vo_adv_9006521_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我百分之百是冤枉的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n而且音源根本是妳的聲音吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚嗚……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊啊啊啊─────！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "喔",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊啊啊─────！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳們看。",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n以大叫反應多樣性著稱的碧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n現在",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只發得出單調的音節……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這下傷得不輕啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈、",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈哈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哈哈哈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n優花梨小姐～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種菇類，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有彩虹女神的味道耶～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n哇，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "純小姐盔甲底下，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來是宏觀大宇宙啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不好了。",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n因為腦內物質過度分泌，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "碧和神明跟宇宙建立起連結了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣下去，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她會知曉世間萬物一切的真理。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂～",
        "unit_id": 110811,
        "voice": "vo_adv_9006521_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "碧～？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳還好嗎～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "趕快醒醒吧～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要準備開始戰鬥囉～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃……",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "奇怪，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿依……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "早安……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n對了，妳聽我說，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我剛剛窺見了真理之門了──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位，我們上！",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n讓我們閉上不停口出惡言的機器，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還有旁邊那尊前衛泥巴人偶的嘴！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟我來──！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊──！",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請等一下，我也要幫忙～！！",
        "unit_id": 104011
    }
]