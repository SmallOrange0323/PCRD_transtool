        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧雖然努力硬撐，但眼淚很明顯已經快潰堤了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "碧，別哭，",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳要嗆回去。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳不斷磨練的無形武器，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不就是要用在這種時候嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什、",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什麼？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我有那種武器",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗆爆它，碧──",
        "unit_id": 110811,
        "voice": "vo_adv_9006521_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不對，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是MC BenYen。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "內心是狂風暴雨！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "Free Style鑽研徹底！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "麥克風所向披靡！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啥！？",
        "unit_id": 104011,
        "voice": "vo_adv_9006521_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在這種關頭，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我該不會要被迫表演自學的搞笑饒舌吧！？",
        "unit_id": 104011
    },
