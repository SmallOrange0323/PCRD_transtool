        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依，",
        "unit_id": 111011,
        "voice": "vo_adv_9006521_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "給她點伴奏。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "用妳超狂的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "人聲節拍器引導她吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳是想說節奏口技吧？",
        "unit_id": 110911,
        "voice": "vo_adv_9006521_023"
    },
