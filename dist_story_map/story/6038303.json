[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，學弟。",
        "unit_id": 111011,
        "voice": "vo_adv_6038303_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不覺得很奇怪嗎，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這到底是怎麼一回事。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "以無視規則的殘忍打鬥聞名的克蘿依，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "面對那個叫什麼美冬師傅的人，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n竟然只會說",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「我覺得很好」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我聽說她是你的師傅，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她究竟是什麼人？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_6038303_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "重視效率、討厭浪費那一型的人啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有種理科人的味道。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若說對此沒有共鳴那我就是在說謊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我在擺設自己房間的配置時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也是以效率為最優先的考量。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然世間好像稱之為亂成一堆沒在收。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔～",
        "unit_id": 111011,
        "voice": "vo_adv_6038303_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "出生在大家庭的長女所以要到處打工啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來她們的際遇很相像呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依在家也一直都是個好姊姊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是或許她自己其實也很渴望",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有個像姊姊一樣的女性在身邊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那選我不好嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "龍殺手啊……",
        "unit_id": 111011,
        "voice": "vo_adv_6038303_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依對這一類孩子氣的別名特別沒有抵抗力呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我決定今後也冠上別名，叫",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「象牙的大學者」吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很難懂？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽不懂的話就本末倒置了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是博學的優妮。",
        "unit_id": 111011
    }
]