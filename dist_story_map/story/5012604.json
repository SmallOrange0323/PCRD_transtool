        "voice": "vo_adv_5012604_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是好難為情啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n在別人面前穿成那個樣子，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "以後再也不想了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、",
        "unit_id": 105511,
        "voice": "vo_adv_5012604_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "　我，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "覺得非常開心。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感覺和大家變要好了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "當、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "當然和前輩也……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞，",
        "unit_id": 105511,
        "voice": "vo_adv_5012604_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "接下來要做什麼？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接下來就是大家最喜歡的",
        "unit_id": 101411,
        "voice": "vo_adv_5012604_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "埋伏監視的調查時間了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃～",
        "unit_id": 104311,
        "voice": "vo_adv_5012604_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我記得埋伏監視調查",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為了掌握證據，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而一直盯著對象",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "進行監視的樣子？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說得沒錯。",
        "unit_id": 101411,
        "voice": "vo_adv_5012604_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像是真琴在晚上穿上可愛的睡衣，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n然後舉辦睡衣派對，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偷偷目擊到這種場面之類的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "笨、",
        "unit_id": 104311,
        "voice": "vo_adv_5012604_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "笨蛋！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　別讓人想起來啦！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊哈哈。",
        "unit_id": 101411,
        "voice": "vo_adv_5012604_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不管怎麼說，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之開始吧。",
        "unit_id": 101411
    }
