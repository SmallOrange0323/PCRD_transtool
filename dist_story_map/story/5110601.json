[
    {
        "type": "background",
        "background": "501322"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某種異變正在蘭德索爾境內無聲無息地進展著。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未與神祕少女接觸後，感受到一股異樣的感覺。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總覺得腦袋從剛剛就一直昏昏沉沉的……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這跟鎮上所發生的異變有關連嗎？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果真有關連，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就有點不妙了……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n連我也會變成那個樣子嗎……？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，這種感覺",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到底是什麼啊……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像又溫暖",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "又讓人不捨……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……且令人懷念？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦……？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n怎麼",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "眼前",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一片白……？　",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……尾狗、",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "刀……",
        "unit_id": 106116
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "──！？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n好危險好危險，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我剛才不小心",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "睡著了嗎！？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼嘛……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼時候跑到外頭來了……？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且周遭景色",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還一片朦朧？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這果然是",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我在做夢吧……？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n話雖如此，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的意識仍相當清楚呢。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "算了，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎樣都行！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n勉強自己思考並不是我個人的作風。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總之，先找找看有沒有可以回到原處的方法！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……不過，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放眼望去，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡也只有「那個」而已。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這地方到處都飄浮著",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓人摸不著頭緒的奇妙結晶。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種結晶",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很明顯不是普通的結晶。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以感受到一股奇妙的力量……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且更加不可思議的是……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……果真有種",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "令人懷念的感覺。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我又沒見過這種結晶，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "與其說結晶本身很令人懷念……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n反倒更像是結晶",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "直接……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "與我的內心搭話？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要試著用手觸碰看看嗎？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該沒問題吧？",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不會在觸碰的瞬間",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就轟隆地",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "爆炸吧？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀如果在這裡，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大概會說出「要再更小心謹慎點～」",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "之類的話。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他搞不好會說：",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「太麻煩了，別管了吧？」",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙現在不在這裡。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我只能相信我自己了呢。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106116,
        "voice": "vo_adv_5110601_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要碰囉……！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在觸碰的瞬間，結晶光芒萬射，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n喚醒了深藏於矛依未心中，令人懷念的光景──"
    }
]