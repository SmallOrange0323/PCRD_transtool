[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特……？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n泥躲到哪裡去啦～",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不會森氣氣的，快粗乃唄……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唔？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n草叢有動靜？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那裡也傳出喵特的叫聲……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n來來，泥就放棄唄，我抓到泥啦……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呀、",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唉呀……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n咦……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對、對對、對不起。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不小心抱住你了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，我有養一隻長得像貓的魔物，",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠叫喵特……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，那個？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，先不管那個……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請問你在這種地方做什麼呢……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你定期會",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n送郵件來【伊麗莎白牧場】吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你工作辛苦了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你、",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你在說什麼呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不記得有這回事，大概是你聽錯了吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "…………",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……請、請你忘掉那件事。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "拜託你，我什麼都肯做。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……先不提那些。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請問你為什麼會倒在這裡？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你是身體不太舒服嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的病房就在附近，那裡也有常備藥品……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，你要在那邊休息一下嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，喵特在這裡呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠給你抱在懷裡……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你們的感情真好呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這孩子很少親近除了我以外的人。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你是走著走著，喵特就突然撲上來了……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後你就因此跌倒了嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那還真是，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我家的寵物給你添麻煩了。",
        "unit_id": 103811
    },
    {
        "type": "still",
        "still": "103800601"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特，這位哥哥不是壞人……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以你不可以趕他走喔，過來我這裡吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n好乖，好乖♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這孩子因為某些原因變成由我來飼養。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是畢竟牠是魔物……魔物是人類的天敵。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我覺得牠要是不能幫上人類的忙，就會被趕走……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我查了書想讓喵特學會做一些工作或是才藝。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是不太順利呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要牠學會做類似牧羊犬或是獵犬的工作的話……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就不會有人認定牠是隻「危險的魔物」，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n也不會想趕走牠了吧？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為是我撿到這孩子的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我必須幫牠創造一個家。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "【伊麗莎白牧場】的人都對我說，",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我不用工作也不要緊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那是因為大家都體貼我。",
        "unit_id": 103811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的身體也不是很好，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我不知道自己可以活到什麼時候。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算我不在了，我也希望喵特能夠生存下去，",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因此我必須要讓牠學會處世之道。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以最近，我們都一起",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n做【伊麗莎白牧場】的警備工作。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠好像是把你當成可疑份子",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n或是入侵者才會襲擊你的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n喵特牠還是個",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n什麼都不懂的小寶寶，請你原諒牠。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果讓別人知道牠襲擊人類的話，牠會被當成魔物消滅掉的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "什麼？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你說喵特只是在和你玩……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你是指這次就當成是這樣原諒牠了吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你能原諒喵特……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你能諒解，我很開心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你果然是一個很溫柔的人。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇啊？",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n喵特？為什麼鬧起來了……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，喵特又撲到你身上了！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不、不可以……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n已經犯了一次，居然再犯第二次。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說不定這次就絕對得不到原諒了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特是怎麼了，明明平常是個好孩子的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特是不是在吃醋呢……",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為我一直看著{player}，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一直和你說話。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒事滴呦～放心唄。",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對我來說，",
        "unit_id": 103811,
        "voice": "vo_adv_1038006_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不論是{player}還是喵特……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "兩邊都一樣重要啊。",
        "unit_id": 103811
    }
]