    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生把空花約出來……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n還挑這麼四下無人的地方，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不知道",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "接下來究竟會\n要求什麼樣的Play呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過虐待狂先生",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還真慢呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嚇！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這莫非是所謂的放置不理……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "胸中這小鹿亂撞的感覺，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生真是太內行了！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花快不行了～～～！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿咿咿！",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "身後傳來虐待狂先生的聲音！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n而、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而且",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "眼前一片漆黑……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這莫非是",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "遮眼Play！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n竟竟、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "竟然讓空花這麼心跳怦怦，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "究竟是有什麼打算呢～！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦……",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "慶祝空花生日，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以才會玩起這樣的Play……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "也不是？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這份禮物",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "真的可以收下嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝謝……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這種心動的感覺",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "究竟是怎麼回事呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生，",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為什麼一到場突然就……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n因為今天是空花生日，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗎……？　",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然很高興，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "突然說什麼一切要求，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼說得出口嘛～～～！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這一定是",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生巧妙的圈套吧！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "故意讓空花自己招供，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把空花的心靈脫個精光，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n想法全部裸露在外",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對吧……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "真是好可怕的人……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿哇啊啊啊！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這聲音是……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "竟然突然從後面講悄悄話，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "莫非是打算先把空花嚇暈，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n之後再下手做什麼事情！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這就是",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "送給空花的生日禮物，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗎……？　",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼會這麼懂空花的口味！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n而且",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "還可以再來第二次嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要絕頂昇天了～！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝、",
        "unit_id": 104511,
        "voice": "vo_adv_1045500_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝謝你，虐待狂先生……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "竟然能",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "帶給空花這麼多的愉悅，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你果然是……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n好吧。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "願意一輩子當虐待狂先生的專屬寵物～～～！",
        "unit_id": 104511
    }
]