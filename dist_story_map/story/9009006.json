    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧格黑納某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n射擊遊戲的攤販前。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "歡迎光臨～☆",
        "unit_id": 106711,
        "voice": "vo_adv_9009006_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如你所見，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是射擊遊戲的攤販哦～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n擺攤也是很重要的生意嘛～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "開什麼玩笑啊，混帳老太婆老大！",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而且",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我都被綁起來",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當成靶子了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你怎麼還悠哉地袖手旁觀啊，小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106511,
        "voice": "vo_adv_9009006_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個情況確實是需要解釋一下呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個，其實是老大她啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好像很中意",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "吉歐‧格黑納這裡",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n類似標語的東西？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「弱肉強食」",
        "unit_id": 106711,
        "voice": "vo_adv_9009006_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是句很好的話呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我把這個學不會教訓、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "打算惡作劇的祈梨",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抓起來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當作射擊遊戲的獎品",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也沒有關係吧～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼可能沒關係啦！！",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不要～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "把那種危險的東西～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對著人啊～！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n噫啊啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "老是動來動去的，都打不太中啊……",
        "unit_id": 1,
        "voice": "vo_adv_9009006_005"
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "喂，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n要是打中這傢伙，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "真的可以把她帶走嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "\n大家可是都餓著肚子在等呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然",
        "unit_id": 106711,
        "voice": "vo_adv_9009006_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "OK了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然她身上",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以吃的地方可能不多，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但當作口感爽脆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "的下酒菜應該還是不錯的吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等等，",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是把我當零食嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我又不是食物！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你看，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看起來要比我",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "更好吃的獎品還有很多呀！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去瞄準那些啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這裡的人們",
        "unit_id": 106511,
        "voice": "vo_adv_9009006_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "比起甜食，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好像對肉更感興趣呢～",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……哎，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然要打斷她難得受歡迎的盛況有點過意不去，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但畢竟也不能真的讓她被吃了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你幫我把她救下來吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很簡單啊。",
        "unit_id": 106511,
        "voice": "vo_adv_9009006_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你只要搶在其他客人之前，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "先射中祈梨就可以了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別擔心，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然聲音聽起來很響亮，但並不是實彈。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫，",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等等！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你也太果斷了吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種情況應該要更遲疑才對……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀嗚！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……嗚嗚，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "居然毫不猶豫地射擊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～命中～",
        "unit_id": 106711,
        "voice": "vo_adv_9009006_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "恭喜你～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這麼一來，祈梨就是你的了～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你可以對她做任何想做的事，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "盡情享受吧～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大，",
        "unit_id": 106511,
        "voice": "vo_adv_9009006_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳這樣說會引起各種誤會啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "擁有這個權利",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是事實沒錯啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小、",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該不會",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是要讓我以為得救了，再把我推入火坑吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你應該",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不會做這麼狠毒的事吧……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼，",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就知道！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥可是我的手下呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我也知道你是一個",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "重情重義的男人！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫噫噫噫噫噫噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n差點忘記了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你平時就是個什麼都吃的人……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "開玩笑的？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等等，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可是真的嚇壞了耶！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "什麼嘛～",
        "unit_id": 106711,
        "voice": "vo_adv_9009006_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真可惜……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也看得滿開心的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就放妳一馬吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚，",
        "unit_id": 106611,
        "voice": "vo_adv_9009006_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我真的是太苦了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真想快點把攤子收一收，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "回去蘭德索爾啦～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}成功阻止了祈梨"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被端上吉歐‧格黑納餐桌的危機。"
