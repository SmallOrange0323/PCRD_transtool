[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "突如其來於阿斯特賴亞大陸上出現的謎之建築物。\n{player}與優衣、真琴、霞共4人，\n正朝著那座巨塔踏出了第一步――"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那就是露娜之塔……",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n取回騎士先生記憶的關鍵，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就藏在那裡頭了對嘛，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像是這樣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "和先前找到的古文書上出現的",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n塔的資料也很一致，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "應該沒錯啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於此事，",
        "unit_id": 101411,
        "voice": "vo_adv_7001000_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "似乎是沒有懷疑的餘地了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這麼說來，",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "接下來就只剩進到塔中這事就對了……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n優衣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "古文書上所寫的地方，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就在這附近對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n寫著是有個照耀著前往塔之道路的祠堂。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "海上到處都是魔物所以就是有船坐也不能幹嘛呢，",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而一眼望過去好像也沒有什麼看起來像是入口的地方啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也是呢。",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果能有什麼線索就好了呢――",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦，",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你要去哪裡呢～？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "欸？　",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有怪異之處？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難道",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是傳送魔法的術式了嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是，",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這有辦法讓它發動嗎？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說啊喂，{player}，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你可別亂來啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦哇！？　",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "傳送魔法突然開始發動了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n到底是怎麼一回事！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴。",
        "unit_id": 101411,
        "voice": "vo_adv_7001000_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我這邊現在，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n似乎看到這個術式對助手先生的存在產生了反應的樣子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也就是說，",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這座塔果然是，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n和騎士先生有所關聯了呢！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好！　",
        "unit_id": 101411,
        "voice": "vo_adv_7001000_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們大家就一起，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從這裡跳進去看看吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n都準備好了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "　要上囉！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "優衣・真琴・霞",
        "words": "預備！！",
        "unit_id": 1,
        "voice": "vo_adv_7001000_015"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔……",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這裡是……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "應該就是塔內不會錯了。",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "成功了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還挺順利的嘛。",
        "unit_id": 101411,
        "voice": "vo_adv_7001000_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接下來，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是快樂的解謎時間了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "開始進行內部探索吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔喔！　",
        "unit_id": 104311,
        "voice": "vo_adv_7001000_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}記憶的謎團，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就由我們來把它解開來吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_7001000_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們出發吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n讓我們來調查這座塔，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一起取回騎士先生的記憶吧！",
        "unit_id": 100211
    }
]