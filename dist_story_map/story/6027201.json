[
    {
        "type": "background",
        "background": "500833"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，",
        "unit_id": 106511,
        "voice": "vo_adv_6027201_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你有沒有看到祈梨啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大在找我們的說，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n到底跑到哪裡去了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎樣",
        "unit_id": 106511,
        "voice": "vo_adv_6027201_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的人啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟外表看起來差不多啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n很弱又少根筋，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘴巴還很壞的小不點……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她心地其實很善良。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "請你跟她做好朋友吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是說啊～",
        "unit_id": 106511,
        "voice": "vo_adv_6027201_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是所謂的上進心嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "像她那種先下手為強",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來壓制對方的做法是很爽快啦，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不過如果她能再做好一點的話就好了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒辦法放下她不管呢。",
        "unit_id": 106511,
        "voice": "vo_adv_6027201_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總覺得她很容易讓人擔心。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這點跟你",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還滿像的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你和祈梨應該滿合得來的吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她是個很有趣的人，所以和她在一起都不會覺得無聊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟你一樣呢！",
        "unit_id": 106511
    }
]