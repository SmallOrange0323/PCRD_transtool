    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "香辛料與調味油層層疊加之料理",
        "unit_id": 129711,
        "voice": "vo_adv_5213088_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "固然上佳，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然若精挑稀世之材，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "佐以發揮其本味之烹調，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n方為真正美味至上。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以最佳火候，",
        "unit_id": 129711,
        "voice": "vo_adv_5213088_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "保留食材本味。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "表面香煎至焦香，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "內裡保留柔嫩的赤肉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n調味僅取適量鹽巴。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此等奢華，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可謂難得。",
        "unit_id": 129711
    }
]