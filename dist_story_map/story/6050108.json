[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說起來，",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "萬聖節的經典活動就是惡作劇對吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不給糖就搗蛋！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這句話可少不了。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生想要嘗試什麼樣的惡作劇呢？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………你突然之間幹嘛啊？",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你那是想要惡作劇啊。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是做了一個可愛的惡作劇呢，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個不怎麼有萬聖節的感覺啊……",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為你很常掉下去？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生難道有認識的獵人嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不可以常常妨礙人家打獵喔。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是為了不被人惡作劇才做的事情啦。",
        "unit_id": 113911,
        "voice": "vo_adv_6050108_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你從一開始就沒有想過要惡作劇吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "受不了，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是個徹頭徹尾的濫好人呢。",
        "unit_id": 113911
    }
]