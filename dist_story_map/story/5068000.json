    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "打工費配發的是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只在那裡流通的私造貨幣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難道不會發生這種事嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……………",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_064"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "………………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "被和不認識的陌生人關在一起，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_065"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我的身心靈可是一秒都撐不住的……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
