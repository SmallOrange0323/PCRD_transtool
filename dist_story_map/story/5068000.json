    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "手臂也快掉下來了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變得軟趴趴的，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "軟趴趴！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說、",
