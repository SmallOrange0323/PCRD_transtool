    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "喂，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那不是天馬的打嗝聲嗎！！",
