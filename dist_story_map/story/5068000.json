        "voice": "vo_adv_5068000_054"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了讓它能承受BB團嚴酷的練習，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
