    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它一定沒事的啦！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n畢竟它的名字代表著",
