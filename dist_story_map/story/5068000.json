        "voice": "vo_adv_5068000_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就別只是恢復原狀了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n乾脆把它改造得帥氣一點吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這是我獨創的善後補救！",
