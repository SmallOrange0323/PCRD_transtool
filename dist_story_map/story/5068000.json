        "voice": "vo_adv_5068000_057"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要改造的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就需要花錢吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "機會難得，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想讓它用好一點的材料……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "話是這麼說，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_058"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但要怎麼籌錢呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你剛剛說什麼？",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_059"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈哈哈，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_060"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你又在說笑了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n打工什麼的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對我來說還太早了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "噫咿咿～～～！！",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_061"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n而而、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "竟竟竟",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "竟然是去工廠！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說到在工廠打工，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不就是讓作業員們待在窗戶全用木板釘死、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n分不清晝夜的環境中，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "默默地面對著機器，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n精神瀕臨崩潰的那種地方嗎！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "回過神來",
