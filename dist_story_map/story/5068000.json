    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這次有好好找到它……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "儘管飛出了比劇毒曼德拉草的觸手還長的距離，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_048"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n好朋友號的身體還是……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如你所見……",
