        "voice": "vo_adv_5068000_055"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "改造得更高大，讓它能在草原上小跳步，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n它會不會很開心呢？",
