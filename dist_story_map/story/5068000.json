    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n別跟我玩躲貓貓了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "快點出來吧──！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唉……",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_044"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要在廣袤的精靈之森裡",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n尋找小小的好朋友號",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "果然太困難了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_045"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一定會找到它的！",
