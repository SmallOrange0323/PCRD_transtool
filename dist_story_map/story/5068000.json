[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天的精靈之森──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n燦爛陽光從枝葉間灑落，森林中迴盪著怪異的聲響。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在、",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在在、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在今天這樣的大好日子裡！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "願聚集在此的",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "諸位！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "都能愈益、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "愈益愈益……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "愈益……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "愈益",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "亦師亦友的藝術家──！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唉……",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天的交朋友練習",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也一如往常，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才剛開始就宣告收攤了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "噫呀啊啊！？\n",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今日",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "店長由於個人私事",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "決定臨時停止營業──！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊！",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來是你啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還以為是有不顧營業時間的奧客上門了呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為是BB團久違的練習，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我不小心太起勁了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我預想了自己交到100個朋友後，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在大家面前進行演說的練習……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種練習對我而言果然負擔太重了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我把「有我在喔好朋友號」比作了人群，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但其實在我面前的也就只有一隻……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它是前段時間新做的人偶，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n名為",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「有我在喔好朋友號V4」。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "…………",
        "unit_id": 7211,
        "voice": "vo_adv_5068000_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這次",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是前所未有的完美作品唷。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n畢竟都進化到了第4代嘛。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哼哼！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我對它非常滿意，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以雖然是用來練習結交朋友的對象，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我還是會盡量小心對待它。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "1號的時期，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "由於話題枯竭導致彼此漸漸疏遠，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我對此進行了反省……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過！",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這次我有了完美的對策！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "比如，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我會向和【森林守衛】交易的商人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n打聽在王都流行的大小事，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "蒐集話題。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖說",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "直接和商人對話的是初音，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我只是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "躲在樹蔭底下偷聽就是了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "或許是因為這些努力，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我已經和V4建立起良好的關係了。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "話雖如此，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它只是拿來練習交朋友的對象。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果能有100隻V4，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就能練習在100個人面前演說了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼多隻不知得做上多少年……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "話說回來，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難得BB團成員全員到齊，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n今天就來挑戰看看",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難度高一點的練習吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n必須找回練習交朋友的感覺才行！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因此！",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要來挑戰與朋友的對話中，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n屬於高難度的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「那件事」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要發表囉……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請你聽仔細了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……就是吐槽！",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "應該是沒有重新說明的必要，但還是保險起見再說一次。",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吐槽",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是只有在彼此建立了信賴關係後，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n才能使用的一種高級溝通技術。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其難度為4顆星",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "（自評）。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能否快速地、",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "正確地吐槽，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n左右著朋友之間關係的友好程度。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "達成多次優秀吐槽能加深彼此的友誼，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "離成為真正的朋友的那天也越接近……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是這麼聽說的。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然而……",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要走錯一步，好不容易構築起的朋友關係",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n或許會就此破滅，是把可怕的雙面刃。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有一種說法是，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吐槽失敗會導致絕交，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這類說法真假難辨、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "且眾說紛紜。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "失敗後的補救似乎也很重要。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n據說也是有透過妥當的補救挽回友情的例子。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是這樣，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它絕對屬於高級的溝通技術。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n該說真不愧是難度4顆星呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖說是練習，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對真正的人類吐槽還是有風險……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這點大可放心！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n「有我在喔好朋友號V4」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "正是為了這種時刻而存在的！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "…………",
        "unit_id": 7211,
        "voice": "vo_adv_5068000_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "事不宜遲，就由我先開始吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "把「有我在喔好朋友號」",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "放在樹樁上，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吸──",
        "unit_id": 104011,
        "voice": "vo_adv_5068000_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吐──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吸──",
        "unit_id": 104011
    },
    {
