        "voice": "vo_adv_5068000_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n之前好像也發生過類似的事情，沒事的。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這種感覺",
