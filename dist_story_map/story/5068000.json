        "voice": "vo_adv_5068000_046"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "找到了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "發現「有我在喔好朋友號」！",
