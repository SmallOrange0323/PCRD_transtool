        "voice": "vo_adv_5068000_056"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "夢想越來越壯闊了呢～♪",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊……",
