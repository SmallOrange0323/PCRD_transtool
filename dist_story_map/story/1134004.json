    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在沙灘棒球社的活動告一段落後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n初音與{player}一起來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好舒服的海風！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓人想一直待在這裡乘涼呢～",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我跟你在這個沙灘",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一起做了很多加油的練習呢。",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的過得好開心啊～",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "到時候也要帶上小栞，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對吧！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "下次我會跟小栞一起來，",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n幫你和沙灘棒球社的大家加油的！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "氣氛一定會很熱鬧！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好期待呢～！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……在回到精靈之森前，",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n得好好",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "將這片景色烙印在眼底才行呢。",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我要永遠記得在這裡",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "締造的快樂回憶……",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這片沙灘、",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大海，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "以及天空都──",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}，你快看！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是彩虹喔，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "彩虹！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n竟然會在這個時間出現，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看來我們運氣不錯呢！",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……奇怪？",
        "unit_id": 113411,
        "voice": "vo_adv_1134004_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這個",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好像不是彩虹？",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不但很刺眼，",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還不斷地",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在靠近我們耶！？",
        "unit_id": 113411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嗚哇哇～！",
        "unit_id": 113411
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太陽好刺眼～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很有",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來到海邊的感覺，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓人很興奮呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那還用說！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我早就決定好今天一整天",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都要跟你一起愉快地度過了！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要從什麼開始好呢～？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我想要玩敲西瓜，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也想要玩衝浪！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n而且，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我對潛水也很感興趣呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n大家在那個海岸邊",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "做什麼呢……？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我知道了，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "他們在玩拖曳傘！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你有聽說過嗎？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那是用小船拉起降落傘，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在天空滑翔的水上娛樂喔！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這麼說來……",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果是玩",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "拖曳傘……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說不定就可以跟{player}",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n一起飛上天空了……？　",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我說啊，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們也一起",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "去玩拖曳傘吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n好像只要去那邊報名，很快就能坐了！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一定會很好玩。",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為飛在空中的感覺",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的很舒服！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我經常一個人用超能力飛在空中，所以很清楚。",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一邊感受著咻咻的涼風，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一邊瞭望美麗的風景……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那是一種無可取代的暢快喔～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想你一定也會喜歡上的！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以說，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要不要一起去玩？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了～！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼就趕緊換上泳裝",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來去挑戰吧～！",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "510270"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼要出發囉～！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "起飛！",
        "unit_id": 101231
    },
    {
        "type": "still",
        "still": "113400401"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇～",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "飛得好高！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且吹著涼爽的風～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真的好舒服喔～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}覺得如何呢？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看來你很喜歡呢！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……其實，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我之前做了跟你一起在空中飛翔的夢。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們手牽著手，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一起朝著遠方飛去。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的讓人好興奮呢～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在那之後，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就一直想說",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是能兩個人一起飛翔就好了。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而現在實現了，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我真的感到很開心、",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很興奮喔！",
        "unit_id": 101231
    },
    {
        "type": "still",
        "still": "113400402"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是嘛！",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總覺得好幸福～♪",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看到你現在的表情，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我就會想讓你感到更開心呢。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "只有現在的話……！　",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看我的！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}，你快看！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是彩虹喔，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "彩虹！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇～",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好厲害～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我第一次看見",
