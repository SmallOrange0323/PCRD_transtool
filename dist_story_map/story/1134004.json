    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我只是想說能讓你感到開心真是太好了～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……我呀，",
        "unit_id": 101231,
        "voice": "vo_adv_1134004_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一直在想。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不管任何時間或地點，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "只要跟你在一起，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n無論做什麼事",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺都會很開心呢。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以說，",
