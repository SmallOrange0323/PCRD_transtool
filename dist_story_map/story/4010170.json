[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "早安……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不對，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是午安？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對不起喔～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為昨天畫圖忙到很晚，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我對時間的感覺有點錯亂了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天找我有什麼事呢？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為你很少主動聯絡我，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嚇了我一跳～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "生日？",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "已經到了這個時期啦～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也有禮物嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我好高興～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "長大之後，",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就會很容易忘記這種活動呢～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n畢竟也沒有其他會幫我慶祝的人，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是沒有你，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就要度過",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "史上最寂寞的生日了～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "明明以前",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "會每天倒數期待生日的說……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊啊，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果願望能實現的話，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真想像那時候一樣",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用閃閃亮亮的心情",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "過生日呢～～～～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你這樣說沒關係嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n要是用那個表情說這種話，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我會變得比平常更任性喔？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我有個請求。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天在這之後",
        "unit_id": 106731,
        "voice": "vo_adv_4010170_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要一～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "直",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟我在一起……♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我仔細地",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好好享受",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你溫暖的溫柔吧。",
        "unit_id": 106731
    }
]