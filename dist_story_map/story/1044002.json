        "voice": "vo_adv_1044002_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這次也罷，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼都很快就變回來了！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n說到底，是否有什麼原因……",
