        "voice": "vo_adv_1044002_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才能恢復真正的模樣？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那個時候，你不是也在嗎！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若你有注意到什麼苗頭，就快點告訴妾身！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……沒什麼特別的…",
        "unit_id": 104412,
        "voice": "vo_adv_1044002_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是頭痛。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n再這樣下去，妾身拿不回力量……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唉、",
