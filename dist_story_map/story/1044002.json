    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只不過……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n若像這樣被抱住，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就不能盡情戰鬥了。",
