        "voice": "vo_adv_1044002_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "其實……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在那之後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身都無法變回真正的姿態……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就妾身來說，",
        "unit_id": 104412,
        "voice": "vo_adv_1044002_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是很想早點取回原本的力量……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但該怎麼做，",
