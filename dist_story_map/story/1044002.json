        "voice": "vo_adv_1044002_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n力量湧現出來了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然沒錯！",
        "unit_id": 104411,
        "voice": "vo_adv_1044002_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖然不曉得是什麼原因，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但只要被你觸碰，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就能恢復成這個姿態了。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此一來，",
        "unit_id": 104411,
        "voice": "vo_adv_1044002_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只要讓你一直摸妾身就好了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這不是很簡單嗎！",
