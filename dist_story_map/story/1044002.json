        "voice": "vo_adv_1044002_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從身體的深處，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有什麼……！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦！？",
        "unit_id": 104411,
        "voice": "vo_adv_1044002_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "恢復原本的姿態了！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然不知道原因，",
        "unit_id": 104411,
        "voice": "vo_adv_1044002_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但做得好啊，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧，",
        "unit_id": 104411,
        "voice": "vo_adv_1044002_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在妾身取回真實之力的現在，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
