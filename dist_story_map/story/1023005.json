[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……咦？",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n{player}哥哥！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你在這種地方做什麼？",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "散步？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哼嗯～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是在到處走走？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為了記住什麼地方",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有什麼東西？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你才剛來到這城鎮，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以還不熟悉環境吧～？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我懂你的心情～",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我剛去【咲戀育幼院】的時候，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也曾經一整天都四處閒晃！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "探險，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n很開心呢♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不曉得什麼地方有什麼東西",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n會覺得很不安吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我懂我懂。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥不介意的話，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就讓我來帶你到處看看吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我可是比哥哥更熟悉這城鎮喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喂喂，綾音……",
        "unit_id": 2111,
        "voice": "vo_adv_1023005_008"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不要緊嗎？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳沒有空去多管閒事吧？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔唔，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉你閉嘴啦～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "又沒關係。",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n遇到有困難的人就要出手相助，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n咲戀媽媽也是這麼說的啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「是喔。",
        "unit_id": 2111,
        "voice": "vo_adv_1023005_011"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n那好吧，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n隨綾音妳高興。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯，我會的～",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n一起去散步吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我來告訴你鎮上的事情吧，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "當然，你如果覺得麻煩，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不要也無所謂……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "太好了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為我不太會顧慮到別人……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我會不小心就沒想到別人的困擾，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只顧著做自己想做的事。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為這樣，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以常弄哭和我待在同一個育幼院的胡桃。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也經常因此被咲戀媽媽罵，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這就是我的壞毛病吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這也沒辦法呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "誰叫我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是備受寵愛長大的嘛。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯……",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那件事，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還不要緊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還有一點時間。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒事的。",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會乖乖做好被交代的事情。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不用擔心。",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們一起去散步吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n手牽手一起走吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你有什麼想去的地方嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個嘛……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就是稍微前面那裡叫做",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "高級住宅街？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n的地方，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "傍晚在那裡有點事情。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "在那之前，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我必須想辦法打發時間。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為育幼院啊～",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "目前正在噴灑殺蟲劑。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n要是待在房間裡，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會非常不舒服。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那裡是老舊建築，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "經常有蟲會跑出來。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我果然",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是有點受不了蟲呢～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為很噁心呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都不怕蟲嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好厲害～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那下次",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n要是房間有蟲出現，就麻煩哥哥來驅除囉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊……",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥並沒有和我們住在一起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n應該很難吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是呀，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "房間要是有蟲出現……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我和胡桃",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "通常都會陷入恐慌之中。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然後用槌子猛敲牆壁之類的，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "結果就變得很不得了♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音，",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_033"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n拜託妳別再",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "用我打蟲了啦……」",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「不如說，",
        "unit_id": 2111,
        "voice": "vo_adv_1023005_034"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳要是鬧過頭，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n小心被趕出育幼院喔。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "平時都很乖巧，不用擔心～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "全都是蟲的錯啦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n都怪蟲太噁心，我才會受不了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023005_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你看你看，哥哥！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那邊的攤販",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
