[
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有兩個人造訪了「吉歐‧提格尼亞」的城鎮。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵……",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這裡就是「吉歐‧提格尼亞」啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就像小哥說的那樣，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看起來是很甜膩膩的城鎮呢……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓人好想吃掉一扇門看看。",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這一帶有滿滿的巧克力，看起來好好吃喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就來嚐個一口，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我咬──♪",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "先給我等等，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別引起騷動啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們今天可不是來打架的耶。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦！？",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是這樣的嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟以嘉夜夜的個性，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我以為是要來新世界打架呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是很想，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但現在也由不得我這麼做啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "自從老大不在之後就人手不足，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我一直忙著經營公會的事務……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔～",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好想跟人大打一場……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在先解決人手不足的問題吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "據{player}表示，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那座城裡似乎有龍人族。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以是要去邀請新成員加入嗎？",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "確實我",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也差不多想要個手下呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「祈梨頭目」……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這聽起來感覺真棒！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好～！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那就立刻",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去找龍人族加入夥伴吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我們突擊～！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都說別引起騷動了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n哪有人會從正面硬上啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天走後門進去！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的……",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "工作量會很多有一半原因，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n都是祈梨愛擅自亂來啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也好想大鬧一場喔……",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "501730"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_010"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "接著是打掃大廳喔。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我們快點掃完吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "唉……",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_011"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好累喔……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "找到了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是龍人族！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔～",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是第一次見到雙胞胎呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n看她們好像是在打掃房間……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咿……！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說到打掃，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n讓我想起被老大呼來喚去那時的往事了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她們也是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被城裡的人使喚著吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等等我……！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳們是我未來的手下！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我現在",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就讓妳們重獲自由！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂喂，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們根本不知道",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她們是否真的被人使喚吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也搞不好是她們自願留在這裡的……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦～？",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰應該都不想要打掃才對啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她們絕對是被逼的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也是這樣啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那是妳吧？",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好了啦，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就先觀察一下，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看是否能邀她們加入夥伴吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我知道了啦～",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……好，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n話說回來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是得多加注意觀察才行。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n畢竟龍人族很少見，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "常常被人口販子抓去賣。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳們是因為什麼理由才會跑來當女僕……",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n兩位小姐，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就讓我們調查一下吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_022"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不可以掃得那麼隨便啦。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這裡會有很多人經過，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "所以灰塵很容易亂飄啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "可是，",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_023"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "姊姊，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n反正明天",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "也還是會",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n打掃這個房間吧？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "話雖如此，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_024"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但妳昨天和前天都掃得很隨便吧？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "所以才會積了這麼多灰塵！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "今天絕對要徹底打掃乾淨喔。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……唉……",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯……",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那孩子",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然很討厭打掃對吧……！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該只是覺得很麻煩吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才沒這回事！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她可是一臉厭惡地在打掃耶！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……我掃掃掃。",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_029"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好了，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我掃完囉，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "姊姊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真的嗎？",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_030"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那我來驗收一下。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n畢竟之前也曾被女僕總管",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n罵說",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "「打掃得不夠徹底」。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "總管她",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_031"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "很囉唆耶……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "明明是個巨人族。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_032"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不可以說那種話啦。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n畢竟女僕總管可是處在需要肩負責任的立場啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳不否認她很囉唆這一點啊。",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_033"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "唔！",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_034"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不要挑人語病啦！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看吧，",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她們提到是被討厭的人逼著做喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個假裝很正經的女生",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看起來其實也很不滿呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那點程度的",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_036"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只是普通的發牢騷吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哎唷，",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳這樣也算是【龍族巢穴】的人嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n保護龍人族不也是我們工作的一環嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "講話別這麼大聲啦……！",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我只是想說不多觀察一下會無法判斷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔唔唔～！！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_039"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊……",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_040"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "等一下。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳的蝴蝶結綁歪了……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳衣服老是穿得很隨便。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "是老姊太講究了啦。",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_041"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n這種衣服才不會有人在意。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆……",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_042"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我想妳應該很清楚，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這套女僕裝",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n是萊拉耶爾殿下",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "替龍人族的我們「量身打造」",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n所準備的衣服，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不可以說什麼「這種衣服」吧！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咿！？",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n嘉夜夜，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯？",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼啦？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還問什麼",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼啦……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她們的老大",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "根本不是個好東西！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n把麻煩的打掃推給她們，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "責罵教訓她們，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "最後甚至……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還強迫龍人族穿上量身打造的女僕裝……",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_046"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是個超級",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大變態啊──！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什、",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的確依個人的解讀，聽起來可以是那麼回事……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但那終究是妳個人的解讀、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "吧……？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到這個節骨眼妳怎麼還藉口一大堆的！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_048"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n放著這種壞蛋不管，會害龍人族有危險！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這有損我們【龍族巢穴】之名啊──！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "夠了，",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_049"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣根本沒完沒了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然如此，我就代替失去銳氣的嘉夜夜……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n帶著她們逃出去！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哇，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_050"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨！？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n被發現就糟……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她跑出去了……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我未來的手下啊！！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_051"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經不要緊囉！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我來救妳們了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「咦？」\n「啊？」",
        "unit_id": 1,
        "voice": "vo_adv_2202103_052"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "被發現了……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳先冷靜啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "放開我，",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_054"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n難道妳不想把她們從",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n超級大變態的魔爪中救出來嗎～！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "超級大變態的魔爪……？",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_055"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "比起這個，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳們是誰啊！？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉……！",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們會在這裡",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是有一～些些的原因……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "並沒有惡意啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯沒錯！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_057"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們是在替手下妳們著想，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n才拼死跑來救人的喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別把事情搞得更複雜！",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_058"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再說",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她們還不是手下啊……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_059"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請別搗亂！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我們現在正好在打掃這裡……！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "…………啊。",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_060"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n腳邊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "嘉夜＆祈梨",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_2202103_061"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "集中的垃圾",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_062"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "都被踩亂了……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n鞋子也整個髒兮兮的……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "看、",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_063"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "看、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "看……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "看妳們都做了些什麼好事！！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我已經向萊拉耶爾殿下",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_064"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "說明事情經過了。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n殿下願意原諒妳們未經同意入侵城內一事。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳們可要好好感謝萊拉耶爾殿下的恩情喔。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉……",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_065"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "所以呢？",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_066"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n妳們說想邀我們",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "加入公會成為夥伴吧？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對，",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_067"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們有此打算才跑來的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這件事已經無所謂了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n妳們",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是出於自願服侍這座城的公主吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是的，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_068"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "萊拉耶爾殿下",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "非常照顧我們。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我們並不是因為妳們所擔心的誘拐",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "還是販賣人口",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n才會來到這裡的。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就好了。",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_069"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉我們擅自在那邊會錯意。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳也快來道歉。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_070"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對不起……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "沒關係，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_071"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "萊拉耶爾殿下都說要原諒兩位了。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "話說……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "龍人族的夥伴",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要找出來感覺很辛苦呢……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "就是說啊。",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_072"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n我們也",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "沒遇過妳們之外的龍人族。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是喔……",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_073"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "龍人族在這裡也很少見啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝妳們。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n總之，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們會一步一腳印慢慢找的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼，",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_074"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "結果是白忙一場呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "受妳們照顧了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我們就回去囉。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_075"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請等一下。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n萊拉耶爾殿下要我傳話給兩位。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "殿下想拜託",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳們一件事……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "嘉夜＆祈梨",
        "words": "什麼事？",
        "unit_id": 1,
        "voice": "vo_adv_2202103_076"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_077"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這……",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "501730"
    },
    {
        "type": "still",
        "still": "220210301"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這打扮是怎麼回事啊──！",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_078"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "幫忙打掃一下，",
        "unit_id": 127712,
        "voice": "vo_adv_2202103_079"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "應該會增進感情吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n萊拉耶爾殿下",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是這麼表示的。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n兩位願意協助打掃被干擾的作業範圍，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也算是幫我們一個忙。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要、",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_080"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要幫忙",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當然是可以啦……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過因為怕弄髒衣服，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就要我們換成這種打扮……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗚嗚，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這不能給幫派成員看到……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……快來這邊。",
        "unit_id": 127812,
        "voice": "vo_adv_2202103_081"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n這裡還有灰塵。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔唔唔……",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_082"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n明明要納為手下，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "竟然反被使喚……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我只是",
        "unit_id": 106611,
        "voice": "vo_adv_2202103_083"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "想幫妳們而已耶～～～！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106511,
        "voice": "vo_adv_2202103_084"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n好想大鬧一場……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果祈梨和嘉夜落得當一天的女僕，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n必須把大廳掃到一塵不染的下場……"
    },
    {
        "type": "still",
        "still": "end"
    }
]