[
    {
        "type": "dialogue",
        "name": "無名的藝術",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗚哇～",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這兩個傢伙到死都不會累啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂、喂、喂，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總之先冷靜一下，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "狗狗Stay。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你們動動腦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們血肉之軀是有體力這個概念的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "懂嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "感覺注意力已經渙散了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該先休息一下。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你們回狗屋去，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "回家回家。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "看什麼看？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "叫你們快點回去啦混帳！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "認可。",
        "unit_id": 13211,
        "voice": "vo_adv_9006523_002"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "接受停戰協議。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n思慮不周，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "深感抱歉。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n十分鐘之後，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "再把妳們變成認不出是什麼的肉塊，",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "掰啦。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "它們，",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像稍微變得比較好溝通了呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "多虧了克蘿依不斷地道德綁架──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "更正，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是教導。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n話雖如此，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但這樣下去也是沒完沒了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真想趕快做個了結……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "回家社的各位，",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_005"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "狀況如何？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如妳所見，",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "修女。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "被迫進入意料之外的長期抗戰，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "大家都精疲力盡了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "碧和秋乃學姐她們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正在那邊休息。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒辦法三兩下就切嚕解決呢。",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "瑪麗會長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有沒有什麼妳最拿手的祕密策略啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "當然有。",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還真的有喔！",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_009"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不難想像",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_010"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "妳們會陷入苦戰。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n下一支──",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "也是最後的支援部隊，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "應該就快抵達現場會合了。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真假。",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n還藏了這招，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是所謂的最終兵器嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "最終兵器！",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n究竟會是哪個團體，又會是誰呢！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n期待與興奮讓我心中切嚕切嚕不已！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "好像剛好抵達了。",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_013"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我向妳們介紹，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n這位是拯救世界最後的救世主，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "請。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "琪愛兒～",
        "unit_id": 3011,
        "voice": "vo_adv_9006523_014"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "有看到什麼好男人嗎～？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這、",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這就是救世主……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們的最終兵器……",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_016"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不好意思，",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_017"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "搞錯了。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "她只是剛好路過的路人，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "請當作沒看到。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說美衣子，",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳在這裡做什麼？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "我嗎？",
        "unit_id": 3011,
        "voice": "vo_adv_9006523_019"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "我聽說這附近，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "\n好像有拯救世界之類的活動。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "雖然不太懂在幹嘛，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "但參加不就有機會遇到高富帥嗎。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "最終兵器",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是來求姻緣的喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不是她。",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_021"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n真正的最終兵器和她不同，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "是非常高貴聖潔的。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "來求姻緣的同學請速速離場。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "好～",
        "unit_id": 3011,
        "voice": "vo_adv_9006523_022"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "那我先走了～",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喂，瑪麗會長，",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_023"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛剛那算什麼？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n場子都被不上不下的搞笑弄冷了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這樣最終兵器出場的難度會越來越高喔，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒問題嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "而且，",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個最後的援軍真的有這麼厲害嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n反正我看來的又是沒戲份的女配角吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不受歡迎又下流的死八婆，掛著令人煩躁的笑容",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喊說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「久等了～」──",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "久等了～！",
        "unit_id": 1,
        "voice": "vo_adv_9006523_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是望望。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "…………！",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦，",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是聖學祭的歌姬。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n最後的援軍是妳啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來得正好，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "亡王亡王。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學姐，",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳為什麼就是死都不把望望的名字記起來？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家，",
        "unit_id": 102911,
        "voice": "vo_adv_9006523_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "又見面了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天成員們也一起來了喔！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "初次見面，",
        "unit_id": 104211,
        "voice": "vo_adv_9006523_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我是千歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n聽說之前望受妳們照顧了，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝妳們。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是紡希！",
        "unit_id": 105411,
        "voice": "vo_adv_9006523_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "抱歉來晚了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要出發的時候剛好遇上製作人開宴會……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哇，真的假的，",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "全員到齊太犯規了吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n大陸級的超級偶像",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "齊聚一堂耶。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說這驚喜太豪華了吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "稍微顧慮一下墨團的立場嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，我記得，",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒非常喜歡慈樂之音。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒，能像這樣和偶像見面，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是太好了呢……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n死、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "死了……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊啊啊啊啊啊啊啊啊……",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_035"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不行不行不行不行受不了到極限了……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不好意思，在妳死掉的時候打擾妳。",
        "unit_id": 105411,
        "voice": "vo_adv_9006523_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝妳平時寄來的信，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "用字遣詞相當獨特，非常有個性。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我常聽小望提起妳的信，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以一直想和妳說聲謝謝。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳的信",
        "unit_id": 104211,
        "voice": "vo_adv_9006523_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總是為我們",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "帶來活力。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "希望妳以後也能繼續替我們打氣，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "慈樂之音好棒棒武士。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊、",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_038"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那是、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "當然的……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "聲音好小。",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_039"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "一年級的琪愛兒，",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_040"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我全心侍奉天主，對所謂偶像這種世俗文化，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n既沒有興趣，也不了解──",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "──但是，",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_041"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "讓千歌成員說出妳那毫不掩飾想受稱讚，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n又不好笑的筆名，我實在難以苟同。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "因為，她的魅力在於她那清純優雅，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "又聖潔崇高的超凡氣質。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "當然，舞台下的她，既樸實又純真，",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_042"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n偶爾也會展現和夥伴嬉鬧的可愛一面。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不過，她的本質，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "仍是那無可撼動的堅強內心──",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "學生會長，",
        "unit_id": 104211,
        "voice": "vo_adv_9006523_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝妳。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳這麼仔細的觀察我，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n雖然有點不好意思，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我覺得很榮幸。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "請問妳是哪位？",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_044"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我對偶像沒興趣，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n麻煩不要隨便和我搭話。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "哇啊啊……！",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_045"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n千歌她！",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "千歌她在我面前說話啦！",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "天啊，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "真是太惶恐了，我不敢待在偶像的視線裡，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "快去其他地方──！　",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但慈樂之音好棒棒武士這個名字，",
        "unit_id": 105411,
        "voice": "vo_adv_9006523_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不覺得有點可愛嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既特別又有趣，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得不錯啊？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "紡希妳先安靜一下。",
        "unit_id": 7111,
        "voice": "vo_adv_9006523_047"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有緊急狀況！",
        "unit_id": 118511,
        "voice": "vo_adv_9006523_048"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n魔物回來了，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請大家助我們一臂之力！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔，",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_049"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來了啊……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n全體人員，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就戰鬥位置！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好喔～",
        "unit_id": 110811,
        "voice": "vo_adv_9006523_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她們說是緊急狀況，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒，要上囉──",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那還用說！",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_051"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這種事，不用勞煩慈樂之音她們！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n世界之敵，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就由我琪愛兒通通切嚕地消滅！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好的，",
        "unit_id": 102911,
        "voice": "vo_adv_9006523_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "琪愛兒，我們一起加油吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_9006523_053"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "上吧，各位！",
        "unit_id": 111011,
        "voice": "vo_adv_9006523_054"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n把這場戰鬥解決掉！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n大家，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出最終之力吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請努力挑戰看看！",
        "unit_id": 118511,
        "voice": "vo_adv_9006523_055"
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "喔喔───！！",
        "unit_id": 1,
        "voice": "vo_adv_9006523_056"
    }
]