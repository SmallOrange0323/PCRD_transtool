[
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "耶～！",
        "unit_id": 1,
        "voice": "vo_adv_4012008_000"
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "變回原本的彩羽了──！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "\n小苑的衣服穿得太整齊了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "好緊喔！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "\n丟丟丟！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "啊哈哈！",
        "unit_id": 132612,
        "voice": "vo_adv_4012008_001"
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "\n好輕盈，動作也好方便！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "\n果然還是這樣最棒──！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "不是，在那之前，別隨便亂脫！",
        "unit_id": 132712,
        "voice": "vo_adv_4012008_002"
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "\n我會害羞好嗎……！",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "……受不了，",
        "unit_id": 132712,
        "voice": "vo_adv_4012008_003"
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "妳每次都太暴露了啦。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "\n說真的，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "妳差不多也該有點羞恥心了。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "\n像是胸部",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "跟腳，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "快遮起來……！",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "好──",
        "unit_id": 132612,
        "voice": "vo_adv_4012008_004"
    },
    {
        "type": "dialogue",
        "name": "小孩彩羽",
        "words": "去外面玩吧！！",
        "unit_id": 132612
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "那",
        "unit_id": 132712,
        "voice": "vo_adv_4012008_005"
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "我要去喝麥酒了，",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "\n",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "成人苑",
        "words": "要大口大口喝。",
        "unit_id": 132712
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……變回原本的樣子反而感覺怪怪的……",
        "unit_id": 132312,
        "voice": "vo_adv_4012008_006"
    }
]