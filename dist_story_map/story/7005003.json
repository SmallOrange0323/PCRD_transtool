[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好痛啊～……",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "手腕不小心破皮了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以說過一定要",
        "unit_id": 100311,
        "voice": "vo_adv_7005003_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n多加小心的啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有打倒魔物是還好，",
        "unit_id": 100311,
        "voice": "vo_adv_7005003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是那樣的敵人",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如果沒有大家一起聯手的話會很麻煩的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之前也跟妳說明過了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊哈哈，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我好像有點太大意了呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你要幫我治療嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太謝謝你了！",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……咦，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你有隨身帶著OK繃呀。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "欸，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是之前照顧你的女孩子讓你帶著的？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是一名叫作可可蘿的女生？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哦。",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎樣都跟我沒關係啦……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？　",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生你的袖子也破掉了呢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請稍等一下呢，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我馬上幫你修補。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的～，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你別動乖乖待著呀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "拿你沒辦法呢，騎士先生。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_7005003_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……紡希他們，",
        "unit_id": 100311,
        "voice": "vo_adv_7005003_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是不是關係突然變好了呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且紡希",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是特地說要來護衛我的嗎，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n怎麼從剛剛",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就只有跟他說話……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且，",
        "unit_id": 100311,
        "voice": "vo_adv_7005003_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他也是。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n好像從剛剛就一直只擔心紡希而已！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "前陣子明明才",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稱呼我為師傅的說……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這樣是，",
        "unit_id": 100311,
        "voice": "vo_adv_7005003_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我在忌妒嗎！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不可能不可能，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼可能會……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哇，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜從剛剛就一直瞪著這邊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是因為剛剛的戰鬥",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有點失誤的緣故嗎？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "太專心縫衣服了",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "，騎士先生的臉好近！？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "縫好了唷。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "走開走開！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n之後注意不要再把衣服用破了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為我不是每次都在你身邊的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎呀，",
        "unit_id": 105411,
        "voice": "vo_adv_7005003_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我為什麼會這樣說呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "也許是因為連續戰鬥導致的疲累吧，\n出現意想不到的言行而感覺不自然的\n怜和紡希兩人。"
    }
]