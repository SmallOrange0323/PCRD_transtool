        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "事實上，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "挑戰有點難度的委託，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n對於持續升級方面是很重要的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過呢，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_039"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我在意的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "並不是那方面。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "而是你們開始瞧不起",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "之前接到的委託這件事。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「那種簡單的委託去找其他公會好嗎。」",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_040"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「我們已經不做那種扮家家酒等級的事了。」",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「這點小事自己就能解決了不是？」",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "從城裡的人們口中聽見各位說過的話時……",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_041"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我真的感到很惋惜。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "挑戰困難的委託沒什麼不好。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_042"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過呢，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "瞧不起拜託自己的人，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這說得過去嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "到後來甚至因為",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_043"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "過度相信自己的能力因而陷入險境，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n真的是讓人無言以對了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可、",
        "unit_id": 1211,
        "voice": "vo_adv_1185002_044"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "可是……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "並不是說你們做得特別差勁。",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_045"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n畢竟會逞強的冒險者",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "多到數不清啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "然後",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_046"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "那種傢伙消失之後，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n替補上來的也是要多少有多少。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "儘管如此，今天你們能撿回一命，",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_047"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n只是因為負責照顧你們的剛好是花凜小姐罷了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "如果不是花凜小姐，",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_048"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n是不會找人做監視新手冒險者這種麻煩工作的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女性、男性",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_1185002_049"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "真是的，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請不要刻意嚇唬人啦。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "目前的公會管理協會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n正在努力充實",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對新人提供的熱情支援喔。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "……這樣啊。",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_051"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "是我多嘴了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "總之呢。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_052"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我希望各位",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對這次事件能深刻反省，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n並且好好地改頭換面一番。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "反正我今天也只是偶然遇上各位，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_053"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n而{player}，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "甚至對來龍去脈根本一無所知。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "即使如此，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_054"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這個人還是在聽見尖叫聲的瞬間",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就衝了出去。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n他一點都沒考慮到衡量得失，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "以及虛榮心之類的事。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果各位",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_055"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "哪天也能成為像{player}這樣，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n能夠為了陌生人行動",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "的冒險者的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我會感到很欣慰的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……好的。",
        "unit_id": 414,
        "voice": "vo_adv_1185002_056"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……我會努力的。",
        "unit_id": 1211,
        "voice": "vo_adv_1185002_057"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "感謝各位。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_058"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼就",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一起回蘭德索爾吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "在那之前，",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_059"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "方便先借用他們一下嗎。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "我想把他們接下的工作處理掉，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n然後順便教導他們身處夜間森林的必備知識。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這麼做真的可以嗎？",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_060"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "畢竟這是花凜小姐妳的委託。",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_061"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n就讓我進行超乎酬勞的",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "勞動作業吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯……",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_062"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼就",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "萬事拜託嘍。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "你們",
        "unit_id": 1111,
        "voice": "vo_adv_1185002_063"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "跟我走。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "女性、男性",
        "words": "好",
        "unit_id": 1,
        "voice": "vo_adv_1185002_064"
    },
    {
        "type": "dialogue",
        "name": "女性、男性",
        "words": "的！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_065"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然嘴上那麼說，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那個人也很溫柔呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我身邊",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "全都是一些好人。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我也得對您說聲謝謝。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_066"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n雖然我很清楚不必擔心，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但怎麼樣都還是有點在意。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "才沒有那種事。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_067"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "協助新手公會",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "再怎麼說都是我工作的一部分嘛。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_068"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不會是因為",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】沒有得到這類支援，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以讓你覺得這很特別吧？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那只是因為各位從一開始就非常優秀了而已。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_069"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不只不需要協助，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "還反過來幫了我不少忙。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這類公會和冒險者是很少見的喔。",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_070"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "比起來會逞強的人數量更多，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "像今天這種事",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "根本是家常便飯。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然可以用「冒險本來就有危險性」來帶過這件事，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_071"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但如果可以，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我還是希望大家都能",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "平安無事，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n順利來回報委託達成了，不是嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "畢竟犯下原本可以避免的失敗，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_072"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n而因此引退的人們，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我實在見過太多了……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以說，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_073"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我的工作",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是要",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "盡可能地，\n減少這類冒險者出現，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是這麼認為的。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然我不像",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_074"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的各位一樣擁有強大的力量，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "即使如此，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我還是想繼續盡己所能。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果像各位一樣",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_075"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不管再怎麼不起眼的委託",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "都能快樂地進行冒險的公會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能一個個持續增加下去",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就太好了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "眾多冒險者",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_076"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "愉快地前去冒險，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n開心地回來報告委託順利達成。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果每天都能過著那種生活，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_077"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我想一定會感到非常幸福。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以說，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_078"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請您以後也要多多達成委託，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n快快樂樂地前來報告委託順利達成。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n為此",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "往後",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我也會拜託您各種事的！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我很期待，",
        "unit_id": 190811,
        "voice": "vo_adv_1185002_079"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n您面帶笑容回來報告的身影哦。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "月光照耀下花凜的笑容，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不知為何讓人覺得比平常更為溫柔了。"
    }
]