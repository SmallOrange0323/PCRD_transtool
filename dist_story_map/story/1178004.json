    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天狗大人駕到是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n若有壞小孩，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就讓你嘗嘗神隱的滋味是也──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正是！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_034"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n既然對手",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "扮成妖怪，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們也",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "用同一招即可是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正所謂",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "入境隨俗是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n同樣打扮成妖怪，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就不怕遭到他們襲擊了。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_036"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天狗啊，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在口耳相傳中，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是能夠變化成",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "人類模樣的是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正是最適合",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個狀況的妖怪是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哎呀──",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_037"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我有事先",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在包包裡偷藏好這套服裝",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是明智之舉是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n有備",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "無患是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿嘿嘿……",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_038"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "難得有這個機會是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在日本妖怪之中",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_039"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就屬",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天狗",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最帥氣是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n若要變裝，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天狗是唯一選擇！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不作他想！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "走吧，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_040"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不可忘記我們的目的。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要開始端正世風是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "本人是",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_041"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正義的大天狗，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n要來嚴懲那些",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對百姓作惡的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妖怪小孩──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "哎唷，",
        "unit_id": 1,
        "voice": "vo_adv_1178004_042"
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "天狗小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "妳的扮裝很用心啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "\n喔喔，好可怕好可怕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "我給妳點心，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "求求妳別對我惡作劇啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔喔──！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_043"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "蔬果店大叔！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你看起來很有活力",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是太好了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這煎餅",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看起來",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真好吃是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_044"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我明明沒說不給糖就搗蛋，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n為什麼",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要給我點心呢？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "這是萬聖節活動的一部分，",
        "unit_id": 1,
        "voice": "vo_adv_1178004_045"
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "我都會發給有變裝的人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "\n為了幫商店街宣傳啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "話說回來，",
        "unit_id": 1,
        "voice": "vo_adv_1178004_046"
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "妳這服裝還真用心欸。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "\n說到變裝，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "大家全都扮成吸血鬼之類的洋派鬼怪，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "蔬菜店店員",
        "words": "\n扮天狗很少見啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_047"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要說日本傳統風妖怪，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n除了天狗別無他選！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "花店",
        "words": "哎呀～",
        "unit_id": 1,
        "voice": "vo_adv_1178004_048"
    },
    {
        "type": "dialogue",
        "name": "花店",
        "words": "好可愛的天狗呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花店",
        "words": "\n來，這個給妳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花店",
        "words": "請收下我的餅乾。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "妳扮得真了不起。",
        "unit_id": 1,
        "voice": "vo_adv_1178004_049"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n我們店裡有在發饅頭。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "來吧，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "喜歡哪個儘管拿！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這次",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_050"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是被商店街的人們包圍是也！？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n得到了",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這麼多點心！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_051"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這些難道是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要進貢給",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的嗎……？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如果是這麼一回事，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_052"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我還想要拿更多是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "拿出天狗真本事的時候到了呀──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈、",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_053"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈、",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "各位老百姓啊──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n倘若不想遭到",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天狗惡作劇，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就交出",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "更多點心來是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "超強……",
        "unit_id": 1,
        "voice": "vo_adv_1178004_054"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n那個天狗",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是剛才帶丸子的大姐姐吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "她要到了那麼多點心……",
        "unit_id": 1,
        "voice": "vo_adv_1178004_055"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_056"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛才",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那兩隻小妖怪吧？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "假如你們放棄惡作劇，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_057"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "成為這一位",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的家臣，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我就分給你們一些",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我得到的點心吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也可邀其他朋友",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_058"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一起來是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如何？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們願意發誓",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "效忠將軍嗎？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "我發誓──！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_059"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "答得好！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_060"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我用點心",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "使侵略的妖怪歸降，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "並擴充家臣了是也──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_061"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們要納入",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "更多家臣！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n百鬼夜行要開始了是也──！",
        "unit_id": 103031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1178004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有做一場好夢嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妮諾真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_1178004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雀躍成那個樣子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來她真的很想扮天狗呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然很機靈地趁勢拿到許多點心，",
        "unit_id": 190011,
        "voice": "vo_adv_1178004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過又全部分給了小孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真像妮諾的作風呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她擁有讓其他人綻放笑容的力量對吧，",
        "unit_id": 190011,
        "voice": "vo_adv_1178004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過本人應該沒有察覺到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妮諾所仰慕的你，",
        "unit_id": 190011,
        "voice": "vo_adv_1178004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在未來的日子裡也要守住她的笑容喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那就這樣，再見囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯，",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_067"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯嗯",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我似乎興奮過頭累倒了，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不小心睡著了是也……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊！",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_068"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請將軍快起床！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n在到家以前",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都算是祭典是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_069"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要是在這裡睡著，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n靈魂",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "說不定會被誤帶去靈界！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖說",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_070"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那邊開始爆發",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "像東國戰國時代般的戰爭，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n但是現在",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "去靈界還太早了是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "首先",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_071"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們要先統一這個現實的天下是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n然後",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "等壽終正寢之後，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們再去統一死者的世界！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到了靈界，",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_072"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在遊行時遇到的",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妖魔",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和幽靈們，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n肯定",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會助我們一臂之力。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大家死後還能再會，",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_073"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "他們都是將軍",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "未來的家臣是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈……",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_074"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過話說回來，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n死掉之後",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也能待在將軍身邊，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是叫人興奮難耐！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "據說死後的世界",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_075"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會永遠存續下去，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我在那邊",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也要一直",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一直",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "當你的頭號家臣喔──！！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "首次度過萬聖節的妮諾"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n天馬行空地幻想著今後繼續延續的統一天下漫漫長路──"
    }
]