    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為萬聖節慶典收尾的遊行結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾熱烈的氣氛逐漸轉為寧靜──"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇呀──",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "滿足，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "滿足是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n萬聖節",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "原來是這麼好玩的習俗，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "超乎想像！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "等將軍",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "造好城堡，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們也在城腳的城鎮",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "舉辦東國風的萬聖節慶典吧！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真想從天守閣",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "觀看百姓",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "開心慶祝的樣子是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……喔？",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍身上又發出",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "之前那種威嚴的光芒了是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "明明是晚上",
        "unit_id": 117811,
        "voice": "vo_adv_1178004_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "卻亮得像白天一樣，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "眼睛睜不開了！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哎～",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呀～～！！",
        "unit_id": 117811
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "好，今天課就上到這裡。",
        "unit_id": 1,
        "voice": "vo_adv_1178004_005"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n請大家回家路上注意安──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪啪！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n打擾了──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "打擾了──！！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "妳、",
        "unit_id": 1,
        "voice": "vo_adv_1178004_007"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "妳是誰！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "那身制服……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "是王林道的……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n來這邊有什麼事？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "有事先辦好訪問申請嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "防問神情？",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "太複雜的日文",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我聽不懂是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "法國來的留學生是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "Bonjour！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有更重要的事，將軍！",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n糟糕了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大事不妙了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "此乃無法預測的危急狀況是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "商店街",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "竟然遭到侵略了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n詳情",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "等到了現場再說！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "先趕過去吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "椿丘高校的各位老師同學，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們就此別過，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "隱身是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "後會有期忍忍是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1178004_012"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "喂！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "給我等一等──！！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不給糖就搗蛋！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔──好可怕、",
        "unit_id": 1,
        "voice": "vo_adv_1178004_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好可怕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我給你點心，放過我吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不給我點心就要惡作劇囉──！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_015"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "吼吼──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呀啊──！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_016"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "給妳很～甜的糖果吧──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍……",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如你所見是也……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n商店街……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "已經被妖怪們侵略了！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們要馬上趕跑妖怪，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "守護居民的生活是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n想必這會是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一場邁向統一天下的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "關鍵戰役！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "啊！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_019"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我們還沒跟那兩個人要點心！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "對呀，",
        "unit_id": 1,
        "voice": "vo_adv_1178004_020"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "去跟他們拿吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "不給糖就搗蛋！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_021"
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "\n不交出點心就對你們惡作劇喔──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔！？",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "隨即就被妖怪包圍了是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "威脅對我不管用喔──！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我平時",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "帶在身上的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "糯米丸子，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n只會賜給要成為將軍的家臣的人！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "喔喔──！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_024"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這丸子看起來滿好吃的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n快把它搶過來──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "包在我身上！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_025"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "咕嘰咕嘰咕嘰咕嘰～～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚哇，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "住手……！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呀哈哈哈哈哈！！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好、",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好癢是也！！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "趁現在",
        "unit_id": 1,
        "voice": "vo_adv_1178004_027"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "拿走妳的丸子啦──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "掰掰──！",
        "unit_id": 1,
        "voice": "vo_adv_1178004_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼……",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n多麼",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "窮兇惡極的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妖怪小孩呀……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "居然搶走我的糯米丸子跑走了……",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最近的年輕人",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "難道不知道桃太郎嗎……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "實在可嘆是也……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_031"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也罷。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n事到如今",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我就展現一下殺手鐧是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 103031,
        "voice": "vo_adv_1178004_032"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請在此稍候片刻！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我準備了",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一招暗藏已久的密技是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪！",
        "unit_id": 103031
    },
