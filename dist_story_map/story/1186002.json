    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……「幸福」",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗎。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "之前……",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐曾經說過呢……",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是不可思議呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1186002_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能夠透過與人接觸的體溫",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感受到幸福，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明我們原本應該",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒有這種能力才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是我",
        "unit_id": 190011,
        "voice": "vo_adv_1186002_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被賦予了這種能力。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n得到了與人類相同的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "珍貴感受性，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也得到了自我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和人生。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從{player}他們的身上……",
        "unit_id": 190011,
        "voice": "vo_adv_1186002_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想要報恩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 190011,
        "voice": "vo_adv_1186002_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我認為妳",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也獲得了和我相同的感受哦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500366"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "透過與人接觸的體溫",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "感受到幸福的能力……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n之前心底感受到的",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那股暖意，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果就是那個的話……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……唉。",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那怎麼可能呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我又沒有去過索爾之塔，",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n也不像菲歐有讓人作夢的能力。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n哪有可能……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "會具備那種功能嘛。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……果然是bug吧。",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "肯定是。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n所以那種感覺",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "遲早都會被修復然後消失掉的。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n又或者，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是bug越來越嚴重，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "最終導致我自己壞掉吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒錯……",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "畢竟我本來",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就是個沒有完成debug的嚮導小妖精。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "永遠都是",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不穩定的存在──",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "！",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "醒來了嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n剛才明明還在呼呼大睡的說。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真不知……",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "該說是時機很巧還是很不巧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……那個，",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我有件事",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "想問你……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我是說如果喔？",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果有一天",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我充滿了bug，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n想修理都無能為力，就這麼壞掉了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你會怎麼做？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我……",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "如果再也不是我了",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "怎麼辦……？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "唔！",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這什麼",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不經思考的回答啦～！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你好歹也稍微煩惱一下嘛！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "唉，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是很像你的作風吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "問了個怪問題呢。",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_019"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "當我沒說過。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你快回房間睡覺吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "…………",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……幹嘛？",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還呆呆站著不動。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你不睡嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "散、",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_022"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "散步～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "大半夜的發什麼神經……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呃，",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "喂！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你真的要去啊？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n等我一下啦～！",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯……",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "夜裡的森林還真安靜啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n看樣子連魔物也都入睡了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "意外地很安全嘛。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……所以呢？",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_025"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你到底要幹嘛？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n找我來這種地方散步。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊！",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "露出真面目了吧，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "拐騙女孩子的色鬼！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難、",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難不成",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你把我帶來這種人跡罕至的地方，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n也是為了……！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "唔！？",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_027"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "明明是個色鬼，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n突然說出了很正經的話嘛……！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可是",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_028"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "人家也不是只會惡作劇好嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n有時候也會想靜一靜啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯……",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你帶我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "來這種安靜的地方……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n或許",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "正合我意",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也說不定？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……謝謝你",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "帶我來這裡。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "…………",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_031"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "討、",
        "unit_id": 190911,
        "voice": "vo_adv_1186002_032"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
