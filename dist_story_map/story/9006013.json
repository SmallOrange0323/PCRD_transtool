[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}回過神來，發現自己佇立在熟悉的地方。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "照慣例說說。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在「那邊的世界」的夢境如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是不是",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像我一開始說的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是份只有我能送的特別禮物啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這場夢境是由你的記憶碎片所構成的，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次是用你記憶中較古老的片段重現的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也因為這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "出現了平常見不到的人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n挺新鮮的吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒想到連那個人都出現了呢～",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也嚇了一跳。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你有喜歡就好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以上，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我這次送給你的夢境禮物結束了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喂，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別擺出那種失落的表情好嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像我做了什麼壞事一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別擔心，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "慶祝還沒結束。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可沒時間讓你感到失落喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "紀念日當天，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還準備了夢境之外的其他禮物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你就",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好期待吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼？",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想知道是什麼禮物……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不行，不能告訴你～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "驚喜要留到當天喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿她們在「這個世界」，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也正在準備慶祝。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為是特別的紀念日，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她們可是卯足了勁準備喔～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明天起你就和她們一起同樂吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真羨慕你～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n啊──！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也好想和小可可蘿一起慶祝喔～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要連我的份一起享受喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟這是一年一度的特別紀念日，",
        "unit_id": 190011,
        "voice": "vo_adv_9006013_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你要盡情地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "投入玩樂喔！",
        "unit_id": 190011
    }
]