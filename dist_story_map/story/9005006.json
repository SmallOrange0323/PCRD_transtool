[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了送禮的事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲持續在街上到處向人徵詢各種不同的意見。"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥會喜歡的東西～？",
        "unit_id": 102012,
        "voice": "vo_adv_9005006_000"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "大概是花冠之類的吧～？",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "才不是呢，美美～！",
        "unit_id": 100411,
        "voice": "vo_adv_9005006_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥喜歡的是有趣的惡作劇！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "送他嚇人箱，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "他肯定會高興得跳起來！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那純粹只是嚇到而已吧，",
        "unit_id": 103611,
        "voice": "vo_adv_9005006_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個人畢竟是變態可疑分子。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我覺得應該送適合這個身分的禮物。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……適合變態可疑分子的禮物",
        "unit_id": 106412,
        "voice": "vo_adv_9005006_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是什麼呢……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請、",
        "unit_id": 103611,
        "voice": "vo_adv_9005006_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請等一下！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不用想得那麼複雜！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我說的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變態可疑分子，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就只是普通的變態可疑分子的意思……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "普通的變態可疑分子是什麼？",
        "unit_id": 100411,
        "voice": "vo_adv_9005006_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華說的話好難懂喔～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不過，",
        "unit_id": 102012,
        "voice": "vo_adv_9005006_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美也想送哥哥禮物～♪",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "如果有美美我們",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "可以幫忙的地方，一定要跟我們說喔，雪菲！",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美我們什麼都願意做！",
        "unit_id": 102012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106412,
        "voice": "vo_adv_9005006_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n謝謝妳們，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等決定好了",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會找妳們幫忙的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "本來是想要採納小孩子的純真意見的，",
        "unit_id": 106412,
        "voice": "vo_adv_9005006_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但真沒想到現在的小孩子",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "懂得這麼多怪怪的事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這或許是意料之外的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "靈感來源也說不定呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_9005006_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那邊也有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一個小朋友。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "抱歉打擾一下，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可否請問妳",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一個問題呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n──這位小妹妹。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_9005006_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "龍人族女孩？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n蹲這麼低，簡直像是在跟幼童講話一樣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……喔，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳在煩惱要送什麼禮物給平日常關照妳的少年？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_9005006_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那個龍人族女孩，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "本來是想徵詢小孩子的純真意見，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n偏偏好死不死找上了100％不純真的汙穢大人：優妮學姐。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會被學姐的外表給欺騙，",
        "unit_id": 110812,
        "voice": "vo_adv_9005006_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n就表示那女孩比學姐要純真太多了……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "遇到詐騙也能學個教訓，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒關係吧？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也不知道啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_9005006_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總覺得我好像不小心陷入麻煩的局面了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀不好意思，",
        "unit_id": 111011,
        "voice": "vo_adv_9005006_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "其實我剛才不小心聽到了妳跟美美她們的對話。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別看我這樣，我也是小小甜心的名譽成員。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "小孩子的純真意見，我可以輕而易舉地",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "提供妳一大堆。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比方說，",
        "unit_id": 111011,
        "voice": "vo_adv_9005006_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想想……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是我個人獨創且純真的意見，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳可以去摘野花回來親手製作一個花冠送給他。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喂，",
        "unit_id": 110911,
        "voice": "vo_adv_9005006_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那傢伙直接盜用別人的點子耶！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，這是可以的嗎！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個汙穢的18歲人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n竟然厚顏無恥盜用一個10歲小朋友的點子啊！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不意外。",
        "unit_id": 110812,
        "voice": "vo_adv_9005006_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那傢伙的字典裡根本沒有純真這兩個字。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真要她自己原創的話，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "肯定會說送些可疑的書或藥物之類的吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮也想送哥哥禮物～♪",
        "unit_id": 111011,
        "voice": "vo_adv_9005006_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n姐姐、姐姐，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果有優妮們可以幫忙的地方，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一定要跟我們說喔！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n優妮們什麼都願意做！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我找錯詢問對象了……",
        "unit_id": 106412,
        "voice": "vo_adv_9005006_019"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲毫無任何斬獲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n只想逃離現場。"
    }
]