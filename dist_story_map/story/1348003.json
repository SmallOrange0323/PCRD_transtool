[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "深入危險的叢林，紡希成功採集到目標的材料。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和{player}一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n馬上"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "試著製作新的衣服──"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼樣？",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這件連身裙！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n活動自如又堅韌，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是堅持講究素材的一件衣服。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "顏色也是",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "保持著華麗的同時又能襯托膚色的絕佳平衡……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "雖然素材看起來的確很堅韌……",
        "unit_id": 50611,
        "voice": "vo_adv_1348003_001"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "造型也不錯，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "不過，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n這個飄來飄去的東西",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "是有什麼用處嗎？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "把抓到的獵物綁起來吊著……？",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "飄來飄去的……",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是在說緞帶嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這不是要那樣用的，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是為了讓衣服更可愛的裝飾。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可以在整體輪廓上再增添點綴，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看起來更時尚♪",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "我沒辦法理解",
        "unit_id": 50611,
        "voice": "vo_adv_1348003_003"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "妳所說的",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "「時尚」。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n動起來會飄來飄去的很礙事，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "而且那個，",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "……我也沒有想要打扮得漂亮",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "去展示給誰看。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不會礙事的，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在這個位置的話，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "拿武器時也不會去勾到。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果想做的更實用的話，也可以換個風格改變位置……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "不是那個問題。",
        "unit_id": 50611,
        "voice": "vo_adv_1348003_005"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "我不覺得",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "穿上這種衣服的自己會更好。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "……總、",
        "unit_id": 50611,
        "voice": "vo_adv_1348003_006"
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "總之！",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "這種風格",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "不適合我。",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "\n",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "衝鋒迅豹女性",
        "words": "很抱歉……",
        "unit_id": 50611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n稍等一下啊……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嚼嚼……",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好辣！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n吉歐‧格黑納的人們真的是！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好辣！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n完全不懂時尚！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好辣好辣！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是啦沒錯。",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這個世界",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "辛香料倒是發展得很豐富呢。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n明明時尚",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "完全不普及……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那算是得意之作的說。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "尤其是那個緞帶，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是我的特別講究的細節。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n果然時尚這件事",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "無法獲得他們的理解嗎。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在慈樂之音，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得可愛的東西，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n小望跟千歌，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有粉絲們",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也都能理解。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在吉歐‧格黑納卻都不管用。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "先不說眼睛跟腦袋還有內心都腐壞的華音，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n連那位女性都無法理解，真是令人沮喪。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然現在是",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "舌頭在刺痛，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但我的心也同樣感到刺痛……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "非常沮喪消沉。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那個，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n時尚",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "到底",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是什麼呢？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n對我來說是很重要，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "屬於自己的一部分。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的髮飾嗎？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……沒、",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n其實是",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和邊緣的絨毛部分統一做成白色的。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "另外",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再加上羽毛裝飾做點綴！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊──！",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生這個色狼──！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……雖然很想這麼說，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但這的確是我講究的細節！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "意外的有在觀察這些設計呢！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊……",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼辦，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "超開心的……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n感覺只要一鬆懈",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就會露出傻笑。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些時尚的小細節能被注意到，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n真的很令人感動呢。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我所重視的時尚，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正是由這些細節巧思累積而成……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "────啊。",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_019"
    },
    {
        "type": "background",
        "background": "502250"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我好像",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "搞錯了。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "至今為止，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我一直在叫人穿這個、",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "穿那個的，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也許有點……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那個，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "強迫他人了。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是我被其他人強迫接受他的穿衣品味，",
        "unit_id": 134812,
        "voice": "vo_adv_1348003_021"
    },
    {
        "type": "dialogue",
