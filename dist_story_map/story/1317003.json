        "type": "dialogue",
        "name": "困擾的人２",
        "words": "打倒它們嗎？",
        "unit_id": 313
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……看吧？",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼你的回答也感覺很呆板？",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_035"
    },
    {
        "type": "dialogue",
        "name": "困擾的人２",
        "words": "其實──",
        "unit_id": 313,
        "voice": "vo_adv_1317003_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就說別再講那句了！",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再繼續抱怨下去也是浪費時間。",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "趕快了結這個",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "任務吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "三隻同時出現什麼的，還真是親切的安排呢。",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別直接放剪影出來啦……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，上吧。",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n數量雖多，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但它們行動本身很慢，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一隻一隻解決吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在它們接近之前把沙子之類的往上掃，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "擋住它們的視線不就好了嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那樣",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "攻擊也會很容易打中喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……總覺得",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可能也已經很久沒有",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給人這種意見了。",
        "unit_id": 131711
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來我的意見有幫上忙呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過……",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還沒有結束。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小心別和她對上視線，看看那邊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "困擾的人３",
        "words": "…………",
        "unit_id": 1512,
        "voice": "vo_adv_1317003_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……對吧？",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說實話，我非常在意那個穿著巫女服的阿姨在煩惱什麼，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但實在沒辦法一直配合這種事啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以說，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要逃了喔！",
        "unit_id": 131711
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……呼，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到這附近來的話，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該也不會再有任何埋伏了吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到底是怎樣？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被某人拜託收集東西，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有因別人的請求而打倒魔物，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該說莫名像遊戲嗎──",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──還是該說",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很懷念呢？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不曉得吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還是菲歐的時候，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "打倒魔物來提升等級",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之類的，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有為了取得稀有道具",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而完成任務，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這些都是",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很理所當然",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的啊……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊啊，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是那麼一回事吧，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別做……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "多餘的事情啦，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵……",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是很無聊的事啦。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，你",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於來到這個夢中之後的我，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n沒有任何想法嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣啊。",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n彆扭的內心",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是不會那麼輕易恢復",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……你那樣覺得嗎？",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是嗎……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就是真正的……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那是我的其中一面，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要記住喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……像這樣站在你身邊，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n果然有點違和感呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是啊……",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為以前的我",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是小小的妖精，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是在你周遭",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到處飛。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……要是累了，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就會停在你的肩膀上。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看看，",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我現在不是沒辦法",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "做那種事嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n時時刻刻都必須用自己的腳來行走。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總覺得沒辦法",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "習慣那一點呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……就覺得，我果然",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟那時的我",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是不一樣的",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n什麼意思？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀──！？",
        "unit_id": 131711
    },
    {
        "type": "still",
        "still": "131700301"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你突然幹嘛啦！",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的行動太出其不意了啦！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀！",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別擅自把我",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抬起來搖晃！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很可怕、",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很可怕啦！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是說，你",
        "unit_id": 131711,
        "voice": "vo_adv_1317003_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是說我很重之類的，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
