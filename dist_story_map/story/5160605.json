[
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "その日、サレンディア救護院ではメドゥーサを歓迎して"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n鍋パーティが催されることになった。"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お招きいただき感謝するぞ。",
        "unit_id": 133212,
        "voice": "vo_adv_5160605_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nこれはお土産のジュースだ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ありがと、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_001"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "モニカ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nサレン！　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "モニカが来たわよ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nアタシも部屋の荷物は片付いたけど……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "いらっしゃいモニカさん。",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_002"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n二人とも、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "はい、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "これ着けて。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "これって、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_003"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "エプロン？　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なんでこんなものを……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "モニカさんは料理の準備を手伝って。",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_004"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nメドゥーサは子どもたちと一緒に配膳をお願いね。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "は、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_005"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "はああ！？　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "お手伝いいぃー！？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "今日はアタシの歓迎パーティーだって聞いたけど？",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_006"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "そうよ。",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_007"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "救護院ではパーティーの主役だって働くの。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n働かざる者食うべからずってね。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nうちは人数が多いから、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お手伝いは当たり前よ。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うむ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160605_008"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "教育が行き届いているな。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n頑張って準備すればその分早く食べられるし、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n働いた後のご飯はいっそうおいしくなるぞ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "郷に入っては郷に従え、",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_009"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "とも言うわね。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n二人とも、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "よろしくね。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたしはスズメを手伝ってくるから。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "はぁ、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_010"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なんでアタシがこんなことを……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n普段は人の世話なんてしないから面倒ったらないわ……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "子ども１",
        "words": "ママ・サレン！　",
        "unit_id": 111,
        "voice": "vo_adv_5160605_011"
    },
    {
        "type": "dialogue",
        "name": "子ども１",
        "words": "テーブル拭き終わったよ！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "子ども２",
        "words": "あたしはお皿並べたよ！",
        "unit_id": 211,
        "voice": "vo_adv_5160605_012"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "頑張ったわね、",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_013"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "二人とも。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nそれじゃあ今度は他の子のお手伝いしてきてくれる？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "子どもたち",
        "words": "はーい！",
        "unit_id": 1,
        "voice": "vo_adv_5160605_014"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "……あんなちびっ子が文句一つ言わずに働いてるのに、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_015"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nアタシってば文句ばっか。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "カッコ悪いわね。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "サレン！　",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_016"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "こっちは終わったわよ！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n次は何すればいい？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ありがと。",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_017"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "それじゃあ薪の追加を持ってきてちょうだい。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "その後何事もなく準備は進み、食卓には大きな鍋が並んだ。"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "これが、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_018"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "お鍋……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "大きな鍋で具材を煮ただけの料理。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nそれをみんなで囲んで食べるなんて……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "子どもはわちゃわちゃして騒がしいし、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_019"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nお姉ちゃんたちと暮らしてた頃の優雅な晩餐とは大違いだわ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nでも……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "全然嫌な感じがしない、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_020"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ううん、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "すごく楽しい！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nみんなで食べるご飯って、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "こんなにおいしかったんだ……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "メドゥーサ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160605_021"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お椀が空になっているぞ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nほら、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ついでやろう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ありがとう。",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_022"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "お肉いっぱい入れてちょうだい！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "こら、",
        "unit_id": 133212,
        "voice": "vo_adv_5160605_023"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "子どもたちも食べるんだぞ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "少しは自重しろ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n代わりに野菜をたっぷり入れてやろう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "あ！　",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_024"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ひどいことするわね、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "蛇虐待よ蛇虐待！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あはは、",
        "unit_id": 133512,
        "voice": "vo_adv_5160605_025"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お肉もまだいっぱいあるから、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "安心して。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nまずは野菜をちゃんと食べてからね。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n野菜を先に食べたほうが、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "美容にもいいらしいわよ？",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "……仕方ないわね。",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_026"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "約束よ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "お姉ちゃん、",
        "unit_id": 133612,
        "voice": "vo_adv_5160605_027"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "お鍋って楽しいわよ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nいつか再会したときは、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アタシが作ってあげるからね！　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "こうして救護院に暮らすことになったメドゥーサは"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n久々の楽しい夕食の時間を過ごすのだった。"
    }
]