        "voice": "vo_adv_2212104_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會賣附贈周邊的預售票",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是鐵則！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣的話，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就得在",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這家店裡",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "買起來才行了！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "預約區在……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔唔？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔唔唔唔唔？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n「吸血鬼‧偶像樂園♪」……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "劇場版",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "中止製作！？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼會，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明是大家都知道的霸權動畫，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n搜、",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "搜尋一下吧……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我看看，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "官方提供的資訊",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只有中止製作……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "網路上的不可靠資訊是怎麼說的呢～？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "中止製作的原因是……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「米奈娃的",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "禁錮」……？　",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……主要工作人員從某天起就",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "下落不明……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n……據傳聞所說",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是沒有從「禁錮」中回來……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……目前毫無",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再次開始製作的預定……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「米奈娃的禁錮」的影響",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "居然這麼大嗎……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難道說，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會就這樣",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再也看不到後續？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……話說大概",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其他的作品也……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──太令人悲痛了！",
        "unit_id": 1,
        "voice": "vo_adv_2212104_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "《忍者國的逆襲》",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "重製漫畫停止發行……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n呃呃，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我無法接受……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "明明專程渡過海洋來到Japon了，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_015"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "不，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "雖然是有任務在身。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n沒想到",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "居然看不到後續了……",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那邊的人，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看起來是國外的忠實粉絲呢。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n哇，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "用手遮住臉，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "做出了打從心底感到難受的動作……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n同為宅宅，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "身為同好，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我非常能理解他的心情。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我記得《忍者國的逆襲》……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n稍微搜尋一下……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然是這樣。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……你好，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那部作品……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n雖然單行本",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "已經停止發行了，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但如果是到途中的話，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "去找雜誌",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該還能看得到。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "什麼？",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_019"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "真的嗎？",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是的，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我記得是換公司繼續連載了……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……那個，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你看得懂",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "日文嗎？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n打開網站……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是這一頁。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "喔喔，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_021"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "這真是……！",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "沒想到還能",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "再次",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "沉浸在",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "這個作品的世界中。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n要是沒有小姐妳，我差點就失去一個邁向明日的希望了。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小意思小意思。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可不能對同好的危機",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "視而不見。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n在下只是以義為名",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "前來相助而已。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "呼嗯……",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_023"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "那高深的說話方式、",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "行為舉止、",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "氛圍。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "看來是很厲害的「熟練者」。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你才是，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在拿著的",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「和牛忍法帖」……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n沒有選打折的便宜版，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而是選重製版真是有眼光。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是不得了的……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "強者",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呢。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "哎呀，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_025"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "今天能在這裡遇到像妳這樣的人真是令人感激。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n如果時間允許，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "希望可以發揮妳的審美眼光，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n告訴我妳推薦的忍者作品。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "根據介紹的作品",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來測試手腕──",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是宅宅間的認真對決。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n雖然",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那方面的作品",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是在下的專業……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但在這裡撤退就太失禮了，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接受挑戰！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "哈哈……",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_027"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "我果然沒有看錯人。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n感謝妳接受我的挑戰，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "那麼，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "就讓我見識妳的本事──",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "──公務臨檢是也！",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔唔！？",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這聲音……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是妮諾氏啊～！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n好久不見了！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話說",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難道這是第一次在現實見面？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔喔，",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "七七香！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好久不見了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還記得我嗎？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為妮諾氏的角色特色很強烈啊～！",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n只要看過一眼，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就不會輕易忘記的！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不如說，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要我忘掉會比較困難。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在這裡遇到",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真巧呢。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妮諾氏的目標是？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔，",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_033"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我今天來",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不是為了",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "買東西！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來找Tonton的！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛才",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_034"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在找將軍的時候，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我看到Tonton了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "從以前就這樣，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "稍不注意",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就會馬上不見……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "因為Tonton",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "從以前開始就喜歡玩捉迷藏呢～",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "Tonton這個名字聽起來",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有九成的可能是寵物。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "聽說最近",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "除了養貓狗，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "養迷你豬的人",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也越來越多了～",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "by",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小七七香個人調查。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在這都會的冰冷水泥叢林中……",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_036"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n和妮諾氏分開的寵物Tonton（暫），",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n一定也很不安……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的直覺",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣告訴我！　",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很好，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這邊就交給",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "名偵探小七七香吧！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真相只有一個！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要找的東西有兩個！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "將軍跟Tonton",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我都會",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "找出來的！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "七七香也要幫忙找嗎？",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_038"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "感激",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "涕零，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "萬分感謝是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯！",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是這樣，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "白衣人！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為了拯救有難的好友，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我就先失陪──",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不見了？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明到剛剛為止都還在的……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n難道說",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是只有我看得見的",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喜愛忍者的大叔幽靈？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "糟了，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我錯過覺醒忍者精神的Flag了嗎……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "七七香，",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_041"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "Tonton",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好像不在店裡是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "找找看",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "其他地方吧！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "了",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "解！",
        "unit_id": 101331
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話說妮諾氏，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_043"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "Tonton是什麼動物啊？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n果然是小豬嗎？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還是熊貓？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不是",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_044"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "動物喔？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在日文中",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是「舅舅」",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "的意思是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們會稱",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "媽媽的弟弟為Tonton，",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n他教了我很多電影和",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "日本文化！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "聽說他最近",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_045"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很認真在工作……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到會在日本看到他是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔～？",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_046"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來是在找",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "舅舅啊。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話說，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我剛剛也和",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從國外來的同好",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "進行了靈魂的對話──",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "──哎呀，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_047"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n危機解除了嗎。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "不過……",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_048"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "沒想到外甥女是{player}的夥伴，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "這世界真小。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "雖然我個人",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_049"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "不排斥重逢……",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "但身為公務員，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "我們的利害關係是相反的。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "現在先避免接觸會比較好吧。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "……Adieu，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "妮諾──",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊～！",
        "unit_id": 103031,
        "voice": "vo_adv_2212104_050"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "Tonton！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "找到你了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "站住站住～！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "──我變。",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_051"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "呼嗯，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_052"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "居然被自己的外甥女逼到無路可退嗎。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "這就是人生。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "為外甥女成長感到高興的同時卻也因此陷入困境，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "切身體會世間無常啊──",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "……",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "哎呀？",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妮諾氏，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_053"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有找到嗎～！？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n哪一位是Tonton氏？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "Tonton～？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "哎呀，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_054"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "居然從背後",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "夾擊。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "嗯，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "這個狀況在日文中要怎麼說呢，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "對了──",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "前門拒虎，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "後門進狼，",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "是嗎。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "和外甥女久違的鬼抓人，",
        "unit_id": 194331,
        "voice": "vo_adv_2212104_055"
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n人數、體力、環境熟悉程度",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "都是對方更占上風呢。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "\n",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "要是能平安度過這次難關就好了……",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "格魯尼",
        "words": "哎呀哎呀。",
        "unit_id": 194331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "格魯尼究竟能否逃過充滿體力的高中女生追蹤呢。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n感受到外甥女妮諾的成長，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n格魯尼不禁對命運的因果嘆息。"
    }
]