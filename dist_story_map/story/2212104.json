    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好久沒有攝取到的",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "二次元成分",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "正在滲透全身……♪",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在小七七香被囚禁在阿斯特朗時，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n出版的大量新刊……！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "角色周邊……！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n錯過的動畫、或官方活動……！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這些東西像這樣一次全部供應的話，",
