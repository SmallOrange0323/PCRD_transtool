    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "某部動畫的劇場版",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也差不多要上映了？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯，",
        "unit_id": 101331,
        "voice": "vo_adv_2212104_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "播出時完全掌握當期話題的……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n異形吸血鬼少女們",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唱歌跳舞的",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個傳說中的偶像動畫！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n「吸血鬼‧偶像樂園♪」",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的劇場版！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這類電影",
