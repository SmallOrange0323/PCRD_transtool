[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟你一起去各地配送郵件之後，",
        "unit_id": 103811,
        "voice": "vo_adv_6040403_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我又再次理解真陽到底有厲害了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "希望能夠成為像她那樣優秀的大人呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然應該沒辦法完全像真陽一樣，",
        "unit_id": 103811,
        "voice": "vo_adv_6040403_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過如果我能以我的作法，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "待人和善，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "開朗地生活下去就好了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n以後",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也想要繼續在真陽身邊觀察她。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "從自己能做到的地方開始做起",
        "unit_id": 103811,
        "voice": "vo_adv_6040403_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你說的對。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不需要著急，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "從現在能做到的事情開始一點一點做起，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就能夠慢慢地接近真陽了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為什麼你要欲言又止呢？　",
        "unit_id": 103811,
        "voice": "vo_adv_6040403_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的確真陽她",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n看起來很嬌小又很可愛……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我可不是",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n說她的外表看起來很孩子氣喔！",
        "unit_id": 103811
    }
]