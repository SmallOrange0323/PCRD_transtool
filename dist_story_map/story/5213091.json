[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔姆唔姆……",
        "unit_id": 101112,
        "voice": "vo_adv_5213091_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n邊吃會邊變大的香菇，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是太厲害了吧！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明明外表閃閃發亮又五彩繽紛，",
        "unit_id": 101112,
        "voice": "vo_adv_5213091_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n味道卻很多汁，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有一點鹹，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還帶著淡淡甜味！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果是我家的公會長，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一定會想把它加進可麗餅裡！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這種該怎麼形容才好呢？",
        "unit_id": 101112,
        "voice": "vo_adv_5213091_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是那種",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "財貓雙全",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "的感覺呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "咦？",
        "unit_id": 133111,
        "voice": "vo_adv_5213091_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "難、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "難道，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "妳是想說才貌雙全嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對，",
        "unit_id": 101112,
        "voice": "vo_adv_5213091_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是這個！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "又可愛又好吃，份量又十足，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的非常棒呢♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_5213091_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我腦中一下子冒出好多靈感喔～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "把這個可愛香菇的花紋，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣那樣搭配一下……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n再加上像這樣感覺的緞帶，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一定會變得很可愛！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你，",
        "unit_id": 101112,
        "voice": "vo_adv_5213091_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有薇歐莉特小姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "多虧了妳們，我腦中湧出好多可愛洋裝的靈感！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "下次，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會把做好的衣服送給妳喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "從這個香菇得到靈感後做出的衣服嗎……？",
        "unit_id": 133111,
        "voice": "vo_adv_5213091_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n走著走著，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就會變大的衣服……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這個，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我實在沒自信有辦法穿好……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "你覺得如何呢……？",
        "unit_id": 133111
    }
]