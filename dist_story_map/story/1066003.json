        "voice": "vo_adv_1066003_050"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥就只要好好地看著",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的生活之道就行了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n……不可以移開視線喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚……",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_051"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但果然還是好可怕……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這次",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就特別允許小哥牽我的手。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只有這次喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祈梨就這樣被拉著手，回到了【龍族巢穴】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而等待著她的，是跪坐著寫五個小時的悔過書、"
