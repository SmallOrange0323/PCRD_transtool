[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾的巷弄間閒晃的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被一個有些熟悉的叫喚聲攔了下來。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊那個你！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n給我把手放在頭上，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "慢慢地轉過身來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要是敢輕舉妄動的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你知道會有什麼下場吧……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然是小哥啊。",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說回來，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥在這裡做什麼？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "散步？",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥還真是毫無危機意識耶……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這裡可是幫派的地盤喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幸好發現你的人是我呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你到底有多傻啊？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過正好，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要去外面辦點事，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就順便帶你出去吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你問我在做什麼？",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的話……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼哼！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不瞞你說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我在執行機密任務喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸？",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "之前那筆生意後來怎麼樣了？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "結果最後，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「地盤裡出現了受歡迎的攤販，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這樣一來",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是也能夠",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大賺一筆嘛～」",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大這麼說了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是說，",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這都是我的功勞！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後呢，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這次是公會那邊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是【龍族巢穴】的任務，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很驚人喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "竟然是要把從某個遺跡出土的東西帶回來。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然，",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我只是要去進貨的商店拿取而已啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過這可是被托付公會重要資金的大任務！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n是只有我這種幹部才能勝任的。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼了？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你有興趣嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……一般來說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種任務可是不允許無關的人參與的喔～",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但如果小哥",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "無論如何都想跟來的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也不是不能考慮一下啦。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不是因為",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我自己一個人會感到不安喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n絕對不是這樣喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這點你可要搞清楚了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總覺得小哥一直都在小看我啊……",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以這次我非得展現出",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我能幹的一面不可！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之，",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥想要一起去對吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n哼哼哼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真拿你沒轍！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那你就跟我來吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n準備突擊囉～！",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我記得那間店是在這附近才對……",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛才那個人是怎樣啊？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看起來還真雀躍耶……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了，不重要。",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在應該專注在任務上。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "店長～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在嗎～？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "我在這裡，",
        "unit_id": 511,
        "voice": "vo_adv_1066003_015"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "有什麼事嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我是【龍族巢穴】的人。",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我來收取",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說好的東西了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "啊啊！",
        "unit_id": 511,
        "voice": "vo_adv_1066003_017"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "啊……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "關於這個呢，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n那個東西",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "已經被剛剛的客人……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥～！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你做了什麼好事！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們可是掌管這一帶的【龍族巢穴】耶！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你竟然不把先說要買的我們放在眼裡，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還真是大膽！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "這個嘛，",
        "unit_id": 511,
        "voice": "vo_adv_1066003_019"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "按先後順序來說或許是這樣沒錯……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "但剛才那位客人",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "可是願意出比你們多一倍的價格啊，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "嘿嘿嘿。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你作為生意人該有的誠信呢！",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你知不知道你能在這裡悠哉地做生意，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都是多虧了誰啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "話是這麼說沒錯啦，",
        "unit_id": 511,
        "voice": "vo_adv_1066003_021"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "不過這附近可沒有任何一家道具店",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n敢得罪收藏家啊……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可惡～",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然如此我就去把那個買家教訓一頓……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "……我不會害妳的，",
        "unit_id": 511,
        "voice": "vo_adv_1066003_023"
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "妳還是死了這條心吧……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "其他東西的話倒是可以便宜賣妳，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "雜貨店",
        "words": "\n能不能就這樣讓這件事過去呢？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算你說其他東西，",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們在找的可是很特別的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等一下。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個東西……",
        "unit_id": 106611,
        "voice": "vo_adv_1066003_025"
    },
    {
