[
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和純在拉菲的帶領下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前往即將舉辦演唱會的廣場。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哦，",
        "unit_id": 124214,
        "voice": "vo_adv_5106604_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是小克莉絲擔任製作人的……",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是慈樂之音的各位吧。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "看來正在傷腦筋的人就是她們幾個呢。",
        "unit_id": 5512,
        "voice": "vo_adv_5106604_001"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "如果是認識的人正好！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n妳們好～！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，",
        "unit_id": 105411,
        "voice": "vo_adv_5106604_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這個地方目前禁止相關人員以外的人出入……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，",
        "unit_id": 102913,
        "voice": "vo_adv_5106604_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你來啦♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我好開心。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這位是？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 124214,
        "voice": "vo_adv_5106604_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "失禮了。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是【王宮騎士團】團長純。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲平時承蒙幾位的關照了……",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦！？",
        "unit_id": 104211,
        "voice": "vo_adv_5106604_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳是純小姐",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗎！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不好意思，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為妳穿得和平時不一樣，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以沒認出來……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們才是受到了製作人的諸多關照。",
        "unit_id": 102913,
        "voice": "vo_adv_5106604_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還有，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "【王宮騎士團】的各位也經常協助",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會場警備……\n真的",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "非常感謝你們。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "寒暄",
        "unit_id": 5512,
        "voice": "vo_adv_5106604_007"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "差不多就夠了啦！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "比起這個，妳們有什麼願望嗎？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 124214,
        "voice": "vo_adv_5106604_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉抱歉。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個女孩是天使拉菲。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n事情是這樣子的……",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後",
        "unit_id": 104211,
        "voice": "vo_adv_5106604_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家就一起幫天使的忙呀。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得很了不起哦。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以才來問我們有沒有願望……",
        "unit_id": 105411,
        "voice": "vo_adv_5106604_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有是有啦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們有點煩惱",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "演唱會的演出效果……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯……",
        "unit_id": 124214,
        "voice": "vo_adv_5106604_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲怎麼說呢？",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人她",
        "unit_id": 102913,
        "voice": "vo_adv_5106604_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正在處理別的事情……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "去幫聖誕老人的忙了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "照理來說，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也應該去的……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但她說什麼",
        "unit_id": 105411,
        "voice": "vo_adv_5106604_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "「聖誕老人三人份的工作量我輕輕鬆鬆就能搞定！」",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n然後就自己去了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n的確很像她的作風啦……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那麼，",
        "unit_id": 5512,
        "voice": "vo_adv_5106604_014"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳們是想幫",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那位製作人的忙，",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n再把她帶回來嗎？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 104211,
        "voice": "vo_adv_5106604_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們完全不擔心她。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "倒是她",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還會罵我們不要妨礙她呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 124214,
        "voice": "vo_adv_5106604_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小克莉絲一個人也不要緊的。",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "反而是演唱會的演出效果",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "更令人擔心吧？",
        "unit_id": 124214
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是的！",
        "unit_id": 102913,
        "voice": "vo_adv_5106604_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然製作人沒有特別說什麼，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但我覺得",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "演出效果可以再華麗一些……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嗯嗯……",
        "unit_id": 5512,
        "voice": "vo_adv_5106604_018"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那麼，",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "演唱會當天，",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n讓100名天使",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "從天界降臨怎麼樣？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 104211,
        "voice": "vo_adv_5106604_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不用做到那種程度……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我覺得很華麗很好呀？",
        "unit_id": 5512,
        "voice": "vo_adv_5106604_020"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嗯？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "什麼？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "你問我有沒有什麼天界的道具",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嗎？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n唔～",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我也沒帶多少過來，",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "如果是這種的話……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是……",
        "unit_id": 105411,
        "voice": "vo_adv_5106604_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "鈴鐺？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哇！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "它對聲音有反應，",
        "unit_id": 104211,
        "voice": "vo_adv_5106604_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以發亮了……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好美啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這個是天界的鈴鐺……",
        "unit_id": 5512,
        "voice": "vo_adv_5106604_023"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n它只是會隨著聲音",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "發亮而已喔？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這種東西能派上用場嗎？",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔……",
        "unit_id": 102913,
        "voice": "vo_adv_5106604_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個很棒！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "用這個的話，不必更動舞台結構",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也能讓演出效果變得更豪華！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這麼一來也有足夠的時間練習舞蹈了呢。",
        "unit_id": 105411,
        "voice": "vo_adv_5106604_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n既然這樣……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102913,
        "voice": "vo_adv_5106604_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳之前提過要在育幼院辦聖誕演唱會的事，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是不是有機會辦得到了？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我確實",
        "unit_id": 104211,
        "voice": "vo_adv_5106604_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是想過總有一天",
        "unit_id": 104211
    },
    {
