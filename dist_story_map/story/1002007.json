[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──接受了擊退魔物的工作的{player}，\n正打算前往目的地。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，你好。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你正準備要去工作嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是擊退魔物的工作呀……如果方便的話，我可以跟你一起去嗎？",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我平時總是受你關照，所以希望能幫助你以作為回禮……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！ 請多多指教呦。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會用魔法支援騎士先生的，請你盡情地戰鬥吧。",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你辛苦了。剛剛那隻是第十隻呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "附近可能還會有魔物，小心一點繼續前進吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了以防萬一，我已幫你施加了防火、防寒……等各式各樣的魔法，",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然我想應該沒問題了，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過還不知道會發生什麼事──",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "危險呀！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_005"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "即使打倒了一隻，又很快會有別的魔物跑出來……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我都不知道原來城鎮附近已變成這樣了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生請等一下。你的手腕受傷了……！ 我馬上幫你治療！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "交給我吧！ 雖然我這樣說，但我也只能做這種程度的事而已……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（雖然我有時候，會對於我自己並非親自上場戰鬥而是擅長支援別人這件事感到厭惡……但現在可以幫上騎士先生的忙……）",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "正因為有這樣的狀況，所以也得施加身體強化的魔法才行……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果只施加一次的話說不定又會受傷了，要再施一次……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "得再強化更多才行……！更多……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……還差一點點……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再多一點……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的也是呢。施加了這麼多強化魔法的話一定沒問題的。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不論是哪種魔物冒出來應該都能輕鬆打倒牠們的呀──",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喔喔好厲害！ 又是一擊就打倒魔物了！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛剛的似乎是最後一隻魔物了。騎士先生，辛苦你了。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我們再往前深入一些，如果沒有魔物出現的話我們就回到城鎮去吧？",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生？ 怎麼了呢？",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，你沒事吧！？ 振作一點呀！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "身體變得很冷……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "看來是過度使用體力的後遺症……我該怎麼辦才好……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總、總之現在要馬上回復體力才行……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "首先要用魔法讓身體回暖……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "希望騎士先生能早點清醒……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_023"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生！ ",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……你醒了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為身體強化的魔法，只能讓身體變得更強韌但體力一如往常，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n如果比平常的運動量還多，身體會負荷不了而動彈不得的。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "身體已經回暖了應該可以動起來……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n怎樣……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……咦？ 為什麼騎士先生的臉會離的這麼近……！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我真是的，因為太擔心他了所以不知不覺就……！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "………抱、抱歉呀！ 這麼近的話你就動不了了呢！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n哈哈哈………",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n（是我的錯覺嗎……連騎士先生也臉紅了……？）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為還不知道會發生什麼事，我先幫你施加治癒魔法吧。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣就可以了……我們走吧，騎士先生。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生，身體還好嗎？ 會不會累呢？",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我們也走了一段路，我再幫你施加治癒魔法吧。",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──能平安回來真是太好了……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們似乎運氣不錯呢",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生，我今天有好好幫上忙嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的嗎？ ",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也是呀！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果騎士先生不在的話，我什麼都辦不到……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……呵呵。我們兩人，真是不相伯仲呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（原來騎士先生，是這樣看待我的……",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "即使如此，我能夠努力到這個地步，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n都是騎士先生的功勞呢）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我呀，會為了能夠幫上騎士先生更多的忙而努力的！",
        "unit_id": 100211,
        "voice": "vo_adv_1002007_037"
    }
]