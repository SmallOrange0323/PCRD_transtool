[
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "文化系の学芸展示も、",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_000"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n小論文とか自由研究とか色々ありましたよね。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ん？　",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まあ、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうだったな……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あれ、",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_002"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "歯切れわる子ちゃんですね。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nユニ博士の日頃の研究成果を提出しなかったこと、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "後悔してるんです？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いや、",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "それについては考えても詮無きことだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nそも考えようとしたところで、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "不思議なぐらい",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "「ま、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どうでもいいや」と気が逸れてしまうからな。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくが思案していたのは、",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_004"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "それではなく",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "芸術出展の方だ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "ああ、",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_005"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "あの不細工な呪われし異形の像、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "通称ユニアート。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うむ、",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_006"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "例の好事家たちは",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『名もなき芸術』などと称していたが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくは今、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "制作者としてあれに『青春』という銘を打ちたい。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "かつて想い焦がれた風景。",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_007"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そして今そこに身を浸している感慨。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n取るに足らん毎日こそが、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの年表に燦然と輝くその二文字なのだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "わあ、",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_008"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "いいですね。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n素晴らしい作品だと思います。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "……な、",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_009"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なんだね急に。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nさんざん不細工だの",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "呪われし異形だのと",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこき下ろしてきた君が、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "急にどうしたというのだ。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "や、",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_010"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "てっきりアレってツッコミ待ちのネタアートかと思ってたんで。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "真面目に作ってアレだったんなら、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "話はちょっと変わってきますよ？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "もしユニ先輩が全力で一生懸命作った結果がアレだったんなら、",
        "unit_id": 116311,
        "voice": "vo_adv_5064603_011"
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\nまあ、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "はい、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "仕方ないですもんね。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "チエル",
        "words": "チエル無理して誉めるぐらいの社交性は持ち合わせてます。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あ、",
        "unit_id": 116411,
        "voice": "vo_adv_5064603_012"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そうなんだ……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なんか、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "あの、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "無理させちゃってごめんね？",
        "unit_id": 116411
    }
]