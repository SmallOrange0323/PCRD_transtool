[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛一直盯著我們的就是你吧！",
        "unit_id": 105811,
        "voice": "vo_adv_5058302_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或許你是打算把我們當成食物，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但這可不行呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "盯上我們是你命數已盡！",
        "unit_id": 106011,
        "voice": "vo_adv_5058302_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看我們來解決你！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓你見識一下我們",
        "unit_id": 105911,
        "voice": "vo_adv_5058302_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的食慾……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這個時候啊，",
        "unit_id": 106011,
        "voice": "vo_adv_5058302_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不說點像是羈絆之類的詞嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得像這樣",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "靠食慾來戰鬥會很脫線……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的食慾是沒有極限的！",
        "unit_id": 105811,
        "voice": "vo_adv_5058302_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然還說得一副很帥氣的樣子！？",
        "unit_id": 106011,
        "voice": "vo_adv_5058302_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，都無所謂啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "盡快解決乾淨吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911,
        "voice": "vo_adv_5058302_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請助我們一臂之力……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看，",
        "unit_id": 106011,
        "voice": "vo_adv_5058302_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞得那傢伙都困惑了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n害他認真在思考要怎麼強化食慾啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要過來了呢，",
        "unit_id": 105911,
        "voice": "vo_adv_5058302_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n專心戰鬥吧……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "害我無法專心的就是妳們耶！？",
        "unit_id": 106011,
        "voice": "vo_adv_5058302_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的是很脫線耶……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過很奇妙，",
        "unit_id": 106011,
        "voice": "vo_adv_5058302_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要和大家在一起就覺得不會輸呢……！",
        "unit_id": 106011
    }
]