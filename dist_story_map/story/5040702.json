[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經差不多習慣趕老鼠了呢。",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過話說回來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼牠們那麼想要起司啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "除了起司以外也還有別的食物啊。",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然這樣講對真陽很不好意思，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過我覺得橡子跟核桃",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n比較好吃。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過仔細回想一下，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我好像沒有",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好好地品嚐過牧場的起司呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但這個起司是要拿來當伴手禮的，",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以不能拿來吃。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從剛剛開始",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就一直有種",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "橡子沒有的獨特香味刺激著我的食慾……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該怎麼說呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有一種像生命泉源般香醇的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "起司感覺也相當……",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不不不！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n果然還是橡子比較好！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一定是橡子比較好！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "老鼠",
        "words": "吱～！！"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇！？　",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又出現了！！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且還比剛剛的老鼠更大隻！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的這麼想要起司嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "害我越來越想調查起司了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就讓我迅速趕跑你吧！",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n做好覺悟吧！",
        "unit_id": 102611
    }
]