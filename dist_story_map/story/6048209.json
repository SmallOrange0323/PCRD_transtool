        "words": "這種經驗",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "平常是絕對不會發生的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我也因此好好思考了很多事呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個啊，",
        "unit_id": 100611,
        "voice": "vo_adv_6048209_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就是姊姊果然是最棒的姊姊",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這件事！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "正是因為交換身體的對象是姊姊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們才成功跨越這場危機喔，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一定是這樣的♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是這樣嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_6048209_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這一次姊姊",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "很帥氣地大顯身手，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果契機是因為進入了茜里的身體裡，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那很令人開心呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯～",
        "unit_id": 100611,
        "voice": "vo_adv_6048209_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然能夠獨占姊姊是最棒的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但看到自己站在眼前",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還是感覺有點怪怪的呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "果然還是",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "像平常一樣就是最好的♪",
        "unit_id": 100611
    }
