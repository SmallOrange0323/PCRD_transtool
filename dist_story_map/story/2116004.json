        "voice": "vo_adv_2116004_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您好像",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒什麼食慾的樣子，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問是怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106412,
        "voice": "vo_adv_2116004_068"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n呃，",
        "unit_id": 106412
