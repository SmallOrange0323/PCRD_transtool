        "voice": "vo_adv_2116004_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大概就是最後的決戰了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就麻煩你們在一切燒成灰之前",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "奪回魔珠囉～♪",
        "unit_id": 106811
