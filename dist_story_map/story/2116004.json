        "voice": "vo_adv_2116004_059"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "世界就會毀滅，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n或許在{player}能夠強化的範圍內，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n大家一起並肩戰鬥",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會比較好呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好！",
