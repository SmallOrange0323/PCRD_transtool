        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然在跟【憤怒‧軍團】的決戰當中，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n當時就只靠我們幾個闖入了敵人的據點……",
