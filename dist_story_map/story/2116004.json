        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "世界上的人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以不會馬上回去啦……",
