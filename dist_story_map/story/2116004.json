[
    {
        "type": "background",
        "background": "501630"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在釋放著龐大熱能與火焰、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n企圖燒盡阿斯特朗的巨神體內。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "厄莉絲正身處於水晶之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並嘗試著控制徘徊的巨神。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……米奈娃。",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我感受到了，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我體內的妳有所抵抗。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳希望能離開我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對吧？",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是……",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我不會、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "讓妳如願的。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是妳僅僅用來實現",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「草野優衣的願望」，\n所創造出的複製體。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就只是為了填補逃走的願望核心──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "草野優衣的空缺。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……就算，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "事實如此……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n現在的我也擁有意志，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還有願望。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使我跟妳之間的連結，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "被遠野帆稀所扭曲，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也絕對，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不允許妳離開。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不論會變得多麼醜陋、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "難堪……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我都要妳，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "陪我到最後。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒錯……",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "直到最後。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使「這個世界」迎來結束，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n在下個世界，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n下下個世界也一樣。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我要妳陪我到……",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我的願望實現的那瞬間為止。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士、",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "先生……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在騎士先生消失以後的世界，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不斷地瀏覽騎士先生他們、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "生存時的紀錄……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n至今為止，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我一直重複著這種惡夢。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我已經無法、",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再承受更多次的輪迴了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我原本，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是這麼想的……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是。",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n「這次」，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我終於見到了騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而且跟他說過的話，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也是至今為止未曾有過的多。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "燒毀世界、",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "破壞系統……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果在這途中，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "發生了什麼意外……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「現在的騎士先生」，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就會消失……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而且忘記我的存在。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會讓我非常非常悲傷，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就像撕心裂肺一樣。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……可是……",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "跟騎士先生，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "交談的記憶。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "跟騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "直接接觸時感受到的溫度。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這些都給了我",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "足以忍受下個輪迴的，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "希望與勇氣……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使是區區數百秒的紀錄，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也會播放",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "幾億次、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "幾兆次……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "撐過輪迴的煎熬。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……啊啊，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但願……",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n下一個你，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能再次、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "打倒霸瞳皇帝。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後……",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "下一次。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "希望你會願意、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "牽起我的手……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "厄莉絲小姐，",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_022"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n妳聽得到吧？",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「…………」",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_023"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "妳似乎也大致習慣",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_024"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "這個巨神的操作了呢。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n移動變得流暢，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "燒毀世界的效率也有所提升了。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「……是啊。",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然外頭的七冠，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "像蒼蠅般圍過來……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n非常煩人就是了。」",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "說是蒼蠅",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_026"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "可就太低估他們了。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那些人就像是",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "各自有著致命毒針的蜜蜂。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "當然──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "兩者同樣是",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "蟲子就是了。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "不論擁有多強的毒素",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_027"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "還是多優秀的能力，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n這個巨神都不會被來自外側的攻擊打倒。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那麼，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "他們接下來會採取的手段便是……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「……奪回、",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "索爾魔珠。」",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "沒錯。",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_029"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n這巨神說到底也只是類似於藏身處的仿造品，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n既然有弱點，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那就還遠遠不及真正的「神」。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "為了讓巨神容納",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_030"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "妳無法控制的米奈娃的力量，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n必須用索爾魔珠",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "維持這個巨大的軀體。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「巨神身體的大部分，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都是吸收來的『漆黑薔薇城』。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n靠著跳躍王的權能，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "便可以潛入其中的空洞。」",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "畢竟是如此龐大的軀體，",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_032"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n索爾魔珠就像是輔助腦一樣",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "被分散、配置在各處，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n所以光靠我一個人",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "無法守護所有的魔珠。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "既然如此……",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_033"
    },
    {
        "type": "still",
        "still": "211600401"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那就只能像「黑色風之精靈」一樣，",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_034"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n用上我收集的眾多阿斯特朗魔物的情報。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "用米奈娃",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_035"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "賜予它們力量，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n讓它們成為守護者",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "來擊退無禮的入侵者。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「……交給你了，",
        "unit_id": 129013,
        "voice": "vo_adv_2116004_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n隨你處置。」",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "來吧──",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_037"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n會是世界先燃燒殆盡呢？",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "還是你們先奪回索爾魔珠呢？",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n又或者是你們成功返回「現實」呢？",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "模索路晶以及其公主騎士等人啊，",
        "unit_id": 192613,
        "voice": "vo_adv_2116004_038"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n若想守護阿斯特朗傳奇──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n那就",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "登上這最後一場遊戲的舞台吧！",
        "unit_id": 192613
    },
