        "voice": "vo_adv_2116004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是{player}你呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你跟許多女孩們",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "締結了羈絆，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在那些女孩當中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也有些人開始察覺了這個世界的扭曲。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不，",
