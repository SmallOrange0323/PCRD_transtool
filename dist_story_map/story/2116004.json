        "voice": "vo_adv_2116004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在那裡應該沒有敵人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且從我的房間，",
