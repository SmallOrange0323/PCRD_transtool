    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯，雪菲。",
        "unit_id": 106012,
        "voice": "vo_adv_2116004_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒有必要擔心做太多",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是會剩下來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳反而該當心別錯過了吃東西的機會。",
