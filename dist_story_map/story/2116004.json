    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能傳送訊息到蘭德索爾的任何一個角落！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽好囉！？",
        "unit_id": 190011,
        "voice": "vo_adv_2116004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在大家來之前，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們幾個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可要好好休息喔！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人……！",
        "unit_id": 105913,
        "voice": "vo_adv_2116004_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萬事拜託您了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀啊～～！！",
        "unit_id": 190011,
        "voice": "vo_adv_2116004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
