        "voice": "vo_adv_2116004_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題啦～小凱留☆",
        "unit_id": 105812,
        "voice": "vo_adv_2116004_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算不夠了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在這之後",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家應該也會帶食物過來♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這笨蛋白癡佩可！",
        "unit_id": 106012,
        "voice": "vo_adv_2116004_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等其他人到齊以後",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就要展開作戰了嗎～！？",
        "unit_id": 106012
    },
