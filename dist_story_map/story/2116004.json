    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n將你們那的公會小屋",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "和魔物體內連接起來。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在那之後",
