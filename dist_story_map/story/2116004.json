        "voice": "vo_adv_2116004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和【破曉之星】的三人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都變強了非常多，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但不曉得彌勒他",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會設下什麼樣的陷阱……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然關鍵",
