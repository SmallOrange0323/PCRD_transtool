    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳要去哪！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當然是索爾之塔囉！",
