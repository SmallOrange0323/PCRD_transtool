[
    {
        "type": "dialogue",
        "name": "深月",
        "words": "溫泉之神",
        "unit_id": 124711,
        "voice": "vo_adv_5108203_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "罪惡與汙穢逐漸祛除了……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "太好了，",
        "unit_id": 124611,
        "voice": "vo_adv_5108203_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "祂好像滿足了呢。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "深月、",
        "unit_id": 124511,
        "voice": "vo_adv_5108203_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "美里，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒時間這麼悠閒了。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n尾牙得馬上繼續才行，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為客人在等了啊～♪",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯，",
        "unit_id": 124611,
        "voice": "vo_adv_5108203_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "加緊腳步吧。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我們正要去收拾",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "散亂的會場對吧。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……現場肯定相當凌亂，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們先做好覺悟吧。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "服務業真的很辛苦呢。",
        "unit_id": 124711,
        "voice": "vo_adv_5108203_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n連喘口氣的時間都沒有……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好了好了，深月。",
        "unit_id": 124511,
        "voice": "vo_adv_5108203_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我等一下會幫妳擦背的，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好嗎？☆",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵。",
        "unit_id": 124611,
        "voice": "vo_adv_5108203_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就負責按摩。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還真是周到耶。",
        "unit_id": 124711,
        "voice": "vo_adv_5108203_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……既然如此，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我就稍微再加把勁吧。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 124511,
        "voice": "vo_adv_5108203_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就往尾牙會場",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "出發囉～！",
        "unit_id": 124511
    }
]