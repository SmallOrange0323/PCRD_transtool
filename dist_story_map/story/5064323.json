[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "糟了個糕。",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那傢伙的感覺好像又變了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n超強的氣勢整個漫出來了耶。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該是把殘存魔力都用來準備攻擊了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看來是有足夠的智慧，能領悟到自己的死期。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n講白一點，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是最後的掙扎。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換句話說，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是憂妮們也已經無法脫離與修復了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n各位，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "勝利就在眼前。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為這漫長的戰爭",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "拉下幕簾吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃，",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是那就表示",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在那傢伙的戰鬥力是特大碗的吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算妳用那種白蘿蔔快乾掉了要我們快吃完的語氣解釋，\n我們是能怎麼樣啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 116311,
        "voice": "vo_adv_5064323_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "乾掉的白蘿蔔真的不好吃呢～",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然是那樣說沒錯啦，",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過也要看煮法喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "拿去滷或醃就反而都不錯。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此。",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n畢竟缺乏水分，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "相對地更能吸收滷汁。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這相當符合邏輯呢，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就記下來吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學姐根本不下廚吧。",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n話說妳連飯都不吃吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "順帶一提，乾掉的白蘿蔔啊，",
        "unit_id": 116311,
        "voice": "vo_adv_5064323_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只要泡在張滿水的桶子裡面，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "多少就會恢復一些脆度喔。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然還有這個方法啊。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "筆記筆記。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不愧是琪愛兒，",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "知道很多切嚕知識，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太煩人了吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位請看！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n面對人類的智慧，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無知的敵人",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "正睜圓了眼睛看著我們！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我覺得她眼睛本來就是圓的，",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們畢竟是知性派嘛，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要比頭腦的話簡單啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮博士，也請妳說個厲害的智慧！",
        "unit_id": 116311,
        "voice": "vo_adv_5064323_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "白蘿蔔含有豐富的澱粉酶與醣苷酶，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n能有整腸與解毒的功效！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只要磨成泥來吃，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不只對胃好，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "下巴也不會累！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "Nice智慧！",
        "unit_id": 116311,
        "voice": "vo_adv_5064323_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那傢伙張著的嘴巴好像閉不起來喔，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很有效很有效！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就這樣一口氣解決那傢伙吧，優妮學姐！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "接招吧，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "最終智慧！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n演技很爛的演員",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "之所以會被叫做蘿蔔演員，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是因為吃白蘿蔔不會食物中毒，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟「不會中選的演員」有異曲同工！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好啊！",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼樣！",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嘎喔個頭啦。",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n是在問怎麼樣啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n聽不懂人話喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "OK羅塞塔，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "憂妮們是在說什麼？",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_5064323_020"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "這是講白一點的翻譯！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n「好了啦趕快放馬過來啦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "三笨蛋。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "三笨蛋",
        "words": "三笨蛋！？",
        "unit_id": 1,
        "voice": "vo_adv_5064323_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 116211,
        "voice": "vo_adv_5064323_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我說啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "吶，是在說些什麼啊，那傢伙。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n竟然對聖德蕾莎的三賢者說這種話，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真是意義不明。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "各位，",
        "unit_id": 116411,
        "voice": "vo_adv_5064323_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "全力支援吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就讓憂妮們",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "徹底了解我們的智慧吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聖德蕾莎的三賢者，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出最終之力吧！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊！",
        "unit_id": 116311,
        "voice": "vo_adv_5064323_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n聖德蕾莎的三賢者，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出最終之力吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "三賢者",
        "words": "唔喔喔喔呀啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_5064323_025"
    }
]