[
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ついに我が【ヴァイスフリューゲル ランドソル支部】にも、",
        "unit_id": 105311,
        "voice": "vo_adv_6106101_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n新たな支所ができたぞ！　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふふふ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "万全の準備で、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "華々しく門出を",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n迎えなくては。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "差し当たり必要不可欠なものといえば……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "それはいいな。",
        "unit_id": 105311,
        "voice": "vo_adv_6106101_001"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "我がギルドの威光を示すには持ってこいだ。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……いやしかし、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "周辺住民の理解を得る上で、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あまり物々しい",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n店構えにするのも考えものか。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うーん、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "悩ましいな……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なるほど。",
        "unit_id": 105311,
        "voice": "vo_adv_6106101_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ギルドの長たるもの、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "礼節をおろそかにしてはいけないな。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "早速、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "菓子折りを持参してご近所を行脚するとしよう。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……け、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "決して私がついでに甘味を楽しみたいからではないぞ！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お菓子……？　",
        "unit_id": 105311,
        "voice": "vo_adv_6106101_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "い、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いや、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "確かに……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n兵糧は組織のまさに生命線であるし、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いわんやそれが甘味とあれば",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n全体の士気にも大いに影響する。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふふ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "さすがの慧眼だ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴公！",
        "unit_id": 105311
    }
]