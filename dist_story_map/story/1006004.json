    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到平原的茜里與{player}，\n被突如其來的光芒包圍。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "什、什麼，這個光是什麼！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥！",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里很害怕……呀啊啊啊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "？",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼、呼，哥哥，太激烈了啦。",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經……喘、喘不過氣了！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對、對不起……",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里稍、稍微休息一下喔……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼……呼……",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，這真是太猛了啦……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然很高興哥哥能陪茜里",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n練習薩克斯風。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為哥哥很會教人，",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以茜里也變得這麼會吹了喔。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣的話，下個禮拜的儀隊公開演奏，",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里搞不好能順利表演……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，那個……",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里還是不太有自信……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……而且，演奏最高潮的地方",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里還不太熟……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為這邊……",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "手指頭的動作非常激烈……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里還不太能駕馭……",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以無法持續到最後。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要茜里現在在這裡做一次嗎？",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n在哥哥面前？",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可、可是，我會害羞啊。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里很討厭失敗……",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n而且……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這、這樣硬來……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會害怕。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……欸？",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n若是我的話，沒問題嗎……？",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……真、真的嗎？",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……我知道了。",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "既然哥哥都這麼說了……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在哥哥面前會心跳加速，",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以很難冷靜呢……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我知道了。",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我會加油的 ♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "………………",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太……太厲害了！",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里照著哥哥說的話做，就能吹到最後了！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能吹到最後……是第一次。",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果是茜里一個人的話，就算到正式演出，",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我想我還是沒有自信……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是多虧了哥哥，",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓我知道我也能吹到最後！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以真的很",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n謝謝哥哥。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是只用說的，好像不太能表達",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里的謝意……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果有什麼好方法就好了……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有了，哥哥！",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這次的回禮，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里就用身體來支付！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里要為哥哥，",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n演奏一曲喔！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵 ♪",
        "unit_id": 100631,
        "voice": "vo_adv_1006004_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請好好地聽茜里的演奏喔？",
        "unit_id": 100631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！你做了個好「夢」嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1006004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和茜里的「記憶碎片」",
        "unit_id": 190011,
        "voice": "vo_adv_1006004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的「夢」唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很懷念嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，還不清楚啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1006004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的「夢」做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1006004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1006004_033"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_034"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里該不會是睡著了吧……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎麼覺得好像夢見了不可思議的夢……",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……咦？",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_036"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥也夢到跟茜里一起練習薩克斯風的夢了？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們能夢到相同的夢，",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_037"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真是不可思議的事情呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥一直以來教了茜里很多事情，",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_038"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就連在夢中也被哥哥教導……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果沒有哥哥的話，",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_039"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里應該是活不下去呢 ♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，茜里說真的喔？",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_040"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對了，所以說哥哥！",
        "unit_id": 100611,
        "voice": "vo_adv_1006004_041"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "趕快繼續多教茜里一些事情吧？",
        "unit_id": 100611
    }
]