[
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕咕嘟嚕嚕嚕嚕嚕嚕啊啊啊啊啊啊！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個，",
        "unit_id": 128011,
        "voice": "vo_adv_5132302_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總覺得比剛剛還更凶暴了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一定是因為克蕾琪塔小姐的攻擊",
        "unit_id": 6111,
        "voice": "vo_adv_5132302_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "而感到惱火吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "啊──啊，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "搞砸了呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以不要說成是我的錯嗎！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132302_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再怎樣我也是很努力在對付啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 127911,
        "voice": "vo_adv_5132302_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想一定是我半吊子的攻擊不好。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是剛剛",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那一擊就解決牠，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請您別說了，",
        "unit_id": 128011,
        "voice": "vo_adv_5132302_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "探究責任歸屬終究只是徒勞，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只要打倒牠，一切就解決了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會全力支援您的，",
        "unit_id": 128011,
        "voice": "vo_adv_5132302_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n所以請您盡情發揮力量吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……克蕾琪塔小姐",
        "unit_id": 127911,
        "voice": "vo_adv_5132302_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是可靠的成熟女性呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳有一種跟【美食殿堂】的大家",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "截然不同的安心感喔。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……這是我的榮幸，",
        "unit_id": 128011,
        "voice": "vo_adv_5132302_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我現在其實想讓我的快樂爆發出來，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但首先──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 127911,
        "voice": "vo_adv_5132302_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們上吧，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了幸福的聖誕節！",
        "unit_id": 127911
    }
]