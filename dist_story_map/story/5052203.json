[
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "好，",
        "unit_id": 114311,
        "voice": "vo_adv_5052203_000"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "反逆獸已經消失了……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "那大家，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我們就來做慣例的「那個」吧！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n我又想了新的版本喔！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "Shiny★智啊……",
        "unit_id": 114211,
        "voice": "vo_adv_5052203_001"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "我從以前就抱有疑問，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "為什麼需要這麼多種版本？",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n……那個叫什麼招牌姿勢的。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "傻問題，",
        "unit_id": 114311,
        "voice": "vo_adv_5052203_002"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "Lovely★莫妮卡。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "變身跟招牌姿勢",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "可說是魔法少女的存在意義也不為過。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我是覺得有點為過啦……",
        "unit_id": 112211,
        "voice": "vo_adv_5052203_003"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "我認為Shiny★智說的沒錯……！",
        "unit_id": 112311,
        "voice": "vo_adv_5052203_004"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "是、",
        "unit_id": 114211,
        "voice": "vo_adv_5052203_005"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "是這樣嗎……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "既然",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "都說成那樣了，也沒辦法。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "那麼",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "各位，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "我們就來──",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "大家不好了！",
        "unit_id": 4211,
        "voice": "vo_adv_5052203_006"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n那邊",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "又",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "出現反逆獸的氣息了！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "什麼！？",
        "unit_id": 114211,
        "voice": "vo_adv_5052203_007"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n看來還無法擺出招牌姿勢呢。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我還想了很多很多種版本的姿勢，",
        "unit_id": 114311,
        "voice": "vo_adv_5052203_008"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n趕快打倒反逆獸，",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "大家一起擺吧！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "……呃，",
        "unit_id": 114211,
        "voice": "vo_adv_5052203_009"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "好……！",
        "unit_id": 114211
    }
]