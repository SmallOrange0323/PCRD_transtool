        "words": "衝著{player}而來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "尾狗刀率領的大群魔物，\n襲擊了獸人族之國‧珊托魯斯。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了保護夥伴們，【哞哞自衛隊】與矛依未攔住了那些敵人。"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嘿、",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_000"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咻──",
        "unit_id": 106211
    },
    {
        "type": "background",
        "background": "501430"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚！",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n唔──！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "快點快點。",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_002"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n妳好不容易才撿起那把大劍，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不拿來用嗎～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過～妳用不了吧，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "都露出一堆破綻了～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……可惡！",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊～真是的，",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "完全沒辦法攻進去！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我的動作習慣、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有招數，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全都在被他看穿了……！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……呵呵。",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……呵呵呵。",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈哈哈！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳為什麼發笑？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n真是個怪人～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈！",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你問我為什麼發笑？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n當然，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是因為很好笑啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管你再怎麼裝作忘了我！",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你還是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對我",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "非常熟悉！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n像這樣一交手，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就讓我清楚地發現了這點！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "501430"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哎喲……！",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看吧，你又閃開了，",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且閃得如此輕鬆！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過也是啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為你對我的動作",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "了解得非常非──常透徹！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們可是曾並肩作戰，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "配合彼此的步調",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "奮戰過好多次啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "──……",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "其實我",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "老實說",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也不想跟你交手！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起心煩意亂地四處尋找你，",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n像這樣直接衝突",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在心情上輕鬆多了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是個笨蛋嘛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯──",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣啊～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我就放棄",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "直接衝突啦。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "大家",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "集合～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "香織、真琴、真步",
        "words": "！？",
        "unit_id": 1,
        "voice": "vo_adv_2110006_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剩下的魔物",
        "unit_id": 101711,
        "voice": "vo_adv_2110006_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "突然集結……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "組成了陣形！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不只這樣而已！",
        "unit_id": 104311,
        "voice": "vo_adv_2110006_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "行動也產生變化──",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "變得會互相合作了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那位尾狗刀先生，",
        "unit_id": 101011,
        "voice": "vo_adv_2110006_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n居然沒用什麼魔力，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就如此",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "自在地",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "操縱著",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔物們……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊。",
        "unit_id": 106113,
        "voice": "vo_adv_2110006_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為真正的你",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是什麼王宮騎士，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而是魔物使。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "辦得到這點小事",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是理所當然的……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還沒完呢，",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_023"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "才不只這點程度而已喔～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呀啊！",
        "unit_id": 101011,
        "voice": "vo_adv_2110006_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n他、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他們的目標是人家！？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那是當然的。",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_025"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n針對治療者攻擊，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是基礎中的基礎吧～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主！",
        "unit_id": 104311,
        "voice": "vo_adv_2110006_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n請退到我們身後！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不好意思！",
        "unit_id": 101011,
        "voice": "vo_adv_2110006_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "包圍戰術與",
        "unit_id": 101711,
        "voice": "vo_adv_2110006_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "各個擊破！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在這種人數差距下使出這些招式，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們光是防禦就很吃力了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘖！",
        "unit_id": 104311,
        "voice": "vo_adv_2110006_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不愧是尾狗刀前輩，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "做事還真狡詐！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "討厭～",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_030"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n要說就說我很聰明啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……應該說，",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_031"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "因為你們來礙事，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n現在讓{player}給逃掉了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我至少得做點其他事",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "來賺分數才行～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "賺分數？",
        "unit_id": 101711,
        "voice": "vo_adv_2110006_032"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "沒錯。",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_033"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n妳瞧，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "舉例來說～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "用魔物們，",
        "unit_id": 106211,
        "voice": "vo_adv_2110006_034"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n搗毀獸人族之國之類的？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我想這會讓人很高興的～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
