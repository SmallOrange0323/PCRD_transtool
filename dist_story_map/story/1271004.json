[
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們一行人",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在無意間阻止了潛藏在旅行背後的陰謀，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n便踏上了歸途。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而在回家的路上，",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們碰到了不可思議的體驗──",
        "unit_id": 127111
    },
    {
        "type": "background",
        "background": "500287"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "真是的，",
        "unit_id": 2414,
        "voice": "vo_adv_1271004_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "明明是來休假，卻碰到意想不到的事件。",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這全都是小伙子隨便就下決定的錯！",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你就用死來賠罪吧！",
        "unit_id": 2414
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "快住手，爸爸。",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這一切都是導遊他們不對。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "況且……",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "況且，",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "時間雖然不長，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻、",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻讓我有了如同約會般的體驗，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "倒也不會覺得",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不愉快呢。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我沒事。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "什麼事、",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都沒有……",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你看那邊。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n海上好像有什麼在發光呢？",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是夜光蟲",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗎？",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "夜光蟲應該不是那樣子發光的……",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "光芒越來越強了，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊、",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊啊！",
        "unit_id": 127111
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "暑假即將結束的某天傍晚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在街上遇到了忍。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好久不見，{player}……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今年的夏天也一樣酷熱，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你沒有弄壞身體吧？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "老實說是有點……",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "暑假期間有很多",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "從全國各地來占卜的客人，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "每天都忙得不可開交……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的，很遺憾。",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我今天也才剛結束工作，正準備要回去。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我原本",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就對夏天的休閒活動沒有太大的興趣，所以沒關係。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難得的暑假",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻都耗費在工作上，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n無法好好享受還是讓人覺得有點可惜呢……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……很感謝你的盛情邀約。",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我從明天到之後也都塞滿了預約，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似乎有點困難呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在嗎？",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個時間點應該沒有地方可以去了吧……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你知道有個好地方？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣啊……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我明白了。",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那就走吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然爸爸他說",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n「這個時間你想把她帶到哪裡去？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我不允許，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我要殺了你！」",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但是",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請你不要放在心上。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510241"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呃……",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這裡",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是你的學校，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n難道說目的地就是這裡……？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "的確",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是沒什麼機會",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "進到別人的學校……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請等一下，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別丟下我啊……",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "社團正在練習呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為我沒有參加社團，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以這樣的光景",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看起來有點新鮮。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "夏天的黃昏時刻，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "朝著目標盡情揮灑汗水。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這感覺就是高中生的青春，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓我看得都有點入迷了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接下來是參觀校園？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的要進去嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果被發現你帶著我這個校外人士在校園裡，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n連你也會挨罵的……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……不過，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "連同這種緊張刺激感在內，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就是冒險，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然爸爸",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "剛剛吵著說",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「快住手，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "馬上回頭！」",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過既然都來到這裡了，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就讓我陪同到最後吧。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510211"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "夕陽下毫無人煙的走廊……",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺很有氣氛呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n簡直",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就像是恐怖電影中的一幕。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然說我平時已經習慣靈異現象了，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但還是不禁稍微感到心跳加快……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是說，是因為和這個人獨處，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n才讓我心跳加快呢？　",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "哪怕是平凡無奇的景色，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也會因著身邊的人而產生這麼大的變化。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "無論原因是哪個，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我都覺得很開心。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "510221"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這裡就是",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "班級教室……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果能和你同班，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且座位就在你隔壁……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我竟然會想像這種事，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看來我也意外地",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "像個女學生呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你有聽到什麼聲音嗎？",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "腳步聲……？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好、",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好的！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……看來",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是走掉了呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊哈哈！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n呼，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這比起和兇惡的幽靈對峙時",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還來得緊張呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這真是一場出乎我意料的大冒險呢。",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "遊魂……",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "它的存在相當地稀薄。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "已經感受不到任何思念，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只是個四處徘徊的無害存在。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "回想起來，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "暑假期間，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只是一股腦地忙著工作，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "什麼事都沒有做的我，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也像是",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "半個幽靈了吧……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總覺得自己已經很久沒有回歸到普通女學生的身分了。",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我得好好地",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感謝{player}才行。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "機會難得，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在這場快樂又有點恐怖的冒險最後，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n想要以我自己的方式",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "向他傳達我的想法呢……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "什麼事都沒有。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果方便的話，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可以去頂樓看看嗎……",
        "unit_id": 103131
    },
    {
        "type": "still",
        "still": "127100401"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……夕陽",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好美啊。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在充滿著令人為之顫慄的赤紅",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n以及黑影的這段時間，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "被稱為黃昏時刻。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "連身邊人的面容也無法看清──",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「汝為何人」之時。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣的話，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在待在你身邊的，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的是上喜忍嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "黃昏時刻",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又被稱作是逢魔時刻。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n與妖魔鬼怪相遇的這段時間。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難不成我──",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的是個幽靈也說不定？",
        "unit_id": 103131
    },
    {
        "type": "still",
        "still": "127100402"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……呵、",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "開玩笑的。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是貨真價實的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "上喜忍喔。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然說我原本，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的差點就成了幽靈……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒什麼。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我只是想到",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你是容易被幽靈附身的體質，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在黃昏時刻，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很可能會在某處遇到可怕的靈異現象……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那時候我會盡全力守護你的，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我一定會這麼做。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這是",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對於幫助我找回自我的你",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所能做的回報……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你聽不懂也沒關係。",
        "unit_id": 103131,
        "voice": "vo_adv_1271004_045"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們也該出去了呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n要是被關在學校裡，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸又會嘮叨個不停的。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呀──！",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "青春！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是好個青春！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像這樣的光景，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像這樣的光景再來多一點！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你平時遲鈍到不行，",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但偶爾會表現出這樣巧妙的一手，讓人看得目不轉睛呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "多虧有你，讓忍也獲得拯救。",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子因為這項異能的緣故，",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會有稍微偏離人類的地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而讓人覺得有點危險呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠將這樣的忍",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "留在這邊的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是因為有你的存在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "忍已經下定決心要守護你了，",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就請你們成為互相守護彼此的夥伴吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為這就是你們兩人的幸福。",
        "unit_id": 190011,
        "voice": "vo_adv_1271004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，今天就到這裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～！",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500287"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……咦，",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "抱歉。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我不小心睡著了。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是這個夏天所累積的疲憊顯露出來了嗎……",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺我在夢中好像度過了一段很快樂的夏季時光。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那赤紅色夕陽令人印象深刻的",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一場夢……",
        "unit_id": 127111
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可惜的是，",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_055"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太陽早已西沉。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過你看，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "星星好漂亮呢。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然遇到了麻煩的事，",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_056"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是能夠像這樣和你一起眺望星空，",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就是一份",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "美好的回憶了。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然而……",
        "unit_id": 127111,
        "voice": "vo_adv_1271004_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "稍微變得貪心了。",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "光是這樣，",
        "unit_id": 127111
