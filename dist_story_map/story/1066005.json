[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在巷弄間閒逛的{player}受到了祈梨的邀請，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n用她從別人那裡拿到的票來看一齣戲劇。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "吞口水……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_000"
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "……幹掉老大吧。",
        "unit_id": 1111,
        "voice": "vo_adv_1066005_001"
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "那東西已經入手了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "\n那可是足以掌控這整條街……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "\n不，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "是能夠辦到比這",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "更驚人之事的超強力量。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "說什麼要和平協調的老大",
        "unit_id": 1111,
        "voice": "vo_adv_1066005_002"
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "就是個老東西。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "\n他只是我們踏上頂峰的",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "絆腳石罷了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "而且，要是把老大幹掉了……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "\n那傢伙",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "也會歸你所有。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來自兒時玩伴的好友──",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "馬克",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "的叛變邀請……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對布拉德來說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是個能奪回自己那成了老大情人的\n心上人的大好機會……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "布拉德，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你會怎麼做……？　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "！！！",
        "unit_id": 1011,
        "voice": "vo_adv_1066005_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "他揍了馬克！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "竟然揍下去了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還拔劍對準了他！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "差點忘了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大對布拉德有大恩……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是這樣好嗎，布拉德！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "唔……",
        "unit_id": 1011,
        "voice": "vo_adv_1066005_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "布拉德還是把劍扔掉了……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然再怎麼樣，也不忍心對情同手足的好友動手吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛剛還替他捏了把冷汗……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "布拉德……",
        "unit_id": 1111,
        "voice": "vo_adv_1066005_008"
    },
    {
        "type": "dialogue",
        "name": "馬克",
        "words": "布拉德啊啊啊啊！",
        "unit_id": 1111
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "唔、唔啊啊啊啊！！",
        "unit_id": 1011,
        "voice": "vo_adv_1066005_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊啊啊啊！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "馬、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "馬克他！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "馬克他竟然刺向了布拉德！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n等等，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦咦咦咦咦咦！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n接、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "接下來",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "會變怎麼樣啊～～～！？　",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你怎麼睡著了啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n快醒醒！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要演到劇情高潮了喔，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "高潮！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在那之後發生了很多事，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "馬克篡奪了組織、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n布拉德也在十三年後從地獄復活了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快看，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個大叔",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是十三年後的馬克喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "為什麼",
        "unit_id": 1411,
        "voice": "vo_adv_1066005_013"
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "你不動手……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "\n你",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "是來殺我的吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我怎麼可能對你",
        "unit_id": 1011,
        "voice": "vo_adv_1066005_014"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "下得了手……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "因為那個時候，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我選擇了你而不是組織啊……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔喔喔！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "原來當時布拉德是這樣想的啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比起忠義，你更在乎友情啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "布拉德……！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "……我對不起你，",
        "unit_id": 1411,
        "voice": "vo_adv_1066005_016"
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "布拉德……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "馬克（中年）",
        "words": "對不起……",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500521"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊啊啊啊──！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "布、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "布拉德……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "馬克～～～！　",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看完戲劇的祈梨和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一如既往地走在蘭德索爾的巷弄間。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔唔唔唔～！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是帥呆了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就該這樣啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這才是幫派分子該有的生存之道啊！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我也想像那樣帥氣地活著！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在手下們給我票的時候，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我還覺得會喜歡這種劇的人\n頂多只有那些大叔而已，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "結果真是出乎預料！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "組織和友情、",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "野心和暴力！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n幫派果然最棒了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你懂這種感覺嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真不愧是小哥！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n懂的人才能體會其中的浪漫嘛！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你竟然不懂。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過算了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這也沒辦法。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n想必要像我這樣",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真正的幫派分子才會懂！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……小哥為什麼要那樣看著我啦。",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幫、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幫派還是和之前一樣",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n會讓我去處理生意喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這次一定也是",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "手下們為了讓我成為更優秀的幫派人物，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n才把那齣戲的票給了我。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的聲望還真是高得嚇人。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就這樣讓組織中的所有人都倒向我，一口氣當上老大！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你問我怎麼看得出來有聲望",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "手下們基本上",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要見到我就會給我糖果點心，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n嘉夜夜也常常請我吃東西。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣看來，離我篡奪家族老大位置的那一天也不遠了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……小哥你怎麼了？",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你問我【龍族巢穴】和家族是不一樣的嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這當然啊！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n本來，【龍族巢穴】的成員",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就只有身為龍人族的\n我、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "和老大三個人而已。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "至於那些平常出現的手下們",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都只是幫派成員。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就是老大擅自篡奪下來的那個幫派。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼這麼做？",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_031"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也不知道呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～嗯，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟是那個老大做的決定……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n理由一定和金錢與權力脫不了關係啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在當時碰巧……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_032"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的只是碰巧被那些幫派抓住的",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我和嘉夜夜，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在老大篡位後，就被拉攏進【龍族巢穴】了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只是，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為被抓去的時間點不好，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就只有我莫名其妙地背上了負債。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且還是筆不小的數目……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊──！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_034"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "光是回想起來就覺得生氣！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n況且當時把我和嘉夜夜拉進公會的時間點就很可疑！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大那傢伙，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一定是在暗中策劃著什麼啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "然後，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之有很多原因……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們龍人族記憶中的這個世界，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "和現在完全不同。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為這樣，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我原本還以為",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這裡只有我自己孤單一人……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管到哪裡全是陌生的景色、",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_036"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "陌生的人們……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而在這之中，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜她們是和我擁有相同記憶",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "的龍人族同伴。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "反正我也沒有其他地方可以去……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以就這樣一直到現在。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們幫派姑且是有個",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "叫「龍骨」的名字。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n雖然我們平時",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都叫它家族……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "【龍族巢穴】的公會長",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "和幫派老大是同一人，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以對外界而言，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "【龍族巢穴】和幫派是相同的組織，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "貌似是這樣。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過這些全都是轉述老大的話啦。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為這樣，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_039"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "【龍族巢穴】的正式成員",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n也身兼家族幹部的職務喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……既然老大和嘉夜夜都是幹部，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我當然也是幹部之一喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊哈哈哈，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是當然的嗎……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可不是小嘍囉喔！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就算有欠債，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也還是幹部！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或者是幹部等級的成員！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "手下們常常向我獻上食物，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_042"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這不就是最好的證據嘛。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你聽懂了嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大將【龍族巢穴】和家族整合為一體，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她的手腕",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或許是很厲害沒錯啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但如果是我的話",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一定也能辦到！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_044"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是我接管了家族，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜就會是我的左右手，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就讓你當我最信賴的部下吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然必須得以下剋上！",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "以下剋上",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才是幫派的精髓啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要想辦法做掉",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個上了年紀的老大……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……咦？",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_046"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不對，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種時候",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她非常有可能就躲在這附近，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n聽我講她的壞話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我得確認一下……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來她這次應該不在。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才、",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_047"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才不是因為我怕她喔！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "凡事都不能太大意而已……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是我成功地以下剋上，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_048"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大就會變成我的部下，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n到時我要把感覺很麻煩的雜事通通丟給她做！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_049"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你說，那不就和現在這樣差不多……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才沒有那回事呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n到時會變成",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我接管老大這個名譽職位喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也要把【龍族巢穴】的公會長之位",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_050"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n順便一起奪過來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "公會實際上沒有很積極地進行活動……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_051"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜說過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "關於這件事老大好像",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "知道些什麼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n卻刻意隱瞞起來……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是這都不要緊，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_052"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等我接替老大這個職位後問題就能解決了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要讓老大從實招來，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她到底有什麼企圖！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說小哥啊，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_053"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你就作為我的部下好好辦事吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n跟著我的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就能拿很多好處喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘻嘻嘻……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_054"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "意思是由小哥來照顧我嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真要說的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應該是我照顧你才對吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥要先認清現實才行喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且按照小哥的說法，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_055"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幫助你的我才是那個賢內助吧……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呃！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你知道你在說什麼嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "竟然讓我說出這種話！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都什麼時代了還在用那種詞彙！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_056"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥啊啊啊啊啊啊？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你你你、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你別胡說八道！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥才不會是我的",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "情、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "情情……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請別再說那種蠢話了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然剛剛的劇裡也有出現情人，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_057"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但那種東西在幫派社會中只能算是個陪襯而已喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥寧願只當一個陪襯嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_058"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我有個這麼不知羞恥的小弟還真是傷腦筋……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來有必要好好教育教育你！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就由我",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_059"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來把小哥培育成能獨當一面的幫派分子吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然要做就要嚴格執行！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你做好心理準備吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老大一個人就已經夠難對付了……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_060"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為了實現我的野心，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事前準備也不能馬虎，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣才是一流的幫派分子！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為了徹底掌控家族……",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_061"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也為了消去那一大筆欠債……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "！\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也要好好協助我喔！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好～",
        "unit_id": 106611,
        "voice": "vo_adv_1066005_062"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼首先……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就來練習幫派分子該有的",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "帥氣走路姿勢吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n等小哥徹底習慣之後，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就換成在草原上不斷折返跑的訓練！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在看完幫派劇後壯了膽的祈梨，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在{player}的跟隨下，大搖大擺地跨步而出。"
    }
]