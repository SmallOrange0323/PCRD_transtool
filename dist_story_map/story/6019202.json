[
    {
        "type": "background",
        "background": "500680"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊啊，討厭！　",
        "unit_id": 110211,
        "voice": "vo_adv_6019202_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明明是來渡假的，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n為什麼我會和鈴奈吵架啦～",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈也真是的！　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "到底誰才像小孩子啊！？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你這個人，",
        "unit_id": 110211,
        "voice": "vo_adv_6019202_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這種時候還能這麼冷靜啊。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也是大人，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不該擺出那種態度呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "先冷靜下來，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "和鈴奈再談一次看看好了？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！　",
        "unit_id": 110211,
        "voice": "vo_adv_6019202_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是想說我才是小孩子嗎！？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是我惹鈴奈生氣了，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也有不對啦。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "的確",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我的態度有點幼稚，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "得先好好反省才行呢……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你幹嘛那麼慌張啊！　",
        "unit_id": 110211,
        "voice": "vo_adv_6019202_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "快冷靜一下……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n沒錯。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "能冷靜應對事情，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才是大人的表現呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n看到慌張的你後，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "讓我想起來了！",
        "unit_id": 110211
    }
]