    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "討厭～",
        "unit_id": 112912,
        "voice": "vo_adv_6042106_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲真是的……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n跟你說喔！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一直在耳邊吵著\n要我快去念書快去念書啦～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我的耳朵都快長瘤了～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～",
        "unit_id": 112912,
        "voice": "vo_adv_6042106_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是很感謝她啦～～",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但在這麼近的距離下\n這麼頻繁地聽這句話，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就覺得好像已經念完書了……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "開、",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "開玩笑的啦！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對不起嘛愛麗絲～！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、",
        "unit_id": 112912,
        "voice": "vo_adv_6042106_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們有嗎……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得我只有被她罵的份。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……這麼說來，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……自從能和愛麗絲對話後總是很熱鬧，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不愁沒有聊天對象了呢……",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這或許，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就代表感情很好吧。",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 112912,
        "voice": "vo_adv_6042106_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是這樣嗎？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥說是那就一定沒錯吧！",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……奇怪，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲擺出了一副不明所以的表情耶！？",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是什麼意思嘛，",
        "unit_id": 112912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "愛麗絲！？",
        "unit_id": 112912
    }
]