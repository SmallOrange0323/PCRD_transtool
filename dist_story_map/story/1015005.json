[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美里正在精靈之森為即將舉辦的朗讀會做準備。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唔嗯，今天要帶哪本繪本去好呢……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n上次講的是魔法師的故事……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咳咳……哎呀？不會是……感冒了吧？",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "傷腦筋呢。要是傳染給大家就糟糕了，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n但是也不能讓期待著的孩子們失望……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咳咳……搞不好抵達那邊的時候就會好轉了，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n總之先出發──",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀哎呀哎呀……",
        "unit_id": 101511
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唉……沒想到居然會倒下……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n沒有做好健康管理呢。我得好好地反省才行。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天的朗讀會暫停，已經用通訊魔法傳達給城鎮裡的人了，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n應該沒問題吧……雖然對大家很抱歉。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n要是繼續惡化下去，甚至妨礙到工作就糟糕了呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……真安靜……因為平常總是有他或者孩子們在，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n很少有一人獨處的時間……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "現在在做什麼呢……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？我為什麼會想起他的事情……真奇怪呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但是……好想見他……生病的時候，突然會變得不安呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，這樣說來與他初次見面時，他暈倒了呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n而我碰巧看見……那時他是否也感到不安呢……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……{player}……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_011"
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒錯沒錯，我就是在這裡與他相遇的呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他誤食了毒蘑菇……從那之後我開始照顧他──",
        "unit_id": 101511
    },
    {
        "type": "still",
        "still": "101500201"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，是一起製作花冠的地方。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那時可是為了孩子們而拼命努力地製作呢……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那時候，他送給我的花冠，現在也好好地裝飾在家裡。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "無論到了幾歲，收到充滿心意的禮物都會很開心呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_015"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "問小寶寶是從哪裡來的……雖然常常被孩子們問，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但失去記憶的他，會在意也是當然的……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "連母親的事情也不記得……那麼，至少，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我要成為代替他母親的存在，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n守護他，我是這麼想的呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "從今以後，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也能帶給他快樂的回憶就好了，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n雖然我是這麼想的，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但跟他在一起，我也感到非常幸福。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "果然，好想見面啊……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼回事？總覺得好溫暖……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這個感覺，我好像知道……這是──",
        "unit_id": 101511
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……我，睡著了……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀……",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}，你來了啊……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這不是{player}嗎。早安啊～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀哎呀……握住了，我的手呢……這樣啊，難怪。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵……沒什麼的唷？",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但是，為什麼會在這裡？今天的朗讀會要暫停，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我明明有通知了……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……聽說我感冒就飛奔過來了？",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，真是急性子呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但是，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你能過來我很高興呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師我也很想見{player}呢♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師正感到有些不安呢，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "然後就在想著你的事情。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "才這麼一想，沒想到本人就來了。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你在擔心我對吧。果然是個溫柔的人呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？哎呀哎呀哎呀！不好意思呢。看見你的臉，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n安心了之後肚子似乎也餓了起來……真令人害羞呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為從一早到現在什麼也沒吃……肚子裡的蛔蟲先生真誠實呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_031"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我來做些東西，方便的話你也一起吃如何？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，你嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……這樣啊，那麼就拜託你了。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵……今天，",
        "unit_id": 101511,
        "voice": "vo_adv_1015005_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n好像成了我受你照顧的日子呢♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不知是否多虧了{player}來探病照顧，\n美里的身體相當順利的康復了。"
    }
]