[
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "魔物を召喚した……！？",
        "unit_id": 135111,
        "voice": "vo_adv_5206321_000"
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "このままじゃ、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "シャドウに攻撃が届かない……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "それだけではないわ。",
        "unit_id": 135011,
        "voice": "vo_adv_5206321_001"
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "\nあの魔物たち、",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "統率が取れている。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "動きから察するに、",
        "unit_id": 135011,
        "voice": "vo_adv_5206321_002"
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "一点突破が狙いか……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "恐らく、",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "最も火力が高い者へ",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "集中攻撃を浴びせてくるはず。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "\nこちらも連携しなければ、",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "苦戦を強いられるでしょう。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "まもの。",
        "unit_id": 135211,
        "voice": "vo_adv_5206321_003"
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "\nおいしそう……",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "（ぐぅ～）",
        "unit_id": 135211,
        "voice": "vo_adv_5206321_004"
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "ごめん。",
        "unit_id": 135011,
        "voice": "vo_adv_5206321_005"
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "ちから。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "プレシア",
        "words": "はいらない。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "もしかして、",
        "unit_id": 135011,
        "voice": "vo_adv_5206321_006"
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "空腹なの……？",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "\nこの状況で……？",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "だ、",
        "unit_id": 135111,
        "voice": "vo_adv_5206321_007"
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "大丈夫。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "ピンチは、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "チャンスです！",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "\nプレシアちゃんが、",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "シェフィ",
        "words": "魔物を食べれば解決だわ！",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "阿賀斗紫布菜、",
        "unit_id": 135011,
        "voice": "vo_adv_5206321_008"
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "落ち着きなさい。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "何もチャンスじゃないわ。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "とにかく、",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "一体ずつ相手にしていては埒が明かない。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "全体的に攻撃をしかけて、",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "エリス",
        "words": "一網打尽にしましょう。",
        "unit_id": 135011
    }
]