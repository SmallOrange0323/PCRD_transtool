[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈！",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好開心喔！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們聊了很久呢！",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n感覺全身都熱起來了……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "欸嘿嘿。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我隸屬的【王宮騎士團】",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n作風是比較嚴謹的那種，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我到現在也還沒習慣……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "總覺得在那裡，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不太能跟其他人輕鬆聊天。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且我也還只是個新人，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為不想被盯上，所以一直都很安分呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但其實我",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的超喜歡聊天的，所以那樣還蠻痛苦的說……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來我也",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "累積了不少壓力呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把悶在心裡那些想講的話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "全～都講出來後，真的是舒爽多了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "身體變得好輕鬆！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n簡直到了讓人想要無意義地四處亂跑，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "手舞足蹈的地步呢♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但是對不起呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天本來",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是想跟{player}聊聊有關你的事情說……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是好像",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "幾乎都是我在說話對吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺有點偏離原本的目的～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣算是任務失敗吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，{player}，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不知道是不是因為喪失記憶的關係，你幾乎都沒有開口呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且，即使我說一些無聊的話題，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你都會很捧場地好好聽完，這讓我好開心。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以不小心",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就一直講下去了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不好意思呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n一～直只聽我說話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還蠻無聊的對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是嗎？",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你這麼覺得的話就太好了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}你真的是一個好人呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣我好像會喜歡上你的。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣可不行呢。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為跟{player}變得那麼要好，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n並不是我任務的目的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你根本不需要道歉啦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒能讓{player}你主動開口說話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n表示我的話術還不夠成熟……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是好奇怪唷，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我想我算是還蠻會說話的呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n哎呀算了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n反正也沒什麼急著想知道的事情嘛……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天光是能加深彼此的關係，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就把這當作是一個好的開始吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算只是我一個人一直說話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也有獲得一些收穫呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像是你對什麼樣的話題有反應，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也確認了你對食物跟飲料的喜好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以這段時間",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "絕非白費。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣幫自己解套之後，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天就滿足地回家吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可以的話之後……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等{player}有空的時候，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要是能再見面聊聊天就好了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當然，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果不會造成你的困擾的話啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等到那時候，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果可以聊些更深入的事情",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就好了呦～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這時候不能太著急，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要一步一步推進……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為這樣才是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真正的捷徑呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那就再見啦。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我家在這個方向，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n差不多得跟你在這裡告別了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……我現在才注意到。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}，\n你難道是送我到我家附近嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}現在住的地方，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我記得是在反方向對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你還真是個好男人呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像這樣默默地",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "做出這種紳士般的舉動，給人的印象分數很高唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣我好像",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的會喜歡上你呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你說你什麼都沒想，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就只是陪我一起晃過來而已？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是不是害羞啦？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}都這樣說了，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那就當作是這樣吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "晚上一個人走在路上真的很危險又很寂寞，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n有你陪我真是幫大忙。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然對{player}來說，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n比起在當女孩子的保鑣，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不如說……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n或許更像是在保護小孩子而已。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟{player}，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還是比我年長許多嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我的老家",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是個很嚴格的道場……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n平常完全不被當成是個女孩子看待，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也不會有人把我當成是小孩子。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "先不論你那麼做是不是有什麼企圖，",
        "unit_id": 103711,
        "voice": "vo_adv_1037003_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我覺得很開心唷。",
