    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個……我很困擾。",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_000"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "有什麼關係？",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_001"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n妳一個人吧？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "和我一起去玩吧。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "其實妳很希望男生來約妳吧？",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_002"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "打扮成這樣～",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "（誰、誰來救救我～！）",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　{player}？",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_004"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "搞什麼啊你？",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_005"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n少管閒事。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n你是這女孩的朋友嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "戀、",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "戀人！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "是你的女友，所以不要亂約？",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_007"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "可是很可疑呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n你們真的是戀人關係嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸、",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸欸！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼說我們是戀人――",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸……讓他誤會比較好？",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的、的確是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對啊！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "戀、戀、戀人喔！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "……好像在說謊。",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎、",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼辦……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n他不相信耶……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也、也對！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是……像戀人的事是什麼呀？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我沒有談過戀愛……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸……少女漫畫的話……",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好像有什麼『壁咚』的？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂，快點『壁咚』！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "哇！ ",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_015"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "要做什麼啊！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不、不是對他，",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是對我做呀！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也、也對！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是戀人之間都說些什麼呀……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸……少女漫畫的話……",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "告、告白之類的嗎……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n像是「我喜歡妳！」？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可、可是、我、我沒有被那麼說過……！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然一直很憧憬……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如、如果你對我說的話……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……欸？已經是戀人了，告白很奇怪？",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對、對喔！已經在交往了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這樣順序會顛倒呢！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～該怎麼辦才好呢……",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n真難呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n都只有我在認真想……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你也要一起想！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你想和戀人做哪些事情呢？",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……不知道？",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～看來不只是念書，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n也得教你各種事情才行呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像是少女漫畫、戀愛小說……",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "下次我會帶很多來給你的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "喂、喂！",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_026"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n竟然無視我的存在，兩個人聊起來了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，抱歉。",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和他聊天很開心，一不小心就……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "可惡……",
        "unit_id": 1011,
        "voice": "vo_adv_1018005_028"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n在那裡打情罵俏！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "竟然真的是戀人……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼，太好了～",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總算讓他相信了呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？為什麼你要道歉呀？",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為你說我們是戀人？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你不需要道歉呀。",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我很開心你來幫我。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且你說我們是戀人……",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒、沒事！什麼事也沒有！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你的幫忙。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又讓你救了我，",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_034"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n得要好好答謝才行。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！那裡有一間很好吃的蛋糕店！",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一起去吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我請你吃！\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這……好像約會耶。",
        "unit_id": 101811,
        "voice": "vo_adv_1018005_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵呵，好期待喔♪",
        "unit_id": 101811
    }
]