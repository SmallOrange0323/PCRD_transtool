[
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311,
        "voice": "vo_adv_5120301_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哈哈哈！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我正是「統御美麗之人」，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "今晚也臣服在我的美麗之下吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妳突然在說些什麼？",
        "unit_id": 126211,
        "voice": "vo_adv_5120301_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "討厭，",
        "unit_id": 126311,
        "voice": "vo_adv_5120301_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳也太遲鈍了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我只是在配合伊莉亞妳啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛才的是在配合妾身嗎！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120301_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……在即將要與對方一戰之際，也太沒緊張感了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳就沒有害怕的東西嗎？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有啊，",
        "unit_id": 126311,
        "voice": "vo_adv_5120301_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那當然是──",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳自身的美麗對吧？",
        "unit_id": 126211,
        "voice": "vo_adv_5120301_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……來，",
        "unit_id": 126311,
        "voice": "vo_adv_5120301_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "開戰吧。",
        "unit_id": 126311
    }
]