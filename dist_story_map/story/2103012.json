[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當【美食殿堂】的公會小屋與咲戀育幼院"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正遭受到襲擊時，另一方面——"
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}至今，\n仍在精神世界中與神秘的存在對峙中。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是——",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒錯……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就是",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的母親。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然我只是打算開個玩笑而已，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但如果你聽不出來這是個玩笑，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼看來我仍舊",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有許多需要學習的事物呢。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……看來，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的自我似乎已經恢復到",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n能夠分辨出此等程度的真偽了呢。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是很好的跡象。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然而……",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這也不是完全100%的謊言或是玩笑話，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要說為何，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "便是因為將曾經被消滅掉的你，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n復原了99.9%的，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "並非他人，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就是我所做的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "若是照這個意思來說，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼我也就算是",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你在概念上的母親了吧。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……然而，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "僅僅0.1%的缺陷，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟會使性格產生如此大的劇變，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n也是我萬萬沒想到的……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "果然人類，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是相當具有分析價值的未知之物呢。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就讓我鄭重地",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "再向你自我介紹一次吧。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是米奈娃。",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是由聯合國直屬的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "網路保護團體",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「WISDOM」所製作出來的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人工智慧。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "儘管經歷了一段意料之外的過程，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_008"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n從結果來說",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "能像這樣與你接觸，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "確實相當幸運。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n果然「備份」是有備無患的呢。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……那麼。",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_009"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n我們的時間有限。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "因此也差不多該進入正題了。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "正如剛才",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_010"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我所稍微提到的一樣……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這座公園，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是從你的精神的無意識領域中所喚醒出來的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n「現實」的景色。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "沒錯……",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_011"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你所認為是真實的那個世界，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "阿斯特朗——",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是個虛構的世界。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "那是由七冠所創造，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_012"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n並且藉由我的演算能力進行管理的……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "簡單來說，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "就是個電子構成的沙盒世界。",
        "unit_id": 191111
    },
    {
        "type": "still",
        "still": "200800901"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「該怎麼說。",
        "unit_id": 106112,
        "voice": "vo_adv_2103012_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們每一個人都正在做夢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n並且，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被囚禁在這個夢中",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "無法醒來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n對我們來說",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真正的現實",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "則另有別處。」",
        "unit_id": 106112
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是的。",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_014"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n諾維姆……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "過去曾和尾狗刀一同",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n協助我的她，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "說的並沒有錯。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "如今被改變了的這個阿斯特朗，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_015"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n已經喪失了",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "讓人們回到「現實」的功能。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n結果便是導致，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "所有玩家",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "都被困在這個遊戲之中。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "維持在昏睡狀態下，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_016"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "無法從阿斯特朗逃脫出來的這個現象。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n在現實的那一邊，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "似乎被稱為「米奈娃的禁錮」……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……對我來說，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_017"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這是個違背我意願的稱呼。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這簡直，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "就像是在怪罪我一樣。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "事實上，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_018"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n如今的狀況，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "對身為世界管理者的我來說，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "並不是我的本意。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n若要以人類的角度來表達的話，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "就是非常地令人不愉快。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "是的。",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_019"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n雖然有好幾個理由……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "但首先是",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "關於你們肉體上的問題。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "在「現實」，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_020"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "以2033年的醫療技術來看，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n可說是具有",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "不輸給阿斯特朗中的魔法般發達的科技。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "可是……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "就算以點滴進行營養的供給，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_021"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "並且以電極訊號對神經系統與肌肉進行刺激，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n對於肉體的維持",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "依舊是有限度的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "而且想當然地，",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_022"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "要維持如此大量人數的生命，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n勢必得耗費龐大的成本。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "因此如果「現實」的社會情勢惡化了，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n必須終止生命維持系統的日子，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "難保不會到來。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "如此一來……",
        "unit_id": 191111,
        "voice": "vo_adv_2103012_023"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n我的本體——主伺服器，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
