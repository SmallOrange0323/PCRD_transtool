        "voice": "vo_adv_5027003_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是睜開眼睛的話，那就不只是這樣了……",
