        "voice": "vo_adv_5027003_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且那個人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她絕對沒有在笑。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的完全不知道她在想什麼……",
        "unit_id": 106611,
        "voice": "vo_adv_5027003_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是說啊……",
        "unit_id": 106611,
        "voice": "vo_adv_5027003_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不知道讓我吃了多少苦頭……",
