    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像叫帆稀。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔～",
        "unit_id": 100511,
        "voice": "vo_adv_5027003_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她明明跟克莉絲提娜阿姨完全不同，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n卻讓人有一種很相似的感覺……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n總覺得",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她和另外兩個人不同，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有種不太妙的感覺……",
