        "voice": "vo_adv_5027003_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有這麼慘嗎……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她眼睛閉著就這麼有魄力。",
