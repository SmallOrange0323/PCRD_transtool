    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在開拓的過程中，由於連日反覆進行相同的作業，開始有人感到不耐煩，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n映照在營火下的營地，蔓延起一股疲倦和倦怠感。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今天的工作辛苦了！　",
        "unit_id": 100511,
        "voice": "vo_adv_5027003_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有找到什麼嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我也很想跟你一起去，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但我還有調查的任務……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不是啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是雜事很多，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以沒辦法一起去。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "！　",
        "unit_id": 100511,
        "voice": "vo_adv_5027003_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在往這邊看過來的人",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也是龍人族吧？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "他們都叫她",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "老大，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她應該就是公會會長了吧。",
        "unit_id": 100511
