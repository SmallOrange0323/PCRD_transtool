        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯，",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還可以啦。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你呢？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "！！",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我跟你一起也",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很開……",
