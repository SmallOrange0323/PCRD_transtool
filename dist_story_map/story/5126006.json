    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於凱留實在過於優秀，因此她將直接跳級畢業。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "轉眼間，凱留明天就要畢業了，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而她正在宿舍收拾行李。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明天就要跟這間學園道別了啊。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢業的時刻也來得太快了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明想在這裡……",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再和大家多相處一陣子。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有好多好多……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在青春裡還沒完成的事……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實我一直很憧憬在傍晚放學後穿著制服……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以想試一次",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看看……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？{player}！！？",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你為什麼在啦！！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為自己的東西整理完了，",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以來幫我？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你原本就是來陪我的，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以也會跟我一起畢業呢。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有要拿東西給我？",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個是，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鈴奈給我的留言？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「凱留寶飛起」，",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是惠啟啦惠啟！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰跟妳飛起啊！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n別連寫封信也要讓人吐槽啊！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……有錯字、漏字，",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和注音符號跟圓圓的文字，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再加上用了一堆顏色，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n未免也太難閱讀了……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來如此……",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上面寫說",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然規模不大，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是他們在明天替我們準備了畢業典禮。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "叫我先想好畢業生代表",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的致詞內容。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 127212,
        "voice": "vo_adv_5126006_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然被告知這種事讓人很困擾耶。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說畢業生根本就只有我們嘛！",
        "unit_id": 127212
    },
