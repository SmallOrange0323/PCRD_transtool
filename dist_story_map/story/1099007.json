[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【美食殿堂】的公會小屋中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可召集眾人並提出了某個計畫。"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "跟【美食殿堂】的各位",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "去冒險？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105812,
        "voice": "vo_adv_1099007_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遲早都會回去原本的世界不是嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想要在那之前，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "與你們一起享受冒險☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是我們平常在進行的那種吃遍之旅，",
        "unit_id": 106012,
        "voice": "vo_adv_1099007_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而是遊歷各個都市，類似觀光的行程。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如何？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之前",
        "unit_id": 105913,
        "voice": "vo_adv_1099007_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聊到冒險話題時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下看您似乎興致勃勃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n於是便去找貪吃佩可小姐商量了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知是否會造成您的困擾？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我非～常地開心喔！",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n還請務必讓我同行。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你們覺得怎麼樣？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "贊成贊成，",
        "unit_id": 2711,
        "voice": "vo_adv_1099007_005"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "舉雙手贊成！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n光是聽到冒險兩個字",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就覺得興奮啊。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "要是愛蜜莉雅大人想去那麼就去吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1099007_006"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n有這麼多厲害的護衛隨行，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "相信不會有危險的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真要說有什麼問題的話，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "頂多就是有個礙手礙腳的巴魯斯。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "姊姊妳也太傷人了吧！？",
        "unit_id": 2711,
        "voice": "vo_adv_1099007_007"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我當然很清楚自己實力不足，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "但我會努力",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不要扯大家後腿的。",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "你不需要擔心喔，",
        "unit_id": 109711,
        "voice": "vo_adv_1099007_008"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆一定會",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "保護好昴的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "名為體貼的利刃",
        "unit_id": 2711,
        "voice": "vo_adv_1099007_009"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "刺進男生的心裡啦！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_010"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "肯定很有趣呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我現在",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就已經開始期待了！",
        "unit_id": 109911
    },
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "決定要與【美食殿堂】一同冒險之後過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n愛蜜莉雅等人前去巡訪各式各樣的地方。"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "哇，",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好棒的街景喔！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "有好多我沒看過的建築物。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "唔喔喔，",
        "unit_id": 2711,
        "voice": "vo_adv_1099007_012"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "想不到阿斯特賴亞大陸",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "還挺懂和風之心的嘛！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這裡該不會",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "也有溫泉吧？",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴、",
        "unit_id": 109711,
        "voice": "vo_adv_1099007_013"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "你要去哪裡啊──！？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昴先生，",
        "unit_id": 105913,
        "voice": "vo_adv_1099007_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "溫泉旅館在反方向。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們今天會在此留宿，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一起過去吧。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "501430"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "巨大的風車，",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_015"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "充滿笑容的城鎮……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然聽說過這裡是獸人族的國家，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但想不到是個朝氣蓬勃的好地方。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "巴魯斯，",
        "unit_id": 109811,
        "voice": "vo_adv_1099007_016"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "一直東張西望的會被逮捕喔。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "太不講理了吧……",
        "unit_id": 2711,
        "voice": "vo_adv_1099007_017"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n我根本什麼都還沒做啊！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不對，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "之後也不會做好嗎！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過去跟獸人族",
        "unit_id": 105913,
        "voice": "vo_adv_1099007_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也曾經有一段關係緊繃的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n時期……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但如今的關係已經有所改善，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n蘭德索爾裡",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有許多獸人族居住。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯☆",
        "unit_id": 105812,
        "voice": "vo_adv_1099007_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在也有很多獸人族的人\n加入了【王宮騎士團】喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "意思是曾經對立的兩個種族，",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_020"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "如今可以和睦相處了？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n竟然能辦到這種事呢！",
        "unit_id": 109911
    },
    {
        "type": "background",
        "background": "501530"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說薩拉薩利亞這裡",
        "unit_id": 105812,
        "voice": "vo_adv_1099007_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有一種把潛伏在沙裡的魔物釣起來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n名為「流沙釣」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的傳統漁法！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我之前聽咲戀小姐提過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "早就想來挑戰一次看看了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在沙漠駕駛船支",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_022"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "將魔物釣起這種事，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真讓人意想不到……！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可是為什麼驅除魔物",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還要特地釣起來呢？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的☆",
        "unit_id": 105812,
        "voice": "vo_adv_1099007_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為他們不光是把魔物釣上來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還會做成美味料理！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在薩拉薩利亞街頭看到的攤販……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說那就是魔物魚♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "原來如此……！",
        "unit_id": 109911,
        "voice": "vo_adv_1099007_024"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n驅除之後再吃掉，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "感覺非～常實惠！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "【美食殿堂】的各位",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也都會吃魔物呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不會吃啦！",
        "unit_id": 106012,
        "voice": "vo_adv_1099007_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
