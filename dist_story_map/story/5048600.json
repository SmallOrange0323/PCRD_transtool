[
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊、姊姊！",
        "unit_id": 100611,
        "voice": "vo_adv_5048600_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "聽說拉菲寄信來了，是真的嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是呀。",
        "unit_id": 102211,
        "voice": "vo_adv_5048600_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如妳所見，確實收到了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵，",
        "unit_id": 100611,
        "voice": "vo_adv_5048600_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳臉上的笑意都止不住呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看來收到信讓妳很高興呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是、",
        "unit_id": 102211,
        "voice": "vo_adv_5048600_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是呀。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "畢竟還是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有點擔心，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "能寄封信過來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是讓人安心不少的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘻嘻，",
        "unit_id": 100611,
        "voice": "vo_adv_5048600_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳的語氣彷彿像是拉菲的親姊姊一樣。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那我們就快看看信裡寫了些什麼吧……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "奇怪，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "除了信以外，好像還有其他東西耶？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真的耶。",
        "unit_id": 102211,
        "voice": "vo_adv_5048600_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "究竟是什麼東西……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇，",
        "unit_id": 100611,
        "voice": "vo_adv_5048600_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這是糖果啦！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好可愛哦～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n看起來很好吃耶，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對呀。",
        "unit_id": 102211,
        "voice": "vo_adv_5048600_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "送這種禮物很像她的作風呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，我總覺得",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像在哪裡看過這種糖果……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_5048600_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "看起來和一般的糖果沒什麼兩樣呀……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果妳很在意的話，要不要再研究一下呀？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……沒關係，",
        "unit_id": 102211,
        "voice": "vo_adv_5048600_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在還不需要。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n而且比起這個，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我更好奇拉菲在信裡寫了些什麼。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說的也是。",
        "unit_id": 100611,
        "voice": "vo_adv_5048600_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們兩個一起看吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊♪",
        "unit_id": 100611
    }
]