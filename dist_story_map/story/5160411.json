[
    {
        "type": "background",
        "background": "501473"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "交流祭終於",
        "unit_id": 133212,
        "voice": "vo_adv_5160411_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也在今天結束了嗎。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然發生了大大小小的問題，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是可以說是大成功吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊。",
        "unit_id": 133512,
        "voice": "vo_adv_5160411_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是大成功到可以讓人確信吉歐‧格黑納跟蘭德索爾，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n接下來也能好好相處的程度呢。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 133212,
        "voice": "vo_adv_5160411_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓我感到遺憾的就只有",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "梅杜莎沒能站上",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n蛇祭的頒獎台而已吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "因為",
        "unit_id": 133611,
        "voice": "vo_adv_5160411_003"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我已經達成了見涅妃‧涅羅的目的了，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n而且，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "要是我出場的話會壓倒性地獲勝，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n那樣熱鬧不起來吧？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實際上是……",
        "unit_id": 133512,
        "voice": "vo_adv_5160411_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為戰鬥後的疲勞，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "隔天幾乎睡了一整天，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "結果就，嗯，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是別提的好呢。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不管怎麼說，",
        "unit_id": 133212,
        "voice": "vo_adv_5160411_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "兩個世界",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "能迎來最棒的新年，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是令人高興的事情。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "接下來是──",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "嗯，",
        "unit_id": 133611,
        "voice": "vo_adv_5160411_006"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我今年一定會找到姊姊她們，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "讓今年變成最棒的一年的！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……話雖如此，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我知道沒辦法輕易找到她們，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n也會有很多辛苦的事情。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "但是，",
        "unit_id": 133611,
        "voice": "vo_adv_5160411_007"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "只要有妳們在的話……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "一定沒問題的。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我暫時會待在蘭德索爾，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "請多指教！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 133512,
        "voice": "vo_adv_5160411_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那是當然的啊！",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我們已經是夥伴了，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們就互相幫忙吧。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對了對了，",
        "unit_id": 133212,
        "voice": "vo_adv_5160411_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有事要先告訴妳。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n蘭德索爾在日常中潛藏的危險，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然不像吉歐‧格黑納那麼多，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但是意外地",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會發生很多問題。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……咦？",
        "unit_id": 133611,
        "voice": "vo_adv_5160411_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是說啊。",
        "unit_id": 133512,
        "voice": "vo_adv_5160411_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "新年就不用說了，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在聖誕節跟萬聖節發生事件",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是每年的慣例，",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在海邊",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也頻頻發生問題啊。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "咦咦！？",
        "unit_id": 133611,
        "voice": "vo_adv_5160411_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以說──",
        "unit_id": 133212,
        "voice": "vo_adv_5160411_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀、莫妮卡",
        "words": "歡迎來到蘭德索爾，",
        "unit_id": 133212,
        "voice": "vo_adv_5160411_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀、莫妮卡",
        "words": "梅杜莎♪",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……難道我",
        "unit_id": 133611,
        "voice": "vo_adv_5160411_015"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "有點太早做決定了？",
        "unit_id": 133611
    },
    {
        "type": "background",
        "background": "502116"
    }
]