[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與伊緒，平安地再度上岸。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "終於回到海灘～",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n剛剛沒有漂走，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "多虧有你呢～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "拼命地在泳圈划水前進，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "肯定是累壞了吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "稍微休息一下吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我請客。",
        "unit_id": 110111
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不好意思！",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_002"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "來了―，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_003"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "歡迎光臨―！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "推薦的",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "特製熱帶果汁請給我兩杯。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "啊不好意思呢，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_005"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "小姐。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n其實剛好水果用完了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "妳要的數量沒辦法製作……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是、",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是唷〜……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "不過，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_007"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "如果一杯可以的話材料還足夠，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "能跟男朋友共享的話可以幫妳製作唷。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什、",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼男朋友呀！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們才不是呢〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "什麼，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_009"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "那妳不要飲料了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "先生覺得如何呢？　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "想喝果汁吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n這杯推薦的特製熱帶果汁。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂喂〜！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你不是說要好好聽老師的話嗎～？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛多虧了你，我們才能回到海邊，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然這樣看起來很像情侶，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但也沒辦法了〜……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "好的，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_012"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "決定好了吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "好的，讓你們久等了。",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_013"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n我有放了兩支吸管，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "好好享用喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "請慢用〜",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇啊―，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好棒的果汁啊！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就說我們不是那樣，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只是老師跟學生而已〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也說些什麼吧～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "糟糕！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很渴了吧！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請用，你先喝吧！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也喝太多了〜！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "知道你很口渴，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但是我的份快沒了啦〜！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是―，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "竟然這樣那我也要……！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "吸〜〜〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "超級好喝！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "濃濃的水果味呢～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對呢～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老闆有說過是使用新鮮水果製作，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n很接近自然的味道吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這杯才是夏天的飲料呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓心臟砰砰跳地、讓人心跳加速的美味！",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你這麼說，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺請客的很值得！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "話說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "竟然不知不覺一起喝起來～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的很好喝呢，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我已經無法忍住～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為只有一杯，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "兩人一起分享吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果你再喝太多的話我會生氣唷～",
        "unit_id": 110111
    },
    {
        "type": "background",
        "background": "500691"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是好喝―！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "恢復精神了！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "開始第3回合吧～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這次一定、要好好地",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "練習游泳呢〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "情侶（男）",
        "words": "今天好開心唷～！",
        "unit_id": 312,
        "voice": "vo_adv_1101003_026"
    },
    {
        "type": "dialogue",
        "name": "情侶（男）",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "情侶（男）",
        "words": "差不多該回家了！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "嗯，",
        "unit_id": 1212,
        "voice": "vo_adv_1101003_027"
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "時間差不多了呢。",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "\n",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "情侶（女）",
        "words": "今天玩的好盡興呢～！",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n糟糕！　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知不覺已經黃昏～？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然可惜，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是今天非常滿足呢～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n還沒有學會游泳，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是今天跟你玩水玩得很開心呢！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我拿杯子還給店家，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n稍等一下唷！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "上次像這樣在海邊嬉戲，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是什麼時候呢……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且也很久沒穿泳衣了呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了今天我還特地新買泳衣呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "身為老師不可以這麼興奮的說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n而且有點害羞所以沒跟他說新泳衣的事，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知道有沒有適合我……？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "多謝招待～",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_033"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "啊，小姐！　",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_034"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "謝謝妳拿容器來還呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "只能幫你們製作一杯果汁，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "不好意思呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不會，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很好喝呢〜！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "哈哈哈，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_036"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "那就好！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "話說，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "今天約會開心嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭～！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我就說不是了～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "多虧有他，今天很愉快。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像只有我有玩到的感覺，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很想跟他道謝呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是我呢，不會游泳，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也不太清楚海邊有什麼。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該怎麼辦……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "噢，",
        "unit_id": 1411,
        "voice": "vo_adv_1101003_040"
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "這樣的話我剛好知道一個好地方。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "可能會耽誤你們回去的時間，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "海之家老闆",
        "words": "\n但是有個很適合小姐你們去的地方唷！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓你久等了―！",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_042"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n剛剛跟海之家的老闆聊了一下，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有點晚回來。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個―……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有個地方想請你陪我去呢！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好嘛，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "拜託。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_045"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，你的表情怎麼這麼不安呀。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不相信老師說的話嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你放心，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是想給你獎勵。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那個沒辦法在學校給你、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天才有的獎勵唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我不會對你做壞事的。",
        "unit_id": 110111
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿咻。",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_047"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你也坐下吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "眼睛閉起來……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_049"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……唔！",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_050"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_051"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好了，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "眼睛張開？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_052"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如何？　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "非常漂亮對吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你看起來好吃驚呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作為今天陪伴我一天的謝禮，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_053"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n想讓你看看這個景色。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_054"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也是第一次看到呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "竟然這麼漂亮……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "完全超出我的想像。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你知道為什麼會發光嗎？",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_055"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有點超出學校的進度，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不過這是海中叫做夜光蟲的生物――",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_056"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像老師一樣的教課，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在就先不說了。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_057"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天，我真得很開心。",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_058"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這樣跟男孩子兩人單獨到海邊，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還是第一次呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n從學生時代",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我就很嚮往這件事。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為跟你在一起太開心，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_059"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們是老師跟學生的關係",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我都不自覺快忘記了呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明最一開始",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只是為了來練習游泳。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你呢？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_060"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天開心嗎。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n希望不是只有我一個人開心而已。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天一起到海邊玩，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_061"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是老師……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是只有我跟{player}之間的祕密唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_062"
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "海面的亮光退去了……",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_063"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "開、",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_064"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "開玩笑的啦！　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "忘掉剛剛說的話吧！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "從今以後我會比平常更嚴格，",
        "unit_id": 110111,
        "voice": "vo_adv_1101003_065"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "做好覺悟吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "海面上亮光逐漸停止，退回水平線。\n兩人佇立在海面與星空之間再度出現的邊界前。"
