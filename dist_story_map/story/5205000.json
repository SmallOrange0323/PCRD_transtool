[
    {
        "type": "dialogue",
        "name": "華音",
        "words": "日安。",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_000"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我是",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "容貌秀麗又高貴的大小姐",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "華音，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是不久後的將來，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n要肩負成為這個吉歐‧格黑納支配者命運的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "最強無敵蠍獅妖魔人。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_001"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "為了給墮落成窩囊廢的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這片吉歐‧格黑納之地當頭棒喝，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "以及",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "為了",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "奪回優雅又華麗",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "的人生，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n正日以繼夜地磨練這出類拔萃的美貌與銳利毒尾♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "應該要打倒的對象是",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_002"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "可恨的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "涅妃‧涅羅！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "她是個以前，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "在與本小姐的決鬥中",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "以一紙之差……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "沒錯，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n就是連翻面",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "都輕而易舉的超～薄的一紙之差",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "把本小姐打倒的混蛋！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就因為那薄如紙片的差距，",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_003"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "現在本小姐的待遇跟奴隸沒兩樣……！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啊啊……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我是絕不會接受這種屈辱的！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "在必定到來的復仇成功日之前，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐是不會挫敗的喔……！",
        "unit_id": 134912
    },
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "餘興狂言已畢？",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實難予以掌聲，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "仍是那老調重彈致使奴家呵欠連連的胡言亂語。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "再者──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──如今正是",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對汝施行罪狀裁決之時。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "權當打賞了，米亞呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唸誦吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "遵命～！",
        "unit_id": 51611,
        "voice": "vo_adv_5205000_006"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n那我唸了。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "──罪狀。",
        "unit_id": 51611,
        "voice": "vo_adv_5205000_007"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "其一，",
        "unit_id": 51611,
        "voice": "vo_adv_5205000_008"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "被告人把從吉歐‧提格尼亞拿來的糖果謊稱為寶石。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n當糖果被吃下時，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "向從異世界來訪的客人",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "要求不當的賠償，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n造成了麻煩。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "其二，",
        "unit_id": 51611,
        "voice": "vo_adv_5205000_009"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "由於被告人自認強大，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "變身為巨大的怪鳥，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n對人們",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "做出「欣賞本小姐的美吧！」",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "等強硬要求，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n造成了麻煩。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "其三，",
        "unit_id": 51611,
        "voice": "vo_adv_5205000_010"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "被告人前往異世界，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n以笛子操縱",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "蛇族妖魔人以及巨大蛇，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "計畫強奪王座。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "除此之外，還有──",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "高聲地笑著吵鬧、",
        "unit_id": 51611,
        "voice": "vo_adv_5205000_011"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n高聲地笑著打破玻璃、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n因為高笑聲而讓小孩子哭出來。",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "等一下，最後！",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_012"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n別趁這時添加一些小家子氣的抱怨啦！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "既然聽到了本小姐高貴的高笑聲，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那明明應該頒感謝狀給我才對吧！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "住口。",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_013"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝當銘記此處乃審判罪過之法庭，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n而非罪人得隨意發言之所。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "唔唔唔",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_014"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "唔……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "涅妃……！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝傍若無人般為所欲為，",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_015"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家無法坐視不管。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n罪之天秤",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "當以罰之重錘",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "平衡才合乎道理。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哼、",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_016"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哼……！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "懲罰的話，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "至今明明已經施行過很多次了吧！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "像是讓我在競技場戰鬥，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "讓我表演才藝，其他還有……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啊！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "該該該不會",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這次是想要",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我的高貴頸項嗎～！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家毋須斬首後仍喧囂的腦袋。",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_017"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "且說，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "方才的罪狀中",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "有一項尤為罪孽深重。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n據說正是這愚者的哄笑，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奪走了孩童的笑容──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "給我等一下，涅妃！",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_018"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n那些不過是庶民的投訴──",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此一來便是必然，",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "懲罰乃──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「搔癢之刑」。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啥！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205000_020"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "妳說搔癢！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "妳是瘋了吧，涅妃！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n為什麼我要接受那種可笑至極的刑罰！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家無半點說笑之意。",
        "unit_id": 129711,
        "voice": "vo_adv_5205000_021"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若奪走了稚子笑容，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便該以汝之身體償還才是。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是吧，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "米亞呀？",
        "unit_id": 129711
    },
    {
