    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被夏日祭典的喧囂所籠罩的蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在人群之中有一個嬌小的身影，將視線投向了一對男女。"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "盯……",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_000"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "太閃耀了……",
        "unit_id": 1111,
        "voice": "vo_adv_9009005_001"
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "妳的眼睛",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "比百萬盧幣的夜景還美。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "那光輝簡直是一等星！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "光是對視，我就覺得自己快要被吸進去了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "妳的眼神，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕男子",
        "words": "是黑洞級別的呢！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "年輕女性",
        "words": "謝、",
        "unit_id": 1211,
        "voice": "vo_adv_9009005_002"
    },
    {
        "type": "dialogue",
        "name": "年輕女性",
        "words": "謝謝你，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "年輕女性",
        "words": "達令。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "年輕女性",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "年輕女性",
        "words": "雖然不知道到底是星星還是黑洞，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "年輕女性",
        "words": "但我很高興。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……23分。",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然有對情話範本加以改編這點值得嘉許，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但可惜的是太沒有品味了呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n女生都有點傻眼了啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒辦法了，",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "為了緩解這凝滯的氣氛，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n只好來逗人發笑──",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了～",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到此為止。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這麼歡樂的祭典之日就別惡作劇了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我今天",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會好好盯著妳的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……妳的意思，",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是叫我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n不要打擾那傢伙和其他女孩子，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……總覺得很令人不悅呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好～",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "既然這樣，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我就來隨機惡作劇吧！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "首先第一個是……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "把小石頭",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "放進街上人們的鞋子裡！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼，",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不起眼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但又相當討人厭的惡作劇……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞，給我站住！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咿──！",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好、",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好痛！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "各種東西都要被扯下來了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\nMayday！Mayday！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "Help me！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "吵死了，",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我只有抓著辮子而已吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要無謂地引發騷動啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯？",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等等菲歐，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳看那個。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n是{player}耶。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚唔～！",
        "unit_id": 1,
        "voice": "vo_adv_9009005_012"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我把會發光的項鍊",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "弄丟了～～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n明明剛剛才在攤販買下來的～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他好像在陪小朋友",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一起找弄丟的東西呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "明明只要聯絡【王宮騎士團】的失物招領處",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就可以了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "他居然要幫忙一起找。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n是不是有點太過濫好人了啊？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哇～",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我一不注意，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就把抓著的辮子放開了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不好了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣的話～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會讓涅比亞逃走的～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦，",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……謝謝，",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳也是有優點的嘛！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "給我等一下，",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_019"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "{player}！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "想在這種人潮中",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "邊走邊找失物是不可能的啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這麼擁擠耶？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "想找也是有極限的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我是覺得啦，",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "找東西這種事",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "從空中來找不就行了嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但怎麼可能那麼剛好，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有個會飛的傢伙",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呢……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦──",
        "unit_id": 190911,
        "voice": "vo_adv_9009005_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我也是很忙的呀～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就只有這一次哦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我說，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳告訴我弄丟的寶物有什麼特徵吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就讓我這個美麗又優秀的嚮導小妖精，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "來幫妳找出來吧！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉……",
        "unit_id": 190011,
        "voice": "vo_adv_9009005_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼不坦率。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就睜一隻眼閉一隻眼吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯笑咪咪地看著"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n心情愉悅地幫忙{player}的涅比亞。"
    }
]