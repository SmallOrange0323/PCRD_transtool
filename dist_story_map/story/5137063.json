[
    {
        "type": "background",
        "background": "500523"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──阿斯特賴亞大陸西部，墨提斯大瀑布上方的空中。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "地形與我的世界不同。",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n看來應該是成功潛入了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……這裡便是",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_002"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "作為一切基礎的",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "阿斯特賴亞大陸嗎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "又來了嗎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "紅霧精靈",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 10712
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……！",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_004"
    },
    {
        "type": "background",
        "background": "500523"
    },
    {
        "type": "dialogue",
        "name": "紅霧精靈",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 10712
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真是纏人的追兵。",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_005"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……那麼。",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n接下來該怎麼做呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "既然防護措施出現了破綻，",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n就代表這個世界發生了與米奈娃相關的「某種事」。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這點是肯定的。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "至於那「某種事」……",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n是否為抵達「重置點之後的未來」的關鍵呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……首先得收集情報才行呢。",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "按常規做法，是要去向人打聽──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不……",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這種事我辦不到……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我一點也不和藹可親……",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n就算去搭話，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "肯定也不會有人想理睬…………",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n更何況，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "要向初次見面的人搭話，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我根本辦不到…………",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唉……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……嗯？",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那是……",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "火柱？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好驚人的威力……！",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……該不會！",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_014"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "當初在入侵這個世界時，",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_015"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就一直有種奇妙的感受。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不斷地嘗試失敗後，",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_016"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "總算在防護措施上找到一個細微的破綻。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就如同是用小湯匙將監獄牆壁給挖穿一般……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我花費時間將縫隙鑿得更大、",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不斷往前挖，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "並阻止其被修復。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "然後，",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "當前方總算出現光芒的瞬間──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n視野便感覺一口氣變得開闊。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "沒錯，",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_018"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "舉例來說……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n「就像原本相鄰的兩個小縫隙連接了起來，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "因而形成一個大洞」。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "若真是如此，",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_019"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "應該就會有。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在我這個怜的「複製品」所在世界的隔壁。",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_020"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n應該有著和我一樣，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不斷地挖出縫隙前進的存在。",
        "unit_id": 135614
    },
    {
        "type": "background",
        "background": "500145"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………！",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很好～！",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n魔物討伐完畢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好像烤得有一～點太焦了……",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "應該沒問題吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……奇怪？",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_024"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那個～",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_026"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n妳也是來討伐魔物的嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……看起來應該不是呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……嗯。",
        "unit_id": 135614,
        "voice": "vo_adv_5137063_027"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳……",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_028"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "看得出來嗎？",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "…………",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_029"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原來是這樣呀。",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_030"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯、",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_031"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗯？",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱抱～♪",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_032"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "唔！？",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_033"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "為、",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_034"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "為什麼要抱住我……？",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n比起那個，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我現在",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "該怎麼辦……！？　",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "…………",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_035"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我呀，",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_036"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "叫做埃拉唷。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉……",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_037"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這是個……",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_038"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好名字。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我是這麼認為的。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_039"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……吶，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "告訴我妳的名字吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "叫妳「怜」的話……",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_040"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也不對吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……！",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_041"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……志那都。",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_042"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n就這樣",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "稱呼我吧。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都……",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_043"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是個很棒的名字呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "初次見面，",
        "unit_id": 135512,
        "voice": "vo_adv_5137063_044"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n今後也多指教囉。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "初次見面，",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_045"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我也要……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "請妳多多指教。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……感覺真奇妙。",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_046"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "明明是「第一次見面」，",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_047"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "卻「彼此認識」。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n明明是「從未相遇過」，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "卻「有著記憶」。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "明明是「陌生人」，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "卻「感到安心」。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135613,
        "voice": "vo_adv_5137063_048"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "明明我很不擅長面對",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
