[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "位於蘭德索爾郊外的【咲戀育幼院】，\n被從城外突如其來入侵的大群魔物給襲擊了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而和躲到育幼院內的城內居民們一同，\n鈴莓一行人正為了擊退魔物奮鬥著。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "看招～",
        "unit_id": 102311,
        "voice": "vo_adv_2013007_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉全力揮擊！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚哇啊啊啊～",
        "unit_id": 102111,
        "voice": "vo_adv_2013007_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "滾出去！　",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "滾出去！　",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "快滾出去呀～！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好可怕呀，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼會有這麼多的魔物……！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "冷、",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "冷靜下來呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳們兩個！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可不能隨便揮舞武器的呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n躲到我們這邊的人們",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在已經擠滿了整棟房子了唷！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可、",
        "unit_id": 102111,
        "voice": "vo_adv_2013007_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果不打倒魔物的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "大家都會死掉的啊……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚嗚～",
        "unit_id": 102311,
        "voice": "vo_adv_2013007_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好可怕！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但我才不會哭的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我可是姐姐啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該該該、",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼辦才好啊？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "到底發生了什麼事情，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "才變成這個狀況啊？　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有大量的魔物聚集了過來，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n甚至把整個【咲戀育幼院】都包圍起來了呀！　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然很想和大小姐她取得聯繫，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但城裡是出了什麼事了嗎……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "魔力被干擾得相當嚴重，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "害得通訊魔法也連不太上。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明直到剛剛，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家都還和平的在享受著這場祭典呀。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n然後因為攤販的食物稍微貴了一點，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以才打算回到育幼院來吃飯的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "接著就突然",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "演變成這樣的緊急狀況了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔唔～？　",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "振作一點呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我自己！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可不能夠慌了手腳啊，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n至少",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也要讓孩子們安全逃出去才行呀！　",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那、",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀！？　",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎怎怎麼了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n妳是，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "被魔物追趕著",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "然後逃到了育幼院裡頭的孩子對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是的。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在我和禊一起逛著祭典的時候，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "魔物突然就冒了出來……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為很害怕所以開始跑了起來，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後不知不覺就逃到這來了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "對對。",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是在我們剛好要去看美美她幫忙的那個攤販的途中呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "被魔物害得我們沒有看到呀，真可惜。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還一直一邊哭一邊拉著我到處跑，真是累死人了。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我才沒有哭呢！　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚～！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "乖喔乖喔……",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不能夠吵架唷，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好朋友要好好相處才行呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚～",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這件事先放一邊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我剛剛想到了一個作戰，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不知道妳可不可以幫幫忙呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖、",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然像我們這樣的小孩子說的話，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n大人大概都不會聽進去就是了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但如果大家能同心協力的話，",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也許就能安全逃出去了也說不定！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以說我，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚嗚……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "妳冷靜一點～",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "乖唷乖唷♪　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒事的唷～☆",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "別把人家當小孩子啦！",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明禊",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳也就只比我大一歲而已呀！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然是這樣，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但也還是比鏡華大了一歲的姐姐唷，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n在這種時候就算是禊也想要『振作點』呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還是說，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊要像平常一樣到處搗蛋會比較好嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚～？",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳還搗蛋的話會讓人很困擾的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可是妳突然這麼認真也讓人很困惑呀……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇哈哈～♪　",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "對不起嘛鏡華，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "妳冷靜一點！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "來，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "跟著禊一起做唷？　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "深呼吸～☆",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吸、",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吸……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吐。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n吸，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吐……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……？",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對不起，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我冷靜下來了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……謝謝妳，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯♪",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個呀。",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就像剛剛說的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我有一個作戰。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "首先我把魔法",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "丟到遠一點的地方造成爆炸，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n藉由這樣來吸引魔物的注意……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "然後我們再趁機逃跑，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這樣子。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就算有魔物跑過來追我們了，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n只要靠禊事前先準備好的陷阱也就沒問題囉！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可以靠地洞陷阱來拖延時間，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "然後再趁機逃掉就好了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "正好，我在來這裡時經過的路上，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_032"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n設置了很多陷阱唷。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我們只要有辦法能逃到那邊，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "魔物應該就沒辦法追上了。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯。",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但我覺得在大家會經過的路邊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n擅自設置陷阱是很不對的就是了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但現在，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "竟然會被禊的這個壞習慣救了一命……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘻嘻♪",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊呀，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為常常會自己不小心踩到自己設置的陷阱嘛，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以最近會記錄下在哪裡設置過了陷阱囉。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們大家，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_035"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "一定能夠一邊避開陷阱然後成功甩掉魔物逃掉的唷！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這之後，",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再直直的朝著城外去……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大概是像這樣的感覺。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳覺得怎麼樣呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是不行嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果然小孩子的想法",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是太『膚淺』了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯～……",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但實際上，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "像這樣繼續死守在這裡也不是個辦法嘛。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大概",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "再過不久這房子的牆壁",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也會被魔物破壞掉呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不管怎樣，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總是要想辦法逃出去的呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就算只有一點點，但可以讓大家安全逃出去的可能性",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是增加了嘛，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳們能把這麼努力想出來的作戰說出來",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是幫了大忙唷。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝妳們，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明妳們也很害怕的吧……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真懂事呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳們兩個人。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "乖寶寶乖寶寶♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇哇？",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "耶嘿嘿、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "被誇獎了耶……♪",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊～",
        "unit_id": 102311,
        "voice": "vo_adv_2013007_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓和別人家的孩子在打情罵俏！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這算是劈腿了吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "都這種狀況了，",
        "unit_id": 2111,
        "voice": "vo_adv_2013007_042"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "應該不是還說什麼誰家的孩子的時候了吧。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這裡該大家團結一致，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "然後安全無事的生存下去。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噗吉說的對……",
        "unit_id": 102111,
        "voice": "vo_adv_2013007_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然很可怕，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但不加油不行呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們家的孩子們也是好棒棒的呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就找個好時機",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "下定決心後大家一起逃出去吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我們先把這個作戰告訴大家，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓大家可以倒數然後一起衝出去。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能夠戰鬥的人，",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就負責盡量把追趕過來的魔物給擊退。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小禊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是叫這個名字對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳可以在前面率領著大家嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_047"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊的名字叫禊唷！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但是，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "率～領～是什麼意思？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "帶路的人，",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我想應該是這個意思喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊啊，",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_049"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那明明這樣講就好了嘛？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好啊，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就讓禊來帶路！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊會說出陷阱在哪些地方，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "大家就一邊閃過一邊跟著我走吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那麼就",
        "unit_id": 100411,
        "voice": "vo_adv_2013007_050"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "Let's GO！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "走吧鏡華，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊總覺得開始興奮起來了呢～☆",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等等，",
        "unit_id": 103611,
        "voice": "vo_adv_2013007_051"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還不能走啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就說要先把這個作戰告訴大家了，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "剛剛那個姐姐不是有講了嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n妳也好好聽別人說話呀！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_2013007_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然害怕得都快撐不下去了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但一看到孩子們這麼有活力的樣子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就稍微冷靜下來了……",
