        "type": "dialogue",
        "name": "咲戀",
        "words": "\n若要逃出這的話還是盡早好呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n簡潔的將作戰傳達下去後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們就要全力逃跑了唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在山上那牧場的人們，",
        "unit_id": 102811,
        "voice": "vo_adv_2013007_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n應該正在準備能夠提供給大家避難的場所……",
