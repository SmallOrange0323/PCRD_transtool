        "name": "咲戀",
        "words": "出發了唷，大家！",
        "unit_id": 102811,
        "voice": "vo_adv_2013007_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n只要堅持不放棄，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼希望就絕對不會消失唷！",
        "unit_id": 102811
    }
