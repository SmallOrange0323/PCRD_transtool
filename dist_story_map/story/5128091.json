[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……蘭德索爾某處。"
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "現在開始",
        "unit_id": 7511,
        "voice": "vo_adv_5128091_000"
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "對被告進行審判。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "檢察官方",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "與辯護方，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "妳們準備好了嗎？",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "檢察官方，",
        "unit_id": 127612,
        "voice": "vo_adv_5128091_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "已做好充分準備。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "辯護方，",
        "unit_id": 127512,
        "voice": "vo_adv_5128091_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一樣沒有問題。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你還問",
        "unit_id": 127612,
        "voice": "vo_adv_5128091_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "現在是什麼情形……？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是小哥你",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "明明都已經有我們了，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n卻還和美美她們許下婚約，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以事情才會變成這樣的吧！？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我反對！",
        "unit_id": 127512,
        "voice": "vo_adv_5128091_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n被告",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是作為扮家家酒的一環，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在不具法律效力的",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n手寫結婚申請書上簽了名而已！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不管法律還是效力，",
        "unit_id": 127612,
        "voice": "vo_adv_5128091_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那都不重要！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我想說的是",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這件事並不合理！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "妳如果要這樣說，那根本就無法審判啊。",
        "unit_id": 7511,
        "voice": "vo_adv_5128091_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之，",
        "unit_id": 127612,
        "voice": "vo_adv_5128091_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我要他負起責任！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n檢察官方",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "希望求處無期徒刑！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要讓他到死為止都為我們盡心盡力！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀，",
        "unit_id": 127512,
        "voice": "vo_adv_5128091_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這就是求刑的內容嗎？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那樣的話辯護方也不反駁了。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "麻煩請判決。 ",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀、流夏",
        "words": "說到底，明明都結婚了就不要跟其他人玩什麼扮家家酒。\n說到底，明明都結婚了就別跟其他人玩什麼扮家家酒。",
        "unit_id": 1,
        "voice": "vo_adv_5128091_009"
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "有話要反駁嗎？",
        "unit_id": 7511,
        "voice": "vo_adv_5128091_010"
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "沒有……？",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "那麼，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "就判無期徒刑。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "\n祝你們永遠幸福，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "可別再弄出這種審判了喔。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "審判長",
        "words": "\n因為我們也不是閒閒沒事做啊。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……在回到家以後，{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也在對妻子的道義與面子顧慮這方面，被說教了好幾個小時。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是……",
        "unit_id": 127512,
        "voice": "vo_adv_5128091_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果真的是扮家家酒的話，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是有酌情處理的餘地呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算是扮家家酒，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也會跟我們報告嗎？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊，",
        "unit_id": 127612,
        "voice": "vo_adv_5128091_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果要玩，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "偶爾也讓我們",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一起參加吧♪",
        "unit_id": 127612
    }
]