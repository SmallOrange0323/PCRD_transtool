[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萬聖節的夜晚。忍感應到街上有一股強大的靈力，\n於是和宮子一同前往拜訪伊莉亞。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈～哈哈哈哈～！！",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身正是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統御黑夜的闇之女王，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n伊莉亞‧奧恩斯坦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "伊莉亞～",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳在做什麼？",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔喔～",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是宮子和忍啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們來得正好。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n我有東西要給妳們看看。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "給我們看？　",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要看什麼呢？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咳咳……",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喉嚨的狀態很完美！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "仔細看清楚囉！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈～哈哈哈哈～！！",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身正是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統御黑夜的闇之女王，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n伊莉亞‧奧恩斯坦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……妳是不是撞到頭了？",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳說什麼！妳這失禮的傢伙！",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難得妾身正在為征服世界後",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n的介紹詞做準備呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家知道了，",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "伊莉亞很閒來的。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一點都不閒！　",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只是，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在妾身也沒有任何關於取回魔力的線索，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "除此之外根本無事可做！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "關於妳的魔力，",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我得到了個或許可以當成線索的情報喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳說什麼！？　",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "忍真是幹得好！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳說的那個情報是？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實我今早",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感應到街上某處有一股強大的靈力……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦，",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "靈力嗎？　",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這可真有意思呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n的確，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這可能是取回妾身魔力",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的一個線索。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因此，",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我現在正打算過去調查這件事。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算這件事和伊莉亞無關，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們也不能放任靈力這樣不斷流出。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子也要一起去來的～！　",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家一定會馬上找到線索來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼回事？　",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳這麼有幹勁還真是稀奇啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "因為等調查結束後，",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n忍就答應人家要辦萬聖節派對來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果有這種閒功夫，不如想想怎麼征服世界……",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想這麼說，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過偶爾放鬆一下也好。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳們就開心的去玩吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身雖然也想跟妳們一起去調查，",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但街上祭典吵鬧的氣氛，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "實在很不合妾身的個性。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有什麼事我會再跟妳報告，",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且宮子也在，沒問題的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊。",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "忍會這麼說，應該就是沒問題。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宮子，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳可不要給忍添麻煩喔？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔～",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家難得這麼有幹勁，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "伊莉亞妳真囉嗦～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "希望妳的幹勁不要往奇怪的方向發展就好了……",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來已經到……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "萬聖節啦……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "伊莉亞？",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒事……",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是身為統御黑夜之人給妳們的忠告，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n萬聖節的夜晚，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也許會有些邪惡的傢伙潛入祭典……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "請務必小心……",
        "unit_id": 104412,
        "voice": "vo_adv_5007000_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n因為今晚",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是一個會發生不可思議事情的日子呢。",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "505032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然伊莉亞說了些令人不安的話，",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但街上卻比平時還要熱鬧，充滿活力。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "伊莉亞擔心過頭了啦～",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_029"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好想趕快舉辦派對來的～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說的也是。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就好好地期待吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n為了派對，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們一起努力調查吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那當然～！",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為了增加幹勁，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家帶了比平常更多的布丁來呢～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚼……",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚼……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "調查空閒中吃的布丁特別好吃來的～！",
        "unit_id": 108211
    },
    {
        "type": "still",
        "still": "500700001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子妳看。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n孩子們正在要糖果呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不給糖就搗蛋！　",
        "unit_id": 112,
        "voice": "vo_adv_5007000_034"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不給我糖果就要搗蛋囉！",
        "unit_id": 112
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！　",
        "unit_id": 108211,
        "voice": "vo_adv_5007000_035"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家要趕快把布丁藏起來！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n不然他們可能會盯上這個布丁！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒事的。",
        "unit_id": 103111,
        "voice": "vo_adv_5007000_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那些孩子",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "事前就已經決定好",
