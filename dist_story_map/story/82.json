[
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "喝啊啊啊啊！",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_000"
    },
    {
        "type": "dialogue",
        "name": "贊恩？",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_0000082_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "留下武器後就消失了……",
        "unit_id": 106011,
        "voice": "vo_adv_0000082_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然是冒牌貨啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "武器，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看起來……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也不像是哥哥真正使用過的那把劍呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓大家都過來幫忙，",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n結果只是白忙一場……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的很抱歉。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太見外了吧。",
        "unit_id": 106011,
        "voice": "vo_adv_0000082_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也差不多",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n該學學某位公主殿下，輕鬆地活著比較好喔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留說的沒錯。",
        "unit_id": 105811,
        "voice": "vo_adv_0000082_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠再次和小雪菲一起冒險，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這種程度的辛苦根本不算什麼啦☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_0000082_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實如此。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有點在意。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關於這個大劍的殘骸，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有貪吃佩可小姐說她聽到的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狼嚎聲──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──媽、",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可蘿小姐！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "後面！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……！？",
        "unit_id": 105911,
        "voice": "vo_adv_0000082_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "贊恩？",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_0000082_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會……",
        "unit_id": 105811,
        "voice": "vo_adv_0000082_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明已經完全打倒了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，",
        "unit_id": 106011,
        "voice": "vo_adv_0000082_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正是打倒過一次的敵人了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一口氣解決吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看我的──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "贊恩？",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_0000082_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105911,
        "voice": "vo_adv_0000082_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "承受了凱留小姐的魔法，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n居然還聞風不動……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "贊恩？",
        "words": "……！",
        "unit_id": 191711,
        "voice": "vo_adv_0000082_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可惡，",
        "unit_id": 105811,
        "voice": "vo_adv_0000082_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那應該是比剛才",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還要重的攻擊才對！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話，我們也要全力以赴──",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請等一下。",
        "unit_id": 105911,
        "voice": "vo_adv_0000082_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該不會",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出現在這裡的冒牌贊恩先生和霸瞳皇帝，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實打倒越多次",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會變得越強？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開玩笑的吧！？",
        "unit_id": 106011,
        "voice": "vo_adv_0000082_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明已經強得不像話了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不到束手無策的程度，但我們可應付不來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我同意。",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我們的目的是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要找到哥哥",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和消失的人們。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n沒時間在這裡應付冒牌貨了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "撤退吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然這樣",
        "unit_id": 105811,
        "voice": "vo_adv_0000082_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "殿後就交給我吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了小雪菲，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會加油的☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳，",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們沒有一起回去的話可就沒有意義了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以──",
        "unit_id": 106411,
        "voice": "vo_adv_0000082_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "盡力想出好辦法",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "成功逃脫吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼。",
        "unit_id": 106011,
        "voice": "vo_adv_0000082_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼突然就變得這麼一派輕鬆了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的──！",
        "unit_id": 106011
    }
]