[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "走在蘭德索爾城鎮中心的{player}\n與秋乃巧遇。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來的正好！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了成為「獨當一面的商人」",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我想到一件最適合的事了。那就是投資文化事業！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我如果對這個國家的文化有所貢獻的話，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n肯定也能獲得父親大人的認同！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因此，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "作為紫藤家支援的文化事業第一彈，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n將要舉行戲劇祭！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "其實，今天就是舉辦日……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果可以的話，你現在要不要",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n跟我一起去廣場觀賞呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可以嗎？謝謝你！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，我們現在趕快走吧！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "氣氛好像已經很熱烈了呢！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也有很多觀眾前來觀賞！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個戲劇祭預計會有一人戲劇、兩人演出的戲劇、",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n多人演出的戲劇及富含娛樂效果的表演。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是令人期待呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？好像有人倒在舞臺的旁邊？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好像是……一對男女呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，我們一起去看看情況吧",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "好痛啊……肚子……",
        "unit_id": 311,
        "voice": "vo_adv_1032006_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "打擾一下？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你還好嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先把這杯水給喝下去吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "謝、謝謝妳…",
        "unit_id": 411,
        "voice": "vo_adv_1032006_011"
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "…",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你們怎麼了呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_012"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "其實我們是等會兒要表演戲劇的演員，",
        "unit_id": 311,
        "voice": "vo_adv_1032006_013"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n但是剛剛在休息室吃的料理好像壞掉了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n現在正因為肚子痛而苦惱著……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "好痛啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "我們很努力練習兩人戲劇表演，",
        "unit_id": 411,
        "voice": "vo_adv_1032006_014"
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "\n但現在這樣……不得不取消……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "好痛啊……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "難得這是個好劇本……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此……這是你們自豪的作品嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_015"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "是啊！我想展現給大家看啊……",
        "unit_id": 311,
        "voice": "vo_adv_1032006_016"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n至少只有劇本也好……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n現在還找不找得到人代為演出……應該是找不到吧……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我知道了！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們就代替你們演出吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "真、真的嗎！？",
        "unit_id": 311,
        "voice": "vo_adv_1032006_018"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "如果你們真的願意代為演出的話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n我們也很歡迎的……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人……\n我擅自決定了，真是對不起……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n給你添麻煩了嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這才是我的騎士候選人啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你不用勉強自己，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但可以麻煩你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "站在最前排\n對著我們，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "然後舉著劇本嗎？　",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果能同時\n小聲地指示我們的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們就能照著演了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "拜、拜託你們了……",
        "unit_id": 311,
        "voice": "vo_adv_1032006_022"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，秋乃與{player}一起演出的\n兩人戲劇的出場時刻來臨了。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這布幕升起後，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "便要開始表演了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還真是稍微……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有些緊張……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我想想，基本的故事情節，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好像是年輕夫妻在房裡對話時，妻子發現老公欠債。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但就算如此，兩人仍互相確認彼此的愛依舊不變……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖說是兩人戲劇，竟然也有簡易的房間布景，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n很正式呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且這是……愛、愛情故事呢……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雖、雖然，我是不介意啦……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總、總之，布幕就要升起了！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n演戲的細節部分，我們就在舞台上修改吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n加油囉，{player}大人！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "秋乃小姐，我搶到最前面的位置了喔。",
        "unit_id": 311,
        "voice": "vo_adv_1032006_028"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n我會從這裡讓你們看劇本，給你們建議的，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n那就麻煩你們了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此，這樣應該就沒有問題了吧……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「我是位年輕妻子，與丈夫一起生活……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n過著自由、滿足的日子。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只是，我無法確信丈夫的愛，而每日感到焦躁……」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「啊，歡迎你回來，老公！",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「嗯，歡迎你回來，親愛的……」",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "年輕夫妻……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "像這樣子感覺也不錯呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……糟糕，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "得快說下一句台詞！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「來吧，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "開始吃晚餐吧！」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「哎呀？　",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這張紙是……」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「這是10萬盧幣的借據！　",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_036"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "親、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "親愛的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你什麼時候借了這麼多錢！？」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「就是說啊。區區10萬盧幣的小錢，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我去買東西的時候就順便幫你還啊」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "請、請不要擅自更換劇本――！",
        "unit_id": 311,
        "voice": "vo_adv_1032006_038"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n10萬盧幣可是筆大錢喔――！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，不、",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不小心就以我平常的金錢觀……！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「不、不對，你竟然欠了10萬盧幣……」",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「這、這張借條先放一邊，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_041"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們來吃飯吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n因為餐具不夠，所以要洗碗」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……洗碗？要怎麼洗呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了！我將盤子跟水一起甩，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n把髒污甩掉吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「哈啊啊啊啊啊啊啊啊！」",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_044"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "嗚哇啊啊！才不是那樣吧！",
        "unit_id": 311,
        "voice": "vo_adv_1032006_045"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "給我正常洗碗啊啊啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾",
        "words": "啊哈哈哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_1032006_046"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來，妻子一邊壓抑對丈夫的怒氣，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_047"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n一邊默默地準備曬衣服……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "曬衣桿……是哪一個呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_048"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我想想……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了！總之，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就先用我的劍把柱子砍掉當棍子的話，就能曬衣服啦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「那個，因為沒有曬衣桿，我就砍掉家裡的柱子囉。",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_049"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就冒昧地用這把劍……嘿！」",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "嗚哇啊啊啊！",
        "unit_id": 311,
        "voice": "vo_adv_1032006_050"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n這個場景就算了，演下一幕吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾",
        "words": "啊哈哈！這齣戲真有趣―――！",
        "unit_id": 1,
        "voice": "vo_adv_1032006_051"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "直接演下一幕嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_052"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那個……因為很多場景都跳過了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以剩下的場景是……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "最後一個場景，說完「只要我跟你之間有愛的話！",
        "unit_id": 311,
        "voice": "vo_adv_1032006_053"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n就算欠債也沒關係！」後就親吻！",
        "unit_id": 311
    },
    {
        "type": "still",
        "still": "103200602"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "親、親吻！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_054"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖、雖然說是演戲，但竟然有那樣的場景……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_055"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我完全沒想到啊……",
        "unit_id": 103211
    },
    {
        "type": "still",
        "still": "103200601"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……你認為如何呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n跟我，那個……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說、說得也是呢……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n演戲，這個是演戲……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "覺、覺悟！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_058"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、那指的不是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n決定要做本小姐的騎士嗎……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是為了紫藤家，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以也主辦了這齣戲劇。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我認為，為各位一般市民做些事情，",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_060"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n是本小姐的義務啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_061"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我現在，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要做我該做的事了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可以的吧，{player}大人？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……謝謝你。",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_062"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你真的是一位非常出色的人呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，開始吧……",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n「只要我跟你之間有愛的話！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就算欠債也沒關係……」親、親吻……",
        "unit_id": 103211
