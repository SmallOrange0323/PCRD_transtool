    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……咦？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_068"
    },
    {
        "type": "dialogue",
        "name": "觀眾",
        "words": "哇哈哈哈哈哈！鼓掌鼓掌鼓掌鼓掌！！",
