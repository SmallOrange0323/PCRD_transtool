        "voice": "vo_adv_1032006_073"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032006_074"
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "這齣戲劇本來是很嚴肅的……",
        "unit_id": 411,
        "voice": "vo_adv_1032006_075"
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "\n但是看到了大家的笑容，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女",
        "words": "\n讓我們知道其實只要這樣就好了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "重要的是，任何夫妻間的問題，都該笑著拋諸腦後呢！",
        "unit_id": 311,
        "voice": "vo_adv_1032006_076"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n你們能代替我們演出……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "真的非常感謝！",
