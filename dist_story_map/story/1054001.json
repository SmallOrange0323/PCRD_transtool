[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}看見了一份招募打工的張貼告示，\n前往了招募地址所在的一間裁縫店。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝您的惠顧――！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n歡迎您再次光臨――！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那邊的那位！你幹什麼？來我的店是有什麼事情嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你從剛才開始就一直呆站在店門前對吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是來打工的嗎！既然如此就直接說啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "打工？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……對了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我都忘記自己在招人了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是對不起。還以為是什麼可疑人士……",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是委託人紡希。非常感謝你的到來！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……雖然體格和相貌看起來都不是很靠得住的樣子，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過能增加人手就是萬幸了，總之就先錄取了吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天就請多多指教了！打工的騎士先生！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那我們現在就馬上進入工作吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了蒐集製作服裝",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所必要、用來當作染料原料的果實，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們出發去森林吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n前往森林的路上再做自我介紹。",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我所屬的是一個名叫慈樂之音的公會。",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n雖然是個進行偶像活動的公會，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但我並不是偶像。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我擔任幕後的工作，主要的職務是服裝製作和演唱會的營運。",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "由於演唱會和服裝的評價不錯，目前獨自開了一間裁縫店。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生下次如果需要訂製服裝的話，歡迎來本店試試。",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是能像怜大人一樣為我宣傳那可就幫了大忙了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對了！還得說說怜大人的事呢！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽好了喔？怜大人是我的熟客，也是我的恩人。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天要請你跟我一起收集製作怜大人的衣服所需要的素材呦！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "首先需要跟你說一下怜大人是何許人呢……！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──那時，怜大人把我從魔物手中救了出來！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n接納了人族與魔族混血的我，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是一位擁有非常出色和高潔之心的人唷！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以，如果是為了怜大人我就算是赴湯蹈火也在所不辭……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而且我也加入了她的粉絲俱樂部，和會員們一起聊怜大人的事情……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……欸？已經到了啊。",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n難道我一直都在嘰里呱啦地說個不停的嗎……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是不好意思……我似乎是說過頭了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "整理一下心情，讓我們著手開始工作吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次需要騎士先生收集的是，這種樹木所長出來的果實。",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n採收的方法是有訣竅的。聽好了喔？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "像這樣，用手指夾住莖的部分……輕輕地彎折起來……",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好！採收到了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這種果實和莖都很脆弱，所以採收時要多加小心唷。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來吧騎士先生，你來試試看！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n沒錯沒錯，輕輕地輕輕地……啊這麼用力的話！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊哈哈。變得一臉紫色了呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這個人沒問題吧？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n該說是手法太差，還是太笨拙了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "算了，沒關係，第一次嘗試嘛！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "振作起來再挑戰一次！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺不錯喔！有變得比較熟練了呢！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣不用我看著應該也沒問題了吧……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我去採收那一側樹木的果實，這裡就交給你囉！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種果實的顏色，對這次的服裝來說是絕對必要的，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因此無論如何都非採到不可！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是偏偏都在這麼高的位置……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n唔……就差那麼一點了！看我的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要我拿出實力這點程度的事根本不足掛齒！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "喝！嘿噫！看我的！嘿啊！喔呀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呀啊！？怎、怎麼了嗎，突然間的！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "採集果實的方法嗎？請你就這樣擰住它的蒂頭……",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "欸？啊、啊啊……是的！請把那個果實摘下來！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "非常……謝謝你！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嚇、嚇了我一跳啊……！突然就在我後面！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且，又這麼靠近……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等一下！只不過是和男生的臉靠近了一點而已，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n心跳個什麼勁啊！冷靜──紡希妳給我冷靜點！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "魔物！？居然在這種時候出現……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看我把它給綁起來！嘿噫！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_036"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "被它躲開了！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "被繞到背後了，這樣下去很危險……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_038"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生厲害！就像真的騎士一樣！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，怎麼揮一劍就氣喘吁吁的樣子！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你還是讓開吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎、騎士先生？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可別為了幫助我而太勉強啊！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是現在的話……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，最後一擊就麻煩你了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_042"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……呼……成、成功了呢……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n啊哈哈哈哈……啊，咦？站都站不起來了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝、謝謝你……",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然剛剛變得氣喘吁吁的樣子，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但騎士先生，意外地力氣很大呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了好了！安全採收到果實了，我們回鎮上去吧！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_046"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天辛苦你了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是今天的報酬。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不介意的話請稍微休息一下。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……明明只要把錢給了就可以讓他回去了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼我還是把他留住了呢……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一開始以為他很靠不住，但人挺不錯的，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n他幫我對抗魔物，我也想好好答謝對方呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗨，紡希。妳好啊。咦……？",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是、是的！歡迎光臨欸欸欸欸欸欸！？是怜大人！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "歡歡歡歡迎您的到來！今天有什麼我可以為您效勞的嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是來確認之前委託訂製的服裝做好了沒，",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "結果沒想到會在這裡碰到{player}啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦？剛才的名字是……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "最近在粉絲俱樂部裡謠傳和怜大人很親近的，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那個可疑男子……！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且還真是出乎我意料之外呢。你居然認識紡希啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是你在服裝上有什麼問題的話，儘管來找紡希商量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然她有點……不，是還滿怪的，但本領確實是沒話說喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該不會難道！難道騎士先生，就是謠傳中的那個人！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騙人的吧……因為我剛剛都沒聽他說自己的名字啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對啦──！一開始忘記問他名字啦啊啊啊！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是聽到了這個名字我絕對會馬上拒絕掉他的說……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……但是看上去無害又善良的騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也不可能會接近怜大人做這樣那樣的事吧……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……該不會，他是假裝對我很好，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也用相同手段來討好怜大人嗎……！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定是這樣！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好危險啊……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果你以為這招對我也通用的話就大錯特錯了哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯──",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的是這樣子嗎……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希？怎麼了嗎，沒事吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是！？對、對不起怜大人！有什麼事嗎！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才也提到了，關於我委託訂製的服裝。",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n很在意是不是已經做好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛才才和騎士先生一起去採作為染料用的果實回來！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想再過幾天就可以完成了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊。那我大概下禮拜看看時間再過來一趟吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是！再麻煩您了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}。要和紡希和睦相處哦。",
        "unit_id": 100311,
        "voice": "vo_adv_1054001_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n紡希妳也是。那就下次見囉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "歡迎再次光臨，怜大人！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……沒想到騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就是那個靠近怜大人的可疑男子……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054001_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我、我可是……最討厭你了啊～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不明所以地\n被態度驟變的紡希用絲線捆綁起來，並扔出了店門外。"
    }
]