        "words": "呼",
        "unit_id": 103813,
        "voice": "vo_adv_5213083_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這出乎意料的發展，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓人不由自主地被吸引進去……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體都開始發熱了。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而且，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就像讀完冒險小說時那樣，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "心跳一直停不下來。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 103813,
        "voice": "vo_adv_5213083_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不是身體不舒服。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……是非常",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好吃。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這就是，",
        "unit_id": 103813,
        "voice": "vo_adv_5213083_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "煉獄魔物的味道……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有點辣，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺對身體也很好。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真是讓人上癮呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "得以觸動栞閣下之味蕾，",
        "unit_id": 129711,
        "voice": "vo_adv_5213083_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家深感欣慰。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此等魔物",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不過是煉獄美饌之一隅。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "秘境深處，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "尚藏有數不勝數的魔物──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃至珍饈美食吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "吉歐‧格黑納裡，",
        "unit_id": 103813,
        "voice": "vo_adv_5213083_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然還有許多",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我所不知道的風景呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "想再去一次了！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5213083_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若栞閣下有此心願，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n無論何時，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家都願為恁引路。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "熔岩翻騰之巖窟，",
        "unit_id": 129711,
        "voice": "vo_adv_5213083_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "瘴氣盤旋之古跡，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "精靈肆虐之混沌原野──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論何處，想必皆乃未曾得見的一段冒險譚。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "待萬事齊備，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸事調妥後，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "再請移駕光臨。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真、",
        "unit_id": 103813,
        "voice": "vo_adv_5213083_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的嗎……！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n務必拜託妳了！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我得先做好各種準備才行……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首先，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要從鍛鍊身體開始，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對吧。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我，",
        "unit_id": 103813,
        "voice": "vo_adv_5213083_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一定會變強的！",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n強到足以前往吉歐‧格黑納的祕境……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請陪我一起訓練，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "拜託你了！",
        "unit_id": 103813
    }
]