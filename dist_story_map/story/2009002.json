[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以我說，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "讓我和純……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和隊長見上一面呀！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "…………",
        "unit_id": 711,
        "voice": "vo_adv_2009002_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喂，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你回個話行不行啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然忠於守衛的職責很讓人欽佩。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但若只是閉著嘴傻傻的站著，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "守在王宮的出入口的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n魔法裝置也辦得到喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望你能通融一下，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你不也是人嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你看，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也是【王宮騎士團】的一員啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然我們不是朋友，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再怎麼說也是同事對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "至少，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "想讓你替我向隊長傳個話。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大家能在同個公會裡也是有緣，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也不想做出硬闖過去這種傷感情的事就是了？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "…………",
        "unit_id": 711,
        "voice": "vo_adv_2009002_006"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "……不管妳再怎麼求我，",
        "unit_id": 711,
        "voice": "vo_adv_2009002_007"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不行的事就是不行。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "終於願意和人家說話了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我好高興。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "簡直就像是對著石像拚了命說話似的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n像蠢蛋一樣的感覺呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "妳並沒有，",
        "unit_id": 711,
        "voice": "vo_adv_2009002_009"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "踏入這個王宮的權利。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那種事我知道唷。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從古至今，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "王宮便一直都採取著那老掉牙的封建社會制度嘛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n貴族與除此之外的身分都被明確地劃清了界線。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而身為庶民的我，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當然沒有進到王宮內的資格。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正因為這樣，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就只到了王宮的出入口，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n然後拜託你替我通知一下純啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "……不行。",
        "unit_id": 711,
        "voice": "vo_adv_2009002_012"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n隊長目前，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "正在參加會議。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會議？ ",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼啊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒聽說過這回事……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "究竟",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在討論些什麼呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "妳並無知悉的權利。",
        "unit_id": 711,
        "voice": "vo_adv_2009002_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這個守衛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大概也是什麼都不知道吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從剛才的一舉一動看來，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他好像也有點困惑。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算死纏爛打",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "套這個人的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n大概也得不到什麼情報。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但再怎麼說…",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n把這個人撂倒，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就這樣闖進王宮也不是什麼好主意。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然也不是不可能。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n【王宮騎士團】說到底也是伙伴，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還是盡量避免露骨地表現出敵意呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔～嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n繼續待在這裡也只是浪費時間而已，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n往別的方面推敲看看吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "怎麼了？",
        "unit_id": 711,
        "voice": "vo_adv_2009002_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n沒其他要緊事的話，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "就趕緊離開吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好啦好啦。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n您工作辛苦啦～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智～姐！",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦呀，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼啦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喘成這樣……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "總是一下就像個無頭蒼蠅一樣，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可是妳的壞習慣唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然像個小孩子一樣很可愛唷♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚喵嗚喵！？",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請不要摸人家的頭啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "比起這件事，",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我有事情想要向純報告！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的嗎？",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有點遺憾呢，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在似乎見不到純唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個壞心眼的守衛叔叔呀，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是死都不讓人過唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "…………",
        "unit_id": 711,
        "voice": "vo_adv_2009002_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔～？",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是可是，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這事很要緊耶！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要不先和我說明一下吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然不知道是什麼事情，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但說不定我能幫上什麼忙。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔～喵？",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": " ",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就跟小智姐說好了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n小智姐也是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "充滿了正義之心的人呢，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也非常",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "尊敬您唷!",
        "unit_id": 100511
    },
    {
        "type": "still",
        "still": "200900201"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "………♪",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_032"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚喵嗚喵！？",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請不要摸人家的頭啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "明明就是個很會說話的人，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼有時候",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會安靜地撲上來摸人呀！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嘻嘻。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "失禮了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "總之，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在這裡傻傻站著也不是好辦法。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "時間剛好也差不多了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就找間店吃個午餐，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "順便聽聽妳要說什麼吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳有什麼想吃的嗎？",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "欸？",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "吃肉好了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只要吃了肉",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就會變強☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "吃肉呢，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "了解。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不想中午就吃那麼油膩的東西就是了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有間推薦的餐廳，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們就一起去吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好的！　",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊啊可是，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我可以叫上其他人嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "其實",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "想要和純商量事情的不是我，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而是那些孩子唷！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我只是",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被拜託\n向【王宮騎士團】傳話而已唷。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她們似乎叫做",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "【小小甜心】這個名字，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐～妳知道嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為跟我住很近，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且年紀差不多",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以偶爾會一起玩就是。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是這陣子在城中玩著公會家家酒到處引起騷動的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那群孩子啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n有時候做的些事還真挺危險的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因此有警告了她們幾次，所以知道唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那些孩子，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "到底在做些什麼呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯～",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我也不太清楚耶，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "詳細就問她們本人吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "前往餐廳時也順便，",
        "unit_id": 100511,
        "voice": "vo_adv_2009002_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和【小小甜心】的孩子們會合吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嘿嘿嘿～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐～請吃飯♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗚嗚。",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【小小甜心】是有幾個人來著？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我的小荷包可沒那麼寬裕啊……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎真是的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "意料之外的花費呀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是嘛，",
        "unit_id": 103711,
        "voice": "vo_adv_2009002_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也算是為了打破這混亂的狀況，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所必要的花費嘛。",
        "unit_id": 103711
    }
]