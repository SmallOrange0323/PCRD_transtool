[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，怎麼這麼煩！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點都不順利……",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我該不會",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是沒有天份吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『公主騎士』，是由對世界特別具有影響力的『七冠』",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n將一部分的權能過渡出來的存在……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我，也是那其中一人。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』是位對誰都不信任的高傲統治者，",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不僅相中我、多少信任我……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還將自己的力量分割給我，提拔了我。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣完全不行呢～我都沒有",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有效利用『公主騎士』的力量呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真失落，我明明不想讓陛下失望啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，『公主騎士』",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像是男性才能擔當的角色。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是女孩子呢～？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是什麼迴路還是系統出現了不良狀況？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正不是我的問題吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，如果我發出那樣的牢騷，",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像會被陛下說出",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『那我去選其他的男性，不需要妳了』然後就被捨棄掉了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下在這種情況下可是很不近人情的！",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只能拼命加油了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧……",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就一面從基礎再次確認理論，一面踏實地練習吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對嘛，我只要肯做就得到。",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為原本幾乎是初學者的我，卻能短時間就掌握魔法。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要肯做就一定能做到！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我從陛下那裡獲得的『公主騎士』權能，",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可是『操縱魔物』！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我能降伏這群怪物，並如自己的手腳般任意驅使！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不知為何，我已經能順利操縱",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個被稱作闇影的傢伙。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來就輪到普通的魔物囉！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我會完美地操控你們的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成為我的奴隸吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿嘿。",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有沒有哪邊有魔物啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看我一招就吃定你們♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唉呀？",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n咦，是你啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在這種地方幹嘛啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇呀啊啊啊啊啊！？",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔、魔物啊，出來了吧！",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是剛好啊……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要操控你們，我肯定做得到！",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n遵從我吧～受我支配吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n成為我的奴隸～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉呀……？",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n咦，是你啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不、不要亂嚇人啊！",
        "unit_id": 106011,
        "voice": "vo_adv_1060005_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你啊～每次每次都是這樣！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n害我這麼慌慌張張的，有這麼好玩嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，比起那個……",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你聽到我在自言自語的內容了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（糟糕！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n剛剛為了要醞釀情緒而發出很有精神的聲音",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "機密情報……該不會被聽到了吧？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（偏偏還是被這傢伙聽到！",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、怎麼辦？宰了他嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只能宰了他嗎！？）",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為今天風很大，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吹得葉子颯颯作響的太吵了，害你聽不清楚？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說的是真的喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n太好了……♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，算你命大！",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說……你在這種森林裡做什麼啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡跟城鎮不同，會有魔物在這裡徘徊，很危險喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你明明是個幾乎沒有戰鬥力的小卒，真是鬆懈啊～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不可以這樣喔。",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你如果在不被人知道的情況下遭到魔物襲擊殺害，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或是在森林裡遇難什麼的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是會讓人困擾的呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，你說我在擔心你嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是笨蛋嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、才不在乎你發生什麼事呢！",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只是……啊啊算了，懶得跟你說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之你不要誤會啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯，你問我在這裡做什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟你沒關係吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說如果有需要幫忙的地方，你會幫我？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、你幹嘛對我這麼溫柔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你喜歡我嗎……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿嘿……♪",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，才不能讓你幫忙呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是，什麼啊～你不要太親近我啊！",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們是朋友嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不是吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果跟你感情變好、喜歡上你的話……",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n之後",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只會很辛苦而已。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事～跟你沒關係。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說雖然我好像問了好幾次，但你到底在森林裡面做什麼？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡幾乎不太會有人來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我才想說是個很棒的練習場所呢～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最近我幾乎都會在這裡喔……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以你要幹嘛？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡可是我的地盤喔？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你不要隨便給我踏進來喔？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n知道了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，知道就好了。",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…… 哦，你是來找晚餐的食材的啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種東西你去店裡買就好了啊，你很窮嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是那樣的話，我來幫你找食材吧。",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我對那種事可是很擅長的喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟在被陛下找到之前……",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可是像流浪貓一樣，過著很不堪的生活呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "找到食材、達到你的目的的話，就會給我回去了吧。",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這麼決定，你不用在意！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你只要照著我說的做就行了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是希望你能趕快給我走開而已喔？",
        "unit_id": 106012,
        "voice": "vo_adv_1060005_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要給我誤會囉？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才不是為你這樣做的喔？",
        "unit_id": 106012
    }
]