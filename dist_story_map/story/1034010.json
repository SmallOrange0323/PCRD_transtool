        "voice": "vo_adv_1034010_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是啊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我不應該一直關在房間裡工作！",
        "unit_id": 103411
    },
    {
