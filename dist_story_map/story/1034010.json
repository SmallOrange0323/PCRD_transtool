        "voice": "vo_adv_1034010_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總覺得",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "心情都嗨起來了……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種時候",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就想一口氣乾下那個",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵呵呵呵……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "酒？",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊！？　",
