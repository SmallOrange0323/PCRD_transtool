        "voice": "vo_adv_1034010_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我沒事！",
