        "voice": "vo_adv_1034010_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這裡的計算有錯。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n看來是沒加到這部分的數字。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我這裡先做更正吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這份文件",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總算是送來了啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "明明就拜託過這種申請要早點送過來了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n還有很多資料都沒填到……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "得聯絡退回才行。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這月的營業額報告書……",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然有穩定上升，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但還有不少能改進的地方。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來整理削減不必要經費的方案吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來是……",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這不是{player}嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n怎麼了？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抱歉，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我現在正在忙。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n沒什麼空能陪你聊天。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯？　",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎麼了？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n一臉驚訝的樣子……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵。",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……難道我一直都被認為講話含糊不清嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你到底是怎麼看待我的啊……",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "的確是我每次都讓你看到那樣的一面。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然我總是讓{player}見到我鬆懈的一面，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但這",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才是原本的我喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你明白嗎？　",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……啊，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "都已經這個時間了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "差不多該去喝……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，不對不對！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "差點就要一副理所當然的樣子說出口了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真可怕……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不可以，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "優花梨！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳不是已經發誓要禁酒了嗎！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "抱歉，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我要接著繼續處理沒做完的工作，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以沒辦法和你一起去吃飯！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今天的工作量也很多呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要拿出幹勁來囉～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "再隔天――"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵、",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒事，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒事的，優花梨！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是為工作而生的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，一週後――"
