    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自禁酒宣言後數日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}很在意優花梨的情況，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便來到了【墨丘利財團】的公會小屋。"
    },
