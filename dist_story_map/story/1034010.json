    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "找到了，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是這個！",
        "unit_id": 103411
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}真的也要陪我來嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n雖然是讓人放心多了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那我先說明情況，",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n【墨丘利財團】的流通路線",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n接獲有魔物出現的報告。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種事情原本",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "應該去拜託騎士團之類的地方。",
