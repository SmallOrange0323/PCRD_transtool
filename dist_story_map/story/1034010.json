        "voice": "vo_adv_1034010_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就不需要去想些多餘的事情了……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊！　",
        "unit_id": 103411,
        "voice": "vo_adv_1034010_028"
    },
    {
        "type": "dialogue",
