        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "她不光擁有能夠製造出任何東西的",
        "unit_id": 137111
