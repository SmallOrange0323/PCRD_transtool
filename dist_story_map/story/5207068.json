        "type": "dialogue",
        "name": "妮諾",
        "words": "總是大排長龍！",
        "unit_id": 137111
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n無所不有的商店，其商品製作人……",
