[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈，還真是滿臉疲倦的樣子呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那也沒辦法嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟你可是爬上了山呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也曾經為了賺取在蘭德索爾裡的生活費，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而做過必須要送信件到深山牧場裡的工作的唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也因為那些經歷，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你才會有機會和【伊麗莎白牧場】的女孩子們相遇就是了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這方面，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若想不太起來，就試著去翻找一下自己的記憶吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之嘛。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也因此充分的爬了無數次山，而練就一身好體力了不是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我有顯著地感受到你的成長唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次也有好好跟在貪吃佩可一旁輔佐她了嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……但是嘛，這次發生的事件可真就像是災害一樣呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "建築物被大火吞噬、大地被凌亂踐踏，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n大量湧出的鮮血伴隨著響徹天際的悲鳴。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "特別是發生在平時看起來都悠悠哉哉的牧場裡的大家身上……",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才更讓人看得心疼不已呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若可以的話，還希望能夠早一點奪回屬於大家的和平啊。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而因此重建的支援活動，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也是你們今後的課題之一喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了能夠找回那些孩子們的笑容，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……接下來呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在要告訴你的這些事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我至今還是很煩惱是否該現在說出口。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為這個對話就像是夢境一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以也不太會留於你的記憶之中……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，就說吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正，也是你們遲早該要正視面對的問題呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次，你和貪吃佩可同行前往了牧場對吧？",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子的事，你怎麼看？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是個怪孩子對吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然和你組了一個名為【美食殿堂】的公會，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並且感情也都還不錯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果聽不懂這件事在說什麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n試著回頭去找一找記憶的線索吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貪吃佩可基本上雖然是個開朗又直率的好孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但卻也抱持著不少的謎團呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她的談吐之中，偶爾會混雜了一些深刻意味深長的話對吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其實那孩子呀，背負著非常沉重的宿命喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也因此讓她的性命，被相當可怕的傢伙給盯上了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管是第一次和她的相遇，還是這次，不都遇上了魔物的大暴走嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是，因為有哪個誰盯上了貪吃佩可的命，才發動的攻擊唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子不管日夜，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都像這樣照三餐被魔物襲擊，時常有生命的危險喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管如此，仍然能夠真心地以笑臉迎人待人，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n光這一點來說還真像是位公主殿下呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不僅如此。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡的問題在於，則是那盯上貪吃佩可性命的人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是被名為『陛下』的人物所指派的，那位凱留喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是你們所熟識的，那個凱留唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是和你與貪吃佩可、可可蘿一同，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在【美食殿堂】中，愉快地過生活的小夥伴。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子，被那位『陛下』賦予了一個特殊的能力，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因此能夠操縱魔物喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然看起來還不能夠熟練地使用能力，總是失誤連連，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而凱留行動中的其中一個目的，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似乎就是暗殺目標貪吃佩可喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若是走在半路上遭到魔物襲擊被幹掉了，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也就能夠當成事故來處理呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但實際上嘛，那些魔物都是凱留在暗中操控的就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而因為這個陰謀，暗殺未遂之事則不斷地上演。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當然的這似乎並非凱留本人之意，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n全都是因為那位『陛下』所命她才做的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那兩位，是這種關係喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是想奪取對方性命的一方，和性命被盯上的一方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是被害者與加害者喔……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但正因為如此。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n每當你們之間的感情越好，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n往後的發展就會越難受喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是這次，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n凱留雖然也試圖想要暗殺貪吃佩可……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但她心中卻也非常的糾結、難受了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她當然也是個好孩子喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也當然不想對那每一天都圍在一塊吃飯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並且感情越來越好的朋友下手呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，那孩子看樣子似乎無法去忤逆那位『陛下』呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再這樣下去，只會演變成一樁悲劇唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只能靠與那些孩子走得最近的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n來顧著她們了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，盡可能努力不讓這齣以悲劇坐收唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是，身為那群孩子的朋友……",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是像家人一般存在的你，才能夠做到的唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是嘛，這並不是件簡單事呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油呢，我會支持你的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但得在更加，小心一點唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那位『陛下』，看來似乎不是個什麼有耐心的傢伙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n差不多開始想自己處理，不想交給總是失敗的部下了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而那傢伙，可是曾經差一點就能將世界給毀滅的邪惡存在唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是輕易地，就能有辦法解決掉的對象。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只能祈禱至少能活下去。",
        "unit_id": 190011,
        "voice": "vo_adv_2004010_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為只要你還活著，就一定留有一絲希望呢。",
        "unit_id": 190011
    }
]