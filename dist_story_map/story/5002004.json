[
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了取得藥草而踏進迷宮的三人。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇，山裡面竟然有這種地方！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊想像的探險就是這種感覺！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這裡曾被過去的人當成要塞來使用。",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n歷史書裡是這麼寫的……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦──！那就是說，也許會藏有寶藏的意思囉？",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯呼呼呼，說不定會被我們發現哦？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我覺得這種地方的寶藏，應該很久以前就被盜賊之類的人給找到了吧。",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "更何況我們的目的是找藥草而不是挖寶吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我，我明白啦──，就當做個白日夢也沒關係吧！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這地方好像很久沒有人出入了，",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就算變成魔物的居所也不奇怪。所以要小心注意──",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇啊啊啊！鏡華！千萬別動～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？幹嘛突然叫住我！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華剛剛踩到陷阱的開關了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "誒誒！怎、怎麼辦！那個，那個……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華冷靜點！亂動的話會粉身碎骨哦……",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "粉、粉身碎骨！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊馬上來救妳！先別亂動……",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎，怎麼這樣……嗚嗚……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我會死在這裡嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……謝謝你……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊一定會救我的，一定會沒事的對吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好，好的……不過，還是有點可怕……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，請留在我身邊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯，這裡要這樣，然後這樣……咦",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什，什麼！怎麼了嗎！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒什麼啦！沒事沒事……應該吧。",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "應該！？",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}～……嗚嗚",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！這樣啊！嗯，這裡要這樣然後……好了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n已經沒事了！解除完畢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼……啊，真的耶……好厲害……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿～！這種程度，對愛設陷阱的人來說是小事一樁的啦♪",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊……謝謝妳。",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哪裡哪裡！一直都受到鏡華的幫助嘛。",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "話說回來，這個迷宮好像有很多陷阱呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯……注意看的話說不定就能發現陷阱……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那好，我來找出陷阱，然後讓禊來解除它們吧！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "明白！禊拿出全力的話根本易如反掌！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，禊，那塊牆壁的顏色是不是很可疑？",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯！？的確很可疑！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這應該是陷坑吧？大家退後一點！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "妳看，果然是陷坑！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n如果沒注意到，一邊摸著牆壁一邊前進的話，就危險了。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯？腳下似乎有什麼光……啊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n禊，地上有一條線！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這種絕對是拉到線就會從兩旁射出箭的陷阱！！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n絕對不能拉到哦！要這樣跨過去前進。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呼，總算通過陷阱區了吧！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "多虧有禊在！還好妳很清楚對應的處置……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_033"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是多虧了鏡華把陷阱全都找出來啦！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊只是幫忙處理而已！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不對不對是禊！",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_035"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不是不是，是鏡華～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華・禊",
        "words": "……噗！",
        "unit_id": 1,
        "voice": "vo_adv_5002004_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華・禊",
        "words": "啊哈哈哈哈哈哈～！",
        "unit_id": 1,
        "voice": "vo_adv_5002004_038"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "（禊好像能和鏡華好好講話了！？",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_039"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "說不定現在就是道歉的機會！）",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "（進入迷宮以後，感覺就能好好和禊對話了……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要道歉的話，應該要趁現在吧？）",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華・禊",
        "words": "那、那個……！",
        "unit_id": 1,
        "voice": "vo_adv_5002004_041"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯？剛才的是……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_042"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那是，陷阱的開關……哥哥，難道……",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_043"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥大笨蛋──！！！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_044"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哇──！！大石頭滾過來了～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊、{player}！",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_045"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n得趕快逃才行！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "之前才說過一定要注意周遭的情況啊！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_046"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呼，呼……啊！裡面有個房間！我們往那裡逃吧！",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_047"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哈、哈……總算，沒事了……",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯嗯，而且好像剛好到了迷宮的最深處了。",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_049"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我想從這深處應該可以回到外面……吧……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華？怎麼了嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_050"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，是什麼東西呢……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_051"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好像是巨大的油燈……啊啊～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_052"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n難道是魔法油燈！？我們發現寶物了嗎！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──咕喔喔喔喔",
        "unit_id": 10211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 10211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "動、動了～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_053"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咿！禊快退後！那不是寶物哦！",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_054"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這是……魔物啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸！這麼大的魔物，光靠我們打不贏吧！？",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_055"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可，可是，不想辦法處理這頭魔物，就沒辦法到出口啊……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_056"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n藥草已經近在眼前了說！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唔唔……雖然害怕……可是美美在等我們呢！",
        "unit_id": 100411,
        "voice": "vo_adv_5002004_057"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n為了治療美美的病，只好打倒你這傢伙了──！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊……",
        "unit_id": 103611,
        "voice": "vo_adv_5002004_058"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也…",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也要戰鬥！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "支援就……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "拜託你了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
