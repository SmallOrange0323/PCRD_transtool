    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太舒服了，泡到都有點頭暈了呢。",
        "unit_id": 111611,
        "voice": "vo_adv_6029110_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被你看到剛洗完澡的樣子，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有點害羞呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵。",
        "unit_id": 111611,
        "voice": "vo_adv_6029110_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難怪會泡過頭呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過要記得補充水分喔！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是真陽送的牛奶……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要不要一起喝？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你還好嗎！？　",
        "unit_id": 111611,
        "voice": "vo_adv_6029110_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你重心有點不穩耶！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n來，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抓著我。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的身體，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好溫暖。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……好像連我",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都覺得有點昏了。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_6029110_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可能是因為溫泉泡太久了吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要一直盯著我看嘛！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會渾身發燙的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的臉",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要湊過來啦！",
        "unit_id": 111611
    }
