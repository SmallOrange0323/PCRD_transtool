[
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，",
        "unit_id": 124711,
        "voice": "vo_adv_5108323_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n宴會也差不多進入高潮了吧。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "溫泉之神",
        "unit_id": 124611,
        "voice": "vo_adv_5108323_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也看起來心情很好呢。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是到目前為止……",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "最開心的一次。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳們兩位",
        "unit_id": 124511,
        "voice": "vo_adv_5108323_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該懂吧？",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們的職責",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是使客人幸福。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n在這間旅館工作的人們",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "全都是為了這個目的而全力以赴。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……",
        "unit_id": 124611,
        "voice": "vo_adv_5108323_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那當然。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可沒打算偷懶。",
        "unit_id": 124711,
        "voice": "vo_adv_5108323_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然如此，",
        "unit_id": 124511,
        "voice": "vo_adv_5108323_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就不用多說什麼了吧。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就算對方是神明，",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也要用盡全力使祂開心。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……就用我們的方式來款待。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來吧，",
        "unit_id": 124511,
        "voice": "vo_adv_5108323_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "溫泉之神。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n接下來是陽卵旅館引以為豪的",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "極致款待。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請好好地",
        "unit_id": 124511,
        "voice": "vo_adv_5108323_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "享受吧！",
        "unit_id": 124511
    }
]