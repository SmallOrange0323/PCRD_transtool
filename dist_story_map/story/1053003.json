    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時間來到莫妮卡打算參加的決鬥大賽當天。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……好、",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "終於到這一天了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為有閣下陪我一起特訓，",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我也變強許多了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在這個大賽裡，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一定可以大顯身手的！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "明明應該是這樣的……",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊，不，沒什麼！",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我、我還得去確認報到，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我走了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "下次見面",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "應該是我獲勝之後啦！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再見！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔……",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "糟糕……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "結果，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還是沒能說出實話……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到，",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大賽居然有身高限制……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可我的身高……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但、",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是讓人幫忙進行特訓，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n結果卻不能參賽，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這實在難以啟齒……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "該怎麼辦呢……",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然在報名表上，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我虛報了一點身高……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不可以放棄！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說不定",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我昨天一夜之間突然長高了也不一定！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且，",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大賽也不一定會仔細檢查身高。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "總之就去報到看看吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "好的，現在開始按照順序量身高喔──！",
        "unit_id": 311,
        "voice": "vo_adv_1053003_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "完了……",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n果然還是要現場量身高啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "下一位──！",
        "unit_id": 311,
        "voice": "vo_adv_1053003_012"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n就是小姐妳啦。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n請站到這裡來。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等、等等、",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我……去上一下洗手間。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "很快就好了。",
        "unit_id": 311,
        "voice": "vo_adv_1053003_014"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "好啦，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "請站上來吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔、",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔嗯……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看來是逃不過了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "我看看……？",
        "unit_id": 311,
        "voice": "vo_adv_1053003_016"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n呃，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "138公分呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "非常抱歉。",
        "unit_id": 311,
        "voice": "vo_adv_1053003_017"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n為了安全起見140公分以下的人不能參加喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "果然是這樣……",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，我有足夠的實力！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且，",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了今天的比賽，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還有夥伴特地陪我進行了特訓，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了夥伴，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我絕對要參賽！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "拜託你了！",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n請讓我參加吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "就算妳這麼說，",
        "unit_id": 311,
        "voice": "vo_adv_1053003_021"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "但規矩就是規矩……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你就行行好吧！",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_022"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "怎麼了，怎麼了？",
        "unit_id": 1011,
        "voice": "vo_adv_1053003_023"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n發生什麼事了啊？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "身高不夠？",
        "unit_id": 811,
        "voice": "vo_adv_1053003_024"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "\n有什麼關係嘛。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "\n她都已經這麼誠懇地拜託了，就讓她參加嘛。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "幾位閣下……！",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_025"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "但是，",
        "unit_id": 311,
        "voice": "vo_adv_1053003_026"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "這是規則……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "不行就是不行。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "對小孩說這種話，太殘忍了。",
        "unit_id": 1011,
        "voice": "vo_adv_1053003_027"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "要不然，大賽也辦一個小孩部門呀！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "是啊是啊！",
        "unit_id": 811,
        "voice": "vo_adv_1053003_028"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "為什麼沒有小孩部門呢？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "\n如果有的話，事情可以解決啦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊……不、",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_029"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我並不是小孩……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "小孩部門！",
        "unit_id": 1,
        "voice": "vo_adv_1053003_030"
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "小孩部門！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都說了，我不是──",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_031"
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "小孩部門！！",
        "unit_id": 1,
        "voice": "vo_adv_1053003_032"
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "小孩部門！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "我、我瞭解了！",
        "unit_id": 311,
        "voice": "vo_adv_1053003_033"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n是我錯了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "所以，請大家安靜！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_034"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "難道，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也可以參加了嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "下次我們會設一個小孩部門的。",
        "unit_id": 311,
        "voice": "vo_adv_1053003_035"
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "接待員",
        "words": "所以小妹妹妳就當個好孩子，等到下次再參加吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔……",
        "unit_id": 105311,
        "voice": "vo_adv_1053003_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔唔唔……！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我都說了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不是小孩！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n滿口小孩、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "小孩的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "給我適可而止──！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "哇、哇啊！\n抓狂了呀！？",
        "unit_id": 1011,
        "voice": "vo_adv_1053003_037"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "誰快來快阻止她──！！",
