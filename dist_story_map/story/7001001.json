[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喔！　",
        "unit_id": 104311,
        "voice": "vo_adv_7001001_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這些魔物身上還會掉出寶物呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好厲害好厲害！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊——，真是失策。",
        "unit_id": 104311,
        "voice": "vo_adv_7001001_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是事先能預料到有這種美事",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n早知道就帶一個大包包來了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "喂喂，",
        "unit_id": 101411,
        "voice": "vo_adv_7001001_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然我不是不能理解寶石的魅力，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但妳該不會是忘記我們此行本來的目的了吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們是來這邊當尋寶獵人的嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_7001001_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不是吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉抱歉，",
        "unit_id": 104311,
        "voice": "vo_adv_7001001_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我知道了啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n優衣這樣總行了吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 100211,
        "voice": "vo_adv_7001001_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當然。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們來調查這座塔，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是要來取回騎士先生記憶的哦。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說，",
        "unit_id": 104311,
        "voice": "vo_adv_7001001_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來到這邊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳有發現到甚麼嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　霞。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒有，",
        "unit_id": 101411,
        "voice": "vo_adv_7001001_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "目前情報不足",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n還不是開始推論的階段呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然如此，",
        "unit_id": 104311,
        "voice": "vo_adv_7001001_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那就繼續調查吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好～耶，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "寶藏等等我喔～！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……我很懷疑我和妳剛才真的有對話過嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_7001001_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真、真琴，我們才剛講過的……",
        "unit_id": 100211,
        "voice": "vo_adv_7001001_010"
    }
]