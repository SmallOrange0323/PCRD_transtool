[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_5084655_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底要怎麼做那傢伙才肯醒來呀……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明就已經把想到的辦法都嘗試過了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "卻完全沒有成效……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再這樣下去……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不行，",
        "unit_id": 106012,
        "voice": "vo_adv_5084655_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可不能",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在這垂頭喪氣！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是還沒有……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好向那傢伙道過謝哪。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明想傳達給他的心意，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多到化為言語也訴說不完。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我決定了。",
        "unit_id": 106012,
        "voice": "vo_adv_5084655_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對不會放棄的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要把那傢伙從夢中帶回來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後將至今為止沒能說出口的想法，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n用言語確實地傳達給他。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好……",
        "unit_id": 106012,
        "voice": "vo_adv_5084655_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然這麼決定了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n無論如何我都要想法子把那傢伙給打醒。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n給我等著瞧！",
        "unit_id": 106012
    }
]