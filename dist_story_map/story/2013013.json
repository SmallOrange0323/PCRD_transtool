[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯～……",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳的朋友們似乎是及時趕到了呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n所以聊天就暫時到這吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n其實，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我也想再說說更深刻",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "且更重要的事情就是了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但是我剛才也說過了，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "時間到了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……？　",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然聽不太懂你在說什麼。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但關於『闇影』是怎樣存在，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "勉勉強強稍微理解了一點。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是我還是看不穿你的目的呀，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你像這樣到處收集著生命力，",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底是為了什麼？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你到底是想要做什麼？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你又到底是許下了什麼願望？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳知道了又想怎樣呢？",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_004"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n實現人民的願望",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是王宮貴族的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是自己的使命～嘴巴這樣說著……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n然後再對我伸出援手嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "公主殿下？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不……",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你曾經",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把我所有的一切全都奪走了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因此是我該要憎惡的人。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然。",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從結果來看，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也是因為曾經流浪過，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才能獲得這麼多珍貴的事物。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我既不會原諒你，",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但也不會肯定你。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果僅僅互相憎恨，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "互相否定對方，也太令人悲傷了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以想至少先聽聽你要說些什麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後再試著去更加的理解你。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不想單方面的把你當做該憎恨的敵人，",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把你想成是個大壞蛋，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後在一刀兩斷解決之後就全部拋諸腦後。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像那樣被全盤否定著，",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被完全遺忘了的事情，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底有多麼的令人難過……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最明白的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且。",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你也是為了活下去而拚了命的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "活生生的一個人……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還大概是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對小凱留來說非常重要的人嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算世上僅僅只有一個人，",
        "unit_id": 105811,
        "voice": "vo_adv_2013013_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但能夠像那樣這麼珍惜的替自己著想……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼這個人的人生、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他的故事，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就不應該隨隨便便被人給遺忘。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可真不得了呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是可真溫柔呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "公主殿下。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可很期待這樣的妳，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "究竟何時才會把這種漂亮話給撤回呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那一刻到來的時候，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就讓我大聲的嘲笑妳吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……我所講的話，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳是不是根本沒有好好的去理解呀？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "做為生命力保管庫的『闇影』該怎麼製作的方法，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我剛剛不是特地詳細的說明給妳聽了嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是從人類的肉體上，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_015"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將魂魄給抽出來唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而成空殼的肉體則會『消失』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被抽出來的魂魄則會成為『闇影』。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……要把魂魄抽離肉體，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳知道最有效率的好方法是什麼嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……不好，",
        "unit_id": 107311,
        "voice": "vo_adv_2013013_016"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我在周圍偵測到了為數眾多的魔力！",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我等",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "已經被大量的魔物群給團團圍住了！",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如今才發覺已經太遲了。",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們真的以為我是如此親切，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "像是三流故事的惡黨一般，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n口若懸河的自白著自己所做的惡行嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我將『公主騎士』的力量賦予給了凱留並讓她進行實驗，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n接著分析了其中的結構……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而最後，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我自己也能自由自在操控魔物了唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "於「再構築」發生之前，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n「魔物使」",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這種職業似乎是存在著呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若沒記錯，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "尾狗刀似乎就是被這樣稱呼著的專家？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以只要能習得相關的技術，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論是誰都能操控魔物。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "則動手操控了足以將整個蘭德索爾城完全淹沒的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "大量魔物，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n並且將牠們呼喚過來了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那可是就算聚集起了你們所有的好朋友們，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n且拼死拼活的戰到最後一刻",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也依舊束手無策的數量唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "僅管能抵抗到某種程度，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但你們終究會精疲力盡而被踐踏成肉泥吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而當肉體被破壞，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "亦或被殺害……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那魂魄自然也就會從身體脫離。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n人只要一死了魂魄就會脫離肉體，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這樣不難懂吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "僅管不知道『現實』是如何，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在這個世界中就是這樣呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n然後",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這些脫離了肉體的魂魄，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我便能將它變成『闇影』。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且。",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就像我剛剛才說過的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n『闇影』對我來講可是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "生命力的保管庫……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是讓我可以美味地享用的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "最高級的飼料唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而你們全部人，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就會像那樣被料理後",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "端到我的餐桌上呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這可真是太美好了不是嗎？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "吶，公主殿下，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳的那個公會好像叫",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『美食殿堂』",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來著吧……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n是以邊走邊吃為目的的對吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "既然如此，妳自然能感同身受的吧？",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n現在的我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "究竟有多麼的興奮難耐！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不光是又笨又蠢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "甚至還少根筋呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們這群人！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "簡直是鴨子背蔥自投羅網呢！",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們就像自願任人魚肉，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只為了被吞下肚而特地聚集於此一樣呀！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來吧，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好愉快、",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好開心的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "午餐時間可要開始囉！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我要開動了……☆",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "先把你們全部殺光，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再將脫離的魂魄變化成『闇影』，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "最後再一個不剩的吞下肚！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "全都是為了改變命運，",
        "unit_id": 106914,
        "voice": "vo_adv_2013013_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且重新描繪出我所嚮往的物語！",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n然後實現",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我所許下的願望！",
        "unit_id": 106914
    }
]