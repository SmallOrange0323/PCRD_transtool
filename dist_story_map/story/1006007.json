[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與{player}約好要一起出遊的茜里，\n早早就抵達碰面地點。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "能跟哥哥兩個人單獨出遊，真期待～",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里還期待好多事情呢～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "之前，去內衣店的時候雖然失敗了，",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但只要不去那種店的話，應該沒問題的吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然茜里跟哥哥一起出去過很多次，",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但是像這樣兩個人出去玩還是第一次呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "跟哥哥的第一次……真期待呢～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們要去哪裡呢？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥喜歡怎樣的地方呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊～！哥哥怎麼還不來呢～",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_004"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……咦、咦？ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n已經到了約定時間了呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥還沒有來呢～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥遲到真是少見……",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過偶爾也會發生這種事呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里再稍微等等看吧～",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥還不來……",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "早就已經過了約定時間……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里不覺得哥哥會沒有任何聯絡",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就放我鴿子……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "該、該不會，",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥被捲進什麼事了？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥現在有危險！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦……哥哥？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你沒事嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你問茜里是什麼事……",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為哥哥這麼晚才來，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我以為哥哥是不是遇上麻煩了？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你說不是什麼重要的事……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥不想告訴茜里說理由呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里非常擔心耶！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n以為哥哥受了重傷什麼的……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真的很擔心……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "儘管如此，哥哥竟然什麼也不解釋，太過分了！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我不管哥哥了！",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼、呼！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里想都沒想就跑走了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都是哥哥不好！",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唉……",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里很喜歡這裡的風景，所以就跑來了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "本來是想跟哥哥一起來看的呢～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……哥哥只是遲到而已，",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里有點氣過頭了嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥也是有他的苦衷吧……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里還是回去道歉吧！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸、欸欸！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n魔物！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎、怎麼辦，這種時候！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里得趕快逃走！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可、可是牠看起來沒那麼強，不然來打一場……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不、不，還是逃走好了――",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇、哇！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不要過來～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n竟然為了保護茜里而受傷……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你說只是一點小傷……可是！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯？先、先逃走嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我知道了，不要再拉了～",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "魔物沒有再追過來呢。",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "總算甩開牠了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那、那個，哥哥……",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n謝謝哥哥來救我。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還有……茜里剛剛發了脾氣，對不起！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不不，哥哥並沒有做錯事喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里只是有點在意哥哥遲到的理由……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，茜里並不是在責備你――",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……那一包是什麼呢？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這是要給我的禮物！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥為了買這個所以遲到了嗎……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥想給我一個驚喜，所以才不能說理由的。",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對不起，我完全沒有注意到……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝哥哥的禮物！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里能馬上打開來看嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n裡面是什麼呢～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這個……是哥哥之前幫茜里選的內褲！ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_032"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真高興！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我會把它當作哥哥，小心地穿上它的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，哥哥一個大男人竟然能自己去買來呢？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_033"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_034"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請姊姊幫忙的……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嗯，這樣子啊。",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥跟我一起出遊前，先跟姊姊……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里要成為世界上最可愛的人！",
        "unit_id": 100611,
        "voice": "vo_adv_1006007_036"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "絕對要！而且要比姊姊更可愛！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茜里下定了新的決心。"
    }
]