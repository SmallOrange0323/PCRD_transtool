[
    {
        "type": "background",
        "background": "500354"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在育幼院忙物產展，在牧場忙舞台劇。\n當美咲開始過慣這種忙碌生活的某一天──"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝謝您的惠顧──！",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呼～",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天這樣就結束了呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n也來了不少的客人，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "感覺算不錯吧？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是我的魅力吸引了客人吧♪",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這對優雅又成熟的淑女來說，是理所當然的呀。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "像是前陣子，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "經常來我們這裡光顧的婆婆，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n還給了我好吃的糖果",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要給我吃呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "居然能收到粉絲給的禮物，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "簡直就像是真正的女演員呢♪",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唉……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "人長得太美",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也真是個罪呢～♪",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為了讓你也能收到禮物，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我來教你各種事情吧！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "開心吧？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "首先是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要學會露出能吸引人的魅力笑容～",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有事？",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n……是真陽小姐拜託你的事情？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "必須靠我們的工作……",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然是這樣，你就早點說啊。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好了，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們快點走吧？",
        "unit_id": 121411
    },
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "啊，",
        "unit_id": 411,
        "voice": "vo_adv_1214002_008"
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "看到人了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "今天",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "謝謝你們兩位特地前來。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n麻煩你們",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "巡邏溫泉了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……巡邏？",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……所以說，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你們明明有放好熱水，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但溫泉卻總是莫名其妙就沒水了？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "沒有錯，",
        "unit_id": 411,
        "voice": "vo_adv_1214002_011"
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "我們都有把栓子給栓好，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "送熱水的管線",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "也沒有任何破損的地方。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "而且，",
        "unit_id": 411,
        "voice": "vo_adv_1214002_012"
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "這是我親眼看到的。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "晚上",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "有未知的龐大物體，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n在溫泉的陰影處動來動去……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "從那之後，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "我就一直在意到",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n連工作都無法專心，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "因為查不出原因，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "所以溫泉也只好停業。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "真陽小姐也有來幫忙調查，",
        "unit_id": 411,
        "voice": "vo_adv_1214002_013"
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "但畢竟她有其他工作，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n沒辦法一直顧著我們這裡，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "所以你們願意來幫忙，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "讓人放心多了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來如此……",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我知道了！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "謝謝你們！",
        "unit_id": 411,
        "voice": "vo_adv_1214002_015"
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n那麼就拜託你們了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "\n我也會轉告真陽小姐，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "說你們有來這裡",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "牧場人員",
        "words": "幫忙了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好～！",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我要努力當個",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "最時尚",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "又華麗的保鑣！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……說是這麼說，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過看守還真閒呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為只是呆呆站在入口而已呀。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "目前",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "熱水好像放得很順利。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n看起來沒什麼問題呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳好，",
        "unit_id": 1411,
        "voice": "vo_adv_1214002_019"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我是來泡溫泉的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃……",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不好意思，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "溫泉目前正在停業中……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1214002_021"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是這樣啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我經常來這裡的溫泉，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還真可惜呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n泡過溫泉後，整個身子會溫暖起來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能讓做粗活累積的疲勞都一掃而空。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "而且妳想想，",
        "unit_id": 1411,
        "voice": "vo_adv_1214002_022"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "剛泡完澡喝的牛奶，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可是最棒的不是嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這裡有預定會重新營業嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是……",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當然的了！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "絕對會重新營業的！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為我",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一定會逮到犯人的！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "犯人……？",
        "unit_id": 1411,
        "voice": "vo_adv_1214002_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒什麼！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這裡很快就會重新營業了，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "能否請您再稍候一段時間？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "聽到這話讓人放心多了，",
        "unit_id": 1411,
        "voice": "vo_adv_1214002_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那麼我會期待這裡重新營業的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n今天就買個起司回去好了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這裡的起司也是堪稱一絕呢，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "而且偶爾上演的舞台劇也很好看。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝謝您的惠顧，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "請您要再來喔。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……這座牧場",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然很受歡迎呢，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n大家都很喜歡這裡。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有好吃的麵包、",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "起司",
        "unit_id": 121411
    },
