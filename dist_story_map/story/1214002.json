        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "走吧，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "{player}。",
        "unit_id": 121411
    },
    {
        "type": "background",
        "background": "500999"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人報告事情的經過之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n牧場的工作人員開心地不斷向他們道謝。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n之後，兩人決定要去泡溫泉，但是──"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為、",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_056"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為、",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為、",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n為什麼我",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "非得和你一起泡溫泉不可啊！？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這種事我知道啦！！",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_057"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真、",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是沒辦法……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我先泡完再換你泡，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "聽到了嗎？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很好，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_058"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你絕對不能轉過來看這裡，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要待在外面門那裡乖乖等著喔？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n絕對喔？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你要是敢想像",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "裡面的情況，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可絕對不饒你喔！？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那、",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_059"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我先進去了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_060"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n喂，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我說你。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會冷嗎？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你說只是打了個噴嚏，所以沒事？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_061"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼可能沒事啦！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好吧，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_062"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也進來啦！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n要、",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要是你感冒，不就傷腦筋了嗎！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你聽好了？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "絕對絕對絕對，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不准看我這裡喔！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不管發生什麼事，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_063"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "都不可以轉向我這裡喔？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要是敢做出",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "企圖偷看淑女肌膚的行為，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我可會毫不留情地用魔法把你轟出去喔？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所、",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_064"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你快點進來啦！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我也",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很冷……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哈啾！！",
        "unit_id": 121411
    },
    {
        "type": "still",
        "still": "121400201"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呼……",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_065"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好溫暖……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這裡的溫泉果然是最棒的呢。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯嗯，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_066"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "畢竟我盡情",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "大展身手了呀！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你到緊要關頭才趕過來的，所以我想你不知道吧，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我可是一個人",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "挺身面對了那隻巨大的魔物。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果只有你一個人，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_067"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你肯定就逃走了吧。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但是我並沒有膽怯……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不、",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_068"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "以結果來說，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是因為有你的力量，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才能戰勝那隻魔物。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "牧場的人們讓我們在這裡工作，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_069"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n還一起準備舞台劇和物產展，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的非常開心。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來觀看舞台劇的客人、",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_070"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來買東西的客人……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n和育幼院的大家……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_071"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "讓所有人都能感到滿足，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "讓大家露出笑容。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我很清楚只靠我一個人是無法辦到的……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "偶爾",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還是需要有你的力量。",
        "unit_id": 121411
    },
    {
        "type": "still",
        "still": "121400202"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_072"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝謝……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身、",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身為成熟的淑女，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "表達自己的感謝",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是理所當然的！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就是因為感謝你，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_073"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為了不讓你感冒，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n才像這樣和你一起泡澡……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可是不是那個意思喔！？",
        "unit_id": 121411
    },
