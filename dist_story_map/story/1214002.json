        "still": "end"
    },
    {
        "type": "still",
        "still": "121400201"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 121411,
        "voice": "vo_adv_1214002_074"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我有說過不准看這裡吧，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋！！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我要出去了，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你一個人待在這裡泡吧！！",
        "unit_id": 121411
    },
