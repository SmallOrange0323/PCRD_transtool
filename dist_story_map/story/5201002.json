[
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──那是"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過去確實存在過的一段時光。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n你的意識慢慢地甦醒過來。"
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看招！",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_000"
    },
    {
        "type": "background",
        "background": "500146"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦。",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n竟然能躲過我的攻擊。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "能對我剛才的速度做出反應，真是不簡單呢。",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別看我這樣，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我玩遊戲的技術可是足以媲美職業玩家的。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看你慌張的樣子，簡直像是被玩具槍打到的鴿子……",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不對，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或許該說是",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被持槍的女豪傑冷不防地襲擊？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是說因為這樣？",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n其實你是被我克莉絲提娜大人惡魔般的美貌給迷住了。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為是測試用模型，所以我就盡情地想加什麼就加了☆",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的角色模型還沒完成，真是太可惜了。",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至少有臉的話，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我肯定要看看你剛才的表情。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你說什麼？",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你不記得前後發生的事？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你知道現在正在跟我進行遊戲的試玩嗎？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼戰鬥動作的確認呢？",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉，",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可能是「mimi」的連線狀況不佳吧。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來得寫進程式錯誤報告裡才行。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就照這樣再來一戰──",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然我是很想這麼做……",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……但還是算了吧。",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "準備登出囉，",
        "unit_id": 133911,
        "voice": "vo_adv_5201002_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n今天就測試到這裡。",
        "unit_id": 133911
    },
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先不提我反射神經好過頭的事，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "目前在操作性上確實有缺陷。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為只要有絲毫時差，沉浸感就會被削弱。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但以現今的技術水準，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "恐怕沒辦法再減少延遲時間。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以「mimi」的基本連接方式，果然──",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還在啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在已經沒你的事了喔……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話雖如此，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你回去的時間也還沒到嘛。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很閒的話，就看看這個吧。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是我接下模特兒工作時收到的贈閱本。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該至少能拿來打發時間吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順道一提，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這本雜誌中就有滿滿的",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n品牌模特兒、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "創業家訪談、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "新款化妝品廣告，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還有滿滿的我喔☆",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不要用那麼崇拜的眼神看我嘛。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要不要幫你簽個名呀？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一天──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天就送你這個手錶吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這是我前陣子去參加名人們的派對時收到的禮物。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖是個相當昂貴的禮物，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但戴在我身上實在不夠華麗。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話雖如此，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算想收起來，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "倉庫也快放不下了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了？",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為何一臉困擾？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你不知道自己該不該收下原本送給我的禮物",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒關係啦。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那些送禮的人所需要的是",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「把東西送給了克莉絲提娜‧摩根」",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n此一事實。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒人會去在乎東西是怎麼被處理的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後的另一天──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說你，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有在聽音樂嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這片CD給你吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒有啦，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其實是我接到了",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一個蠢委託，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n叫我當製作人，替偶像做企劃。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我試聽了一下，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是還過得去啦。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要讓對方獲得商業上的成功很容易，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但總覺得不太提得起勁。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過將來哪天，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當某人的製作人或許也會是件趣事呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖說能比我還耀眼的人，是不可能存在的♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "更之後的另一天──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那支隊伍",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是讓每個玩家自由發揮各自的技術，並發動連環攻擊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n屬於先發制人類型的……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和我們這隊的風格很像。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該如何對抗才好呢……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我現在正在做的不是開發工作。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是因為由我所率領的專業玩家隊伍，最近就快要比賽了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "隊伍成員的狀態管理、敵方隊伍的分析，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有提出作戰策略什麼的，都是一定要做的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然這點程度，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是希望交給每個人自己判斷就好……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "忙碌",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟我這麼精明能幹，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "忙得不可開交也是難免的嘛。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "由於我才華洋溢，所以各業界都搶著要，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n且我不論做什麼都很成功，這也為我帶來下一份工作，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n並進而讓我累積更多實績。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事業做太大也很令人困擾呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在為了這邊的開發計畫，我已經減少工作量了。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使如此，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "邀約還是如雪片飛來。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真受不了，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "每天都嫌時間不夠用呢♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……！",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是嗎？",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你說我",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "覺得很無聊？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這話真有意思。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n聽了我說的那些話後，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你為什麼會這麼看我？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不……",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不必回答。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然是那個長老帶來的人才，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聰明伶俐是當然的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的看法很正確。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的確",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "覺得很無聊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論把事業經營得多成功、",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論走過了多少華美的紅毯、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論在絢爛的宴會中與多少人共飲美酒。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都無法抹消我的無聊。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──現今的世界太過於簡單了。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "卻又充斥著過多的枷鎖。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "法律、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "常識、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "世俗的眼光──",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明我有信心每次擲骰子都擲出最高點，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但總會有蠢貨扯著我的後腿說我違反規定。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不僅如此，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那些蠢貨還充斥在各種地方，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n宛如空氣般填滿了整個世界，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從任何地方緊盯著我不放，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為的就是「棒打出頭鳥」。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以這個世界",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才需要──",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "絕對的存在。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來你知道啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n知道我崇信真那大人。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一點也沒錯……",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我贊同真那大人所追求的思想。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那位大人的生存方式實在非常極端。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n毫無遲疑地走在孤獨的道路上，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "眼裡容不下任何異物。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他會排除所有阻撓他的事物，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "並以此鋪成自己的道路。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "即使因此毀滅世界也在所不惜。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這正是擁有絕對力量的人才能展現出的態度。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實在很令人憧憬呢。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他讓我覺得",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來「絕對」就存在於這裡。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我在世界上所感受到的累贅",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或是壓抑什麼的，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真那大人一定都能將其粉碎吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正因為從他身上感受到了「絕對」，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我才追隨他。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了活在那位大人的──",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──活在千里真那所創造的世界。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想必那會是個",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "充滿了混沌的亂數、",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對我而言宛如聖域一般的世界吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "研究員",
        "words": "──時間到了。",
        "unit_id": 7531,
        "voice": "vo_adv_5201002_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來接你的人好像到了呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你就回房間去吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我今天有點太多話了。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……這些事要保密喔。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "研究員",
        "words": "那麼，",
        "unit_id": 7531,
        "voice": "vo_adv_5201002_060"
    },
    {
        "type": "dialogue",
        "name": "研究員",
        "words": "我送人回去。",
        "unit_id": 7531
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要鄭重以待喔。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "七冠──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "誓約女君。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克莉絲提娜‧摩根對世界上所蔓延的壓抑揭起反抗的旗幟。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這一切"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "都是為了抹殺那糾纏不清的無聊感。"
    },
    {
        "type": "still",
        "still": "520100201"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "妳還真忙啊，",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_062"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "克莉絲提娜‧摩根。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，長老。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n已經到交接的時候了嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯。",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是本次收集的戰鬥資料。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該有必要重新考慮暴擊率的計算方式，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n目前的算式太單純了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "要讓數值更無秩序可言嗎。",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_066"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "想求得聽天由命的結果，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "就交給妳辦吧。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈、哈、哈☆",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會讓你見識到宛如上帝擲骰一般的亂數。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "放手去做吧。",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_068"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n……這是",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "慰勞品。",
        "unit_id": 107231
    },
    {
        "type": "still",
        "still": "520100202"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個是",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "懷舊點心？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n該不會",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是給那個私生……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是給你女兒的？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "就說她並非我的私生女。",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_070"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n唉，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "甚至連晶",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "都懷疑我女兒是新開發的機器人等類。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n妳們究竟把我當成什麼了。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "遠離俗世的仙人。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_071"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "光看視線動向",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_072"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "就能明白妳在想很失禮的事。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n妳等會",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "去進行場景的除錯作業吧。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_073"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拜託請等一下！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你應該知道我很不擅長做這種事吧！？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "除錯也是很重要的工作。",
        "unit_id": 107231,
        "voice": "vo_adv_5201002_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……唔。",
        "unit_id": 107131,
        "voice": "vo_adv_5201002_075"
    },
    {
        "type": "still",
        "still": "end"
    }
