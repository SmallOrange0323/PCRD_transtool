    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}停留在七夕村。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正當他漫無目的的四處散步時──"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來你在這裡呀～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是的～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我四處找你呢！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "緊急狀態啦～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼怎麼了，",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我現在已經",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "急得像熱鍋上的螞蟻！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果錯過這次機會，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可能會憂鬱到臥床三天！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼，",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你反應這麼快，真是幫大忙了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "正義魔法少女VS",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔物們的幟熱戰鬥……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是啦！！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實是因為",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個村落裡",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有舉辦跳蚤市場！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以我想拜託你來幫我的忙♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你的表情",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一臉就是",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「什麼是跳蚤市場呀～？」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒辦法，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就由七七香老師來告訴你吧。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n簡單來說，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "任何人都可以開店設攤的自由市集……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是這樣啦。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總而言之，",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跳蚤市場裡有賣各式各樣的東西！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在這種地方",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "特別容易出現稀有的舊書，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或獨立開發的",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n私人魔法魔導書，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "千萬不能錯過！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是說真的！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "心想",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「下次再買就好啦～」",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "的書會缺貨，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或是在錢花光光以後，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "才看到想要的超稀有商品，\n這些都是",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跳蚤市場獨有的特色！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你明白這樣的活動",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是多麼重要的",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "聖戰了嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "萬一演變成激戰就不妙了",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "拜託你！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "陪我去買東西吧～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好耶！",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這才是男子漢該有的態度！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "走，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們鼓足幹勁上吧～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔喔！",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是這種感覺！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n到處都散發著好書的味道～！！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這位大姐姐。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n請問這本是",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "關於什麼的書呀？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1133001_011"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "這個是強化紅蘿蔔的魔法。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "魔法師",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "都需要一些在緊急狀況下",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "可以保護自己的武器嘛。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "不過使用劍或魔法",
        "unit_id": 1211,
        "voice": "vo_adv_1133001_012"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "會讓對手充滿警戒，甚至有可能會被奪走……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "所以才發明了",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "這個紅蘿蔔魔法！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我看看……",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "紅蘿蔔佩劍、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "紅蘿蔔步槍！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要準備好一定數量，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "甚至可以發動紅蘿蔔小型光束武器……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "而且使用過後的紅蘿蔔還可以吃掉處理，",
        "unit_id": 1211,
        "voice": "vo_adv_1133001_014"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "非常環保！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼有趣的書",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然要買呀！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請給我1本！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想不到這麼突然就巧遇珍奇逸品，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真幸運♪",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還有沒有什麼有趣的書呢……",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n大哥，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這本書是什麼樣的書呀？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "這是關於",
        "unit_id": 311,
        "voice": "vo_adv_1133001_017"
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "聲音變化魔法的書。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "裡面涵蓋各種魔法，讓妳能成為自己理想中的聲音。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什、",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什什什、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這不是能夠",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "達到全人類的理想的",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最強魔法嗎！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "沒錯，",
        "unit_id": 311,
        "voice": "vo_adv_1133001_019"
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "為了能轉變成理想的女聲，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "我發明了這個魔法。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "只不過，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "這實在是太難掌控了，所以我一直無法使用……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "嗚、",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "哥哥",
        "words": "嗚……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不好意思，我看一下。",
        "unit_id": 113311,
        "voice": "vo_adv_1133001_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯嗯，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "控制起來確實是很麻煩。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過這種程度",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要七七香出馬……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咳！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "閃亮動人～☆",
