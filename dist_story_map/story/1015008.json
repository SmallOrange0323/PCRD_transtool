[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}接受了美里的請託，\n正在幫忙製作繪本。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯──要做怎樣的故事好呢～",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n果然還是冒險故事之類的……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦，",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n{player}，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你又在發光了哦～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好厲害啊～",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那是怎麼做到的呢──",
        "unit_id": 101511
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的～大家好好排成一排喔──",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_003"
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好的──！",
        "unit_id": 1,
        "voice": "vo_adv_1015008_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們一起散步回幼稚園吧──",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？這不是{player}嗎，",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你好呀～",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真巧呢～",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你也來散步～？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "等下大家要一起製作繪本，",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n若是方便的話，你也一起參加如何呢？",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀！那就這麼說定了──",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n還是人多一點比較開心♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀沒問題的唷。因為繪本是沒有標準答案嘛。",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "用你的畫來做一本世上獨一無二的繪本吧♪",
        "unit_id": 101532
    },
    {
        "type": "still",
        "still": "101500801"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，在這紙上描繪大家想出的故事跟圖畫吧～",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家覺得什麼樣的故事好～？",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_011"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "王子跟公主的故事──！",
        "unit_id": 1,
        "voice": "vo_adv_1015008_012"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "我也是～！然後呢──王子殿下要是超級帥哥！",
        "unit_id": 1,
        "voice": "vo_adv_1015008_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，其他還有什麼特徵呢？",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_014"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "嗯～這個呢──是有錢人吧──而且很時髦──",
        "unit_id": 1,
        "voice": "vo_adv_1015008_015"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "個子也要高一點好──！還有什麼都會買給我的人！",
        "unit_id": 1,
        "voice": "vo_adv_1015008_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，大家，光靠外表跟地位，",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n不能決定一個人的價值的唷──",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "那美里老師喜歡怎麼樣的人呢──？",
        "unit_id": 1,
        "voice": "vo_adv_1015008_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯──這個嘛……",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "純粹而坦率，很體貼的人吧。",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_020"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "聽不懂──！",
        "unit_id": 1,
        "voice": "vo_adv_1015008_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，總有一天大家也會了解的喔。",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n當那樣的人出現在自己身邊的話……對吧♪",
        "unit_id": 101532
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，比起老師的事，來聊聊大家想做的繪本吧。",
        "unit_id": 101532,
        "voice": "vo_adv_1015008_023"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦你了。",
        "unit_id": 190011,
        "voice": "vo_adv_1015008_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "王子殿下啊，只要是女孩子，不管是誰都會憧憬的呢～",
        "unit_id": 190011,
        "voice": "vo_adv_1015008_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每個人都有屬於各自理想中的王子樣貌，",
        "unit_id": 190011,
        "voice": "vo_adv_1015008_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是能夠好好地看待別人內在的美里老師，我覺得很成熟哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對她來說，比起虛有其表的王子殿下，",
        "unit_id": 190011,
        "voice": "vo_adv_1015008_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n擁有溫暖的心的人，也許才是真正的王子殿下呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就到此為止囉。再見──♪",
        "unit_id": 190011,
        "voice": "vo_adv_1015008_028"
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯──\n……",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，哎呀？老師不知不覺睡著了……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，你也睡著了啊。",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "又是兩個人一起睡著了呢。呵呵呵呵。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我做了非常奇妙的夢喔。",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_031"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n連睡夢中也在製作繪本……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？你也做了相同的夢？",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "之前也有過一樣的事呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？老師理想的王子殿下是誰……",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說的也是……會是誰呢～",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_034"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n會在哪裡呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "偷瞄……呵呵呵♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_035"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對了！來畫老師在夢中所說的「純粹而坦率，",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_036"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n有著體貼別人心意的王子殿下」的故事如何？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那樣的話，老師一定能夠畫得非常好♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_037"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n因為啊……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我身旁就有這樣的人在呀♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015008_038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與不知為何好心情的美里一起，\n兩人感情很好的製作著繪本。"
    }
]