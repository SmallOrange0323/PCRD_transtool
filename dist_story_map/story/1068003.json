[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}走在蘭德索爾街上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被正在可麗餅店工作的拉比林斯達給叫住了。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨，少年！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你要不要來賣可麗餅？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒錯！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是賣！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我今天",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是希望你買下來，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而是希望你能賣出去！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀～",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實我今天也和平時一樣完全沒有營業額！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以請你幫忙一下！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拜託！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要有困難，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "即使對方是七冠也會出手相助。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我相信",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你就是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種人喔！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "幫大忙了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n雖這麼說，但我想讓你幫忙的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是接待客人，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而是開發商品。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "之所以會沒有客人上門，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或許是因為菜單太普通的關係。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以我今天",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "打算嘗試挑戰",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "開發新口味。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這麼說來少年，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你平時和【美食殿堂】會到處邊走邊吃對吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你們都吃了些什麼東西？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就算不是類似可麗餅的料理也沒關係，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你回想看看。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物料理。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是喔，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物啊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物料理？",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是打倒魔物後，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再進行調理？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n邊走邊吃是這種意思嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此啊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過要以甜點來說有點……",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做成像鹹味可麗餅，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或許也能作為主食銷售……？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……我們就來嘗試看看",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物料理吧！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n既然決定了，那就去討伐魔物。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "走囉，少年！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "移動過程就簡單了事吧！",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只要稍微改一下這個物件……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "目標，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "獲取食材之旅！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "出發！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "首先",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "找找看這附近吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你怎麼了？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒什麼？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就好。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "馬上就發現第一隻！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n角鹿長老啊，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不錯耶。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "趕快打倒牠吧！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我看看……",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "除了堅硬的地方以外，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來有很多地方都能用。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到下個地方去看看吧！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到達〜！",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "立刻",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "討伐！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦？",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這隻魔物",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "收集了樹果啊。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個好像也能用。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "去下一個地方吧！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……石頭再怎麼說也沒辦法吃吧。",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "下一個！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯～",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還想再多收集點食材呢。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將不同的食材做組合，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說不定可以讓東西變得更好吃。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這麼說來，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "把魔物拿來當食材的點子是誰想到的？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "貪吃佩可？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真不愧是公主，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "吃得真是講究啊。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然是做魔物料理，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就表示不一定非得要堅持做成甜點。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是說，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以做成早餐、",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "午餐",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或晚餐，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n任何時段都能販賣的料理！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，少年。",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "告訴我還有什麼其他",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好吃的魔物！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我來去一網打盡吧！",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀～",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "收集到了不少食材呢！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這也都是多虧有少年你的協助！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你累了？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以先去好好休息一下喔。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只不過，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我待會要請你試吃，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以麻煩你要空下肚子來。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉，這樣帶著你到處跑。",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你現在先休息吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n待會就有",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好吃的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可麗餅等你享用囉♪",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "完成〜！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總之",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我篩選過後試做了三樣出來。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n分別是配合",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "早餐、",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "午餐",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "及晚餐的時段做出來的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物可麗餅！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無法將食材的外表處理的沒有魔物感，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但味道應該不差。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請享用♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我期待你能坦率地",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說出感想喔！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……感覺如何？",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是喔！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那真是太好了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……果然還是不太好啊！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是說",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "味道還算可以啊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n謝謝，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很值得參考。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然特地讓少年花時間陪我，但很抱歉，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這無法採用為新菜單。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我還以為行得通的說，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n試試看能不能再稍微改良一下吧……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年？",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "怎麼了？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……說的也是，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難得和少年合作做出來了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n先推出來給客人嚐過以後",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再來做判斷吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "把菜單重新寫過，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣就行了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n既然少年都提案了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那也要請你來幫忙接待客人喔，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可以吧？",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歡迎光臨～！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "本店推出的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "新口味是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "魔物可麗餅～！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "她說魔物可麗餅耶，",
        "unit_id": 311,
        "voice": "vo_adv_1068003_038"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "外表會不會很可怕啊？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "咦～",
        "unit_id": 411,
        "voice": "vo_adv_1068003_039"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你很在意嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n要買是可以，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "但你自己吃掉喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那還用說，",
        "unit_id": 311,
        "voice": "vo_adv_1068003_040"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要挑哪一種口味呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不好意思，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我要一個「角鹿長老肉汁可麗餅」。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好～！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請稍等喔！",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓你久等了！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這是你點的「角鹿長老肉汁可麗餅」！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔哇，",
        "unit_id": 311,
        "voice": "vo_adv_1068003_043"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "外表還挺有衝擊性的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "話說，這是不是插了個角啊？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "算了，無所謂。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我開動了～",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……如何？",
        "unit_id": 411,
        "voice": "vo_adv_1068003_044"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 311,
        "voice": "vo_adv_1068003_045"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能吃耶，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "而且還挺不錯的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嘿～",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "原來魔物吃起來是這種味道啊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真有趣。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年少年！",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "反應比想像中還好！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n聽你的意見是對的耶。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你看那兩人，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對可麗餅充滿了興趣……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……原來如此。",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這次",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "重要的是吸引人注意，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就算味道普通也沒問題啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不如說魔物料理",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "反而就是要味道普通才能入口！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我雖然覺得可麗餅是個很深奧的東西，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但多虧少年，我才能像現在這樣注意到這件事。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝你！",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉。",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_049"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說了這麼多，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "結果還是讓你幫忙我到這種時間。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n今天都讓你一直在幫我忙，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "至少讓我送你回去吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是晚上回去發生什麼萬一也會很困擾，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而且我也希望",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能讓大家吃吃看可麗餅啊♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "食材也都準備好了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們走吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話又說回來，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你經歷了不少有趣的體驗吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n希望下次",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你能仔細地說給我聽聽呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……少年，",
        "unit_id": 106812,
        "voice": "vo_adv_1068003_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你能",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "幫我拿一下食材嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還有",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請你暫時",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "乖乖待著別動。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是不清楚對方是誰，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但還真是不解風情。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難得有機會能和少年親親熱熱的……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "OK，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我就來陪你玩玩吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我知道你在那裡，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "出來吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嘰、嘰」……",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "本人只負責隔岸觀火啊……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n目的是要偵察這裡的情況吧？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很遺憾。",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "淑女的祕密",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可不能輕易洩漏給他人知道呢。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想你也不能空手而歸吧，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以你如果能傷到我，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那我就告訴你一個情報吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一決勝負！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "權能，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "解放！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "改變吧世界！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n──「迷宮生成！」",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嘰、嘰」……！",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歡迎光臨。",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這是將物件變更",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並再造所建構而成的，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的世界。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我以迷宮女王的身分歡迎你們。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在這裡",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就能不必在意主人的命令",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "盡情戰鬥了吧？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n來～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "放馬過來吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "姐姐我來陪你們玩玩！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……怎麼了？",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "該不會是",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嚇破膽了？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n人偶總不可能會感到害怕吧？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嘰、嘰」……！",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "太慢了太慢了！",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "攻擊要這樣做才對啊！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "……！",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "掰掰，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可憐的人偶們。",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……這樣就行了，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是讓他們帶回任何一點情報就麻煩了，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我把他們和迷宮一起消滅掉了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒事啦，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓你擔心了呢。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……很抱歉把你捲進來。",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝你。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你真的很溫柔呢，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "從那時候起就一直是……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正因為少年是這樣的人，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我才會覺得為此賭上性命也願意……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "礙事的傢伙都收拾掉了，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "前往公會小屋吧！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n得向大家展示一下我和少年",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一起做的新口味魔物可麗餅呢！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這次的目標不是少年，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而是我。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n今後對方也會盯著我來。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來我盡量到處去留下蹤影，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n把自己當成誘餌會比較好呢……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "放心吧，",
        "unit_id": 106811,
        "voice": "vo_adv_1068003_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無論這之後的戰鬥會迎來什麼樣的結局，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我都一定",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會成為你的力量。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成功阻止敵人襲擊的拉比林斯達，在內心重新下定決心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並與{player}一同走在夜晚的路上。"
    }
]