[
    {
        "type": "background",
        "background": "501330"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幻影貓……",
        "unit_id": 121611,
        "voice": "vo_adv_6090205_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她的實力是貨真價實的呢。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n的確是有能力讓蘭德索爾為她興起話題。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說回來……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個小偷貓的真面目",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底是怎麼樣的人呢？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟她是甘願做義賊這種麻煩事的人啊。",
        "unit_id": 121611,
        "voice": "vo_adv_6090205_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n應該溫柔又人很好這點看來不會錯。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管她是誰，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們的實力都在她之上啦！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算她自稱幻影貓，",
        "unit_id": 121611,
        "voice": "vo_adv_6090205_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也不代表她一定就是貓啊。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一般應該都不會取這種",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "暴露自身特徵的名字！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥太單純了，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "必須要像我一樣再更機靈一點哦！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 121611,
        "voice": "vo_adv_6090205_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你怎麼說得好像是她朋友一樣呢。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算小哥人脈再怎麼廣，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n也不可能",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "跟幻影貓認識……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們曾一起工作過嗎！？",
        "unit_id": 121611
    }
]