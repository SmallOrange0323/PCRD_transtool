[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咲戀小姐的美……",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然多到令人不曉得該從哪一點先說起，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但她那無論面對任何困境，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也依舊保持優雅的行為舉止是必提的吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不單單只是美麗，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而是驅使她這麼做的心",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就蘊藏著「美」了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美的道路是沒有終點的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真想看到她繼續磨練，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n經過打磨後，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那提升到極致的優雅之美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我相信有一天",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我能在美的道路盡頭",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再見到她的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "鈴莓小姐美麗的地方，",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是她總是專注於目標，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "全心全意努力的態度吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽說她打掃的技術也是首屈一指。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她那為了打造出美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n而堅毅努力的樣子，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是甚至不輸給「美」本身的尊貴存在。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似乎會太過介意自己的失敗呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不用在意！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然有工整的秩序之美，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼同樣也有透過破壞秩序才能產生的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n混沌之美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "藝術就是爆炸、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美即是破壞，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拿出自信來吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "綾音小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那天真爛漫的笑容",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "令人感受到可愛的美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n她在育幼院裡，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似乎是作為大家的姐姐在努力呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "尤其是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她做家事時，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會有點逞強的地方",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓人覺得很可愛。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果要變得更美……",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個嘛，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "希望綾音小姐",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n別忘記那天真燦爛的笑容之美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有時",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也要記得全力揮擊，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來擊出全壘打！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "胡桃",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然現在",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "給人的感覺仍像是含苞未放的花蕾，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但正因為如此，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她在不同人的眼中，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會呈現出千變萬化的綻放姿態呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "從她身上能感受到這樣的神秘之美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這就是所謂的女演員氣質嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只是",
        "unit_id": 126311,
        "voice": "vo_adv_5120070_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她在演戲時，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有時會展現出不容置喙的氣勢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那已經超越美的範疇了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該另外為其命名比較好吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "尤其是她在演繹錯綜複雜的愛恨情仇劇時，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又更令人震撼。",
        "unit_id": 126311
    }
]