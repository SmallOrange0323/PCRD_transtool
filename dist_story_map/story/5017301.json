[
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "受了那麼多傷，",
        "unit_id": 109911,
        "voice": "vo_adv_5017301_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n居然還能以那樣的氣勢襲來……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……對於魔女教徒而言，",
        "unit_id": 109811,
        "voice": "vo_adv_5017301_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "疼痛",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "以及死亡",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "都不具任何意義。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "他們擁有的",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就只有瘋狂而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人，",
        "unit_id": 109711,
        "voice": "vo_adv_5017301_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這裡太危險了，請您退到後面。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這裡就交給雷姆吧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沒事的！",
        "unit_id": 109911,
        "voice": "vo_adv_5017301_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我也是",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "很～強的！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不論對手是誰，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我都會擊潰他的！",
        "unit_id": 109911
    }
]