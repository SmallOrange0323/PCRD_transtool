[
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "早安，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我正等著你喔。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個行李你拿！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我們立刻出發吧！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你問要上哪去？",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這句問得好啊。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "現在我們要去挖掘溫泉！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊。",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看你臉色，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是想著不可能吧。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒問題的，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我有到礦坑打工的經驗。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "挖坑是我的拿手好戲。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我靈光一閃！",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "打造最棒度假村的最後關鍵……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那就是，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "溫泉了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在美麗的大海盡情徜徉後，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "用溫泉暖和身心，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n再配上極品美食與美體療癒……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你不覺得這就是完美的旅程嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總之，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "開發溫泉已經是最優先事項囉。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如果明白的話，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就盡快出發！",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我看過地質調查的資料，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這附近還挺適合的。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n來！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "開始囉～！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼……",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我以為開挖就會挖到，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n結果完全感覺不像有溫泉的樣子。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "暫時休息一會吧。",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如果不休息，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可會撐不住的。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不。",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "溫泉在打造最棒的度假村過程中是絕對不可或缺的喔。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我沒打算放棄啊。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒有這回事。",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要打造最棒的度假村，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是最短",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "且最有效率的路線喔。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我想{player}也是好好考慮過，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n才說過很多話來勸我的……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但這件事情，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也不打算放棄。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀……",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "什、什麼！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等等，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "突然拉著我",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是要帶我去哪裡！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "去大商會會長那裡？",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "為什麼要去那種地方……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我可先說清楚，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不管找誰來勸什麼都沒用的喔？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "喔？",
        "unit_id": 911,
        "voice": "vo_adv_1080003_015"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "這不是帝王章魚那時候的小子跟小姐嘛。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n是怎麼了？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "這，",
        "unit_id": 911,
        "voice": "vo_adv_1080003_016"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "喂喂。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "什麼呀小子，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "一上門來就低著頭。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等、等等！",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n怎麼{player}要做這種事啊！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "什麼？",
        "unit_id": 911,
        "voice": "vo_adv_1080003_018"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "想要我們一起挖掘溫泉？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n為了小姐想打造最棒的度假村？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "最棒的度假村……",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n{player}也是認真地考慮的。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就算向敵對的一方低頭，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也要請他們來挖溫泉……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那就算是我，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也得對{player}的心意有所回應才對！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "會長，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也拜託你了！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我想打造出屬於這片海景的驕傲，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n想打造最棒的度假村。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "請你也來幫助我！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "連小姐也……",
        "unit_id": 911,
        "voice": "vo_adv_1080003_024"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "饒了我好嗎，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "真是的。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "……最棒的度假村呢。",
        "unit_id": 911,
        "voice": "vo_adv_1080003_025"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "這個口氣真大呀。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "不過……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "話倒說得很好。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "令人心動，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "很響亮的理念。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "我很中意啊，小姐。",
        "unit_id": 911,
        "voice": "vo_adv_1080003_026"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "憑這句話，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "我就信你們這一次。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n也讓我看看吧，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "最棒的度假村。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊……",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "非常感謝你！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "那，",
        "unit_id": 911,
        "voice": "vo_adv_1080003_028"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "什麼時候要開工啊？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個。",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "其實已經開工了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "啊？",
        "unit_id": 911,
        "voice": "vo_adv_1080003_030"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "你們是怎麼募集人手的？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊哈哈……",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只有我們兩個而已。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "做事情怎麼這麼沒腦筋啊你們！？",
        "unit_id": 911,
        "voice": "vo_adv_1080003_032"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "哈哈，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "真受不了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "知道了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "盡快開始吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "那開始作業啦！",
        "unit_id": 911,
        "voice": "vo_adv_1080003_033"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "開工啦你們幾個，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "來挖個特大的溫泉吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真不得了，",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_034"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一下子就挖出一個深坑了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也要努力才行。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "喂，小姐。",
        "unit_id": 911,
        "voice": "vo_adv_1080003_035"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "休息途中打擾一下好嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "什麼事呢？",
        "unit_id": 108011,
        "voice": "vo_adv_1080003_036"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "妳的夥伴，",
        "unit_id": 911,
        "voice": "vo_adv_1080003_037"
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "也算是個好傢伙嘛。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "會長",
        "words": "\n為了別人可以把頭壓得這麼低，",
