[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天午後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在「Naschkatze」店內，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n珠希正無所事事。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼～",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我捏我捏。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你的肉球捏起來太舒服了喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我決定今天一整天都要欣賞你的肉球喵～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "嗚喵～",
        "unit_id": 1713,
        "voice": "vo_adv_1251001_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗚喵？",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我是知道啦，但又沒有客人喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你自己還不是從剛剛開始就一直在洗同一個盤子喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然因為莫妮卡接下了討伐魔物的委託，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以就暫時讓我顧店……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但根本沒有任何要做的事喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好了，你也過來這邊，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一起跟貓咪玩喵～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我捏～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我捏我捏～～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我捏～～",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呃，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在不是逃避現實的時候喵！！！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "太多客人一擁而上雖然也很困擾，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但要是就這樣下去，會連房租都付不出來的喵……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們對餐點味道是有自信的……",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "接下來得思考讓客人上門的方法才行喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "妳好～",
        "unit_id": 411,
        "voice": "vo_adv_1251001_008"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n能給我一杯咖啡嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我要外帶。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "歡迎光臨～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我馬上準備喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "嗯嗯……",
        "unit_id": 411,
        "voice": "vo_adv_1251001_010"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "好香。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我果然最喜歡這裡的咖啡了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n我也好想讓奶奶喝到啊。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我奶奶也",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "非常喜歡咖啡。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳這麼說讓我好開心喵！",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n希望妳也務必帶奶奶過來喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "嗯，",
        "unit_id": 411,
        "voice": "vo_adv_1251001_012"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我是很想這麼做啦……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "但奶奶住在遠離城鎮的地方，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n加上腳也不方便，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "所以大概有點困難吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣啊喵……？",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n妳奶奶的家在哪裡呢喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯嗯，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "原來在那片岩壁的前方啊喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我明白了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就由我來把咖啡外送到奶奶家喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵呵呵♪",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不只有請人來的方法，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n也有由我們從這裡送過去的方法啊喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "咦……",
        "unit_id": 411,
        "voice": "vo_adv_1251001_016"
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "我是很開心啦，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "但我認為那很難喔？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "雖然看起來可能",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "會覺得奶奶家離很近，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "客人",
        "words": "但那裡──",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "機會難得，所以我也要請她吃鯛魚燒喵！",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那跟熱呼呼的咖啡可是絕配喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說的也是～",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "畢竟今天也沒客人……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我明白了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那準備後就出發喵～！",
        "unit_id": 125111
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們是咖啡廳「Naschkatze」喵……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們送咖啡來了……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀，你們",
        "unit_id": 611,
        "voice": "vo_adv_1251001_020"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這不全身是汗嗎……！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n你們是從鎮上跑過來的嗎！？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "雖然這裡看起來離鎮上很近，",
        "unit_id": 611,
        "voice": "vo_adv_1251001_021"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "但因為必須繞遠路，所以出乎意料地累人呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯喵……",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "比想像中還花時間，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓妳久等了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這也不是什麼久不久等的狀況……",
        "unit_id": 611,
        "voice": "vo_adv_1251001_023"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這麼說來，送咖啡？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n我並不記得我有做那樣的委託喔……？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是妳的孫女委託我們的喵。",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n她說想讓奶奶喝到這個咖啡。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "咦？",
        "unit_id": 611,
        "voice": "vo_adv_1251001_025"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那孩子嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呵呵，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那還真令人開心呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n她有記住我喜歡咖啡嗎……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呵呵呵。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯喵！",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也請妳一起享用鯛魚燒……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "喵──♪",
        "unit_id": 1713,
        "voice": "vo_adv_1251001_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂、",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂，你！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個鯛魚燒不是你的！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且熱呼呼的鯛魚燒",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對有貓舌的你來說……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "白",
        "words": "舔舔。",
        "unit_id": 1713,
        "voice": "vo_adv_1251001_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……很正常地在舔喵。",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難不成……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊啊！？",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不管是鯛魚燒還是咖啡，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n都已經冷掉了喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "奶奶，",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對不起喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呵呵，",
        "unit_id": 611,
        "voice": "vo_adv_1251001_033"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "別在意。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "謝謝你們還特地到這種地方來啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那我去拿錢，等等喔。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯喵……！",
        "unit_id": 125111,
        "voice": "vo_adv_1251001_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n生意人的自尊不允許我",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "供應這樣的咖啡和鯛魚燒喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
