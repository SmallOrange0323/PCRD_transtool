[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是在詭異的光芒中，{player}做了一個神奇的夢。"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好久不見──！",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "　最近還好嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我為了一路努力至今的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n特地帶了個獎品給你哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "獎品就是，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「夢」哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是我為了你特地創造的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一場美妙絕倫的「夢」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一臉擔心的樣子？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n相信我好嗎！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夢裡所見的「那裡」的世界，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的是一個很棒的地方哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟「那裡」再怎麼說……",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是你的故鄉嘛☆",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "把那些你曾經，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在故鄉體會過的事件，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓現在的你，再體會一次哦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過雖說是故鄉，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對喪失記憶的你來說應該一點頭緒也沒有吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以「那裡」，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是個你既沒見過也沒聽過的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不可思議的地方呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但是你啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對那件事是不會抱有任何疑問才對哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於待在「那邊」這件事本身，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你應該能夠認為是理所當然，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就儘管放心，享受這場夢吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1900999_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見囉～♪",
        "unit_id": 190011
    }
]