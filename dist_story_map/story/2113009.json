    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "原來如此個頭啦！",
        "unit_id": 191616,
        "voice": "vo_adv_2113009_078"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我堅決反對！",
        "unit_id": 191616
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我才不要跟那些傢伙聯手呢！",
