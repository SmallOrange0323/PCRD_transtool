[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊。",
        "unit_id": 105913,
        "voice": "vo_adv_2007003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您不要亂動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "～……♪",
        "unit_id": 105913,
        "voice": "vo_adv_2007003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經準備好行李等等了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "隨時都可以出發囉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也準備好囉！",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來……小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每天早上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳都像這樣替他換衣服打理外貌嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可以嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2007003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "照顧好主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就是在下的使命♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是沒有不可以啦～",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但如果照顧的太過無微不至，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺他會變成一個廢人呢，真讓人擔心。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像小嬰兒似的。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不對，應該說跟王公貴族一樣呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可不可以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓我叫你一聲王子大人呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的可以嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇呀～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王子大人～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n果然感覺怪怪的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不要這樣叫比較好？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？不行嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呿呿～明明就給人家取了一個「貪吃佩可」的小名耶。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也想喊大家的小名嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來。",
        "unit_id": 105913,
        "voice": "vo_adv_2007003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐自己，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不才是正牌的公主大人嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難道平時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身邊沒有侍從替您招呼日常的事務嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼說呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們家的風氣比較率真一些。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小時候，我真的就像掌上明珠一樣被養育長大。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但懂事了以後，就對這種作法感到有點厭煩了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而「那男人」……",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜，\n他的態度似乎相當傲慢，還擺出國王的架子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但並非只要裝模作樣",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能算是王族了對吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n大家聚在這，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是準備要出門嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n正準備要去找尋，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之前提到那占卜師的下落。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但似乎是他所認識的人物，",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以說不定很輕易的就能見上一面了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}你的人脈，依舊是不可思議的廣呢……",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果有什麼消息的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也請通知我一聲。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟是住在同個屋簷下的交情呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就讓我們一同向前邁進吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好。",
        "unit_id": 105913,
        "voice": "vo_adv_2007003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也正準備出趟門嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n因為一連串的事件，必須與【哞哞自衛隊】，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n和【王宮騎士團】開會唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真讓人提不起勁啊～",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n若回來遲了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n孩子們又要發脾氣了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不管是大量破壞魔法，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是有關牧場再建的事呀……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可一點也不用擔心沒事情可以討論呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n明明沒有任何薪水",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還得耗費這些時間，真讓人開心不起來呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且感覺光是討論一個問題，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就又會衍生出兩、三個新煩惱唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "加上好像又發生了些什麼事的樣子，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n包括被抓到牢裡的克莉絲提娜給逃獄之類的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因此【王宮騎士團】，\n現在似乎也是一團亂的模樣。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說是絕對不可能被逃獄的監牢，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但發現時，克莉絲提娜早已經消失的無影無蹤了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚呃！？",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然讓那人給逃獄了嗎……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽說抓到她了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才安了不少心的說。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也是呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎、真是的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是一波未平一波又起呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還是讓我們一件一件事來解決吧，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟，這也是為了打造孩子們安穩和平的未來嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為此就是兩肋插刀都在所不惜呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這裡若有什麼新消息，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不會忘記和你們共享的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就麻煩妳囉～。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但話又說回來……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "反倒是我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總是受到【咲戀育幼院】的照顧呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係嗎。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然都到了這個田地了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不用太在意唷，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正本來就有空房間呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過老實說，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果能繳一下房租就好了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且不管是妳、{player}、還是可可蘿，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n似乎都處在這場風暴的中心呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n先確保你們的安全，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一定會有其意義。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為有這層考量，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以你們也不用感謝我們。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咲戀真是有話就會直說的人呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我很喜歡唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～……",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但如果因為我的關係，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓育幼院被捲進了什麼大麻煩，就真的太抱歉了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要說麻煩的話，從很早以前就被捲進去搞得一蹋糊塗啦。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但畢竟還有父親大人派遣來的護衛做警備，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果不是太嚴重的事情，也不太需要擔心吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "若真的出了什麼萬一，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也準備了可以讓孩子們即刻進行避難的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然是違禁品就是了。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n之前拜託了父親大人，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請他設置了隨時都能發動的空間移轉魔方陣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以說是有萬全準備了唷。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然依舊不能大意，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過只要是為了孩子們的安全，凡事都得盡心盡力才行呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟這就是【咲戀育幼院】存在的意義啊。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "空間移轉……",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是什麼來著？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像在哪裡有聽過耶？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是能和其他的場所空間連接，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一瞬間便能讓人移動到遠處的魔法唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然在這家中設置的魔方陣，有使用次數上的限制，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但還是足以讓孩子們到安全的地方避難。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為現在，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "王宮正全面禁止使用這種魔法……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n若在自家中設置了這種東西被人家給知道了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可就出事了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "關於這件事還希望你們口風緊一點呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那個魔方陣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n能夠決定要瞬間移動到什麼地方嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若善加利用的話……",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不就能瞬間飛到尤絲蒂亞娜在王宮之中的所在地，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後兩三下把他解決掉嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～……",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可能有點難度呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟移轉魔法只能在固定的地方間移動而已。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "且王宮在魔法的防衛方法上也下了不少功夫，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n光是想移轉到內部就是天方夜譚囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "況且本來就是種高等的魔法。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能夠正確的施使的人，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在這個世上可能用一隻手就能數得出來也說不定呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這次所設置的魔方陣，",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也是費了好一番功夫才入手的唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟父親大人，就算是對親生女兒也照樣要收錢的……",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然因為是父女少算了利息，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但也算是和父親大人借上了一筆錢呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_2007003_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n本院，可是本來就有財政上的困難了啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果順利地能夠重回公主的身分，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一定不會忘記為【咲戀育幼院】提供金援唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因此嘛……",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不趕緊將自己的地位給奪回來不行囉。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家再一塊加把勁吧！",
        "unit_id": 105812,
        "voice": "vo_adv_2007003_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n耶",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔～☆",
        "unit_id": 105812
    }
]