[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "手裡拿著神祕書本、來到【哞哞自衛隊】公會小屋的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}──"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "接下來",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "穿這件。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "放過我吧公主。",
        "unit_id": 104311,
        "voice": "vo_adv_9002010_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不是說好只穿一件嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家有說",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那種話嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說不定是因為真琴",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "太可愛了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以人家才忘記了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再說就算不是我也沒關係吧，",
        "unit_id": 104311,
        "voice": "vo_adv_9002010_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那邊不也剛好有個人在嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "給我等一下。",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是在說我嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說的也是呢。",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n霞要不要也",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "偶爾試穿看看",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可愛的洋裝呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可愛的洋裝我已經穿得太多了呢。",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不好意思，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這次就容我婉拒了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_9002010_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我倒是沒見妳穿過",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像是公主一樣輕飄飄的衣服呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦！？",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "糟了，",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "腦中立刻浮現出魔法少女的裝扮了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯！",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是這樣！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說的好呢助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因為我覺得日常的服裝是最可愛的唷！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……嗯、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼時候來的？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "糟糕了！",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說起來",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生來的日子呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "慘了，",
        "unit_id": 104311,
        "voice": "vo_adv_9002010_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "完全忘記了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "已經準備完成了吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊，",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在大概在香織的房間。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我去看一下吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "手忙腳亂的",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真不好意思呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "稍等一下唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨──呵！",
        "unit_id": 101711,
        "voice": "vo_adv_9002010_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我拿過來了唷，",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "公會長。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝妳們",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "兩位。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請將你手上的那本書",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "借給人家。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把這個這樣～",
        "unit_id": 101011,
        "voice": "vo_adv_9002010_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可愛的書本完成了呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下一個收件人也已經記錄好了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一路小心。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可不要繞去奇怪的地方啊。",
        "unit_id": 104311,
        "voice": "vo_adv_9002010_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請小心",
        "unit_id": 101411,
        "voice": "vo_adv_9002010_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不要迷路了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "加油嘿──！",
        "unit_id": 101711,
        "voice": "vo_adv_9002010_021"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【哞哞自衛隊】目送中離去的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n邁步出發前往下一個目的地。"
    }
]