[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來如此……",
        "unit_id": 101411,
        "voice": "vo_adv_5012101_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你的前輩被捲入了",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n『好像會一直捲入危險事件』",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的這種事件裡。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這個事件，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳希望拜託我這個偵探來解決",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、",
        "unit_id": 105511,
        "voice": "vo_adv_5012101_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n再這樣下去前輩會有危險，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "卻沒有人願意相信我……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "能拜託的",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只有偵探小姐您了！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先告訴我事情的原委吧。",
        "unit_id": 101411,
        "voice": "vo_adv_5012101_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n從頭開始全部告訴我吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就在鎮上所舉辦的馬車競賽",
        "unit_id": 105511,
        "voice": "vo_adv_5012101_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "才剛公開的時候……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n外出去吃午餐的前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "遇到了建造中的房屋木材",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "突然倒下。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一開始還以為是偶發事件，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但意外不斷發生……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一大早在前輩的面前",
        "unit_id": 105511,
        "voice": "vo_adv_5012101_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "遇到黑貓路過，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "午餐時",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "則是定食上",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n被漏放了醬料，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "下午在打工的地方差點把錢吃掉，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "然後晚上",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n在回家的路上，幫助了迷路的孩子，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那真是超帥的……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 101411,
        "voice": "vo_adv_5012101_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你講到中間已經不算是事件了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n到最後",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "單純變成妳在抒發感想而已嘛……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，等等。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n監視了一整天，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那不就是個跟蹤……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我的事現在不重要啦！",
        "unit_id": 105511,
        "voice": "vo_adv_5012101_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也想過原因，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但完全想不通……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "偵探小姐的話一定知道原因吧……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵……",
        "unit_id": 101411,
        "voice": "vo_adv_5012101_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "身為偵探的我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "立刻就明白事件的解決方式喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n早晚都出門，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "白天和下午則在外面店家，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一眼似乎看不出這些場所的共通點",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但其實是有共通點的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都是離開了家門！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "離、",
        "unit_id": 105511,
        "voice": "vo_adv_5012101_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "離開家門……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也就是說，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果一整天都不出門，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n一～直在家裡的話，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就會很安全呢！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不愧是偵探小姐！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那我快去和前輩說～～！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未、霞",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5012101_009"
    },
    {
        "type": "dialogue",
        "name": "步未、霞",
        "words": "「王都的名偵探　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未、霞",
        "words": "嘆息的追緝者（跟蹤狂）」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天又",
        "unit_id": 101411,
        "voice": "vo_adv_5012101_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解決一個難解事件了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要人們的心裡存在黑暗，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事件就會不斷上演。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n即使如此我還是要奮力一戰……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是個偵探呀♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦……",
        "unit_id": 105511,
        "voice": "vo_adv_5012101_011"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "仔細想想，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我是希望前輩不要",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n再被捲入事件，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣沒有解決根本的問題啊……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "偵、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "偵探小姐！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "　我想解決的",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不是這個啦～～！！",
        "unit_id": 105511
    }
]