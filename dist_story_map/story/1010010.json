    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您就先在沙發那坐一會兒吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "——蛋糕切成這樣應該就沒問題了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "剩下的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是把茶準備好……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗯！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_024"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n因為",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我長大要當公主，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n然後和王子殿下結婚的嘛～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然這是早就心裡有數的事情了……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n畢竟王子先生是很棒的人呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不只是我們這的孩子們，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其他人",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也不會放著不管嘛……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……忌妒小孩子也不是辦法呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是趕緊到王子先生的身邊……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……咦！？",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您是什麼時候！？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓您久等了真是不好意思，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這邊馬上就把茶和蛋糕端過去，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還請您稍待一下呢～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼了？王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那樣子緊盯著人家的臉看……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……討、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "討厭。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您這樣盯著看，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會不好意思的呀～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這是，那個……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是切蛋糕之前，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
