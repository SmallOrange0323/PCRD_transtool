    {
        "type": "dialogue",
        "name": "旁白",
        "words": "包含了對平時的感謝之意，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真步打算為了{player}舉辦一場下午茶會。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因此立刻著手開始在公會小屋內準備了起來。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "茶和點心就放在這邊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "準備完成～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然能和王子先生兩人一起喝下午茶，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來今天將會是最棒的一天呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "玄關傳來了聲響……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該不會，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是王子先生來了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣的話得去迎接他才行呀～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "吶吶，王子殿下！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_003"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n不要只是摸摸人家的頭，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "也抱抱我嘛～♪",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n我要公主抱～♪",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不只是王子先生而已，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有其他客人呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我、",
        "unit_id": 413,
        "voice": "vo_adv_1010010_005"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我們擅自就進來了真的很抱歉。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我們正好",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "在玄關和王子殿下碰了個正著，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n然後跟在打算進來的王子殿下後頭，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這孩子也一起跑了進來……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們的公會小屋",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是來者不拒的，所以沒關係唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "記得沒錯，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您是那天迷路的女孩子的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "母親對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "當時，",
        "unit_id": 413,
        "voice": "vo_adv_1010010_007"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真的非常感謝您的幫忙。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n今天是",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "專程想來道個謝。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "大姐姐！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_008"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "　王子殿下！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n謝謝你們！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不用這樣，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還請別這麼客氣。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那也是咱們",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "【哞哞自衛隊】的職責嘛♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "啊，",
        "unit_id": 413,
        "voice": "vo_adv_1010010_010"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這個是我們烤的蛋糕。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n若不介意的話，請和【哞哞自衛隊】的各位，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "還有王子殿下一塊嘗嘗看吧。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我也有幫忙唷！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_011"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "厲害吧厲害吧～♪",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的很厲害呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "蛋糕就讓我們在下午茶的時候好好享用了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "那麼，",
        "unit_id": 413,
        "voice": "vo_adv_1010010_013"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我們也差不多……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我不要～！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_014"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n我要和王子殿下在一起～！",
