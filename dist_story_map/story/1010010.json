    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真是的，",
        "unit_id": 413,
        "voice": "vo_adv_1010010_015"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n妳這樣子給王子殿下添麻煩是不行的喔？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生真的很受女孩子們的歡迎呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "小妹妹，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳也喜歡上",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗯！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_017"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n因為",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我長大要當公主，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n然後和王子殿下結婚的嘛～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_018"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "妳又在說這種話了……",
        "unit_id": 413,
        "voice": "vo_adv_1010010_019"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "妳這樣子給人家添麻煩是不行的喔？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n好了，我們要回去了唷。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真步小姐，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真的非常謝謝您。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "王子殿下～！",
        "unit_id": 415,
        "voice": "vo_adv_1010010_020"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n你一定要等到我當上公主唷～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "隨時都歡迎妳們再來喔～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那麼，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家就先去把這塊蛋糕切一切了，",
