        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒有那回事唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家就和平常沒兩樣呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總之，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我沒事，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您就在那兒稍待一下……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……呀啊！？",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您這麼突然抱住人家是怎麼了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還被摸摸頭了呀～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家已經",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "16歲了啦～！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像這種事，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對我這年齡的人做的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您說之前，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您也有讓人家做過類似的事情嗎……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果是讓人家來做的話自然是沒什麼關係，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但若是像您一樣的男性的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該說是會很不好意思嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家並不是討厭這樣唷……！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您可以繼續嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……王子先生的手，",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好溫暖呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "簡直",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就像是母親大人的手一樣呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……能夠像這樣",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n和誰撒嬌，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經好久沒有過了呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被男性做了這樣的事情，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n果然",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有點不好意思……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是真想一直像這樣",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和王子先生撒嬌呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "託、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "託王子先生的福，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家打起精神來了呢～",
