        "voice": "vo_adv_1010010_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為什麼人家心裡想的事情會……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n該不會，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的尾巴和臉上全表現出來了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人、",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家沒事了唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家才不是那種撒嬌鬼的嘛……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
