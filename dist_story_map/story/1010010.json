    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是太任性也不好嘛……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊嗚嗚……",
        "unit_id": 101011,
        "voice": "vo_adv_1010010_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生的手",
