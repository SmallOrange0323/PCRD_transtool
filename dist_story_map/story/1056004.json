    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "原來不是變態啊……",
        "unit_id": 1,
        "voice": "vo_adv_1056004_041"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "太好了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣一來你的誤會也解開了。",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_042"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來剩這些貓……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀呀，該怎麼辦呢……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "咦？",
        "unit_id": 1331,
        "voice": "vo_adv_1056004_043"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "大姐頭？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳好！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "流夏大姐頭！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是你啊……",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_044"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不准叫我大姐頭。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "抱歉，",
        "unit_id": 1331,
        "voice": "vo_adv_1056004_045"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "一不小心就……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "嘿嘿嘿。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～你問他是誰？",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_046"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "之前我遇到他在做壞事，把他訓了一頓以後，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就混熟了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "大姐頭，",
        "unit_id": 1331,
        "voice": "vo_adv_1056004_047"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "有什麼煩心事嗎？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就說不准叫我大姐頭……",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_048"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉，算了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你能不能",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "幫我替這些貓咪找飼主啊？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我家不是魚商嗎？",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_049"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n怕牠們會打商品的主意，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒辦法養。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不然在找到飼主之前，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "先寄放你那裡也行。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "既然是大姐頭的吩咐，",
        "unit_id": 1331,
        "voice": "vo_adv_1056004_050"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我會全力幫忙！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你明明知道還故意這樣叫是吧……",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_051"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "算了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n最好是能找到",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有人願意全部收養呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我去找死黨，問看看有沒有人可以養！",
        "unit_id": 1331,
        "voice": "vo_adv_1056004_052"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我也會請他們問認識的人，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n不用擔心！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝啦。",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_053"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n……不過，如果是他們的話應該能馬上找到吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之事情圓滿落幕。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你也辛苦了。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過你還真了不起啊，",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_054"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n事發突然你卻願意來幫我的忙，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n被人誤會了也毫不在意。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦……",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_055"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這年頭這種人已經不多了呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n願意這麼為了助人而採取行動。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你真是個了不起的男人！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "下次到商店街的時候，記得來我店裡露個臉。",
        "unit_id": 105631,
        "voice": "vo_adv_1056004_056"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我家的招牌商品可以算你便宜喔。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n……今天謝謝你啦。",
        "unit_id": 105631
    },
