        "voice": "vo_adv_1056004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她也是一個人。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總有一天會遇到無法獨自跨越的難關。",
