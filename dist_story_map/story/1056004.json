        "voice": "vo_adv_1056004_063"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也是。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n沒想到竟然會做夢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
