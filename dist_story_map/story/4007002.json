        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在蘭德索爾搶奪食物對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是沒有食物的話，我就",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不對，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蘭德索爾就完蛋了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能辦到的事情就得去做啊！",
        "unit_id": 105812,
        "voice": "vo_adv_4007002_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請讓我去吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然我很想說",
        "unit_id": 190811,
        "voice": "vo_adv_4007002_038"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果是貪吃佩可小姐的話",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "或許可以……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但是要操控戰鬥機，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "需要兩個飛行員才行……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………那就沒辦法了。",
        "unit_id": 106012,
        "voice": "vo_adv_4007002_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n和貪吃佩可一樣強壯的傢伙，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可不是那麼容易找到的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不可以放棄！　",
        "unit_id": 1,
        "voice": "vo_adv_4007002_040"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳們說的我都聽到了！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個聲音是……！！",
        "unit_id": 105913,
        "voice": "vo_adv_4007002_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道是……！！",
        "unit_id": 105812,
        "voice": "vo_adv_4007002_042"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是我啦！！",
        "unit_id": 105211,
        "voice": "vo_adv_4007002_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………是誰？",
        "unit_id": 106012,
        "voice": "vo_adv_4007002_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只聽聲音聽不出來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是莉瑪，",
        "unit_id": 105211,
        "voice": "vo_adv_4007002_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪啦！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我來和貪吃佩可一起",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "搭乘戰鬥機！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "莉瑪……",
        "unit_id": 106012,
        "voice": "vo_adv_4007002_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然妳確實也很強壯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個圓盤",
        "unit_id": 105211,
        "voice": "vo_adv_4007002_047"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "把我特地留下來準備享用的蘋果",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "全部拿走了！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不可原諒！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果能報仇的話，我想去報仇！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "莉瑪……！！　",
        "unit_id": 105812,
        "voice": "vo_adv_4007002_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是食物被奪走的怨恨吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我懂的！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也懂哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們就徹底消除怨恨吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "到宇宙去，",
        "unit_id": 105211,
        "voice": "vo_adv_4007002_049"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "搶回我們的蘋果！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "九死一生的危機出現了一線曙光。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾的命運就這麼交給了這兩位美麗的少女。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106012,
        "voice": "vo_adv_4007002_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們兩個……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒把我給忘掉了吧？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "記得嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要救回的不是食材，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我才對吧！？",
        "unit_id": 106012
    }
]