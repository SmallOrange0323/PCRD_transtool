    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與霸瞳皇帝戰鬥而造成破壞的街頭在重建後的某日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}正賣力做著送貨的打工。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好了快點，",
        "unit_id": 711,
        "voice": "vo_adv_1047009_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "來這邊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算你這麼說……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我只是在搬行李，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n什、",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼事都沒做啊……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "那",
        "unit_id": 711,
        "voice": "vo_adv_1047009_002"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "你為什麼要東張西望？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "這、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_003"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "這是、",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "因為、",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那個……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "幫、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_004"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "幫幫我！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我遇到了一點麻煩……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "最近",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_005"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我剛到這附近開店，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "所以不太知道路……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n然後",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "就被說很可疑……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "嗯、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_006"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "嗯……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "話說回來，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我好像在哪裡見過你……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你不就是開店時來幫忙的人嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "幫、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_007"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "幫幫我。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我、那個、很不擅長對付……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "【王宮騎士團】，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n沒辦法好好跟他們說話，所以現在很困擾。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "你們在說什麼悄悄話！",
        "unit_id": 711,
        "voice": "vo_adv_1047009_008"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "對、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_009"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "對不起。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "但、",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "但是我真的沒有做什麼壞事……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "知道了知道了。",
        "unit_id": 711,
        "voice": "vo_adv_1047009_010"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n到騎士團據點後我再問個清楚。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n聽好了，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "抵抗的話我可不排除使用武力喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "原來你在這裡啊，",
        "unit_id": 1,
        "voice": "vo_adv_1047009_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "少年。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "這次又是誰……",
        "unit_id": 711,
        "voice": "vo_adv_1047009_012"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團長！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "之前",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剛加入我們的新人團員，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "是的！",
        "unit_id": 711,
        "voice": "vo_adv_1047009_014"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "我在巡邏的時候",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n看到了可疑人物，所以……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……希望你",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "稍微跟我說明一下事情經過。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……原來如此。",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的話",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就不需要特別帶回去問話了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "但、",
        "unit_id": 711,
        "voice": "vo_adv_1047009_017"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "但是……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這間店的事情我聽少年說了，",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也確認過他手上的隨身物品，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有什麼問題。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真擔心的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟他一起去店裡就知道了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "是、",
        "unit_id": 711,
        "voice": "vo_adv_1047009_019"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉把你留在這裡。",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_020"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "不、",
        "unit_id": 4911,
        "voice": "vo_adv_1047009_021"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "不會！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那位幫忙的人，也謝謝你！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "下次",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "再麻煩你送貨喔！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "……真抱歉，",
        "unit_id": 711,
        "voice": "vo_adv_1047009_022"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "團長。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "慎重行事並不是壞事。",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "採取過於壓迫的態度",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不太好喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也有些人不信任【王宮騎士團】。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了贏回信任，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們每天都在努力著。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你在對市民偵訊的時候可以更慎重一些。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "是、",
        "unit_id": 711,
        "voice": "vo_adv_1047009_025"
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "是的……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "很抱歉。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "\n保險起見，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "新人王宮騎士",
        "words": "我去看一下那名男子說的店家。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……抱歉啊，",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n沒有你的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可能就會非法逮捕善良市民了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使如此，受到了你的幫助也是不爭的事實。",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n然後……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實我本來正在找少年你。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近，",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "發生了很多事情，都沒有機會好好聊聊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以想說能不能一起吃個飯。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n當然，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也得是少年覺得沒問題的話……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看起來沒問題呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n今天我們都有工作……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也是呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等到下次我休假的時候比較好吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "由我提出邀約卻還要你配合我的時間……",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然很抱歉，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但如果可以的話就太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "最近",
        "unit_id": 104711,
        "voice": "vo_adv_1047009_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "任務本身雖然告了一段落，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但仍是人手不足……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哎呀，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下次再跟你好好聊一聊吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "近期見。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}抵達了和純約定的地點，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但到了約定時間，純卻還沒有出現。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱、",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n剛剛有點忙，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就遲到了……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "噢，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你問我這身裝扮啊……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然今天是休假，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但想說距離約定時間還有一段空檔，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我就做了些工作。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我原本是想換好衣服再過來的，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但後來時間變得不夠充裕，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以就直接過來了。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難得",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "久違地和少年說話，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "本想用更普通的裝扮來的……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因此，拿掉頭盔",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "算是我的誠意，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你要是能這樣想，我會很開心的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "咦？",
        "unit_id": 712,
        "voice": "vo_adv_1047009_037"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "在那裡的是團長嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n在這個地方做什麼……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "咦？",
        "unit_id": 712,
        "voice": "vo_adv_1047009_038"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團、",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "團團團團長和男人在一起！？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n該、",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "該不會，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "是在約會……！？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "也、",
        "unit_id": 712,
        "voice": "vo_adv_1047009_040"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "也是，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不會有這種事呢。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n應該是什麼特殊的任務吧。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n抱歉",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "打擾兩位了……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我先告辭！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……沒想到會被誤會在約會呢。",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年和我……？",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……不行不行，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不可以",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱著奇怪的想法。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……果、",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "果然穿著鎧甲太顯眼了呢。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n快點進去店裡吧，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104712
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼，",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "先讓我好好為上次那件事向你道謝。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝你，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那時真的幫了大忙。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】正在重新編組，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n團內和貴族勾結的問題終於整頓好了。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "目前就連讓還沒受到完整訓練的人才執行任務，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n都仍是人手不足。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大家都很努力……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原本團裡",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就人手不足了，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也明白重新編組的話會變成這樣的狀況……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但也無法放任問題繼續拖沓。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在這個狀況下，",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無法將每個成員訓練到位，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也是沒辦法的事……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說如此，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這也只是藉口呢。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "讓市民感到不安，真的是萬分慚愧。",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正因如此，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我才想避免剛才那種事情發生，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以防造成市民多餘的不安。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "騎士團好不容易能夠發揮應有的作用了，",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但現況真是令人無地自容……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真抱歉，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "忍不住就發了牢騷呢。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還得再請人民忍耐一陣子，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過狀況正在一點一點改善，所以沒問題的。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以少年你也不需要這麼不安……",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_052"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是嗎？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那你在擔心什麼呢？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "！！",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有事能瞞得住少年你呢。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也並不是",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很辛苦。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "明明是為了守護國家行動的，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "回過神來，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "卻發現自己是被利用了。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "比起後悔，",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我曉得自己有更該做的事。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n即使如此，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "腦海裡偶爾還是會浮現這種想法。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……我又說出不重要的話了。",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟你說話就會不小心……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把平常無法說出口的事情說出來。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這種事情",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_058"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "實在無法告訴團員。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正因為如此，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對於看穿我的真實想法、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "並為我感到擔心的少年的存在，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我感到很開心。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣是不是撒嬌過頭了呢？　",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是說，",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_059"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我在想些什麼啊。",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總覺得",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "見到少年就……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_061"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可能是因為今天有點熱……",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊！？",
        "unit_id": 104712,
        "voice": "vo_adv_1047009_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼了，",
