        "words": "……不過，",
        "unit_id": 104611,
        "voice": "vo_adv_1046010_058"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "至少要把這些聽進去喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "前方的道路，",
        "unit_id": 104611,
        "voice": "vo_adv_1046010_059"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也就是世界的陰暗面。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一旦失敗就是坐牢，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n還可能被惡人記恨，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "威脅到人身安全也說不定喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即便如此……",
        "unit_id": 104611,
        "voice": "vo_adv_1046010_060"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你還是堅持要幫我喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……謝謝你喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046010_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n和{player}相遇，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的是太好了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好啦～",
        "unit_id": 104611,
        "voice": "vo_adv_1046010_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "給我做好覺悟喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這群壞蛋們～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "幻影貓",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要來懲罰你們了喵～～！！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聲音響徹於蘭德索爾郊外……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雖然在街上行人耳裡聽來只是醉漢在胡亂大叫，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但對珠希來說，這是她新的決心，以及承載著堅固羈絆的誓言。"
    }
