        "type": "dialogue",
        "name": "商人１",
        "words": "更限制了物流量……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n都是因為他們，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "根本沒辦法好好做生意。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……惡心疵聯合商會？",
