    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "怎麼了？",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n妳們突然呆住不動了喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好美的彩燈呢──",
        "unit_id": 119311,
        "voice": "vo_adv_5080323_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對啊……",
        "unit_id": 119211,
        "voice": "vo_adv_5080323_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n太有聖誕節的華麗氣氛啦……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳們還在那邊悠哉地欣賞什麼！",
        "unit_id": 119911,
        "voice": "vo_adv_5080323_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n快點打倒那傢伙！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子要報布丁的仇喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……啊！？",
        "unit_id": 119311,
        "voice": "vo_adv_5080323_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不行不行。",
        "unit_id": 119211,
        "voice": "vo_adv_5080323_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我竟然被迷惑了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "宮子，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要報",
        "unit_id": 119911,
        "voice": "vo_adv_5080323_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁的仇喲～～～～！！",
        "unit_id": 119911
    }
