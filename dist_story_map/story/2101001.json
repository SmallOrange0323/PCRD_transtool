[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "企圖對世界進行變革的霸瞳皇帝，被一名無名英雄給打倒了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被所有人忘卻了的少女‧貪吃佩可\n在取回了她的名字『尤絲蒂亞娜』後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同時也取回了王女的身分……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而在那一天過後，時間輾轉過了一個月。"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "母親、少女",
        "words": "呀啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_2101001_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911,
        "voice": "vo_adv_2101001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一塊上吧！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "――哈啊！",
        "unit_id": 105911,
        "voice": "vo_adv_2101001_002"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "嘎哦哦哦哦……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯、",
        "unit_id": 211,
        "voice": "vo_adv_2101001_003"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n謝謝你們，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大哥哥、",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大姐姐！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "非、",
        "unit_id": 1511,
        "voice": "vo_adv_2101001_004"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "非常感謝你們……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n感謝你們……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……竟然就連距離蘭德索爾並未有多遠的道路上，",
        "unit_id": 105911,
        "voice": "vo_adv_2101001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都仍還有魔物於此處徘徊。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【王宮騎士團】的人手不足之問題仍然相當嚴重呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……兩位。",
        "unit_id": 105911,
        "voice": "vo_adv_2101001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭德索爾的冒險者，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n目前則是在運送貨物的工作歸途上。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若兩位不介意，",
        "unit_id": 105911,
        "voice": "vo_adv_2101001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要一同搭乘馬車呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n運客的業者，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人會負責向對方解釋清楚的……",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "……真的非常謝謝你們的幫忙。",
        "unit_id": 1511,
        "voice": "vo_adv_2101001_008"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n我們",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "因為前陣子那場魔物的騷動，所以離開了蘭德索爾，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "並且在位於鄉下的故鄉中暫住了一陣子……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "「城裡已經安全了，",
        "unit_id": 1511,
        "voice": "vo_adv_2101001_009"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "重建也很順利。」",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n因為丈夫在送來的信中這樣寫道。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n所以我才帶著孩子，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "正在回去的路上。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是辛苦您了。",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過還請您安心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正如您丈夫在信中所述，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n當下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭德索爾已重回了和平，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且在重建上也充滿了生氣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下與在下的主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最近這陣子",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也在幫忙重建的相關事宜。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今日，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是向那熟識的牧場",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遞送著食品的訂單",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與資材費用……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哥哥，",
        "unit_id": 211,
        "voice": "vo_adv_2101001_012"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們來玩吧～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "嘿、",
        "unit_id": 1511,
        "voice": "vo_adv_2101001_013"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "不行……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "對不起唷，這位哥哥。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n這孩子就是活潑了一點……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "來玩吧，",
        "unit_id": 211,
        "voice": "vo_adv_2101001_014"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "來玩吧～♪",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的身體還行嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您才經歷了場戰鬥，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該還很疲憊才……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……從與霸瞳皇帝決戰的那天算起，",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "約莫過了一個月。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人所受的傷，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本該是全都治好了才是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……然而從那一日以來，",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人似乎就偶爾",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會有劇烈暈眩的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而似乎是為了不讓在下擔心，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以都不怎麼表現出來就是了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "話說回來，",
        "unit_id": 1511,
        "voice": "vo_adv_2101001_019"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "你們還真是了不起呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "明明還沒有多少年紀，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "就能像這樣兩個人一起出來工作了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人僅是",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了賺取自己的生活費，因此才會承接工作而已……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而依舊非常感謝您的稱讚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前陣子與主人一同暫時叨擾的",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【咲戀育幼院】，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最近也為了收容失去雙親的孩子們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以面臨著相當的困境。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了回報她們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此才會需要一些資金。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您畢竟才受過腹部被開了個大洞如此這般的重傷……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您還是該好好安養歇息才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n資金的方面，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就由在下來負責賺取便是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您方才戰鬥的模樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是變得相當可靠了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明知道得讓主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好保重身體的才是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而能與主人兩人這樣同行，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻也同時感受到了無比的喜悅……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……但",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不知為何。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於在下的心中……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是有種難以言喻的不安逐漸蔓延。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下最喜愛的，",
        "unit_id": 105913,
        "voice": "vo_adv_2101001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那帶給人溫暖又溫柔的主人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎會就此離去……",
        "unit_id": 105913
    },
