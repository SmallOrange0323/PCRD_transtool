[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人和伊莉亞她們兩人",
        "unit_id": 111611,
        "voice": "vo_adv_6029106_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n都準備了我意想不到的禮物。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然有時候會覺得她們做得有點過火……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，我也不會輸的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_6029106_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的意思是",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我只要照自己的方式來就好了……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說的也是呢！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要用自己的禮物讓大家感到開心才行，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n否則的話當聖誕老人就沒有意義了！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_6029106_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然你也這麼想嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她們的禮物充滿了玩心和驚喜，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的很厲害。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果真的有那樣的聖誕老人的話，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定會很開心。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 111611,
        "voice": "vo_adv_6029106_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果沒有這樣的衝勁，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是沒辦法帶給大家快樂的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好～",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我還要更努力！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請你繼續為我加油打氣！",
        "unit_id": 111611
    }
]