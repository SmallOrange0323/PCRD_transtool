[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "103300101"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小朋友們，快過來集合啦～！",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n牧場的姊姊來啦～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "【伊麗莎白牧場】產地直銷，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "美味肉品和乳酪跳樓大拍賣的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天早上牛的狀態很好，擠了很多牛奶，",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "營養滿分又美味的啦～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小朋友們可以免費拿餅乾唷～",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不管是爸爸媽媽、阿公阿嬤，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還是小狗小貓和魔物，走過路過千萬不要錯過☆",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "特別附贈我最私房的相聲表演～！",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好吃又好笑，大家都會笑嘻嘻的啦～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊，是牛姐姐！",
        "unit_id": 111,
        "voice": "vo_adv_1033001_005"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "姐姐～♪",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇？你這樣飛撲過來很危險的啦，",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n攤車……架子會倒的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我好不容易搬來的商品，可是會報銷的呀？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣我不就只好直接收攤，回家哭哭了嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且大家也會看不到好笑的相聲、吃不到好吃的東西，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雞飛蛋打兩頭空的啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "連雞都跑光光的話，那就真的搞笑的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對吧～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊哈哈☆\n",
        "unit_id": 111,
        "voice": "vo_adv_1033001_009"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳在說什麼呀！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "哎呀，不可以打擾姐姐工作。",
        "unit_id": 411,
        "voice": "vo_adv_1033001_010"
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "不好意思～可以給我一些肉嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "\n可以直接跟生產者買肉，果然還是最讓人放心呢～♪",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "歡迎歡迎，請隨意參觀選購！",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "參觀選購好心情也GOGO啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這位媽媽也吃個點心，甜蜜在心啦♪",
        "unit_id": 103311
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯，",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天我的狀況很好的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雙關語的靈感源源不絕！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "表演相聲給【伊麗莎白牧場】的大家看，\n大家反應都很冷淡……",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最近都有點失去自信了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然莉瑪莉瑪會禮貌地笑一下，\n但鈴鈴都「嘿」地笑一聲，好像把我當笨蛋一樣。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞也不知道為什麼對搞笑的要求很高，總是不滿意。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真希望找到更了解我搞笑藝術的夥伴。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n一個人說相聲也有極限～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說真的最想要的是搭檔啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在牧場的時候，可以和牛搭檔說相聲。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但也不可能",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n把牛從山上帶來蘭德索爾的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴對這種事配合度不高。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞的身體不好，不能勉強她……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪長得像魔物，到城鎮來就會造成騷動。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這也不通，那也不通～\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，「不通」和「噗通」發音很接近，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "下次有機會可以用一下。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，今天靈感一個一個跑出來的啦～♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯？\n那邊那位老哥，怎麼從剛剛就一直安靜地站在那裡啊。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有什麼想買的嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n心動不如馬上行動，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對吧～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？迷路了嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我常常推著攤車在鎮上移動，路很熟的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我來告訴老哥怎麼到目的地啊♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～老哥想去哪裡呀？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n跟我買「乳酪」的話，我就把地圖拿出來告訴老哥「路囉」！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "開開玩笑的啦～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔喔，反應真好……",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "竟然有人給我這種前所未有的好反應啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n真害羞的啦～！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很好笑嗎？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好，我要把剛剛的雙關語當作招牌哏的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等一下，我先寫下來……",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也順便",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n畫地圖告訴老哥想去的地方怎麼走啊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "另外再送老哥一些乳酪，謝謝老哥那麼捧場～♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦、咦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不好笑喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，「乳酪」和「路囉」發音很像吧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是雙關語的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚嗚，竟然呆住了……",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我可是忍下這份恥辱，說明了哏在哪裡耶……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑藝人的路果然很艱辛的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為、為什麼現在才捧腹大笑啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，知道意思之後覺得很好笑？",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈……老哥的反應好到",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好像有生以來第一次聽到雙關語的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥真的超配合的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但好像是個生面孔呢，是這個城鎮的人嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔……名叫{player}啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "以後還請多多光顧啊♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，我叫真陽啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n是山上那座",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n【伊麗莎白牧場】的經營者啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我有時候會到城鎮來，像這樣賣賣乳製品。",
        "unit_id": 103311,
        "voice": "vo_adv_1033001_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為蘭德索爾的人們",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n覺得鎮上很安全，所以不大愛到鎮外去～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我只好到城鎮來賣東西啦。",
