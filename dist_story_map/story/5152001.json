        "type": "dialogue",
        "name": "昴",
        "words": "然而過去曾一同作戰的夥伴也在此時現身，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "是嗎。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n這展開也太熱血了吧！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "喔～",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_031"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "兄弟。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n你過得好嗎？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不過這種事光看就知道了呢。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "咦？",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_032"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你該不會，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "忘記我了？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "也是，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "上次我的臉幾乎都被長袍遮住了。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "仔細想想，那根本就是可疑人物嘛……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我啊，是我！",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_033"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "菜月昴！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n遇合有緣，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "天地無垠的預言者！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n我們可是乾杯結拜為兄弟的交情對吧～？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "所以說將美味食物吃個精光的公會",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_034"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "【美食殿堂】\n這次的目標，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "是那隻巨大鯨魚嗎？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "無法想像那會是幾人份的分量呢～",
        "unit_id": 2612,
        "voice": "vo_adv_5152001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常可惜，",
        "unit_id": 107511,
        "voice": "vo_adv_5152001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是收到來自公會管理協會的討伐委託呢～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該死的眼鏡女要我們來調查",
        "unit_id": 107811,
        "voice": "vo_adv_5152001_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n出沒在海邊的巨大黑影的真面目，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果就是這樣！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可沒聽說會是這麼巨大的鯨魚啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 107611,
        "voice": "vo_adv_5152001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「看我三兩下結束討伐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剩下的時間就優雅地享受海水浴！」",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本明明這麼地興致勃勃，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在是太令人同情了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "喂喂，",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_039"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "你說這話也太見外了。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n能在這裡遇到也是某種緣分。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n我也還欠兄弟你們人情呢──",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "讓我們",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_040"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "也來幫忙吧。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是啊，",
        "unit_id": 131911,
        "voice": "vo_adv_5152001_041"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "說的沒錯，昴。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "貪吃佩可，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也讓我們一起戰鬥吧。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣可以嗎……？",
        "unit_id": 107511,
        "voice": "vo_adv_5152001_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果有愛蜜莉雅你們在，當然是很讓人安心……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但你們難得來海邊……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請交給我處理！",
        "unit_id": 132111,
        "voice": "vo_adv_5152001_043"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "有這樣的魔物在，",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴和姊姊都不能安心遊玩。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "難得的休息時間都要白白浪費了呢。",
        "unit_id": 109812,
        "voice": "vo_adv_5152001_044"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我當然",
        "unit_id": 2612,
        "voice": "vo_adv_5152001_045"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "不會放過危害莉雅安寧的傢伙哦。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的",
        "unit_id": 107511,
        "voice": "vo_adv_5152001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很謝謝大家！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼就讓我們",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再度攜手吧！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "再一次請多指教囉，",
        "unit_id": 131911,
        "voice": "vo_adv_5152001_047"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "貪吃佩可！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "好啊弟兄們！",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_048"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n讓牠瞧瞧",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我們的力量吧！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆、雷姆。",
        "unit_id": 109812,
        "voice": "vo_adv_5152001_049"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真不可思議。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n作戰時最沒用的巴魯斯，",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n為什麼會那麼自信滿滿呢。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊、姊姊。",
        "unit_id": 132111,
        "voice": "vo_adv_5152001_050"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴一定是想透過那樣率先發出高聲吶喊，",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n鼓舞雷姆我們的士氣。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n看看他高舉向天的拳頭，",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆的心正為之震撼……！",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就不能稍微讓我耍帥一下嗎！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_051"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n雖然我",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "在戰場上的確可以說是沒有用處啦！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "好啦好啦，",
        "unit_id": 2612,
        "voice": "vo_adv_5152001_052"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "就算沒用也別哭別哭。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "昴你啊，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "只要待著就能炒熱氣氛這點我覺得很好喔？",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "這根本就是把我當成職場邊緣人，或者說是海岸邊緣的我了吧！",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_053"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "可惡！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "會熱烈地追著我的就只有魔獸嗎！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "……不對，等等。",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_054"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n雖然不確定這個世界的魔物吃不吃這招，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "但是那傢伙和白鯨這麼像。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n搞不好我可以作為誘餌……！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼首先，",
        "unit_id": 107511,
        "voice": "vo_adv_5152001_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們先來分享關於那隻白島鯨的資訊……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "好。",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_056"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "由我來當誘餌，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "大家就趁這個空檔攻擊……！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "啊，",
        "unit_id": 131911,
        "voice": "vo_adv_5152001_057"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "等等，昴！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n不可以一個人擅自衝出去……！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "沒問題，",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_058"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我不會做那種危險的事啦！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n只要牠會追著我的味道跟過來就好。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "最糟糕的情況，我就在牠面前晃晃，引起牠的注意……！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下。",
        "unit_id": 107511,
        "voice": "vo_adv_5152001_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那隻白島鯨有特殊能力──！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "咦？",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_060"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n感覺我剛剛",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "好像聽到了特殊能力之類的危險字眼……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "白鯨",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 18511
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "嗚哇！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152001_061"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n怎麼忽然變狂暴了……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "牠剛剛，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "看了我嗎……？",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n牠果然有聞到什麼──",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "巴魯斯！",
        "unit_id": 109812,
        "voice": "vo_adv_5152001_062"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你在發什麼呆！",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那可是敵人的面前啊！",
        "unit_id": 109812
    },
    {
