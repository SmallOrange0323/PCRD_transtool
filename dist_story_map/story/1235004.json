    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴",
        "unit_id": 190011,
        "voice": "vo_adv_1235004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可能跟一般的孩子不太一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而你也試圖",
