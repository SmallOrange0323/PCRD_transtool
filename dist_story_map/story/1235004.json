    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我很期待",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在夢中與你再次相見喔♪",
