        "voice": "vo_adv_1235004_063"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個話題到此為止。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n既然是夢，我覺得我應該在夢裡做了很多天真的事。",
        "unit_id": 102611
