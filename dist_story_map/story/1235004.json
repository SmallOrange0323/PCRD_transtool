    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望你們能一起度過開心的兩人時光就好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴也害羞了起來，",
        "unit_id": 190011,
        "voice": "vo_adv_1235004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的心情似乎有傳達給她了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n透過這次的夢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我非～常了解你們之間的羈絆了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n保持這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這邊的生活也要努力加油呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1235004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "差不多是該起床的時間了。",
