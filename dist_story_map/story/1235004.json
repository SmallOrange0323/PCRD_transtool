[
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利地通關恐怖的蘭祭限定版遊戲後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴跟{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨著萬聖節期間的結束，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人也要回復以往的日常生活了。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然是第一次參加蘭祭，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但玩得真開心呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且也成功買到，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然超級可怕，但也超稀有的限定版遊戲了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "想做的都做到了，實在沒什麼好抱怨的呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可以的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為了繼續沉浸在這個餘韻之中，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n接下來幾週……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "接下來幾個月都想耍廢度過啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你有聽到",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我剛剛說的話嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我明明就說我想耍廢度過了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你為什麼還要把從公會寄來的信",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "拿過來啊～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也只是在做你的工作而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n抱怨你也太不講理了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "給我吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯哼嗯哼……",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "上面寫，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n關於協助蘭祭警衛一事，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "請提交報告書至【哞哞自衛隊】。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也就是說還不急，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先放一陣子也無所謂吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你說我在工作上也要多投入一點？",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是說啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來寫吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "發生了這麼多麻煩，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺會寫很長呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "像這樣，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "回到原本的工作崗位後，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就會覺得，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "蘭祭真的結束了啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你問我覺得寂寞嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對呀，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可能吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這次的蘭祭真的很好玩啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這一定是因為，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有你一起在我身邊的緣故。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然有遇到麻煩，但也成功解決了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且我們兩個不但一起逛了展示會，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n還一起玩了遊戲。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要是，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也覺得很開心的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要不要明年也……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇，",
        "unit_id": 102611,
        "voice": "vo_adv_1235004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼！？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這道光，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我記得之前也……！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦～",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這下打倒的活動BOSS數量",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "達到100隻了呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然離完成任務，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還差200隻就是了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你在說什麼啊～",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們才剛開始四小時而已喔？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個遊戲的萬聖節限時活動獎勵，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我絕對要全部拿到。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "簡單算一下，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再努力八小時就能結束囉？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n兩個人一起合作的話，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "早上前就可以完成了啦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "喂──",
        "unit_id": 1,
        "voice": "vo_adv_1235004_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "快點～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n點心要沒了啦～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "等等我啦～！",
        "unit_id": 1,
        "voice": "vo_adv_1235004_016"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n你跑得那麼急，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "會跌倒喔～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從剛剛開始，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "外面就很吵耶？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n發生什麼了嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……萬聖節？",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也有收到宣傳單呢，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我記得是從今天開始在城鎮裡舉辦活動吧？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我想說反正我不會去，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以就忘得一乾二淨了呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再說了～",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家真的知道萬聖節是什麼",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才慶祝的嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n明明就是國外的節慶，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼要在日本這麼盛大地慶祝啊？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……只是單純好玩？",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然這個回答說了跟沒說一樣，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過也許大部分的慶典就都是這樣的吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大家聚在一起，大肆慶祝，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺也很有趣的樣子。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也還好啦。",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要參加的話，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該要在到處都是人的地方走來走去吧？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這對室內派的我來說，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是無緣的節慶啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～不用啦，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不用啦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要參加的話，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該要在到處都是人的地方走來走去吧？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n感覺就是個很難讓室內派的我",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "盡情享受的活動呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也覺得",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該會很有趣吧～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我覺得我很有可能會面臨",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在中途放棄的窘境呢……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "糟糕，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "死掉了……！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n已經連續死三次了耶～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這BOSS明明也沒有那麼強啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我連續失誤很稀奇？",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "快馬會失去平衡，摔到地上，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "懶人也會失去平衡，摔到床下嘛。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且也有可能是熬夜熬太久，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒辦法集中精神了也說不定。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先暫停BOSS戰，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "回城鎮裡一下吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n遊戲裡的城鎮好像也換成萬聖節活動風格的了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n一起走走吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……咦～",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還蠻講究的嘛。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n啊，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經有人穿著活動獎勵的限定服裝走來走去了！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好好喔～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好想要喔～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "商店也全部變成萬聖節風格的了，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n跟平常的感覺完全不一樣。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這次的活動",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "蠻用心的嘛。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也這麼覺得嗎？",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……就是說啊～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "光是散步就覺得很開心呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該怎麼說。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是能像這樣，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "走在真正的城鎮中，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "應該會很開心吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n等、",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "等等，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你丟下遙控器是要去哪裡啊！？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們還沒做完",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所有的活動任務耶～！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……跑掉了。",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看他好像很慌張的樣子，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是想起了什麼",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "非在今天買到不可的東西嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真拿他沒辦法。",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然效率變低了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "暫時就一個人繼續做任務吧～",
        "unit_id": 102631
    },
    {
        "type": "background",
        "background": "510092"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……都已經晚上了說。",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就是因為一個人玩很沒效率，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才到這傢伙的家裡來的耶。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣子活動完全進展不了嘛～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難道他是因為刷關卡太累",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才逃跑的嗎……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要是真的是這樣的話，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在我完成所有活動任務前，他都不准離開這個房間一步……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你在",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "「我回來了」什麼啦～！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你到底跑去哪買東西了？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我一～直一個人在刷活動喔～！？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你說很難買到想要的東西？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說來說去，你到底是跑去買什麼啊？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個是……",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "萬聖節的服裝跟",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "點心組合包？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為有萬聖節慶典的關係，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不用說點心了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n連好多服裝都賣完了，而你也因此很困擾？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好～的，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道你動作很慢的原因了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n可是，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你到底為什麼要去買這些東西啊？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難不成",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你現在要去參加慶典嗎？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你說要在這個房間過萬聖節……",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦～！？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n怎麼這麼突然……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不懂啦！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要是在家裡辦，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就跟人多沒關係了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也不用到處走來走去？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "照理來說是這樣沒錯啦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……難道",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是因為我白天說的那些莫名其妙的話？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那種話",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明不用在意也無所謂的。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你……",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "等，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要把衣服塞過來啦！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我知道了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我去換！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會好好換上的啦！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "相對地，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你也要老實換裝喔？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可不要只有我",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "穿上奇怪的裝扮喔？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿咻，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿咻……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "超大件的……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了沒關係，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我換好囉～",
        "unit_id": 102631
    },
    {
        "type": "still",
        "still": "123500401"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我還在想你買了什麼衣服呢～",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n原來是超正宗",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "經典魔女感的衣服啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "尺寸也不對，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "手都被袖子蓋住了啦～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你跟店員說是要給高中生年紀左右的女生穿的？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不用特別講這種事嘛……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的心白白受到傷害了啦。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n再說了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也覺得",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不適合做這種打扮。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……很適合？",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_048"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很可愛？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "反正也只有",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}你會看到，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是你滿意的話那就沒差了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是說，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你是扮木乃伊？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n明明我的是很講究的魔女裝扮，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你感覺就只是個受重傷的人一樣。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……買了我的衣服之後",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_050"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "錢就不夠了？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你自己的變裝，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是用家裡的繃帶隨便繞繞而已？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明不用做到這個程度的……",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_051"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……這樣啊。",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_052"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你是這樣",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看待我的啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實呀，",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_053"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也是很想去看看",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "萬聖節慶典的。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那個，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝你。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯！",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_054"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天真的",
        "unit_id": 102631,
        "voice": "vo_adv_1235004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝你。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n希望未來，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們也能兩個人去城鎮裡的萬聖節慶典……",
        "unit_id": 102631
    },
