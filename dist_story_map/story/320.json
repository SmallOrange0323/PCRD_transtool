[
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "【美食殿堂】的大家，",
        "unit_id": 190811,
        "voice": "vo_adv_0000320_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "久等了！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "意思是……？",
        "unit_id": 105811,
        "voice": "vo_adv_0000320_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "終於？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　終於嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n花凜小姐！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒錯！",
        "unit_id": 190811,
        "voice": "vo_adv_0000320_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這次因為一些原因",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "加上大規模準備的關係很辛苦，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但事情終於有了進展唷！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等貪吃佩可！",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「終於……」",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "指的是什麼！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n給我好好說明得讓人聽得懂啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 105811,
        "voice": "vo_adv_0000320_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還沒好好說明呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次我們【美食殿堂】決定要接受來自",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【公會管理協會】的長期派遣調查的委託。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "派、",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "派遣調查？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對♪",
        "unit_id": 105811,
        "voice": "vo_adv_0000320_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐會幫我們安排好出國方式和物資。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n地圖和目前已知魔物的情報，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有各種保險的手續都幫我們準備好了唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在，",
        "unit_id": 190811,
        "voice": "vo_adv_0000320_007"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "以【公會管理協會】為中心，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n正在進行著於阿斯特賴亞大陸有段距離的另一個大陸的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n預想移居開墾開發計畫。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次要麻煩大家的是，",
        "unit_id": 190811,
        "voice": "vo_adv_0000320_008"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一邊支援已經在進行工作",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "的先遣隊，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n一邊調查與報告尚未進行開墾的部分。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不管怎麼說，",
        "unit_id": 190811,
        "voice": "vo_adv_0000320_009"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "都是幾乎未開墾過的大陸。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "魔物也頻繁出沒，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "開墾計畫也不斷碰到困難的樣子呢。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "未開發地區？",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　會出現很多魔物？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然要去那麼不文明的地方，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n恕我無法奉陪！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果有像大家",
        "unit_id": 190811,
        "voice": "vo_adv_0000320_011"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一樣優秀的公會願意幫我們調查的話，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n作為【公會管理協會】也會很放心。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要徹底無視我！",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說都說了是長期，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們根本什麼都沒準備啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可不會疏忽掉這種事！",
        "unit_id": 105811,
        "voice": "vo_adv_0000320_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我已經拜託花凜小姐，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把大家的行李也都",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n裝載在那邊的船了♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冒險之門已經近在眼前囉♪",
        "unit_id": 105811,
        "voice": "vo_adv_0000320_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿還有{player}！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼要準備得那麼齊全啊！",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你這傢伙總是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭討厭討厭～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_0000320_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關於幾乎未開墾過的這件事，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會不會讓主人",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再遇到危險呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您覺得如何呢，",
        "unit_id": 105911,
        "voice": "vo_adv_0000320_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟貪吃佩可小姐和凱留小姐一起去探險",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本身就很有趣的樣子，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然在下沒問題，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但讓主人遇到危險的話就……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯呢。",
        "unit_id": 105911,
        "voice": "vo_adv_0000320_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論出現了什麼樣的魔物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都不會讓主人受到任何一點傷害。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼你",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明平常都只會發呆，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就這種時候這麼積極啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011,
        "voice": "vo_adv_0000320_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話也只能去了，那未開墾過的新大陸！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過相對的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可要給我滿滿的報酬唷！",
        "unit_id": 106011
    }
]