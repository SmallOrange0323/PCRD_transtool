[
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 113811,
        "voice": "vo_adv_5048322_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是什麼……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "長、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "長得跟我還有茜里一模一樣耶！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "到底是從哪裡冒出來的呀……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這也是受到弓箭失控的影響嗎？",
        "unit_id": 113711,
        "voice": "vo_adv_5048322_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不管怎麼說，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我從它們身上感受不到什麼善意，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們快點收拾掉它們吧，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就、",
        "unit_id": 113811,
        "voice": "vo_adv_5048322_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就算妳那麼說，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "看見自己出現在眼前的感覺",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好不舒服啊……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那雙眼睛",
        "unit_id": 113811,
        "voice": "vo_adv_5048322_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "彷彿能夠看穿我們的一切……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真是的，",
        "unit_id": 113711,
        "voice": "vo_adv_5048322_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊你就是太愛操心了。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "確實外表和我們一模一樣，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但也僅止於此呀。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "畢竟它們沒有心，",
        "unit_id": 113711,
        "voice": "vo_adv_5048322_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "肯定是我們兩個比較強呀！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 113811,
        "voice": "vo_adv_5048322_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說得對。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不管再怎麼模仿我們的外貌，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n沒有心的冒牌貨之間",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是萌生不出親姊妹的羈絆的。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "抱歉我剛才說了喪氣話。",
        "unit_id": 113811,
        "voice": "vo_adv_5048322_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就讓它們見識一下",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們無敵羈絆的力量！",
        "unit_id": 113811
    }
]