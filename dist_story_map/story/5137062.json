    {
        "type": "dialogue",
        "name": "常客3",
        "words": "\n天空變得一片紅通通的呀！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "天空？",
        "unit_id": 1,
        "voice": "vo_adv_5137062_039"
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "\n……咦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客1",
        "words": "難不成已經快要天亮了？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "不是那樣的啦。",
        "unit_id": 411,
        "voice": "vo_adv_5137062_040"
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "\n你們幾個是從幾點開始泡在這裡的啊……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊，來得正好。",
        "unit_id": 4911,
        "voice": "vo_adv_5137062_041"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "公所的大姐，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我問一下。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n之前那個被懸賞的魔物，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "應該",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "還沒有被打倒吧？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "是啊，",
        "unit_id": 411,
        "voice": "vo_adv_5137062_042"
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "還沒有呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "都是因為那魔物在這附近亂晃的關係，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "\n害得現在想去蘭德索爾都要費一番工夫……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "常客3",
        "words": "真讓人困擾啊。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "讓人困擾……",
        "unit_id": 135512,
        "voice": "vo_adv_5137062_043"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "如何啊，",
        "unit_id": 4911,
        "voice": "vo_adv_5137062_044"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這位客人。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n既然您對戰鬥本領有自信，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "要不要去試試看打倒那個魔物？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_5137062_045"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好主意！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我就去",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "打倒那個魔物吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這樣也可以獲得懸賞金，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "而且──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有困難的時候，",
        "unit_id": 135512,
        "voice": "vo_adv_5137062_046"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就互相幫助幫助！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈！",
        "unit_id": 135512
    }
]