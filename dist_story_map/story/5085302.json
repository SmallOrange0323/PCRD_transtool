[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺到了比剛才還強的力量……！",
        "unit_id": 121011,
        "voice": "vo_adv_5085302_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不只那樣，",
        "unit_id": 121111,
        "voice": "vo_adv_5085302_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們的力量",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是……！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "成長與進化的可能性。",
        "unit_id": 121211,
        "voice": "vo_adv_5085302_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n想必",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「那一側的少年」",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會無止境地變強下去。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要阻止那個……",
        "unit_id": 121211,
        "voice": "vo_adv_5085302_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只有靠「現在的少年」壓制它，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並且表明自己的意志。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……你的表情，",
        "unit_id": 121211,
        "voice": "vo_adv_5085302_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是在說「我知道」吧。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "非常好。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那就是過去我曾相信過",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並寄託願望的……",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不。",
        "unit_id": 121211,
        "voice": "vo_adv_5085302_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "與那時候比起來，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「現在的少年」肯定更帥氣。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿♪",
        "unit_id": 121011,
        "voice": "vo_adv_5085302_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得沒錯！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你一天比一天更強壯、",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "更帥氣喔☆",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是嗎～？",
        "unit_id": 121111,
        "voice": "vo_adv_5085302_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們會不會誇過頭啦～？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這傢伙",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到現在吃飯時還讓可蘿仔幫他擦嘴巴，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一有機會就啊～地張嘴",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被別人餵飯喔？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不、",
        "unit_id": 121111,
        "voice": "vo_adv_5085302_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過？",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n偶爾……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的是偶爾，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他也不是沒有帥氣的時候，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這我也不是不能認同……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且現在也是……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看你都讓我說了什麼！",
        "unit_id": 121111,
        "voice": "vo_adv_5085302_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好啦，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是要戰鬥了嗎！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快上吧！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "藉此",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我們瞧瞧吧。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──帥氣的你！",
        "unit_id": 121111,
        "voice": "vo_adv_5085302_010"
    }
]