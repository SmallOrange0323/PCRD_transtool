[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}遇見心情很好的初音。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啦啦啦～♪",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n小～栞，我馬上就過去，等我一下喔～☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哎呀呀？ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還以為是誰，原來是你！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是巧遇！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 我看起來心情很好？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～果然看得出來呀～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其實，我接下來要去牧場找我妹妹！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為很久沒見了，我現在很興奮呢～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "她叫小栞，是非常可愛的妹妹♪",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真想快點見到她呢～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你也有事要去牧場？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，一起去吧――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，你腳邊很危險喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n有水坑……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，跌倒了……",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為有泥濘，變得容易滑倒呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你沒事吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "若在平時我也許能用超能力幫你……",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，今天不行不行！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "若使用超能力後睡著的話，",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就沒辦法和小栞見面了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今天就算你陷入危險，我也做不了什麼，所以要小心喔～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，出發前往牧～場！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_010"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇啊啊啊啊！",
        "unit_id": 111,
        "voice": "vo_adv_1012003_011"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n好可怕啊！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "孩子被狗嚇壞了！？ 我必須救他！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……但是不能使用超能力……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你被狗咬了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒、沒事吧！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n快點治療……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗚哇啊啊！ 救救我！",
        "unit_id": 1411,
        "voice": "vo_adv_1012003_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這次是被貓追的人……",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃，貓！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n他怕貓啊？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "呼咻―――！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這次是被貓抓傷了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不、不要緊吧！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "無賴（小）",
        "words": "嗚喔喔喔喔！ ",
        "unit_id": 811,
        "voice": "vo_adv_1012003_017"
    },
    {
        "type": "dialogue",
        "name": "無賴（小）",
        "words": "誰、誰來救我―――！！！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "鸚鵡",
        "words": "啾啾啾～♪",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這次是被鸚鵡追的人……呃，",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦咦！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "鸚鵡",
        "words": "啾――――！",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你、你被鸚鵡啄了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_019"
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "喂，搞啥啊！ 想打架嗎！？",
        "unit_id": 911,
        "voice": "vo_adv_1012003_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇哇！ 這次又是什麼！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_021"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "藉口就留到監獄再聽吧！",
        "unit_id": 711,
        "voice": "vo_adv_1012003_022"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n跟我走吧！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "有本事的話，就來硬的試試啊！",
        "unit_id": 911,
        "voice": "vo_adv_1012003_023"
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "放馬過來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可、可怕的人和騎士團的人正在爭執……？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然想幫忙……可是不能使用超能力……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "嗚哇！",
        "unit_id": 911,
        "voice": "vo_adv_1012003_025"
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "你這傢伙在做什麼！ 放開我！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "喔，",
        "unit_id": 711,
        "voice": "vo_adv_1012003_026"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "感謝你的幫忙！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n再幫我壓制這傢伙一下！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我馬上綁住他的手腳！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "可惡！",
        "unit_id": 911,
        "voice": "vo_adv_1012003_027"
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "\n不要妨礙我！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇～",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你好嚴重呢……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你受了不少傷呢……",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n還會痛嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我其實也很想幫忙，",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但是若使用超能力，就會變得想睡……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，你好厲害呢。",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "明明沒有超能力，卻馬上去幫忙……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我太感動了啊～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "該怎麼說呢，非常――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "噫欸欸欸！",
        "unit_id": 511,
        "voice": "vo_adv_1012003_033"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n來人啊――！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊啊！ 魔物正在襲擊老爺爺！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喂――！ 住手！！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "壞魔物就用超能力來打跑！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嘿──噫！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好了！ 這樣就解決了喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……啊！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然還是無法置之不理，而使用了……超能力……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n怎麼辦……變得好想睡……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": " 睡得好飽～！！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃，不行不行！ 不能睡著啊！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_040"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎怎怎、怎麼辦！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n天色已經暗了，見不到小栞了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？ 這裡是牧場？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇！ ",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n為什麼你會揹著我！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦……因為我睡著了，所以你揹著我來這裡嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這樣啊……",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_043"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～，謝謝！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，到小栞那裡還有一小段路，",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_044"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以就麻煩你揹我到那裡吧♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸～！ 小氣──！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_045"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n再揹一下就好了嘛──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好了好了，出──發！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇～，謝謝♪",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_046"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，你的背好溫暖呢。",
        "unit_id": 101211
    },
    {
        "type": "still",
        "still": "101200301"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小――栞！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_047"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我來找妳了喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊……妳來了啊？",
        "unit_id": 103811,
        "voice": "vo_adv_1012003_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n謝謝！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好久不見了呢！",
        "unit_id": 103811,
        "voice": "vo_adv_1012003_049"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我好開心～☆",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！ 姐姐也很開心喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_050"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，我原本也不曉得今天能不能來呢……",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_051"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為途中我使用了超能力而睡著了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n多虧了他帶我來喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞，小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_052"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n他很厲害喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n他總是不斷幫助我♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1012003_053"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n謝謝你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n連姊姊也給你添麻煩了呢……",
        "unit_id": 103811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "…………嗯嗯嗯？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_054"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 什麼什麼！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_055"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你們兩人認識嗎！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯。",
        "unit_id": 103811,
        "voice": "vo_adv_1012003_056"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我也總是受到",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這個人的許多幫忙。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "…………呣～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_057"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": " 總覺得無法接受！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "接受……？",
        "unit_id": 103811,
        "voice": "vo_adv_1012003_058"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊，妳怎麼了？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、我不知道！",
        "unit_id": 101211,
        "voice": "vo_adv_1012003_059"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總之我覺得心情鬱悶！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你這個笨蛋～！",
        "unit_id": 101211
    }
]