[
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 113811,
        "voice": "vo_adv_5048308_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這股不尋常的魔力",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是怎麼回事……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "意思是它到剛才為止都沒有展現出真本事嗎？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "面對這種強敵，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們該如何是好……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……姊姊，",
        "unit_id": 113711,
        "voice": "vo_adv_5048308_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳會怕嗎？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我怕得要命。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n如果是我自己孤軍奮戰的話，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "搞不好早就逃跑了……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但是，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我不會逃避的。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n因為我並不是一個人呀。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我說得沒錯吧？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里……",
        "unit_id": 113811,
        "voice": "vo_adv_5048308_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳說得對。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "優秀的妹妹",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就在我身邊嘛。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n無論面對什麼樣的困難，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只要兩人同心協力就能夠克服……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是一定會克服！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，",
        "unit_id": 113711,
        "voice": "vo_adv_5048308_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這才是我最喜歡的姐姐嘛♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們走，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓它見識見識",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所向披靡雙胞胎的真本事！",
        "unit_id": 113711
    }
]