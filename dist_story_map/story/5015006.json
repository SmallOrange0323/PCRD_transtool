        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "惡代官……",
        "unit_id": 11411,
        "voice": "vo_adv_5015006_032"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "要拉腰帶……",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n腰帶……",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "腰……",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "帶…………",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "吼喔喔喔喔喔喔喔喔！！！",
        "unit_id": 11412,
        "voice": "vo_adv_5015006_033"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "惡、",
        "unit_id": 105511,
        "voice": "vo_adv_5015006_034"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "惡代官的身體",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "產生變化了！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n那個身體是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "在土產店看過的",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "機關人偶！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……身體強韌到用刀鞘攻擊無效，",
        "unit_id": 105311,
        "voice": "vo_adv_5015006_035"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "連劍都沒用的",
        "unit_id": 105311
