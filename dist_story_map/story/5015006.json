        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原因是這個啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來是仿造惡代官做出的機關人偶幻化成了魔物，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n模仿了惡代官的行動……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以才模仿惡代官的特技，",
        "unit_id": 105311,
        "voice": "vo_adv_5015006_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要讓它行動變得緩慢……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真不愧是妮諾！　",
