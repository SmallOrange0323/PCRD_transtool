[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}他們離開了露娜之塔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在塔中仍有著"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "低聲交談的細微聲音。"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "走了啊。",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_000"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "呵呵，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "已經看不見他們的身影了。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "…………",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_001"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "很",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_002"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "寂寞。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n你，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "會這麼覺得嗎。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "不會。",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_003"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "……這麼說或許是騙人的，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "但畢竟本來就連萬分之一的可能性都沒有。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "能夠遇見另一個我，",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_004"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "還有她。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n光是這樣就夠了。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n對於由記憶碎片構成的我來說，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "已經別無所求。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "謝謝妳，",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_005"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "米奈娃。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "被收集起的、",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_006"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你的記憶碎片們。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "沒想到，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "竟能像這樣",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "復原出「你」。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我原本，",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_007"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "沒有",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "這麼做的理由和必要。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……然而。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "一定是因為──",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "一直接觸她的願望。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "所以就產生感情了吧。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "雖說是跟塔的Bug產生共鳴，",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_008"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "但就如同奇蹟一般……",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "不。",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_009"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "果然──",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "還是彌補不了0.1％的缺口。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "你跟原本的他並不完全相同，",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_010"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n跟現在的他既是相同，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "卻也不同。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "雖然細微到光憑資訊，",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_011"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "或電子訊號都測量不出來，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n但",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "確實存在著",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "絕對性的差異。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "所以厄莉絲才選了他吧。",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_012"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n她看出了",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "我終究只是他的複製品。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "既然她自己主動去尋求",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_013"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "與他共度的未知未來，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n我想為她高興。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "還有，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "目送他們離開的你也是。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "製作物擁有自我，",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_014"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "仿造品擁有願望，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n我認為十分值得愛惜──",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "另一個{player}。",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_015"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n我想向你，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "提出一個請求。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "能請你守護這座塔嗎？",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_016"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "守護對那兩人來說，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "相當於「祕密基地」的這個地方。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我總有一天",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_017"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "會離開這裡。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n因為接下來，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我有必須要做的事。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "……嗯，",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_018"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "當然可以。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n我也知道",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "米奈娃在防備的事情。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "這裡很長一段時間，",
        "unit_id": 15811,
        "voice": "vo_adv_7030004_019"
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "是以連製作者都沒預料到的方式在成長的，",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n所以必須有人看守才行。",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "騎士先生？",
        "words": "\n……對吧？",
        "unit_id": 15811
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "謝謝你。",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_020"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n願你",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "於萬象之塔下，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "受到天象的加護。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "並且。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "願你獲得太陽與星星的祝福。",
        "unit_id": 191112,
        "voice": "vo_adv_7030004_021"
    }
]