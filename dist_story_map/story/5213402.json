        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "太作弊了啦、太作弊了啦～！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "梅莉莎太可憐了啦～！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才不是作弊。",
        "unit_id": 138312,
        "voice": "vo_adv_5213402_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且……",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "梅莉莎小姐，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對這個國家出手的人，是妳。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以──",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "將我的信念寄託於這把劍上。",
        "unit_id": 138312,
        "voice": "vo_adv_5213402_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會粉碎妳的野心。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "哼……",
        "unit_id": 20013,
        "voice": "vo_adv_5213402_003"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "妳的天真，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "已經不見了嘛。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "真是的，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "煩死了。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "好",
        "unit_id": 20013,
        "voice": "vo_adv_5213402_004"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "啦好啦，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "是我輸了。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n尤絲──",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "不對。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "……貪吃佩可。",
        "unit_id": 20013,
        "voice": "vo_adv_5213402_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
