    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "加以協助，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許就能以有利的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「屬性之力」來攻略「深域」了。",
        "unit_id": 105911
    },
    {
