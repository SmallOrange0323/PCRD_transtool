        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有，",
        "unit_id": 105811,
        "voice": "vo_adv_0000070_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個結晶是",
        "unit_id": 105811
