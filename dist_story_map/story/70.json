    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各地的「深域」",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會有各種有效的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「屬性之力」喔！",
        "unit_id": 105811
    },
