        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說來就來，",
        "unit_id": 105811,
        "voice": "vo_adv_0000070_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺是很別具風味的魔物啊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "馬上",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把它做成美食吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要上囉，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公主突襲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": " ──吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可的攻擊完全沒用……！？",
        "unit_id": 106011,
        "voice": "vo_adv_0000070_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "相當強啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看招，",
        "unit_id": 106011
