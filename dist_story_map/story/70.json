    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下，",
        "unit_id": 106011,
        "voice": "vo_adv_0000070_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼妳正流著口水興奮啊！",
