        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我滿腦子都是魔物料理的事，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一不小心就忘記了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然如此，",
        "unit_id": 105911,
        "voice": "vo_adv_0000070_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能也可以重新審視一次編組呢。",
        "unit_id": 105911
