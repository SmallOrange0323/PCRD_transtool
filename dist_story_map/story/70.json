    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是為了魔物料理，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而是為了尋寶而來的喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": " ──吼喔喔喔喔喔！",
        "unit_id": 1611
    },
