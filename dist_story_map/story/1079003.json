    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我還是第一次見到這麼大顆的星星啊喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺星星就要落下了一般呢喵……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好大的流星啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然我知道其實距離還很遠，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但看起來就像是要落在這附近一樣呢喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對了，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就像那塊大岩石一樣……",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_046"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那塊大岩石！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "和地圖所標記的大岩石長的一模一樣呀喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們去那塊岩石下挖挖看吧喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_047"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_048"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這難道就是……！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "太棒了！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_049"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是寶箱呢喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "終於找到了喵—！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "箱子裡面是……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_050"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是貝殼，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有一封信？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_051"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這些貝殼、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "全部都是貓的形狀呢喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "信上寫著……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_052"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「這是這片海岸最美麗的地方哦。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要和哥哥永遠幸福快樂呦！」",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這麼一段話呢喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這些貝殼，",
