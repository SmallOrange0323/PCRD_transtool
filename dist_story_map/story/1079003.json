    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天{player}\n也到珠希賣鯛魚燒的攤位來幫忙了。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，一直以來都謝謝你了喵～♪",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我特別",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把鯛魚燒這香脆的薄片部分留給你呢喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來來，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你別客氣，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把嘴張開啊……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "鯛魚燒的姐姐～！",
        "unit_id": 211,
        "voice": "vo_adv_1079003_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是之前我送過妳貝殼的小女孩啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是來買鯛魚燒的喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 211,
        "voice": "vo_adv_1079003_004"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不過還有一件事，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳看這個！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這張紙是做什麼的喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "欸嘿嘿，",
        "unit_id": 211,
        "voice": "vo_adv_1079003_006"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是張藏寶圖哦～♪",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "藏、",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "藏寶圖！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是貨真價實的藏寶圖喵！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 211,
        "voice": "vo_adv_1079003_008"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這是當作謝禮送給妳的哦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "快和那位哥哥",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "一起去找找看吧！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是為何啊喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為",
        "unit_id": 211,
        "voice": "vo_adv_1079003_010"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你們兩人",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不是一對情侶嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "一定要讓哥哥好好跟著才行哦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我我我、",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "才不是什麼情侶呀喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們看起來像喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還真是有點害羞呢喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "很危險的，",
        "unit_id": 211,
        "voice": "vo_adv_1079003_013"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你們一定要兩個人一起去找才可以哦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那麼再見囉～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然這樣，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "店門一關我們就出發去探險尋寶吧喵！",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然現在是挺暗的，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過地圖上寫著是夜晚才能找到的寶物，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們去找找看吧喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還只限定夜晚，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "或許是真的有什麼東西也喵不定……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過那孩子不像是會為了惡作劇這麼投注心力啊喵～",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之我們就過去看看嘛喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "搞不好",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "會是個很厲害的寶藏也說不定呢喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我看看，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "首先朝東方前進吧喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n按照標記所示的位置……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "寶藏似乎是在海邊的樣子呢喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我在海邊這裡並沒有看見什麼類似的東西呀喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n難道是藏在沙灘下面了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沿著海岸走過去",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "或許可以發現什麼也說不定喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們繼續前進看看喵～",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然在海岸附近這邊發現了洞窟……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n真是不該走進洞裡啊喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "應該說，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們是不是迷路了喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說起來這地圖也看不出洞窟中的路線喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這這這、",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這該怎麼辦喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是不擺脫這困境的話……！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且這裡，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼暗岩石坑坑窪窪的……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這地方感覺一整個毛骨悚然喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你快看那邊！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那座岩洞怎麼看起來像一張臉呀喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵～開玩笑的……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_028"
    },
    {
        "type": "still",
        "still": "107900301"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵啊！？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "別因為害怕就抓著我的尾巴喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n剛才只是開了點玩笑喵～！",
        "unit_id": 107911
    },
    {
        "type": "still",
        "still": "107900302"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦欸！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "剛才，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你有沒有聽見女人在哭泣的聲音喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且我腳底下似乎有什麼東西呀喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我好像踩到什麼了喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "話說，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你幹嘛趁亂抱住人家啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "抱上去的人是我啊喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n真是抱歉了喵，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺有點",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可怕啊喵……",
        "unit_id": 107911
    },
    {
        "type": "still",
        "still": "107900303"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哇啊！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我好像被絆倒了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是詛咒啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是洞窟的詛咒啊喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了防止人接近寶藏，",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n謎之力量在阻礙著我們喵──！",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_036"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "突然覺得好累啊喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那就是",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "洞窟出口了嗎！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快點！",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們快離開這裡喵！",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這裡是，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "瑪爾傑海岸……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒想到居然會和這種地方相通呢喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_040"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼了喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你怎麼指著天空……",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "510272"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵……",
        "unit_id": 107911,
        "voice": "vo_adv_1079003_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "多麼美麗的星空啊喵……！",
        "unit_id": 107911
