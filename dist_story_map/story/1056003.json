[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──這一天，當{player}\n漫無目的地走在街上時，遇見了流夏。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不要太過分了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n自己捅的摟子自己收拾。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "大姐頭，請妳不要這麼說嘛！",
        "unit_id": 811,
        "voice": "vo_adv_1056003_001"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n拜託妳了！拜託！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別叫我大姐頭！",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……什麼拜不拜託的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是丟人現眼，快走……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦，小哥。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你最近過得好嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太好了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……喔，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說這傢伙啊？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說這傢伙啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我之前稍微修理過這傢伙。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n他好像遇到了有點麻煩的事。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不是有點麻煩而已！",
        "unit_id": 811,
        "voice": "vo_adv_1056003_006"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我剛剛也說了，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "再這樣下去，我會被宰了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但是去取對方頭目的性命，",
        "unit_id": 811,
        "voice": "vo_adv_1056003_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n橫豎也是死路一條……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哈哈哈……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好像是",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這傢伙想脫離一個幫派，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那個幫派的老大命令他",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "去暗殺敵對犯罪組織的頭頭。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "都是我不好我欠了老大人情……",
        "unit_id": 811,
        "voice": "vo_adv_1056003_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n他威脅我說，如果拒絕的話，就吃不完兜著走……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可是我已經想金盆洗手，",
        "unit_id": 811,
        "voice": "vo_adv_1056003_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "規規矩矩地過生活！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n托大姐頭的福我已經清醒了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我只能靠妳了，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "大姐頭！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就說不要再叫我大姐頭了！",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……真拿你沒轍。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你告訴我，那個老大人在哪裡。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我直接去找他談。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "大姐頭！",
        "unit_id": 811,
        "voice": "vo_adv_1056003_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝謝妳！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳的大恩大德我一輩子都不會忘記！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這才不是什麼大恩。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我只是不想看到你的屍體而已。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣好嗎？",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也好，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總比一個人去來得放心。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "請多指教，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "……哼哼。",
        "unit_id": 911,
        "voice": "vo_adv_1056003_015"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "那個傢伙。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "自己沒出面也就算了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "竟然敢讓別人代替他過來。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你就是這裡的老大嗎？",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我是流夏。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我在鬧區的魚店裡工作。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "魚店……？",
        "unit_id": 911,
        "voice": "vo_adv_1056003_017"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "哈哈哈哈哈！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "這也太可笑了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就直說了。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你就饒了那傢伙吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他已經不是你的部下了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "……我怎麼可能平白饒過他。",
        "unit_id": 911,
        "voice": "vo_adv_1056003_019"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n如果妳代替他把對方的首級帶來，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "我就饒了他。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊？",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為什麼我得做這種事……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "──那傢伙不是拜託妳幫忙了嗎！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_021"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "既然這樣，妳幫他擦屁股才是合乎道理啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼道理啊？",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還真敢講，分明是你趁人之危……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "不過那傢伙也真是，誰不拜託，",
        "unit_id": 911,
        "voice": "vo_adv_1056003_023"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "卻偏偏去拜託一個魚店女人……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "哼哼哼。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "我就要看！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "妳到底有什麼能耐？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "反正妳會切的也只有魚吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你可不要小看魚店的女人喔。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然你這麼說，那我就做給你看！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "妳要是做得到務必讓我見識一下！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_025"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n反正一介賣魚的不可能辦到吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "妳放心！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_026"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "如果搞砸我會幫妳收屍啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "哈哈哈哈！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……到時被首級嚇到可不關我的事。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "打擾了。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我又搞砸了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "喂，小哥！",
        "unit_id": 811,
        "voice": "vo_adv_1056003_029"
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "大姐她出來囉。太好了呢！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "\n你可以不用再提心吊膽了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "呀哈哈哈！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "抱歉讓你在這裡等。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們走吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "細節等一下邊走邊說。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "──就是這麼一回事，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n最後變成我得代替他去做這件事。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為那傢伙瞧不起我的工作，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我吞不下這口氣就……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖說我天生個性如此，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過這次我真的有好好地反省……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "希望能順利解決",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n他們雙方的對立……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說得也是。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓敵對的雙方自己處理是最好的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是說啊。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_035"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "把毫不相關的人硬捲進來實在太過分了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然要做乾脆讓他們互打……",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_036"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是這個。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "根本不需要弄髒我們自己的手啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要讓雙方頭目碰面，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_037"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來他們就會互相擊潰了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼一來，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_038"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要做的事就只有一樣……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n首先要先找到首領。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著流夏就開始去找敵對組織的首領。\n終於，打聽到那個頭頭經常出沒的地點，\n流夏和{player}一同前往該地點。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……看來那個傢伙就是首領吧。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_039"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你在這兒把風。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我過去囉！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "借一步說話！",
        "unit_id": 105612,
        "voice": "vo_adv_1056003_040"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "妳誰啊！",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_041"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喝！",
        "unit_id": 105612,
        "voice": "vo_adv_1056003_042"
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "唔哇！",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_043"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……成功了呢。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_044"
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "打擾了！",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_045"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "原來是妳……",
        "unit_id": 911,
        "voice": "vo_adv_1056003_046"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "一定是夾著尾巴逃回來了吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "我早就知道──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我把對方的首領帶來囉！",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_047"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n剩下的就讓你們自己去談吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "唔……",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_048"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "妳說什麼！？",
        "unit_id": 911,
        "voice": "vo_adv_1056003_049"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "我可沒要妳把他帶來啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "這裡是……",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_050"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "原來是你搞的鬼！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "\n居然搞這種手段！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "你的組織會怎樣都無所謂了嗎！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "這，這是誤會！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_051"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "……對，對了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "我其實是想和你結盟，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "來壯大彼此的組織！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊！？",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_052"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "什麼～！？",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_053"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "……是，是這樣啊！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "其實我也正在思考著同一件事！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "\n再這樣互相對立下去，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "最後也只是兩敗俱傷！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "是啊是啊！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_054"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "所以說……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "今天這事都是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "那個女人搞的鬼！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "這個女人，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "就是挑撥我們的主嫌！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "原來如此……",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_055"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "搞出這件事的原來就是妳！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "\n妳想阻礙我們聯手壯大組織是吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領的部下",
        "words": "首領！",
        "unit_id": 1011,
        "voice": "vo_adv_1056003_056"
    },
    {
        "type": "dialogue",
        "name": "首領的部下",
        "words": "我們來救你了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "喔！",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_057"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "他們不是敵人！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "我們的敵人是那個女人和小鬼！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "老大，只要打倒這個女人就行了嗎！",
        "unit_id": 811,
        "voice": "vo_adv_1056003_058"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "沒錯！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_059"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "順便連他旁邊的小鬼也一起滅了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "記得把門鎖緊喔……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……哎呀呀。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_060"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來這就是壞人的鬼點子嗎。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真不是什麼好東西。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "笑死人了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥你快逃吧。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_061"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這裡我會想辦法。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……小哥。",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_062"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這種義氣，我喜歡！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那就讓我再借助你的力量吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……哎呀呀，真是的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來我也得拿出真本事",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來回禮才行呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……像你們這種小嘍囉，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_063"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對我而言根本是小意思。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我本來想盡可能和平處理的……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然這樣，我就不管你們有什麼下場囉！",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_064"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想死的傢伙",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "儘管放馬過來！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "怎，怎麼回事！？",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_065"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "這女人怎麼突然氣勢變強了……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "殺氣騰騰的……！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_066"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "喂，妳這傢伙！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n妳到底是什麼人！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "是那傢伙雇來的殺手嗎！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "問我到底是什麼人，",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_067"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我真的只是一個魚店的臨時工啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也順便兼職",
        "unit_id": 105611,
        "voice": "vo_adv_1056003_068"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "暮光流星群的公會長就是了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "……暮、",
        "unit_id": 911,
        "voice": "vo_adv_1056003_069"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "暮光流星群！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n哈哈哈，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "怎麼可能……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "對吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "老大，",
        "unit_id": 811,
        "voice": "vo_adv_1056003_070"
    },
    {
        "type": "dialogue",
        "name": "老大的部下",
        "words": "她剛剛講的該不會是……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "「獨眼惡魔」……",
        "unit_id": 1111,
        "voice": "vo_adv_1056003_071"
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "不僅如此！還有「收藏家」！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "\n以及「破壞者」和「移動龍卷風」幾人所屬的公會，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "首領",
        "words": "這個鎮上最可怕的公會吧……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "但是，公會會長卻完全不在黑社會露面……！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_072"
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "\n聽說她的實力強大到能讓那些傢伙乖乖聽話……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "乖乖聽話？",
        "unit_id": 105612,
        "voice": "vo_adv_1056003_073"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那些傢伙怎麼可能會乖乖聽話呢？",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我只是被她們逼著接下了這個工作而已。",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我到現在……",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "依然只是個普通的賣魚人啊。",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "組織的老大",
        "words": "可惡！",
        "unit_id": 911,
        "voice": "vo_adv_1056003_074"
    },
    {
        "type": "dialogue",
