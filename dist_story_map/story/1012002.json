    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正當{player}要回家時，\n看見正在空中飛的初音。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_000"
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_001"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喂，你看啊。",
        "unit_id": 911,
        "voice": "vo_adv_1012002_002"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "竟然有個女的睡在這裡？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "嘿嘿嘿，總之先搶走她身上值錢的東西，",
        "unit_id": 811,
        "voice": "vo_adv_1012002_003"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "再順便讓我們稍微享受一下吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "啊？ ",
        "unit_id": 911,
        "voice": "vo_adv_1012002_004"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "搞什麼，你這傢伙！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n打算妨礙我們嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喂！",
        "unit_id": 911,
        "voice": "vo_adv_1012002_005"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n在我們說話的時候，那個女的不見了喔！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n她去哪裡了！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "你這傢伙做了什麼嗎？",
        "unit_id": 811,
        "voice": "vo_adv_1012002_006"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n竟敢救走我們的獵物！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "啊，站住！",
        "unit_id": 911,
        "voice": "vo_adv_1012002_007"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n你想逃走嗎！？",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……呼嚕呼嚕……呼嚕呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "什、",
        "unit_id": 711,
        "voice": "vo_adv_1012002_009"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "什麼！？ 有個在皇宮前面睡著的傢伙！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "可疑的傢伙……逮捕她吧！",
        "unit_id": 711,
        "voice": "vo_adv_1012002_010"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "你也是這傢伙的同夥嗎！？ 一起逮捕！",
        "unit_id": 711,
        "voice": "vo_adv_1012002_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要起來還太早了啦。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼嚕呼嚕。",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500202"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……呼嚕呼嚕……呼嚕呼嚕……呼嚕呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_013"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……嗯嗯～？",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n感覺有魔物的聲音～嗯呀嗯呀……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是……家裡不可能會有魔物……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，原來這是夢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那麼，晚安～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在搖晃？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真不好睡啊……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……咕嚕咕嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嗚，好痛苦……無法呼吸……咕嚕咕嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但素豪想睡……呼嚕呼嚕……咕嚕咕嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_018"
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……呼嚕呼嚕……呼嚕呼嚕……呼嚕呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～！ 睡得好飽～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "初音完全恢復了！ 閃亮亮☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？ 這是哪裡？",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為什麼我會在這裡～？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，你也在！",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你好像很想睡……怎麼了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為我邊睡邊飛，你很擔心……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是這樣啊～",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你不眠不休在照顧我呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我有時會在睡夢中不小心使用超能力，",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不知不覺就輕飄飄地飛起來呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為給你添麻煩了，",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我必須為此道歉",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n及感謝你照顧我！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有什麼希望我做的嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我什麼都能為你做喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦～，不要那樣說嘛！",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我會過意不去的！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喂，讓我為你做點什麼嘛～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "只要是我做得到的事，什麼都可以喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n放心交給我吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為我有超能力，大部分的事情――",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_030"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇！ 是、是魔物！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不得了了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，對了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "作為你照顧我的謝禮，這次就讓我幫你吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "用瞬間移動來逃離魔物吧！ 嘿噫！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "到了～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n一瞬間就逃掉了喔！ 很厲害吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "耶～，勝利勝利！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 但是，我們瞬間移動到了未知的洞穴……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你知道出口的方向嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不知道對吧……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我也不知道該往哪走比較好……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，沒――事，沒――事！",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒關係喔～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n只要再用我的超能力移動……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼哇～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……因為使用了瞬間移動，又變得想睡了……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯呀～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對不起喔……晚安……",
        "unit_id": 101211,
        "voice": "vo_adv_1012002_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不管等多久，初音都沒有醒來，\n{player}只好扛著初音，\n拼命地尋找洞穴的出口……"
    }
]