    {
        "type": "dialogue",
        "name": "旁白",
        "words": "競速賽結束以後過了一段時間，參賽者們聚集到神殿"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備進行頒獎典禮。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "胡桃也",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很努力呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來不及幫妳加油。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒關係。",
        "unit_id": 102111,
        "voice": "vo_adv_5031007_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我只是想說如果咲戀媽媽",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "能看到轉播就好了。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n對、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對了，鈴莓姐，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "恭喜妳",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "得到第一名。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝！　",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還是冒冒失失的，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n給大家添了麻煩呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳還在說那個呀？",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話先說在前頭，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也是有很多缺點的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以沒辦法",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在意每個細節唷？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大、",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐的缺點",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是缺點！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是那句話。",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對我來說，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓的缺點也不是缺點唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一直以來，妳知道",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我被妳救了多少次嗎……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也就是說，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我繼續冒冒失失的比較好嗎？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我不是說那樣比較好唷？　",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是要努力改進才行。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "包括冒失和努力在內，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那些全部都是鈴莓妳的一部分，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我希望那樣的鈴莓",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能陪在我身邊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "僅此而已。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大、",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、",
        "unit_id": 102111,
        "voice": "vo_adv_5031007_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也會加油的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當然，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也最喜歡",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來的胡桃了唷？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家一起加油吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "接下來",
        "unit_id": 1,
        "voice": "vo_adv_5031007_011"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "要進行頒獎典禮！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n請各位選手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "到頒獎台周圍集合！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_5031007_012"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "我們請",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "成功取得福氣公會稱號的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "【美食殿堂】的各位",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n來選擇豪華獎勵！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃、",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我要這個，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "精靈樹的――",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "稍等一下。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？　",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個如何？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "「公會小屋家事套組」……",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個是",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非常高級的",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n掃除套組？　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不可以！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "至少要選更吉祥一點的",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n東西吧！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "本來就是",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我給談生意的對象添了麻煩――",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那件事啊，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為妳參加了競速賽，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以談得很順利唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……咦？",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對方說妳之前的冒失行為，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反而讓他感覺很安心呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是鈴莓的冒失",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓生意談成的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說到吉祥，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓妳努力的模樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就已經把好運帶給我",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有育幼院的大家了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸，",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "既、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "既然大小姐這麼說……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可是，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說我帶來好運好像有點太――",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "喂！　",
        "unit_id": 311,
        "voice": "vo_adv_5031007_023"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "就是她！　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "「山神大人的巫女」！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "聽說如果能得到她的加持，",
        "unit_id": 411,
        "voice": "vo_adv_5031007_024"
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "今年一整年的運氣",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "就會提升哦！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這是怎麼一回事！　",
        "unit_id": 1,
        "voice": "vo_adv_5031007_025"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "為了得到鈴莓選手的保佑，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n觀眾們都擠了上來！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n對此",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "神殿的祭司也苦笑……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "不對，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "是很歡迎大家這樣做的樣子！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦咦咦！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我才沒有那種力量啦！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "保佑！　",
        "unit_id": 1,
        "voice": "vo_adv_5031007_027"
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "保佑！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "保佑！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇哇哇哇哇哇哇",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿噗！",
        "unit_id": 112111
    },
    {
        "type": "still",
