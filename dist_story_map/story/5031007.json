    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了慶祝獲勝，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起辦慶功宴吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既、",
        "unit_id": 112011,
        "voice": "vo_adv_5031007_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然這樣，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要不要就用我拿到的這個",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n高級餐廳全餐免費餐券？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "偶爾也想吃不是用魔物做的料理――",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇――！　",
        "unit_id": 111811,
        "voice": "vo_adv_5031007_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這家",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是賣高級魔物料理的餐廳嗎！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來妳那麼想吃魔物料理呀！",
        "unit_id": 111811
    },
    {
        "type": "still",
        "still": "503100702"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……蛤？　",
        "unit_id": 112011,
        "voice": "vo_adv_5031007_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "高級、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物……？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別開玩笑了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "偶爾也想跟你們一起吃些好東西啊……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 111811,
        "voice": "vo_adv_5031007_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道妳為了我們……？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要是跟小凱留還有大家一起吃飯，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n全～部的食物看起來都像大餐唷？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，",
        "unit_id": 112011,
        "voice": "vo_adv_5031007_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在競速賽中也說過那種話呢。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，不對！　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不要吃魔物啦――――！！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 111911,
        "voice": "vo_adv_5031007_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了好了，凱留小姐。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n反正這也是高級餐點嘛。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "問題不在那裡啦，可蘿仔……",
        "unit_id": 112011,
        "voice": "vo_adv_5031007_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇，",
        "unit_id": 111811,
        "voice": "vo_adv_5031007_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一回過神來，已經過12點了呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "竟然在育幼院外",
        "unit_id": 102811,
        "voice": "vo_adv_5031007_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "迎接了新年，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺有點新鮮呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚，",
        "unit_id": 112111,
        "voice": "vo_adv_5031007_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "竟然在新年到來的同時跌倒了……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真不吉利呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 111811,
        "voice": "vo_adv_5031007_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有這種事啦？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們可以一起慶祝耶！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們今年也一起",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃很～多美味的食物吧！",
        "unit_id": 111811
    },
