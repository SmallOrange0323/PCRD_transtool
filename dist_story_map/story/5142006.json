        "name": "惠理子",
        "words": "\n那隻魔物……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "聽覺很敏銳。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n要是現在發出那麼大的聲音……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "北方森林的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 18311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142006_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "牠果然",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在對聲音做出反應，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n應該會朝傳出歡呼聲的方向過去吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "怎、",
        "unit_id": 717,
        "voice": "vo_adv_5142006_039"
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "怎麼這樣……！？",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "教官，",
        "unit_id": 711,
        "voice": "vo_adv_5142006_040"
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "我們該怎麼辦……？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "\n牠要是就這樣撞向其他班的人，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "事情就不得了了……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是啊。",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "牠要是突破新兵們的阻擋，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n附近的村莊也會有危險吧……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那、",
        "unit_id": 129811,
        "voice": "vo_adv_5142006_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那可就糟了！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們得想辦法應付才行！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_043"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把牠引誘到其他地方吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "咦？",
        "unit_id": 711,
        "voice": "vo_adv_5142006_044"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "惠理子教官……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "\n您的意思是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯，",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就由我們來打倒牠。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "由、",
        "unit_id": 711,
        "voice": "vo_adv_5142006_046"
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "由我們，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "來打倒那麼強",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "的魔物嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "\n雖然說有教官們在，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "但還是很困難吧……？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是啊，",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_047"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那樣的魔物，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "光憑我一人恐怕無法招架。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "戰鬥的基礎",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_048"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是以多對一……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯吧？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "！",
        "unit_id": 129811,
        "voice": "vo_adv_5142006_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嘿嘿。",
        "unit_id": 129811,
        "voice": "vo_adv_5142006_050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳也開始明白了嘛！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒錯，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對方只有一隻，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而我們有這麼多人！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就來打倒牠吧……！",
        "unit_id": 129811,
        "voice": "vo_adv_5142006_051"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們馬上來思考作戰計畫！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣的話，",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_052"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我有一個計策。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我後方",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有個陡峭的下坡，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n而對方的眼睛",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在看不見……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以大家",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_053"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就躲藏在斜坡下。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n然後由當誘餌的人，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "負責把那傢伙引誘到我們潛伏的地點。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "趁牠沒注意到陡坡使得身體失去平衡時，",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所有人一起攻擊牠……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼樣？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142006_055"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我覺得這個作戰很好。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要由誰來當誘餌──",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "……",
        "unit_id": 711,
        "voice": "vo_adv_5142006_056"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "請讓我",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "來當誘餌吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "咦……",
        "unit_id": 717,
        "voice": "vo_adv_5142006_057"
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "弗萊迪！？",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "\n騙人的吧，",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "你都受傷了……",
        "unit_id": 717
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "沒問題，",
        "unit_id": 711,
        "voice": "vo_adv_5142006_058"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "剛才是你們救了我，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "這次該輪到我努力了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "\n而且，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "那傢伙之所以會生氣，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "是因為我闖入了牠的地盤。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "\n請給我挽回的機會吧……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "教官！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_059"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我明白了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這就是最後的",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "長跑訓練了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n使盡全力奔跑吧，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我可不准你……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "偷懶喔？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "是！",
        "unit_id": 711,
        "voice": "vo_adv_5142006_060"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "Yes！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "北方森林的魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 18311
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "喂！",
        "unit_id": 711,
        "voice": "vo_adv_5142006_061"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "魔物──！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "我在這裡──！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "北方森林的魔物",
        "words": "！？",
        "unit_id": 18311
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "快過來啊！",
        "unit_id": 711,
        "voice": "vo_adv_5142006_062"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "我就是在你地盤搗亂的罪魁禍首！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "\n不、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "不來追我沒關係嗎！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "北方森林的魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 18311
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "噫！？",
        "unit_id": 711,
        "voice": "vo_adv_5142006_063"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "追來了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "\n不對，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "現在不是害怕的時候……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "我在這裡！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "喬",
        "words": "弗萊迪那傢伙，",
        "unit_id": 711,
        "voice": "vo_adv_5142006_064"
    },
    {
        "type": "dialogue",
        "name": "喬",
        "words": "應該",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "喬",
        "words": "不要緊吧……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……當然不要緊。",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_065"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我一直以來都看著他跑步，",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_066"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然進步緩慢，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但有漸漸變快了……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……沒錯。",
        "unit_id": 129911,
        "voice": "vo_adv_5142006_067"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以不要緊的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n他一定會順利逃到這裡來的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "呼……",
        "unit_id": 711,
        "voice": "vo_adv_5142006_068"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "呼……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "北方森林的魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 18311
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "呼……",
        "unit_id": 711,
        "voice": "vo_adv_5142006_069"
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "呼……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "呼……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
        "words": "呼……！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "北方森林的魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 18311
    },
    {
        "type": "dialogue",
        "name": "弗萊迪",
