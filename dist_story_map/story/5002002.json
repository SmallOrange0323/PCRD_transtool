[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和鏡華吵架之後的隔天，心浮氣躁的禊\n無法好好唸書準備考試，也完全無法集中精神。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊啊，看了教科書也根本看不懂啊！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n為什麼一定要唸書呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "話說回來，要是沒有考試這種事",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n也不會和鏡華吵架了嘛！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n全都是考試的錯！禊是無辜的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……嗯……不過還是去道歉比較好吧……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n但是該說些什麼才好呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "話雖然這麼說，說不定道歉也不會原諒我！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n畢竟鏡華很生氣啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要是一直這樣下去怎麼辦～！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唔──，一直這樣心浮氣躁真是討厭～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "其實昨天本來也是想唸完書後和大家一起玩的……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n會不會再也見不到鏡華了呢……畢竟都說要和我絕交了……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？哥哥？",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n怎麼了……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，對了！請哥哥幫忙好了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n說不定哥哥會教我和好的辦法！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "喂──咿！哥哥～～――！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥不見了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n……啊，對了，是禊挖了一個陷阱啦。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真是的，哥哥還是一樣粗心耶──",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n跑過來的時候，禊還覺得像是救命英雄呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這種時候拜託看看氣氛嘛。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，啊哈哈……因為吵架覺得很煩就……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是哥哥啊，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不要連禊在失落的時候都掉到陷阱裡嘛～",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿，嘿呀！啊哈哈，髒兮兮，",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不多注意一下週遭是不行的哦？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？找禊有事嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "現在什麼事都先別管，禊要跟你商量一下",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊昨天不是和鏡華吵架了嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n說真的，鏡華的教學方法完全聽不懂，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n又光出些困難的問題，真的讓人火大……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是，拜託她教禊唸書的也是我自己，",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n半途而廢是禊不好，這我也明白……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且，吵完架就算惡作劇也高興不起來，",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不管做什麼都無法集中精神呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那個，所以啊……禊想和鏡華和好啦！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n想要好好說聲對不起！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是……鏡華一定還在生氣……畢竟都絕交了……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥，要怎麼做才能和好呢？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華喜歡的東西？嗯，是杯子蛋糕吧。",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "以前她好像說過，只要吃了杯子蛋糕，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不開心的事就會煙消雲散……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "如果是杯子蛋糕的話，說不定禊也做得出來……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊啊，可是鏡華喜歡的應該是",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n街上賣的那種做得很漂亮的啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "只要心意到了就好了？",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……說的也是，不愧是哥哥！說的真不錯！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，那禊也要做杯子蛋糕送給鏡華了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n然後藉此和鏡華和好！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那好！既然決定那麼做，就趕快來做杯子蛋糕吧！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥也會幫忙對吧！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呃……攪拌奶油和砂糖，再加入蛋……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n做好之後，再用篩籃倒進這種粉",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唔……咳、咳……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n為什麼杯子蛋糕會爆炸啊～！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "奇怪耶……應該已經照食譜寫的放進材料了……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "原來！哎呀！這根本不是麵粉，",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是禊的惡作劇道具爆裂粉啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊啊……要是知道會發生這種事，",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n平時多幫忙媽媽就好了",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是，現在後悔也太遲了……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "與其這樣，不如現在讓禊用全部精力",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n為鏡華做出杯子蛋糕吧",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就算不能像店裡賣的那麼漂亮，只要有心意……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "（絕對能和好的！禊能夠一直開玩笑胡鬧，",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n也是因為有非常認真的鏡華在啊！)",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "（雖然料理和唸書差不多都不拿手，可是，可是……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_032"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不會再半途而廢了！就算是禊，只要願意做還是做得到的！)",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "份量……大概是這些……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_033"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n倒入材料的順序是……時間大概是這樣……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "放進烤箱……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "拜託了！這次一定要順利完成哦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥哥哥哥哥！好香的氣味！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_035"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我有預感這次大成功了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那要打開烤箱囉……來吧",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_036"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "！",
        "unit_id": 100411
    },
    {
        "type": "still",
        "still": "500200401"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚哇！順利膨發起來了！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_037"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n好棒好棒！禊順利完成了唷！",
        "unit_id": 100411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "也要謝謝哥哥借我廚房！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_038"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n在家裡做的話就會被媽媽罵，叫我去唸書了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咿嘻嘻，這樣鏡華也會高興了吧！",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_039"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……啊啊──！可，可是要怎麼交給鏡華才好！？",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_040"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要是跑去送給她的時候，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n「都已經絕交了還來做什麼？」說不定會這麼說，那怎麼辦……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯？什麼？突然拿出信來……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_041"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "蛤？難道是哥哥要給我的情書！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊還只是小孩子哦！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯？什麼什麼……「探險邀請函」……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_042"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這，這是鏡華寫的信嗎！？",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_043"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣啊！原來哥哥是特地把這個送來給禊的呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "在這一天把杯子蛋糕送給鏡華的話……",
        "unit_id": 100411,
        "voice": "vo_adv_5002002_044"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
