    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了慶祝安的生日，\n帶她逛起她不認得的地方──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}的家鄉。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人逛了商店街和車站"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "等幾個場所……"
    },
    {
        "type": "background",
        "background": "510160"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗚哇～",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_000"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "有好多書！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這裡是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "圖書館吧？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n這裡的書都可以自由閱讀吧！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "太棒了！",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_001"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "要先看哪一本呢～",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "雖然有很多陌生的困難文字，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但很奇妙地我似乎懂它們的意思……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "而且，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_002"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這種設計到底是怎麼畫的……！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n「CG」……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這邊世界的技術",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "真的好厲害！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "好像魔法喔！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "當然喜歡！",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_003"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "逛了商店街跟車站，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n認識這裡也很好玩……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "更重要的是，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_004"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "你記得",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我喜歡書！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n果然這才是最讓我高興的事！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "國家不同，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_005"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "藏書真的也完全不同呢。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "好像沒有魔導書……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但這個書架上的是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "工具書？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "哇，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "上面寫了好多公式！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這邊的書架是普通的小說嗎？",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_006"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n學園類……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "奇幻類？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "魔法這概念本身是存在的啊！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "哦～！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呼，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_007"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "好想把古蕾婭也帶來喔～",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是說，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "想看完所有書要花幾天啊？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n有一整天的話，應該至少可以看完書架的第一層吧？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那就……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗚，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_008"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "果然不行啊……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "可是，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我真的覺得這裡棒到我會想過夜！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這真的是最棒的禮物～！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呵呵，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_009"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "謝謝你！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "…",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "…啊，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "對了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "方便的話，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "能再多問你一些",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n關於這裡的書的事嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "畢竟我不懂的事情很多，",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_010"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "像文化跟技術……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n我想知道更多更多",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這裡的事。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "謝謝你！",
        "unit_id": 109211,
        "voice": "vo_adv_4010222_011"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那麼，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "剩下的時間也要繼續麻煩你了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "要從哪裡開始讀起呢！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呵呵♪",
        "unit_id": 109211
    }
]