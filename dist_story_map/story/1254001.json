    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "完全是竊盜罪。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我要以遊俠的權限",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_073"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "拘捕你。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n詳細的事情，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就到牢裡再說吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "……！",
        "unit_id": 811,
        "voice": "vo_adv_1254001_074"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n喂，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "給我殺了那些傢伙！！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請你快點退下！",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_075"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我會和喵特一起",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "制止魔物！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特！",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_076"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n過來這裡！！",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎喔喔──！！",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一口氣壓制住牠們！",
        "unit_id": 125413,
        "voice": "vo_adv_1254001_077"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "可惡……！",
        "unit_id": 811,
        "voice": "vo_adv_1254001_078"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n得快去通知老大──",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你別想逃。",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_079"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "可惡……！",
        "unit_id": 811,
        "voice": "vo_adv_1254001_080"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "居然連拖延時間都辦不到……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n那些傢伙在搞什麼啊……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠們應該正在熟睡中喔，",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_081"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為遊俠的麻醉箭效果很強。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "比起那個──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我勸你在這裡乖乖就範，",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_082"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為我並不想對你動粗。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎嚕嚕……",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "…………可惡，",
        "unit_id": 811,
        "voice": "vo_adv_1254001_083"
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "謎樣男子",
        "words": "真的有夠倒楣耶……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "纏上繃帶……",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_084"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "包好了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n幸好我有跟真陽學替魔物包紮的方法。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "……………………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好了，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_085"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你不需要繼續生活在恐懼之下了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有你的同伴",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都已經自由了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………\n……………………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……走掉了呢。",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_086"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖說是被人操縱，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我知道依照原本的規定，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠們也必須受懲罰才行。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是……",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_087"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "既然隸屬魔法已經解除了，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想牠們也不會再出現在人類的村子了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以──",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……是的。",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_088"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們也回村子去吧，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_089"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n得向村長先生報告才行。",
        "unit_id": 125414
    },
    {
        "type": "background",
        "background": "500700"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "沒想到會這麼快就查清楚原因了……！",
        "unit_id": 511,
        "voice": "vo_adv_1254001_090"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們確實逮到了一名犯人，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_091"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過還稱不上是解決了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要說我們現在能做的事，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "頂多只有進行巡邏……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但我們會盡力防止事件再次發生的。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "妳叫做",
        "unit_id": 511,
        "voice": "vo_adv_1254001_092"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "栞小姐對吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我相信只要有妳在，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n我們和魔物就都能放心生活了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "今後也麻煩妳了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……！",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_093"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的！",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你。",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_094"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為有你的協助，才能有這樣的成果。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎嚕嚕……",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇啊！？",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_095"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也沒有忘了喵特喔。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n謝謝你和我一起戰鬥。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "咕嚕嚕♪",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那位愛吃醋的搭檔硬是擠到兩人中間坐了下來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n栞則是抱緊牠，對牠露出笑容。"
    }
