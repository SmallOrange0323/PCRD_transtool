[
    {
        "type": "background",
        "background": "501690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "獵人公會的場地內──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正是現在，有隻巨大的魔貓襲向了逃跑中的人影。"
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "嘎喔喔──！！",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵特！",
        "unit_id": 1,
        "voice": "vo_adv_1254001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\nStay！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "──！！",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……很好，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "成功抓到目標了呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n好乖。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "咕嚕嚕♪",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}。\n那個，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你沒受傷吧？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有哪裡會痛嗎……？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你沒事，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那就太好了。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "願意扮演盜獵者的角色。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣的話，應該能從教官那裡得到合格的分數。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這讓我放心了……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當有敵人或獵物在眼前時，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔物會陷入亢奮狀態。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們沒有辦法阻止依照本能行動的魔物。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這一點喵特也是一樣……",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果發生了出乎意料的事，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠將會聽不進去我的聲音。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因此",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我才開始訓練牠，讓牠學會無論何時都要聽從我的指示……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛開始總是失敗，真的很不容易。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "比如牠在訓練中發現罕見的蟲子，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n會追著蟲子一起蹦蹦亂跳……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當看到牠開心地將抓到的蟲子交給我時，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n又讓人很難去罵牠。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有打雷時也是，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠會用頭抵住我的肚子磨蹭……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有時候甚至在天氣變好之前，我都動彈不得……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "在那時候我也會忍不住去摸摸牠的頭來安撫牠，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但如果在任務中發生那種情況，會很傷腦筋呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想那一定是",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n當時我們身為遊俠的覺悟還不夠。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "隨著持續進行訓練，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "成功的次數也漸漸多於失敗了……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是慢慢累積下來的努力，給了我們自信並加深了我們之間的羈絆。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "即使牠真的因為本能而失控大鬧，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要我好好看著牠的眼睛跟牠對話，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠就會變回「喵特」。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特。",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n謝謝你一路跟著我",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "走到這裡來。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "咕嚕嚕♪",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵……",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n喵特的耳朵向後倒，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "表情看起來也像是在笑呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n好可愛呦～♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "妳還是這麼溺愛牠呢。",
        "unit_id": 414,
        "voice": "vo_adv_1254001_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "教官！",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_018"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我看到你們的表現了，",
        "unit_id": 414,
        "voice": "vo_adv_1254001_019"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "這樣應該能夠順利完成課題吧。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "再來只剩下累積經驗了。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "──因此，",
        "unit_id": 414,
        "voice": "vo_adv_1254001_020"
    },
    {
        "type": "dialogue",
        "name": "獸人教官",
        "words": "我要指派首次的任務委託給你們！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_021"
    },
    {
        "type": "background",
        "background": "501850"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這裡就是",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n「魔物保護區」的森林啊……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "…………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "即使看到人也不會襲擊過來。",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟教官說的一樣，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "生活在這裡的魔物都很溫馴呢。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣的話，",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那件事又是怎麼回事呢？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「魔物們襲擊人類村子」",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種消息──",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂～！",
        "unit_id": 1,
        "voice": "vo_adv_1254001_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n魔物又襲擊過來了～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "！？",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "聲音是從那個村子傳來的！",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們過去看看吧！！",
        "unit_id": 125414
    },
    {
        "type": "background",
        "background": "500700"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔物在哪裡！？",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n立刻引導居民避難──",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "喝啊啊啊啊！！！！",
        "unit_id": 1511,
        "voice": "vo_adv_1254001_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "…………咦？",
        "unit_id": 125411,
        "voice": "vo_adv_1254001_030"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "又跑來搶食物了嗎！！",
        "unit_id": 1511,
        "voice": "vo_adv_1254001_031"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "管它是人還是魔物，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "來偷東西的我都不會放過～！！！！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊！？",
        "unit_id": 311,
        "voice": "vo_adv_1254001_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "剛曬的魚被搶走了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "給我還來～！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這個小偷魔物～！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "真是的！",
        "unit_id": 1511,
        "voice": "vo_adv_1254001_033"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n每天都這樣，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "究竟是怎麼回事啊！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "婆婆，",
        "unit_id": 311,
        "voice": "vo_adv_1254001_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳這麼激動的話，又會倒下的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "村長也說過他已經向遊俠請求協助了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n再忍耐一陣子就好。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不過",
        "unit_id": 311,
        "voice": "vo_adv_1254001_035"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真的很不可思議呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n那些不會主動接近人的魔物，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "居然會特地跑來搶食物……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那、",
        "unit_id": 125414,
        "voice": "vo_adv_1254001_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n能請你們詳細說明一下情況嗎？",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "嗯？",
        "unit_id": 1,
        "voice": "vo_adv_1254001_037"
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "有遊俠來到這裡，真是讓人放心了。",
        "unit_id": 511,
