[
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "莫夫，",
        "unit_id": 125511,
        "voice": "vo_adv_5118323_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你還想繼續打嗎？",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不管戰鬥幾次，結果都會是一樣的。",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "……呵呵，",
        "unit_id": 17512,
        "voice": "vo_adv_5118323_001"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "還沒結束。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n我還沒拿出所有的本事呢……！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "不，",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "不如說，精彩的才正要開始！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "到現在這一瞬間為止，我所累積的",
        "unit_id": 17512,
        "voice": "vo_adv_5118323_002"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "知識、",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "經驗、",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "意志力！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n讓我將其彙整，用來一口氣擊潰你們吧！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n無知的存在啊，",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "是時候懂得懼怕我所擁有的智慧了！！",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118323_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n都到了這地步竟開始耀武揚威，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "莫夫你還是太缺乏鍛鍊了呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "或許這也代表",
        "unit_id": 125711,
        "voice": "vo_adv_5118323_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "他已經被逼到沒有心力管那麼多了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n接下來恐怕會出現比先前更猛烈的攻勢。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "聽起來真不妙！",
        "unit_id": 125611,
        "voice": "vo_adv_5118323_005"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "但反過來說，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "只要撐過這一波，莫夫就沒辦法再耍花招了對吧？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "既然如此，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我們要做的事只有一件！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們就堂堂正正地",
        "unit_id": 125511,
        "voice": "vo_adv_5118323_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "正面粉碎莫夫的野心吧！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n大家，",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要上囉！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "碧卡拉、花凜",
        "words": "嗯！\n好的！",
        "unit_id": 1,
        "voice": "vo_adv_5118323_007"
    }
]