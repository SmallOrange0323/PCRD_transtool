    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "連老大都這麼說了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "要是沒發生奇蹟的話，就完蛋了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……但是。",
        "unit_id": 106511,
        "voice": "vo_adv_5084658_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n如果是你，就能引發奇蹟。我這麼相信著。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "若是為了幫你，",
        "unit_id": 106511,
        "voice": "vo_adv_5084658_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n而你也需要我的力量的話，我願趕往天涯海角。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也只會打架一類的事情而已啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……一定要醒來啊。",
        "unit_id": 106511,
        "voice": "vo_adv_5084658_004"
    },
    {
