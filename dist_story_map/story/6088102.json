        "words": "胡桃平時那麼文靜，",
        "unit_id": 121411,
        "voice": "vo_adv_6088102_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但演起戲來真的很厲害耶。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "簡直像另一個人。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n那就是",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "女演員啊……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……？",
        "unit_id": 121411,
        "voice": "vo_adv_6088102_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你在胡說什麼啊。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我怎麼可能像胡桃那樣……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊！",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是想說我老愛裝大人是吧！？",
