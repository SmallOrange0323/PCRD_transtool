    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "透過庫露露的努力，以及真步與{player}的協助，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n「大夢想樂園」正一步步逐漸改善。"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嘿嘿～♪",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_000"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n客人的笑容，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "越來越多了呢～♪",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是呀～",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n到處",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都能聽到",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "愉快的歡笑聲呢～♪",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來到吉歐‧提格尼亞後",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家才發現。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這裡的人們，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "明明有著各式各樣的種族，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但大家都溫和地",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "友好相處哪。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然並不是說",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在咱們的世界裡就關係惡劣，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但不久之前，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "才剛因為種族的事情",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而有過爭吵……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個世界如此地祥和，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓人家有點羨慕哪。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "確實",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_004"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "就像妳說的。",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "因為這裡的人們都不喜歡爭吵，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "所以很少發生爭執──",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 1,
        "voice": "vo_adv_5146003_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你這隻",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小狗！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你你……",
        "unit_id": 1,
        "voice": "vo_adv_5146003_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說什麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你這、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "大塊頭！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼哼！！",
        "unit_id": 1,
        "voice": "vo_adv_5146003_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很溫和地在吵架……",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_008"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "哈哇哇……",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_009"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "這在吉歐‧提格尼亞可是很嚴重的吵架～！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "得趕快阻止他們才行～！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "死黨1、死黨2",
        "words": "再……",
        "unit_id": 1,
        "voice": "vo_adv_5146003_010"
    },
    {
        "type": "dialogue",
        "name": "死黨1、死黨2",
        "words": "再來一次，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "死黨1、死黨2",
        "words": "哼！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "五體投地～～～！！",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_011"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n看在這顆寶石的分上，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "請別吵架了～～！！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "死黨1、死黨2",
        "words": "咦咦，",
        "unit_id": 1,
        "voice": "vo_adv_5146003_012"
    },
    {
        "type": "dialogue",
        "name": "死黨1、死黨2",
        "words": "下跪道歉！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "突然之間很抱歉哪。",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好了庫露露小姐，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把寶石收起來，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抬起頭吧？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……你們兩位，",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底是怎麼了？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看樣子似乎是在吵架……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "遊樂園",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "應該是開心玩耍的地方，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是嗎？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "死黨1",
        "words": "……",
        "unit_id": 9411,
        "voice": "vo_adv_5146003_015"
    },
    {
        "type": "dialogue",
        "name": "死黨1",
        "words": "哼。",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "死黨1",
        "words": "\n一點也不好玩。",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "……",
        "unit_id": 9211,
        "voice": "vo_adv_5146003_016"
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "沒錯。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "因為這個遊樂園。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "\n根本沒有能讓我們兩個一起玩的遊樂設施。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "咦……？",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_017"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n這是",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "什麼意思？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "死黨1",
        "words": "我們兩個，",
        "unit_id": 9411,
        "voice": "vo_adv_5146003_018"
    },
    {
        "type": "dialogue",
        "name": "死黨1",
        "words": "沒辦法玩同一個東西。",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "……就是這麼回事。",
        "unit_id": 9211,
        "voice": "vo_adv_5146003_019"
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "\n我能搭乘的遊樂設施",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "對這傢伙來說太小了，",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "\n反過來說這傢伙能搭的，",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "對我來說又太大了。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "因為這樣，",
        "unit_id": 9211,
        "voice": "vo_adv_5146003_020"
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "才會變得有點煩躁。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "\n虧我原本還這麼地期待……",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "\n算了，",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨2",
        "words": "回家吧。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "死黨1",
        "words": "我會比你還早回家。",
        "unit_id": 9411,
        "voice": "vo_adv_5146003_021"
    },
    {
        "type": "dialogue",
        "name": "死黨1、死黨2",
        "words": "……哼！！",
        "unit_id": 1,
        "voice": "vo_adv_5146003_022"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "哈哇哇～～！？",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_023"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n因為「大夢想樂園」的關係，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n讓兩人的友情出現裂痕～～！？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個是",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只有在吉歐‧提格尼亞才會出現的問題哪……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算是體型不一樣的朋友，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也能一起享受的遊樂設施。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這到底",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該怎麼做才好呢……？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "體型不一樣的朋友，",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_025"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也能一起享受的遊樂設施……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "體型不一樣的朋友，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也能一起享受的遊樂設施……！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "體型不一樣的朋友，",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "也能一起享受的遊樂設施……！！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "噫噫噫噫！",
        "unit_id": 130912,
        "voice": "vo_adv_5146003_026"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n這太困難了～～！！",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "喂～！",
        "unit_id": 126411,
        "voice": "vo_adv_5146003_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n庫露露～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的耶……",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過是從哪裡傳來的呢？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咚──！",
        "unit_id": 126411,
        "voice": "vo_adv_5146003_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n著地！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇，",
        "unit_id": 131011,
        "voice": "vo_adv_5146003_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嚇了一跳。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n克蘿茜小姐，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳剛才是在天上飛嗎？",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的！",
        "unit_id": 126411,
        "voice": "vo_adv_5146003_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為波波爺爺似乎把眼鏡弄丟了，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n所以我就飛在空中來找！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "要找東西的話，",
        "unit_id": 126411,
        "voice": "vo_adv_5146003_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n從空中最能看清楚了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "庫露露",
