        "voice": "vo_adv_1131004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "心思也很細膩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n從今以後，你也要好好地成為她的助力喔。",
        "unit_id": 190011
