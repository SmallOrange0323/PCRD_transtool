        "voice": "vo_adv_1131004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "堅毅而帥氣的大人。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也見到她",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不一樣的一面了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "偶爾流露出來的柔和神情",
