[
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "教訓完盜墓者的隔天──"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊……",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "天終於亮了，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哇啊啊啊啊！",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜託饒了我吧……！？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……喔，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來是你啊！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別突然",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟我搭話啦，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還以為是什麼出現了……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一回想起昨天的事，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怕得要命……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要稍微有點聲響，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就會",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "驚醒。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "反倒是",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "遇見那種事，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "居然還能這麼平靜啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你都不覺得",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "害怕嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "碰上真正的靈異事件，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的反應就這樣而已嗎……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺別人就會說",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的心臟是鐵打的呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說的是沒錯啦……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但幽靈這種存在，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "本身就令人害怕不是嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唉，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說是我想太多",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "確實也不無道理。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也覺得這樣的自己",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "滿丟人的……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只不過，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也不曉得",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "自己為什麼會這麼怕鬼。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "畢竟",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也沒有",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的被惡靈纏身的經驗。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "算了，",
        "unit_id": 113111,
        "voice": "vo_adv_1131004_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "像現在是大白天，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也不會特別放在心上。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "光線不曉得為什麼特別強……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你怎麼在發光呀！？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這也該是",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一種靈異現象了吧！",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼回事……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊！",
        "unit_id": 113111
    },
    {
        "type": "background",
        "background": "510292"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "抱歉啊，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "臨時約你出來。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你等很久了嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒有啦，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是那麼嚴重的事。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我只是",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想和你一起",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "體驗一下夏日風情啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……怎麼了？",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓你那麼意外嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我也是會有",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "想要玩樂的時候呀。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "長大之後",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就沒有暑假了，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能像這樣子玩樂的機會也不多。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以呀……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你看，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "煙火組合包。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n商店街的人給我的。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然不是祭典的煙火，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但這種煙火也不賴吧？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我還提了水桶過來，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "兩個人一起",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "悠閒地玩一玩吧？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在這附近玩煙火",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "會被罵的。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們去",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "寬敞一點的公園吧。",
        "unit_id": 105632
    },
    {
        "type": "background",
        "background": "510122"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在這附近應該就沒問題了。",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那要從哪種煙火開始玩呢？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這是會冒出長長一條的煙火吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就玩這個……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "…………",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "奇怪？",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個煙火有這麼普通的嗎……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我記得小時候玩得滿開心的呢……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說到正統的煙火，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "果然還是這個吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我先點火，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後再接給你……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……咦？",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要一次拿那麼多嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你說一口氣點燃",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比較好玩啊……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也是可以啦……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哇啊啊啊！",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "等等，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沖天炮！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n怎麼會有沖天炮混在裡面啦啊啊啊！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "最後",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來玩線香煙火吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要來比賽",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看誰的煙火撐得比較久呀？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "輸家",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要無條件聽從贏家的一個要求。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那要開始囉……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "開始！",
        "unit_id": 105632
    },
    {
        "type": "still",
        "still": "113100401"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦？",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的煙火",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好像快掉下去了耶。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n看來輸贏已經",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很明顯囉？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈哈，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你能撐到什麼時候呀。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就讓我見識一下",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的毅力吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……我啊，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然很怕鬼。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但夏天夜晚的氣氛，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其實，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還蠻喜歡的呢。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "微風吹拂，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "蟲鳴此起彼落……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n有種",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "「啊，夏天來了。」",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的感覺。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就突然發現。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n明明是夏天，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "自己卻完全沒有",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好好享受過。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "擇日不如撞日，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就約了你。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "即便是這麼倉促的邀約，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你還願意陪我，真是太好了。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n託你的福，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我好好體驗到夏日風情了呢。",
        "unit_id": 105632
    },
    {
        "type": "still",
        "still": "113100402"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我會這麼想，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "或許……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就是因為有你在身邊吧。",
        "unit_id": 105632
    },
    {
        "type": "background",
        "background": "510122"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是我贏了！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那要",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓你答應我什麼要求好呢……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 105632,
        "voice": "vo_adv_1131004_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就讓你請我吃超商的冰淇淋吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我們可以",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "邊吃邊漫步回去。",
        "unit_id": 105632
    },
