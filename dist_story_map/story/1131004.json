    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n剛才",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你所看見的畫面是像夢境一樣的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "玩得還開心嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "平時的流夏給人的印象是",
