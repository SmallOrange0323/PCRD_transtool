[
    {
        "type": "dialogue",
        "name": "真步",
        "words": "員工先生的真面目，",
        "unit_id": 131011,
        "voice": "vo_adv_5146301_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是賭場王‧",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吉諾先生……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他跟王子先生他們",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "以前",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像也",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有過什麼恩怨呢。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嗚欸欸欸，",
        "unit_id": 130911,
        "voice": "vo_adv_5146301_001"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "好受打擊……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "一直以來一起共事的員工先生居然……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嗚嗚。",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "員工先生",
        "unit_id": 130911,
        "voice": "vo_adv_5146301_002"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "是對於在我們這裡上班有所不滿嗎……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n像是休假太少，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "或是想要求加薪之類的……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "嗚嗚，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我要反省。",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我明明是經理，卻沒能察覺到……",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這應該不是那種",
        "unit_id": 131011,
        "voice": "vo_adv_5146301_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "類似罷工的行為吧，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他剛才也說了",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他要奪走",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "「大夢想樂園」……",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總之咱們",
        "unit_id": 131011,
        "voice": "vo_adv_5146301_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在先打起精神吧。",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "得趕快阻止他，",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不然遊行",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可就泡湯了……！",
        "unit_id": 131011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "說、",
        "unit_id": 130911,
        "voice": "vo_adv_5146301_005"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "說的也是說的也是！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "員工先生！",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我們會阻止你的！！",
        "unit_id": 130911
    }
]