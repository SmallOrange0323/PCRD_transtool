        "words": "嘿嘿……",
        "unit_id": 121511,
        "voice": "vo_adv_6090104_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "能收到這麼棒的怪盜服，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我好開心。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n帆稀小姐",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真的什麼都會耶。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "學長……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這件衣服，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你有特別喜歡的",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "部分嗎？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 121511,
        "voice": "vo_adv_6090104_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也很喜歡",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這件披風！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n學長總是",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "披著很帥的披風……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n所以，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我一直都希望自己有一天",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也能穿上披風……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這件服裝",
        "unit_id": 121511,
        "voice": "vo_adv_6090104_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真的好厲害……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n居然還有附加隱藏氣息的魔法……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有了這個，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n不管碰到什麼任務，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一定都有",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "辦法過關的……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說到怪盜，",
        "unit_id": 121511,
        "voice": "vo_adv_6090104_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然少不了",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "面具。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……咦！？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩說想戴看看",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我的面具嗎！？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不是",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不可以……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只是覺得",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有點嗨羞……",
        "unit_id": 121511
    }
]