        "voice": "vo_adv_2102003_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好久不見～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晶小姐……！",
        "unit_id": 105913,
        "voice": "vo_adv_2102003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼稱呼您才是呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您能回來這邊了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "勉勉強強啦♪",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟『那邊』引起的騷動，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也進展到小康狀態的階段了嘛。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "加上在『這邊』也還有我得去做的事。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "另外，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有……",
        "unit_id": 106812
    },
    {
        "type": "still",
        "still": "210200301"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "更重要的是，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好好跟你道個謝呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……謝謝你，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你真的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "成功阻止真那了呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並且，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你還沒有殺了真那。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n關於這點，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我真的再怎麼感謝你都不夠呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但只要一想到因為你的這份溫柔，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n害得你",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的靈魂受到了深刻的傷害……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就真的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓我不知道該如何面對你了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然當時事態有可能更加惡化……",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但畢竟給予你那份力量的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是別人正是我啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……不過……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能像這樣與你重逢，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能這樣直接觸碰到你。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我對於",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能夠看到了你現在的這個樣子，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可是感到非常高興的唷……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可說是能當場跳起舞來，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "給他乾了好幾杯都沒關係的心情唷。",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳說現在騎士先生的這個樣子",
        "unit_id": 100211,
        "voice": "vo_adv_2102003_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……是、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是什麼意思啊？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！　",
        "unit_id": 105812,
        "voice": "vo_adv_2102003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難不成是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n『喜歡有著嬰兒人格的{player}！』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n——這樣的意思嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_2102003_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n喜、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喜喜喜歡歡……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯？　",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不不，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是不是。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓我高興的地方，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是他的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『成長』唷。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的、",
        "unit_id": 105913,
        "voice": "vo_adv_2102003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "成長……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是叫『公主型態』",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "究竟為什麼會產生了那樣的能力，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "老實說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就連我也不知道。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是比我給他的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『公主騎士』之力更高了一層的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是只有現在的少年才擁有的東西。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年他不知不覺，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就成為超越了我所能預想到的存在了……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對這件事",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "感到非常非常地高興。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈。",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當父母的心情，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大概就是這樣吧！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812,
        "voice": "vo_adv_2102003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我記得沒錯若照似似花所說的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他力量的成長，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是因為拉比林斯達交給他",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的力量耶……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，嗯。",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我確實是把",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『原本的公主騎士之力』",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還給了他。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那力量",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎和",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "他之中的『什麼』混在了一塊呢～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到底為什麼會變成這樣呢？",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊啊，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是真的非常想知道呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "難不成，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你撿了什麼奇怪的東西吃下肚了？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……啊，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在的你回答不出來嘛。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不過嘛言而總之。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那個『公主型態的力量』",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還只是剛覺醒而已，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "他還沒辦法掌握是無庸置疑的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然剛剛日和問說，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n『如果力量用過了頭，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "會不會讓他傷得更嚴重呢？』",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "像那樣\n擔心了一下……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但從現階段來看，",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "承擔風險的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該是被給予力量的一方。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我認為反而是妳們才對。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "優衣",
