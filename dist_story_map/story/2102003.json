        "voice": "vo_adv_2102003_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟我們可是一起和霸瞳皇帝戰鬥的夥伴嘛☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有小雪菲也是唷♪",
