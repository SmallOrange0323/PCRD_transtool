        "voice": "vo_adv_2102003_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這座城卻被身分不明，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並且非常危險的公會給盯上了……",
