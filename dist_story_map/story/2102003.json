    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_2102003_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "若是那位陛下的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
