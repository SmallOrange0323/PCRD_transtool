        "voice": "vo_adv_2102003_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2102003_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然已經和大家借了好～多的力量，",
        "unit_id": 105812
    },
