    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還將我們從牢裡放出來，",
        "unit_id": 100211,
        "voice": "vo_adv_2102003_058"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n真的是幫了我們很大的忙。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝妳呢，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "貪吃佩可！",
