        "voice": "vo_adv_2102003_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我得做為一名公主！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了守護這個國家去戰鬥才行！",
        "unit_id": 105812
    },
