    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常不好意思。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒事沒事，不用在意。",
        "unit_id": 106812,
        "voice": "vo_adv_2102003_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這翅膀和耳朵……",
