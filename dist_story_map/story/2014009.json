    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從很久以前開始，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就已經在我的手掌心上囉。",
