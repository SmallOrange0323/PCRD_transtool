    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "咕喔！",
        "unit_id": 107312,
        "voice": "vo_adv_2014009_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咕！",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "怎麼啦怎麼啦。",
        "unit_id": 106914,
        "voice": "vo_adv_2014009_002"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們兩位，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可太不像樣了吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我明明就只是，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "朝所有方向連續放出了魔力而已喔……♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咕……",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n竟讓我只能專心進行迴避，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還在那開什麼玩笑……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……霸瞳皇帝，",
        "unit_id": 107312,
        "voice": "vo_adv_2014009_004"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "竟有如此實力……！",
        "unit_id": 107312
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……然而",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為何？……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n從途中開始，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很明顯地就轉變成愚弄我們的戰法了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n明明一開始，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還像是急著要分出勝負而焦慮的感覺……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好了，",
        "unit_id": 106914,
        "voice": "vo_adv_2014009_006"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要再來一次囉。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要迴避也行。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要放棄防禦朝我這殺過來也無妨。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論如何，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若不再加把勁……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可是會死的唷？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那連續放出的魔力，",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟能完全在我從絕對防禦轉換為攻擊的瞬間見縫插針！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在與我戰鬥的這段期間，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然已經能夠計算到這種地步了嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你的頭腦究竟是！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……咕啊！",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_008"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "――克莉絲！",
        "unit_id": 107312,
        "voice": "vo_adv_2014009_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還早、",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還早啊……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n令人愉快至極的這場遊戲，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在才正要開始……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "就到此為止啦！",
        "unit_id": 190711,
        "voice": "vo_adv_2014009_011"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n妳這個不要命的老太婆！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大吾！？",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是和矛依未她們去解決街上的魔物了嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那邊早就結束了啦！",
        "unit_id": 190711,
        "voice": "vo_adv_2014009_013"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……話說回來你們，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "怎麼都被打得這麼慘兮兮啊……！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈，",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣可是比平常更美麗了對吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……比起這個，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別礙事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在打得",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可正精彩呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2014009_015"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "來得可真晚呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "公主騎士們……",
        "unit_id": 106914
    },
    {
        "type": "still",
        "still": "201400901"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "你們幾個……！",
        "unit_id": 999990,
        "voice": "vo_adv_2014009_016"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人！！　",
        "unit_id": 191011,
        "voice": "vo_adv_2014009_017"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您沒事嗎！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……和聽到你那惱人的聲音，",
        "unit_id": 107011,
        "voice": "vo_adv_2014009_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而使人不悅相比，沒事唷。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真軌。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "霸瞳皇帝。",
        "unit_id": 104911,
        "voice": "vo_adv_2014009_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你所操縱的那些魔物，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n已經幾乎都被我們解決掉了唷！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很遺憾的，",
        "unit_id": 101711,
        "voice": "vo_adv_2014009_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你就在這裡束手就擒吧――！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拜託你了，",
        "unit_id": 100211,
        "voice": "vo_adv_2014009_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "別再",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n傷害任何人了……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……陛下",
        "unit_id": 106011,
        "voice": "vo_adv_2014009_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……對不起。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你已經",
        "unit_id": 105811,
        "voice": "vo_adv_2014009_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有棋子",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒有能夠逃的地方了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你就覺悟吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一個接著一個。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n全都跑到這兒來了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是打算要把我的樂趣給奪走嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……那麼，",
        "unit_id": 107111,
        "voice": "vo_adv_2014009_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可要記在帳上啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n給我記好……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們一個又一個，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不用多久……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就會去跟你們討的啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別忘啦……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克莉絲……",
        "unit_id": 107011,
        "voice": "vo_adv_2014009_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真虧妳可以撐到這時了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就連我也有些少見地，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想和妳道個謝了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "謝謝妳。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是……",
        "unit_id": 104311,
        "voice": "vo_adv_2014009_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底是什麼鬼啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霸瞳皇帝……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "連那個強得一塌糊塗的克莉絲提娜阿姨，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n竟然也會被打得這麼破破爛爛的……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然我們",
        "unit_id": 101711,
        "voice": "vo_adv_2014009_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也有被強化了……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但一路到這裡來，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也是消耗了不少呀。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們真的可以誰都不用犧牲，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "然後打贏這個人嗎！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_2014009_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "霸瞳皇帝也一樣……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從剛復活不久後就一路打到現在了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n應該也花掉了不少魔力才是。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "若我們要趁虛而入，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是現在了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "――那麼，",
        "unit_id": 105811,
        "voice": "vo_adv_2014009_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請覺悟吧，霸瞳皇帝！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
