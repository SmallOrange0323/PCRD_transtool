    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可麗餅店【拉比林斯】的攤位上──"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104914,
        "voice": "vo_adv_4013001_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n怎麼啦？你今天",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是來買可麗餅的嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還是來見姐姐的呢？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有重要的事……？",
        "unit_id": 104914,
        "voice": "vo_adv_4013001_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是弟弟來見姐姐的這件",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "非常重要的事吧♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你一個人來",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是了不起、了不起♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的！",
        "unit_id": 101112,
        "voice": "vo_adv_4013001_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我是知道妳想補充久違的哥哥成分，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但我們是為了講那件事才請他來的啦，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳沒忘記吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對喔！",
        "unit_id": 104914,
        "voice": "vo_adv_4013001_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你能來這邊一下嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "再右邊一點吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "往前一步……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對對，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是那附近。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "做得很好♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐給你摸摸頭喔。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 101112,
        "voice": "vo_adv_4013001_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "小心別咬到舌頭了喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這可是青天霹裂、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "弓其不備喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是箭其不備才對？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不論哪個都有點不對吧～？",
        "unit_id": 104914,
        "voice": "vo_adv_4013001_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果只論發音，弓是正確的就是了。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過也對呢，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了不讓弟弟嚇到，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐會緊緊抱住你的。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_4013001_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好詐喔～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼我也要……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抱緊",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "～～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼哥哥，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "準備好囉？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要注意著地時的衝擊喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就啟動門！",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "502531"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "平安",
        "unit_id": 101112,
        "voice": "vo_adv_4013001_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抵～～達！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們想",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓哥哥看的就是這裡。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實啊，",
        "unit_id": 104911,
        "voice": "vo_adv_4013001_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我們",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "之前就接受了公會長的委託，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一直在調查這類遺跡或地下城。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n當然，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也常為了這件事踏入其中……",
        "unit_id": 104911
    },
    {
        "type": "background",
        "background": "502530"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是這種感覺，",
        "unit_id": 104911,
        "voice": "vo_adv_4013001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而這個遺跡……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n似乎連接著某個別的空間～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以我就想，只有我們兩個調查，會不會有點辛苦",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實……",
        "unit_id": 101112,
        "voice": "vo_adv_4013001_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是公會長命令我們調查的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我們才會叫來幫手。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是我們家哥哥你！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼弟弟，",
        "unit_id": 104911,
        "voice": "vo_adv_4013001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們走吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n最初的隊伍成員",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是姐姐喔♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_4013001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等一下，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有一張像信的東西掉在那邊喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃──",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼什麼……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「前方",
        "unit_id": 106811,
        "voice": "vo_adv_4013001_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為開發用測試區域，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "目前一般玩家禁止進入。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n由於不曉得會發生什麼事，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "踏入時務必要小心！」──",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「話雖如此，",
        "unit_id": 106811,
        "voice": "vo_adv_4013001_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒有名字的話很不方便吧～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果要取名……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就叫『黎明界』吧，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "懷著我從這個地方",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "創造世界的願景。」",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "靜流、璃乃",
        "words": "「……這是公會長的字跡吧。」\n「……這是公會長的字跡呢。」",
        "unit_id": 104911,
        "voice": "vo_adv_4013001_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就代表",
        "unit_id": 104911,
        "voice": "vo_adv_4013001_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個遺跡是公會長創造的？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把工作推給別人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "自己不知道在哪裡做什麼……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多虧如此",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才能見到弟弟，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "結果算是不錯吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然今天",
        "unit_id": 101112,
        "voice": "vo_adv_4013001_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "叫哥哥來是正確答案♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為就算有危險，只要哥哥在就放心了呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來吧，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "向前邁進！",
        "unit_id": 101112
    }
]