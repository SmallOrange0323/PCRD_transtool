[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這鎧甲看起來很堅固呢。",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我一眼就看出",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是熟練的工匠製作出來的喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你看，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這從頭到腳",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都經過徹底計算的曲線。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "細心研磨過，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n像鏡子一樣的表面……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不好。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我差點看自己看入迷了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……嗯嗯，",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是關於純小姐，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能映照出我的鎧甲，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真的是美極了呢！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了更展現出",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n純小姐嚴以律己的魅力，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "偶爾露個臉出來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該也不錯吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "克莉絲提娜小姐是個名人呢。",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的自信與強悍",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓她的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n化為絕對的存在了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該可以這麼說吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就連那旁若無人的態度",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都很迷人。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我要不要也來學學她呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話雖如此，",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她不管什麼事都靠力量去解決的這點我可無法認同呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "透過將那美貌化為力量，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "採取更柔軟的行動，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有時候也很重要吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "力量是力量，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美也是一種力量，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要充分發揮才行啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "人們的目光都會被",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "智那華麗的劍術給吸引過去呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "身為御久間流",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n繼承人的凜然之美，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可不是一朝一夕",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就能獲得的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要經過不懈的努力，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美才會寄宿在身上！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話說回來。",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她會對魔法少女這個詞彙",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "反應那麼敏感呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n雖然她好像喜歡魔法少女……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是似乎還隱瞞了什麼事的樣子。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "祕密跟美是密不可分的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這或許",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也跟她的美有所關聯？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說到茉莉的美，",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是那對英雄的熱情吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她那純粹的憧憬",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不只是接受的一方，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就連周圍的人也都為之所吸引。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得她之後，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也一直珍惜這份熱情就好。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的建議是……",
        "unit_id": 126311,
        "voice": "vo_adv_5120069_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不要只是跟平常一樣替虎虎加油，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n試著替其他英雄加油看看也不錯吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比方說身為美之化身的我，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或是我，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有我，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "之類的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你覺得如何？",
        "unit_id": 126311
    }
]