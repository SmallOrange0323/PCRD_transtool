[
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然穿出來見人的時候我感覺很害羞……",
        "unit_id": 130711,
        "voice": "vo_adv_6144202_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但我真的覺得，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這套花祭禮服很美。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n而且鈴莓小姐也有幫我特別加工過。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……就是，",
        "unit_id": 130711,
        "voice": "vo_adv_6144202_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我真的",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有適合穿這套衣服嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這裡現在只有我們兩個人，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請讓我聽你的真心話。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……",
        "unit_id": 130711,
        "voice": "vo_adv_6144202_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "被你一臉認真地這樣說……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我開始",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有一點害羞了……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你",
        "unit_id": 130711,
        "voice": "vo_adv_6144202_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "告訴我感想。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……我很高興。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是、",
        "unit_id": 130711,
        "voice": "vo_adv_6144202_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是嗎。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "既然沒有旁人在場你還是這樣說，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n看來是可以相信的呢……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你真的",
        "unit_id": 130711,
        "voice": "vo_adv_6144202_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是個廢柴變態可疑分子！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為我是小孩子",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就在耍我對吧！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你去吃路邊的雜草吧！",
        "unit_id": 130711
    }
]