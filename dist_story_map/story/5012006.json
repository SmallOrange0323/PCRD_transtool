        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n但",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "其實並非如此吧……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n你有著",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "互相信任的夥伴……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "如果我也有",
        "unit_id": 11111,
        "voice": "vo_adv_5012006_058"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "那樣的夥伴……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n可能就和你們一樣，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "有希望活下去了……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那是，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_059"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "只是戲言罷了。",
        "unit_id": 11111,
        "voice": "vo_adv_5012006_060"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n最後，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "告訴你們……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "就算我的意志消失，",
        "unit_id": 11111,
        "voice": "vo_adv_5012006_061"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "詛咒依舊仍在……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n曾經存在的痛哭",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "並不會停歇……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "在不遠的將來，",
        "unit_id": 11111,
        "voice": "vo_adv_5012006_062"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "渴求絕望的詛咒……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n可能會再次浮現在你們眼前……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不在意喔。",
        "unit_id": 101411,
        "voice": "vo_adv_5012006_063"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "無論多少次，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我都會奉陪。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對呀。",
        "unit_id": 104311,
        "voice": "vo_adv_5012006_064"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果妳還心存不滿的話，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我會不斷對妳說教的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "呵呵。",
        "unit_id": 11111,
        "voice": "vo_adv_5012006_065"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "還",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "真可靠呢……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n那就拜託了……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "說完這句話，哀嘆之女神\n就像漸晴時的霧一般，煙消雲散了。"
    }
]