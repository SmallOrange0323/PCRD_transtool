[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "馬車競賽的當天――"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "馬車的操作法也練習不少次了，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "今天就一起加油吧，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那麼，",
        "unit_id": 411,
        "voice": "vo_adv_5012006_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "馬車競賽終於要開始了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這次也聚集了許多無所畏懼的勇者，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "想要成為競賽英雄而前來！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "觀眾",
        "words": "唔喔喔喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_5012006_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呀！？　",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真是歡聲雷動啊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "開始緊張起來了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩和我組隊，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真的沒問題嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是嗎？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸嘿嘿，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "聽到前輩這麼說",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我覺得好像能更加努力了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "絕對不能扯後腿才是……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "運動神經比較好的人，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼想都是真琴啊。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然霞說，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "哀嘆之女神若出現，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我會比任何人\n都能更快感覺到，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然是這麼說，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但還是很不安……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_009"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不能示弱對吧……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "得回報大家的期待才行！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好……",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "集中、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "集中啊步未。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "深呼吸、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "深呼吸……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呼、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "哈。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "仔、",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_011"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "仔細想想，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是兩人一起坐馬車對吧。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就在這麼近的地方，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "簡直像做夢一樣……！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_012"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不行。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這可是攸關前輩的性命，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n這種時候怎麼能只顧自己……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我真是笨蛋笨蛋！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是、",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "時不時會碰到手臂吧……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然很害羞但又好開心……！　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那麼馬車競賽！　",
        "unit_id": 411,
        "voice": "vo_adv_5012006_014"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "Ready？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "Go！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦！？　",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "討厭，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "開始了嗎！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "出、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "出發吧！！",
        "unit_id": 105511
    },
    {
        "type": "still",
        "still": "501200601"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "在這場比賽的途中，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "哀嘆之女神一定會出現，盯上前輩。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "反過來由我們來埋伏她……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞雖然",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n外表看似穩重，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但其實是很大膽的人呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "馬車競賽是由",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n市區出發前往郊外，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "然後再返回市區的長程賽道。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "在那之中，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "市區的廣場附近，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是最多人聚集的地方……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "預測的襲擊地點，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_018"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就在那個廣場。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "往郊外去時，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "應該還不會有所行動。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "應該是會在賽事最高潮，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所有人目光集中的最終階段。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n所以從郊外回到市區的時候，應該就會發動攻擊……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對吧。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好的，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_020"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……那、",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_021"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可以",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "聽我說幾句話嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_022"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不太擅長表達自己的情感，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n可以拿來當做話題的事",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也都沒有，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "從以前就很難融入團體之中……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是最近，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_023"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我好像有了些改變……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和公會的大家是如此，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和這次認識的大家也是這樣。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真琴對於",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_024"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "初次見面的我，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n就像面對認識很久的夥伴一樣真心相待。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "霞對我說，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我一直看著前輩這件事情，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是能夠幫助前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "的力量。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我明明只是",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一直看著前輩而已……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這種幸福的感覺，",
        "unit_id": 105511,
        "voice": "vo_adv_5012006_026"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是前輩給予的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n前輩",
