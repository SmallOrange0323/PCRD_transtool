[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "敗給{player}等人之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "回過神來，她已身在洞窟之中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n失去了記憶，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "現在的她成為連要面對自身罪孽這件事都遺忘的可憐存在。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的名字是──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "阿剌克涅。"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "…………",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_000"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……好暗。",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_001"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n啊啊，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "實在是",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "太暗了……",
        "unit_id": 136011
    },
    {
        "type": "background",
        "background": "501791"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這裡是，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_002"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "哪裡呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n是在洞窟裡面嗎……？　",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "石頭，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_003"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好冰冷……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n身體，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好沉重……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_004"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是想做什麼呢？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n該去哪裡才好呢？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n說起來……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_005"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是誰……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不知道……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_006"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "什麼都不記得……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那個……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_007"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "有人，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "在嗎……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n無論是誰都好……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n聽見的話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請回答我……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "…………",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_008"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "誰都、",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_009"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不在呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是孤身一人呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_010"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "該怎麼辦才好呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "究竟是誰呢……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請告訴我……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_011"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n有誰……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "能有誰……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "…………",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_012"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "經過了多久呢……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_013"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n兩天？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "三天？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "還是",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "更久……？　",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "原本就已經、",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_014"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "什麼都想不起來了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n現在似乎連時間流逝的感覺，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "都變得模糊……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊啊……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_015"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好睏……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "明明很睏，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "卻又害怕睡著……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n醒來的時候，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "又要被迫體認到自己是孤身一人這件事，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n我已經",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "無法忍受了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_016"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是光。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "耀眼的光芒……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_017"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "溫暖的光芒……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "但是……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "多麼遙遠的光芒……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "如果朝著那道光前進，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_018"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "說不定會有什麼改變……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "說不定就能不再是一個人了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是阿剌克涅獨自一人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n彷彿被光芒吸引了一般，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "朝著洞窟外走去了。"
    },
    {
        "type": "background",
        "background": "502081"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……雖然樣貌變了很多……",
        "unit_id": 130011,
        "voice": "vo_adv_1360001_019"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n但魔力可是無法蒙混過去的。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這次一定要，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "將妳打到體無完膚！",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "那個……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_020"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n請問兩位……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "知道些什麼",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "關於我的事情嗎？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "阿剌……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_021"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "克涅？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "不好意思。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n我沒有",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "印象……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳在開什麼玩笑！",
        "unit_id": 130011,
        "voice": "vo_adv_1360001_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n難道說，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳連我們都不記得了？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "我",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_023"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "好像是失去記憶了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "什麼都不記得……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n不管是關於自己的事情，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "還是關於家人的事情。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "看來，",
        "unit_id": 130011,
        "voice": "vo_adv_1360001_024"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是我認錯人了。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳這樣的傢伙，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我們可不認識。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "不認識……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_025"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "是這樣嗎。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n太可惜了……",
        "unit_id": 136011
    },
    {
        "type": "background",
        "background": "502711"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "……",
        "unit_id": 136212,
        "voice": "vo_adv_1360001_026"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n這個人的名字，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "是叫「阿剌克涅」",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "嗎……？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是的，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_027"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "也許……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n別人是，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這麼稱呼我的。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "咦？",
        "unit_id": 136212,
        "voice": "vo_adv_1360001_028"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "也許，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "是什麼意思？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "其實，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_029"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我失去記憶了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "雖然，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是件丟臉的事。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我連自己的事都不太清楚……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n如果會造成困擾的話，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "就請把我",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "丟在這裡吧。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "那個，",
        "unit_id": 136212,
        "voice": "vo_adv_1360001_030"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "那個……",
        "unit_id": 136212
