    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼、",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那個……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "就麻煩您了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_059"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "呼……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "嗯……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "被騎士先生觸碰著，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好舒服……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……這麼說來……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_060"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n剛才，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "沒有……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "做惡夢？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n難道說……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是因為這位先生，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "待在我身邊的關係……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……有些事，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_061"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "想請騎士先生聽我說，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n可以嗎？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "雖然很丟臉……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_062"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n但我不知道往後，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "該怎麼活下去才好。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "多虧了騎士先生等人，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_063"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我與許多人成為了朋友。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "但是……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我依然，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是個空虛的存在。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "或許應該要找回記憶才對……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_064"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "但對我來說，過去的我",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是太過可怕的存在……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "現在的我什麼都沒有，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "只是個徒有巨大身軀的，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "渺小女性……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是的，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_065"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我明白……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生所說的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n可是……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "現在的我，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "連自己去尋找的力量都沒有了……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這是，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_066"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那個……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "非常抱歉。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n明明在說正經事，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我的身體卻……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "啊呣……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "湯，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "很好喝。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_067"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "想活下去的、",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_068"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "證明……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n明明是連活著的方法都不知道的我……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……總覺得，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_069"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "變溫暖了。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "無論是心，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "還是身體。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……回想起來，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_070"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生從第一次見面開始",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "就對我很溫柔。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n現在，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "感覺內心深處殘留的冰塊，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "也正在一點一點地融化。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不光是言語，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_071"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n騎士先生這個溫暖的存在",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "正在照耀著我……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "您，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_072"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是光。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n照亮了身處寒冷、",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "漆黑之地的我的光芒……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "沒關係的。",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_073"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "能感覺到騎士先生的光芒，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n一定就是屬於我的幸運。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "謝謝您。",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_074"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n湯也，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "多謝款待。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼……",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_075"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我就恭敬不如從命，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "稍微睡一下。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……晚安，",
        "unit_id": 136011,
        "voice": "vo_adv_1360001_076"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "光芒之人。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自從以現在的模樣甦醒之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "阿剌克涅從未熟睡過。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但她卻在此刻，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "發自內心感受到了安穩，終於沉沉睡去。"
    }
]