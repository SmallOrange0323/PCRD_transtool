[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇……☆",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n廣場還是像以往一樣生氣蓬勃的耶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "熱鬧得讓人都開心了起來！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為是午餐時間，每家餐廳都傳來了好香的味道～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子都餓了♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們要不要先去填飽肚子呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是剛才在育幼院吃完午餐的嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從以前就一直這麼想了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您的胃袋難不成破了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有呀……",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也不知道還會發生什麼事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總想要多攝取一些營養嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像也說明過幾次了。",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的『皇家裝備』，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在使用上所必須消費的熱量，可不是開玩笑的勒。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但若是脫下了它，",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "戰鬥力又會大幅降低了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為貪吃佩可小姐原本是位公主殿下，",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但卻能夠在最前線積極奮戰，想必也都是託這個裝備的福……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也正在鍛鍊。",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要不是太過艱難的狀況，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就交給在下來處理吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也不想讓小孩子去戰鬥就是了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦！",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有攤販唷～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以去買來邊走邊吃嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "悉聽尊便。",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……小攤販的料理，",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐很喜歡吃呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好陣子沒有消息了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道凱留小姐是否過得還安好呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "依主人說詞來看……",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎是尤絲蒂亞娜手底下的一名人物呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是擔心她的安危，",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有生命危險就好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全聯絡不上呢……",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她也真是的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是堅持不把聯絡方式告訴我們。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為她說她受僱於王宮，",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以拜託了有管道的咲戀替我們調查過了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是聽說她出差",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以不在宮內呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也無從得知這消息是真是假，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真令人擔心。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留她好像",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也處在奇妙的因緣之中。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真希望我們能再和樂融融地一起",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "圍繞在餐桌旁呢。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "200700401"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哈啊～",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哈啊～……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "解、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "解決了？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "　魔物",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "被解決掉了嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯。",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n真的是相當弱的魔物唷，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "弱到令人好奇到底是怎麼闖到城裡的程度呢。",
        "unit_id": 100611
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯～……",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "近些日子的【王宮騎士團】，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n似乎沒有正常地在運作呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n城裡警備，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像因此鬆懈了不少呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這次是剛好能對付，",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n若是被更高級的魔物給入侵，事情可就不得了了唷。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的。",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n最近不管是這還那，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都瀰漫著濃濃火藥味啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說的沒錯呢。",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n只要魔物一作亂……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對常被誤會成魔物的我們，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n印象也會更加差了呀。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然現今，",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也已經不是那種時代就是了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯。",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "比起那種事，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們快點來清理掉這些被打倒的魔物吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要先聯絡負責清掃的公會……說起來，",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "清掃的費用，讓政府的公所來支付就好了對吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔呵呵～",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這專門溶解衣服的神奇黏液，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就偷偷給它留一些下來好了♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳、",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳要留下那種東西做什麼啦？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n拜託妳一滴也不剩，全部清掃乾淨好嗎～！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嗯嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是發生了什麼騷動了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n似乎是有魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "入侵到了城裡的樣子呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然看起來像是弱弱的魔物就是了。",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後那孩子們就出手退治了～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣的感覺吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得那兩位女孩子，",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "長得一模一樣呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難不成是雙胞胎嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n果然主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也認識這些……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "女孩子嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦，",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難怪您看起來一副早就知道些什麼的樣子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該不會……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您和兩位是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早已經有認識了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望您還能適可而止一點呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2007004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成這個世上，已經沒有您不認識的女孩子了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯？",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_037"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "{player}哥哥♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請別看過來呀！",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_038"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n因為不幸的事故，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因此姊姊的衣服被溶掉了喲♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸！{player}？",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼每次都挑這種時間出現呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "明明在我最危機時候，",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "連個影子都沒看到的啊！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就是這一點讓人超不爽呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這還真是熱鬧呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有哪裡有受傷吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯。",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_042"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊那輕微的暴露行為，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n傷及社會地位了？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚哇呀，",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_043"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳好慘呀……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只、",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_044"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只不過是衣服稍微有點溶解掉了而已！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不要說得好像是我真的脫光光到處遊走了一樣呀～～！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚～……",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_045"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n真是受夠了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也太衰了啦。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果以茜里的角度……",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_046"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n能親眼見到就連當今戀愛喜劇漫畫中都看不太到的橋段，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可算是相當幸運的呢♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸嘿嘿，",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_047"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "等很久了呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "{player}哥哥♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "聽說您有事要找忍吧。",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_048"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n可以替您牽線唷，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "畢竟她和我們也是同個公會的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來妳們本來就在等我們了呀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n確實……{player}好像有講過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總之就先到廣場上和帶路的人會合～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來，",
        "unit_id": 105812,
        "voice": "vo_adv_2007004_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們就是替我們帶路的人了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以那位",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "名為「忍」的人……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n正是我們找尋的那位占卜師嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯。",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_051"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n那人呀，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "動不動就在巷弄間徘徊，有些隨心所欲捉摸不定呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以偶爾也有想要見上一面，卻怎麼都找不到的情況。",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_052"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但如果讓我們來帶路，就保證能夠讓妳們見面囉。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然有時候，",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_053"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "完全搞不懂忍她在想些什麼。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但似乎還是有",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好好的珍惜茜里和其他公會夥伴呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唔嗯。",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_054"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n而且也算是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有受過{player}的關照呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n只是引見一下同伴這點小事還是做得來啦，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "別忘了要感激我唷。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "往這裡喔，",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_055"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "跟我來。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "自我介紹之類的事，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "先等找到落腳之處後再說吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100611,
        "voice": "vo_adv_2007004_056"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "等茜里一下！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "若需要總之還是先把這些神奇的黏液，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n全部都回收起來，再找個地方來保管好呢♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 102211,
        "voice": "vo_adv_2007004_057"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這種齷齪下流的黏液，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n趕快拿去哪個水溝裡倒掉啦～！？",
        "unit_id": 102211
    }
