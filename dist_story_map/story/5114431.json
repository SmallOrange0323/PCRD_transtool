[
    {
        "type": "background",
        "background": "501952"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 125211,
        "voice": "vo_adv_5114431_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "人潮總算減少了哪。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們也",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "稍微休息一下吧。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好想吃甜食啊……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了想吃甜食的莫妮卡……",
        "unit_id": 125111,
        "voice": "vo_adv_5114431_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鏘鏘──！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我準備了特製焦糖鯛魚燒，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n加上超甜奶茶的套餐給妳喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可以一直續杯續鯛魚燒喵。",
        "unit_id": 125111,
        "voice": "vo_adv_5114431_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以妳想吃多少就吃多少喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔嗯嗯……",
        "unit_id": 125211,
        "voice": "vo_adv_5114431_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在還是營業時間，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如此強大的誘惑……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在又沒有客人，",
        "unit_id": 125111,
        "voice": "vo_adv_5114431_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "吃點員工餐沒問題的喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "況且，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "面對這種誘惑，就該老實地順從喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這家店的店名就是……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "偷吃的貓！",
        "unit_id": 125211,
        "voice": "vo_adv_5114431_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "確實，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "珠希妳說得對。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那我就心懷感激地享用吧。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "──啊，",
        "unit_id": 125111,
        "voice": "vo_adv_5114431_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像有客人來了喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "歡迎光臨喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哎呀，",
        "unit_id": 125211,
        "voice": "vo_adv_5114431_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不行不行。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也得工作才對。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這鯛魚燒我晚點再享用吧。",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──歡迎光臨！",
        "unit_id": 125211,
        "voice": "vo_adv_5114431_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n歡迎來到貓與懷舊點心的咖啡廳",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「Naschkatze」！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n請在這裡",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "盡情地放鬆享受吧！",
        "unit_id": 125211
    }
]