[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔～唔～嗯……？",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，我想到了！",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就是這裡，在這裡放騎士棋子……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿，這樣就將死囉～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊！",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不是那邊的騎士，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是將這邊的騎士移到這格……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n玩西洋棋時，我若一直冒失地把棋子碰倒就玩不下去了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以才讓你幫我移動棋子。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你快要輸的時候，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就故意假裝誤解我的指示，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n將棋子放在不對的格子上對吧～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不能當狡猾的人喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，真是的，我就說不是那邊的騎士！",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哼～你意外地不服輸呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一旦攸關比賽，就變得非常認真呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為你原先給我的印象，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是相當穩重溫柔的人……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你會專注於遊戲中，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "變得一心想著「我想贏！」「我不想輸！」，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這一點讓我很意外。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，我是在稱讚你！",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣不是很好嗎，感覺很像男孩子……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，你想要假裝不小心移動棋盤對吧？",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣不行喔～要更堂堂正正……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇啊！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我失去平衡把棋盤踢翻了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒辦法呢，這次的輸贏就當沒這回事吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不小心沉迷在遊戲中了呢～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "已經相當晚了啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你……如果不趕快回家的話，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n家裡的人不會擔心嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，到你贏為止都不回家？",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是，你應該失去記憶了吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你是剛剛才學會規則的初學者，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要贏我還早得很喔～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "像這種桌上遊戲，我可是接受過父母的訓練喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為要接待客人時，這可是必要的技能呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "麻將、撲克牌，還有花牌等我都很擅長喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然做家事總是冒冒失失，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但我好像很擅長玩遊戲。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可能是因為要做的事情明確，讓我能集中精神吧。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，今天你真的該回去囉。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "最近的治安不太好，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n天色太暗的話會很危險的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且……",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你不是和像妹妹一樣的女孩住在一起嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果你不回去的話，她會擔心的喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要比賽的話，我把棋盤和棋子借給你……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你帶回去練習。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那麼再見，請再來玩喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我隨時都非常歡迎你♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇啊！？",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你又發光了喔？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是什麼，看起來……不像魔法？",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "510170"
    },
    {
        "type": "still",
        "still": "102500801"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "糟了糟了糟了～！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要遲到了～！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，呀啊！？",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對對對、對不起！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n撞到你了……！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，是！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你好♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，現在可不是悠閒打招呼的時候啊！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你沒事吧？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我撞到你的時候，你的頭撞到電線桿了喔！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你、你流血了！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我現在替你治療喔？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，是！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我沒事！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "多虧你馬上就扶住我，我才毫髮無傷～♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但你因為接住我而受到衝力，",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n頭撞到電線桿了喔！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你正在流血，我來替你治療吧！",
        "unit_id": 102531
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿咻……",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，治療完成。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我很冒失，常常跌倒，",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我會隨身攜帶急救箱之類的東西。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的非常對不起喔！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是說，你為什麼",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會在我們家宅邸前呢？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "找大小姐有什麼事嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯哼嗯哼……？",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為你剛好走到附近，想著若能見到大小姐就好了～",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以才到宅邸這裡嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，你想見的不是大小姐而是我？",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為為、為什麼想見我這個身分低微的女僕？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你想要一雪前陣子下將棋的恥辱嗎？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "前陣子我們順勢比了一局呢。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你從那之後不斷練習變強了，所以前來再次挑戰？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔～",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n抱歉，雖然我很想陪你，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但是今天有點困難。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐有重要的聚會，",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n和父母一起出國了喔。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也因為有事不能同行，而留下來看家。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今天大小姐終於回國了……",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我正要去機場迎接她。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是我因為學校的事情耽擱，已經快遲到了。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "再這樣下去，會讓大小姐在機場空等！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所、所以我才這麼急！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "很抱歉，將棋就等到下次吧～！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哇哇？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛剛快跌倒時，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n將包包裡的東西都掉出來了！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我得撿起來～！　",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n裡、裡面還放了餐廳的預約券！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你幫我撿起來了呀。",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的幫了大忙～各方面來說我真的很抱歉！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、那麼，我就先失陪了喔！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對不起！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚哇啊啊！？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、我又跌倒了……",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，你怎麼了？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，因為擔心我，所以你要陪我去？",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "反正你今天很閒……？",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝、",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n老實說，真是幫了我大忙，",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我如果一著急，每走幾步就會跌倒！",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我快跌倒的話，請扶住我喔！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n麻煩你了♪",
        "unit_id": 102531
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐，鈴莓現在就過去～！",
        "unit_id": 102531,
        "voice": "vo_adv_1025008_051"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鈴莓她真的總是慌慌張張的呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1025008_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n該說無法放著她不管嗎……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，她並不是什麼都做不好的沒用女孩對吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟她似乎很擅長玩遊戲呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1025008_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大概是分心或著急時，才會搞砸事情吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是集中力的問題嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過……這輪不到我來思考，",
        "unit_id": 190011,
        "voice": "vo_adv_1025008_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該是鈴莓自己和你要面對的事情呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要好好思考，細心地支持她喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，看起來似乎不用我再多說。",
        "unit_id": 190011,
        "voice": "vo_adv_1025008_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今後也請像這樣，幫助你身邊的人喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你一定會有得到回報的一天。",
        "unit_id": 190011,
        "voice": "vo_adv_1025008_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我的預言相當準喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別看我這樣，我在「這邊」的地位就像神一樣。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，你醒來了嗎……？",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為你突然睡著了……",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我就先將你搬到臥室。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我一個人搬不動，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以就請魔像幫忙了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你能起來嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你好像不太舒服呢～沒事吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果不能動的話，不要勉強，請繼續睡吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會設法用通訊魔法，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_061"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n和你入住的飯店取得聯絡。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "通訊魔法非常難，所以似乎會很辛苦。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_062"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但我好歹也是個魔法師，",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_063"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我會努力的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……又睡著了呢。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_064"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為動腦筋玩西洋棋，所以變得想睡了嗎～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n欸嘿嘿，好像寶寶一樣♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請好好休息，主人。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_065"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "開～玩笑的……",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_066"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你不是我的主人呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025008_067"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果這個樣子讓大小姐看到的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "或許會讓她吃醋嫉妒呢……♪",
        "unit_id": 102511
    }
]