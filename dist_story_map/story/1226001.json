[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【破曉之星】和{player}，\n從南島度假回來後過了幾天──"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在南島",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "玩得真開心啊……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我忍不住",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說出來了呢。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n對騎士先生說了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「最喜歡你了」這種話……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是因為當時是在那座火熱又耀眼的島，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我才說得出口嗎……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚……！！",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我並不覺得後悔。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n因為那是……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的……",
        "unit_id": 100213
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真心的……！",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呀啊啊啊啊！",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你什麼時候開始在那裡的！？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃，",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你在是完全沒有問題啦……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n只不過……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我希望你能再",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "出點聲音",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你今天來是有什麼事嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "幫忙騎士先生的，",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "打工……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣啊，",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是很想",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "直接答應啦……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不過日和跟怜今天都不在。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我一個人也",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "幫得上忙嗎……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的嗎？",
        "unit_id": 100213,
        "voice": "vo_adv_1226001_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……你被要求",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「要和女孩子兩個人一起去」？",
        "unit_id": 100213
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣和{player}總之還是來到了打工雇主的「社長」所在之處──"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_010"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "等你們很久了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "妳叫什麼名字？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "優衣？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "請多指教囉～",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "這是名片。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我在經營舉辦活動的公司。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n我是社長，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "這位是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我的專務",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "兼妻子。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……你們好。",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_011"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "那麼",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_012"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "進入正題。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n想請兩位協助的活動就是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "專為情侶設計的",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "海灘慶典",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗎……？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "對。",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_014"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "有看到嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "那邊一整排的夏季活動設施。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n那些",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "全都是情侶專用的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "很厲害吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "這一定會爆紅的～",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_015"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n遊客肯定會像",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "那朵積雨雲一樣",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "湧入這裡。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……負債也像那朵積雨雲一樣膨脹就是了。",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_016"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "那種事",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_017"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "不重要啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "所以，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "想請兩位來當這個慶典的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "「體驗測試人員」。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "體驗測試人員……？",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_018"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "對。",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_019"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "其實在那邊的各項活動設施，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n都還沒確認完",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "其安全性與實效性。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n所以想拜託兩位",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "幫忙做事前檢測。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也就是說，",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個工作是要我們兩個，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n去試玩情侶活動",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的意思嗎……？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "對，",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_021"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "一點也沒錯。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原、",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原來如此……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我跟騎士先生……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一起玩",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "情侶取向的……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "………………",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_023"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……你們兩個有在交往嗎？",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_025"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "那種小細節",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_026"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "不重要吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這很重要好嗎？",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_027"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n難道",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "你又想隨便檢測讓實際舉辦時出大包，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n辦成讓負債滾雪球的活動嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "不、",
        "unit_id": 1411,
        "voice": "vo_adv_1226001_028"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "不是啦，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我不是那個意思──",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我已經受夠陪著你打腫臉充胖子了。",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_029"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "不好意思，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "可以請你們告訴我嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "只要說有沒有在交往就好。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n抱歉問了這麼隱私的問題。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊不會！",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……說得也是。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n畢竟這是情侶取向的慶典體驗測試人員……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會問也是正常的。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我跟騎士先生",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "之間並不是",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "情侶……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "關係。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "啊，",
        "unit_id": 6511,
        "voice": "vo_adv_1226001_032"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "你們沒有在交往啊？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "感覺好意外。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……是的。",
        "unit_id": 122611,
        "voice": "vo_adv_1226001_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以就不錄取了",
        "unit_id": 122611
    },
