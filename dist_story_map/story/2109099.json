[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對！",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在不是寒暄問候的時候啊，真是的！！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到底",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "發生了什麼事？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n情況簡直一團混亂，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也一頭霧水……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總、",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我試著整理了情況……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次重要的是，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不只這次而已……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對於這個故事而言，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "十分重要的是……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "叫厄莉絲的存在。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管我想過",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "除了霸瞳皇帝之外，還有其他危險人物存在……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "坦白說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使是我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也沒料到會出現那種傢伙。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然美空說了很多，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她並非單純地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是優衣的複製品……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優衣的願望，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為霸瞳皇帝的關係而失控……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n世界",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "變成了這個樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n從「禁錮」算起，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "產生了許多悲劇……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……優衣……",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子……",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n被迫面對殘酷的真相。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她深受傷害，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "精神幾乎崩潰。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我明明想保護她。",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明想找出方法，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "避免這種情況發生。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "卻只能旁觀……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……吶，你。",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然我想你也",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "承受了很多打擊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n受到了傷害。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你……",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幫助她們。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不只優衣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有叫雪菲的女孩",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "與小可可蘿。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n以及那些與你締結了羈絆的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "許多女孩們……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "情況真的很驚險呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒想到",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "克莉絲提娜和似似花她們，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n居然會再次與你們為敵。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若不是【憤怒‧軍團】那位叫阿澤爾德的大叔",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓大家逃走……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的會",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "全軍覆沒吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……雖然那個人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像也有種種苦衷……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……對了。",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n阿澤爾德",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似乎將你們送到了獸人族之國。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管是敵人，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個判斷下得很好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個國家的實力僅次於蘭德索爾。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最重要的是，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那裡有【哞哞自衛隊】的大家，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有你可靠的夥伴們。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "自從霸瞳皇帝",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "與討厭的貴族們一起失勢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n蘭德索爾對獸人族的歧視減少之後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真步他們，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像回到了故鄉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們突然以空間跳躍出現，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓他們大吃一驚。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "多虧他們迅速給予治療，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "保住了性命。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以……",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們先在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他們那邊",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "慢慢休養身心的創傷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就要開始反擊囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對手強大無比，",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "充滿謎團。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然對付起來不是麻煩兩字足以形容的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我相信你們辦得到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為……",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n即使處在絕境之中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們還活著。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為你們的羈絆，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "甚至擊敗了霸瞳皇帝。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以……",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要輸啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "英雄……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………！？",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_024"
    },
    {
        "type": "background",
        "background": "500271"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……咦……！？",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n什、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有、",
        "unit_id": 190011,
        "voice": "vo_adv_2109099_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n正在干涉",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我播放訊息中的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "本體！？",
        "unit_id": 190011
    },
    {
