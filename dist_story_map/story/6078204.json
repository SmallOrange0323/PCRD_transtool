[
    {
        "type": "background",
        "background": "501450"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "虐待狂先生。",
        "unit_id": 119112,
        "voice": "vo_adv_6078204_000"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花覺醒了愛與希望之力，",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "當上魔法少女了。",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n空花要把這股力量用在正確的方面，",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "讓街上的人們都露出笑容。",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "沒錯──",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "要把所有人都變成被虐狂，",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "帶給全世界幸福！",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "什麼？",
        "unit_id": 119112,
        "voice": "vo_adv_6078204_001"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "有搞錯什麼嗎……？",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n魔法少女不是這樣的存在？",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "可是空花，",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n基本上只擁有把人變成被虐狂的力量……",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "該怎麼做才好呢……？",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "謝謝你，",
        "unit_id": 119112,
        "voice": "vo_adv_6078204_002"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "虐待狂先生！",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n一起不斷奮戰下去吧……！",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "直到讓整個世界",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "都充滿被虐狂的那一天……！",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "咦……！",
        "unit_id": 119112,
        "voice": "vo_adv_6078204_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "只要有、",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花……？",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "怎麼會，",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "居然說了「空花是專屬於我的被虐狂」",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這種話……",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花的",
        "unit_id": 119112
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "愛與希望之力會太過高漲啦……",
        "unit_id": 119112
    }
]