        "voice": "vo_adv_9007014_011"
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "那個啊！",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "一碰到莉瑪小姐全身毛絨絨的觸感，",
        "unit_id": 193511
