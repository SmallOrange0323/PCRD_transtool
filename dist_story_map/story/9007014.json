        "voice": "vo_adv_9007014_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n沃爾加諾先生，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那是什麼意思？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "因為，",
