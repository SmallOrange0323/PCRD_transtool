    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "\n",
        "unit_id": 193511
    },
    {
        "type": "dialogue",
        "name": "沃爾加諾",
        "words": "多虧了莉瑪小姐的毛絨絨，",
        "unit_id": 193511
