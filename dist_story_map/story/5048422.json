    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "奇怪……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們贏了？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哈、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哈哈……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "成、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "成功了……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！",
        "unit_id": 100611,
        "voice": "vo_adv_5048422_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳沒事吧！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 113811,
        "voice": "vo_adv_5048422_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我沒事啦……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可能是繃緊的神經一下子鬆懈下來，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n突然全身沒有力氣了……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唉，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我這樣子",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還真是狼狽啊。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才沒那回事！",
        "unit_id": 100611,
        "voice": "vo_adv_5048422_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為姊姊妳在我的身邊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n一直保護著我，我們才能戰勝的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不管別人怎麼說，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊都是最厲害的！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里……",
        "unit_id": 113811,
        "voice": "vo_adv_5048422_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝謝妳。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "能聽見妳這麼說，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我作為雙胞胎的姊姊，面子也保住了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811,
        "voice": "vo_adv_5048422_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我能努力到這一步全都是因為有妳陪著我。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "多虧有妳，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我才有辦法戰鬥到最後一刻。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯，",
        "unit_id": 100611,
        "voice": "vo_adv_5048422_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳說得對！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要我們兩個同心協力，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就是所向披靡的雙胞胎！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n嘿嘿，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "以後也請多關照囉，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊♪",
        "unit_id": 100611
    }
]