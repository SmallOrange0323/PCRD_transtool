[
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "妳們看，",
        "unit_id": 112411,
        "voice": "vo_adv_0000316_000"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "小凜、未央！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n盆栽小花它",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "越來越大了……！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "到底為什麼會變成這樣呢！？",
