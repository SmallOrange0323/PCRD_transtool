    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "似乎是呢。",
        "unit_id": 112511,
        "voice": "vo_adv_0000316_003"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n難不成，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "可以從那個地方爬上去嗎？",
        "unit_id": 112511
    },
