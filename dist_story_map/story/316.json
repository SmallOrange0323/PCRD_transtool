        "type": "dialogue",
        "name": "卯月",
        "words": "那個……",
        "unit_id": 112411,
        "voice": "vo_adv_0000316_004"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我們要不要去看看呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "或許，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可以知道盆栽小花長大的原因",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n也說不定。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那樣好像很有趣！　",
        "unit_id": 112611,
        "voice": "vo_adv_0000316_005"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "大冒險耶！",
        "unit_id": 112611
