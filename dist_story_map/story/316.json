    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯……",
        "unit_id": 112511,
        "voice": "vo_adv_0000316_001"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n這是代表盆栽小花",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "對偶像的欲求，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n又變得更高了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "也許呢！",
        "unit_id": 112611,
        "voice": "vo_adv_0000316_002"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……咦？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n欸，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那邊，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是不是變得有點像入口啊？",
