[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管怎麼走，",
        "unit_id": 105811,
        "voice": "vo_adv_9051155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是到處都是沙子耶～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果能找到個能休息的地方就好了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011,
        "voice": "vo_adv_9051155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們一直重複在沙丘",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "爬上爬下的……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且不管走到哪裡都熱得要命……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不行了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟是沙漠，",
        "unit_id": 105911,
        "voice": "vo_adv_9051155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這也是沒辦法的事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話是這麼說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不找個地方休息不行……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐已經坐下來了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那",
        "unit_id": 106411,
        "voice": "vo_adv_9051155_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們就在這裡休息吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有個好主意，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等我一下哦？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106011,
        "voice": "vo_adv_9051155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在做什麼呀？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳怎麼有那麼大塊的布？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且顏色還那麼鮮豔……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還有",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那邊那個像長棒子的東西也是。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯，",
        "unit_id": 106411,
        "voice": "vo_adv_9051155_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我把之前打倒的魔物的花瓣帶來了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n因為它又薄又結實，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想說可能會派上用場。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這邊的",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是那隻魔物的樹枝。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "把這個",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "拉緊然後",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "再組合起來……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_9051155_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我知道了☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是帳篷吧！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲真厲害！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "除了吃的以外，什麼都想不出來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105911,
        "voice": "vo_adv_9051155_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是嶄新的觀點。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_9051155_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "進來裡面",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以擋住陽光很涼快，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且意外地寬敞。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那隻魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是棲息在沙漠中，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以它的表皮",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能對日曬與乾燥的抗性也強。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的耶……",
        "unit_id": 106011,
        "voice": "vo_adv_9051155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實很涼快……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "意外地光滑，摸起來很舒服耶。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸雪菲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個還有很多嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我還有好幾塊預備的。",
        "unit_id": 106411,
        "voice": "vo_adv_9051155_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳需要的話就請用吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_9051155_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我就拿囉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "涼涼的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像很適合用來睡午覺……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼啊……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_9051155_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "裹在花辦裡",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "睡著了耶～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像黃色的高麗菜捲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來好好吃……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可見這有讓凱留小姐",
        "unit_id": 105911,
        "voice": "vo_adv_9051155_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能忍不住睡著的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n舒適程度。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是慧眼獨具。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105911,
        "voice": "vo_adv_9051155_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有什麼聲音……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 105911,
        "voice": "vo_adv_9051155_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那魔物往這裡來了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n恐怕",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是之前逃掉的那隻……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們迎擊吧！",
        "unit_id": 106411,
        "voice": "vo_adv_9051155_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留也",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "別再悠閒地睡覺了！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼嚕呼嚕…………",
        "unit_id": 106011,
        "voice": "vo_adv_9051155_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再來一碗……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嘿嘿嘿嘿……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說凱留，",
        "unit_id": 106411,
        "voice": "vo_adv_9051155_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "快起床了！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不行，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "她睡得很熟……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來只能靠我們自己想辦法了……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好！",
        "unit_id": 105811,
        "voice": "vo_adv_9051155_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那就不要吵醒凱留……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "悄悄地去吧！",
        "unit_id": 105811
    }
]