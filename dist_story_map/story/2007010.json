[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要啟動轉移魔法了喔。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "期待期待♪",
        "unit_id": 100711,
        "voice": "vo_adv_2007010_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這次要去哪裡呢？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n希望是個全國民的主食都是布丁、",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "夢幻的布丁王國呦！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這塊大陸上並不存在那種國家唷。",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n別在這節骨眼給妾身喧鬧呀，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳是個乖孩子對吧……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "移轉魔法可是極度難以操作的高等魔法呢，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在使用上若不細心專注一點可不行吶。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "設置在城裡的這個魔方陣，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就算是全盛時期的妾身，\n也需要費上一番功夫才有辦法啟動喔。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若在使用上稍有差池，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就會永遠受困於空間的狹縫裡了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那麼為了萬全的準備，",
        "unit_id": 102211,
        "voice": "vo_adv_2007010_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n讓伊莉亞變成大人比較好不是嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯嗯。",
        "unit_id": 100611,
        "voice": "vo_adv_2007010_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n畢竟是成人才能做的行為呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還看什麼呢{player}哥哥，",
        "unit_id": 100611,
        "voice": "vo_adv_2007010_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n快抱抱伊莉亞呀！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n要溫柔一點呢……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是讓我們安份一點吧，",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大家。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可不能干擾到了",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "伊莉亞的專注力啊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來……",
        "unit_id": 105913,
        "voice": "vo_adv_2007010_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡的大家，都要一同前往嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是這個人數……",
        "unit_id": 105913,
        "voice": "vo_adv_2007010_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就像是在這魔方陣內疊羅漢一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺有點壅塞呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好。",
        "unit_id": 105913,
        "voice": "vo_adv_2007010_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管怎麼樣都會緊挨在一起……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家散發出的熱氣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像在烤箱一樣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……？",
        "unit_id": 105913,
        "voice": "vo_adv_2007010_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": " ",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然有點擠，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但還不到連站的空間都沒有。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這麼一大群人一同前往，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許會造成對方的困擾也說不定。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "由於應該只有我們",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "和似似花見過面，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以就由我們來引見吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n當然，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "前提是不會造成你們的麻煩的話。\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她的警戒心相當地強……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果只讓{player}你們單獨前往可能也見不到面，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n沒處理好的話，甚至有可能被她當成入侵者攻擊也說不定。",
        "unit_id": 103111
    },
    {
        "type": "still",
        "still": "200701001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "除了{player}的身體接觸之外，",
        "unit_id": 104411,
        "voice": "vo_adv_2007010_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n難道就沒有其他變回這個姿態的方法了嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n總覺得每次",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都害妾身要平白無故地臉紅心跳啊。",
        "unit_id": 104411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不公～平。",
        "unit_id": 100611,
        "voice": "vo_adv_2007010_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也想有個，不被哥哥抱一下就會呼吸困難～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n之類的設定呀♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "設定什麼的，",
        "unit_id": 102211,
        "voice": "vo_adv_2007010_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n姑且他也是個男孩子，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳也再多抱持一點警戒心吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是姊姊妳太過於警戒啦～",
        "unit_id": 100611,
        "voice": "vo_adv_2007010_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "{player}可是個木頭唷，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n喜歡的話，不再積極一點發動攻勢可不會被注意到的唷。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才才才、",
        "unit_id": 102211,
        "voice": "vo_adv_2007010_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才沒有喜歡呢！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……哇哇，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "魔方陣開始發光了！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104411,
        "voice": "vo_adv_2007010_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "準備完成了。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "確定要去似似花的研究所，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有錯吧？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為那棟研究所本身，",
        "unit_id": 104411,
        "voice": "vo_adv_2007010_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n有針對魔法的防衛措施……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若只是用轉移魔法是沒辦法直接抵達的，",
        "unit_id": 104411,
        "voice": "vo_adv_2007010_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n總之先穿越到那附近再說囉。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就麻煩妳囉～。",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哎呀，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "忍不住興奮期待起來了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是謹慎一點為妙吧。",
        "unit_id": 105913,
        "voice": "vo_adv_2007010_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟，對方可是身分不明的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『七冠』喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2007010_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請絕對不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "離開在下的身邊呢。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200701002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真是一片狼藉呢……",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_028"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宮子，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒事吧？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳身為幽靈，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "較容易受到魔力的影響呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為比起擁有肉身的生物來說，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳對於魔力更沒有防備吶。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n有沒有受到移轉魔法的影響，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "靈體出現了什麼不適呢？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒事沒事的喲～",
        "unit_id": 100711,
        "voice": "vo_adv_2007010_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子可是很強的喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "欸嘿。",
        "unit_id": 100711,
        "voice": "vo_adv_2007010_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n剛剛才吃了一大堆布丁呢，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在可是活力充沛的喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "反倒是伊莉亞，",
        "unit_id": 100711,
        "voice": "vo_adv_2007010_033"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "又變回小孩子了喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這樣子完全沒辦法戰鬥吧，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "別擔心宮子會保護妳的喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n因為在啟動移轉魔法時，耗費了許多魔力吶，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是欲哭又無淚呀……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的感覺呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯……",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n總之，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看起來像是全員都成功移轉到這了呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算撐過來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家辛苦囉～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以放下心了呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以這裡就是那位",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似似花的研究所嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "正確來說，",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是通往研究所的地下遺跡喔。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n從這裡開始走，通過特定的路徑之後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才能真正抵達似似花的研究所。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她那個研究所",
        "unit_id": 104412,
        "voice": "vo_adv_2007010_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "位於地底下。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而地上則是有座山脈作為天然的要塞，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因此幾乎沒幾個人到得了那。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不只如此，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還有些魔物在附近晃來晃去的。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "戒備相當森嚴",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的樣子呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那位叫似似花的人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼不惜遠離人群到這種深山中……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且甚至要隱匿蹤跡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "躲藏到地底下呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道，",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她是觸犯了重大禁忌的罪犯之類的嗎……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會在這個連公權力也無法觸及的祕密基地進行研究？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不無可能。",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n雖然並不清楚詳細情況就是。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "畢竟，",
        "unit_id": 103111,
        "voice": "vo_adv_2007010_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們的身分也不太適合攤在光天化日之下。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因此互相不打探對方的底細，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是我們無需言說的共識。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔嗯，",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺就像是黑社會之間的交流呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能有機會和這潛藏在暗處的可疑人士接觸，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還真是僥倖呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是用一般的方法來找的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2007010_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想應該是找不到的吧。",
        "unit_id": 105812
    }
]