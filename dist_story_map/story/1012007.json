[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音臉色大變地來到\n一如往常過著平靜日子的{player}面前。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "終於找到你了――！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不好了啊，不好了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我做了預知夢！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你知道預知夢嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n是夢見未來之事的超能力……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的嗎！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你也是超能力者！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……因為夢到咖哩，所以中午就吃咖哩？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、那才不是預知夢呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒錯沒錯！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "預知夢使用了超能力，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以我剛醒來又覺得睏，睡了回籠覺呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不是說這些話的時候了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "聽我說！ 蘭德索爾要不見了喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我在預知夢裡看見了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今晚會有隕石掉落在蘭德索爾喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n是非常非常大的隕石！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖是這麼說，你也不會相信吧？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這麼離奇的事情……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的嗎！ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝――！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你果然是最棒的朋友呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你有一半是相信的？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，即使只有這樣我也很開心喔。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但、但是，該怎麼辦？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n變成那樣的話，大家會很困擾吧……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n最喜愛的城鎮沒了，很令人傷心呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也對呢。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n至少要讓城鎮裡的人們去避難――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……但是，他們不會相信這種事吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也不能到處去說我的能力……",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就算說了超能力的事，也不知道有沒有人會相信……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦咦！？ 怎麼做？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我覺得那是不可能的……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……什麼什麼？ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你忽然想到什麼了！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 之前我睡很飽的時候？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，原來如此！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果我像前陣子一樣睡很飽的話，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n也許就能使用非常厲害的超能力！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣一來，也許連隕石都能破壞！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "即使破壞不了，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n如果能改變它的路線，也許就不會掉在城鎮裡！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，好主意！ 不愧是你！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好――！ 我們馬上去準備吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這裡是我喜歡的地方喔。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為很舒服，可以讓我熟睡！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喂，你也一起午睡嘛。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果你在身邊的話，我就能睡得很好……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n喂，可以吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……可以嗎？ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n好啦好啦，躺下來吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n休息吧～♪",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～，睡得好飽……",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！ 精神百分之兩百喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你還在睡呀……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……你就在這裡睡吧。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就算我失敗，這裡的話應該很安全的。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，我絕對會成功給你看的。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我必須守護大家的城鎮！以我全部的超能力……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "即使用我的生命交換，也要守護蘭德索爾。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "………………",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……謝謝你總是幫我喔。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在我睡著的時候守護我，",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n也替我隱瞞超能力的事情……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "自從和你在一起之後，",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我每天都非常開心喔。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ 還有，以防萬一！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "若是我不幸失敗，被隕石壓扁的話～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞……就麻煩你了。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "若是你的話，我就可以將",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我最最、最～重要的小栞放心交給你……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果有你在小栞身邊的話，",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我想她一定也會很開心的喔。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那樣的話，我也會很高興的。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是……",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我有點……羨慕呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有點……不甘心呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不只是……有點……呢……",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……說不定這是最後了，所以我就說囉。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我……最喜歡你了喔。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……欸嘿嘿。",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "趁你睡著的時候說有點狡猾呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但這是最後一次了，原諒我吧。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，我去去就回♪",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_040"
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的掉下來了……！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是的！ 什麼預知夢嘛，失準的話該有多好！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，我睡得很飽，所以沒問題的！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那種隕石我兩三下就能破壞了喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿――――噫！！！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_043"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚……嗚！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_044"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": " 好、好重……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我明明充飽了電，使出超過全力的力量……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n卻無法破壞隕石！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這樣下去的話……！",
        "unit_id": 101211,
        "voice": "vo_adv_1012007_045"
    },
    {
