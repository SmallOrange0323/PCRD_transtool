[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜利用休假來海釣。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天能找到這麼好的地方，真是太好了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n又安靜，收穫也豐富……真是最棒的休假。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像這樣悠哉地釣魚，",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓人感到心情平靜……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那是……除了我之外還有其他人在釣魚啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我還在想是誰呢，不就是他嗎。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呦。你也會釣魚啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n今天這附近的魚很好釣喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的魚上鉤了喔！",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不趕快收線的話！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，就是這樣……！",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，不行啊……！",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n照這樣下去，你會被拖到海裡去的！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "究竟是什麼樣的大魚……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什……！？ 剛才跳起來的是……！！",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼巨大的魚，我從來沒見過……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以牠為對手的話，用那樣的釣具，你只會被往海裡拉！",
        "unit_id": 100312,
        "voice": "vo_adv_1003003_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n事情變成那樣的話，我就砍了牠！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "巨大魚",
        "words": "──呱歐歐歐歐歐！"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "牠注意到我們這邊了！",
        "unit_id": 100312,
        "voice": "vo_adv_1003003_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正好！ 看我將你碎屍萬段！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……密斯脫拉突風！！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……剛才真是驚險。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是能釣起那麼大的魚，你真了不起。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要給我嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但這是你釣起來的魚……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "幫助你的謝禮……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是這樣，我就不客氣收下了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……雖然想這麼說，",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n看你一臉那麼想要這條魚，我很為難呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是你說要讓給我的喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，你為何會來這裡釣魚呢？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……話雖如此，你卻一條魚也還沒釣上來。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈哈，肚子叫得那麼大聲。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我現在要在這裡烤剛剛釣的魚，要一起吃嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為我一個人再怎麼說也吃不完。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你肚子餓了吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不用客氣來吃吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你的吃相真驚人。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個能算是料理嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我除了簡單的烹飪之外，其它的都不會做。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過被你稱讚，我還是很開心喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，太誇張了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n能讓你那麼高興，我的努力也有價值了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你接下來如何打算？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我還想要再釣一會，你方便的話要不要一起呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不用還也沒關係的說。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道了，我就不懷期待的等著。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那麼我們開始吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喔……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你的釣竿，魚鉤快鬆脫了喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要多留意一下。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對對，確實地重新綁好……",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等等。你不覺得綁法很奇怪嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你該不會是釣魚菜鳥吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那樣的話釣不到也是理所當然的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的……拿你沒辦法。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我來教你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "首先重要的是好好地保養釣魚當天要用的魚鉤和線。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不珍惜道具的話，無論如何都釣不到魚的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "綁的方式",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是把這個如此這般……這樣就好了！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "懂了嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接著是釣魚的地方喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在沒有魚的地方垂釣也沒有任何意義。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個附近很好釣，所以今天不用換地方也沒關係。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再來是拋竿的遠近，",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n落點的深淺……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "諸如此類的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我會一面實際操作一面教你，你得努力跟上。",
        "unit_id": 100311
    },
    {
        "type": "still",
        "still": "100300301"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……比我想像中釣得還多呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n太好了，我們都大豐收呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你釣魚的天分也不錯呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我只是稍微點一下，你就能釣上這麼多魚。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "師傅！？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "被你那麼叫，感覺很不好意思……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且我只是放不下有困難的夥伴而已。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不用放在心上。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再說……想道謝的反而是我。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為我也釣得很開心。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我釣魚通常都是一個人居多啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以今天久違地跟他人一起釣魚……很開心喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要你願意的話，要不要再一起去釣魚呢？",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了，這是只屬於我們兩人的約定喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003003_038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "除了至今為止的關係之外，\n{player}和怜也成了釣友。"
    }
]