    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡雖然也滿有意思的，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但是統御黑夜之人的傳說",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不該在這裡締造。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大家有好好享受",
        "unit_id": 126311,
        "voice": "vo_adv_5120411_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美麗了嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "時間還很充裕，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就好好欣賞我",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "直到最後一刻吧♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比起伊莉亞，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的魅力",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更應該留下來成為傳說……！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……吶，",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身一直很在意一件事。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞，是什麼事呢？",
        "unit_id": 126311,
        "voice": "vo_adv_5120411_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是我的美麗祕訣？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真拿妳沒辦法，我就告訴妳吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總之，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳先空出個幾天的時間來吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是這個！",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別自顧自地說下去啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妳",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "基本上在稱呼別人的時候",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都會加稱謂吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 126311,
        "voice": "vo_adv_5120411_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "莫妮卡小姐、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妮諾小姐、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "空花小姐、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "步未小姐。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也有留意在用字遣詞上要很優美呀♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那妾身呢？",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞。",
        "unit_id": 126311,
        "voice": "vo_adv_5120411_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼啊！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳這樣",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "實在太奇怪了吧！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟為何",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只對統御黑夜之人的妾身",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "直呼名字！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話說，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "以前見面的時候，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳對妾身是稱伊莉亞小姐吧！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n為何變了！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳的心境上到底是起了什麼變化！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算妳這麼問……",
        "unit_id": 126311,
        "voice": "vo_adv_5120411_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然是瞧不起妾身吧……！？　",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……因為伊莉亞",
        "unit_id": 126311,
        "voice": "vo_adv_5120411_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跟我差不多美呀。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我只是覺得競爭對手",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不需要加敬稱啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……竟然是這樣！",
        "unit_id": 126211,
        "voice": "vo_adv_5120411_013"
    }
]