[
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……少年",
        "unit_id": 104711,
        "voice": "vo_adv_5084643_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天也仍然在睡嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n儘管我平時就常告誡他不要太勉強身體，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但像這樣變成令人擔心的狀況……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "實在是不像他會做的事呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不曉得事出何因，",
        "unit_id": 104711,
        "voice": "vo_adv_5084643_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也無法採取對策……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n身為【王宮騎士團】的團長，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這還是我第一次感到如此無能為力……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……不行。",
        "unit_id": 104711,
        "voice": "vo_adv_5084643_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然你目前聽不到我說什麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但還是不能說如此喪氣的話哪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或許我能幫上的忙不多……",
        "unit_id": 104711,
        "voice": "vo_adv_5084643_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過至少……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了迎接我們能再次對話那天，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我發誓一定會守護好這個你回來的地方……！",
        "unit_id": 104711
    }
]