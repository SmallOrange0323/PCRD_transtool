    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在神殿發生了那種事之後，優衣與{player}兩人\n也不禁感到了疲倦，並且回到了公會小屋之中。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我回來了……",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然因為是在擁擠的人群之中移動……",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不過還真是累垮了呢……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "奇怪？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "小屋中怎麼會有亮光呢？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且這道光……",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像在哪裡見過……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對了，",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要見到這道光……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不知道是為什麼，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總是會、",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "變得好睏……",
        "unit_id": 108811
    },
    {
        "type": "still",
        "still": "108800401"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？{player}？你好。",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "新年快樂！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今年也請多指教囉。",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "{player}也是來買東西的？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……怎麼了？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有哪裡很奇怪嗎？",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難不成看到了這件和服所以嚇了一跳？",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這件和服，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和阿斯特朗裡頭的時裝是同個花樣的唷。",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n遊戲有能夠掃描現實中和服的功能，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就是掃描了這一件。",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝、",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊哈哈，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是怎麼回事呢，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真不好意思……",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝、",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你……",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我沒有想過竟然會被這樣稱讚，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以有點驚訝！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才剛過年就被{player}你這樣稱讚了，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n感覺今年也會是個好年呢！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不好意思，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是弟弟他們打來的……",
        "unit_id": 100232
    },
    {
        "type": "still",
        "still": "108800402"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了嗎？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你說弄丟了！？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你、",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你問該怎麼辦呀……",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想想、",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓我想想……！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我弟弟他們，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不知道把放了壓歲錢的紅包弄丟到哪裡了……",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你們現在在哪裡？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……我知道了。",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我馬上就過去你們那邊。",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個是……？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這是，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "{player}你的壓歲錢對吧！？",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不行啊，不能這樣！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不能收下的！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是！",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就算這樣，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也沒道理收下你的壓歲錢啊……！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……{player}是，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n只要下定決心要去幫助誰，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "直到最後都不會退讓的人呢。",
        "unit_id": 100232
    },
    {
        "type": "still",
        "still": "108800403"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝你！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我下次一定會補償你的！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼我，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就先去弟弟他們那邊了！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的非常謝謝你！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再見！",
        "unit_id": 100232
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在和優衣分開之後，\n便前往因新年首賣而非常熱鬧的動漫商店。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而此時正好在樓梯一隅，發現了別人弄丟的小紙袋。"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "是紅包袋啊……",
        "unit_id": 1031,
        "voice": "vo_adv_1088004_027"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "上頭有寫姓名呢。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n草野……",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我看看名字是……",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你好？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了嗎？",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我弟弟他們的話不用擔心唷。",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n現在他們已經都不哭了，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總而言之決定先去派出所……",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "動漫商店？",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等一下，你們又怎麼了！？",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n聽話，不要吵鬧！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抱歉啊，",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我弟弟他們又開始哭鬧起來！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哎，",
        "unit_id": 100232,
        "voice": "vo_adv_1088004_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我知道了，先別哭！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我之後再打給你喔！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼先這樣！",
        "unit_id": 100232
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "難不成，",
        "unit_id": 1031,
        "voice": "vo_adv_1088004_031"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "你認識這紅包的主人嗎？",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "啊！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "客人！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請稍等一下！",
        "unit_id": 1031
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後迎來新學期，\n{player}在教室裡和優衣碰面了。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "早安，{player}！",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "前陣子那次，真的很謝謝你！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "聽我說喔，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "弟弟他們的壓歲錢，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "找到了呢！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以說，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是{player}你的壓歲錢……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是呢，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想說做為謝禮，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "圍巾！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然是手工製的，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但如果你不介意……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "戴戴看吧？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然後，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有另外一個謝禮……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這、",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是我們家店裡的折價券！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我家啊，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是開食堂的……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊，但是，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還是等到你真的",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很想來吃吃看時再來就好！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好嗎？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是的……",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然說讓他幫了大忙，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但爸爸和媽媽他們倆，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n竟然就以為{player}是我的「男朋友」了！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還說什麼想要看看長相，所以要我把他帶來，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "絕對辦不到～！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟{player}他的事情，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_041"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n如果被意有所指地亂問，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會很害羞呀……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_042"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "爸媽硬塞給我折價券要我帶來學校，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不送給他也不行吧……",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但如果他真的來了，事情絕對會變得複雜啊～！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什、",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_043"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什什什、",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "什麼事都沒有喔！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那麼{player}，再見了喔！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……說什麼再見了，",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_044"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "座位就在旁邊，所以我只是坐了下來而已啊！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我到底在做什麼呀，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是個笨蛋～！",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會不會被他以為我是個奇怪的人呀……？",
        "unit_id": 100231,
        "voice": "vo_adv_1088004_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚嗚，",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好丟臉～！",
        "unit_id": 100231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的～",
        "unit_id": 190011,
        "voice": "vo_adv_1088004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n剛剛那是以你的記憶基礎所做出來的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真要說就是如同夢一般的情景唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被{player}你出聲叫住時，優衣的那表情，",
        "unit_id": 190011,
        "voice": "vo_adv_1088004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n簡直就像是與命運之人相遇的公主一樣呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "照這麼說來，你或許",
        "unit_id": 190011,
        "voice": "vo_adv_1088004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是在公主危急時伸出援手的騎士啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許哪一天你會騎著白馬，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現身在優衣的面前也說不定呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對那邊的優衣來說，{player}你也是相當重要的，",
        "unit_id": 190011,
        "voice": "vo_adv_1088004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你得把人家看好唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011,
        "voice": "vo_adv_1088004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你那自我犧牲精神也稍微適可而止一點啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n知道了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖這麼說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但反正你還是會拚了命去做的吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是個這樣的傢伙呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1088004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你這人……",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500041"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這裡是……？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原來如此。",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_053"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才剛回來沒多久我就睡著了呀……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生也是一樣嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個呀，",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_054"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我呢，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像做了一個夢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "然後，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生在夢裡出現了呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "夢裡的騎士先生，",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_055"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和現在在這裡的騎士先生，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n完全沒有變，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一樣非常溫柔……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓我想到，騎士先生你不管到了哪裡，",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_056"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都還是騎士先生呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n然後啊？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就不知為何……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "覺得非常開心。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是，",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_057"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我不覺得自己有累到會立刻睡著的程度呀……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟直到剛剛都是我有事情要你陪我嘛，\n接下來，就換我",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_058"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "陪騎士先生去做你想做的事吧。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是要給可可蘿的，對吧。",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_059"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼既然要去，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也分給貪吃佩可和凱留她們",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一些年糕好了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要帶多少會比較好呢……",
        "unit_id": 108811,
        "voice": "vo_adv_1088004_060"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣夠嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了，騎士先生？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "完全不夠？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這樣嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優衣和{player}兩人準備好了之後，\n便一同出發去給可可蘿壓歲錢，\n還有分送年糕給貪吃佩可和凱留她們了。"
