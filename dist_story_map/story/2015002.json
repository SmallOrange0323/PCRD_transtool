        "words": "剛剛那個防禦魔法，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n是騎士先生幫我們",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "高度強化的功勞。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "霸瞳皇帝的力量，",
        "unit_id": 105911,
        "voice": "vo_adv_2015002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在太過強大。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算借助了主人的力量，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也未必能一直安然度過。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再這樣下去……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……真是丟臉呢。",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_008"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n只不過是稍微",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "陪你們玩玩的程度而已……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就已經",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "幾乎沒人能站起來了嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就這點程度的話，",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我是不是根本沒有必要",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n特地變成這個姿態呢？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……唉。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔……！",
        "unit_id": 100311,
        "voice": "vo_adv_2015002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳以為妳已經贏過我們了嗎……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……呵。",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳說",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這就算贏了嗎？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可不這麼認為呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若真是如此……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我又豈會如此空虛。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "空虛……？",
        "unit_id": 105811,
        "voice": "vo_adv_2015002_012"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我剛剛……",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也和克莉絲提娜講過了。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我是",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「真的不打算」",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "與你們進行戰鬥的。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我不但不打算讓你們見識到這個姿態，",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也沒有打算",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將如此重要的王牌用在這個場合。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為了那即將到來的",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「真正的戰鬥」，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我原先是想保留實力的……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "「真正的戰鬥」……？",
        "unit_id": 101711,
        "voice": "vo_adv_2015002_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是為了",
        "unit_id": 107011,
        "voice": "vo_adv_2015002_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與我們七冠戰鬥……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是為了要拿來",
        "unit_id": 106011,
        "voice": "vo_adv_2015002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對付我們這群反叛者……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n陛下……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請告訴我們！",
        "unit_id": 100211,
        "voice": "vo_adv_2015002_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳到底……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是打算和什麼東西戰鬥？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "霸瞳皇帝……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這話怎麼是由妳來問呢？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "優衣。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……？",
        "unit_id": 100211,
        "voice": "vo_adv_2015002_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "算了……",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也好。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n畢竟這片夕陽，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也像血海一般美麗……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而你們也活不到今晚了，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就讓我來和你們",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "說點什麼吧。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……說到底。",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個世界，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n本來就是由謊言與假想所建構而成的。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是想像與虛構的幻想世界。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "安穩地生活在其中的你們，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "想必根本未曾注意過吧？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "善與惡，本來應該會",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "依據觀測者的立場而有所改變。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然而在這虛構的世界中，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "卻存在著一個絕對之惡……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個世界竟是藉由那絕對之惡的存在",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而持續運轉的。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "簡直",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就像在訴說著自己即是「神」呢。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……不可饒恕對吧？",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n明明這個世界裡的「神」，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "除了我──",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "霸瞳皇帝之外就再無他人了。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "淨在那邊說些，",
        "unit_id": 100311,
        "voice": "vo_adv_2015002_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唯我獨尊的狂言……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不。",
        "unit_id": 107011,
        "voice": "vo_adv_2015002_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先不說別人，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是從千里真那口中所說出來的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這番話就並非只是唯我獨尊的狂言了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若要說是為何……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若要說是為何，自然是因為這名為阿斯特朗的世界，",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n原本就是我們七冠",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所創造出來的。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n對吧？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "變貌大妃。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的……",
        "unit_id": 107011,
        "voice": "vo_adv_2015002_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就算在我們之中，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳也是最出類拔萃的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒錯。",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這裡明明是以「神」的身分成長的我，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為了以「神」的身分統治一切",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而創造出來的世界……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "除了我以外，",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若有任何人膽敢坐上「神」座，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那麼，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我就必須不計代價將那人給打落在地才行。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "畢竟所謂的「神」，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "可是唯一且絕對的存在。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而我，",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將會創造出一個符合我心中理想的新世界！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n擁有天之瞳的我所踏上的霸王之道，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是不會被你們所阻礙的！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼就由我來――",
        "unit_id": 1,
        "voice": "vo_adv_2015002_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n將妳那所謂的霸王之道",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給斬斷吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "――天樓霸斷劍！",
        "unit_id": 106113,
        "voice": "vo_adv_2015002_034"
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……！",
        "unit_id": 106915,
        "voice": "vo_adv_2015002_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "諾維姆！？",
        "unit_id": 100211,
        "voice": "vo_adv_2015002_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們也一同助陣！",
        "unit_id": 104711,
        "voice": "vo_adv_2015002_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n尾狗刀！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好啦好啦……",
        "unit_id": 106211,
        "voice": "vo_adv_2015002_038"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真拿她沒辦法呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "――看招！",
        "unit_id": 106211
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是【王宮騎士團】的純小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_2015002_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_2015002_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個輕浮的人，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得好像在哪裡看到過！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是之前",
        "unit_id": 104911,
        "voice": "vo_adv_2015002_041"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家在搶諾維姆的時候，跟我們打過一場的人唷，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然搞不太清楚狀況，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但現在好像是自己人的樣子。",
        "unit_id": 104911
    },
    {
