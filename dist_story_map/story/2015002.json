        "name": "香織",
        "words": "……！",
        "unit_id": 101711,
        "voice": "vo_adv_2015002_042"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們也上吧！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊！",
        "unit_id": 104311,
        "voice": "vo_adv_2015002_043"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這應該",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是我們最後的機會了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
