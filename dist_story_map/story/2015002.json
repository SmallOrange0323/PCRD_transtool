    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也要謝謝可可蘿妳……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼、",
        "unit_id": 100211,
        "voice": "vo_adv_2015002_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不用謝……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
