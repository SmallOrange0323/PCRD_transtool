    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "傳說的吸血鬼，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "伊莉亞‧奧恩斯坦大人。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "我認為不該打擾偉大的您進行談話，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_032"
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "因此一直保持沉默。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "萬一妾身就這樣一直沒注意到，你要怎麼辦啊……？",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你似乎很明白妾身的偉大啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就允許你上前來說明你到這裡的理由。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "是！",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_034"
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "不勝感激。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊～！",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_035"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n等等，伊莉亞，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是我先的才對吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "無論是先是後結果都一樣！",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳就乖乖放棄，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "去成就身為人的美吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……咳咳。",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "久等了，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "先報上你的名號吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我名叫布拉德。",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_038"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n是居住在某個遠離此地的城鎮裡的",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "魔族。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那麼布拉德，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就聽聽你的來意吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "──傳說的吸血鬼。",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_040"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是在遙遠的太古，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "率領著我們魔族，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n和人類、",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "精靈族",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "以及獸人這三個種族作戰的",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "魔族之王。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "依據我們魔族的傳說，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_041"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n您在與諸神的爭鬥中敗北，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "並被封印了起來。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哼嗯～",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_042"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我完全不知道那種傳說耶。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這是真的嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "誰曉得呢，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟妾身也活了很長的時間。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好像有這麼回事，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "又彷彿沒這回事……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話說，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雪妳別若無其事地插話啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……所以呢？",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_044"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n布拉德啊，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不需要多餘的開場白，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "直接說重點吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "遵命。",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_045"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n……",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我是",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "聽到某個傳言而前來這裡拜訪的。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "「傳說的吸血鬼復活了，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_046"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "但是──",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "已失去了力量。」",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……喔？",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_047"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n莫非",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你是來討伐",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "已失去力量的妾身的？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵……",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不必，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "退下吧，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "盯上妾身，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "並企圖藉此一舉揚名的野心分子多的是。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身是不會輸給",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這種程度的傢伙──",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "──您說的沒錯！",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_049"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我這種小人物",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是不可能敵得過傳說的吸血鬼的偉大力量！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "手指一揮就能改變天候，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_050"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "腳下一踏便能使大地裂開，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "如果嘆了口氣，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n則會颳起龍捲風，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "光是一個眼神即可魅惑數萬生物的心。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "面對擁有這等力量的存在，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我又怎麼敢有反抗之心呢！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔、",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_051"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身有這麼厲害啊……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是、",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_052"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你就儘管",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "尊敬妾身吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈～哈哈……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞，",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_053"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳的笑容好像有點僵硬耶？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不過啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "現在的伊莉亞並沒有那種力量吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n他剛才有說過「已失去了力量」嘛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是的，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_054"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我聽到的內容是如此。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n因此我──",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是為了使伊莉亞大人恢復力量而前來的。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說讓妾身……",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_055"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "恢復力量？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "沒有錯。",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_056"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "請您",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "看看這個。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喔～",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_057"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好美的石頭。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拿來做成我的飾品──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──妳還不住手！",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_058"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那是什麼？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你帶來的那顆石頭。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……感覺那上面有著奇妙的魔力。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "這個世界中，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_059"
    },
    {
