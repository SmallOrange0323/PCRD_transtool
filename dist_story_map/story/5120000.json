[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "矗立於遠離蘭德索爾之地的古城。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那裡是統御黑夜之人，伊莉亞‧奧恩斯坦的城堡。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所～以～說，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就叫妳回去了啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不，",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不回去。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在妳願意聽我的願望前，我是不會回去的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呃～",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "居然每天每天都學不會教訓地跑來！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "無論妳拜託多少次，妾身都不會聽從妳的願望！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身不會害妳的，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳就乖乖離開吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼啊？",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n妳不就是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "傳說的吸血鬼嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的確是偉大的吸血鬼，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統御黑夜之人──",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在由於各種因素……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總之就是沒辦法！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不是現在就不行啊！",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦！",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}啊，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你來的正是時候！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你能幫妾身把這傢伙給趕出去嗎！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵。",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n{player}",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也被我的美貌給吸引而來了呀。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然如此，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也來幫忙拜託",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這位吸血鬼小姐啦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拜託她將我──",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "變成吸血鬼！",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是這麼回事。",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你能幫忙想個辦法嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我太美了！",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你看，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n根本完全無法溝通對吧？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "根據我聽到的消息，",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吸血鬼",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似乎能維持固定的樣貌，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n活在永恆之中不是嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "的確",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是如此沒錯。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也活了很長的一段時間。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "樣貌上……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "多少會變大或變小就是。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我呀，",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了將自身的美貌",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "化為永恆不變的存在，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我認為",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該要讓自己變成吸血鬼。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這就是背負美麗之人的宿命啊！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "被妳背負的美麗想必也感到很困惑吧。",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……吶，{player}啊，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這傢伙究竟是怎麼回事？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身還是第一次見到這麼莫名其妙的傢伙。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哼哼，",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞也感到很驕傲吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳能夠將我的美",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "變成永恆的存在喔♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唉……",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "自從這傢伙找上門以後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n【惡魔偽王國軍】的成員",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也開始不再靠近城堡了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就連那個宮子，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也被迫聽她解說好幾個小時的",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n「我滑嫩的美肌比布丁更重要」，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "最後嚇得逃走了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "最開始妾身",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是命令依里去應付雪的。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但那傢伙",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在聽了雪的話一陣子後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就眼眶泛淚了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟她不擅長",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "應付個性強勢的人啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "茜里還滿有前途的呢。",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我開始說起關於美的事之後，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她就充滿興趣地聽我說呢♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……因此",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為了避免讓她們見面，妾身先放她假了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要是她受到了不必要的影響，那可不行啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這麼說來，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "忍那傢伙沒見過雪呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那傢伙",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在雪來這裡之前，有先占卜過什麼！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "她該不會是預知到這結果，所以先躲避了……！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總之，",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為這傢伙的關係，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n【惡魔偽王國軍】被搞得分崩離析了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現在",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這座城",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "除了妾身和你們兩人之外，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有其他人了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 100811,
        "voice": "vo_adv_5120000_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是這樣嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那麼，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那個人是？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……那個人？",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_027"
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "…………",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你是誰啊！？",
        "unit_id": 104412,
        "voice": "vo_adv_5120000_030"
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "哦哦，",
        "unit_id": 9811,
        "voice": "vo_adv_5120000_031"
    },
    {
        "type": "dialogue",
        "name": "男魔族",
        "words": "竟然能被您主動搭話，真是榮幸至極。",
