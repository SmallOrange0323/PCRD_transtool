    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嘿，少年，",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "歡迎你來。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n難道說",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你是來買可麗餅的嗎？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我很高興哦，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "額外多送你一點",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "配料～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "咦？",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不是嗎？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那難道說，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是來幫忙店裡的！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n幫大忙了～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我正想專心思考新菜單呢～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……也不是為了這個，",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是嗎。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那是什麼～？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "居然能讓被稱為迷宮女王的我",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這麼煩惱，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n少年你還真不簡單呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊～！",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "原來是這樣，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "原來如此……！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "確實稍微想一下就會知道，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "今天是我的生日！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為我平常總是過著漫不經心的浪人生活～",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以沒有慶祝紀念日的習慣。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過沒想到，",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n少年居然會特地過來幫我慶祝生日……",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊哈哈！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這股心情是什麼，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "難道這就是喜悅嗎？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "心臟越跳越快了。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗚哇～",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你到底想把大姐姐我怎麼樣～？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而且這個還是",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "FPS的新作耶！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我還沒有入手呢～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很好，少年，",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我們現在就來一起玩吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你說顧店？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "當然是臨時休息啊。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n不管是遊戲機還是螢幕",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "全都有在車子裡哦♪",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "平常就已經",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_008"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "受你這麼多照顧了，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n居然還讓你來慶祝",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我的生日……",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果沒有",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "讓你盡情玩個夠本的話，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "反而會",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "很失禮呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "少年，",
        "unit_id": 106832,
        "voice": "vo_adv_4010187_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "謝謝你。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n從你身上「得到的東西」我一定會報答的。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n賭上我的一切，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "來回報給你，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "哦。",
        "unit_id": 106832
    }
]