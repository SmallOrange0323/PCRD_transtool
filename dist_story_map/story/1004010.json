[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天禊把{player}叫了出來後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當她正在挖特製的陷阱地洞時──"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哼哼哼！",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "感覺今天的陷阱地洞設置得特別完美呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "到底會上鉤幾次呢～？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這次禊挖了很多洞，還真是令人期待呢～♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "找到了！",
        "unit_id": 1,
        "voice": "vo_adv_1004010_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是如同通報所說的可疑傢伙！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "什麼什麼？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "我們是【王宮騎士團】！\n不准動！",
        "unit_id": 711,
        "voice": "vo_adv_1004010_004"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "給我安分點！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n……呃，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "是小孩子？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你說的可疑傢伙是指禊嗎！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "做了什麼壞事嗎……？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "總而言之，",
        "unit_id": 1,
        "voice": "vo_adv_1004010_006"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "妳快把身上的東西全都交出來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你來的正好！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "嗯？",
        "unit_id": 1,
        "voice": "vo_adv_1004010_008"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "你是誰啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "是她的同夥嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你聽禊說，",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這些人",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "竟然說禊很可疑！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "妳都挖了這麼多的地洞，還敢惡人先告狀！",
        "unit_id": 711,
        "voice": "vo_adv_1004010_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是說啊！",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n為什麼禊非得被抓起來不可啊？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "最近常有盜賊出沒，",
        "unit_id": 1,
        "voice": "vo_adv_1004010_012"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n他們會先讓人掉入陷阱地洞，再假裝要幫助受害者，趁機搶奪財物。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "然後我們接到了通報，",
        "unit_id": 711,
        "voice": "vo_adv_1004010_013"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "說是有人正在這裡挖掘大洞。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n在趕來查看之後，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "就發現了這個孩子在這裡。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊才不會做那種事呢！",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個陷阱地洞",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "也只是為了哥哥才挖的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "別說是藉口了，聽起來根本就像是招供啊！",
        "unit_id": 711,
        "voice": "vo_adv_1004010_015"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n這個男人也是一夥的吧！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "你也讓我們檢查一下！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "為什麼！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥他什麼都沒做啊！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "意外地聽話嘛。",
        "unit_id": 711,
        "voice": "vo_adv_1004010_017"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "那就讓我來確認……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "嗯？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "怎麼了？",
        "unit_id": 1,
        "voice": "vo_adv_1004010_018"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "他身上有什麼可疑的東西嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "不，",
        "unit_id": 711,
        "voice": "vo_adv_1004010_019"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "正好相反，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "這傢伙……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "身上什麼都沒有。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "什麼？",
        "unit_id": 1,
        "voice": "vo_adv_1004010_020"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "謝禮？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "來這裡的途中掉進陷阱地洞，",
        "unit_id": 1,
        "voice": "vo_adv_1004010_021"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n為了答謝救你的人，所以把身上東西全交出去了……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "你是",
        "unit_id": 711,
        "voice": "vo_adv_1004010_022"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "被騙了啦！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n從手法來看的話，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "那些傢伙肯定就是我們在找的盜賊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n他們跑去哪了？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "往對面那裡去了？",
        "unit_id": 1,
        "voice": "vo_adv_1004010_023"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "我們趕緊去追！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n你們的嫌疑已經洗清了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "懷疑你們真是不好意思。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……走掉了。",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "一點都不好！",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥身上的錢之類的東西，全部都被偷走了啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這都是",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊的錯吧。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n要是禊沒有叫哥哥出來，你就不會過來了，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n你會掉進陷阱地洞，也是因為把那個洞當成是禊挖的洞了吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要把哥哥被偷走的東西拿回來！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "交給剛才那些人就行了？",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個嘛……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣啊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "說得也是呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊～啊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "難得要跟哥哥好好玩一場的說，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n結果今天的行程都泡湯了。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊要回家囉，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥回去時也要小心哦。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那麼再見囉，",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "根據哥哥說的，",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "應該就在這附近吧。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "如果是禊的話……",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_032"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "會在那一帶設下陷阱地洞！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "接下來就只要躲在這裡，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "等壞人們過來……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_033"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "為什麼你會在這裡？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "難道說",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "壞人的真實身分就是哥哥……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是不可能的吧。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唉～",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_034"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "明明會掉進禊的陷阱，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n卻能看穿禊在想什麼啊～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然哥哥阻止過禊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_035"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但禊果然還是想拿回屬於哥哥的東西。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要是可疑的傢伙來了，褉一定會去通報的！",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_036"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "褉絕對不會做危險的事，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "拜託你了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "謝謝你，",
        "unit_id": 100411,
        "voice": "vo_adv_1004010_037"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡似乎不錯呢，",
        "unit_id": 1,
        "voice": "vo_adv_1004010_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n趕緊動手吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
