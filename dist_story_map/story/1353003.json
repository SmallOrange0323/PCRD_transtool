    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夏日度假旅行來到了最後一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n把美好回憶打包好後，就可以回家了……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而事情卻沒這麼順利──"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呼……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哈啊……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n嗯嗯……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──可璃亞因為發燒身體不適，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在旅館臥床不起。"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起，",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_001"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這沒什麼大不了的……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "只是中暑而已……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好像",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "有點玩過頭了……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n結果忘記自己的極限……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "像小孩子一樣，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好丟臉……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "沒錯……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真的",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "非常開心。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉和普蕾西亞能夠玩得盡興，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我也很高興。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……但是，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "最後一天，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "竟然變成這樣……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "讓那兩個人",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "去找醫生，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還要照顧我……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真不知道該怎麼道歉才好。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……如果要倒下的話，",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n至少等明天再倒下就好了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "明天的話，",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n就不會讓快樂的旅行",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "留下掃興的回憶。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……嗚",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "、嗚嗚……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唔。",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥、",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "你",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "別摸我的頭啦……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這樣的話，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那個，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n反而變得更熱……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "身體都是汗……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我、",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我要換一下衣服……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥不好意思，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可以請你到外面──",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唔。",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "蟬叫聲",
        "words": "唧唧、唧唧……",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "和哥哥四目相交的瞬間……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不知道蟬聲，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "有沒有蓋過我的心跳聲……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我的視線……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "沒辦法離開哥哥。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n想一直、",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "一直",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這樣看著他……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥、",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_013"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呼……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呼……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……唔。",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_015"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n流了這麼多汗。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "床單",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "都濕透了……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗚嗚，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好害羞……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "請不要看我，哥哥……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_016"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n一直被哥哥這樣看著的話，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n身體",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "越來越熱，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "汗會……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "停不下來。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_017"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……奇怪？　",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怎麼回事……？",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_018"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n頭……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好昏……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_019"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……不要走。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "蟬叫聲",
        "words": "唧唧、唧唧……",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……呼。",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_020"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……呼。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呼",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_021"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……那個，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "身上的",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_022"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "汗……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我、",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_023"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我又要做……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這麼大膽的事……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "果然",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是夏天的關係……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗯，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "一定是這樣。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以，",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_024"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這也是沒辦法的吧……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……哥哥。",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_025"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n你可以",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "幫我擦汗嗎……？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……是的。",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_026"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n其實……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我聽默涅說了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n之前",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也幫默涅",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "擦過汗。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "默涅身體不舒服的時候，",
        "unit_id": 126012,
        "voice": "vo_adv_1353003_027"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥也像這樣照顧她……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那時候，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "你幫她擦了汗，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧……？",
        "unit_id": 126012
    },
