[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人真的是個很厲害的人耶。",
        "unit_id": 111611,
        "voice": "vo_adv_6029103_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她總是很果決，能迅速處理很多事情！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "給人一種能幹的感覺！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、",
        "unit_id": 111611,
        "voice": "vo_adv_6029103_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這我不能否認……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，這也是因為",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她有堅定的信念。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也能成為像她一樣那麼強大的人嗎……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你勸我不要比較好？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的！　",
        "unit_id": 111611,
        "voice": "vo_adv_6029103_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之前有粉絲吵了起來，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她一個人在轉眼間就解決了整件事情。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個時候的\n製作人，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的非常可靠……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過她也是鬧得最兇的人就是了。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵。",
        "unit_id": 111611,
        "voice": "vo_adv_6029103_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶爾",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然她很容易讓人誤解，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過製作人她很溫柔喔？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為她會用很嚴厲的話",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來激勵我們！",
        "unit_id": 111611
    }
]