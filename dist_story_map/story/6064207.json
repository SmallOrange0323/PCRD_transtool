    {
        "type": "dialogue",
        "name": "サレン",
        "words": "『料理は得意』って言っても、",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_000"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nそんな凝ったものは作れないのよね……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "もちろん、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "味には自信あるのよ？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ええ、",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_001"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "そうだったわね。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……ね、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ねぇ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "今度、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "救護院で",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "料理を作ろうと思ってるの。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "自信作を用意するから、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ひまだったら食べに来てよね。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ふふ、",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_002"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "それなら二人で挑戦してみない？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "そういうことだから、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "今度時間作ってよね。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……約束よ？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……もう、",
        "unit_id": 114511,
        "voice": "vo_adv_6054207_003"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ほんとアンタって、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "天然っていうか、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ズルいというか。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも正直言うと、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "その言葉が一番、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "うれしいわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……ありがとう。",
        "unit_id": 114511
    }
