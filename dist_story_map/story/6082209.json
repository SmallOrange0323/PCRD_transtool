    {
        "type": "dialogue",
        "name": "レイ",
        "words": "パレードといっても",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_000"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "歩くだけだと思っていたけど、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "意外とやることがあったんだね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "あの子たちはきちんとできていてすごかったな。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "そう言ってもらえるとうれしいよ。",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_001"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "でもあのときは、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "むしろあの子たちに助けられたかな。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ふふっ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "本当に最初の頃とは大違いだったよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ああ。",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_002"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "あの子たちを見ていると",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "自然とね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "本当に立派なお化けだったよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "たとえ怖くなくたってね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "次はもっと上手にできるといいな。",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_003"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "なんて言うと",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ツムギが張り切りそうだから、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n少し内緒にしておこうか。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "サプライズにとっておきたいし。",
        "unit_id": 114011
    }
]