[
    {
        "type": "dialogue",
        "name": "望",
        "words": "好，",
        "unit_id": 132212,
        "voice": "vo_adv_4012015_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到此為止感覺都不錯，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來要加入的素材是……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "接著是這個。",
        "unit_id": 132312,
        "voice": "vo_adv_4012015_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是？",
        "unit_id": 132212,
        "voice": "vo_adv_4012015_002"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "糞。",
        "unit_id": 132312,
        "voice": "vo_adv_4012015_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "別嘲笑我，跟我說啊～",
        "unit_id": 132212,
        "voice": "vo_adv_4012015_004"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "所以我才說糞啊。",
        "unit_id": 132312,
        "voice": "vo_adv_4012015_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳踩到了什麼？",
        "unit_id": 132212,
        "voice": "vo_adv_4012015_006"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "所以我說糞！",
        "unit_id": 132312,
        "voice": "vo_adv_4012015_007"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n便便啦，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "便便！！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不好意思，",
        "unit_id": 132412,
        "voice": "vo_adv_4012015_008"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n剛剛",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是不是有人在說便便？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……沒有！",
        "unit_id": 132512,
        "voice": "vo_adv_4012015_009"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n沒有人在說便便。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n回床上去睡覺──",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……是嗎。",
        "unit_id": 132412,
        "voice": "vo_adv_4012015_010"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n是我聽錯，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "以為有人在說便便了啊。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "失禮了。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呼……",
        "unit_id": 132512,
        "voice": "vo_adv_4012015_011"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我說露易、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "望。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n別用那麼大的音量說便便這兩字啦。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那傢伙",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "好不容易快要告別便便熱潮了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "對、",
        "unit_id": 1,
        "voice": "vo_adv_4012015_012"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "對不起……",
        "unit_id": 1
    }
