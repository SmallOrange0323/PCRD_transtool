    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你好呀。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你說我嗎？ 我呀……打算到城鎮郊外去修行鍛鍊。",
        "unit_id": 100211,
        "voice": "vo_adv_1002001_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也想讓自己更能幫大家的忙。",
