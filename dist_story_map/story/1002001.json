        "voice": "vo_adv_1002001_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總是一直保護著我……）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（總覺得……騎士先生的氣氛跟那個人很像。",
