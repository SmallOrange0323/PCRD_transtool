    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "忘了帶的東西……應該沒有呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002001_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好，這樣就萬事俱備了……",
