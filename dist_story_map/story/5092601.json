[
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "海盜島的冒險結束後，霞等人返回蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然後過了一段時間──"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉……",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是接下海盜島那份大案子的後遺症嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n回到這裡以後，我整個人都提不起勁……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖說工作沒有好壞之分，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也都沒有偷工減料，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但完全感受不到",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "成就感跟充實感呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且在那之後，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也沒有見到杏奈、忍",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有助手先生……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然明白大家都很忙，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但還是會覺得有點寂寞啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "回想著島上的時光，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就這樣走進了古物道具店，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我還真是病得不輕啊……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "該好好調整心態了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是……",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──事情就是這樣，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "既然我拿到了藏寶圖，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n接下來就讓我們去尋寶吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我明白。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要看了這份地圖就會明白我為什麼止不住興奮吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……確實。",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這份地圖雖然很舊，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但反而",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很有氛圍呢。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對啊，",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可以理解平時冷靜的霞為什麼會那麼興奮了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n繼海盜島之後，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "又是一個可以獲得寶藏的機會！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳就盡情使用",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「熾炎戰鬼煉獄血盟暗黑團」團長的力量吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明就是杏奈最興奮。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那我們趕緊",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "出發去尋寶吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請等一下。",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳突然說要去尋寶，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但我們完全沒準備",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "旅途要用的東西啊。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒關係，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是蘭德索爾的地圖喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳看，圖上寫著深淵樹界的地方。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這裡應該就是神秘森林。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如此一來，在這裡的是──",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "冥狂斷崖……",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個令人困惑的浮誇地名，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就是布里薩溪谷吧。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "確實",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "跟蘭德索爾的地形吻合。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "故意標記成與現實不同的地名，",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來讓人推理嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "製作這份地圖的人",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還真有本事呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這下",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "愈來愈有趣了──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔，",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "突然起風了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊！",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "地、",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "地圖飛走了……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "快追啊！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼、",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "終、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "終於追到了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔啊……",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "掉進水窪裡溼掉了啦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要小心別弄破了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "奇怪？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n地圖變了？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒錯。",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "多虧如此，原本看不見的地方",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "終於能看清了。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "背面有簽名耶。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是繪製者的名字嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我看看……",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "安妮、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "羅潔‧馮……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "修特帕魯……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是我？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呃，",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這會是某種暗號嗎……？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這只是單純寫上了杏奈的名字吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯～",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我想起來了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我小時候",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "畫了好幾張這種地圖。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那些地圖幾乎都弄丟了，",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也忘得一乾二凈。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒想到會以這種形式再次見到。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "霞、",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "忍。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們之間",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "果然有著奇妙的緣分呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈哈哈哈！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊……",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "仔細想想，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這些地名完全就是杏奈的品味啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "害我還這麼興奮，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好丟臉……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒關係。",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也完全被這張地圖",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "的精緻度給騙過去了。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可是",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_027"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們好不容易有幹勁，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "卻如字面上地被潑了一盆冷水呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n如何？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "今天就這樣解散嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……不。",
        "unit_id": 101411,
        "voice": "vo_adv_5092601_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "機會難得，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我希望妳可以教我繪製藏寶圖。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然真相讓人覺得惋惜，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但那張地圖本身就像是寶藏呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的，",
        "unit_id": 103113,
        "voice": "vo_adv_5092601_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也想要收藏一張。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n然後",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "拿給公會的夥伴看，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "告訴她們這是我的寶藏。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……這樣啊。",
        "unit_id": 100911,
        "voice": "vo_adv_5092601_030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就來教你們",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "完美藏寶圖的繪製方法吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "要不了多久大家就會察覺吧。和夥伴度過的輕鬆日常，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n才是連那個大海盜都無法獲得的最佳寶藏。"
    }
]