[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵，",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想到好點子了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在店裡販售貓咪小物",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼樣喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要有兼職收入，咖啡廳就能賺錢，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n莫妮卡也會很開心的喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你有沒有",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼好主意喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "原來如此喵！",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請自己支持的愛貓用肉墊當成印章來蓋喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要擺在家裡，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "每次看到就會很想念自己支持的愛貓，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不禁一直來店消費……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "任何人都抗拒不了貓的魅力喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "──這、",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這主意真是太棒了喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不只替店裡招攬客人，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還能彰顯貓派的勢力喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n然後將來貓咪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "將支配整個蘭德索爾喵～！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵！？",
        "unit_id": 125111,
        "voice": "vo_adv_6114206_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就算同樣是貓……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n也禁止摸我或是碰我喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我是非賣品喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……不、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唯獨你，要我賣給你也行喵……",
        "unit_id": 125111
    }
]