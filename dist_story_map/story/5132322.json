[
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕呃呃呃呃呃呃──！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯喔喔欸欸欸欸！！！",
        "unit_id": 128011,
        "voice": "vo_adv_5132322_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐～！！？",
        "unit_id": 127911,
        "voice": "vo_adv_5132322_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這是乘載了巴西利斯克",
        "unit_id": 6111,
        "voice": "vo_adv_5132322_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "全身體重",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "從上空而來的高速衝撞。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要是正面承受，會連一下都堅持不住──",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "親身證明了這樣的先例呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……等一……下，",
        "unit_id": 128011,
        "voice": "vo_adv_5132322_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號……？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n別人都像一塊破抹布一樣被擊飛了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不要還冷靜解說啊……！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過，陛下，",
        "unit_id": 6111,
        "voice": "vo_adv_5132322_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請看。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n發動攻擊的巴西利斯克似乎也",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "因後座力而衰弱……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "看樣子那個攻擊",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就像是會消耗生命的雙面刃呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911,
        "voice": "vo_adv_5132322_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的耶☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "秘書小姐的觀察力",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真厲害呢！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔～！",
        "unit_id": 128011,
        "voice": "vo_adv_5132322_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟然丟著我不管，還受到陛下的稱讚！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是好大的膽子呢，秘書一號，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也差不多該讓妳嘗嘗苦頭了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n等下次攻擊來臨，我就拿妳來當盾牌～！！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐，",
        "unit_id": 6111,
        "voice": "vo_adv_5132322_007"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n要是在戰鬥中想事情，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "會很危險的喔。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您看，後面。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯？",
        "unit_id": 128011,
        "voice": "vo_adv_5132322_008"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕呃呃呃呃呃呃──！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯呀呀啊啊啊啊啊！！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132322_009"
    },
    {
        "type": "dialogue",
