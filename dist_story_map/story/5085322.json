[
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯哼，",
        "unit_id": 121211,
        "voice": "vo_adv_5085322_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來如此原來如此……",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真不愧是妳們",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "，竟然可以撐過剛才的那個。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這樣應該就能取得很好的資料。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別、",
        "unit_id": 121111,
        "voice": "vo_adv_5085322_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別開玩笑了～～～！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這叫哪門子實驗啊！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說不是認真的，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果根本來真的不是嗎！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是當然的喲～",
        "unit_id": 121211,
        "voice": "vo_adv_5085322_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不是逼近極限，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果不超過",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一點極限，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n實驗就沒有意義了嘛。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然沒辦法照原樣重現那個力量，",
        "unit_id": 121211,
        "voice": "vo_adv_5085322_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但妳們真的是應對得當……",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "明顯成長了不少呢，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "年輕人們。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉比林斯達小姐！",
        "unit_id": 121011,
        "voice": "vo_adv_5085322_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n麻煩妳……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "繼續實驗！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想在",
        "unit_id": 121011,
        "voice": "vo_adv_5085322_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不論發生任何事情時，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都有能力守護那個人！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦，",
        "unit_id": 121211,
        "voice": "vo_adv_5085322_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是充滿幹勁。",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那麼，也讓我來",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "展現一下實力如何？",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，真是，",
        "unit_id": 121111,
        "voice": "vo_adv_5085322_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這白癡佩可！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳自己一個人衝在前面根本解決不了問題吧！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……老實點，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多依靠我們一下嘛。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 121011,
        "voice": "vo_adv_5085322_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然囉♪",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起加油吧♪",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……呵呵。",
        "unit_id": 121211,
        "voice": "vo_adv_5085322_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那麼，第二回合要開始了，",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也來",
        "unit_id": 121211
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "幫妳們一把……！",
        "unit_id": 121211
    }
]