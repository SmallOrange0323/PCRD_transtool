[
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟在抱頭苦思！",
        "unit_id": 117111,
        "voice": "vo_adv_5070321_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "終於開始挑戰他不擅長的科目了……",
        "unit_id": 117011,
        "voice": "vo_adv_5070321_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等寫完作業後，",
        "unit_id": 117111,
        "voice": "vo_adv_5070321_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就用美味的餐點來招待弟弟吧！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會做一套全餐，內容全都是弟弟喜歡吃的東西！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就",
        "unit_id": 117011,
        "voice": "vo_adv_5070321_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來做餐後甜點吧……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "做個能浸透疲憊的腦袋，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "放了一堆砂糖的……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就我讓",
        "unit_id": 117111,
        "voice": "vo_adv_5070321_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吃飽後想睡覺的弟弟，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n睡在我的大腿上！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然如此，",
        "unit_id": 117011,
        "voice": "vo_adv_5070321_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了讓那位大人能睡得香甜，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我來調配特製的香氛……",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔～～",
        "unit_id": 117111,
        "voice": "vo_adv_5070321_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那我就……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，不行不行。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n現在得專心處理眼前的事情！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了盡情地寵溺那位大人，",
        "unit_id": 117011,
        "voice": "vo_adv_5070321_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在先暫停，",
        "unit_id": 117011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就只有現在……！",
        "unit_id": 117011
    }
]