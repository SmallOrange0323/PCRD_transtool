    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼……",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來直到剛才為止，牠都是只是玩玩而已呢。",
