        "words": "只要擁有能夠守護重要夥伴",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的力量",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
