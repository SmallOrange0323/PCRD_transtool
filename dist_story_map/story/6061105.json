        "voice": "vo_adv_6061105_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是之前的變身蘋果",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我肯定已經動不了了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為了報答似似花，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我一定要參加舞會！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣說",
        "unit_id": 115812,
        "voice": "vo_adv_6061105_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也太誇張了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我沒辦法像",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "【哞哞自衛隊】那樣守護鎮上的大家。",
        "unit_id": 115812
