[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留與{player}在蘭德索爾的鬧區\n正在邊走邊吃地逛街。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊唔啊唔啊唔……",
        "unit_id": 106012,
        "voice": "vo_adv_1060011_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好幸福♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n便宜好吃份量又夠，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡的攤販果然最棒了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也吃啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1060011_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不趁熱吃的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會變得不好吃哦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼。",
        "unit_id": 106012,
        "voice": "vo_adv_1060011_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肚子填飽後，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就冷靜下來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得",
        "unit_id": 106012,
        "voice": "vo_adv_1060011_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最近……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n太常被捲入{player}的步調了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060011_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}，你好像在發光？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這之前也發生過好幾次……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊！？",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉……",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_005"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不想去上補習班……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好想翹課……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可是",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_006"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果無故缺席，之後媽媽接到電話聯絡，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n會被臭罵一頓……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "絕對會被狠狠教訓。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那樣的話，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_007"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "到了某種程度",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就會開始哭了呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n肯定會說『妳以為我是為了誰的將來",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "才花這麼多錢』",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這種",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n高高在上的話……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "妳在乎的",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_008"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只有面子和別人的眼光吧！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n明明就根本",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不關心我的未來！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "光是想像就覺得想吐……！",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_009"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可惡、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可惡！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好想快點長大",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "獲得自由……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n等自由以後，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "想和真那大人變親近……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗚喵啊啊！？",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_011"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "又、",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_012"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "又是你啊！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n小心我宰了你喔！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦？",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_013"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "　你問我是不是又把錢包弄丟了？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "怎麼可能會一直弄丟啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "笨～蛋。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我有好好帶在……",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_014"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "　奇怪？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n不會吧！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "　錢包不見了！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊，討厭，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_015"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "到底是怎樣啦……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n太不幸了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唔……！",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_016"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼啦，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不管是誰",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "都會肚子餓吧！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "誰要和你",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_017"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "一起去吃啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n再說，我就說我的",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "錢包不見了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你是真的想被我宰掉嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦？",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_018"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "　你要請客？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "誰要接受你的施捨啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊唔……！？",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n誰、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "誰要接受你的～～……",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "106001101"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊唔。",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_020"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊唔啊唔！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n嗯～",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好吃～♪",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這裡的漢堡",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n比起其他的連鎖店，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我更加喜歡呢～！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然知道卡路里很高，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但就是讓人欲罷不能！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嚼嚼，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嚼嚼嚼♪",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……不好不好。",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這樣不就像是被餵食的貓了嗎。",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "106001102"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "話說回來，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n現在也還在",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "玩阿斯特朗吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果玩阿斯特朗，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "會遇到真那大人嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我之前和你說過吧？",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n真那大人和我",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "說不定是遠親的『兄妹』。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我在那之後思考過了，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_027"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n但要怎麼在現實與真那大人見面，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "卻完全不曉得。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然想過在遊戲……",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_028"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n在阿斯特朗",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "或許就能見面了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是開發者怎麼可能",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "會找玩家說話呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "欸！？",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "　真的嗎！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你如果有機會",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "見到真那大人的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n絕對要告訴我喔！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "　絕對喔！！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1060011_030"
