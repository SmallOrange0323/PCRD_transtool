        "type": "dialogue",
        "name": "亞里莎",
        "words": "因為剛剛跑過來的時候沒看地圖，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n結果完全搞不清楚現在在哪裡了啊……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "這樣的話，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_032"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "永遠都沒辦法抵達蘭德索爾了……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "真是的，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "為什麼我總是……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……咦？",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_033"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n你、",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你說你是從蘭德索爾來的！？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "真、",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "真的嗎！？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那、",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_034"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n明明已經被你救了一次，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "還要再麻煩你真是對不起！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n能請你帶我去蘭德索爾嗎！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我無論如何，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_035"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "都一定得去蘭德索爾一趟。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n所以，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以拜託你了！",
        "unit_id": 106311
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……這條大路直直往前走，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_036"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "就是蘭德索爾對吧。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "謝謝你！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我已經，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不知道該怎麼道謝才好……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……這下子總算，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_037"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "或許能見面了呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n等著我，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "蘿莎麗亞……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……啊，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_038"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "對不起。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "其實，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "蘿莎麗亞是我的一位好朋友，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我一直在找她……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "蘿莎麗亞和我一樣，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_039"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "住在「避世精靈村」，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我們約好要一起當上森林守衛，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n感情",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "一直很好……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "但是，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_040"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "有一天，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "蘿莎麗亞突然消失了。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n對我和其他人",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "什麼都沒有說，就……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_041"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我踏上了尋找蘿莎麗亞的旅程！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n雖然有點辛苦，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n不過最近，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "終於找到了線索……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "蘿莎麗亞她，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_042"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "也許就在蘭德索爾。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……雖然只是傳言，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "但是，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我想相信。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n所以就跑來這裡了。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊……",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_043"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個城鎮的燈光……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n那就是蘭德索爾嗎？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "非常漂亮呢……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……不過，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_044"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "好像有點可怕。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n因為村子從來沒這麼明亮過……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……那、",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_045"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "這個，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_046"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n謝謝你救了我，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "還幫我帶路，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n這種事還要拜託你真是不好意思……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你也是蘭德索爾的人嗎？",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_047"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n……那個，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我是第一次，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "來到這麼大的城鎮。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n方便的話，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "能請你幫我導覽嗎……？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……真、",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_048"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "真的可以嗎！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "太好了！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "謝謝！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n你真是個溫柔的人呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……啊，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_049"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "這麼說來。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你叫什麼名字？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n……一直用你來稱呼的話，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "很奇怪呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……{player}？\n呵呵，",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_050"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "感覺是個很像你的名字呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n聽起來既溫柔又好聽……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……咦？",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_051"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n你說我可以不用太拘謹？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n是、",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是這樣嗎……？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……耶嘿嘿。",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_052"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n其實，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我也不太擅長很拘謹。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "嗯！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "{player}先生！\n不對……{player}！\n接下來也請你多多指教哦！",
        "unit_id": 106311,
        "voice": "vo_adv_1063001_053"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這就是{player}和天真爛漫的少女亞里莎，\n兩人的相遇。"
