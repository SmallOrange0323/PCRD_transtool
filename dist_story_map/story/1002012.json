        "voice": "vo_adv_1002012_084"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "給了我勇氣。",
        "unit_id": 100211
