        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那我們去吃飯吧！　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也會來吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……什麼嘛",
        "unit_id": 104311,
        "voice": "vo_adv_1002012_086"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然有工作。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我還想問個清楚的說。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
