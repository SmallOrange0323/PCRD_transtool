[
    {
        "type": "background",
        "background": "502630"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靜流和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天也享受著新婚生活。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人走在街上的時候，\n璃乃勢不可擋地衝了過來。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你們好！",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥、姐姐，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我有話要說～！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳怎麼了？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要我給妳新年第一發的頭錘嗎？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我才不要！",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "比起施展頭錘，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n請先做出",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聆聽可愛妹妹說話的姿態！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "被罵了。",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿☆",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……其實我，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有【拉比林斯】的任務在身，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n現在正在為任務做準備。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "獨自一人。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當妹妹正在獨自努力的時候，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n姐姐",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "卻和哥哥待在一起喔。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吸",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吐……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣不是很奇怪嗎！？",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有任務在身沒關係！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要我獨自準備也沒關係！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但是！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然而！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們明明是手足，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "卻只有我獨自一人，好寂寞～！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你們兩個還卿卿我我的！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也就是說，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃是……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想跟你們一起玩！",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我勉強擠出了時間，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以一起來玩吧！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "應該說",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請跟我玩！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯♪",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那樣的話，妳來得正好喔。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我今天也準備了要來玩新年遊戲♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n正想說要找璃乃一起玩呢！",
        "unit_id": 136511
    },
    {
        "type": "background",
        "background": "502660"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是這樣……",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我想來玩經典的新年遊戲，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也就是放風箏！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "風箏上畫了圖……",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這該不會是……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒錯，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是弟弟喔！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想透過展現在空中翱翔的弟弟，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n讓東國的人們也了解",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟的可愛與帥氣。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想東國的人們看見弟弟後，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一定也能",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "帶著幸福的心情度過這一年！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "藉由在新年的空中飛翔，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n弟弟將會一飛沖天！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也對風箏寄託著這樣的心願！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來如此！",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……原來如此？",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "都好啦。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n反正放風箏感覺很好玩！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要放囉……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我放～！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哼哼♪",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我要就這樣讓風箏線延伸到極限，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓風箏飛得更高更遠！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "控制得很穩定……",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃真拿手！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n風箏上的弟弟",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來也很開心呢♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿♪",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "被人稱讚",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然很高興呢～♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也順利讓風箏線拉長到最極限了！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就像是景上天飛一樣！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳想說的是「錦上添花」，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喜上加喜的意思吧。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃居然",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能讓弟弟飛到空中極限……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼接下來，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "輪到姐姐了！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n換手吧，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "給妳♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝♪",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼那麼，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在這裡要拿出來的是……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "新的風箏線～！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n把這條線綁上去……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很好！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就用這條線跟姐姐的愛，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n把弟弟帶到更高的地方去！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n去吧，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟～！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真不愧是",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n風箏上的哥哥，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "變得越來越小了喔！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為姐姐的愛",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多到可以穿越天空、直達太陽啊！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這點小事是理所當然的……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "奇怪……？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐？",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳怎麼了？",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總覺得，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "空中上層的風好像很強……！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n突然很難控制",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "風箏了……！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不會吧……",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_030"
    },
    {
