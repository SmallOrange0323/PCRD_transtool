        "name": "靜流",
        "words": "呵呵……",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_058"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "笑我吧，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟、",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "笑我這個大放橘子的",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "悽慘的姐姐……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳想說的是",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "「大放厥詞」吧。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣下去絕對不行！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n姐姐居然反過來說錯話被我糾正，太嚴重了！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為了讓姐姐的心靈恢復……",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然還是得靠哥哥才行！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想到了一個辦法，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請幫幫我！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_061"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請哥哥",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "坐在這裡，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n然後把兩眼無神的姐姐",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "移動到哥哥後方，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n再把剩下的年菜放在哥哥面前……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很好。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這下子，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥和姐姐一起玩的雙人羽織，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就準備OK了！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和弟弟玩",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_063"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雙人羽織……！？",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像逐漸回神了呢，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "身為妹妹，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無法對崩潰的姐姐置之不理，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以想出了可能會讓姐姐開心的法子喔。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃……",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_065"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n妳真是個為姐姐著想的妹妹啊……！",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼就請兩位，",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_066"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "披上這件偏大的羽織……",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請用♪",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n姐姐，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請餵哥哥",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吃年菜！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_067"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我要餵了喔，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊啊，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好幸福……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "居然可以緊貼著弟弟，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n同時餵他吃年菜……♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然雙人羽織看不見對方的表情，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_068"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過這部分我會用姐姐的想像力補足的。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼……",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "張嘴啊～♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好厲害！",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_069"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n明明應該看不見哥哥嘴巴的位置，",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n卻準確成功地餵他吃了年菜喔！",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這就是，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_070"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐力♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n也就是，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "愛的力量哦♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我原本想說不論成功或失敗，都會很有趣……",
        "unit_id": 137912,
        "voice": "vo_adv_1365002_071"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過實在是太厲害了，嚇了我一跳。",
        "unit_id": 137912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃也是，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_072"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "等妳能夠隨心所欲地使用妹妹力，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一定就能變得跟姐姐一樣喔。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼弟弟，",
        "unit_id": 136511,
        "voice": "vo_adv_1365002_073"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我繼續餵下一樣給你吃喔。",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "張嘴啊～♪",
        "unit_id": 136511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靜流寵溺著心愛的弟弟，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也順利展現了愛有多大，感到心滿意足。"
    }
]