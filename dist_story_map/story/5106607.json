    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}、依里及茜里在拉菲和艾米的帶領下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n走在充滿聖誕氛圍的蘭德索爾街道上。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "弟弟～！",
        "unit_id": 1,
        "voice": "vo_adv_5106607_000"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "怎麼回事？",
        "unit_id": 5512,
        "voice": "vo_adv_5106607_001"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n有個人朝著這裡跑過來，都揚起塵土了……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個聲音",
        "unit_id": 124112,
        "voice": "vo_adv_5106607_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "難道是……",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然是我弟弟！",
        "unit_id": 104914,
        "voice": "vo_adv_5106607_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我看一眼就認出來了。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這果然是",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "愛的力量吧♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇，",
        "unit_id": 124012,
        "voice": "vo_adv_5106607_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是靜流小姐耶♪",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳好～！",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你們好",
        "unit_id": 104914,
        "voice": "vo_adv_5106607_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天大家聚在一起是怎麼了呀？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果要做什麼事的話，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我也來幫忙吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "不必勞煩妳費心了！",
        "unit_id": 8912,
        "voice": "vo_adv_5106607_006"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n我們是天界的天使。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n倒不如說我們是為了幫助你們人類而降臨的。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳們是真的天使呀？",
        "unit_id": 104914,
        "voice": "vo_adv_5106607_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這還是我第一次看到呢。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大家這是在幫忙嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真不愧是弟弟，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "了不起、了不起♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "所以，",
        "unit_id": 5512,
        "voice": "vo_adv_5106607_008"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我也會讓姐姐妳幸福的！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n我開始囉！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n天使",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "之箭！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_5106607_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "奇怪？",
        "unit_id": 124112,
        "voice": "vo_adv_5106607_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什麼事……",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都沒發生？",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "靜流，",
        "unit_id": 124012,
        "voice": "vo_adv_5106607_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳有覺得哪裡不一樣了嗎？",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有呀？",
        "unit_id": 104914,
        "voice": "vo_adv_5106607_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n和往常一樣，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "心裡滿滿的都是對弟弟的愛……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "姊姊的魔法居然沒有作用，",
        "unit_id": 8912,
        "voice": "vo_adv_5106607_013"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n太奇怪了，",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "不可能呀。",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "那換我來吧……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n天使之箭！",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許……",
        "unit_id": 124112,
        "voice": "vo_adv_5106607_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是因為她已經很幸福了",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也說不定……",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯♪",
        "unit_id": 104914,
        "voice": "vo_adv_5106607_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我都能這樣和弟弟待在一起了。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n非～常幸福的♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好厲害……",
        "unit_id": 124112,
        "voice": "vo_adv_5106607_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不愧是靜流小姐。",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n愛的力量真是不得了……",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯、",
        "unit_id": 124012,
        "voice": "vo_adv_5106607_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里我們也得好好學習呢……",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我說我說，弟弟，",
        "unit_id": 104914,
        "voice": "vo_adv_5106607_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你還好嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是幫天使們的忙累了，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐隨時可以幫你接手的。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "……這未免也太姊弟情深了吧？",
        "unit_id": 8912,
        "voice": "vo_adv_5106607_019"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n人類",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "還真是讓人有點搞不懂……",
        "unit_id": 8912
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哈哈哈，",
        "unit_id": 124012,
        "voice": "vo_adv_5106607_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我覺得天使也有相似之處呢。",
        "unit_id": 124012
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這種事",
        "unit_id": 124112,
        "voice": "vo_adv_5106607_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也許是自己發現不了的吧～",
        "unit_id": 124112
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "怎麼了，",
        "unit_id": 5512,
        "voice": "vo_adv_5106607_022"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳們兩個這樣一直盯著我們看……",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "很",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "奇怪耶！",
        "unit_id": 5512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，雖然什麼事都沒做，\n{player}一行人又再次盡到天使的職責。"
    }
]