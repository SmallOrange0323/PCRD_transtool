    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好～",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n美美，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "快起來快起來。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n快點，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "曬在太陽公公下很快就會醒囉。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "啊嗚嗚～？",
        "unit_id": 102011,
        "voice": "vo_adv_2008001_001"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n禊，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不要抱人家啦～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊哈哈，",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒想到美美這麼重！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不愧是最年長！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對、",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對女孩子說",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳很重的這件事，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是非常沒有禮貌的唷！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是我在書上看到的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "沒關係唷？",
        "unit_id": 102011,
        "voice": "vo_adv_2008001_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n但是，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不要抱著人家嘛～，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "因為暖暖的",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "就又會想睡了呢♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呀哈哈～",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "小孩子的體溫好像比較高喔！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n之前，哥哥他說過的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚咕……",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n為什麼大家",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都這麼隨心所欲呀，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n看來我不振作一點可不行呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "比起這件事！",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家看這邊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "聽我說！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n很明顯這非常的奇怪對吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明應該是在安全的蘭德索爾裡玩吧……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但一醒過來，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "卻是在見也沒見過的外頭呀。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "真的耶～",
        "unit_id": 102011,
        "voice": "vo_adv_2008001_009"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n這",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不是在做夢吧。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "禊，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "捏我的臉頰看看～？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真捏了妳就又會要哭要哭的啊，美美……",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還有",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們可不是在玩唷，鏡華。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我們是在進行【小小甜心】的活動吧。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也只是扮家家酒吧。",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我們不過就是在學",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大人們在公會裡，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "工作的樣子而已啊。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "比起這種事，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我認為應該要再多念點書會比較好。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那樣的話，",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華妳不要參加不就好了嘛～？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊和美美兩個人玩就好♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我又沒說我不想要參加！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n而且如果我不在，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還不知道又會鬧出什麼事，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我不好好看著妳們不行啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "欸嘿嘿。",
        "unit_id": 102011,
        "voice": "vo_adv_2008001_014"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "雖然一直都是{player}哥哥他，\n像是爸爸一樣在身邊照顧著我們啊。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "可是最近，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "他好像有點忙呢。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "大人們還有工作要做，真累人呢。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n但是，我還想要和哥哥再一起出來玩呢～。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美也想～",
        "unit_id": 102011,
        "voice": "vo_adv_2008001_016"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "想要和哥哥見面呢♪",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "知道了知道了，",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要扯開話題啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n比起那種事，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們還是先來想想要怎麼回到蘭德索爾吧！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然想把麻煩的事都交給鏡華……",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n但這看起來好像真的不太妙，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不做點什麼事不行呢。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那個嘛……",
        "unit_id": 102011,
        "voice": "vo_adv_2008001_019"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "迷路的時候呀，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n只要把索爾之塔當做路標走就行了，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "大人們都這樣說的唷。",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "在哪裡呢，那個索爾之塔？",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～？",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n被附近的樹和石頭檔住了，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "什麼都看不到喔～？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！ ",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "禊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不可以探出頭！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "外面可是有很多魔物在徘徊的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果不躲好的話可是很危險的唷～！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但如果不找到索爾之塔，不就回不去了嘛。",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "別擔心啦別擔心，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們可是很厲害的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不會輸給什麼出沒在路邊的魔物啦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": " 大概吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "『大概吧』",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還得了呀～！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n和魔物戰鬥，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果輸了可是會死掉喔～……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還是仔細思考過後，再行動吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們之所以勉強可以和魔物戰鬥的原因……",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是因為{player}",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個奇怪的能力，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n把我們的力量增強的關係。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "『若看到魔物先跑再說』，",
        "unit_id": 103611,
        "voice": "vo_adv_2008001_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "爸爸媽媽都是這樣教我們的吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n像我們一樣的小孩子，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是打不贏魔物的唷，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "常理來講。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是這樣來著……？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣的話，我們去找哥哥吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n如果有哥哥在，就誰都不會輸了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "叫一叫會不會冒出來呀？",
        "unit_id": 100411,
        "voice": "vo_adv_2008001_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "喂～咿，",
        "unit_id": 100411
    },
