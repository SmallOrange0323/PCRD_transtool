[
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在吉歐‧尼布爾黑爾中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n薇歐莉特與格蕾斯，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "還有管家杜蘭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了７周年紀念日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在計劃要送賀禮到蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "該送騎士先生他們",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "什麼樣的禮物才好呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "因為現在沒辦法去參加慶祝的宴會，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "至少",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "想要挑個能讓他們高興的賀禮……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒辦法，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_001"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我們就待在吉歐‧尼布爾黑爾陰暗地慶祝吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "其實妳很期待",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "烤玉米嗎？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒、",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_002"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒有。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "才不是那樣……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯真是的，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "站著大口吃東西那種事，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我已經不會再做了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……",
        "unit_id": 52612,
        "voice": "vo_adv_9010004_003"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "以前去吉歐‧格黑納時發生了什麼，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "我之後再慢慢聽……",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n吉歐‧尼布爾黑爾現在",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "正處於騷亂中。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n雖然十分可惜，",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "但這次的宴會只能缺席了。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如果我們突然到訪蘭德索爾，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_004"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "可能也會",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n讓大家嚇一跳。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "妳想想，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就像移動式鬼屋一樣，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "應該會一片混亂吧？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……哎呀？",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_005"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n反倒是個好機會嗎。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "來去嚇破吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "把蘭德索爾所有人的膽子",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "全～都嚇破。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "呵呵呵……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "請妳別一個人自得其樂了。",
        "unit_id": 52612,
        "voice": "vo_adv_9010004_006"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……雖然想著",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "至少要送上賀禮。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n但要送什麼才好呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "能讓騎士大人",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "和大家都開心的東西……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n實在是想不到。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "果然還是",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "食物嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "畢竟貪吃佩可公主很愛吃。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "話雖這麼說，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "異世界的各位會喜歡的食物，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n吉歐‧尼布爾黑爾好像也沒有……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這時候，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_009"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就要用我們的特色決勝負呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "剛才我有抓一些過來，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "像這個，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "還有這個跟這個。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "之前在吉歐‧格黑納給大家看的時候，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_010"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n被說是有眼睛",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "又很黏稠",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "怎麼看都不像食物，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n從各位那邊收到了很多好評。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "哎呀……",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "原來發生過這種事嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "惡作劇可不能做過頭喔？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是的，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_012"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我知道。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過那時候，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n只是要獻給前輩貢品而已。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "雖然前輩想要的是布丁就是了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "黏稠的某種東西",
        "words": "●％◇★＠△！　●％◇★＠△！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這可不是……",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_013"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "布丁呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "只是誤差罷了，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_014"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "誤差。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n因為都是果凍狀的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "趁新鮮趕快做成料理吧，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "還是生的會讓他們更高興呢？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "希望",
        "unit_id": 133111,
        "voice": "vo_adv_9010004_015"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "他們不要被嚇到。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……不，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "畢竟是在廣闊的世界冒險的各位。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這些擔憂",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "應該是杞人憂天吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嗯，",
        "unit_id": 133012,
        "voice": "vo_adv_9010004_016"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒問題的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n貪吃佩可公主的話",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "一定會吃得津津有味的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "被",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "嚇一大跳……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "開心的表情彷彿在眼前浮現呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……妳果然",
        "unit_id": 52612,
        "voice": "vo_adv_9010004_017"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n只是想嚇他們吧……？",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，吉歐‧尼布爾黑爾"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n送出了新鮮又神秘的幸福贈禮。"
    }
]