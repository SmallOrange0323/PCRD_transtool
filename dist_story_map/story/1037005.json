[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "總覺得，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最近狀況不太好呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟成果",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不是馬上就能拿得出來。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這倒是可以明白，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "正因為每天勤奮的鍛鍊，才能獲得光彩的榮耀。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就是相信這一點，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以明白要設法熬過這種艱苦的時期。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我卻屢屢失敗。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "訓練中發呆被教官罵，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n寫的文件也是錯誤百出。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "完全無法集中呢，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該是個更精明一點的人才對啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都是因為{player}……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "吧，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "果然是這樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "自從遇到他之後，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我的狀況就變得怪怪的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然常常在鎮上遇到他，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但每次心臟都跳得很快，也不敢叫他。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "即使能說上話，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n聲音也會變尖，沒辦法好好說話。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "到底是怎麼回事呢……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n難道這就是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "傳說中的戀愛病嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不不不，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像我這麼粗魯的人怎麼可能……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔～",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺真的很奇怪。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "明明就得調查{player}的事情，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但莫名地會想避開他。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣可不行呢。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n實在",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太不像我了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？\n{player}？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼你會在這個森林裡啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為一直在想{player}的事情，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以我",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看到幻覺了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……哇呀！？",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n等、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}？\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要突然摸我啦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我想你應該是為了告訴我，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這不是幻覺才摸我的～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但這樣我會很困擾。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不可以這麼輕易地就碰觸女孩子的身體。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n根據狀況不同，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有可能構成犯罪唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "身為維持法律與秩序的",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】的一員……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n到時就必須要",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "逮捕{player}了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要把問題丟回來給我啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗚嗚。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}，果然還是很難對話呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不是在說你不好，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是覺得和你跟其他人的距離感不太一樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是因為身負某個任務，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n才會來探索這個神秘森林。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這是我隸屬的",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】所指派的工作。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是個很適合新人的打雜工作，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不是什麼重要的任務唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這座森林裡有原產一種，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以當作研磨劑材料的植物。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要以特殊的器具採伐收集，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n然後再帶回去",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}喪失記憶了嘛……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你知道研磨劑是什麼嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "簡單來說呢，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是用來保養武器用的道具。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最近陛下不知道有什麼打算，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n開始準備大量的武器跟防具，正在強化軍備呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "照那樣子看來，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺像是要發動戰爭呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，準備好的武器裝備，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也不是光放在倉庫什麼的就好了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "萬一要用的時候卻不能用的話就糟了，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以還需要保養才行呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這種工作",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大都是交給階級最低的人去做。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也就是",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "像我這種新進團員負責的工作囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，【王宮騎士團】",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為歷經長年的軍事經費縮減，所以沒什麼預算呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也就沒辦法",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "購買保養用的道具。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以呢……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就才需要來找生長在野外的植物，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n自己製作研磨劑囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了配合上面的人心血來潮的想法，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們這些第一線人員可是很辛苦的耶。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "開～玩笑的啦……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，不小心發了牢騷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣好像在",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "批判高層跟王宮一樣……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這種話可不能跟同事說呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能夠聽我發牢騷的人，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n大概也只有{player}了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聽我說這些事情應該很悶吧。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n抱歉抱歉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那換個心情，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來聊些有趣的事情吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "基本上我只要可以聊天就會覺得很開心，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n很幸福唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……那個。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}，\n為什麼要用那麼憐愛的眼神看我呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "「很辛苦呢。一定很累吧。打起精神來」",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯、",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n謝謝。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}真的很溫柔，",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是想幫我打氣對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇啊……",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}真的是個好人呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我很喜歡呢。",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不對，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是指單純喜歡這樣的人的意思。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呀！？",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n為、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼要把臉靠過來？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你還不能親我啦……！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你聽不太清楚我說的話嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "森林裡",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那些大自然的聲音意外地很吵呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而且跟{player}在一起，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不知道為什麼我也沒辦法大剌剌地說話了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你還問我「為什麼」？",
        "unit_id": 103711,
        "voice": "vo_adv_1037005_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你這樣問我，我也很困擾好不好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我才想知道原因是什麼呢。",
        "unit_id": 103711
    }
]