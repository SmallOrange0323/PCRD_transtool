    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呼，",
        "unit_id": 133712,
        "voice": "vo_adv_5201401_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這傢伙",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "動作很不錯喔。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我記得是真那製作的魔物吧。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 133912,
        "voice": "vo_adv_5201401_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "名字是神荒尾。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是個非常麻煩",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "又令人熱血沸騰的對手。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說……",
        "unit_id": 133812,
        "voice": "vo_adv_5201401_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "決定這名字的時候，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真那很難得選擇了",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在七冠內舉行命名投票呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～",
        "unit_id": 133712,
        "voice": "vo_adv_5201401_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有印象我有印象。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n結果還是選中了真那提名的名字嘛。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我一直很在意……",
        "unit_id": 133812,
        "voice": "vo_adv_5201401_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那時候",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的候補名稱裡",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是不是有個叫做",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「狐太」的名字？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "狐太……",
        "unit_id": 133912,
        "voice": "vo_adv_5201401_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那什麼一點命名美感都沒有的名字。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真的有，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我確實有印象。",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會提出這種像開玩笑的名字的七冠……",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是妳？",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那怎麼可能啊。",
        "unit_id": 133712,
        "voice": "vo_adv_5201401_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳把我當成什麼樣了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也不討厭狐太這個名字",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是了。",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 133812,
        "voice": "vo_adv_5201401_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "反正這種事怎麼樣都好。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大概是因為變成懷念的模樣了，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想起這件事",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就順口提起來。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……嗯～？",
        "unit_id": 133712,
        "voice": "vo_adv_5201401_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然不知道誰提議狐太這名字，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而且說起來，",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那她為什麼會選擇投票啊？",
        "unit_id": 133712
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在思考也不會明白囉。",
        "unit_id": 133912,
        "voice": "vo_adv_5201401_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比起那種事，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來戰鬥還沒有結束喔？",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這場還在四處上演的爭鬥盛宴，",
        "unit_id": 133912
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我們先下手為強吧……☆",
        "unit_id": 133912
    }
]