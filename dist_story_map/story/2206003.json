        "words": "妳好像心情非常好喔～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "妳這麼喜歡呀？",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_052"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "他、",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "們♡",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是啊。",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_053"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "過去光是聽汝談論旅行見聞，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家便已對他們深感興趣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而聽人轉述與親眼見識之間，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "仍有天壤之別。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "明明生著一張連蟲子都不敢殺的臉，",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_054"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而無論哪位",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "都各有奇異之處。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n再加上",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此後又會有新的來客上門──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家想必是太過期待，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才會不禁",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "暗自偷笑啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_055"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "好玩的事跟可愛的人都還有很多喔～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "應該不會讓妳失望吧？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "大概啦～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那可好極了。",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_056"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……然而──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為了避免對客人失禮，",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_057"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n更要緊的是，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為了避免災厄降臨吉歐‧格黑納，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "必須速速斬斷",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "後顧之憂。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯──",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_058"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n妳是說小鳳的事嗎～？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_059"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論是急速衰老，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還是不完整的轉生，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n發生於她身上的種種，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "怎麼想都有人在幕後操控。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是啊～",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_060"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n我個人呢，",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n對於「牆」",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "變得鬆鬆垮垮這件事？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也有點在意～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "的確。",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_061"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那麼──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……涅婭呀，",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_062"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可否",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "託汝去辦一件小事？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "哇～",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_063"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "出現了～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "姊姊提出無理要求時的常用問句～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "抱歉",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_064"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "總是麻煩汝。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "除了汝以外，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n再無他人能如此沒有貳心，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並且即使遇險",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也能靠一己之力歸來。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也是啦～？",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_065"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n因為我不會管國家政事嘛？",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "雖然妳叫我做，我就去做啦～",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "【幻變少女】的那些小姑娘",
        "unit_id": 129711,
        "voice": "vo_adv_2206003_066"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以及鳳凰，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n應可交由城中眾人接待。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "至於卡里莎小子──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "當然",
        "unit_id": 123311,
        "voice": "vo_adv_2206003_067"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "要帶他一起去呀♡",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那麼──",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我去散個",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "稍微久一點的步囉～",
        "unit_id": 123311
    }
]