[
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鈴莓小姐的說明書大獲成功！",
        "unit_id": 130711,
        "voice": "vo_adv_6144205_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這樣一來，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "應該不會再有因為冒失而延宕作業的情況了。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……那個，",
        "unit_id": 130711,
        "voice": "vo_adv_6144205_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我有想過。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果不是鈴莓小姐的，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而是做我的說明書，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不知道會是什麼樣子的呢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你的意思是",
        "unit_id": 130711,
        "voice": "vo_adv_6144205_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我是很難搞的小孩嗎！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我沒辦法接受這個感想，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼會需要",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這麼多頁數，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請你好好地說明！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哼哼，",
        "unit_id": 130711,
        "voice": "vo_adv_6144205_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是當然的♪",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "美美應該也只會有少少的頁數，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但禊很喜歡惡作劇，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "頁數可能會多一點呢。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為、",
        "unit_id": 130711,
        "voice": "vo_adv_6144205_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼會需要那樣的說明啊！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再說了，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我平常不是一直都有說",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不要把我當小孩子對待嗎！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……那個，",
        "unit_id": 130711,
        "voice": "vo_adv_6144205_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要摸我的頭，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也不是絕對不行。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但有時候我不想被摸頭，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有時又想要被摸頭，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n會有不同的情況……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "確實可能需要說明書……",
        "unit_id": 130711
    }
]