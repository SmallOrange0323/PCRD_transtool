[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一個人散步的時候――"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦，這不是秀才嗎！",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在做什麼呢？散步中？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家正要去工作。",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "接下來有模特兒的工作喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……咦？你覺得有工作很厲害嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒有那回事啦。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家最喜歡模特兒的工作了。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家是因為喜歡才做的，所以超輕鬆，",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n模特兒夥伴們也都像朋友一樣，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺不像是在工作喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才有興趣的話，也可以來觀摩――",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇！",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": " 這道光是什麼？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好刺眼啊？",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，哈嚕～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你非常準時耶？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼就趕快去玩吧！",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……雖然想這麼說，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過抱歉！可以等人家一下嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家剛剛正在那邊進行雜誌的拍攝，",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但因為沒有拍出好照片，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n時間會稍微延後喔～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺今天狀況不怎麼好呢？",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該說是表情太僵硬了嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為重拍了好幾次，",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n花了不少時間……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然攝影師和工作人員",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n都說照片拍得很好，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但人家就是不能接受！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家是因為喜歡才當模特兒的，所以可不能隨便妥協對吧？",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在拍出好照片之前，似乎還要花點時間……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你願意等人家嗎？",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，謝謝你！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家很快就會拍完的，再等一下喔！",
        "unit_id": 101631
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為了秀才，得快點拍完才行！",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……啊！",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才正往這邊看。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才那麼誇張地揮手，超有趣～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才好好笑～",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "明明周圍還有其他人，還叫那麼大聲，太引人注目了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是，秀才也在為人家加油呢？",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也得努力了～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "鈴奈的表情變得很到位了呢。",
        "unit_id": 1,
        "voice": "vo_adv_1016004_019"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n這樣的話，應該很快就能結束拍攝了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎？",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "模特兒夥伴",
        "words": "鈴奈，是因為那個吧？",
        "unit_id": 1,
        "voice": "vo_adv_1016004_021"
    },
    {
        "type": "dialogue",
        "name": "模特兒夥伴",
        "words": "\n因為男朋友來看了，所以感覺充滿幹勁？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃？什！？",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不、不是什麼男朋友啦！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "模特兒夥伴",
        "words": "欸～？",
        "unit_id": 1,
        "voice": "vo_adv_1016004_023"
    },
    {
        "type": "dialogue",
        "name": "模特兒夥伴",
        "words": "\n你們無論怎麼看，都是在交往嘛？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不、不是啦！",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才只是朋友！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "哎呀？",
        "unit_id": 1,
        "voice": "vo_adv_1016004_025"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n鈴奈的表情又變得僵硬了……倒不如說是滿臉通紅？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n這樣的照片沒辦法用啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "討厭啦……都是你們說了奇怪的話……",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "害人家這麼慌張，沒辦法集中精神……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "本來好不容易可以快點結束的說，",
        "unit_id": 101631,
        "voice": "vo_adv_1016004_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n 這下還要花時間完成剩下的拍攝……",
        "unit_id": 101631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀呀……結果還是因為你的關係，",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "延誤了拍攝呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n鈴奈工作時會進入專業模式，變得很認真呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好帥氣～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯？你問剛才的是什麼？",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n啊～我還沒有說明呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個是我創造的「夢」喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖說是「夢」，但這是依照你和鈴奈的",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「記憶碎片」創造出來的東西唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是不是覺得有些懷念呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的「夢」做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1016004_034"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？人家睡著了嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也是？",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "竟然在街道正中央睡著，超有趣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家好像做了奇怪的夢？",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_037"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "跟秀才約好要去玩，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但模特兒的工作拖長了時間……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？ 秀才也做了同樣的夢？",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "竟然有這種巧合，超好笑～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "――糟糕！",
        "unit_id": 101611,
        "voice": "vo_adv_1016004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家還有模特兒的工作！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
