[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像突然變冷了呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這點程度，反應太誇張了吧。",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n變涼了不是反而挺好的嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為小凱留是貓咪，",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以怕熱嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了。",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n比起炎熱的天氣，大家肯定更愛涼爽的天氣啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才沒那回事呢～",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也喜歡熱熱的呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱抱～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真受不了，",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別黏著我啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感情一直都很好呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，可蘿仔！",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是妳說的那樣啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點來解救我啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留還是老樣子，身上很香呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聞著聞著肚子就餓了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在說什麼莫名其妙的話啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放──開──我──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我又不是食物！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同貪吃佩可小姐說的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n氣溫開始逐漸下降了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原本生長著的樹木，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "模樣也跟著變了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是什麼？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿？",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像有什麼東西。",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "莫非是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "格里芬？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像是呢。",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這還是在下第一次見到那種顏色的格里芬。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實如此……",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難不成",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是公會尚未發現的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稀有物種嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……吞口水。",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好呢？",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠好像沒有察覺到我們的存在，",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就這樣等牠離開比較好吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………唔唔。",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說的也是。",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是連公會都不知道的存在，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也沒把握牠的能力有多強。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這麼做沒問題吧？",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……貪吃佩可？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我忍不住了！",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳沒頭沒腦的做什麼呀！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，小可蘿！",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子非常地餓！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尤其是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我超想吃烤雞串，想吃得不得了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來格里芬",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像發現我們了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此，先下手為強！",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們上！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011,
        "voice": "vo_adv_9040155_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳幹嘛突然發起突擊啊，白癡佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們也跟上！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好、",
        "unit_id": 105911,
        "voice": "vo_adv_9040155_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "目標，",
        "unit_id": 105811,
        "voice": "vo_adv_9040155_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "烤雞串！",
        "unit_id": 105811
    }
]