    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "騎士先生，",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_000"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "今天約我出來見面，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "該不會是……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "謝謝……",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_001"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "謝謝你，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "騎士先生。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n我現在能夠",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "跟騎士先生站在一起，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "光是這樣就很幸福了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n想不到竟有這麼一段",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "能讓我倆獨處的時間──",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "不過。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "啊，",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_002"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "不過",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "要是可以的話，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n我想跟你",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "要一樣東西。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "那個……",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_003"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "你可能會覺得有點怪。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n我想要騎士先生你的……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "簽名。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "還是、",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "不方便？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "這張紙上的……",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_004"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "這個欄位喔。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "簽上你的名字……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n然後再幫我蓋個章",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "就完美了。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "嗯。",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_005"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "沒……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "沒有啦。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "我、",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "我是……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "開玩笑的。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "畢竟在這夢境中收到的禮物",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_006"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "肯定是帶不回去的，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n終究只會淪為一場遊戲……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "所以我就想說，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n既然如此",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "乾脆玩得更認真一點",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "豈不更好？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "咦？",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_007"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "你真的……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "願意簽上名字嗎？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "這種像笑話一般的願望，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "你竟然願意幫我實現……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "……呃，",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_008"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "那麼……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n等一下……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "再去約個會",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "之類的。",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n只有今天一天，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "像夫妻那樣……",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "這也",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "可以嗎？",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "讓我做了一場如此美妙的夢……",
        "unit_id": 129031,
        "voice": "vo_adv_4010248_009"
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "\n",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "謝謝你，",
        "unit_id": 129031
    },
    {
        "type": "dialogue",
        "name": "愛莉",
        "words": "騎士先生……♪",
        "unit_id": 129031
    }
