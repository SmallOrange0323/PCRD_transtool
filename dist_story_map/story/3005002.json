    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "早啊～……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉呀？",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴早安，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳今天很早起呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是打這麼大呵欠可不行……",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "女孩要有女孩樣唷♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～……瑪莉早上太有精神了……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳的聲音在我睡眠不足的腦袋中哐啷作響的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n能不能把聲量放小一點啊～……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我的名字，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳還記不起來嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還以為我們很要好的，真令人難過～",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我不是『瑪莉』，是『莉瑪』唷？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，我是記得名字啦。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的名字不是鈴嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而妳是莉瑪，有時候會因為發音相近而搞混～……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有人叫了聲『莉瑪』，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我就會不小心回頭看『是我嗎？』，多此一舉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以從今天開始，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳就叫『瑪莉』吧～……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不行不行，",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n父母取的名字怎麼能這麼容易就改呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過可以的話，我也希望小鈴可以改名字呢。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟跟我的名字唸起來有點像呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～這種沒有結論的對話真是麻煩……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒關係，莉瑪就莉瑪吧。剛剛只是叫好玩的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哈哈哈。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n雖然『瑪莉』這名字也挺可愛的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是小鈴，妳看起來比平常還更想睡呢。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n妳又熬夜玩那個什麼『電玩』了嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳知道的，昨天那傢伙來牧場了嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n{player}要投遞信件跟貨物，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以才定期往來城鎮跟牧場呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "他是為了要賺零用錢，",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n才接這份工作嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對呀對呀。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是晚上下山很危險，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以每次都會在牧場過夜。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那傢伙很隨和啊～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "他在這邊過夜時，我們就會一起玩通宵。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那傢伙，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總是豪爽地答應跟我一起玩，我很喜歡他呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那傢伙還沒回去嘛，他在哪？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想解一個不一起玩就沒辦法通關的地圖，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要找他幫忙。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這就沒辦法讓莉瑪來了吧～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哈哈哈。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n對我來說，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要操作『電玩』的控制器很困難呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我剛剛有看到{player}……",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "他正在整理那邊的牧草地喔。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好像正在幫忙真陽的工作。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "{player}真是好孩子呢～很勤奮……",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，他應該會是個好丈夫♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為什麼大家都那麼喜歡工作……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真搞不懂，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我也沒意見。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我懶得走到牧草地，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳可以揹我嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是的，每次都這樣。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳不要過分把我當成馱獸喔。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴……",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳要更加學習",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好好照顧自己啦。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，如果我想的話～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好啦，揹我啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不行喔～我已經被預訂了。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳看妳看，我正揹著小栞呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼、呼……♪",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉呀，小栞……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為什麼她在妳背上睡得像個小嬰兒呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。小栞她一開始",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n想跟{player}",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n一起幫忙真陽的工作。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不知道是不是累了。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n看到她睡著了，我就揹她。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "睡覺一直吹風會感冒的吧。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞畢竟身體不好……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我們要多多照顧她才行。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我的背上有很多毛，感覺很柔軟……",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "應該很溫暖吧，嘻嘻嘻♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，咦？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我睡著了嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "早安，小栞。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "抱歉，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我們說話吵醒妳了嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "早啊～小栞。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那可是我的床，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳可以讓開嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，啊……",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起，給妳添麻煩了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n莉瑪不喜歡被當成馱獸對吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒關係啦。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n平常都給小鈴騎，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "已經習慣了啦♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞妳繼續睡吧。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_041"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我會把妳載到床邊喔。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，真是不好意思……",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_042"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天身體狀況不太好。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "意識感覺也模～模糊糊的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在好像也不太能走。",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果可以載我一程，真是幫了大忙呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n莉瑪很暖和，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n給妳揹著好舒服喔……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，我有同感。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好好喔～小栞。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也好想睡，沒辦法走了，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n莉瑪，載完小栞後",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就回來載我吧～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是的，不要一直撒嬌啦。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_047"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我會慢慢走，盡量不讓妳覺得搖晃喔？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103811,
        "voice": "vo_adv_3005002_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真謝謝妳，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n莉瑪……♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n沒關係。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "反正我找其他人揹我。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_050"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那傢伙",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就在那片牧草地上呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘻嘻，就找那傢伙揹我吧。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_051"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n畢竟是男生，體力應該不錯吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喂～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唉呀，鈴鈴！",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_052"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n早上就起來了超稀罕的啦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總算要過作息規律的生活了嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，我完全沒這個打算……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_053"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼了，這樣慌慌張張地跑來跑去。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "出什麼事了嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_054"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是什麼麻煩事嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是，稱不上出事的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_055"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……只是奶擠不太出來。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_056"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳有小孩喔？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是不是，",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_057"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我不是在說我的奶啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_058"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，妳是在逗哏嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可惡～我居然沒有注意到妳就在眼前鋪哏！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，我基本上就是個逗哏的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔，妳在說什麼……？",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_059"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽雖然看起來這樣，畢竟也已經二十歲了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就算已經結婚還是什麼的，我也不覺得奇怪～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是不是，我還單身的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_060"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在這偏僻的牧場，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n也不會有奇怪的人要來娶我啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唉呀，先別管這事啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_061"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我是說，這隻牛最近出奶狀況不好。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我很擔心。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_062"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這有可能是生病的初期症狀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果是傳染病，不好好處理的話，整個牧場就都遭殃啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且如果是會傳給人的疾病，",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_063"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就要擔心栞栞……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以，我正在多方檢查研究啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_064"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也讓老哥",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n來幫忙這件事呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這隻牛脾氣有點暴躁～",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_065"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n要檢查也有點辛苦的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴，妳也來幫忙壓著這隻牛吧？",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_066"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳也算是先鋒部隊的，應該還算有臂力吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_067"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我有一段時間沒有接受訓練了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n肌肉無力啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦！？什、什麼？",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_068"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這隻牛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像在舔我呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，牠不是舔鈴鈴。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_069"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是舔卡在衣服上",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n看起來像是白色毛髮的東西……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_070"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n是莉瑪莉瑪的毛髮嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，大概是。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_071"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n莉瑪毛茸茸的很舒服，每次看到她我都會抱她。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可能就這樣沾到她的毛了吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～……",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_072"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n給牠這麼隨便亂舔，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n全身都濕答答的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_073"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n看看這隻牛的眼神，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不是在思春啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我很確定，",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_074"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n因為我從小就在牧場長大的嘛……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是這樣才擠不太出牛奶嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不是吧。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_075"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n會產奶代表牠是母的吧，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n莉瑪不也是母的？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且從根本來說種族也不一樣，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_076"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n牠只是肚子餓了吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "欸欸，",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_077"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是誰在叫我啊？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_078"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳來得正好。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_079"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我們在說這隻牛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n會不會是愛上妳了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦，什麼跟什麼啊？",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_080"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "突然跟我說這種事，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我很困擾的！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我、我不排斥被喜歡啦～？",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_081"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但是我覺得",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n戀愛對我來說還太早了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_082"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "牛牛，對不起喔？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n可以讓我考慮一下嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪，妳可以跟牛交談嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_083"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不過話說回來，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳也可以很正常的跟我們說話呢～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也沒有人在追究這件事，",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_084"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大家覺得也沒差，就這樣不了了之。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，不知為何我就是會說人話啊。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_085"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是我沒辦法跟牛牛交談呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵。",
        "unit_id": 105211,
        "voice": "vo_adv_3005002_086"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但是，你喜歡我，我很高興……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我來幫你刷刷毛吧♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔，不知是不是錯覺，這牛的心情好像好起來啦。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_087"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果牠的出乳量，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就這樣恢復正常就好了……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是的，",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_088"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n讓我擔心到沒完沒了的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哈哈哈。",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_089"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這不是很好嗎，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不過就這點煩惱而已……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "反觀城市的治安在惡化～",
        "unit_id": 102611,
        "voice": "vo_adv_3005002_090"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像很不得了呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n似乎有什麼腥風血雨呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，說的也是。",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_091"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴，妳的狗嘴偶爾也會吐出象牙的啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在這邊像這樣平安無事，",
        "unit_id": 103311,
        "voice": "vo_adv_3005002_092"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n感覺一則以喜一則以憂呢……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "希望平靜的日子能夠一直持續下去呢。",
        "unit_id": 103311
    }
]