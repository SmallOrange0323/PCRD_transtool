[
    {
        "type": "background",
        "background": "500404"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位～。",
        "unit_id": 105913,
        "voice": "vo_adv_4003006_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為時間的關係我們就依照這份在遺跡中得到的食譜，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n製作些簡單的料理吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然材料方面不算充足，",
        "unit_id": 105913,
        "voice": "vo_adv_4003006_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不可能完全依照食譜啦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這個遺跡，好像也沒什麼生物呢。",
        "unit_id": 105812,
        "voice": "vo_adv_4003006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖說會出些『闇影』就是了～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，但只要能吃到好吃的東西我就沒有怨言了",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵，我這次也沒意見囉！",
        "unit_id": 106012,
        "voice": "vo_adv_4003006_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為我發現了『斷崖遺跡』裡面有搬不完的金銀財寶呢！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算遇到生死關頭，只要有你們相陪就好了。",
        "unit_id": 106012,
        "voice": "vo_adv_4003006_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要賣掉得到的寶物還可以成為小富婆呢，可以買之前一直想要的書跟小玩意之類的東西♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯但是遺跡都是受國家管理的，如果要把寶物全部據為己有的話，會有些法律的問題。",
        "unit_id": 106012,
        "voice": "vo_adv_4003006_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過只是稍微拿走一些的話應該是不要緊的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_4003006_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "參考的食譜，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是用古代文字寫的，所以解讀上要花點時間。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_4003006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次也沒遇到什麼問題就調理好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n味道究竟如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很好吃呦！",
        "unit_id": 105812,
        "voice": "vo_adv_4003006_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但肚子餓的時候什麼都好吃就是了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔嗯。",
        "unit_id": 106012,
        "voice": "vo_adv_4003006_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳隨時隨地都是這句『什麼都好吃』嘛？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對！",
        "unit_id": 105812,
        "voice": "vo_adv_4003006_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要大家在一起，就是隨時隨地『什麼都好吃』的～☆",
        "unit_id": 105812
    }
]