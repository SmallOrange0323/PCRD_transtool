    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們要",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "永遠在一起喔。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿♪",
        "unit_id": 104932
    },
    {
        "type": "still",
