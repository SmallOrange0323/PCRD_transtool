    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n什麼東西都學得很快，",
