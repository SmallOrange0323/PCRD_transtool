    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好巧喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是啦，",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這次真的是貨真價實的偶遇。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "連姐姐我都很意外呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你在做什麼呀～",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n怎麼會在這裡？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔，",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "投遞信件的兼職嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為這個緣故，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你偶爾會在這座牧場和蘭德索爾之間往來嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你做這麼多份兼職工作啊，\n{player}。",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我好擔心你會不會因為工作過頭",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把身體搞垮了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起在家閒著沒事做，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n充分利用閒暇時間要來得有意義多了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我呀～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如你所見，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我在這座牧場練習騎馬呀！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "剛才差點撞上",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n路過的{player}……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "都嚇出一身冷汗了～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為公會的工作的關係，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會跑遍全國各地。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想會騎馬的話，應該會方便許多，",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以現在正在練習。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果距離很遠，",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n以徒步的方式移動會滿辛苦的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "大部分以少人數行動居多……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起一整輛馬車，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n單借一匹馬要來得划算多了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，\n你不嫌棄的話，回程……",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐騎馬送你一程吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有和牧場簽約，",
        "unit_id": 104911,
        "voice": "vo_adv_1049008_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n租借了馬匹一個月。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以可以把馬騎回家～♪",
