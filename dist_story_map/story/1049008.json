        "voice": "vo_adv_1049008_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還起了個大早去叫醒你……",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "結果{player}\n自己起床了，真可惜。",
        "unit_id": 104932,
        "voice": "vo_adv_1049008_026"
    },
