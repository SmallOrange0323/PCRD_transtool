[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳打算怎麼做？",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n剛才我也說了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n拉基拉基已經到極限了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要是不趕快回去原本的地方的話，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n道路就要關閉了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "想加入我們的話，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就快點抓住我的手。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "趕快決定。",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我可不想",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n陪妳一起被關在這種地方哦。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……就我個人來說，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我是很想把妳從監牢裡救出來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然妳是個暴君，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我討厭妳的殘忍、煩人、還有大濃妝。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但並不是個會讓人反胃的大壞人。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "至少妳沒有壞到，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n需要被關在這個",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n奪走妳自由的牢房裡。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……這種話，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n出生至今我還是頭一次聽到呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好吧。",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳讓我對這事開始感興趣了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就跟妳一起走吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然要不要當妳們同伴還是得看我心情，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣也沒關係嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈哈哈。",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們可是從未想過",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n可以控制住像妳這樣的人啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟能夠自由自在的活著才像妳啊。",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n『七冠』之一，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n『誓約女君』克莉絲提娜‧摩根。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "『七冠』……",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n『誓約女君』……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知道為什麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總覺得我似乎有聽過呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂！",
        "unit_id": 1,
        "voice": "vo_adv_2006013_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "隔壁的傢伙，妳吵死了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚呀！？",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n怎、",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊……",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那是在我被逮捕之前，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n先被關到牢房裡的人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知道是難伺候還是只是個笨蛋，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一直發出噪音害我無法清淨呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然這裡是個無法以正常手段逃離的監獄。",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但牢房與牢房間的牆壁",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n卻意外地很薄呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聲音很容易就傳過來，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就連打呼聲也都聽得一清二楚，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有夠受不了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啥？",
        "unit_id": 1,
        "voice": "vo_adv_2006013_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n話說隔壁的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳從剛才開始就在跟誰講話啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是不是看到幻覺了啊？",
        "unit_id": 1,
        "voice": "vo_adv_2006013_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在跟妳腦中的小妖精開心地聊天嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要是妳再繼續大吵大鬧的話，",
        "unit_id": 1,
        "voice": "vo_adv_2006013_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我就要打破牆壁，過去把妳嘴巴強行封起來啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吵死了。",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只不過是路邊的一團爛泥，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一副了不起的口氣，你以為你在跟誰說話啊？？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈，",
        "unit_id": 1,
        "voice": "vo_adv_2006013_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我口氣不好還真抱歉啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是從小就在暗巷裡長大，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n土生土長的不良份子！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要我像那些高雅的貴族一樣說話，",
        "unit_id": 1,
        "voice": "vo_adv_2006013_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n光想就讓我全身發癢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等一下……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個聲音，難道是！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大吾！",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你該不會是大吾吧……！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊？",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_027"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n怎樣，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "為什麼妳會知道我的名字啊？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哈哈！",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_028"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n看來我大吾大人的名號",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n也變得很有名啦？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "話說……",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_029"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我真的聽到鄰居小姐以外的人的聲音了，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n是怎樣？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是我在牢房裡待太久，",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_030"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n腦袋變得怪怪了嗎？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "還是說是",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_031"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "鄰居小姐\n妳一人分飾兩角在演戲嗎？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可沒那種可愛的興趣呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……妳認識他嗎，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諾維姆？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n喂大吾，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你還記得我嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是我啊，諾維姆。",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在【永恆集會】的時候，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們有在一起做事吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊？",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_035"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n永恆……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "什麼？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n那種東西我聽都沒聽過啦！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妄想也該適可而止吧！",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_036"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n本大爺從出生以來就沒有朋友跟家人，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n從小到大都是孤獨一匹狼！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太可憐了……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但聽你說了你的身世，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或許能跟你變得更加親近呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，這樣啊。",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你也",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把以前的事情全都忘了啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "即使如此",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你也還是我們的夥伴，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我絕對不會見死不救的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一個人逃獄跟兩個人逃獄都一樣，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n讓我來幫你一起逃獄吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳說什麼？",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_041"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n幫我逃獄？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這個嘛……",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_042"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n要是能離開這種煩悶的地方，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n也算是實現了我的願望啦。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但那種事情，有可能辦到嗎？",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_043"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n這裡可是在長久的歷史當中，從來沒人逃獄成功，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n藏在王宮裡的永久監獄耶。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "就算本大爺用盡全力想打破牆壁，",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_044"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n也是全部都被反彈回來了！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～。",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你和克莉絲提娜的牢房之間的牆壁，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n比較……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "薄對吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要你們兩個盡全力使出攻擊，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n或許可以打破也說不定？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要你能來到這邊，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我就能讓你一起離開。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不試也不知道結果，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你就用全力打向牆壁吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "加油，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你是全世界最強的男人吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊？",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_049"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n雖然不懂怎麼回事，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但都被妳慫恿成這樣了，我可不能無視啊？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "如果在牆壁旁邊的話就先退下吧，",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_050"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我要用力打囉！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哦啦哦啦哦啦……！",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦哦，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像可以！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n牆壁上出現裂痕了哦～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "加油～加油♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拜託妳了，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_052"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n克莉絲提娜，妳也幫幫他好嗎！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要是『七冠』與",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n獲得那個權能的『公主騎士』合力的話，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就沒有什麼是不可能的！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊？",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為什麼我得……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然是想這麼說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我一直待在牢房裡，身體都遲鈍了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了解決運動不足的問題，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就稍微幫點忙吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知道是不是太過信任這監獄的牢房，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他們居然沒有沒收我的武器。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會用這把劍",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "全力砍向牆壁！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算好時機就一起上吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "隔壁的！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "好哦，",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_058"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "隔壁的！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "準備…",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "上啦上啦……☆",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦哦，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺不錯！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們兩個果然都很厲害啊！",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200601301"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太好了，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的太好了啦……♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然你不記得我的事情，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但能再見到你我還是覺得很開心！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為你",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一直下落不明……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n原來啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來你一直被關在牢房裡啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還好嗎？",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_062"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n身體狀況有出什麼問題嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有沒有好好吃飯呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你是我老媽嗎！？",
        "unit_id": 190711,
        "voice": "vo_adv_2006013_063"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n搞什麼啊這傢伙？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "啊啊真是的，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我快瘋了啦？",
        "unit_id": 190711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然這光景令我莞爾……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我們不是沒時間了嗎，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諾維姆。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們要是因為動作慢吞吞而超過時間，",
        "unit_id": 107111,
        "voice": "vo_adv_2006013_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n導致無法逃獄的話，就真的蠢斃了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_066"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說的也是，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這些話就等之後再說吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "首先大家先一起逃出這裡！",
        "unit_id": 106112,
        "voice": "vo_adv_2006013_067"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "朝著那自由的世界出發，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "Let's Go～☆",
        "unit_id": 106112
    },
    {
        "type": "still",
        "still": "200099901"
    }
]