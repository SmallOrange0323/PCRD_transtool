[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "除夕當天。{player}到達了\n從日和那邊拿到的地圖上所紀錄的會面點。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　這裡這裡！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呀。",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有遲到真是太好了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生。",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你會不會口渴？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "　\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們有帶飲料和便當過來，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n肚子餓的話就說一聲唷。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說這件嗎？",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "　這叫做和服，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是這附近年底年初或慶典之類的時節會穿的衣服。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原本",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像是從其他大陸傳過來的服裝。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看你看，騎士先生！",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　不錯吧〜！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我的和日和的，",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都是怜幫我們穿上的喔。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還適合……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗎？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝、",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "謝謝……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能被你誇獎真榮幸。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿。！",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　謝謝囉，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "――不好意思打斷你們講話。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_009"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n你們幾位，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "是【破曉之星】的成員嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正是。",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "您是這裡的祭司嗎？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "沒錯。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_011"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "這次能接受我們的委託，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n真的非常感謝。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請別在意！",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的時候",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就要互相幫助幫助",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛那句話是公會的基本方針，",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不需要客氣。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "我明白了。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_014"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "哎呀，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "好像比聽說的人數",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "多了一位……？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難道，",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行嗎……？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他會幫忙支援我們，",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是很可靠的夥伴。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望這次的委託",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能讓他一起同行。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "原來是這樣啊。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_017"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "當然非常歡迎。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n我們也會多準備一人份的報酬。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "非常謝謝你！",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了，騎士先生！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "不不，我們才是。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_019"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "那麼馬上",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "來針對今天的委託",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "做比較詳細的說明吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "再麻煩您了！",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_020"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "那麼首先",
        "unit_id": 511,
        "voice": "vo_adv_5010001_021"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "從這座神殿的由來開始……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "這裡是自古以來就存在於蘭德索爾，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "祭祀古老神明的神殿。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我記得文獻上說，",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡可能比索爾之塔還要古老……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "妳很了解呢。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_023"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "而且據說這座神殿直到現在，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n都受到職掌願望的古老神明的庇佑。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "庇佑，",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "指的是什麼呢？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "這是很好的問題。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_025"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n就是……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "獻給這座神殿的願望會成真",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "的意思。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原來是這樣……",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很棒呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "然後如大家所知，",
        "unit_id": 511,
        "voice": "vo_adv_5010001_027"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n這座神殿",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "會在除夕時進行焚燒儀式。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在紙上寫下那一年沒實現的願望，",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一邊默念著希望明年可以實現，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一邊投入火焰中。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以這樣的方式",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓願望回到天上。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家都說在這裡焚燒的願望，",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n常常會在隔年實現呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "是啊。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_030"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "藉由淨化讓它蛻變，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n願望會變得比過去更容易實現。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "我們是這麼想的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好厲害——……",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來真的可以",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "做到這種事啊！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "當然實現與否",
        "unit_id": 511,
        "voice": "vo_adv_5010001_032"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "也會因人而異。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是呢……",
        "unit_id": 108711,
        "voice": "vo_adv_5010001_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "覺得有點可惜。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "可惜……",
        "unit_id": 511,
        "voice": "vo_adv_5010001_034"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "就是這樣。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "留下來的思念、",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "願望。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "這正是今天請大家過來的原因。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "只憑著焚燒儀式，",
        "unit_id": 511,
        "voice": "vo_adv_5010001_035"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "是無法完全淨化願望的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "殘留在焚燒的紙張或物品上的願望和思念未被淨化，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n充斥著這座神殿，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "最終將會化為實體。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說什麼……！？",
        "unit_id": 108911,
        "voice": "vo_adv_5010001_036"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "一開始會呈現像是碰不到的薄霧的樣子。",
        "unit_id": 511,
        "voice": "vo_adv_5010001_037"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n但是接近新年願望殘渣增加的話，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "就會附身於物品，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "最糟糕的狀況會化為實體開始暴動，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "襲擊來參拜的客人。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼會……",
        "unit_id": 108811,
        "voice": "vo_adv_5010001_038"
    },
    {
