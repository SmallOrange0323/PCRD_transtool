    {
        "type": "dialogue",
        "name": "碧",
        "words": "發、",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "發生什麼事了？　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "突然收到召集……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難不成",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "發生了什麼會對BB團的活動造成影響的重大事件！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "生日快樂～。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是哪裡的哪位先生女士，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "觸發了生日會這種現充的活動啊？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？　",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是我嗎？　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是我生日？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你竟然要幫我這種邊緣人慶生……！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種事發生在我身上真的可以嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦咦咦咦！",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n為為為、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為什麼你會知道這件事？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我我我、",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的生日這種小事，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就跟今天掉了幾根睫毛一樣\n不值得記住啊！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為什麼你會記住那麼沒有意義的事情呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "BB生日活動是什麼……",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "邊緣人為了邊緣人所舉辦的\n邊緣人生日派對？　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那還真的是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "等級相當高的邊緣人呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那種人真的存在嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有耶！　",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是我！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是我！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天是我的生日！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為太邊緣人到",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "連我自己都忘了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原、",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這就是所謂的驚喜啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過我真的很開心。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有了這個",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就算再當邊緣人10年我都能夠忍受……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊！",
        "unit_id": 104011,
        "voice": "vo_adv_1040500_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣不行！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今後BB團的活動……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要比以往更加努力才行！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
