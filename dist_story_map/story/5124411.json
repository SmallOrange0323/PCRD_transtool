[
    {
        "type": "background",
        "background": "500016"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふう、",
        "unit_id": 105311,
        "voice": "vo_adv_5114411_000"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そろそろ客足も落ち着いてきたな。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n私たちも",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "すこし休憩にするか。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "甘味が恋しくて仕方がない……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "そんなモニカのために……",
        "unit_id": 104611,
        "voice": "vo_adv_5114411_001"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "じゃじゃーん！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n特製カラメルたい焼きと、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n激甘ミルクティーのセットを用意しといたにゃ！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お代わりもいっぱいあるからにゃ。",
        "unit_id": 104611,
        "voice": "vo_adv_5114411_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "好きなだけ食べるといいにゃ。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うむむ……",
        "unit_id": 105311,
        "voice": "vo_adv_5114411_003"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "営業時間中だというのに",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ものすごい誘惑だ……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "今はお客さんもいないし、",
        "unit_id": 104611,
        "voice": "vo_adv_5114411_004"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "賄いを食べたって問題ないにゃ♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それに、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "こういう誘惑には、素直に従っておくものにゃ。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n何しろ",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "このお店の名前は……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "つまみ食いする猫！　",
        "unit_id": 105311,
        "voice": "vo_adv_5114411_005"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "だものな……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ふふ、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "確かに",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "タマキの言う通り。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ありがたくいただこう。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "──っと、",
        "unit_id": 104611,
        "voice": "vo_adv_5114411_006"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お客さんが来たみたいだにゃ。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "いらっしゃいませにゃ～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あっと、",
        "unit_id": 105311,
        "voice": "vo_adv_5114411_007"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いかんいかん。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "私も店に出なければ。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "このたい焼きは後ほどいただくとしよう。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "──ようこそ！　",
        "unit_id": 105311,
        "voice": "vo_adv_5114411_008"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "猫と駄菓子の店、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "『ナッシュカッツェ』へ！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n心ゆくまで",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "くつろいでいってくれ！",
        "unit_id": 105311
    }
]