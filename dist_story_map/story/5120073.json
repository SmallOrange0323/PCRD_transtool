[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "秋乃小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她在強韌和良好品行之間拿捏得宜，這一點很美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她憑藉著超乎尋常的行動力拉著大家走，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但用字遣詞卻很細膩。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n正因為她會體恤他人，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大家才會仰慕她吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話說回來，",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "紫藤家多到有剩的財力……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能不能也來",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n投資一下我的美麗呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "向世界廣傳",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我美麗的一大事業。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這肯定會",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "帶來任誰都開心的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美好結果的！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我常看到美冬小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在忙著工作，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那似乎也是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了重要的家人呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了誰而拼命的模樣",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n非常地美麗。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或許可以說",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她是體現了勞動之美吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有時候就別那麼重視效率，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一步步慢慢來如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真正的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可不是靠打折特賣就能獲得的啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只顧著",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n追求效率，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是會錯失",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真正重要的事物喔♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看著優花梨小姐的爽朗笑容，",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "心情就會很舒暢呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她喝下麥酒後",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "露出的放鬆表情……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我很喜歡喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為平常她是能幹",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又可靠的大姐姐，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才令人格外這麼覺得。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想送給優花梨小姐的建議只有一個……",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是適可而止……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這件事。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "凡事",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "做得太過頭都會有傷身心喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美容和健康",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "兩者是相輔相成的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美貌",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算美得過頭也不會有傷身心呢♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "貓",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "加上鯛魚燒……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就等於是珠希小姐呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n她的所有舉動像隻貓又隨心所欲，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "令人非常感興趣喔！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "誰都無法模仿",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的言行舉止……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "即便是真正的貓也一樣。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "其實我……",
        "unit_id": 126311,
        "voice": "vo_adv_5120073_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒有要送給珠希小姐的建議呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為她的美所屬的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n類型跟我稍稍不同呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來個聯名活動如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我覺得我的美貌×如貓一般",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "＝",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "偉大之美的發明喵♪",
        "unit_id": 126311
    }
]