[
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "竟然、",
        "unit_id": 10811,
        "voice": "vo_adv_5010321_000"
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "將煩惱、",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "打破什麼的……",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "\n那麼，",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "來讓我集結、",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "全部的煩惱……！",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "給你們瞧瞧吧！",
        "unit_id": 10811,
        "voice": "vo_adv_5010321_001"
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "\n你們這些傢伙，",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "邪餅神鏡餅",
        "words": "將人類的污穢的心靈……！",
        "unit_id": 10811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "全部的煩惱……？",
        "unit_id": 108811,
        "voice": "vo_adv_5010321_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "該不會，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要把108種煩惱一口氣全部叫出嗎！？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 108911,
        "voice": "vo_adv_5010321_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來這手啊……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接下來的戰鬥會更嚴峻呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論是什麼樣的對手，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "絕對不可氣餒，去戰鬥吧！",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好的——！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010321_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然我不太懂煩惱的事，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n總之把它們解決掉吧！　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要上囉——！！",
        "unit_id": 108711
    }
]