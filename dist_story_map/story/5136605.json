    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "街道をぶらつきながら、ノウェムはオクトーに話しかける。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なあオクトー",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n前から気になってたんだけどさ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "結局オマエって",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "強いの？　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "弱いの？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "えー、",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボク？　",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そりゃ弱いってことはないけど……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "普通くらいじゃない？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nそこらの連中は余裕だけど、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェムよりはか弱いしさ～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "やっぱり、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシのことバカにしてるよな？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nどうせ働くの嫌だーとかで",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "本気だしてないだけだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ってことで、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ちょっと調べてやろうと思ってさ～",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "おう！　",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_003"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "見つけたぜオマエら！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n俺と勝負しろ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うわ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_004"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "いつのまにこんな近くに……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェムさあ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "気付いてて黙ってたでしょ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "へへっ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_005"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "さっきあっちから走って来るのが見えたからさ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nいいぜ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "受けてやる！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトーがな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "え～、",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_006"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なんでボクがそんなことしなくちゃいけないのさ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nやだよ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "めんどくさい。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "こうでもしないと",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエの本気が分かんないだろ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "構わないからやっちゃえ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "どっちが相手でも俺はいいぜ！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_008"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n二人がかりでも上等だけどな！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "いやだってば。",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_009"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nボクはここらでバイバイさせてもら……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "っ",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "てノウェム、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "逃げるの邪魔しないでよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いーや、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_010"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "逃がさないぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n今日こそオマエの本気、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "見せてもらうからな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "いい加減覚悟しろや！　",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_011"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "オラァ！",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うわっ！　",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_012"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ちょ！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nボクは頭脳労働担当で",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "肉体労働は向いてないんだって！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いや！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_013"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエは本当の力を隠してる！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nアタシにはわかるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "だからー、",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_014"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんなのないってば。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nノウェムはさあ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なんでそんなにボクに期待しちゃってるわけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そりゃオマエ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_015"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシの相棒なんだから強くないとな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "って、オクトー！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "前！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "前！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "俺様相手に油断してんじゃねえよ！",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_016"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\nもらったあ！",
        "unit_id": 190711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ぐ",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_017"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "はっ！？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "よっしゃ！　",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_018"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "いいの入っ……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "ぐえっ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おい！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_019"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシの相棒になにすんだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "なん……",
        "unit_id": 190711,
        "voice": "vo_adv_5110605_020"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "でだ……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "よ……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "いたたた……",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_021"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あ～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n背後からかなりいいの入っちゃったねえ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "あ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_022"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "やば……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "つい……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nげっ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ダイゴのやつ",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "気絶しちゃったぞ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "どうしよう、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトー……？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まあ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_023"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "二人がかりでも、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "って言ってたし",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "油断してたのはダイゴのほうだしね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nボクらは悪くないんじゃない？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110605_024"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そうだよな……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nとりあえず……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ここは……",
        "unit_id": 106211,
        "voice": "vo_adv_5110605_025"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "逃げちゃおう！",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "倒れたままのダイゴを置いて逃げ出すノウェムとオクトーであった。"
    }
