    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n剛、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛才那是……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊──",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊──♪",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的喉嚨狀況，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "正在恢復……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "清冽的藥草香氣盈滿鼻腔，",
        "unit_id": 104211,
        "voice": "vo_adv_5213093_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "卻又不會過於刺激……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那高雅的清涼感，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "與溫柔甜味彼此調和的滋味，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n簡直就像交響曲一般……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "精靈們好像也很開心！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呵呵，",
        "unit_id": 133111,
        "voice": "vo_adv_5213093_002"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真是非常動聽的歌聲。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n若能幫上像千歌小姐這樣的人，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n雪野一定也會很高興的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "～♪",
        "unit_id": 104211,
        "voice": "vo_adv_5213093_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好厲害……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總覺得，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "音域好像比之前更寬廣了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不只是這樣，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "連音量和顫音，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都進步了好多……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真想也推薦給望、紡希，",
        "unit_id": 104211,
        "voice": "vo_adv_5213093_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有蘭法小姐她們呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "薇歐莉特小姐，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們下次",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以一起去",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n吉歐‧尼布爾黑爾打擾嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想讓大家也吃吃看這道冰品。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "大家一定都會很開心的♪",
        "unit_id": 104211,
        "voice": "vo_adv_5213093_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣一來，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "由慈樂之音和蘭法小姐，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起辦場演唱會，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n說不定也很不錯呢！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 133111,
        "voice": "vo_adv_5213093_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們還沒有在吉歐‧尼布爾黑爾公演過……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "製作人",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一定也會贊成的！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "立刻去和她商量！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多謝款待！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這、",
        "unit_id": 133111,
        "voice": "vo_adv_5213093_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這道冰品應該沒有那麼誇張的功效才對……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "怎麼辦，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "事情好像越鬧越大了，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n騎士先生……！",
        "unit_id": 133111
    }
]