[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}一行人從那不可思議的夢境中醒來時，\n在『王宮』中發生了異常的變化。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "所有的東西都劇烈搖晃著，\n而從牆壁龜裂的縫隙之中，有著像是黑色泥濘的東西流了出來。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}弟弟！",
        "unit_id": 104911,
        "voice": "vo_adv_2012015_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n快起床快起床，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你這個貪睡鬼！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n大事不妙了呀～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐可要用魔法之吻",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "叫你起床了唷☆",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_2012015_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "姐姐妳好卑鄙！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那種事可是妹妹的工作啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在可不是講這種話的情況了啦，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的是事態緊急了呀……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇呀？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "睡著了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯喔！",
        "unit_id": 101112,
        "voice": "vo_adv_2012015_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　在哥哥他",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "正好接近了那個叫凱留的人的同一時間，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不知道為什麼貪吃佩可",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "和可可蘿妳們倆，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也一起",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "直挺挺的倒了下來啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後就那樣，",
        "unit_id": 101112,
        "voice": "vo_adv_2012015_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "睡了一小段時間唷！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們都很擔心唷，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還以為妳們是不是死掉了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……？",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有沒有好好地變回了原樣了呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106015,
        "voice": "vo_adv_2012015_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來好像是",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還沒有醒來的樣子呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但畢竟沒有意識，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以也沒辦法再那樣連續丟魔法了嘛……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以全身崩壞後死掉",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的這個最糟糕的情況",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也可以避免了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真讓人擔心。",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們到底",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有沒有成功幫到了小凱留呢……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105911,
        "voice": "vo_adv_2012015_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此衝擊究竟為何？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "異樣的黑色泥濘，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看似也漸漸溢滿了出來的模樣……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}……你也醒過來了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_2012015_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或多或少地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽見了各位的談話。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下一行人在愛梅斯大人的指引之下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n暫時地睡了過去",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且做了一場共通的夢呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "見到了凱留小姐的記憶……",
        "unit_id": 105911,
        "voice": "vo_adv_2012015_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並且",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得以與凱留小姐的內心直接對話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而就在揣摩著談話內容的途中，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便因這場衝擊",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而甦醒過來了嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底有沒有成功救到了小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都還一頭霧水的感覺呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果可以的話必須再回到夢境裡一次，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後想辦法說服小凱留到",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她能夠完全接受為止。",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇，",
        "unit_id": 101112,
        "voice": "vo_adv_2012015_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "剛剛那個爆炸是什麼……！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "…………",
        "unit_id": 106914,
        "voice": "vo_adv_2012015_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個是……！",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才的聲音是你的呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把我的所有全都奪走的，",
        "unit_id": 105811,
        "voice": "vo_adv_2012015_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "罪惡的根源！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n假貨的尤絲蒂亞娜！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "……那個名字，",
        "unit_id": 106914,
        "voice": "vo_adv_2012015_018"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我想已經用不著了就還給妳吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "和妳不同，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n對我來說公主殿下",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這個稱號",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "一點也不適合我呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我乃",
        "unit_id": 106914,
        "voice": "vo_adv_2012015_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "統御這世間萬物之絕對者，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "千里真那。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "『霸瞳皇帝』",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "得這麼報上名才是呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳們還真讓我佩服呢，",
        "unit_id": 106914,
        "voice": "vo_adv_2012015_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n沒想到竟然能抵抗到這種地步……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "又得重新進行計算，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將計畫修正後",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再重新啟動才行了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不會讓任何人來妨礙我的……",
        "unit_id": 106914,
        "voice": "vo_adv_2012015_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "遊戲結束了唷，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "傻瓜們。",
        "unit_id": 106914
    },
