    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我聽說了。",
        "unit_id": 133611,
        "voice": "vo_adv_0000441_000"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "今年",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "似乎是",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "蛇年對吧？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n也就是說",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "是屬於我的一年，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "沒錯吧！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "好了，",
        "unit_id": 133611,
        "voice": "vo_adv_0000441_001"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "你可以盡情地來稱讚我。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "現在不管是",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "讚賞還是禮物",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我都熱烈接收中！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "請等一下～！",
        "unit_id": 51611,
        "voice": "vo_adv_0000441_002"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "梅杜莎小姐，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就算妳是蛇的貴族，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n我也不能",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "讓妳這個新人太囂張～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "請看看",
        "unit_id": 51611,
        "voice": "vo_adv_0000441_003"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我這副扭來扭去的身體～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n我相信懂的人就懂，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n到底誰才比較適合當蛇年代表～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "嗚，",
        "unit_id": 133611,
        "voice": "vo_adv_0000441_004"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "尾巴這麼長讓我不想承認也不行呢……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "但是，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "重要的不是只有外表。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我們來一決勝負，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "決定誰才比較適合當蛇年代表！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "沒問題～",
        "unit_id": 51611,
        "voice": "vo_adv_0000441_005"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n就讓身為成年蛇的我，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "來幫妳指導一下～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "啊",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不過，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "需要體力的勝負",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就饒了我吧～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉呀請稍待。",
        "unit_id": 1,
        "voice": "vo_adv_0000441_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這場勝負，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也讓奴家參加吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "涅妃‧涅羅……！　",
        "unit_id": 133611,
        "voice": "vo_adv_0000441_007"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "很抱歉",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "這可不行。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n就算妳是公主也不可以，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n今年的代表絕對不能讓給妳！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "請不要出手，",
        "unit_id": 51611,
        "voice": "vo_adv_0000441_008"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "涅妃‧涅羅大人～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這可是賭上蛇之威望的一大勝負……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "而且，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這也是在幕後的我能成為主角的一大機會～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哎呀哎呀。",
        "unit_id": 129711,
        "voice": "vo_adv_0000441_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n居然要奴家不要出手，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "說得如此過分。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不過若是蛇的話──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看吧，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就像這樣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "鐵大蛇",
        "words": "──！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吾鐵所化之形非獨蛇也。",
        "unit_id": 129711,
        "voice": "vo_adv_0000441_010"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "只要去模仿所有生肖的形狀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那麼年年歲歲",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "都必定由奴家來做代表。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "梅杜莎‧米亞",
        "words": "「太、太狡猾了！」\n「好、好狡猾～」",
        "unit_id": 1,
        "voice": "vo_adv_0000441_011"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好了，",
        "unit_id": 129711,
        "voice": "vo_adv_0000441_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "胡說八道就到這裡。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n首先要跟騎士殿下",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "拜個年才對吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "說、",
        "unit_id": 133611,
        "voice": "vo_adv_0000441_013"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "說得也是……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "新年快樂，{player}！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n就讓本小姐來讓你",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "多多指教吧！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "涅妃‧涅羅大人還有我們，",
        "unit_id": 51611,
        "voice": "vo_adv_0000441_014"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "今年也請你多多指教～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好，",
        "unit_id": 129711,
        "voice": "vo_adv_0000441_015"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n願恁的新年",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "能充滿幸福──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吾等蛇一同",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為恁誠心祈願。",
        "unit_id": 129711
    }
]