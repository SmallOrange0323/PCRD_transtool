    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "ペコリーヌが魔物で食費を節約するとか言い出さなきゃいいけど……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "あ、",
        "unit_id": 112011,
        "voice": "vo_adv_6056304_003"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "あたし……？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
