        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "今年一年はどうなるのかって不安半分、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "期待半分だけど……",
