    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "でもまぁ、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "これからもおいしい物を食べるために節約も必要よね。",
