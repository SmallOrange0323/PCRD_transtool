    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "……ったく、",
        "unit_id": 112011,
        "voice": "vo_adv_6056304_001"
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "あんたらしいわね。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "まぁ？　",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "キャル",
        "words": "あんたがそこまで言うんだったら……",
