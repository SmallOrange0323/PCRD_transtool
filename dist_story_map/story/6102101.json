[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來……",
        "unit_id": 123611,
        "voice": "vo_adv_6102101_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看到你在當同人誌攤位的小精靈，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我真的嚇了一跳耶。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到你甚至還能當漫畫助手。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我有點好奇",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你都畫什麼樣的畫呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我記得",
        "unit_id": 123611,
        "voice": "vo_adv_6102101_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你曾經在知名漫畫家的身邊",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "學過畫漫畫對吧？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你這股自信也很讓人信服呢……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喔？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你的暑假圖畫日記，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也一樣備受好評嗎？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣的話，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "希望哪天可以看看",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你那本圖畫日記呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦！？",
        "unit_id": 123611,
        "voice": "vo_adv_6102101_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你要畫我！？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個嘛……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n感覺很難為情耶……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你都已經提議要畫我了，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我如果拒絕好像也很失禮……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "吧？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……要把我畫得可愛一點喔，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦咦！？",
        "unit_id": 123611,
        "voice": "vo_adv_6102101_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "跟你一起做同人誌！？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我沒辦法啦！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我既不會畫畫，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也沒有構想故事劇情的經驗……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以還是讓我婉拒吧……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我是有點興趣啦……",
        "unit_id": 123611
    }
]