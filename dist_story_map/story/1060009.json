[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留結束了在王宮中的工作，來到了蘭德索爾的城鎮散步。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最近陛下",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n比起貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎對{player}更感興趣呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛才也",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總是在聊{player}的話題。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來沒打算要去跟蹤他，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但還是去一下會比較好吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說不定會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誇我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做得很好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咿呀！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n什、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來是{player}！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這個人",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道興趣是嚇人嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在這種地方做什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　你在這個攤販打工顧攤位？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你真的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接了各種的打工耶……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "運氣太好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到會是{player}主動找我說話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正如我所願。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘿～",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有魔術書還有",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "古文書啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無論哪種書，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n全都是出處很可疑的書籍呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我看看，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上頭寫著",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「操縱意志的魔石」――",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　操縱意志的魔石！！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個該不會是",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n能夠讓我的公主騎士的權能",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n力量提升的東西吧……！？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯～",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "外表",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺就像",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨處可見的魔石。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一般可以想像是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "作為發動時的觸媒……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我如果能",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "更得心應手地操縱魔物，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肯定",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會讓陛下更高興才對……！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……買下來了。",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然多了開銷，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但若能提升力量這也算便宜吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　你不用打工了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "店要收攤了啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然如此，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稍微跟我來一下。",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個『怪獸大賽』的會場",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也有在等著調教的魔物，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正合我意呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個。",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是有見過我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n調教魔物的{player}，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這魔石有沒有效果，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想你應該看得出來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你稍微幫我看一下吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要上囉――",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來吧，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "受我支配吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成為我的奴隸吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　啪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一聲的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　破掉了！！？？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少開玩笑了少開玩笑了，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的別給我開玩笑了！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這不是一下子就壞了嗎！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說你啊～！",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n居然敢讓我買不良品，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你好大的膽子！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}？　你有在聽嗎！？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n什麼啦，突然癱倒下去！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你難道以為裝睡",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就能蒙混過去嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　凱留大人？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別用那麼噁心的稱呼叫我啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n該、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……吶，{player}。",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n稱讚我吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可、",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可愛……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣就算是稱讚了嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺是不壞啦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是啊就是啊♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你很清楚嘛！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然是這個樣子。",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n公主騎士的權能提升了力量，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能對{player}……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物之外的對象進行操縱了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好厲害好厲害！",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n太厲害了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說不定是天才！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，",
        "unit_id": 106012,
        "voice": "vo_adv_1060009_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
