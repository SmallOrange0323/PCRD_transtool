    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "關於龍次先生……",
        "unit_id": 130711,
        "voice": "vo_adv_6144203_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n村長先生",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼要讓他",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n打扮得那麼像變態可疑分子呢？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唔……",
        "unit_id": 130711,
        "voice": "vo_adv_6144203_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n村長先生雖然也這麼說，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但就我看來既沒有漂亮",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也沒有可愛……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是，",
        "unit_id": 130711,
        "voice": "vo_adv_6144203_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然我也有隱約察覺到是這樣，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但還是得用更友善的講法才行吧！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……要不是他穿成那樣，",
        "unit_id": 130711,
        "voice": "vo_adv_6144203_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家本來會更害怕他？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "確實，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "龍次先生如果維持平常的穿著，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "再加上那種說話方式，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我可能會覺得有點害怕。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這是村長先生以他的方式，",
        "unit_id": 130711,
        "voice": "vo_adv_6144203_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在為龍次先生著想呀。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "告訴我這點♪",
        "unit_id": 130711
    }
]