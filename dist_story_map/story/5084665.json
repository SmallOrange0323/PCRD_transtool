[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是不會擔心的。",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聽聞學長他陷入沉睡，可能一輩子都不會醒來。",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n並且證實這件事不是開玩笑，似乎是真的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n因此，優妮學姐和克蘿依學姐",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "都露出嚴肅的表情，一言不發。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "儘管如此，",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我還是絕對不會擔心的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為學長他",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "和我是一樣的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長肯定不會想因為自己的事，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "害別人變得鬱鬱寡歡。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長他",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "應該就是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣的人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n總是想讓大家露出開朗笑容的類型。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以就算優妮學姐和克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n還有其他人再怎麼擔心學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只有我，要像笨蛋一樣不看場合說話──",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊哈哈哈！",
        "unit_id": 110911,
        "voice": "vo_adv_5084665_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你怎麼在睡懶覺都不工作啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種要人來關心你的行為，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是有點煩人的耶？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好啦，再不快起來，我可要在你臉上塗鴉寫上「切嚕～」囉！",
        "unit_id": 110911
    }
]