[
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了製作花祭用的花冠，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與真步再次來到了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真步真步王國的庭園。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天也是",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好天氣呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "走出公會小屋，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到真步真步王國的庭園來",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是正確的選擇♪",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "終於要用摘的花",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來做花冠了。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "編法",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會教您，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不用擔心。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就先把",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "上次摘的花排在這邊……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家先編給您看。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就請您照人家的做法",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來編。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "首先是",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "拿起兩枝花，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓它們交錯。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把其中一枝的莖",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "捲在另一枝花上……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說得也是，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "面對面",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "的確不好懂呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家就坐到王子先生的旁邊吧。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……呵呵，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "離王子先生這麼近，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n讓人有點",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "害羞起來了呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "春天也才剛到來，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像這樣靠在一起，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n應該比較溫暖才對……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說笑的♪",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您很厲害呢♪",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經完成",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "目標的一半了呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說什麼老師，太誇張了啦。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那接下來",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就把剩下的一半……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀？",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個呀，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那個正在走過來的人，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "上次那位獸人少年嗎？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……",
        "unit_id": 416,
        "voice": "vo_adv_1160002_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看你那麼沮喪的樣子，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是怎麼了嗎？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "朋友沒有跟著一起來，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "發生什麼事了？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……我",
        "unit_id": 416,
        "voice": "vo_adv_1160002_012"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好像再也",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "沒辦法見到她了。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦！？",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是發生了什麼事？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……我們吵架了。",
        "unit_id": 416,
        "voice": "vo_adv_1160002_014"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "她的爸爸是",
        "unit_id": 416,
        "voice": "vo_adv_1160002_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "商人。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n之所以來蘭德索爾也是為了做生意，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n接下來",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "又要去別的城市了。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我",
        "unit_id": 416,
        "voice": "vo_adv_1160002_016"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "原本以為",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "她會一直待在這裡。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以她跟我說這些的時候，我大受打擊……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就吵起來了。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "但是",
        "unit_id": 416,
        "voice": "vo_adv_1160002_017"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我馬上就覺得後悔，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "跑去她家想道歉，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "卻被她爸",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "趕了出來……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣啊……",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "果然是",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "「羅密歐與茱麗葉」呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n面對悄悄培育出愛的兩人，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n命運之神",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是不會",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "放過他們的呢……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣下去的話，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "他們明明就互有心意，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "卻錯身而過",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就此永別。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n直到在天國重逢，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "才終於能夠廝守……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行。",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那可不行啊。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在人家仍活在這世上的期間，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "絕不允許",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那種悲傷的結局！",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "雖、",
        "unit_id": 416,
        "voice": "vo_adv_1160002_021"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "雖然不太明白……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "也討厭不能和好就分開。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "但是，",
        "unit_id": 416,
        "voice": "vo_adv_1160002_022"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "她爸",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "真的很恐怖耶。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……還有她，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "她搞不好也不想見到我……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不去向本人確認，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就無法明白吧。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且，",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是因為無法徹底放棄，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n才會過來",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們這邊吧？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……或許是",
        "unit_id": 416,
        "voice": "vo_adv_1160002_025"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這樣沒錯。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n覺得",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "如果是哥哥跟姐姐，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "應該願意幫我說話。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生說得沒錯。",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……請放心吧。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步王國的",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "公主跟王子，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
