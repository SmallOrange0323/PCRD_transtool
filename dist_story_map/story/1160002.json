        "voice": "vo_adv_1160002_059"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "真步・少年",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1160002_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底是為什麼啊？",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都說明白了，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不就是代表要讓我們見面嗎？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "呃……",
        "unit_id": 416,
        "voice": "vo_adv_1160002_062"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n那個，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這裡畢竟是現實，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n肯定不會像童話故事那樣",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "簡單順利嘛。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "別說那麼令人難過的話嘛……",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_063"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這一切，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都是人家能力不足的關係……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "沒這回事！",
        "unit_id": 416,
        "voice": "vo_adv_1160002_064"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我反而才因為這次下定決心了……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你要放棄嗎！？",
        "unit_id": 116011,
        "voice": "vo_adv_1160002_065"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "才不是啦！",
        "unit_id": 416,
        "voice": "vo_adv_1160002_066"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "相反了！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我獲得滿滿勇氣了！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我果然還是想要好好和好，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n所以",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我會繼續加油的！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以今天就先……",
