    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n但是",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "他也沒有阻止我追出來……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "謝謝你今天過來。",
        "unit_id": 211,
        "voice": "vo_adv_1160002_071"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "還有，",
