        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "新年快樂，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今年也請多指教囉！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n今年也一起",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "度過開心的一年吧！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_065"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們就再稍微",
