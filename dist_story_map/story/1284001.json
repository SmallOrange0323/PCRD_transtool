    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "視野也很棒，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "從這裡感覺能看到很壯觀的日出耶～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……話雖如此，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在日出之前還有時間呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "機會難得，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們來回顧去年是怎麼樣的一年吧！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有什麼讓你印象深刻的事嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就是說呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也一樣。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n畢竟是才剛發生的事情，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且實在太過衝擊，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "腦裡想的都是隕石呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "年底轉眼就過了啊～",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這忙碌程度也能夠理解",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為什麼會被稱為「師走」呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "去年過得這麼驚人的話，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不知道今年會是如何呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真想一起經歷",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "比破壞隕石還要更驚人的事啊。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對了，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你有想好今年希望過個怎麼樣的一年嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n新年參拜要祈求的事已經決定好了嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你今年想努力念書啊？",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是認真呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我要不要也效仿你，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "然後一起念書呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為你想啊，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "互相教對方就能開心地努力用功了吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看來你今年也想努力工作呢！",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟你一直都很努力地在打工，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我大概可以理解。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "人手不足的時候，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "隨時都能告訴我喔。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也會幫忙的！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是這樣嗎！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你的意思是想像我一樣，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "能飛起來或者做預知夢嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n咦～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但就算沒有什麼超能力，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也覺得你已經非常厲害了喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你想嘛。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我遇到麻煩的時候，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你總是會幫助我，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就連年底時也是……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你是在開玩笑啊。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嚇我一跳呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "應該想祈求身體健康",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "或疾病康復吧。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大家都能健健康康的話，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n光是這樣我就覺得很開心、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很幸福了呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也會祈禱",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你可以健健康康的喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果這一年彼此的願望都能夠實現就好了呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難道你是想睡覺了嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你剛剛",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "眼睛有點閉起來了耶？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊啊，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不用那樣揉眼睛",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來勉強自己清醒啦！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟年底一直很忙，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你也很累了嘛！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在日出前",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還有時間，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n稍微小睡一下比較好吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對、",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對了，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你來躺在我的腿上吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你想，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我之前也有躺過你的腿，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這是那個的回禮喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你不需要客氣！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我沒問題的，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我完全不想睡喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n畢竟為了做預知夢，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "已經睡得很多了呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我在日出之前會醒著的，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你可以放心睡喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不客氣。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來吧！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我準備好了喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……………………",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_040"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎、",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼樣？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你睡得著嗎？",
        "unit_id": 128411
    },
    {
        "type": "background",
        "background": "500512"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦！？",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n已經睡著了！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好快！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……我因為心跳加速，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "反而很清醒的說。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_043"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟你一直非常努力嘛。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好乖好乖，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "辛苦你了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好好睡吧♪",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咻……"
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_044"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n交給、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "吧……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔嗯唔嗯……",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_045"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "再一下就好……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_046"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這裡",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是哪裡！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這是怎麼回事！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難道說",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_047"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我剛剛睡著了！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抱歉～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我好像睡迷糊就飄起來了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎麼辦？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "必須想想辦法……！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_048"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "確實！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是初超能呢～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "現在不是講那種話的時候啦！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵……",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_049"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為剛剛的話，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓我稍微冷靜下來了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n謝謝你，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "慌慌張張的話會很危險呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總之，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_050"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "先繼續維持飄在空中……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n現在應該",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "快到天亮的時間了吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我試著傳送回原本的地方喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_051"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你想",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "在這裡看日出？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不去推薦地點沒關係嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_052"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太陽開始升起了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你看！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔哇啊啊～！",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_053"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是元旦日出啊！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好耀眼～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_054"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很值得慶祝呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n太陽升起之後，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "心情也會一下子變得很開朗啊～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你看，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_055"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "蘭德索爾的城鎮",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也被太陽照得閃閃發光喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是漂亮的景色呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_056"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是多虧了你喔。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我就只有在那邊驚慌失措而已……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是因為你靈機一動，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "才能看到這樣的景色喔。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦……",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_057"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那是",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼意思？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n之所以會慌張忙碌，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是因為我一直在為人奔走？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_058"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你那樣說，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓我很開心呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也很喜歡",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_059"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "和你一起度過的時光喔！",
