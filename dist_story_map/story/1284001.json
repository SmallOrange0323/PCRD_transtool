    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欣賞一下這景色吧。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這裡只有我們兩個人，可是很難得的呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "元旦日出從地平線升起。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n初音與{player}在只有他們兩人的特別之地，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n迎來了歡欣雀躍的新年。"
