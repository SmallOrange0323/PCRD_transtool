        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n連同現在，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還有隕石那時候也是。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是我很慌張，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_061"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你就會對我說沒事的。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "聽你那樣一說，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我真的就能夠冷靜下來呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "該說",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是你的超能力嗎……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我認為這正是你厲害的地方喔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對了！",
