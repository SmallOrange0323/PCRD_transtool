    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音等人在除夕夜拯救了蘭德索爾不受隕石撞擊。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在那之後，【王宮騎士團】針對騷動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n向{player}和初音進行偵訊。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "禁、",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "禁止通行的證明書？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我什麼都不知道呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咻～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "嗯……",
        "unit_id": 712,
        "voice": "vo_adv_1284001_001"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "我收到了部下的報告，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n說在我們不知道的地方有通行管制，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "但那果然是誤會嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n還有什麼隕石，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "和女孩子變大之類",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "荒誕無稽的報告呢……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就、",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就是啊！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一定是有什麼誤會啦！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你也是這麼想的吧！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "嗯，",
        "unit_id": 712,
        "voice": "vo_adv_1284001_003"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "果然是誤會吧……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n弄到這麼晚，真抱歉啊。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "謝謝你們的協助。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n那麼，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "祝你們新年快樂。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "新年快樂～！",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想辦法蒙混過關了呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……話說，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "新年快樂……？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難道說，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "新的一年已經到了嗎！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔哇，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還真的……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "老早就過了啊～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "竟然是在偵訊中跨年，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音我也嚇了一跳……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "再幾個小時就天亮了呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其他人都早早被釋放了，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n小栞現在也正睡得香甜吧～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們不小心熬夜了呢……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……！",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想到了一個好主意！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "機會難得，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們去看元旦日出吧！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "再幾個小時天就要亮了嘛！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太棒了～！",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n感覺興奮起來了～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮☆",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕～～～"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一亢奮，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "肚子就叫了……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這麼說來，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們什麼東西都沒有吃呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "現在還有時間，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們去吃碗跨年蕎麥麵吧。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n雖然已經跨完年了，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但那邊剛好有攤販呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好好吃！",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "身體也溫暖起來了，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好暖和啊～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "跨年蕎麥麵",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然很棒呢～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "謝謝，",
        "unit_id": 1411,
        "voice": "vo_adv_1284001_014"
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "能夠聽妳那麼說我很高興喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "跨年蕎麥麵",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "有著把去年的災禍都斬斷的含意。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "如果今年是美好的一年就好了呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哦～",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來是這樣啊。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟年底還發生了那種事，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是能靠這個好好斬斷就好了呢！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "話說回來，",
        "unit_id": 1411,
        "voice": "vo_adv_1284001_016"
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "你們在這種時間外出……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "難道",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "小姐你們",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "是要去看元旦日出嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "我有推薦的地點，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "要告訴你們嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的嗎！？",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "請務必告訴我們～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "當然好。",
        "unit_id": 1411,
        "voice": "vo_adv_1284001_018"
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "郊外有一座山丘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "從那裡看到的日出非常漂亮喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n那邊也有鋪設道路，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "所以應該可以輕鬆爬上去。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "雖然是手寫的，",
        "unit_id": 1411,
        "voice": "vo_adv_1284001_019"
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "不過我給你們一張簡易地圖吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "元旦日出",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "有祈禱那一年",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "能幸福與豐收的含意呢，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "蕎麥麵店店長",
        "words": "\n你們就去好好欣賞吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大叔！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "告訴我們這麼棒的事～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們就馬上出發吧。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n謝謝你的款待！",
        "unit_id": 128411
    },
