        "voice": "vo_adv_1284001_062"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是在空中分散的話會很危險，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們先牽著手吧。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你想，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣要是發生了什麼事，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也能夠應對吧？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_063"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抓住了……！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n欸嘿嘿，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我不會放開了喔～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這下",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不管發生什麼事，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都不用怕了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 128411,
        "voice": "vo_adv_1284001_064"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還有，要再說一次……",
