[
    {
        "type": "background",
        "background": "500584"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在舉辦著慶典，相當熱鬧的蘭德索爾城內……\n結束大陸全土巡演後歸來的【慈樂之音】，\n也按照預定舉行了凱旋演唱會。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家～",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你們！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後是！　",
        "unit_id": 105412,
        "voice": "vo_adv_2012002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓我鄭重宣布，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們回來了！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
        "unit_id": 104212,
        "voice": "vo_adv_2012002_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "能再次在大家的面前歌唱",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是我們的榮幸。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該說是最棒、",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "最幸福了。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "同意～！　",
        "unit_id": 105412,
        "voice": "vo_adv_2012002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然很遺憾，但下首歌就是今天演唱會的最後一首了。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但從明天開始",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "到祭典的最後一天為止，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們依然都會站上舞台的喔！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還請各位，",
        "unit_id": 104212,
        "voice": "vo_adv_2012002_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一定要找你們親朋好友",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起來聽看看我們的歌呢！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果不嫌棄，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還請別吝嗇你們的掌聲和笑容，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "替我們加油唷！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們【慈樂之音】，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "永遠都會站在這閃爍著光芒的舞台上等待著大家到來的！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼今天的最後一首歌，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要來囉！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n千歌、",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希、",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "準備OK了嗎～？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n畢竟直到今天可是經過了場漫長的旅程嘛，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "搞不好都已經累癱了呢？",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不！　",
        "unit_id": 105412,
        "voice": "vo_adv_2012002_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "甚至可以說，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "變得更有精神了呢！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n就算是現在馬上再一次，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算是要再繞這片大陸多少次，也沒問題唷！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的。",
        "unit_id": 104212,
        "voice": "vo_adv_2012002_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一次接著一次的表演，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "使得那詩意永無止盡地湧現。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就連精靈們也都樂此不疲……",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我終於能體會望口頭禪的意義了，",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的所有東西",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都是亮晶晶的呢。",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊哈哈。",
        "unit_id": 105412,
        "voice": "vo_adv_2012002_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是開心的淚水嗎？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一定是眼眶有淚水，",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以才會看什麼都亮晶晶的吧？",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哈哈～",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這還不是該掉眼淚的時候啦，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n直到最後都得有偶像的樣子，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也像平時的我們一樣！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們會將最棒的演唱會呈獻給大家的～",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管是今天",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "、明天",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是那",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "遙遠的未來！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跟上腳步囉！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好的，",
        "unit_id": 104212,
        "voice": "vo_adv_2012002_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不論那目的地在何處！",
        "unit_id": 104212
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當然，",
        "unit_id": 105412,
        "voice": "vo_adv_2012002_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這還用說嗎！",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "望、千歌、紡希",
        "words": "慈樂之音，",
        "unit_id": 1,
        "voice": "vo_adv_2012002_014"
    },
    {
        "type": "dialogue",
        "name": "望、千歌、紡希",
        "words": "登台！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這會場的氣氛被炒熱到最高潮了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幹得好呀，【慈樂之音】，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連我都難得想讚美呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "身為一名製作人我也與有榮焉……",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不好，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明就是個可棲之木而已，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不小心鬧得差一點認真起來了呀。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但這樣的人生，說不定也是一條路呢。",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不持劍，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不傷害任何人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不踏上那條使人們雞犬不寧的修羅之道……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而是支持的深愛之物，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "守護",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "且為了人們的和平與幸福做出貢獻――。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如同一名平凡女子的",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人生。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過。",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事到如今也沒有退路了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "箭已射出，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就只能屏息以待那中靶之際到來了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "突襲了『王宮』的那些傢伙，",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還有進行誘敵作戰的諾維姆，不知道她們是否還順利呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這邊早就做好萬全準備了唷，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "趕緊完事到這集合地來呀。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次【慈樂之音】巡迴所用的飛空艇，",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不論何時都能起飛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若全員",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都能順利會合，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "便即刻乘船出發……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先暫時逃到",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的祖國避難。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管還得看作戰的結果，",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但不管如何還是得等事件稍稍平息後，才能偷偷的回國……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是當初的計畫。",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我竟被拜託負責如此無趣的收尾工作，世事還真難料呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然而，",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟敵人是那位『陛下』……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尤絲蒂亞娜。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而他手底下【王宮騎士團】的那群傢伙們，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再怎麼說和我也曾是同事一場，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真要對壘起來自然也棘手。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "非也。",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當不得不捉對廝殺的那一刻真到來了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果我無法戰鬥……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不僅對作戰會造成影響，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而我也會對那軟弱的自身幻滅吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "考量到此事，",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因此才會讓我去負責作戰核心以外的部分。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也並非是如此呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "逃避了嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真令人失望啊，克莉絲提娜。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳竟是如此軟弱的女人呀？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慚愧至極，",
        "unit_id": 107111,
        "voice": "vo_adv_2012002_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真讓人笑不出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯嗯～？",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼好像",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一臉凝重的表情呢？　",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然拚命偽裝，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但其實連體力都到極限，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都累垮了呢。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "硬著頭皮也不能露出馬腳，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "至少不能被來場客人看穿就是了。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但真不愧是頂尖的製作人呢，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然全都被她看透了嗎？　",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且仔細一看，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "觀眾群中其實",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是也有一些不怎麼起勁的人在呢……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "畢竟這演唱會",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也只是祭典表演的一環嘛。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不是真的每一個人都是我們的粉絲。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算有人沒什麼興趣，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n呆呆的佇在那邊看也沒辦法的嘛……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但就算",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有那些人在，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們也一定要做出最棒的表演，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n棒到那些人因此成為我們的粉絲。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們的話，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定辦得到！　",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果是【慈樂之音】的話！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然辦了場這麼大規模的巡迴演唱會，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像是有些太得意忘形了一點。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但我們也是還有很多很多能夠成長的空間呢！　",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就讓我們不驕不餒，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "繼續朝著",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "頂尖偶像邁進吧……！　",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "畢竟託克莉絲提娜小姐的福，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們也辦成了前所未聞的大陸全土巡迴演唱會了嘛……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之後也還希望能夠讓她來帶我們，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以可不能讓她心寒不要我們了呢。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總而言之這首歌，",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得全神貫注地唱到那最後一個音符結束前才行……！　",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剩下三秒、",
        "unit_id": 102912,
        "voice": "vo_adv_2012002_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "兩秒、",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一秒……",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "Finish！",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n最後帶著笑容，",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "Peace☆　",
        "unit_id": 102912
    }
]