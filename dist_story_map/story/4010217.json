    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦──",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_000"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "辛苦了。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n好巧啊，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "竟在這種地方遇見。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……嗯，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這是什麼？",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊，",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "抱歉。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n我沒什麼從男人手中收到生日禮物的記憶，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n腦袋處理不來。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是說，",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "也不用這麼費心啦，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n多給同學送一點啊。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "已經有送了嗎？",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……這樣啊。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我想也是。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……呵呵，",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "抱歉，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我還沒道謝吧。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "謝謝你。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "幾歲就是企業機密了喔。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……咦？",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "當、",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "當然有啊。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n成熟的女人在生日晚上怎麼可能沒事，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n真是個蠢問題……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "今年",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "就是偶然有空啦。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯……",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "這是",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "什麼……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "等等。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n這是",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那間訂不到的餐廳的招待劵……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你說",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "一起去……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你這會不會太風流了……",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……呵呵，",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我知道了。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n你好不容易準備的，我就陪你去吧。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……可是，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "能讓我先回家準備一下嗎？",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "得為彩羽準備飯菜。",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_007"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呵呵，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不是要盛裝打扮，可別期待啊♪",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呃，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不會啊。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "都要自我厭惡了，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "忘了",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "剛剛那句話吧。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那",
        "unit_id": 132531,
        "voice": "vo_adv_4010217_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "等會見。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我很期待喔，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呵呵。",
        "unit_id": 132531
    }
]