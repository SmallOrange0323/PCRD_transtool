[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人踏入了露娜之塔內部。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦～",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "塔裡面原來是這種感覺啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好厲害喔～！",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_001"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "星星閃閃發光的！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那大概不是真正的星星，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而是模擬星星的粒子效果吧？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為那似乎並未作為物件擁有實體。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這麼說來，",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_003"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比跟僕從",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "該做什麼好呢？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n剛才只說",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "要來調查……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想想，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "基本解析有我一個人就夠了……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該說",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只有我能辦到啦。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以請妳幫忙調查這附近，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有看到什麼令人在意的東西，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就回報讓我知道好嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年也是，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請你暫時先跟班比一起行動吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好的～！",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "走吧，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好了，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我這邊要從哪開始動手呢？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n首先──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎喲，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我才剛說就這樣！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然事前已經聽說會有魔物出沒了！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你帶著班比退到後面吧，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "客人就由我來招呼……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "真是的～！",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_010"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "拉比林斯達在工作，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不可以打擾她呀！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哇喔！",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好厲害～！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n居然可以秒殺魔物，真令人刮目相看！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿嘿～♪",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_012"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "畢竟班比可是最強的～！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_013"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "會好～好地",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n保護僕從喔！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "班比居然這麼擅於戰鬥，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真是意外之喜呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼對魔物的警戒和對應就大致交給你們，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我去集中精神在調查跟解析上好了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟多工處理的話，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n難免會占用思路嘛～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能更深入地專注做解析，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n實在太令人感激了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n當然，我還是會做好最低限度的警戒的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "哼哼，",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_018"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就交給班比吧～♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝啦～！",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那我就不客氣地，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n仰賴班比一下囉～！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總而言之，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "先放出各種解析用的程式……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拜託你們可要活著回來喲～？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是當然啊！",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟連我都無法輕易調查透徹的東西，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在就在我面前嘛。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "遇到無法理解的東西就要徹底理解！",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不管是構造方面",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是謎團方面等等，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想通通解析並調查清楚呢！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且比起眉頭深鎖地工作，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還是輕～鬆",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "開朗地做事比較開心不是嗎～？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好了，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在這層要做的事都做完了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "「解析」",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_025"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "都結束了嗎？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比跟僕從",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "才調查了一點點喲？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是啊。",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這座塔這麼大，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果要把每層所有角落都調查徹底，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不管花多少時間都做不完的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以！",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我寫了能夠自動掌握塔的構造和空間的",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n程式……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "解析魔法？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣說比較能理解嗎？",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我臨時創造了新的解析魔法出來！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話雖如此，",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果要從一樓慢慢按順序掃描一遍，會太花時間，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以我會空出適當間隔，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "用並列處理的方式掃描……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但它也有可能會被防禦程式之類的東西殺掉。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "…………？",
        "unit_id": 122311,
        "voice": "vo_adv_7028001_029"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n拉比林斯達說的話，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比聽得不是很懂",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呃……",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總之",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想要每隔幾十層",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n使用一次魔法，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以還需要往塔上爬很多層樓！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "班比你們只要大致檢查",
        "unit_id": 106815,
        "voice": "vo_adv_7028001_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n有沒有顯眼的東西就好了！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不用仔細到連掉在地上的砂礫都撿起來看喔！",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "反正就是這種感覺，",
        "unit_id": 106815,
