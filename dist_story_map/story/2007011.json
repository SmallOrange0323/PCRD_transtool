    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔？",
        "unit_id": 100711,
        "voice": "vo_adv_2007011_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n大家，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "安靜一下喲……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好像有一股～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "奇怪的氣息喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有股",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不祥的預感呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也聽見腳步聲了。",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎有什麼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正在朝這裡接近……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有魔力的感覺。",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n朝這靠近的是魔物呢，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "十之八九。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似似花為了保衛這研究所，",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在各處都配置了一些自製的魔物吶。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來是察覺到咱們的入侵，",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以派了那些魔物來吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "大概二話不說就會殺過來了吶。",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這邊也必須做好準備來對付。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "前衛就交給我！",
        "unit_id": 102211,
        "voice": "vo_adv_2007011_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也一塊上囉～♪",
        "unit_id": 100611,
        "voice": "vo_adv_2007011_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家真是習慣呢……",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難不成每次來這個研究所都會被襲擊嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不過，剛才",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她們好像說了",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「自製的魔物」？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是能做出來的嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該只是語病吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請退到在下的身後。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如平時一樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的安危就由在下來守護。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這可不足掛齒。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "守護主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是在下的重要使命之一。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您有這份心就足矣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令人引以為傲……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但適才適所也是很重要的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡請就交給在下來辦吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐也是。",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若用您那身武裝參與戰鬥，一定會產生劇烈的消耗吧……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡就交給在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請好好保存戰力與體力吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這條路也不是很寬敞嘛……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以這個人數，反而會互相干擾呢，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就暫且撤退吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但若大家遇到了危險，",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是會毫不猶豫的栽進去就是囉。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您多操心了，",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會輕易遇到危險的……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呣呣？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有著不曾見過的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奇特造型呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是只有在這研究所週遭才曾被目擊過，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謎樣的魔物。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是被人工製造而出，",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "且作為研究對象的魔物……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n特徵是由複數的魔物合成的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "樣貌。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種魔物的事，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是在哪有聽過嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牧場的大家，好像有提到過這樣的話呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會在牧場週遭被目擊到的奇妙魔物，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是從這研究所中逃亡後",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "野生化的傢伙嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唔呣，",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似似花有點神經質呢……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該不會輕易地就讓眷養的魔物，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n輕易逃亡到外頭到處搗亂才對。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總覺得，",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好像有點不太對勁。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "出現的魔物數量也比平時多上不少。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "且在行動表現上",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "似乎有些脫序了呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看起來相互齜牙裂嘴對立起來的模樣。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n簡直是在",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "同類相殘呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚噁……",
        "unit_id": 102211,
        "voice": "vo_adv_2007011_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好噁心，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好詭譎的感覺。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 100611,
        "voice": "vo_adv_2007011_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "得要鼓起勇氣去面對才行唷！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就算是詭譎，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要心中有愛，也能看到他可愛的一面，所以不用擔心唷♪",
        "unit_id": 100611
    },
    {
        "type": "still",
        "still": "200701101"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別忘記了沒有清空所有魔物的必要吶，",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把擋在路上的傢伙撂倒後就趕緊跟上囉！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "魔物可是多到足以淹沒整條路呢，",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "每一隻都處理的話就太浪費體力了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚～……",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現在的妾身連縛雞之力都沒有呀",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n幫不上什麼忙，真是技癢呀。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "欸嘿嘿。",
        "unit_id": 100711,
        "voice": "vo_adv_2007011_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n別急別慌張的喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": " 嚼嚼♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "宮子……",
        "unit_id": 104412,
        "voice": "vo_adv_2007011_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳呀，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "連沒吃完的布丁都一併帶過來了嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還真是一點也不緊張呢……",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "整體來說我們並不是特別優異於戰場上廝殺的公會，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n拖越久越不利。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "注意別受傷了，",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "趕緊向前進吧。",
        "unit_id": 103111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂！",
        "unit_id": 2411,
        "voice": "vo_adv_2007011_036"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你們這群臭魔物！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n別隨便就往老子的寶貝女兒身上貼過來呀……！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "父親，別太激動了。",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在是混戰中。",
        "unit_id": 103111,
        "voice": "vo_adv_2007011_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n攻擊若不節制一點，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n會不小心就把同伴也給捲進去了唷。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔～呣。",
        "unit_id": 105911,
        "voice": "vo_adv_2007011_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但魔物仍舊不停冒了出來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絲毫沒有減少的跡象呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再這麼下去，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能就會被包圍到無處可逃了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳叫做宮子對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳把那個布丁讓給我吃。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦？",
        "unit_id": 100711,
        "voice": "vo_adv_2007011_041"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "才不要喲，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這是宮子的布丁喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n之後我會做一大堆讓妳吃到撐死的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託妳了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔，",
        "unit_id": 100711,
        "voice": "vo_adv_2007011_043"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "約好了喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如果違反了跟幽靈的約定可是很恐怖的。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子會每天晚上在妳耳邊喊",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "「好恨喲～」的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "沒辦法，",
        "unit_id": 100711,
        "voice": "vo_adv_2007011_044"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就分妳吃一點吧。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘴巴打開……♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～嗯♪",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嚼嚼嚼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好喔！能量也填充完畢了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家，",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請躲到我的身後唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會丟個大招，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後就要強行突破囉！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要上囉～！",
        "unit_id": 105811,
        "voice": "vo_adv_2007011_047"
    },
    {
