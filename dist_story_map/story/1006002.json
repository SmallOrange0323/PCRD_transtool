        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我已經不行了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n再繼續下去的話……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會變得奇怪的～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還、還是要繼續嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "竟然……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然確實是我拜託哥哥的……",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但是這樣，茜里的身體會壞掉的……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……我、我知道了啦。",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n再一次而已喔？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "開、開始囉……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼！呼！呼！呼！呼！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里已經到極限了……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼、呼……",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎、怎麼樣？ ",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我覺得自己剛剛跑得很快！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸？變慢了……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……可是，從剛剛開始茜里已經跑了幾十次了耶？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然確實是我主動問哥哥，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n「吹薩克斯風，要怎麼樣才會進步？」",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥說「吹薩克斯風要吹得好，首先要增進體力」，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然我也贊成哥哥的意見……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但是茜里跑不了這麼多圈啊～",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "喜歡！雖然所有的音樂我都喜歡，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但是最喜歡爵士樂了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可能是因為父親很常聽，所以喜歡上的吧？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因此茜里就開始練習吹薩克斯風，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是都沒什麼進步呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里要努力變厲害，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n然後讓哥哥能聽到最棒的演奏喔！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為了這個心願，必須運動、鍛練肺活量……",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我、我知道啦～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸？馬上再跑一次？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里已經跑了好幾次……不行了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n稍微讓我休息一下……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "馬、馬上跑嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊嗚……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，太心狠手辣了啦。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥也跟茜里一起跑嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對、對呀……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "兩個人一起跑比較好呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，開始跑囉！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好的，咚！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼、呼、呼！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊！哥、哥哥，跑得太快了啦！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n該怎麼做才跑得快呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "腰、腰嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……收小腹然後多用點力嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "知、知道了。",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要輕輕握拳……然後大幅度地快速擺動對嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎、怎麼了嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里有越來越好嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "非常厲害……嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，太棒了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里被哥哥誇獎了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會再更加努力喔！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿咿、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……呼、呼。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，哥哥……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里沒辦法再撐下去了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥也到極限了吧？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥的臉很紅呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，茜里接下來要做最後衝刺囉。",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n會比剛才還要更激烈喔～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿咿！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸咿！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼……呼……呼……呼……",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里已經，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "精疲力盡了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經一步也跑不動了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥還跑得動嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好厲害……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "精力旺盛呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "今天的練習已經結束了吧？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，我的腿和腰已經都沒力了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n如果不稍微休息一下，茜里可能回不了家。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥、哥哥！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n為什麼要揹茜里！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸？哥哥要送我回家嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_032"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太棒了！謝謝！",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_033"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，茜里就恭敬不如從命囉。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘻嘻，哥哥的背，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_034"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "又大又強壯……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好棒呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果哥哥每次都能像這樣送我回家的話，",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n每天都想練習呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "下次再一起進行只有兩個人的",
        "unit_id": 100611,
        "voice": "vo_adv_1006002_036"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "祕密特訓吧？",
        "unit_id": 100611
    }
]