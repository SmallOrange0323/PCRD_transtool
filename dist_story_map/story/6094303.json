[
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是熱鬧呢……",
        "unit_id": 104715,
        "voice": "vo_adv_6094303_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不愧是露營熱潮。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……雖然我正在休假，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但保險起見",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還是去巡邏一下比較好吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n呵呵，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這句話要是被少年聽見，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或許會被他笑呢……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊，",
        "unit_id": 104715,
        "voice": "vo_adv_6094303_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對了。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是少年，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他會像這樣換一個說法吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n散步啊……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然是自己提出來的，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但還不錯呢。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n聽起來很符合休假氣氛，這不是很好嗎？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就這麼做吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……他或許會這樣對我提出邀請呢。",
        "unit_id": 104715,
        "voice": "vo_adv_6094303_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年是一個很溫柔的人。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即便知道我的性情，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他還是會接納我。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……不過，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我今天還是",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "自己去吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對了……",
        "unit_id": 104715,
        "voice": "vo_adv_6094303_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年很善解人意，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會悄悄地從背後推我一把。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n他一定會看穿我在勉強忍耐吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就算在休假，我還是我，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "本性難移。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然如此……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "答案只有一個！",
        "unit_id": 104715
    }
]