    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "辦一場交換會……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們快把要買的東西買好，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_055"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n挑選要來交換的禮物吧……",
        "unit_id": 102111
    },
