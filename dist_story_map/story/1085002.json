    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣子絕對，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會更好一點吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就是這樣呢……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_053"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "爸爸，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "媽媽……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸、",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_054"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在聖誕節的時候，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n關係要好的朋友們會進行交換禮物哦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n大家把禮物湊在一起，",
