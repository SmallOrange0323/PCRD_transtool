[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "胡桃已然下定決心，擔任聖誕節戲劇表演的主角。\n{player}，則陪著她一起進行戲劇的排練。"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那哥哥，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就請你來幫我念一下劇本上所寫的台詞了哦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你有不會念的字嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥雖然已經漸漸把記憶找回來了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但一開始還真是一個字都看不懂的呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還有",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "看到不會念的字嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那就讓我來教你吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你不會念的字，是哪一個啊？",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我因為常向咲戀媽媽借一些難懂的書來讀，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n大部分的字應該都會念了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我是這麼想的♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼要遮住呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "覺得太羞恥了嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥是因為喪失記憶的緣故，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不會念，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n或是念不出來那也是沒辦法的事嘛……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有什麼好羞恥的，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓我看看嘛……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好嗎♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個字是……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有記錯的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是念作蘋果吧？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這是壞王后要毒死公主的橋段，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n記得應該是念作蘋果的……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思～，{player}！",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可以請你去幫我買個東西嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說，你們兩個怎麼貼得這麼近啊？",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "胡桃也已經長大了，",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請在距離感上應該多注意一下喔……\n{player}？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇啊，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是鈴莓姐！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "{player}哥哥現在，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是在陪我進行話劇的排練……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n難怪你們兩人的臉會靠那麼近，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "原來是在念劇本啊。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "太好了，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為胡桃很怕生，我原本還很擔心的……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "感覺和{player}挺親近的嘛，",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟總是那麼熱心也很會照顧人呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n剛才拜託哥哥出門去買東西，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也可以去幫忙嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥一個人的話，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可能不是很熟練，怕他要花上不少時間……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也排練得有點累了，想休息一下……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、不行嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，不是說不行啦。",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還得先準備過年要用的生活用品之類的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大概也要提上不少東西吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且我想胡桃大概是，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不想讓{player}離開自己身邊對吧……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我就成全你，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓你們一起去吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼，",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就拜託你們兩個嘍。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝你們總是幫忙做家事，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "兩位都是哦♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n當個好孩子，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "才會得到聖誕老人的禮物啊……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的。",
        "unit_id": 102511,
        "voice": "vo_adv_1085002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們這裡有這麼多乖孩子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想聖誕老人的禮物大概多到運不過來了呢～♪",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "still",
        "still": "108500201"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這邊這邊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n過來過來……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "快點……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "從這邊過去有一間很大的店鋪，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要買的東西應該全部都可以在那邊買到吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥？",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不是那邊啦，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不可以隨便晃到巷子裡……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和、",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和我一起出來買東西，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "果然很無聊嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n總感覺心不在焉的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然我覺得很開心……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n讓我回想起了和哥哥相遇時的樣子，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n感覺就像是約、約會一樣……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你不知道嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥真的是什麼都不知道呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那哥哥你有和誰約會過的經歷嗎，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我是第一個嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸、",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個嘛，約會這個東西，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就是關係很要好的兩個人一起出來買東西之類的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "應該是這樣吧。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也不是特別清楚……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "戀愛小說什麼的，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "經常有這樣的橋段……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我覺得很棒，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也好想體驗看看呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過哥哥已經是大人了，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n肯定覺得是在和小朋友玩耍的感覺……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我可以當作是在約會嗎……？",
        "unit_id": 102111
    },
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……我說，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你又沒在聽了。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "從剛開始就一直東張西望的呢，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n有什麼好奇的東西嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇哇？",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你不要突然把我抱起來呀……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　好可怕啊！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔唔……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我並不是討厭這樣，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要做什麼之前可以先跟我說一聲嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "突然被碰到，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會讓我嚇一跳的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？　",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "「那是什麼？」嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是有人扮成聖誕老人的樣子在賣蛋糕呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵。",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "聖誕節明明還有兩個禮拜才到，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n已經到處都裝飾得像聖誕節了呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你喪失了記憶不知道是怎麼一回事，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n看到這個景象覺得很不可思議對吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "什、",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "什麼嘛，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "太好了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不是因為和我一起出來買東西，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以覺得很無聊啊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個嘛。",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個就叫作聖誕老人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是聖誕節的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "話說在這之前，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你還不曉得聖誕節是什麼日子嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "聖誕節可是，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很久以前一位偉大人物的生日哦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n大家為此一同慶祝，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一起享用美味佳餚，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "載歌載舞……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "然後，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有好好當個乖小孩的人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就會收到聖誕老人的禮物哦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "聽完說明有比較清楚了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿。",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_044"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為我的父母『消失』了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我本來以為收不到禮物的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過今年是和【咲戀育幼院】的大家在一起，",
