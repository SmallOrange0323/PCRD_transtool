    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就先不和哥哥說好了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "相信自己收到聖誕老人的禮物，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_051"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也會比較興奮嘛……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿。",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_052"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也不要總是想得那麼悲觀了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n還是開開心心的期待聖誕節的到來吧……",
