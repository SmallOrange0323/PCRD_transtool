    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_047"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n你問說",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "送禮物的",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不是聖誕老人嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不，可是……",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也不是小孩子了所以能理解，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n其實送禮物的並不是聖誕老人……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……話說，",
        "unit_id": 102111,
        "voice": "vo_adv_1085002_049"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥喪失了記憶，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這樣講只會造成他更混亂吧。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "其實並不是聖誕老人，",
