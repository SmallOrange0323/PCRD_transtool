[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔！",
        "unit_id": 105811,
        "voice": "vo_adv_9009155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　在這種地方竟然有這麼棒的土雞☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那並不是土雞，",
        "unit_id": 105911,
        "voice": "vo_adv_9009155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個魔物是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寒冰孔雀夫人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從雪山來到人類村莊裡，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "襲擊人類的搗亂元凶。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以【公會管理協會】才會發出討伐委託。",
        "unit_id": 106011,
        "voice": "vo_adv_9009155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而・且・呀～♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個漂亮的尾巴羽毛，似乎能賣出好價錢呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_9009155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道是為了這種事，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才帶主人來到",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種積雪深厚又寒冷的地方嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔你們",
        "unit_id": 106011,
        "voice": "vo_adv_9009155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也需要錢吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想想能得到的報酬，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就不會覺得冷了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把那個羽毛全部帶回去大賺一筆吧！",
        "unit_id": 106011
    }
]