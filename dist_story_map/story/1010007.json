[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生～",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n歡迎光臨♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最近",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生常常來玩，人家好高興。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "平常的【哞哞自衛隊】",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n感覺是自由參加的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以有些日子，都沒半個人會出現。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天也是呢……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然真琴和香織輪流來來去去的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她們",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好像忙東忙西的呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且很快就回去了，讓人家很寂寞♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不能讓客人站著說話。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "快進來吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家去準備茶和點心，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生先坐著休息唷♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天有什麼事嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸～？",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "太開心了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也很想和王子先生見面♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "聽見王子先生的肚子在叫了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說了些好聽的話……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n其實王子先生是因為餓了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想要人家請王子先生吃一些點心吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好喔，好喔。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n進來吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "肚子餓很難受的，太可憐了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "多吃一點呀～",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生吃得這麼津津有味，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家光用看的就覺得幸福♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就算沒有事情，也隨時歡迎來玩唷，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦？",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n忘記的東西……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是什麼？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，王子先生的衣服是吧。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這麼說起來，之前被人家的魔法吹飛而且弄髒了衣服……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後王子先生就在這裡洗澡和換了衣服嘛。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "之後王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就穿著人家借的衣服回去了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "本來穿在身上的衣服，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就放在這裡忘記拿了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是粗心呢，王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家應該是一起清洗了以後，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "收到衣櫃去了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家現在去拿，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生等等呀～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "找到了、找到了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是這個對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊哈哈，結果和人家的衣服放在一起……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說不定人家喜歡的香味都沾了上去，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不好意思喔？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但是王子先生能來這裡玩，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家真的很高興呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果人家和王子先生變得親近……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好像也能證明",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n獸人和普通人類可以維持良好的關係呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "得好好相處才行呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為種族的不同而互相仇視，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那樣就太可悲了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不這麼覺得嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只是……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在獸人裡面，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也有討厭或害怕普通人類的孩子。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果王子先生莫名其妙地被盯上了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n記得要跟人家商量唷？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家畢竟算是【哞哞自衛隊】的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n公會長……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "每天從早到晚都在這棟建築物裡面唷。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "應該說人家暫住在這裡。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家因為很多因素離開了故鄉……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n現在在這個蘭德索爾生活。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然人家懂這裡的語言。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但其實人家是來自有點遠的地區喔。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "本來的話，人家應該是不會離開出生的故鄉……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而是要繼承老家的生意。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像籠中鳥一樣過著平凡的生活。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但人家不想要那樣，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以向爸爸媽媽撒嬌。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說是要增廣見聞……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就離開了故鄉，開始一個人生活。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不過這樣的生活也有期限就是了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的爸媽保護人家過頭了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了當作人家的住處，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就把這棟建築物買了下來。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是只有人家住在這，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n空間多出來很多……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以就用來當作公會之家了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也順便",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n收留一些沒有去處的獸人夥伴。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為人家和【動物苑】的高層是知己，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以就在他們組織底下設立了【哞哞自衛隊】。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "經過大大小小的事之後，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就變成現在這樣了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然不都是有趣的事，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是最近每天……都很熱鬧歡樂呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且也和王子先生相識了……",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "下定決心離開故鄉，真的是太好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過也不能",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一直這樣任性下去。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家還得負起老家商店繼承人的責任。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真希望可以一直",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像這樣一邊喝著茶……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "舒適悠閒地過下去呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想和珍貴的夥伴們，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還有王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一起享受更多的青春歲月唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真討厭，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n氣氛變得這麼感傷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不能讓客人",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n變得這麼安靜啊。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如何？要不要跳支愉快的舞呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家希望",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生笑呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒關係。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一點都不覺得不幸。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "童話故事裡面公主所遭遇的那種悲劇，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n完全沒有發生在人家身上♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n要是真的發生了什麼事的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會和王子先生商量的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在希望",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生無憂無慮地笑就好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……需要再來一些點心",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是貪吃鬼呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來，王子先生張開嘴巴，",
        "unit_id": 101011,
        "voice": "vo_adv_1010007_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n啊～……♪",
        "unit_id": 101011
    }
]