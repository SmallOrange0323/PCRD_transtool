[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_1038001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯嗯。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？那、個……？",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我昏倒了嗎……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呀！？",
        "unit_id": 103812,
        "voice": "vo_adv_1038001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對、對不起，一下就弓矢相向……",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個，你是？",
        "unit_id": 103812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你叫，{player}是嗎？\n",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你好，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "初次見面……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的名字是栞。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如你所見我是獸人……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我是【動物苑】旗下公會，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n 【哞哞自衛隊】的一員。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我現在算是正在休養中……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為各種原因，我被派到同為",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n【動物苑】旗下公會的【伊麗莎白牧場】。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，現在不是該作自我介紹的時候吧……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起，我剛睡醒頭腦還昏沉沉～的不太清楚。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我本身有低血壓。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，我昏倒在路旁，",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是你照顧我的吧……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的是……很抱歉，給你添麻煩了吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起，我的身體不太好。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有時候就會頭昏……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "眼花的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我一直都在山上的牧場靜養。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天因為覺得身體狀況還不錯，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我久違地試著下山來城鎮看看。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我有些想買的東西，像書之類的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "平常我都是拜託牧場裡的人……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "偶爾會託來探病的姊姊",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n幫我買東西。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是那樣我還是會覺得很不好意思。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不能老是就這樣依靠別人……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我應該要變得能夠照顧自己才行。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我是這麼覺得的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "光是抵達城鎮，我好像就體力透支了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，我沒事的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請你不用擔心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想我只要稍微休息一下，就會恢復了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯？",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼了嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你好像有什麼話想說呢……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗚哇……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n怎、怎麼了？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你為什麼要摸我的頭？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你覺得我的耳朵很稀奇嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，你是在測我的體溫呀，我不要緊的……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我還覺得有點頭暈，",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是和你聊天後，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我已經大致清醒了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你不用這麼擔心，我不要緊的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我明明就昏倒，說起來沒什麼說服力。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是再給你添麻煩的話，我會很過意不去。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "無論如何，我已經沒事了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我就在此告退了喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "受你諸多照顧了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038001_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這份恩情，我會擇日報答的。",
        "unit_id": 103811
    }
]