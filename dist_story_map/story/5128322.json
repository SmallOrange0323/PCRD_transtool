[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "它的動作",
        "unit_id": 127511,
        "voice": "vo_adv_5128322_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然稍微停止了一下……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但總覺得",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽到了危險的蓄能聲音耶！？",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這氛圍不太妙啊。",
        "unit_id": 127611,
        "voice": "vo_adv_5128322_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n看來我們是點燃了對手的導火線呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "繼光線之後，",
        "unit_id": 127611,
        "voice": "vo_adv_5128322_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不曉得還會出現什麼東西。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不管出現的",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是什麼……",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該都不會是愉快的事吧。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然如此，",
        "unit_id": 127511,
        "voice": "vo_adv_5128322_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只有搶在出現前削弱敵人的力量了！",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n先不管恢復和防禦，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "用最大火力來決勝負吧！",
        "unit_id": 127511
    }
]