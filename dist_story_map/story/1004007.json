        "type": "dialogue",
        "name": "禊",
        "words": "禊的肚子好餓呀──",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n要是沒有在晚餐之前回家的話，媽媽會生氣的……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要是就這樣回不了家怎麼辦……",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_019"
    },
