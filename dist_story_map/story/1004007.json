    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～乾脆來吃便當，",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n然後耐心等候有人路過好了！",
