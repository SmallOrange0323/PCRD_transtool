    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還是路過的哥哥──！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥呀……",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊和哥哥約好的地點，是在蘭德索爾的正中央耶～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥不可能來這裡的吧……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚嗚，太失敗了～",
