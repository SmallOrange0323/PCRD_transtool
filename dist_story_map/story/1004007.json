        "voice": "vo_adv_1004007_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "本來是想要讓哥哥掉進來，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n才特地挖了這個地洞的～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒有想到地洞的底下居然是空的，",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "讓整個地洞都塌陷了。",
        "unit_id": 100411
