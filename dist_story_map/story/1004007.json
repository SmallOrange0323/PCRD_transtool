        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有沒有路過的旅行者──",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n還是路過的傳說勇者──！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "或是路過的美美──",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n路過的鏡華──",
