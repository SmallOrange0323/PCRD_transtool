    {
        "type": "dialogue",
        "name": "禊",
        "words": "都沒有人路過……",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n怎、怎麼辦……都已經晚上了……",
        "unit_id": 100411
    },
