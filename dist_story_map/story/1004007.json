    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天， 約定的時間。"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有──人──在嗎────！",
        "unit_id": 100411,
        "voice": "vo_adv_1004007_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n有沒有人在呀────！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚嗚，怎麼辦……禊沒有辦法逃出這個地洞陷阱了……",
