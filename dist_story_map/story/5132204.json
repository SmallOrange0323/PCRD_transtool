[
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "────咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這、",
        "unit_id": 128011,
        "voice": "vo_adv_5132204_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是怎麼回事……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "魔物們都失去理智了！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在太危險了啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "恐怕是因為那隻巴西利斯克吧。",
        "unit_id": 6111,
        "voice": "vo_adv_5132204_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "要是它們被巴西利斯克嚇得驚慌失措",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "而無家可歸，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "也有可能會大舉下山往城鎮的方向移動。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不只是那樣。",
        "unit_id": 127911,
        "voice": "vo_adv_5132204_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是魔物消失，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只有巴西利斯克留在山上，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "山中的生態系會崩壞的……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是發生那種事，",
        "unit_id": 128011,
        "voice": "vo_adv_5132204_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會對蘭德索爾造成什麼樣的影響……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這已經不再只是為了美食而狩獵了呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯，",
        "unit_id": 127911,
        "voice": "vo_adv_5132204_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聖誕節當然重要，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但為了大自然和未來的蘭德索爾，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定要解決牠！",
        "unit_id": 127911
    }
]