[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霞遭到「闇影」攻擊，受到了致命的傷害。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正當她的存在於{player}的懷中「消失」時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從她口中傳來了聲音。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……看來好像",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒趕上呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉讓你有了痛苦的回憶。",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是我能再更有能力一點就好了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不對。",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管多有力量，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都觸碰不到霞的想法吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在還不遲。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在霞的存在「消失」的前一秒，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我勉強連結到她了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是用非常犯規的方法就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "霞的內心，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為「闇影」而受到了很大的傷害。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就那樣放著她不管，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肯定會「消失」的吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……一旦失去作為核心的內心，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就連作為器皿的身體也會消失。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了阻止這件事發生，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我採取了一種方法。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這是唯有霞才能使用的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "例外手段。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將即將消失的心，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "用其他的心修補。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將霞的身體與這個世界連結的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個存在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無限接近她的內心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "性質相同到足以欺騙世界。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你已經",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明白了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這終究是欺騙世界的行為。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是被發現了就會馬上結束，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "異物會很輕易地被抹去。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不能認為還有很多時間喔。",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在真的太遲了之前──",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "找出它吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n找出霞那顆被「闇影」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所奪走的內心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我能做的就到此為止了。",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n之後的事你就問「那孩子」吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她還談不上是",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠自由自在地說話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但她待在我的剩餘空間時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看過了各式各樣的記憶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以比以前更會講話了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喔，對了。",
        "unit_id": 190011,
        "voice": "vo_adv_1014010_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「那孩子」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟剛出生沒有兩樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要對她溫柔點喔。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「──學長。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「早安。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「你真是個貪睡鬼，",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要遲到了喔。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「你",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "認識我嗎？」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「是的。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_020"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「很高興你記得我。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「我是小霧。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_021"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「為了拯救名偵探小姐，」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_022"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「我想我能幫上學長的忙。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「這些話，",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_023"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "有好好表達意思嗎？」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「謝謝你。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_024"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「太好了。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「……嘿嘿♪」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_025"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「這是個困難的問題呢。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_026"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「因為我一直在沉睡著。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「不過現在",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "已經能活蹦亂跳了。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「我也是。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_027"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「能見到我最喜歡的學長，」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「我很高興。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「喵♪」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_028"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「啊……",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "不對嗎？」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「這不是，",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "要我伸手的意思嗎？」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「那麼，",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_029"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "學長。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「我們開始調查吧。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「你還記得嗎？」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_030"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「要找出攻擊名偵探小姐的闇影。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「重點是",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_031"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "方法吧。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「要解開謎題，",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_032"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "就需要材料。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「尋找目擊者",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "是調查的基本。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「這句話，",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_033"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "我一直很想說一次看看。」",
        "unit_id": 101412
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「……哇啊。」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_034"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「這裡就是",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_035"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "街上啊。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「我之前都只待在小小的房間裡，」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_036"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「所以覺得很新鮮。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「非常感謝你",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_037"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "貼心的顧慮。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「我沒有問題的。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「學長還真是溫柔的人呢。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「我以前，",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_038"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "曾那麼說過。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「現在也",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "一樣。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「學長來看我好幾次，」",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_039"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「還很照顧我。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n「我非常開心。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「那麼，",
        "unit_id": 101412,
        "voice": "vo_adv_1014010_040"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "就開始來打探吧。」",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "\n",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「交給我吧，",
        "unit_id": 101412
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "學長。」",
        "unit_id": 101412
