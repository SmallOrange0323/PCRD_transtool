[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在廣場散步的伊莉亞與{player}突然被光芒所包覆。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哇，怎麼了！？",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n又是這道光！！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……！",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n發、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "發生什麼事了！？",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼……呼……嗚……妾身已經不行了……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒想到，太陽居然會大成這樣……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就算戴上帽子，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "體力還是被耗盡了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只不過想去買個番茄汁而已，",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也就到此為止了嗎……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "至少在最後，",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n真希望能讓妾身咬一口",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "充滿活力的男人的脖子……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯、嗯嗯……！",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n等、等一下啦！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不要搖這麼大力！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼、呼……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這樣不是害妾身消耗更多體力了嗎！？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔，你要為了妾身犧牲自己嗎？",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯，真感動。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那麼，妾身就不客氣了……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊唔……啊唔啊唔……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不行。",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n已經連咬的力氣都不夠了……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "倘若庫存的番茄汁還有剩，就不會發生這種事了……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那個塑膠袋裡放的該不會――",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是、是蕃茄汁嗎！？",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快拿來！",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n現在馬上拿給妾身！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕嚕！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕嚕、咕嚕……呼啊～！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵哈哈哈哈，哈～哈哈哈！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身復活啦！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在妾身的身體裡，",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n彷彿湧出了足以征服全世界的力量！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "汪汪！",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咦？什麼，是小狗啊……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看在妾身現在心情好的份上。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n小狗，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就讓你靠近妾身吧！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "啊嗚……",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎麼了，露出那種苦苦哀求的眼神？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔……看來，",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是想要妾身的番茄汁啊？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "區區下等生物，竟想要妾身的東西……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n才不會給你呢！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "啊嗚……",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……別、別用那種眼神看妾身啦！",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這、這是妾身的番茄汁……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……沒辦法。",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那特別分給你一些，但只有這次哦！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼！？",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你說妾身很溫柔……？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別、別別開玩笑了！",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身可是有朝一日要征服世界的人！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n一點都不溫柔！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若、若你下次再說妾身溫柔，",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就判你死刑！",
        "unit_id": 104431
    },
    {
        "type": "still",
        "still": "104400801"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯，看來有好好地在反省。",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那麼，就當作是賠罪，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n今天一整天，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你都要當妾身的隨從！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "首先是……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身肚子餓了！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "帶妾身去這個城裡最好吃的餐廳！",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_029"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}……",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這是什麼餐廳啊……？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "招牌上寫的是",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n「蒜頭滿滿餃子專賣店」……？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔啊啊啊啊啊～～！？",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這是什麼味道啊！！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身最討厭大蒜了啦～！！",
        "unit_id": 104431,
        "voice": "vo_adv_1044008_033"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1044008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難道不知道大蒜料理，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很不適合身為吸血鬼的伊莉亞嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說到底！你怎麼會想到要帶一位淑女去吃大蒜料理餐廳啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1044008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是",
        "unit_id": 190011,
        "voice": "vo_adv_1044008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "根據你跟伊莉亞過去的記憶所打造的「夢」喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而現在的你採取了這樣的行動呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這讓我也看得很開心呢♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次再見囉～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1044008_037"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身討厭大蒜～",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……咦？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妾身又做夢了嗎？",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似乎又是個奇妙的夢呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵呵，",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n{player}你在夢中也是妾身的隨從，真令妾身感動。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼？",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你也做了同樣的夢嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那這樣事情就好辦了！",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n咱們來延續夢境吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "帶妾身去這個城裡最好吃的餐廳！",
        "unit_id": 104412,
        "voice": "vo_adv_1044008_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不、不過，不能有大蒜唷！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，像夢裡一樣，\n{player}與伊莉亞一起去吃飯了。"
    }
]