[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ノウェムとオクトー"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n二人が組んでからまだ、間もない頃。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "よしオクトー！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nリーダーを決めるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うわー",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "またなんか面倒そうなこと言い出したねー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いやさ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "『アイツら』はいつも力を合わせて戦って、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nここまで勝ち続けてきてるだろ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシたちと何が違うのかなって考えてさ。",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_003"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "それはやっぱり、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "リーダーの存在じゃないかな",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "って思ったんだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まぁ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_004"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あちらさんは",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "彼を中心に固まってるもんねぇ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でもさ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "こっちは基本二人だよ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nリーダーとか別にいらなくない？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いいや、",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_005"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いる！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ふぅ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_006"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "相変わらずの熱血ちゃんだなぁ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "でもまぁ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_007"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "確かに指揮系統を定めるのは",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "悪くはないのかもねー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ノウェムを自由に動かしとくと、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "危なっかしいし。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "というわけで",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_008"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "決めるぞ！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "リーダー！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いいか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "リーダーの言うことは",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "絶対だからな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "どんな命令にも従うんだぞ！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ふっふっふ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "うわぁ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_009"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n超能力なんてなくても",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "邪な考えが手に取るように分かる。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ねぇ、",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_010"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "もしかしてノウェム、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "リーダーになりたいのって",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nボクをいいように動かしたいだけだったりするー？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "はっ！？　",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_011"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ま、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "まさかそんなわけないだろ！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nめんどくさがりのオクトーが",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アタシの命令に従う姿が見たいとか",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nそんなこと全然思ってないからな！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……少し見直して損しちゃったなー",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_012"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それで、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "どうやって決めるわけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nまさか武器持って戦うわけじゃないよね？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もちろんそうだぞ！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_013"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n昔から決まってるじゃないか！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "強い方がエラい！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_014"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "その発言からリーダー性の欠片も感じなーい。",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "というか、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "力って明らかにそっちのが上じゃない？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nヤバい剣も持ってるしさー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんだ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_016"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "戦う前から降参するのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "だったら",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "リーダーはアタシで決まりだな！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "はいはい、",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_017"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクの負けでーす。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "じゃあ次の勝負いこうかー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "へっ？　",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_018"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "次？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "自分に有利な勝負だけで",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_019"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nリーダーが決まるわけないでしょ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n次はボクが決めたルールで勝負ね。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "うっ……",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_020"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "じゃあ数学で勝負ね。",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_021"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "お互いに問題を出しあって",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "解き続けていくんだ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nじゃあボクの方から問題を……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "まっ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_022"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "待った！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nそんなのオクトーが有利に決まってるじゃないか！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nずるいぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "あれー？　",
        "unit_id": 106211,
        "voice": "vo_adv_5110602_023"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "戦う前から降参しちゃうの？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "じゃあ引き分けだねー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nどうする？　",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "次のラウンドに行く？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "うぅ～～～～～！",
        "unit_id": 106114,
        "voice": "vo_adv_5110602_024"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nこれじゃ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いつまでたってもリーダーなんて",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n決まらないじゃないか～～～～～～～！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ノウェムの叫びを聞きながら、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nオクトーはかすかに笑うのであった。"
    }
]