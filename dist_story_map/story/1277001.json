[
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "萊拉耶爾公主的女僕"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "琳德，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n今天也跟烏爾姆一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "勤奮地做著城裡的工作。"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "西側的燈保養完了。",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_000"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n也聯絡好送食材的人了，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "接下來要洗完衣物，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "然後……",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生！",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_001"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "你到吉歐‧提格尼亞來啦。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n辛苦了。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是，",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_002"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這種程度的工作量很普通喔。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這是跟平常一樣的日常。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我們這邊女僕的人數不是很多，",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_003"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n所以基本上",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "不什麼都去做的話會忙不過來。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……不過，",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_004"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊她除了平常的工作之外，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n還會自己跑去被別人拜託做事情就是了。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "像是洗盤子",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "或是修剪路樹之類的。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆妳才是老是在偷懶啊！",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_005"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "而且，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "女僕不是只要做好被吩咐的工作就可以了啊。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要是有人感到困擾的話，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要去幫忙才行。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦！？",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_006"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n那怎麼行，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生明明也很忙碌，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n怎麼能讓你來幫我……！",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "沒關係吧，老姊。",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_007"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n既然他有幹勁的話就交給他吧。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那麼，全體注意──",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_008"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "這邊的騎士先生，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "似乎不管拜託他什麼",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n他都會幫忙喔──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "喔，",
        "unit_id": 9411,
        "voice": "vo_adv_1277001_009"
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "那就拜託你幫我洗碗吧！",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "\n",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "我最近很忙，都沒空去洗……",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "\n",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "還有，",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "今後如果要跟異世界交流的話，我想增加餐具……",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "我剛好想要人手啊～",
        "unit_id": 9311,
        "voice": "vo_adv_1277001_010"
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "\n",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "要從城裡的各個地方回收待洗衣物",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "也需要人手啊……",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "\n",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "啊，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "就順便拜託你幫我洗好吧。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我的肩膀僵硬到不行啊，",
        "unit_id": 9111,
        "voice": "vo_adv_1277001_011"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "可以請你",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "幫我敲一下嗎？",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "等、",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_012"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "等等啦，各位！？",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "還有烏爾姆，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那些是我們的工作啊！",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "明明是那樣，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "卻把騎士先生捲進來──",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要交給你嗎！？",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_013"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "唉……",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_014"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我知道了。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那麼，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "今天就拜託騎士先生也跟我們一起工作。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請你不要勉強喔！",
        "unit_id": 127711
    },
    {
        "type": "background",
        "background": "501730"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "首先從洗碗開始吧。",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_015"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不過，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "沒想到",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要洗的碗盤會堆積如山啊……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的。",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_016"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n大家明明都是大人了，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "都太仰賴騎士先生的好意了啦！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "就算是那樣也還是要有限度的啊！",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_017"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n應該說，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要是平常就有勤勞地在洗碗盤的話，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n是不會堆成這樣的喔？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "為什麼大家都不認真工作呢……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_018"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "明明一開始就認真工作絕對會比較好啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不拘小節……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_019"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我是",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也覺得那樣不壞啦。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那不是能不認真工作的理由吧？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n因為",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那樣最後會傷腦筋的是自己啊！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_020"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "很仰賴我？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……我、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我是不會被那種話騙的喔！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我並沒有感到高興！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……不對，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_021"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "現在不是能一直講話的時候呢。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "如果有不懂的地方的話，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n不用客氣盡管問我吧！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "還有烏爾姆不要在那偷吃東西！",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_022"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n要好好擦盤子！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好好好，",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_023"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我知道啦──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "今天的姊姊",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_024"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "莫名的有幹勁呢……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "希望她不要努力過頭就好了。",
        "unit_id": 127812
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "打掃王座之廳",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_025"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也是女僕工作的一環。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這裡只有被萊拉耶爾殿下信賴的人",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n才能負責打掃喔。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那麼，",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_026"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我們就分頭進行吧。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "首要要從把裝飾品上的灰塵撢到地板上開始……",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "可以嗎？",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_027"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我要做的時候，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "都要站到凳子上去……",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n然後因為站不穩所以很辛苦。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是的！",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_028"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n那麼我們也",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "配合你，",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "開始擦東西",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "跟掃地了喔。",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "居然能這麼順利開始工作……！",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_029"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "你難道很習慣打掃嗎？",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真厲害……！　",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "能進行地這麼順利的話，",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_030"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n今天的工作感覺能很早結束……",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n好──！　",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……嗯，",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_031"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "奇怪？",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆？",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "妳在哪裡？",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那麼。",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_032"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我就去睡個覺……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏～",
        "unit_id": 127711,
        "voice": "vo_adv_1277001_033"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "爾～",
        "unit_id": 127711
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "姆～！？",
        "unit_id": 127711
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嘿咻……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_034"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嗯，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是這邊吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆～？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n妳有好好跟上來嗎？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "不用妳說我也在這裡啦。",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_035"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "那麼",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我會去晾洗好的衣物，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "就拜託騎士先生準備繩子了喔。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "呼……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_036"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "終於晾完一半左右了吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這都是託騎士先生幫忙的福喔！",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_037"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "平常要花更多時間的。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "今天天氣也很好，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_038"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是太好了。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n你看，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "被陽光照著的泡泡非常漂亮喔！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n圓潤又發著光，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "像糖果一樣……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嗯，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_039"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "奇怪？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n為什麼會有泡泡在飛舞啊？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n這附近明明就沒有使用洗衣精、",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "的說……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "…………（呼──）",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_040"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆！",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_041"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n真是的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "要我說幾次妳才懂啊！？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好好好，",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_042"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我會去工作、我會去工作。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n我只是稍微休息一下而已啦。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "是那那樣沒關係嗎，",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_043"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "姊姊？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "妳背後那邊，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "洗好的衣服被馬卡龍狗們當玩具玩耶。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦？",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_044"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……啊！？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不會吧，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_045"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "討厭啦！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我好不容易才洗好了說！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n不可以吃！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "住手啊～！",
        "unit_id": 127712
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "唉……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_046"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "被口水弄得濕濕黏黏的了……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n被吃到的被單",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n只能回城裡重洗了呢……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_047"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "難得騎士先生來幫我了啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "而且，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "在這之前明明都很順利的說……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_048"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_049"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "果然很厲害啊……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n就連發生這種突發狀況也不慌張。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生在工作時動作也很俐落……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_050"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n明明是我說有不懂的地方可以問我，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我卻反而一直被幫助。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "相較之下，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_051"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "…………",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_052"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我說，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是的……",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_053"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嗯，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "奇怪？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請等一下，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "你披風的袖子被土弄髒了。",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_054"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n而且，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "衣服的袖子也……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請等我一下喔。",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_055"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嘿",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咻……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "好了，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "撥掉了！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "這種程度的事情，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_056"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "請你別在意！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n因為服務其他人也是女僕的工作。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "咦？",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_057"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我很……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "了不起嗎？",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "沒、",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_058"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "沒有那種事啦！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n身為萊拉耶爾殿下的女僕，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "會注意服裝儀容",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是理所當然的！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "應該說，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_059"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "是大家太不認真了。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n烏爾姆的蝴蝶結也老是歪的。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n每天要幫她調正也很辛苦啊！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "所以說",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_060"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不是我很認真……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我並沒有",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "很了不起啦……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "嘿嘿……♪",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "…………",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_061"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……唉。",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_062"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n老姊真的是",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "很好搞定啊。",
        "unit_id": 127812
    },
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後──三人在東奔西走後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在太陽要下山時終於完成所有工作了。"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_063"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "今天很謝謝你！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我跟姊姊都被你幫了不少忙啊。",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_064"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n騎士先生，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "你要不要就這樣在這裡工作？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "烏爾姆妳真是的，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_065"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "不要說那種話啦。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生他們有要做的事情啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "但是他留下來的話",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_066"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "老姊會很高興吧。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那、",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_067"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那是……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那個。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……是那樣沒錯啦……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "你們三個！",
        "unit_id": 9311,
        "voice": "vo_adv_1277001_068"
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "\n你們真的",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "把工作全都做完了呢！",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "你們真的幫了一個大忙啊。",
        "unit_id": 9411,
        "voice": "vo_adv_1277001_069"
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "\n這個是我烤給你們當謝禮的烘焙點心，",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "你們拿去吃吧！",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "各位！？",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_070"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "就算你想用點心來拐騙我也不行喔！",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n今天我一定要讓你們好好反省──",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "好啦好啦好啦。",
        "unit_id": 9311,
        "voice": "vo_adv_1277001_071"
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "\n",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "託你們的福，",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "負責洗衣的女性",
        "words": "\n我們連平常兼顧不到的工作也完成了喔。",
        "unit_id": 9311
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我的肩膀也舒暢開了，",
        "unit_id": 9111,
        "voice": "vo_adv_1277001_072"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n工作得比平常還要勤奮啊。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n所以啊，",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "好嘛？",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "妳就收下吧。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……如果是那樣的話，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_073"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "我就吃一個吧。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "啊姆。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "……！",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_074"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "好好吃……♪",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就是說吧、",
        "unit_id": 9111,
        "voice": "vo_adv_1277001_075"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就是說吧。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n是大家一起決定",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n要做成琳德你們喜歡的口味的喔。",
        "unit_id": 9111
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "但是",
        "unit_id": 127812,
        "voice": "vo_adv_1277001_076"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我們能收下這麼多嗎？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "這樣滿滿一箱，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "會讓我們暫時都不缺點心啊。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "那是……",
        "unit_id": 9411,
        "voice": "vo_adv_1277001_077"
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "那個，",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "該說是為了今後先預付的嗎……",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "妳懂吧？",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "廚師",
        "words": "\n嘿嘿……",
        "unit_id": 9411
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "那點請你們好好反省！",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_078"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "真是的，",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "大家都很會見風轉舵啊……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "但是，",
        "unit_id": 127712,
        "voice": "vo_adv_1277001_079"
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "騎士先生如果也有什麼需要的話，請不要客氣直接跟我說喔。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n我必須回報你幫忙我這件事才行……",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "\n而且照顧大家",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "琳德",
        "words": "也是我們的工作啊。",
        "unit_id": 127712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "琳德跟{player}順利完成了工作。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被眾人們的感謝與甜美的香氣包圍著，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人一邊感受著成就感，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一邊相視而笑。"
    }
]