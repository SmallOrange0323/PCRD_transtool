[
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "魔物解決掉了嗎……？",
        "unit_id": 117311,
        "voice": "vo_adv_5072203_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我想",
        "unit_id": 117411,
        "voice": "vo_adv_5072203_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該是吧……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣演唱會就可以繼續進行下去了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行喔，",
        "unit_id": 117211,
        "voice": "vo_adv_5072203_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們可別鬆懈了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n偶像的演唱會當然會波瀾不斷，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n看來還沒有結束呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "似乎就是這樣……",
        "unit_id": 117311,
        "voice": "vo_adv_5072203_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就當作是精進歌唱和舞蹈技巧的磨練，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "勇往直前吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "各位觀眾們，",
        "unit_id": 117411,
        "voice": "vo_adv_5072203_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也請你們要更賣力地聲援我們喔！",
        "unit_id": 117411
    }
]