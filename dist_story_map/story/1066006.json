        "voice": "vo_adv_1066006_058"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥覺得怎麼樣呢？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我工作時的身姿，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很帥氣吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n觀摩後有什麼感想嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼～",
        "unit_id": 106611,
        "voice": "vo_adv_1066006_059"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是吧是吧……",
