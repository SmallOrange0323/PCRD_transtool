    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "終於清完了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這樣就乾淨多了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啊，",
        "unit_id": 106611,
        "voice": "vo_adv_1066006_057"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好像也沒有多乾淨……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算、",
