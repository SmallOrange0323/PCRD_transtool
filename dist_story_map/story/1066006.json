        "voice": "vo_adv_1066006_061"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難得讓小哥見識我工作的模樣，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你就不能抱著一顆從中學習進取的心嗎！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n真的是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很讓人傷腦筋耶。",
