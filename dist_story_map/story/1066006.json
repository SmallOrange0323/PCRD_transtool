    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "放心吧，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不必擔心錢的問題！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然是去手下擺的攤位……",
