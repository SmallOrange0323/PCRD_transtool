        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，一副傻樣……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算我是個大美人，",
        "unit_id": 107111,
        "voice": "vo_adv_2009012_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也不該這樣死命盯著人家看唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還真是不懂禮儀呀，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最近的年輕人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_2009012_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過嘛，你會如此驚訝也無可厚非嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟就連我自己也不敢置信了呀……",
        "unit_id": 107111,
        "voice": "vo_adv_2009012_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個天下無雙女中豪傑的克莉絲提娜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然淪落到來當上了個什麼偶像的製作人呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但正因如此，",
        "unit_id": 107111,
        "voice": "vo_adv_2009012_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人生才有趣呀！",
        "unit_id": 107111
    },
