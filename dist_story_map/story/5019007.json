    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之前只有雨吉先甦醒了呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "無論如何，",
        "unit_id": 511,
        "voice": "vo_adv_5019007_017"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我們已經體會到",
