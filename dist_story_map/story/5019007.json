    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聚集了鈴奈等人的祈禱之力，晴神大人終於平安甦醒。\n海灘變得晴空萬里，雨神大人也恢復了原本的模樣。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 11711,
        "voice": "vo_adv_5019007_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難道他就是……？",
        "unit_id": 110011,
        "voice": "vo_adv_5019007_001"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "晴吉吉吉吉～～！！",
        "unit_id": 11611,
        "voice": "vo_adv_5019007_002"
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "唔！",
        "unit_id": 11711,
        "voice": "vo_adv_5019007_003"
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "\n早安！",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "晴吉、",
        "unit_id": 11611,
        "voice": "vo_adv_5019007_004"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "晴吉！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n我好想見你啊～！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了！",
        "unit_id": 110011,
        "voice": "vo_adv_5019007_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喚醒晴吉了呢！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀，",
        "unit_id": 110211,
        "voice": "vo_adv_5019007_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只要交給我們，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很快就沒事了啦！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "各位，",
        "unit_id": 110111,
        "voice": "vo_adv_5019007_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你們辛苦了。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天我要幫你們畫特大的鼓勵小花！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "你們那樣吵吵鬧鬧的在做什麼？",
        "unit_id": 11711,
        "voice": "vo_adv_5019007_008"
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "\n我的頭還有點昏昏沉沉的……",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "\n感覺這次",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "好像有點睡過頭了呢？",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "而且，",
        "unit_id": 11711,
        "voice": "vo_adv_5019007_009"
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "你說的晴吉",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "是什麼？",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "呵呵呵，",
        "unit_id": 11611,
        "voice": "vo_adv_5019007_010"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n那是鈴奈為我們",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "想的暱稱！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n鈴奈她呀，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "是我新結交的",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "人類朋友。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "她說是朋友的話，",
        "unit_id": 11611,
        "voice": "vo_adv_5019007_011"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "有個暱稱會比較好。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n所以說，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "我叫雨吉！",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "咦！",
        "unit_id": 11711,
        "voice": "vo_adv_5019007_012"
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "\n妳就是鈴奈？",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "\n以一個人類來說，",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "妳還蠻有品味的嘛！",
        "unit_id": 11711
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈哈哈，",
        "unit_id": 110011,
        "voice": "vo_adv_5019007_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還好啦！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "那個……",
        "unit_id": 511,
        "voice": "vo_adv_5019007_014"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "雨神大人……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不對，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是雨吉，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "還有晴吉，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "這次的事",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "實在很抱歉！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "晴吉",
        "words": "……？",
        "unit_id": 11711,
        "voice": "vo_adv_5019007_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為晴吉之前在沉眠，",
        "unit_id": 110111,
        "voice": "vo_adv_5019007_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n看來你不知道",
