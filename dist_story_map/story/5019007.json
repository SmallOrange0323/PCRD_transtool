        "voice": "vo_adv_5019007_020"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "　天氣一事，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "就交給我們。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n對吧！",
        "unit_id": 11611
    },
