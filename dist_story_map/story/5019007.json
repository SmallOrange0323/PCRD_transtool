    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "像這樣的事情，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "不會再讓它發生第二次……",
        "unit_id": 511
