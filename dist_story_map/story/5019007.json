        "voice": "vo_adv_5019007_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你們沒事吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n雖然剛才的表演有點浮誇，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但大家玩得開心嗎～？",
