[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和鈴奈正一起享用午餐。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這間店的料理很美味吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是人家很中意的店喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "作為之前幫人家算錢的回禮，",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你可以盡量吃沒關係喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，可是人家待會有工作，",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒什麼時間。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家在當模特兒～",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n待會在廣場有舉辦活動喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說是要介紹我們的日常穿著。你方便的話，也來看看嘛。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "集合時間是1點鐘～",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃，時鐘時鐘……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在是……12 點 5 分左右？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼嘛，時間還很充裕！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯？什麼？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n現在已經過了1點鐘？ ",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "騙人，真的嗎！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家把長針和短針看錯了嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "糟糕！",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n也就是說，不就已經遲到了嗎！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家不走不行了！",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，謝謝你告訴人家時間！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "呀～！",
        "unit_id": 411,
        "voice": "vo_adv_1016002_009"
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "\n鈴奈！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕！",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這就是人家的日常穿著喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是能作為參考？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "非常有參考價值――！",
        "unit_id": 1211,
        "voice": "vo_adv_1016002_011"
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "\n好可愛――！！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了～",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n謝謝～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……咦？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那個站在後面的人是……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然是秀才！",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你來看了啊～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個活動就要結束了，",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家想要聽聽秀才的感想！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！你有看到嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家看起來如何？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說什麼呢，好好笑～",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家跟秀才一樣都是人類喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "意思是說秀才也想當模特兒嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那不太可能吧～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才看起來那麼寒酸……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之，有讓你覺得很厲害嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有的話就算OK了吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～？不只是很厲害？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼意思？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說你覺得不能跟人家像平常一樣說話？",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～你說的話好奇怪？超有趣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就算人家是模特兒",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n也沒什麼好在意的吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "應該說，",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就算你在意，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家還是會一直找你說話。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以秀才也不用在意，要跟人家聊天喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就這麼說定了喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "呀～！",
        "unit_id": 411,
        "voice": "vo_adv_1016002_025"
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "\n是鈴奈――！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "咦？",
        "unit_id": 1211,
        "voice": "vo_adv_1016002_026"
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "\n跟鈴奈在一起的是誰？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女粉絲２",
        "words": "難道是戀人！？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "糟糕，粉絲們還在這裡……",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果招來奇怪的誤會，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才可能會遭殃……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_1016002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要逃了喔～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "鈴奈，等等――！",
        "unit_id": 411,
        "voice": "vo_adv_1016002_029"
    },
    {
        "type": "dialogue",
        "name": "女粉絲１",
        "words": "\n那個男的是誰――！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "直到完全逃離粉絲之前，\n兩人不斷地奔跑。"
    }
]