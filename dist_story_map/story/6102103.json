[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒想到",
        "unit_id": 123611,
        "voice": "vo_adv_6102103_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在我表演劍舞之後，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n會有人來找我說要當我的粉絲……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我第一次遇到這種事，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還有點不知道該怎麼辦呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "連你都這麼說！？",
        "unit_id": 123611,
        "voice": "vo_adv_6102103_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……雖然覺得很害羞，可是……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n畢竟如果錯過今天，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "以後應該也很難有Cosplay的機會……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……沒辦法了，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只拍幾張的話，就讓你拍吧。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只能拍幾張喔。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不是啦，",
        "unit_id": 123611,
        "voice": "vo_adv_6102103_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我既不是",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "直播主，也不是Coser……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "說得也是。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有人可是說了會替我加油呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我要把工作做好，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "才不愧對那個人的支持。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我之前也說過了……",
        "unit_id": 123611,
        "voice": "vo_adv_6102103_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我並沒有成為直播主之類的想法喔。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟我其實也不適合，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再說了，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我還有著",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "守護人們的使命啊。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有人想看我的直播，這一點倒是讓人滿開心的。",
        "unit_id": 123611
    }
]