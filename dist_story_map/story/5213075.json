    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哈嗚嗚嗚……",
        "unit_id": 102511,
        "voice": "vo_adv_5213075_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n明明只喝了一口，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "卻有一種滿足感在不斷擴散開來……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "清爽的口感，",
        "unit_id": 102511,
        "voice": "vo_adv_5213075_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "加上蓬鬆柔軟的奶油泡沫，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n彷彿被涼爽的微風輕拂般的舒適感……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明只是飲料，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "卻已經像一道完整的料理了……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳能滿意",
        "unit_id": 126511,
        "voice": "vo_adv_5213075_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是太好了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那個飲料",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會對飲用者的魔力產生反應",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而起泡喔。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不只是味道，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還能加入趣味性一起享受的飲料呢……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚……？",
        "unit_id": 102511,
        "voice": "vo_adv_5213075_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦咦咦咦咦咦！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是怎麼回事？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "周圍的瓶子",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "突然開始冒氣泡了！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "材料的蘇打水",
        "unit_id": 126511,
        "voice": "vo_adv_5213075_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "從瓶子裡溢出來了嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "鈴莓，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "難道妳",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "喝過其他瓶子了嗎……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咕嘟咕嘟咕嘟……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_5213075_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我可沒有做那種事啊～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這次我明明沒有冒失啊～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……咕嘟咕嘟咕嘟……",
        "unit_id": 102511
    }
]