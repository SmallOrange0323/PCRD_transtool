    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "大体、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "織姫ちゃんって超絶美少女がいるのに",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n他の子とキャッキャウフフしたいとか贅沢極まりない！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "その通り！　",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_001"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "欲張りすぎ！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "けしからん！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n太古の昔から、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "欲に溺れたものは身を滅ぼすものなんじゃよ。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nというわけで彦星ーっ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "首を洗って待ってろよーっ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "そうだねぇ……",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "というわけで",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ここはやっぱり魔法少女の出番だー！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ちょっぴり刺激的な魔法の力で、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "彦星殿を説得してやるー！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "えっ、",
        "unit_id": 113311,
        "voice": "vo_adv_6044206_003"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "私だったら？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "そりゃあ悲しい、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "と思うよ。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "やっぱり好きになった男の人には、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n自分だけを見ていてほしいっていうか……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "って何言わせんのさぁっ！？",
        "unit_id": 113311
    }
]