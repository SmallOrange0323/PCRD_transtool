        "voice": "vo_adv_1227003_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "根本是變態！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你真的要變成變態可疑分子了喔！",
