        "voice": "vo_adv_1227003_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還真是個粗心大意的人呢。",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我明明都避開了，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼你會絆倒啊？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什……！",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你、",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你是指那是我的錯嗎？",
