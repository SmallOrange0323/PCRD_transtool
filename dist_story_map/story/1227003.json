    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗎？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但我",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒有臉面對……",
