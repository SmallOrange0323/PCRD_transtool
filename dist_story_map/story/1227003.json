    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唔，",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "到此為止了……",
