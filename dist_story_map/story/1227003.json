    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "把錯誤歸咎於人",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是不好的喔。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你的膝蓋擦傷了呢。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n讓我看一下。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……對不起。",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n都是因為我，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才讓你受傷了。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還有",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個夏令營也是，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明是我說要請你幫忙的，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "卻還做出疏遠你的舉動。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "水上步行的魔法也是，",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明明要是沒有你的力量，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我根本就無法像那樣使用，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但我卻還因此被大家稱讚，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "並沾沾自喜……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家有危險時，",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也什麼都辦不到。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我明明都說",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "自己是隊長了……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "欸嘿嘿，",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我這是遭天譴了。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我想……",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "大家，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n都對我感到很傻眼，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "並且討厭我了吧。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什麼絕對？",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_037"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那種事你怎麼可能知道！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為我",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_038"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明向大家大肆炫耀，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但關鍵的時候我卻只會發抖……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "讓他們經歷了可怕的事。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……所以我被討厭是理所當然的。",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_039"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……什？",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_040"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什……",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_041"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什……！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你突然之間",
        "unit_id": 122711,
        "voice": "vo_adv_1227003_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是在講什麼啊！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
