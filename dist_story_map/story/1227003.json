        "voice": "vo_adv_1227003_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼變快了！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我不是說了不要跟過來嗎！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "追著女孩子到處跑，",
