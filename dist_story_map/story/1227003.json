        "voice": "vo_adv_1227003_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好危險，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "地面有凸起……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我差點就要摔倒了……",
