    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要直接回家了！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你就這樣告訴大家！",
