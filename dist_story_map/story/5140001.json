[
    {
        "type": "background",
        "background": "500970"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我回來了，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "新校舍！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊哈～",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "外面世界的空氣真清新！",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "整個沁入五臟六腑啊……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "終於回來了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這就是我們優妮們安穩的日子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯！",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這是我們好朋友社安穩的日子！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀～",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然阿富小姐最後",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "跟我們說什麼不要再回來了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過那種地方，就算被拜託也沒有人要回去吧～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這是當然的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算給我一大堆的盧幣，我也不要回去。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，瑪麗亞把那個瘋狂聖女發配邊疆，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還真是明智的決定。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要是就這樣放任她踏入社會，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n對於管理方來說算是相當考驗管理制度的問題人物吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "面對突如其來的告別，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n一不留神就以賺人熱淚的演出做結束了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但是冷靜想想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "完全沒有任何值得我們感動的要素啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為什麼我們會突然獲得釋放呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n富美惠修女看起來似乎也沒有掌握情況，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但應該是鋼鐵瑪麗亞她因為什麼原因而改變心意了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是為什麼呢。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了，是什麼都好啦。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只要不必再回到那個地獄──",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔喔，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}學弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好久不見了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來你今天有來上學啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你來得太晚了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你在今天之前都在做些什麼啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們可是直到剛才",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "都一直處在恐怖的地獄監獄篇耶？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你近來如何呢。",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有段時間沒見到了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不知道你過得好不好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反正八成是和其他女生在到處",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n做著賺不了錢的慈善活動吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無所謂，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不管怎樣……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你回來就好。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "看你剛剛好像在找什麼的樣子。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，是發生什麼事了嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "啊？",
        "unit_id": 1,
        "voice": "vo_adv_5140001_015"
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "老師指定的教室就是這裡嗎……",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可是，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "裡頭似乎已經聚集了不少學生，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n為什麼要讓我們在這種地方集合？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳可以不用再假裝自己是轉場後負責開場的主角了喔。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "哦～",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_018"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "好朋友社來了。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "日安，",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "克蘿依同學。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "工作辛苦了，",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "克蘿依同學。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝啦。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是什麼集會？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "詳細情況",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "我們也還沒有聽說。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "只知道要來這裡集合。",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_023"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "修女說，",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_024"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "好像是有什麼重大發表。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小希爾修女的重大發表？",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_025"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會是什麼呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "說到重大發表，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大致上不是結婚、解散就是發表新歌呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "修女並沒有在從事藝能活動。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也是呢～",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要是她有從事就好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "以隨便附和聞名的琪愛兒。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_028"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "各位，",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_029"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "日安。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "哼嗯……",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_030"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "優妮妳們也回來了呢。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n工作辛苦了。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "咳，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "那麼",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "就開始吧。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "嗯～",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_031"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "本校",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "至今，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "多次邀請來自外部的專家，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n提供了學習實踐性社會活動的機會。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "那就是",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "深受理事會與贊助者好評的",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "「特別講座」。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_032"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有這麼一回事呢……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像是什麼自然、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼經營之類的？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然我不太記得自己學到了什麼就是。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果是巨大植物魔物",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "或巨大鋼鐵人偶失去控制，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n使得學院瀕臨滅亡危機的記憶我倒是有。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為這樣導致我們每次都被冤枉的記憶我倒是有。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_034"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也就是說，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_035"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只有不愉快的記憶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "哎呀哎呀，",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_036"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "各位的眉頭皺成那樣看起來很高興呢。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "對，沒錯，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "各位引頸期盼的特別講座",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "將在今天再次舉辦！",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "欸────",
        "unit_id": 1,
        "voice": "vo_adv_5140001_037"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "呵呵呵……",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_038"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "要歡呼還太早了唷？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n這一次的講座，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n可是之前博得好評的那群人士",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "又再次前來了。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "好～",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_039"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "那麼，我就請對方進來吧。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n不侷限於教室講課，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "擔任「實踐性經營學」講師的，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "就是各位都認識的這群人士！",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "請進！",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦～呵呵呵！",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n日安，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "聖德蕾莎女子學院的各位！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_041"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是小墨丘利們。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好久不見了，",
        "unit_id": 108011,
        "voice": "vo_adv_5140001_042"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "各位！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "很高興再次見到各位！",
        "unit_id": 126811,
        "voice": "vo_adv_5140001_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "大家都有當個好孩子嗎喵～？",
        "unit_id": 107911,
        "voice": "vo_adv_5140001_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "特別講師",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "【墨丘利財團】，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "粉墨登場喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "墨丘利財團",
        "words": "喵",
        "unit_id": 1,
        "voice": "vo_adv_5140001_045"
    },
    {
        "type": "dialogue",
        "name": "墨丘利財團",
        "words": "───！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "姐姐們，",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳們是怎麼了？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n今天的登場比平時還要更有活力呢。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而且，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我並沒有什麼久別重逢的感覺。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為我們跟小墨丘利們",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_048"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n在學院外常常扯上關係嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大概是「前陣子謝謝妳們了」的感覺吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "咦？",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_049"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "這群活潑的姐姐們",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "是誰啊？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "她們，",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "就是那群人士呀……",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "\n",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "在上次的特別講座",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "讓巨大的機關人偶失控……",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "然後",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "導致我們的校舍陷入一片火海……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "\n",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "這次究竟",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "會燒掉什麼呢……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "奇、",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_052"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "奇怪……？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位……？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n跟我預期的反應",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "稍微有點落差呢……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不愧是我的得意門生，",
        "unit_id": 108011,
        "voice": "vo_adv_5140001_053"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "問得好。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不如說希望你能在一開始就先提問呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_054"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這次計畫的象徵──",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也就是",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "制服。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "簡報最重要的是衝擊性，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以作為表演手段，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們從形式方面來著手。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等講座開始後，",
        "unit_id": 126811,
        "voice": "vo_adv_5140001_055"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們也要請各位一起穿上唷。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啥？",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "穿泳裝？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "為什麼……",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在還是冬天耶？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯，",
        "unit_id": 107911,
        "voice": "vo_adv_5140001_057"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是冬天喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這次的特別講座要請妳們",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "協助我們的新事業",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「寒冬的盛夏計畫」喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "寒冬的……",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，什麼？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "寒冬的盛夏計畫喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5140001_059"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "寒冬的盛夏計畫。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……難以理解。",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點的話？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說到冬天就是盛夏！",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "說到冬天就是盛夏。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳們是在說什麼啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳們從剛才開始到底是在說什麼啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小墨丘利們……",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_065"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為過度勞動導致腦袋終於……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不是啦！",
        "unit_id": 108011,
        "voice": "vo_adv_5140001_066"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是指我們要一起建立這種新的價值觀。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所謂商機，",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_067"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就在沒人料想得到的地方──",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也就是說，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就在「妳是在說什麼」",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "的前方唷！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那就是寒冬的盛夏計畫！",
        "unit_id": 107911,
        "voice": "vo_adv_5140001_068"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "顛覆常識的創新事業喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "太棒了！",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_069"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n不愧是特別講師們，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "真是讓人受益匪淺的一席話！",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n優妮博士，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "妳不做個筆記嗎？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_070"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現階段，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我只有一股不祥的預感，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還沒有聽到任何具體的內容。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也是呢，",
        "unit_id": 126811,
        "voice": "vo_adv_5140001_071"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣講好像有點太空泛了。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼就請你們到現場親身體驗，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "順便當作驚喜吧。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "哎呀，",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_072"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "這實在是太感激不盡了！",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "好了好了，各位，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "不要驚訝得目瞪口呆的，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "趕快做好旅行的準備吧。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "啥…………",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_073"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "咦，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "現在開始？",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "視情況可能會住一晚……",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_074"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "或是兩、三個晚上，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "不過我們已經事先",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "跟各位的監護人聯絡好了。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n沒有問題的。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "問題是在那裡嗎？這可是個大問題呀！",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_075"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "學院跟財團聯手合作",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_076"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "的手段太高超了，真恐怖呀！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然距離現場有段距離，",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_077"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但這點也請各位放心。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我已經讓我們家的飛空艇",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在這邊的中庭待命了。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喔喔，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_078"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "飛空艇！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是傳聞中飛行於高空的船啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那還真是有趣呢！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，連那種東西都拿出來了，",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_079"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我們到底是要被帶到哪裡去啊。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈哈，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_080"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我已經猜到了喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「寒冬的盛夏計畫」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "據說在阿斯特賴亞大陸的南端，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_081"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有著全年氣候穩定，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "四季如夏讀島嶼。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳們是買下那樣的土地，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "展開度假村業務了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不愧是優妮博士，",
        "unit_id": 126811,
        "voice": "vo_adv_5140001_082"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大致上都對了。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "哎呀，",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_083"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "居然是南島！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "好像很有趣呢！",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_084"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "好像會有美好的邂逅在等著呢！",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_085"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以？",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_086"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "到頭來，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們會被帶去哪裡？",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "泰美斯銀嶺。",
        "unit_id": 126811,
        "voice": "vo_adv_5140001_087"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "根本超北邊的啊！",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_088"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_089"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真‧雪山！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "要在真‧雪山穿著泳裝！？",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_090"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "妳們的腦袋切嚕了呀！",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_091"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "在那種地方是要跟誰邂逅啊！？",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_092"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "\n那裡只會有用力把岩石丟過來的雪男吧！",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳們是算計好了吧，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_093"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡的切嚕丘利財團……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "又是打著「顛覆常識」為名目的愚蠢事業啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我好想詛咒就在前一刻天真地感到開心的自己。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "修女，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_094"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為了保險起見，我先問一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這場特別講座什麼的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們有拒絕的權利嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "當然有。",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_095"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "本校無論何時都會尊重學生的自主性唷？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "如果沒有意願參加，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n只會請妳們留在這裡，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "接受平時的課程。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "上課啊～",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_096"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "\n這個",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "也很讓人提不起勁呢……",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "尤其是",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_097"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "好朋友社的各位，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n還有根據學生會自治法所規定的",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "「自習」呢。",
        "unit_id": 3211
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "好朋友社",
        "words": "啊……",
        "unit_id": 1,
        "voice": "vo_adv_5140001_098"
    },
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘖，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_099"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所謂的「特赦」就是這麼一回事吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我瞭了。",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_100"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是牢房或雪山的二選一吧。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "實際上就只有一個選項吧！",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_101"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒已經徹底受夠牢獄生活了喔！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "好了各位，",
        "unit_id": 3211,
        "voice": "vo_adv_5140001_102"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "決定得如何？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "妳們可以自由選擇也沒有問題唷？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比起回到那個地獄，",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_103"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不管是要去向何處都只能前進了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "誰受得了成為什麼",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優秀的聖人君子啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "如果克蘿依同學她們要去的話，",
        "unit_id": 2911,
        "voice": "vo_adv_5140001_104"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友1",
        "words": "那我們也要去。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "我已經下定決心了，",
        "unit_id": 3111,
        "voice": "vo_adv_5140001_105"
    },
    {
        "type": "dialogue",
        "name": "克蘿依的朋友2",
        "words": "也讓我一起去吧。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "啊～說的也是。",
        "unit_id": 3011,
        "voice": "vo_adv_5140001_106"
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "\n",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "雖然搞不太懂現在的狀況，",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "美衣子",
        "words": "但交給好朋友社就行了。",
        "unit_id": 3011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳剛才說飛空艇停在中庭吧。",
        "unit_id": 111011,
        "voice": "vo_adv_5140001_107"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼秋乃，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請準備起錨。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那什麼寒冬的盛夏計畫，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然非我所願，但是就來被捲入其中吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉……",
        "unit_id": 110812,
        "voice": "vo_adv_5140001_108"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "到頭來還是會變成這樣啊。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這次會有什麼樣的爛劇情發展在等著我們呢。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為跟小墨丘利們扯上關係，",
        "unit_id": 110911,
        "voice": "vo_adv_5140001_109"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以最後大概會是爆炸結尾吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好了，",
        "unit_id": 126711,
        "voice": "vo_adv_5140001_110"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "聖德蕾莎女子學院的各位，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
