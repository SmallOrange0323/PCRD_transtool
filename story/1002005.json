        "voice": "vo_adv_1002005_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎騎、騎士先生！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……我、你對我的看法是……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……沒、沒事的什麼都沒有！",
        "unit_id": 100211,
        "voice": "vo_adv_1002005_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是不好意思！剛才的事請忘記吧！",
