    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（不行呀～……",
        "unit_id": 100211,
        "voice": "vo_adv_1002005_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "緊張到想說的話都說不出口～！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
