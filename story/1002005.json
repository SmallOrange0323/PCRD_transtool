        "voice": "vo_adv_1002005_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、對了！就請你喝我上次買到的美味好茶來當作謝禮吧！",
