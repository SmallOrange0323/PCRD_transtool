        "voice": "vo_adv_1002005_031"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……騎、騎士先生。剛才那件事……謝、謝謝！",
