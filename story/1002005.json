    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（弄，弄錯了～！",
        "unit_id": 100211,
        "voice": "vo_adv_1002005_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這裡不是販賣魔法書的書店……！）",
