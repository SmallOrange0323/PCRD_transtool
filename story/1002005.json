    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我得努力學習，讓自己能使用各式各樣的魔法才行呢……）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
