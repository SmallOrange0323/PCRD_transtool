    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚嗚……真是害羞到讓人想趕快逃離這裡呢……）",
