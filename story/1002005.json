        "voice": "vo_adv_1002005_023"
    },
    {
        "type": "dialogue",
        "name": "店員２",
        "words": "今天在這一帶的店，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "店員２",
        "words": "\n情侶檔購物的話會打折喔。",
