        "voice": "vo_adv_1002005_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯、嗯！",
        "unit_id": 100211,
        "voice": "vo_adv_1002005_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的沒錯呢！啊哈哈……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（難道……就算在剛才那位店員以外的其他路人眼裡，",
        "unit_id": 100211,
        "voice": "vo_adv_1002005_034"
    },
