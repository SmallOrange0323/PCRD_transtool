        "type": "dialogue",
        "name": "優衣",
        "words": "\n我們兩人，也像是一對情侶嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（這是表示我們的情誼已經如此融洽的意思嗎！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002005_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我喜歡……騎士先生。",
        "unit_id": 100211
