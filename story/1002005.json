    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想應該沒有這回事的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "店員２",
        "words": "是嗎？那把它賣給其他人也沒問題囉？",
