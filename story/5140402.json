    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依，",
        "unit_id": 111011,
        "voice": "vo_adv_5140402_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在不是像主角一樣說明狀況的時候了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們終於跨越了障礙，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "趕快來進行計畫吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "說的也是。",
        "unit_id": 110911,
        "voice": "vo_adv_5140402_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n都到這裡來了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n富美惠學姐和綠之監視員小姐也不在吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼～",
        "unit_id": 110812,
        "voice": "vo_adv_5140402_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒有人來攪局真是太棒了。",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼總之，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就趁要顧慮的人不在時完美收場吧～！",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可喜可賀、可喜可賀！",
