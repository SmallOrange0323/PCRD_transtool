    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然我們好不容易",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "才搭上飛空艇回到這裡，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n但富美惠學姐那傢伙，",
        "unit_id": 110812
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不管被打倒幾次，",
