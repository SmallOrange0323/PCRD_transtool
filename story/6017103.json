        "voice": "vo_adv_6017103_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這個答案應該最接近實際的情況。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這不是你自己講的嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "怎麼一臉驚訝？",
