        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n啊，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為我沒有毛茸茸的？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "要不要摸摸看我的頭髮？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "看起來是很可愛沒錯，",
        "unit_id": 109911,
        "voice": "vo_adv_6017103_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過帕克是精靈喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真要說的話，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "應該算監護人吧。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "當然，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克是我的監護人喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵，",
        "unit_id": 109911,
        "voice": "vo_adv_6017103_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雖然我們關係的確很親密。",
        "unit_id": 109911
    },
