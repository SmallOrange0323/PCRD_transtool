[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "任務を終えた帰り道。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nノウェムはため息交じりに呟きを漏らす。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ほんっと",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "人使い荒いよなぁ",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "アイツら。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "どしたの急に。",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_001"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nストレス溜まった顔しちゃって。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "七冠の連中だよ。",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_002"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nちょっとアタシたちをこき使いすぎだと思わないか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それは仕方ないでしょ。",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_003"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクらはそういう役回りなんだからさー",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "それがアタシたちの仕事だってのは分かってるけどさ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nそれでもこう、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "時々無性に暴れたくなるんだよ～！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "仕方ないなぁ。",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_005"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "愚痴くらいなら聞いてあげるよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n具体的に誰が気に入らないわけ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そうだな～",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_006"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n特にひどいのは……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ク",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "リスティーナだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ほうほう。",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_007"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nそれはまたどうして。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "すぐに怒鳴るしさー、",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_008"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "人を囮に使うしさー、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "この間なんて、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n退屈だから",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "その辺のモンスター全部倒してこい！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "とか言い出すしさー",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "なるほどねー",
        "unit_id": 106211,
        "voice": "vo_adv_5110604_009"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "……うん、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それでそれで？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "口を開けば",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_010"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "「さっさと動け！」",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "とか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nちょっと失敗すると",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "「お仕置きが必要なようだな？」",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "とか、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "見た目まんま、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "やたらと圧が強いんだよなー",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ふむふむ。",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_011"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nもっと言っていいぞ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "おう、",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_012"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いくらでも出てくるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nっていうかどうしたんだよオクトー",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nなんだか今日は",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "いつもより聞き上手だな？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……だろう？",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_013"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "……な？",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_014"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ヤツならもういないぞ。",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_015"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "面白い講座の特等席を快くワタシに譲ってくれたよ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……さぁ、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "続きを話すがいい。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "いくらでも出てくるんだろう？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "クッ、",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_016"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "クリスティーナ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n待ってくれ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "これは誤解なんだ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "っていうか",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "どこから聞いてたんだ！？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "「ほんっと人使い荒いよなぁ",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_017"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "アイツら」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "初めっからだな！",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_018"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "どうした、",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_019"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "なにを挙動不審になっている。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "「特にひどい」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "クリスティーナさんが聞き上手に徹してやっているんだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "遠慮なく話すがいいよ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……話せ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "圧っ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_020"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "この圧なんだよ～！　",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "ふっふっふっふっふ。",
        "unit_id": 107111,
        "voice": "vo_adv_5110604_021"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\nいや、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "退屈しのぎの散歩も悪くないものだ。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "こんな愉しい瞬間に出くわせるのだからな！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オ",
        "unit_id": 106114,
        "voice": "vo_adv_5110604_022"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "クトー！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n覚えてろよおおおおおおおおおおお！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ノウェムがクリスティーナに解放されるのは、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nそれから数時間後のことであった。"
    }
]