    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有生以來第一次打雪仗，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真的很好玩呢♪",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊，",
        "unit_id": 114411,
        "voice": "vo_adv_6054106_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣一來",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我的社會經驗又增加了一項！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要不要下次組成打雪仗的隊伍，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來舉辦打雪仗大會呢？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "到時候，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也務必要請你幫忙我舉辦活動囉♪",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我也沒想到",
        "unit_id": 114411,
        "voice": "vo_adv_6054106_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我居然會熱衷到這個地步！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "起初我還不太會打雪仗，一直很焦急，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但多虧有你靈機一動，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在對我來說已經成為美好的回憶了！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒想到",
        "unit_id": 114411,
        "voice": "vo_adv_6054106_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "居然會受你邀約……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算有再怎麼充滿魅力的生意，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還是與你的約定最讓我高興。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "今後我們也一起創造許多回憶吧！",
        "unit_id": 114411
    }
]