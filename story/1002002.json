    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──發生過這樣的事情呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從那以後，他就陪我修行了好幾次。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來如此呀……",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣……妳呀，喜歡上了那傢伙吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喜、喜喜喜！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生才、才不是我喜歡的對象……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "比起這件事，還是專心挑選食材吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "吶！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我知道啦。真是拿妳沒辦法。",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說優衣，站在那邊的人，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不就是那傢伙嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是的……真琴妳呀，",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就打算這樣嘲弄我……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊咧？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你、你好呢！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n天氣真好呢！你、你在做什麼呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂……",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳整個人也變得太僵硬了",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原來騎士先生你打算去吃午飯呀。",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這樣呀……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我說優衣。",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "機會難得，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳就試試也邀請那傢伙一起吃午飯吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "欸欸欸欸！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不、不行啦……！我還沒有心理準備……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒、",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒什麼事！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我、我們也差不多該走了呢！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我們就告辭了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生。",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，如果你方便的話……可以一起吃頓午飯嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "材料的話剛好現在正在採買，",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n而且吃飯的話大家一起吃會更好吃……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你覺得……如何呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可以嗎……？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那得快點去採購才行呢！",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……真是太好啦，優衣。",
        "unit_id": 104311
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我回來了～。",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生你請坐吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n料理會由我和真琴來製做的。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就是這樣，所以你乖乖的等吧。",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我說優衣。雖然我知道妳喜歡那傢伙，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但契機是什麼啊？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……妳可別反應得太大聲嚷嚷喔？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "其實──",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "──妳說那傢伙可能是經常在夢中出現的騎士先生？",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣啊……雖然之前有聽妳說了，所以不難理解如果",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那樣的傢伙出現了，妳會採取這樣的態度……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好！這裡就由我為了青梅竹馬的妳，幫妳一把吧！",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "糟啦，我忘了工作上還有些事沒做啊！",
        "unit_id": 104311,
        "voice": "vo_adv_1002002_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我出門一趟，那午飯就交給你們兩人處理囉！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我馬上回來！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這麼突然……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……真的離開了呀",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒、沒問題的！",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "料理我自己一人也做得來，請不用擔心。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "首先得把材料準備好才是……",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不用了，你坐著就可以了呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那我還、還是拜托你好了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊咧！？為什麼你在我後面！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n明明直到剛才還是坐著的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呀啊！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚……不……",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不會痛？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n啊咧……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎騎騎、騎士先生！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_028"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n為、為為為為什麼！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（為什麼我、我會被騎士先生抱著呢！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被這麼近距離緊盯著看的話，我……！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我……我我我我我……！",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起！！",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_031"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（啊啊……",
        "unit_id": 100211,
        "voice": "vo_adv_1002002_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n難得真琴為我製造了二人獨處的機會……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我真是大笨蛋！）",
        "unit_id": 100211
    }
]