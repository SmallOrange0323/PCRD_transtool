    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼了？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛上的課有不懂的地方嗎？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個……",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的確是我的生日……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n難道說這個，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是要送我的生日禮物嗎？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……呵呵。",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你記得我的生日。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不可以帶跟讀書無關的東西來哦。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個就由老師先幫你保管。",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n放學後，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "記得到老師這裡來。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "──我在屋頂上等你。",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_004"
    },
    {
        "type": "background",
        "background": "510181"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對不起。",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n做了這種拐彎抹角的事。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只是，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為走廊上還有其他學生在看著……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對吧？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來。",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "按照約定，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個禮物還給你。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "然後……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為已經放學了。",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能再來一次嗎？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你……♪",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101832,
        "voice": "vo_adv_4010195_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在學校的屋頂做這種事。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n感覺心臟跳得好快♪",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是真的哦。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來聽聽看嗎……？",
        "unit_id": 101832
    }
]