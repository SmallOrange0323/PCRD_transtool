[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011,
        "voice": "vo_adv_9048155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無論走到哪都是沙子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "半點樂子也沒有。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唉呀，",
        "unit_id": 106411,
        "voice": "vo_adv_9048155_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟是沙漠嘛。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才沒有那種事！",
        "unit_id": 105811,
        "voice": "vo_adv_9048155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算到處都是沙漠，肯定也會有快樂的事情……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣如何！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此……",
        "unit_id": 105911,
        "voice": "vo_adv_9048155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是沙浴嗎。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "喔，",
        "unit_id": 106411,
        "voice": "vo_adv_9048155_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "居然是埋在沙子裡，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來還有這種浴池呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "連疲勞",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都能消除。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺就像是泡在海裡一樣，很快樂呢☆",
        "unit_id": 105811,
        "voice": "vo_adv_9048155_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下放鬆了不少。",
        "unit_id": 105911,
        "voice": "vo_adv_9048155_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不愧是貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 106011,
        "voice": "vo_adv_9048155_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們怎麼只有自己一下子就離開沙子啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也快點拉我出去啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～",
        "unit_id": 105811,
        "voice": "vo_adv_9048155_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行啦～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟小凱留特別累啊。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n貓咪都喜歡溫暖的地方，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以這種時候",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請埋在沙裡",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好休息吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個不叫溫暖，是叫熱！",
        "unit_id": 106011,
        "voice": "vo_adv_9048155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總之快拉我出去！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不然我宰了妳喔！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個聲音是……？",
        "unit_id": 105911,
        "voice": "vo_adv_9048155_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "糟糕！",
        "unit_id": 106411,
        "voice": "vo_adv_9048155_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有魔物！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～",
        "unit_id": 105811,
        "voice": "vo_adv_9048155_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就以【美食殿堂】全體人員",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "進行迎擊吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂……",
        "unit_id": 106011,
        "voice": "vo_adv_9048155_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼偏偏要挑這種時候──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n埋在沙裡是要怎樣戰鬥啦──！？",
        "unit_id": 106011
    }
]