[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "海で泳ぎ楽しむのはよいが、",
        "unit_id": 113211,
        "voice": "vo_adv_6044301_000"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そればかりではいかんぞ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "熾炎戦鬼煉獄血盟暗黒団として、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "他にも成すべきことはあるはず。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "さぁシグルド、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "答えよ──",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "我らがこの海で楽しむべきことを！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "なるほど、",
        "unit_id": 113211,
        "voice": "vo_adv_6044301_001"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "熾炎戦鬼煉獄血盟暗黒団の従者を探すのだな！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nこの真夏の陽光を浴びたヤドカリだ、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "さぞ力を蓄えているであろう。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "どちらが大きい従者を得られるか",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "競争だ！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "行くぞーっ！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ほほう、",
        "unit_id": 113211,
        "voice": "vo_adv_6044301_002"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "我らの城を",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "この海辺に作り上げるということか！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "その意気やよし。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "では魔法を使い、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "本格的な城塞を築こう！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "だが",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "その前にデザインを確認すべきだな、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "こういう見た目で～――",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "何を言ってるのだぁ！　",
        "unit_id": 113211,
        "voice": "vo_adv_6044301_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "貴様、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "常夏のエネルギーを放棄するのか！？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n閃光のシグルドともあろうものが、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そんな体たらくでどうする！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ええい、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "休むのは後にしろ！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "私についてこい！",
        "unit_id": 113211
    }
]