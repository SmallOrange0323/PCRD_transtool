[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚嗚……",
        "unit_id": 112011,
        "voice": "vo_adv_5056323_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也到極限了……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是……！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只差一點點，",
        "unit_id": 111811,
        "voice": "vo_adv_5056323_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就快了……！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的！",
        "unit_id": 111911,
        "voice": "vo_adv_5056323_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即將分出高下了……！",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……！",
        "unit_id": 6411,
        "voice": "vo_adv_5056323_003"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "小兄弟和小姑娘們都繃緊了神經……",
        "unit_id": 6411,
        "voice": "vo_adv_5056323_004"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n鎮上那幫漁夫",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "也全都在作戰……！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "是啊，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這種情況下我怎麼可能放棄呢……！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "要上啦，",
        "unit_id": 6411,
        "voice": "vo_adv_5056323_005"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "各位！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n這是最後的大決戰了！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 112011,
        "voice": "vo_adv_5056323_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n和正大叔……！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……為了小鎮、",
        "unit_id": 111911,
        "voice": "vo_adv_5056323_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了大間的人們……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和正先生的這份心意，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人也會陪著您",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到您達成心願的！",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "交給我吧，",
        "unit_id": 111811,
        "voice": "vo_adv_5056323_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和正先生！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我絕對會把牠釣上來的！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "嘿……",
        "unit_id": 6411,
        "voice": "vo_adv_5056323_009"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n你們真是一群",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "可靠的弟子啊。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "好啦──",
        "unit_id": 6411,
        "voice": "vo_adv_5056323_010"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "做個了結吧！！",
        "unit_id": 6411
    }
]