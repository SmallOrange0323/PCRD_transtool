    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那個弓箭",
        "unit_id": 113712,
        "voice": "vo_adv_6048108_000"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "非常強啊……！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我們",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "能夠制止它嗎……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那個自信心是從哪裡來的啊……",
        "unit_id": 113712,
        "voice": "vo_adv_6048108_001"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "被你這樣一講，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不知道為什麼就感覺能成功制止它呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n既然你誇下海口那就拜託你了喔！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這、",
        "unit_id": 113712,
        "voice": "vo_adv_6048108_002"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這不是理所當然的嗎？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "事到如今你要是說要逃跑我可饒不了你哦！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "走吧！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "趕快制止它的失控，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "差不多該結束這場騷動了呢！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "……你這種耿直到犯傻的個性，",
        "unit_id": 113712,
        "voice": "vo_adv_6048108_003"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "讓人有點羨慕呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗯，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我非常害怕……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不可思議的是我完全沒有想逃走的意思。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n大概",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "是因為我不是一個人吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我相信你喔。",
        "unit_id": 113712
    }
]