[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "蘭法小姐。",
        "unit_id": 126311,
        "voice": "vo_adv_5120080_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然我知道她過去做了很多事情，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是在美的面前",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n一切罪過",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都是無力的……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該不能這樣說吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過她那輕透而虛無縹緲的氛圍，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "確實不是能輕易模仿的呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽說她是無人能媲美的歌姬，",
        "unit_id": 126311,
        "voice": "vo_adv_5120080_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了將我的美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "傳達給全世界的人們，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n希望她能為了我吟唱頌歌。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗的我，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "被美麗的歌聲給讚頌著。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這真是個超棒的主意啊……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "希望有天能拜託她看看呢♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美空小姐的臉上",
        "unit_id": 126311,
        "voice": "vo_adv_5120080_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然看起來總是掛著明朗的笑容……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是在那深處",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n似乎隱藏著什麼呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果能夠窺視她的內心，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是不是可以找到",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n存在其中的美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是個高難度的美啊！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 126311,
        "voice": "vo_adv_5120080_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒想到居然會有連我都無法看穿的美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然很不甘心……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是關於這件事，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似乎是我輸了呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "難道說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她有著",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只有你知道的一面嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然涅婭小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120080_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的方向性跟我不同，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我覺得她",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n對美有著相當的堅持呢～",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我感覺她知道要怎麼展現",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n自身魅力的方法。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我說中了嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是",
        "unit_id": 126311,
        "voice": "vo_adv_5120080_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得她對於比自己年紀小的男孩子，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所展開的攻勢有點太激烈了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n稍微冷靜一點會比較好吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過話說回來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她頭上那個",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n有彈性的黃色東西是什麼呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺我好像有在哪裡看過啊……",
        "unit_id": 126311
    }
]