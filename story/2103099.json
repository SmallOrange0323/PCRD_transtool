[
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過了幾天後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾宮殿──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈☆\n{player}！",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒想到",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你會特地來這邊見我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我真的非常",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常開心呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "努力把工作做完都值得了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的♪",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n託你的福，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我已經完全康復了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且純小姐",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也回歸到警備的工作行列中了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也……",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "復原到原本的樣子了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這真的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的是太好了♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然嬰兒版本的你，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也非常可愛就是了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但能像這樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好地與你對話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的很高興♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽我說。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "機會難得，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且現在也沒有人看到……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我有一件小事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要拜託你……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然不是……",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……但或許，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這回事也說不定。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "210309901"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正餓得咕嚕咕嚕叫呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但不是身體上的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而是心靈上的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……抱抱、",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱抱……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯～嗯……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n光是這樣做，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺就非常滿足了呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只有你，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並非是把我視為一名公主……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而是單純當成一位女孩子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是唯一願意這樣看待我的男孩子……♪",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不久之前，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以為只要打倒了霸瞳皇帝，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一切就能夠回歸正軌，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並且能夠重回那幸福的時光了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而……",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "逝去的時光，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是無法重來的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算霸瞳皇帝已經不在了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這一切也不會像魔法一樣",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n完全恢復成原樣呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然這本來就是理所當然的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "父皇與母后",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "依舊沒有醒來……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而我身為蘭德索爾的公主，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得扛起治理這國家的責任。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王宮裡的人們，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "儘管大家幾乎都是很好的人……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但其中還是有一些些人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並非是如此。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也有不是為了國家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而是為了自己",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而工作的人們……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我得向留意叮嚀各式各樣的人，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "時而下達指示，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還得和文件大眼瞪小眼。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甚至有時……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得讓士兵們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n賭上他們的性命去戰鬥。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……這真的很困難。",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算不使用皇家裝備，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但坐在這張椅子上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每天感覺都像是在戰鬥一樣……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而我的心靈，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也因此餓得扁扁的了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算受到了{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有大家非常多的幫助……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最後終於打倒霸瞳皇帝了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而還是無法……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "恢復到",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像以前那樣",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幸福快樂的日子呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是我希望你不要誤會了唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然沒辦法恢復到原樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我現在也覺得這樣就好。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "霸瞳皇帝，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是為了自己一個人的幸福，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才會支配這個國家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這件事是無庸置疑的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算真因為某個強大的力量，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓所有事情都恢復了原樣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若因此",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我和【美食殿堂】的大家……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和{player}的那些幸福的記憶，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n全都因此重置了的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可沒辦法接受呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說……",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會以公主的身分，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再更努力下去的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這也是為了",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "將我養育成人的這個國家……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "成為一名更可靠的公主才行……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我在說什麼呀……",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真不好意思。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n盡說些喪氣話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且還都是我一個人自顧自地在講呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也想",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽聽你的事。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟好不容易，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又可以像這樣和你正常地說上話了嘛。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_2103099_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你回想起什麼了？",
        "unit_id": 105812
    }
]