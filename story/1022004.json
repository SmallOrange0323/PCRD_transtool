    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在玩依里帶來的\n各種遊戲。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸！無效化！？騙人！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚嗚～～～輸、輸了～～～～～～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你啊，明明沒有記憶，卻這麼會玩遊戲。",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不管是棋盤遊戲，還是卡片遊戲都很強……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過多虧有你我才能一起玩遊戲，我也很開心啦。",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……啊，不、不對！剛剛說的不算！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我也沒那麼開心，就只有一點點開心而已！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而、而且，現在還是我贏的比較多喔。",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "下一個要玩什麼遊戲？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……咦？",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、這個光是什麼！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你做了什麼嗎！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦……",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊啊啊！？",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天是遊戲展的開幕紀念特賣！",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "遊戲軟體、電腦周邊設備和攻略本……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呵呵。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n雖然很累，但也買到了很多好東西！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓你幫忙拿東西，真不好意思啊。",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "想買的東西太多了，我一個人拿不動……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你有空真是幫了大忙。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸……該怎麼說呢……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那、那個，總之謝謝你了！我有謝謝你囉！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那你覺得如何呢？",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天來買東西開心嗎？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，那個……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因為讓你一直陪我買東西，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n覺得有點過意不去……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……你買到了想買的東西？",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太好了。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你買了什麼呀？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……美、美少女遊戲！？",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你喜歡那種遊戲！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "給、",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "給我看看！欸……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「和女僕、護士、巫女、小魔女的後宮生活」！？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼、哼嗯～",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你喜歡這種類型的女孩子啊？",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……因為包裝很大盒卻超便宜所以就買了？",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這、",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣啊！太好了～",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、你的喜好是什麼，我才一點都不在意就是了！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也有那本書耶！",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你說一聲的話，我就借你了……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說回來，這本書是和你爭論之後，",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還向你借錢買的……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚嗚……又回想起丟臉的回憶了……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過呢，我原本鎖定的目標也",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n全都買到了，非常滿意。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "得趕快回家玩遊戲才行呢！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊～好期待～！",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n今晚要熬夜徹底地破關！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不過這次買的遊戲，",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n比起一個人玩的RPG，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n兩個人對戰的遊戲還比較多……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也對！",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "既然都拜託你陪我去購物了，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n接下來也一起玩遊戲……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……嗯？",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊！不、不！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n等、等一下！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然我剛剛隨口就講了出來，",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但那是很大膽的話吧……",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我竟然說什麼……男女在一起熬夜……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚嗚……！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、不行～～～！一起玩遊戲，不行～～～！",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總、",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總之今天我先回去了！",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，欸……那個……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我、我還是要好好向你說一聲。",
        "unit_id": 102232
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個……今天，你來陪我……",
        "unit_id": 102232,
        "voice": "vo_adv_1022004_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n真的很謝……謝……",
        "unit_id": 102232
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！",
        "unit_id": 190011,
        "voice": "vo_adv_1022004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你做了個好「夢」嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和依里的「記憶碎片」",
        "unit_id": 190011,
        "voice": "vo_adv_1022004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的「夢」唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很懷念嗎？嗯，還不清楚啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1022004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的「夢」做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1022004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1022004_036"
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯……",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我剛剛該不會是睡著了吧……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "竟然在玩卡片遊戲時睡著……",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n而且還作了奇怪的夢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說回來，夢裡面好像也講到遊戲……",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但是那個遊戲是什麼呀……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸……？你也做了一樣的夢？",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有這麼巧的事情啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，現在不是討論夢境，",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n也不是睡覺的時候了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你看，",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_042"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還有那麼多想玩的遊戲，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天你要陪我玩到早上喔。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……咦？",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_043"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n總覺得我在夢裡頭，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n好像也說了類似的話……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_044"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、不是那樣的喔！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n雖然我說陪我到早上，但絕對沒有奇怪的意思喔！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要想歪成那種不知羞恥的事！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……好、",
        "unit_id": 102211,
        "voice": "vo_adv_1022004_045"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好啦！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n趕快繼續玩遊戲了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和用生氣掩飾害羞的依里，\n又重新開始玩遊戲了。"
