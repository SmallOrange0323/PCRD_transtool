    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "やったッス！　",
        "unit_id": 123911,
        "voice": "vo_adv_5104442_000"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "自分たちの大勝利ッスよ！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "敵の切り札も打ち止め……",
        "unit_id": 123811,
        "voice": "vo_adv_5104442_001"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "というところか。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\nこれで和平活動の支障はすべて排除した。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "さあ、",
        "unit_id": 123811,
        "voice": "vo_adv_5104442_002"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "早く撤収して祝杯を挙げるぞ。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n思う存分に飲み、",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "そして食らうがいいよ。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "今日は特別にワタシがおごってやる。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "本当ッスか？　",
        "unit_id": 123911,
        "voice": "vo_adv_5104442_003"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "よかったッス！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "自分、",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "もうおなかペコペコッスよ～",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "なに、",
        "unit_id": 123811,
        "voice": "vo_adv_5104442_004"
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "部下の功労に報いるのもワタシの仕事だからな。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "明日からはまた頑張ってもらうことになるが……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "フッ、",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "今日くらいは",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "クリスティーナ",
        "words": "ゆっくりしてもバチは当たらんだろうさ。",
        "unit_id": 123811
    }
]