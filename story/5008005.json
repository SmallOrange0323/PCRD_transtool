    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "您醒了呢。",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓人這麼擔心……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這裡",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是我們所搭乘的馬車。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們在{player}大人倒下的洞窟附近的村子，",
        "unit_id": 102711,
        "voice": "vo_adv_5008005_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n和流夏她們會合的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是的，",
        "unit_id": 102711,
        "voice": "vo_adv_5008005_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "正如您所見。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我是只屬於{player}大人的惠理子。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯嗯，",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "早安。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "醒來的感覺如何啊？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真的太好了……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們收到七七香的通訊魔法得知有狀況發生，",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n急忙趕了過來……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n見到你失去意識時，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可是讓我驚慌失措了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也是……",
        "unit_id": 102711,
        "voice": "vo_adv_5008005_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然後，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當{player}大人",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n陷入這樣的困境卻沒能陪在您身邊，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n讓我打從心底的詛咒自己……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "怎麼了呢。　",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "突然東張西望的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其他人都在外面警戒",
        "unit_id": 102711,
        "voice": "vo_adv_5008005_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和整理情報。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果能動的話，",
        "unit_id": 105111,
        "voice": "vo_adv_5008005_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就讓她們看看你吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "尤其是杏奈，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她似乎感到很自責呢。",
        "unit_id": 105111
    },
