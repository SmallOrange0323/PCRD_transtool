        "voice": "vo_adv_5008005_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚嗚嗚……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "太好了、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "太好了啊！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n要是吉格魯特有什麼萬一，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚嗚、嗚嗚。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……咦？　",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你說抱歉給我添麻煩了……？",
