    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你到底在說些什麼啊！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "添麻煩的人是我才對吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "多虧有吉格魯特保護我，",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n彼此才能像這樣子脫離險境……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感覺簡直",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就像是欠了你一輩子的人情啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……吶，",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我發誓",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "再也不會讓你遭遇危險了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所以，",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "今後也能請你和我共同行動嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "謝、",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "謝謝你{player}……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "謝謝你！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你果然是",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我所認同的\n熾炎戰鬼煉獄血盟暗黑團的第二連隊長，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "閃光的吉格魯特！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008005_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "{player}！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太好了呢。　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我好擔心你！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "{player}……",
        "unit_id": 105611,
        "voice": "vo_adv_5008005_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你醒來了啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不需要道謝。",
        "unit_id": 105611,
        "voice": "vo_adv_5008005_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "{player}也不是想被感謝，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n才保護杏奈的吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然",
        "unit_id": 101311,
        "voice": "vo_adv_5008005_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉拚命地",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n保護{player}並逃離洞窟，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也不是因為想要被感謝對吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抱歉……",
        "unit_id": 101311,
        "voice": "vo_adv_5008005_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為了保護我，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "吉格魯特他……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n把他、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "帶到……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "安全的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "地方――",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃唔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚～！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008005_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個時候的杏奈美眉是真正的英雄喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "簡直到讓人想特別製作插畫的等級了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳、",
        "unit_id": 100911,
        "voice": "vo_adv_5008005_032"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳到底在說些什麼，七七香！？　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "別在那開玩笑了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我可是很拚命的耶！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯，",
        "unit_id": 101311,
        "voice": "vo_adv_5008005_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我知道啊。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想著非保護{player}不可，\n而努力的杏奈美眉，",
        "unit_id": 101311,
