        "voice": "vo_adv_1309002_003"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "對不起，像我這種無能兔子",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
