    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "我就先說給你聽看看……",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "可以嗎？",
        "unit_id": 130912
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "……我明白了。",
