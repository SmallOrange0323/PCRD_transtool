[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然叫我",
        "unit_id": 107111,
        "voice": "vo_adv_6104201_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "去進行和平活動，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然由我自己說這話很奇怪，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但這應該是選錯人了吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不曉得團長和公主殿下",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底在想什麼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼輕易就來依靠我，我會很困擾的。",
        "unit_id": 107111,
        "voice": "vo_adv_6104201_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可絲毫不打算以正義的夥伴自居，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跟你們站在同一陣線，\n也純粹是因為利害一致。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是你們誤解可就讓我傷腦筋了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，",
        "unit_id": 107111,
        "voice": "vo_adv_6104201_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你似乎比想像中更了解我啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比起愛、羈絆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這些彷彿像在依賴他人般的輕浮字眼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n締結契約相較起來還更值得信賴。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對大人而言尤其如此。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別擅自把人當成危險藥品。",
        "unit_id": 107111,
        "voice": "vo_adv_6104201_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這張嘴說出如此惡毒的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是不是該永遠堵住比較好呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己也很清楚，我至今的所作所為很難否定這句話。",
        "unit_id": 107111
    }
]