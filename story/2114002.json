        "type": "dialogue",
        "name": "怜",
        "words": "\n像這樣",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "將錯就錯下去。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣的話……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──怜！",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n怜～！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和……？",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n已經",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到蘭德索爾了嗎……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還沒。",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n還要再一會兒……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我看妳",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像睡得很不安穩。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一到達蘭德索爾",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可能就要開戰了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以事先在城鎮外",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跟騎士先生他們",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會合比較好。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我記得",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之前是這麼說好的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊……",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝妳。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n剛才做了個",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "奇怪的夢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有一件我刻意想要忽略的事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻被我自己給指正出來了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……還是說，",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n剛才那",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "其實是「再構築」前的我的聲音……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳是說……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和。",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n優衣不在，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個時候說這個……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可能有點卑鄙……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔、",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但我實在很想",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說給妳聽。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為妳跟我一樣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是那個時候",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有被選上的人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊……",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不論是優衣的願望被扭曲，",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "進而引發「禁錮」的事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還是過去跟我們一同冒險的「他」",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已不復存在這件事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都相當令人痛心……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且不光是優衣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也難辭其咎。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是……",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n坦白說……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我其實",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很羨慕優衣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即使那麼做",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會讓世界陷入扭曲……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並遭受苦難。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且……",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當時只不過恰巧",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我們三個人在場罷了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會不會其實",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他真正想要選擇的另有其人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n會不會「再構築」後的他",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會有不一樣的答案、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……唉，",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我真是糟透了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n之前明明說過",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "「無論選擇誰都不會有怨言」的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳可以鄙視我沒關係。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "儘管想把優衣",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從痛苦中解救出來的想法……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並不是虛假的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但我覺得自己試圖導正當前世界的扭曲這種行為",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "簡直……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像是要否定掉",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣被選上的可能性一樣……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜……",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……抱歉。",
        "unit_id": 100311,
        "voice": "vo_adv_2114002_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明一場大戰在即，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我卻說出這種莫名其妙的話。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳跟我不一樣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該不會這樣胡思亂想……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_049"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實我也一樣……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我只是沒有妳",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼善於表達而已。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也覺得心頭",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "亂糟糟的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明總想著要幫助",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但我卻沒辦法",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "解決自己的煩悶……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_051"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是漫畫或",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "戲劇裡的主角，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會幫助所有有困難的人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "打飛所有壞蛋……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n最後願望肯定也會實現，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來個圓滿大結局。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但……",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_052"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現實肯定",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有那麼好的事。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家都是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "自己人生的主角，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n都有屬於自己的",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "寶貴願望……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_2114002_053"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我好像",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說了些很不像我會說的話！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
