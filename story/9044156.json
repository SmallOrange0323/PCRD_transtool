[
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 105911,
        "voice": "vo_adv_9044156_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "擊退魔物了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牠往洞窟深處逃走了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是千鈞一髮～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肚子都餓得咕嚕咕嚕叫了啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為對方是個蠻強的敵人嘛。",
        "unit_id": 105811,
        "voice": "vo_adv_9044156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家能夠平安無事都沒有受傷，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許就是賺到了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子也都餓了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要回去了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是啊……",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最後還是沒有獲得寶石，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是很累的結束了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成為億萬富翁的夢想啊……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105811,
        "voice": "vo_adv_9044156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留悶悶不樂的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105811,
        "voice": "vo_adv_9044156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看這個！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有寶石碎片掉在這裡呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是戰鬥時削下來的",
        "unit_id": 105911,
        "voice": "vo_adv_9044156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物身體一部分嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然不大，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這一小塊應該也足夠有價值了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算只是這樣一塊碎片，也貴到不行了吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們卻放棄了那麼大塊的寶石，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是太可惜了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稍微休息一下也好，",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n再一次",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "與那個魔物戰鬥吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "寶山就在眼前了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能回去呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難得都來到這麼裡面了，",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回去也很麻煩對吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "經歷了很多冒險，變得很強了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一定沒問題的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許正如凱留小姐所說的，但……",
        "unit_id": 105911,
        "voice": "vo_adv_9044156_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只有三個人還是很令人擔心……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「只有三個人」……？",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我有個想法呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想法……",
        "unit_id": 105911,
        "voice": "vo_adv_9044156_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊，",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是最終絕招喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我現在就用通訊魔法聯絡花凜，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等我一下！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是有什麼祕計了吧！",
        "unit_id": 105811,
        "voice": "vo_adv_9044156_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不愧是小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真可靠☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不是當然的嘛！",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這點小事對我來說",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過就是小小菜一碟。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n交給我吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "順利結束後，",
        "unit_id": 106011,
        "voice": "vo_adv_9044156_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再與【美食殿堂】的大家一起享用美味佳餚……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我一定",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會想辦法成功的！",
        "unit_id": 106011
    }
]