[
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對了，碧讓我想起來。",
        "unit_id": 110811,
        "voice": "vo_adv_6023101_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你現在算是",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "暫時插班入學吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "感覺如何呢，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "在德蕾女高的生活？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有好好念書嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也是啦。",
        "unit_id": 110811,
        "voice": "vo_adv_6023101_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "畢竟父母辛苦讓你讀了好學校――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你的學費是誰付的？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n咦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你不知道？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你不知道啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_6023101_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也是啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們的課程",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "難度很高呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n老實說我也是，光是要跟上進度就已經吃不消了……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別說這個了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "多說無益。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啥？　",
        "unit_id": 110811,
        "voice": "vo_adv_6023101_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是怎樣？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那回答也太模糊了吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那種像政治家的說法，你是從哪學來的？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n應該有更應該學會的詞彙吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你給我認真點啊。",
        "unit_id": 110811
    }
]