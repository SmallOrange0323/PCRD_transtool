[
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是太好了呢，",
        "unit_id": 130811,
        "voice": "vo_adv_5144101_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏡華！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "他們竟然將這麼漂亮的服裝借給我們……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我現在就開始期待「鮮花祭」了♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那是在花朵盛開的村莊中所舉辦，",
        "unit_id": 130711,
        "voice": "vo_adv_5144101_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n祈求豐收的祭典……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對吧？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為我們是主辦單位方，",
        "unit_id": 130711,
        "voice": "vo_adv_5144101_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以得好好幫忙籌備祭典才行！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是啊！",
        "unit_id": 130811,
        "voice": "vo_adv_5144101_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只是，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也有件擔心的事……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳說擔心的事，",
        "unit_id": 130711,
        "voice": "vo_adv_5144101_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "鈴莓小姐感覺很可靠，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以我覺得沒問題的。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唔",
        "unit_id": 130811,
        "voice": "vo_adv_5144101_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "！？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n其實關於這點……",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說的對呢！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在開始之前，就擔心自己會不會冒失也是沒有用的嘛！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只要全心努力，",
        "unit_id": 130711,
        "voice": "vo_adv_5144101_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就一定沒問題的！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真要說的話，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我比較擔心",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n附近會有小偷跑進來……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、",
        "unit_id": 130811,
        "voice": "vo_adv_5144101_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那樣子很可怕呢。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果到了晚上，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳會怕小偷的話就告訴我吧。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們待在一起的這段期間，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我可以睡在妳的旁邊喔♪",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請別把我當作小孩子！",
        "unit_id": 130711,
        "voice": "vo_adv_5144101_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也不可以摸頭！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為我也能跟大人一樣",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好好幫忙的！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏡華，妳很有幹勁呢～",
        "unit_id": 130811,
        "voice": "vo_adv_5144101_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣的話，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也得讓大家看看",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我不是只有冒失的一面！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "盡我所能！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓、鏡華",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5144101_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓、鏡華",
        "words": "「花開季節的真心」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "502260"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "無論冬日有多麼漫長，",
        "unit_id": 130811,
        "voice": "vo_adv_5144101_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在春天都會綻放出花朵的♪",
        "unit_id": 130811
    }
]