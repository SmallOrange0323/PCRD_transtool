    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天的月光學院。\n{player}留下來接受伊緒的單獨教學。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對對。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就是這個樣子～",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "下一個問題的解法……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "糟糕！",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就是說呢，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這必須讓你自己去解開才行。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那裡的計算……",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "討厭～！",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你明明這麼努力，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是我卻不能教你～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這道光，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "之前也出現過好幾次……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀啊啊啊啊～～！！",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "510222"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有、",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有人在那裡嗎！？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你為什麼這種時間還在學校裡……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你該不會是忘了作業，又跑回來拿吧？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n會想要做功課是很棒，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但居然會忘在學校裡。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還沒有找到嗎？",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師也來幫你找吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿咻……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀啊！？",
        "unit_id": 101831
    },
    {
        "type": "still",
        "still": "101801101"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "痛痛痛……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "跌倒了～",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n太暗看不清楚椅子的位置～",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯、",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我沒事。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然這裡被我弄得一團亂，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但我並沒有像看起來得那麼痛。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是在批改考卷才留到最後，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n本來想說回去前巡邏一下……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真沒想到自己會把教室弄得這麼亂。",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明還有地方必須去確認的說～",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "510222"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "找到作業了嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了～！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我可以陪你一起走喔。",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼暗你應該會害怕吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒事嗎？　",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你可以一個人走在晚上全黑的校舍裡？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的沒事嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是喔……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那就好……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是喔……………",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……我是不太習慣黑的地方……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n明明是個老師，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個和那個是兩碼子事喔～",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我平時都是自己一個人喔。",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我已經是大人了嘛。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是真的喔。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天正好你也在嘛，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得有這機會……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "拜託你，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和我一起巡邏好嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我也有幫你找",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你忘記的東西對吧……？",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "510212"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "學校這麼大，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "巡邏起來要花很多時間，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但有你和我一起巡邏，就讓人放心多了～",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像這樣兩人單獨走在晚上的校舍裡，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就像探險一樣，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是興奮呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛才在教室裡發現人影的時候，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我真的以為心臟差點就要停掉了。　",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還在想該不會是可疑人物！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但我畢竟是個老師，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "必須想辦法才上前搭話的，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "發現是你以後，讓我鬆了口氣～",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在和你在一起，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就算真的有可疑人物，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也一定沒問題吧！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……啊！",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "才不是啦！",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你看，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天是滿月呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n可以再稍微陪我巡邏一下嗎？",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "510182"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對不起，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_034"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "巡邏到這裡就是最後了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖是這麼說，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還要確認頂樓有沒有鎖……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我喜歡的少女漫畫呀，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是部在頂樓上",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "邊眺望著滿月邊舉辦茶會的作品。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也很希望能和作品中一樣，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在滿月的夜裡像這樣到學校頂樓來看看。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "平時我……",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為很黑，所以都馬上就回去了，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但今天有你和我在一起，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我才能第一次來到這裡。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且頂樓的氛圍，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "比想像中還浪漫得多了！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要是有年輕的高中生們聚集在這種地方，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很有可能就會發展出各式各樣的戀情呢～！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "比如說",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "翹掉補習班，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "放學後像這樣聚集在頂樓，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在昏暗的月夜裡，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "仰賴著月光",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一起念書之類的……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "然後、然後！",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_040"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n凝視著彼此，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就像這樣……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呀――！",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我在讀女校的時候，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就一直很憧憬這種事，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不禁都興奮起來了！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能像這樣和男孩子獨處，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_042"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而且還能體驗像是喜歡的少女漫畫故事的劇情，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我又實現",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一個夢想了！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明老師才應該要協助學生實現夢想，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但卻都是你來幫我實現夢想呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也想",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "替你實現願望或夢想。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果我做得到，我什麼都會幫，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以儘管跟我說喔。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖是這麼說，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_045"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但我還是個菜鳥老師，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也不知道自己能做到什麼程度……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和我相比，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你明明還是個高中生，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "卻非常了不起呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能到這所學校任教，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_046"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我真的覺得太好了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為和你相遇了呀。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……那部我喜歡的漫畫呀，",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_047"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n作品中有為女主角實現願望的妖精登場，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n對我來說那位妖精",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "或許就是你呢。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今後",
        "unit_id": 101831,
        "voice": "vo_adv_1018011_048"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我的願望……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和我想嘗試看看的夢想，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也讓你",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來為我實現好了？",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1018011_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你被人叫成妖精，",
        "unit_id": 190011,
        "voice": "vo_adv_1018011_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺還挺有趣的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先不說這個了，",
        "unit_id": 190011,
        "voice": "vo_adv_1018011_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你明明都幫她實現這麼多學生時期沒完成的事情了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "伊緒真是的，對自己的感情很遲鈍呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "老師和學生的關係，",
        "unit_id": 190011,
        "voice": "vo_adv_1018011_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難度真的那麼高嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要再表現得更可靠一點，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到足以跨越那個障礙啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "伊緒就麻煩你囉，",
        "unit_id": 190011,
        "voice": "vo_adv_1018011_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妖精先生。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯、",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_054"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯嗯～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼啊啊～……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_055"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不知不覺睡著了……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……你也是？",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_056"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我們又一起睡著，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "然後做了相同的夢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這種事情居然發生了好幾次，真不可思議。",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_057"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一想到兩人能夠再次做相同的夢，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就覺得很開心。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_058"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "目前還正在小考中喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n得集中精神才行呀。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_059"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "題目已經全部做完了？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我看看……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_060"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n完全沒問題！　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你很厲害嘛！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n就特別給你",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "獎勵的小花吧！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "第一次見面時，",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_061"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你明明連讀寫都不太會呢……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n就照這步調",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "繼續學習各種知識吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……我也",
        "unit_id": 101811,
        "voice": "vo_adv_1018011_062"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "必須作為老師有所成長！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可不能輸給你呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會比之前還更嚴厲的，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要做好覺悟囉！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "後來，授課的難度突然急速地提高，\n引發了班級中劇烈的騷動。"
    }
]