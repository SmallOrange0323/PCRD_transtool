[
    {
        "type": "background",
        "background": "501040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "我一出現，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「我」就一副驚訝的樣子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看來「我」誤會了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "我，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不是敵人。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個模樣是……",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "普蕾西亞，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳退下。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯……",
        "unit_id": 135211,
        "voice": "vo_adv_5206005_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……不需要戒備。",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是協助者。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我一直都在看著，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "此行是要找她的父親吧？",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我來",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為妳實現願望──",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "咦──",
        "unit_id": 135211,
        "voice": "vo_adv_5206005_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "普蕾西亞……！？",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳把她帶到哪裡去了？",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "遷移到由記憶",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "編織的幻影裡了。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣一來，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就能專注於「我」自身的願望上了。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這次一定",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要實現。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「只有騎士先生和我的永恆世界」。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……妳，",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是誰……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "正如所見……",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n我是",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "「我」的夢之殘影。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "在戰鬥中落敗、快要消失時，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n「我」的留戀",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "就寄宿在「理想鄉」的殘骸中。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "這就是，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "我。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "難道──",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_011"
    },
    {
        "type": "background",
        "background": "501650"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但我……",
        "unit_id": 129014,
        "voice": "vo_adv_5206005_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "卻失敗了。",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我沒能，",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "創造出",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "理想鄉……",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n沒能，",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "讓騎士先生……",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "牽起",
        "unit_id": 129014
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我的手……",
        "unit_id": 129014
    },
    {
        "type": "background",
        "background": "501040"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不可能……",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n理想鄉，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "應該沒有完成啊……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "被隔絕的空間，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "這就是理想鄉。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n因為有我寄宿，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "它才能以未完成的殘骸形態，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n勉強繼續存在。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "但殘骸就是殘骸。",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "是因為再再構築的影響，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "被埋在海岸下，全都是錯誤的地帶。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……那麼，",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "阿賀斗紫布菜的影像",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是妳做的？",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就為了把我引誘至此。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "……是D型檢體和殘骸接觸引發的bug吧。",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "我剛剛也說了，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "因為有所損毀，錯誤很多。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "一切都是因為D型檢體擁有駭入米奈娃的紀錄，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n殘骸",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "誤認她為管理者，進而執行了她的願望……",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "即使想修復殘骸，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n沒有米奈娃之力的我也束手無策。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "不過，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "擁有殘渣的",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "「我」來了。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "所以，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "我花時間去調查了。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n然後得知，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "透過「我」持有的米奈娃的力量殘渣，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n殘骸已經開始稍稍穩定了。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "願望一開始只能在源自",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "D型檢體之力的範圍執行。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "但是，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "如今只要是位於海岸範圍的角色，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n就可以分析那種力量，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "並加以應用。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "也就是說，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "「我」擁有的力量",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "如今仍對這理想鄉有效。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n只要有「我」在，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "應當就能完整修復理想鄉……",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……是嗎。",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n果然，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "妳的目標是米奈娃的力量殘渣啊……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "所以──",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n我希望能將這裡的管理者權限，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "轉讓給",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "「我」。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n收下吧。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "什麼……？",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "我說過了吧，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "我就是「我」。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n是願望轉為闇影的存在。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "想要實現自己的心願。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "怎麼了？",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "一直很想實現的願望終於能夠實現了喔？",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 135011,
        "voice": "vo_adv_5206005_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "這都是「我」希望的，",
        "unit_id": 129021,
        "voice": "vo_adv_5206005_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n不必迷惘。",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "\n",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "只要完成修復，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
        "words": "這次和他一起創造出屬於兩人的理想鄉，",
        "unit_id": 129021
    },
    {
        "type": "dialogue",
        "name": "厄莉絲的闇影",
