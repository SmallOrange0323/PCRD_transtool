[
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔～呣。",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "誰也",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曾從『那邊』回來……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曾甦醒過來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那為何在下和晶小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會在『這邊』呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "別叫什麼晶小姐啦～",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "聽起來真不自在。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "放輕鬆點，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "叫聲姐姐來聽聽吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是晶小姐",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非在下的姐姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否拘謹過頭而失了禮數呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "沒關係唷～",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我本來就知道妳是這樣的孩子了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n妳可能已經不記得了就是，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但我可是替妳換過尿布的唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟妳的父親可是我的恩師呢，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以我從妳小時候就知道妳的事了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n妳剛出生那時可是引起大騷動了唷～，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "『棗 可蘿』醬。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為在突然間",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就冒出一個小孩了嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n大家一開始",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還懷疑妳是長老做的機器人、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n人工生命體……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "或是人造人之類的東西呢♪",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "棗 ",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可蘿……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下於",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『這邊』的名字嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯。",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "沒有什麼實感對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我也是被人家叫了模索路晶以後",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "完全是『哪位啊』的感覺。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n大概是因為，在那邊一直",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "都被大家用拉比林斯達這名字叫來叫去的吧～？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "順便請問一下，",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼會用拉比林斯達這個名字自稱呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為我",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在網路世界中也算很有名氣的呀。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果在網路遊戲用上本名總會被騷擾，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n為了避免這種事，才會用暱稱",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拉比林斯達。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但是為什麼會取這樣的名字呢……？",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "迷宮，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是來自其語源Labylinth這個還算記得。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊，是Crystal（水晶）啊，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也就是Labylinth Crystal的簡稱呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這事現在好像不是很重要呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "更重要的是。",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "成功在『這邊』取回意識的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n目前來看也就只有我們兩個而已……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我們是相當重要的存在，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以也被期待著能夠完成使命。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使命，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是指……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "簡單來說，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_014"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是當『那邊』與『這邊』之間的橋樑。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "現在，『那邊』的人們",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不知為何記憶全被封鎖住，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n因此將『這邊』的事全給忘了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以打算",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "要先將那些被隱藏起來的記憶全找回來。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "同時，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_016"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "將世界的真相傳達過去，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n讓人們在『那邊』也能為了回到原本的世界",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "盡一份力。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "為此也有必要在",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "『那邊』，讓擁有立場、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n信用與權力的某個人，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "將這個真相廣泛地傳達給大眾。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果不這樣的話，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家就會認為是在造謠而不願意相信嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "實際上，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_018"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這聽起來就像荒誕無稽的妄想嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但是，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_019"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我在『那邊』已經被當成恐怖份子了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也因為消耗了大量魔力的關係，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n光是要保住小命都得用盡全力呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_020"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "希望妳能夠來代替我做這些事。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而為此也投下了鉅款，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "並在反覆的錯誤與嘗試下，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n終於能讓妳在短時間內回到這邊的世界。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n只將心靈、",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "精神抽取出來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "讓妳寄宿到了這個人偶中呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過因為出了一點小差錯，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_022"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以才會讓妳走到了這種地方就是了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "原本是打算，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在被隔離起來的研究所之類的地方，再讓妳醒過來的……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "總而言之。",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_023"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "希望妳能在那個狀態下盡可能獲取情報，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n然後在『那邊』找個有聲望的人幫忙，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n將事實廣泛的宣傳出去。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "欸……",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算您對在下這麼說……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在『那邊』，不過就是個單純的小市民。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且已經演變成與王宮敵對，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "何時被通緝都不足以為奇的狀態了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若說立場，",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與拉比林斯達小姐並無太大的差異。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_026"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "妳和我之間有著一個決定性的差異。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n妳和那個世界中，擁有最高權力的人，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n和那名公主殿下結交了友誼唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "公主殿下……",
        "unit_id": 105913,
        "voice": "vo_adv_2010003_027"
    },
    {
        "type": "still",
        "still": "201000301"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就是貪吃佩可唷。",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_028"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n妳是她相當重要的夥伴，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果是妳說的話她一定會相信。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n儘管現在",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她的身分",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "被奪走了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不過一旦她取回了那份權威，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_029"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n就是位有資格能將真相",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "訴諸大眾的真正的公主殿下了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "只要她能奪回屬於她的地位，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_030"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就能讓所有人明白那個世界的真相。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "當然從現狀來看，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n要幫她奪回地位並不是件簡單的事情。",
        "unit_id": 106831
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而且也不是說只要讓『那邊』的人們了解了事實，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_031"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n就一定能順利的將問題全都解決嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "有可能會引起騷動，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_032"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "或是被當作搞笑，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "被人們一笑置之也說不定。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但是，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_033"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "風向應該是會改變才對。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我們對此抱持著期待。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟也不能就這樣，把人們永遠都留在那個夢境之中啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "把被囚禁在『那邊』的人們，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_034"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "全都帶回『這邊』。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n這是作為開發出米奈娃",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "與阿斯特朗傳奇的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我們『七冠』做為贖罪",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "的義務唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然把我們大人的責任，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_035"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "讓妳來背負實在是很過意不去。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但沒有其他能夠寄託的人了……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然我們",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "能像作弊一樣，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這樣子回到『這邊』。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但接下來我必須以『七冠』的身分，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_036"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n暫時在『這邊』",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到處東奔西跑。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "得盡可能讓『這邊』的、現實中所蔓延的騷動",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_037"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "穩定下來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n為此必須對相當多的問題來進行處理。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_038"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "才希望妳能來做那些事。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不對，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是除了妳以外沒有人辦得到了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "要將精神從『那邊』給抽回來……",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_039"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n得讓心靈產生『這就是自己的肉體』的誤解，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n為此必須要有個完美的義體才行。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在這個當下，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_040"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "完成品就只有妳的那個而已。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n這個義體的開發者是妳的父親，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "他一心想要把女兒給救回來，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n靠著毅力",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "及非比尋常的努力，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "花上半年才做出來的。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而我的這個身體雖然也和妳一樣是義體，",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_041"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但完成度卻相當的低呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n這次可說是運氣好才能回到『這邊』，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n下次還能不能成功就不知道了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果要持續的往返是不可能的。",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_042"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n能夠做到這件事的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "現在也就只有妳而已了唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以",
        "unit_id": 106831,
        "voice": "vo_adv_2010003_043"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "務必要",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拜託妳了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n讓大家從夢境中醒來吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "希望妳能救救他們，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可可蘿。",
        "unit_id": 106831
    }
]