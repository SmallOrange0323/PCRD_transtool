[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是{player}\n和【new generations】的三人相遇前的故事——"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那個，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_000"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "小凜。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我今天想去一趟公會管理協會，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n有什麼需要我先幫忙詢問的事情嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "管理協會……",
        "unit_id": 112511,
        "voice": "vo_adv_1124001_001"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "啊，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是要去蒐集情報呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這樣的話，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就打聽一下其他公會的動向吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "搞不好",
        "unit_id": 112511,
        "voice": "vo_adv_1124001_002"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "能掌握意料之外的情報也說不定。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不過，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果太勉強的話，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "調查看看現有的委託就好了喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "其他公會的動向和委託，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_003"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "對吧。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我知道了，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那我出發了！",
        "unit_id": 112411
    },
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "哎呀小卯月，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_004"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "歡迎妳呀。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "是要來接委託的嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "您好！　",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_005"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我是來看看今天是不是有新的委託。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "請問還沒刊登的委託裡，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "有沒有比較推薦的呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "好的，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_006"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "我看看。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "還沒刊登的委託在這邊～",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "不過好像都不太適合委託小卯月的樣子呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_007"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是這樣嗎？　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "嗯……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "如果不是給我，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "例如說，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是委託給小凜的話呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "啊～",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_008"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "小凜的話身手不錯應該是可以。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "那再加上這個……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "來，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "新委託的一覽表。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n有想要接的隨時跟我說吧。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好的，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_009"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "非常感謝您！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "有很多都寫著「募集精銳冒險者」呢。",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_010"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "這樣的話，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我應該派不太上用場……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "的確，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_011"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "內容似乎都有點困難的樣子。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我好像幫不上什麼忙，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "有點可惜。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "嗯……",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_012"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "啊，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "對了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "這樣的話妳能接下我個人的委託嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n因為用品用完了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "想請妳幫忙跑個腿。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "讓我來",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_013"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n可是跑腿的話，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不是都交由這裡的員工嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "其實啊，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_014"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "平常拜託的那孩子身體不適所以正在休息呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "而我不能離開工作崗位所以想請妳幫忙，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "可以嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好的，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_015"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "當然沒問題！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不嫌棄的話，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "請讓我幫忙吧。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "謝謝妳，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_016"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "這是採買的清單。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n不是很緊急，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "慢慢來就好了喲。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "早安——",
        "unit_id": 1211,
        "voice": "vo_adv_1124001_017"
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "\n……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "啊，小卯月。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "\n妳接了什麼委託嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "妳好！　",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_018"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是的，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "現在正好要出發去採買。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n各位",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是過來接什麼委託的嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "我們是有其他事情要辦。",
        "unit_id": 1011,
        "voice": "vo_adv_1124001_019"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "先前拜託您的這個，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "能幫我們在協會找個地方貼起來嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "好的。",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_020"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "感覺終於要冒險者畢業了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "有點寂寞呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_021"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "冒險者畢業！？　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "發生了什麼事嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "哈哈哈，",
        "unit_id": 1211,
        "voice": "vo_adv_1124001_022"
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "並不是有什麼變故啦。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "之前我們同伴之間",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "討論過好幾次了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "\n我們想釐清自己真正想做的事。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "雖說也不是對冒險者有所不滿，",
        "unit_id": 1211,
        "voice": "vo_adv_1124001_023"
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "該怎麼說呢……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "大概是討厭這種沒有目標",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "的感覺吧。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "所以，",
        "unit_id": 1011,
        "voice": "vo_adv_1124001_024"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "我們就順其自然地放棄當冒險者，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "並且決定今後要作為街頭藝人公會展開活動！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "哇，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_025"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好厲害！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "從冒險者到街頭藝人，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是跟以前截然不同的公會活動呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "啊哈哈，",
        "unit_id": 1011,
        "voice": "vo_adv_1124001_026"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "確實是如此呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "會覺得街頭藝人不錯，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n也是因為不小心接錯委託不得以去嘗試的工作。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "不過",
        "unit_id": 1211,
        "voice": "vo_adv_1124001_027"
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "多虧如此，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "我們查覺到自己「想讓人們綻放笑容」的心情。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性冒險者",
        "words": "比起冒險者，這方面好像更適合我們。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "這個，",
        "unit_id": 1011,
        "voice": "vo_adv_1124001_028"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "是下次表演的傳單。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "小卯月和朋友有空的話就來看看吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好的，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_029"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "當然沒問題。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "謝謝你們！",
        "unit_id": 112411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "唔，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_030"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "這些就是所有該買的東西了……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "花了好多的時間在找，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "要快點回去才行——",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "哎呀，",
        "unit_id": 811,
        "voice": "vo_adv_1124001_031"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "抱歉！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊。",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_032"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "對不起，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不小心撞到……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊！？　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那、",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那是，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我的包包！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "請等一下——！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "該不會是搶劫！？　",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_033"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "怎、",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "怎麼辦……！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n那個人腳程好快……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "這樣下去追不上的……！　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "誰、",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_034"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "誰可以幫幫我！　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那個人，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是強盜——！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n請抓住他，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "拜託請抓住他——！！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "什麼！？　",
        "unit_id": 1411,
        "voice": "vo_adv_1124001_035"
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "覺悟吧……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "看招——！！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "嗚啊！",
        "unit_id": 811,
        "voice": "vo_adv_1124001_036"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "　放、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "放開！　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "快給我放開，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "混蛋！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "呼……",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_037"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "呼……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n不、",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不好意思，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "真的很謝謝你……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "不用放在心上，",
        "unit_id": 1411,
        "voice": "vo_adv_1124001_038"
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "這種時候就交給我這樣的人吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店裡的大叔",
        "words": "像小妹妹這樣的女孩子可不能亂來啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "嗚嗚……",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_039"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "人家",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好歹也算是個冒險者……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "結果比商店的大叔還靠不住……",
        "unit_id": 112411
    },
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "——因為發生這樣的事，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_040"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "所以回來晚了，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "對不起！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "沒事沒事，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_041"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "我說過不用急的嘛。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "東西也都有好好買回來了，別在意唷。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "只是，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_042"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "雖然就結果來說是順利解決了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n但去追強盜可是很危險的喔？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦？　",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_043"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可、",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可是，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n採買用的包包被搶走了，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不能就那樣不管……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "我舉例來說好了。",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_044"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "比方說在強盜逃走的方向上，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n有同夥埋伏著……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "像這種事也是有可能發生的吧？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊……",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_045"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "聽您這麼說確實是這樣呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n當時只想著得先追上去，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "所以沒想得那麼多。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "妳很努力想幫忙的心情我很開心。",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_046"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "可是",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "最重要的是",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "妳的人身安全，不小心點可不行。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "小卯月只是普通的女孩子呀，",
        "unit_id": 1511,
        "voice": "vo_adv_1124001_047"
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "\n希望妳以後不要太勉強自己了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "協會的阿姨",
        "words": "好嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "好的……",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_048"
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "普通的女孩子……",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_049"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "說得",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "也是呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "身為冒險者沒辦法像小凜那樣活躍，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n也不像未央，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "各式各樣的事情都能妥善處理。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我想要做的事情，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_050"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "到底是什麼呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我能不能像那時遇到的街頭藝人公會一樣，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "找到真正想做的事呢……？　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然和小凜、",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_051"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "未央一起生活很開心。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不過，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "接下來我想要怎麼做呢？　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "……我能夠，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_052"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "找到些什麼嗎。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我會想嘗試去挑戰的，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "新事物——",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "咦，",
        "unit_id": 112411,
        "voice": "vo_adv_1124001_053"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "已經這麼晚了！？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "得、",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "得快點回去才行！　",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "她們兩個會擔心的！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "卯月透過今天所發生的事，開始思考起自己真正想做的事。\n而等到她遇見自己的目標，那又是好一陣子之後的事了──"
    }
]