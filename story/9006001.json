[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}回過神來，發現自己佇立在熟悉的地方。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的～",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，該說早安嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不好意思啊，突然把你找來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別擔心別擔心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的本體現在還好好地在房間裡睡覺呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我只是在你睡覺的時候招待你來夢裡而已。",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以不用著急。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "找你來的原因？",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那還用問嗎。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "馬上就要到你和我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有其他女孩子們相遇的紀念日了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在可以在一定程度上自由行動了，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想說可以幫一直很努力的你慶祝一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "事情就是這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我決定要用只有我才做得到的特殊方式",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n送你一個很棒的禮物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就是……",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夢！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說是「那邊的世界」對你來說會比較好理解吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "女孩子們曾經幫你慶祝過",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在「那邊的世界」相遇的紀念日呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，今年我決定送你夢作為禮物，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓你可以和女孩子們一起慶祝在「那邊的世界」的相遇。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還不只這些哦。",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在「這邊的世界」，我也準備了慶祝活動和禮物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "兩邊都能被慶祝，這可是只有你才有的哦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼樣？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開心吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "準備起來還需要一點時間呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在準備好之前，你就好好享受「那邊的世界」的夢吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到你醒來之前的這一小段時間，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會把你送入夢鄉的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "究竟會夢到誰，就留到當天當作驚喜吧。",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那這次",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就先聊到這裡吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再見囉～♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n圍繞著紀念日的夢的日子開始了。"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好……",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他醒了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也得準備好才行。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唔唔唔唔……",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呃～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿、小可可蘿，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽得見嗎～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在妳接收到的是愛梅斯的神諭哦♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我有件事想拜託妳，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳方便嗎～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當然是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟他有關的事囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n準備好要做筆記了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唔，",
        "unit_id": 190011,
        "voice": "vo_adv_9006001_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "首先……",
        "unit_id": 190011
    }
]