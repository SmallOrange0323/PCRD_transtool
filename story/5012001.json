[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞～！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你在吧，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "過來一下好嗎！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n怎麼了，真琴，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這麼大聲。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唷，",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這不是助手先生嗎。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我今天應該沒有請你過來打工",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才對呀？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哎呀。",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生會來的原因，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就由我來推理一下吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯～……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "跟真琴一起也就是說……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來跟戀愛糾葛之類的事件無關呢。",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你管太多了吧！",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起這個，霞！",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n有個謎團想請妳幫忙解決。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}的性命好像被人盯上了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "性命嗎？　",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽起來可真不平靜啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我知道了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽妳說就是了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哼嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來如此。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一開始發現到有異狀，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是餐廳裡的碗盤無緣無故破掉的時候",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n開始感覺到人身安全受到威脅，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是在這幾天，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大概就是這麼回事吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光根據你剛剛說的那些，",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就已經是很有力的線索了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "周圍完全沒有可疑的感覺對吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊。",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然獸人族",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對那些事情可說是很敏感的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但完全沒感覺到什麼異狀。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是不是在哪裡受到詛咒了呢。",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "像是被壞精靈附身之類的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "身體狀況很正常吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n任何異常的狀況",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也完全沒發現。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先別說動機和手段了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說到底，連這件事到底是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n單純的意外，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是另有企圖的事件，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都還無法判斷呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嘻嘻……",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嘻嘻嘻嘻嘻！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是說，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是真正的神秘事件啊！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若是這樣子的話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就換我出場了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太棒了呢，助手先生！",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在我們的眼前",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "出現了挑戰這個大謎團",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的權利！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……雖然我很想這麼說、",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但我們也不能光顧著高興。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟助手先生身陷危險之中，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "需要盡早解決。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "首先必須掌握",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "更詳細的情況。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好，",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那我們快開始調查吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "出門囉！",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原本以為是要一起上街，",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n結果是要讓{player}獨自一人，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n然後我們跟在後頭……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底在想些什麼呢？　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽到助手先生被盯上的消息時，",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我腦中",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "立刻浮現一個可能的原因。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可能的原因？",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就是女生過度的怨恨，",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有執念喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說怨恨，",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n感覺不是這麼容易發生在{player}身上的吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的確，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙的身邊淨是女生嘛。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不小心招人怨恨",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "的這種事也不是完全沒可能。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然沒有……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哈哈。",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的確，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光看助手先生的為人，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的確很難想像他會遭到怨恨啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於執念這個部分，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "倒是滿有可能的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是說，",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生搞不好是被跟蹤狂給盯上了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我是這麼想的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊、",
        "unit_id": 101411,
        "voice": "vo_adv_5012001_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "快看。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n才剛說到而已，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生就被搭話了喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "跟蹤狂",
        "unit_id": 104311,
        "voice": "vo_adv_5012001_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一般不會自己跑來搭話吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，沒辦法，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們持續監視吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這或許就是能找到犯人的線索呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 100811,
        "voice": "vo_adv_5012001_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這不正是{player}嗎。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真巧呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "該不會，",
        "unit_id": 100811,
        "voice": "vo_adv_5012001_030"
    },
