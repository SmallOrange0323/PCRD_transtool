    {
        "type": "dialogue",
        "name": "忍",
        "words": "無法直視他的眼睛說話了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於忍對{player}感到非常在意，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因而變得無法直視他的眼睛。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的這般思念究竟該何去何從──"
