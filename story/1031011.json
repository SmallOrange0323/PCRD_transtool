    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人結束巡禮後，終於回到蘭德索爾市區。"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "呼，",
        "unit_id": 2411,
        "voice": "vo_adv_1031011_000"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "總算回來了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這一路上簡直吃盡了苦頭。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n一整天和小伙子待在一起，我都快瘋掉了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他幫你洗刷了冤情，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請不要說這種話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔……",
        "unit_id": 2411,
        "voice": "vo_adv_1031011_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "可是，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我就是感到",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "很煩悶啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不管是這次，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "還是那老太婆的事件，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "全都讓人覺得很不痛快！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "所以說，這全是小伙子的錯，",
        "unit_id": 2411,
        "voice": "vo_adv_1031011_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是他不好！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "還不快滾！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "討厭，",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸從什麼時候開始有了這項功能的？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咦？",
        "unit_id": 2411,
        "voice": "vo_adv_1031011_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這什麼",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我不知道啊，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好可怕！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍，快救我──！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀啊！",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_006"
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，{player}獨自一人在街上散步。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_1031011_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請等一下──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請務必",
        "unit_id": 1,
        "voice": "vo_adv_1031011_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聽我說幾句話──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊……{player}！",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有人在追我……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "找到了！",
        "unit_id": 1,
        "voice": "vo_adv_1031011_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請給我一點時間吧──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這",
        "unit_id": 1,
        "voice": "vo_adv_1031011_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對妳來說，是很重要的事！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "已經追上來了……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼辦……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好的……！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼，",
        "unit_id": 1,
        "voice": "vo_adv_1031011_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "她到底跑去哪裡了？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "她應該不會跑太遠。",
        "unit_id": 1,
        "voice": "vo_adv_1031011_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那女孩是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "未來的明星，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一定要",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "招攬她加入我們的事務所！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……那、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這縫隙",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有點窄……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "靠得有點太近了……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呃，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸你說什麼……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們兩人靠得太近了？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那也是沒辦法的事啊，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為情況緊急嘛。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你說他們啊，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我還沒跟你說明清楚呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呃，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他們是",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雜誌的記者，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有經紀公司的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "星探。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你感到",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很訝異吧。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "演藝圈什麼的，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再怎麼想都與我格格不入。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "老實說，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我之前曾接受過一次地方刊物的採訪。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那篇報導……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說來有點難為情，\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "標題被寫成是",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「美少女占卜師特輯」……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "從那次之後，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其他媒體，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n甚至連經紀公司的人全都跑來找我，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以我才會像這樣，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "到處躲避他們。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然我父親",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "得意洋洋地",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說：",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「大眾總算注意到忍的存在了！」",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但我一點也不希望",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "自己引人注目。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你說這是個",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可以成為偶像的好機會？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "當個又唱又跳又會占卜的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "靈感偶像？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別再說了，爸爸。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是不可能的！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是因為……",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我一時",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "糊里糊塗……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我說真的喔？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不用了，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是我自己來說。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n真要說的話，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是我自己惹出來的禍。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒錯，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "老是依賴這個人",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一定會──",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "記者",
        "words": "嗚哇──！",
        "unit_id": 1,
        "voice": "vo_adv_1031011_030"
    },
    {
        "type": "dialogue",
        "name": "記者",
        "words": "你、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者",
        "words": "你要做什麼！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "星探",
        "words": "嗚、",
        "unit_id": 1,
        "voice": "vo_adv_1031011_031"
    },
    {
        "type": "dialogue",
        "name": "星探",
        "words": "嗚咿──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "星探",
        "words": "救命啊──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那聲音……",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "聽起來像是剛才追我的那群人。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這種慘叫聲，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "肯定是出了什麼事。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "過去看看情況！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個人是……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "終於清除掉礙事者了。",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_034"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "接下來，只要找到忍就行了……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "喔喔！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "忍！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳是特地來見我的嗎？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n我也很想見妳呢。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "自從忍為我占卜後，",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_035"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n好運接連而來，感覺像是重生了一樣。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我已經準備好一大筆金錢，",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_036"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n今天一整天",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "就讓我獨占妳吧！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呃，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他是之前有來找我",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "占卜過一次的客人。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "啊？",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_038"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "你這傢伙跟忍說話",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "裝什麼熟啊？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n就是因為有煩人的傢伙們在忍身邊徘徊，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n才害我完全沒辦法請她幫我占卜，搞得我心浮氣躁的。",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "你也是礙事者？",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_039"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我說得沒錯吧？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n既然這樣，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "在吃苦頭前，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "快給我滾吧！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唔！",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_040"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "啥？",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_041"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "你以為這是誰害的？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "現在馬上給我滾！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼辦……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再這樣下去，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個人會有危險的，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而我卻連聲音都發不出來……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "幽靈",
        "words": "交給我們吧……",
        "unit_id": 1,
        "voice": "vo_adv_1031011_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_044"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_045"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "嗚……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "怎、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "怎麼回事……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "突然感到一股寒意……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔，",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_046"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "這、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "這聲音到底是……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "幽靈",
        "words": "接受報應吧……",
        "unit_id": 1,
        "voice": "vo_adv_1031011_047"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "是、",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_048"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "是誰……！",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "身、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "身體突然",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "變得",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "很沉重……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "站、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "站也站不穩……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "好、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "好痛",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "苦……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不、",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_049"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不可以！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔、",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_050"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔嗚……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "忍，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳說什麼、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "不可以啊……？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "\n",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我已經",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "這麼痛苦了，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "不要否定我！",
        "unit_id": 1331
    },
    {
        "type": "still",
        "still": "103101101"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "唔……",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可以請你",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "離開嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "啥？",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_052"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為我狀況不佳，無法為你占卜，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的很抱歉。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_054"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為這漾而造成他人的困擾是不對的事。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n還請你",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "快住手。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳、",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_055"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳是說我做錯了嗎？",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "妳說啊──",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請你快住手。",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_056"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "唔……",
        "unit_id": 1331,
        "voice": "vo_adv_1031011_057"
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我、",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "我知道了……",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "可惡，",
        "unit_id": 1331
    },
    {
        "type": "dialogue",
        "name": "小混混",
        "words": "這到底是怎麼回事……",
        "unit_id": 1331
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……呼，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_058"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好緊張……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_059"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我只是因為鬆了一口氣。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你剛才",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫我說話。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_060"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也謝謝你們，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幫了我一個大忙。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒錯，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_061"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幽靈們就在我們身邊。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而我剛才揚聲大叫就是因為，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_062"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖說是為了保護我，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也不希望它們去傷害人。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "再說，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_063"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這也是為了激勵",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因接受採訪而引發這一連串事件，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻只知道四處逃竄的自己。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_064"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一直很希望自己能夠改變，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻不知道",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "該怎麼做才好。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就在這時候，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "地方刊物正好前來採訪，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我心想這應該會是個機會，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以就答應接受採訪。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "老實說，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_065"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "成為名人",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "與我想要的改變相去甚遠。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為如果失去了自我風格，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那就毫無意義了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_066"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我已經沒事了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n經過這次的事件，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "多少給了我一些勇氣。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是微小",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "卻很重要的改變。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "幽靈",
        "words": "……加油喔。",
        "unit_id": 1,
        "voice": "vo_adv_1031011_067"
    },
    {
        "type": "dialogue",
        "name": "記者",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1031011_068"
    },
    {
        "type": "dialogue",
        "name": "記者",
        "words": "忍！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "記者",
        "words": "終於找到妳了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "星探",
        "words": "剛才的小混混……",
        "unit_id": 1,
        "voice": "vo_adv_1031011_069"
    },
    {
        "type": "dialogue",
        "name": "星探",
        "words": "很好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "星探",
        "words": "看來已經離開了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_070"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒問題的。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看到你，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓我深深覺得自己必須有所改變。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我要自己做個了斷，",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_071"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請你在一旁守護著我。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個嘛……",
        "unit_id": 103131,
        "voice": "vo_adv_1031011_072"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在還不能告訴你♪",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1031011_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你只要跟忍在一起，總會被捲入稀奇古怪的事件，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n令人百看不厭。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1031011_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "忍她變了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n即便她仍有不為人知的一面，是個很奇妙的女孩，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻有了想要改變的勇氣，還能付諸行動。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "忍她為何那麼想要改變？",
        "unit_id": 190011,
        "voice": "vo_adv_1031011_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你真的知道嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要努力變堅強，",
        "unit_id": 190011,
        "voice": "vo_adv_1031011_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當忍某天向你展現出勇氣時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你才有辦法回應她喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1031011_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就聊到這裡囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊……",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_078"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你醒過來了呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我又做了那個奇妙的夢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖說目前仍不清楚那場夢的真正原由，",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_079"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "麻煩事也一樣接連不斷，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但那絕不是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一場討厭的夢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "夢中的我",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_080"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很努力地想要改變。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是不是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也該這麼做呢？　",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們之間的關係是因為幽靈才有所交集。",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_081"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n當問題解決了，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或許自然就會漸行漸遠。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很令人難過的事。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為了不讓事情變成那樣，",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_082"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "除了靈能力",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "和想守護這個人的使命感之外，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也得努力做些改變。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_083"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就是這麼想要",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "待在這個人的身邊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不、",
        "unit_id": 103111,
        "voice": "vo_adv_1031011_084"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒事……",
        "unit_id": 103111
