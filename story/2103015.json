[
    {
        "type": "background",
        "background": "500792"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以被囚禁著的霸瞳皇帝為目標，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【憤怒‧軍團】的贊恩，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正獨自一人朝著蘭德索爾的王城前進。"
    },
    {
        "type": "dialogue",
        "name": "士兵們",
        "words": "嗚啊啊啊～！",
        "unit_id": 4311,
        "voice": "vo_adv_2103015_000"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "咿～！",
        "unit_id": 4311,
        "voice": "vo_adv_2103015_001"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n快逃，",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "快逃啊！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "他是怪物啊，",
        "unit_id": 4311,
        "voice": "vo_adv_2103015_002"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "根本不是人啊！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n這絕對是贏不了的！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔、",
        "unit_id": 191411,
        "voice": "vo_adv_2103015_003"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔唔唔唔！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n豈有這種道理啊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n宮殿前的守衛，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "他竟然獨自一人就輕易地突破了啊……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_004"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "咿！",
        "unit_id": 191411,
        "voice": "vo_adv_2103015_005"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n……撤、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "撤退，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "撤退！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n【黃金之手】部隊，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "全軍撤～退～！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "可、",
        "unit_id": 4312,
        "voice": "vo_adv_2103015_006"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "可是議長！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n這樣的話宮殿就沒有人防守了……！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "蠢貨！",
        "unit_id": 191411,
        "voice": "vo_adv_2103015_007"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n我等需保護的對象是陛下的玉體！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n而既然陛下都親自出征到外頭了，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那如今在這死撐還有何意義！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "因此……",
        "unit_id": 191411,
        "voice": "vo_adv_2103015_008"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "撤退！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n撤～退～！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "議長～！",
        "unit_id": 4312,
        "voice": "vo_adv_2103015_009"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n請您等等～！",
        "unit_id": 4312
    },
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_010"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……？",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀，",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不得了呀不得了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所謂的一騎當千就是在說你呢，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "【憤怒‧軍團】。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "妳是……",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呃——",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我有需要",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "自我介紹嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "「七冠」——",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_015"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n迷宮女王，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "拉比林斯達。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……模索路晶。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哼嗯～",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你用「那邊」的名字叫我呀。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n外加你那雙角，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有那條尾巴……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是讓人越來越感興趣了呢～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以說，",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你的目標",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這座宮殿裡的千里真那嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "是。",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_018"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……但正確來說……",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "應為「將軍抽車」才是。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈。",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這麼說來，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我不就被你給釣個正著了嗎～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……看來你們正在獵殺七冠的傳聞，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是真的呢。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……我們全員都是你們的目標。",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n同時，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你們並不是為了要報仇",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……哈哈。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這下我大概猜得出來了唷，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "關於你們的",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "背景身分。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟{player}少年他們現在也不太妙嘛……",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這也沒辦法，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我就姑且兩肋插把刀吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n再說，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也不想在這個階段就把真那交出去呢～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有就是那個嘛，",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果大罪犯被賊黨給奪走了的話，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我想利用的",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「皇家的威信」，不也會有所影響了嘛？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_024"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "——獻醜了。",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_025"
    },
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "——",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎呀，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "越看越覺得厲害了呢，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你呀。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n竟然連覺醒都沒有就擁有這種程度的力量。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再加上，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那把劍——",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "咬碎她——",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "！",
        "unit_id": 106811,
        "voice": "vo_adv_2103015_028"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "——「蠻牙龍咬」。",
        "unit_id": 191711,
        "voice": "vo_adv_2103015_029"
    }
]