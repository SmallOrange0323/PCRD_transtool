[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的課程",
        "unit_id": 116011,
        "voice": "vo_adv_6061203_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就到這邊結束囉～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然當老師之類的工作",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家還做不習慣，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過若能對大家有所幫助，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也會很高興。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您，",
        "unit_id": 116011,
        "voice": "vo_adv_6061203_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一想到",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被稱為老師，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這大概是最後一次了，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就覺得有點寂寞……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以請您",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "再喊我一聲老師嗎？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那當然。",
        "unit_id": 116011,
        "voice": "vo_adv_6061203_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家當老師，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "絕不會對任何一位學生",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "棄之不顧。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的課程雖然結束了，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但還是會暗地為學生加油打氣，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還請多多指教囉～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然可以！",
        "unit_id": 116011,
        "voice": "vo_adv_6061203_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這孩子",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是跟王子先生同甘共苦的夥伴。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當您不在人家身邊時，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就請把它當作人家，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好好珍惜它吧～",
        "unit_id": 116011
    }
]