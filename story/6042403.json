        "voice": "vo_adv_6042403_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請安靜點！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……說不定老大正在哪裡聽我們說話呢。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "保持沉默……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "保持沉默就是最好的回答喔……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是啊！",
        "unit_id": 106612,
        "voice": "vo_adv_6042403_003"
    },
    {
