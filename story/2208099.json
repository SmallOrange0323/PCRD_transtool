        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "黎‧普賽爾",
        "words": "『七冠』的領導人物",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "黎‧普賽爾",
        "words": "『長老』\n",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "黎‧普賽爾",
