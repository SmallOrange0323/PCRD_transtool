    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n都說過要她跟我們一起來了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "搞什麼啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "實在是……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「對不起……",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對不起，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了幫助我們，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳才變成這樣……」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "貪吃佩可小姐……",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_063"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n希留耶……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……目前，",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_064"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n以她為代表，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒有脫離「米奈娃的禁錮」",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "的那些人們，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們至今仍未發現能讓他們甦醒的辦法。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她們",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_065"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這些玩家的靈魂……",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n依然還囚禁在《阿斯特朗傳奇》裡。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「靈魂……？」",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_066"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳說的靈魂……",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_067"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不是在說遊戲裡虛構的事，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是嗎？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "靈魂啊神明什麼的",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_068"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n現實根本就不存在嘛！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "應該……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不存在吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我非常明白",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_069"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳們說出這些話的心情。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n可是……",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我呀，",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_070"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "遠在「米奈娃的甦醒」之前……",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就已經以腦神經學者的身分",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "參與開發mimi。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我搞不好有跟{player}",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "提到過一些呢。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦！？",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「深月小姐",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "參與過mimi的開發……？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當然，",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_073"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "除了我以外",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有許多研究者與工程師。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n重要的黑盒部分",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也掌握在WISDOM的高層手上。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_074"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "核心部分──",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "例如抽出並傳送靈魂，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這些過程原理，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很可惜我也還不清楚。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n畢竟我專精的，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是阻止回饋到神經系統時發生事故……",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過……",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_075"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "自己參與開發的東西",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "造成這樣的結果，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n身為研究者",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是覺得自己該負起責任。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我深深",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如此認為。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……妳剛剛",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_076"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n說「不清楚過程原理」。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n可是啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要是……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「要是有什麼線索的話請告訴我們好嗎，",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "深月小姐！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們該怎麼做，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才能夠幫助小雪菲他們……！？」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_078"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在我能夠告訴妳們的，",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_079"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只有兩件事。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "首先必須找到曾經是《阿斯特朗傳奇》主要伺服器的，",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_080"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n超超高密度記憶體……",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n通稱",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「埃忒耳模組」。",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以及──",
        "unit_id": 105132,
        "voice": "vo_adv_2208099_081"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們必須再一次，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n進入那個世界，",
        "unit_id": 105132
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "潛入那個世界才行。",
        "unit_id": 105132
    },
