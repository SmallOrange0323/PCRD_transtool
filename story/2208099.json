        "voice": "vo_adv_2208099_006"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「米奈娃的禁錮」結束後，過了一陣子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n世界恢復了和平──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "表面上看起來似乎是如此。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可和希留耶和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了幫助還未從「米奈娃的禁錮」甦醒的人們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n持續尋找著棗可蘿和她的父親。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而──"
    },
    {
