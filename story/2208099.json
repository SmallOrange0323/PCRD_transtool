    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「……就是這樣。",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尋找小可蘿父親的事",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變得越來越困難……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在很傷腦筋耶～」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "黎‧普賽爾小姐……",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不僅將貪吃佩可小姐驅逐離開祖國，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n沒想到還盯上了可可蘿的父親……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "黎‧普賽爾本人多半也只負責掌旗出面，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n實際上大概還有一群人在背後出謀劃策，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n當幕後黑手。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原來如此……",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種劇情",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的確",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有在小說之類的",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看到過。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那種自己完全不知道",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "遭到欺騙利用，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n最後",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還慘遭捨棄",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "落得悽慘下場",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的女孩子……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不，",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_012"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我沒有說得那麼誇張喔……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「這邊的栞",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也一樣很喜歡讀書呢☆」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "打從出生以來",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體就不是很好。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n平時都在看書……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只是把習慣，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n帶到遊戲裡了而已。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……在《阿斯特朗傳奇》",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然也是身體虛弱，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "倒還是能幫忙做農場的工作，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n或是陪喵特玩……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那時候好開心……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還能變成",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔法少女……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "目前",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還算沒問題。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……不過……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛從「禁錮」的昏睡中甦醒那時候",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的相當辛苦……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一直到最近才能像現在這樣",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "正常走路。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「這樣啊……」",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有一段時間",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "被謝絕會客，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n現在也還看不到出院的希望……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且醫生",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也不准許我持有任何電子儀器。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n當時想到又要",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "回去那種",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n只能看書的生活，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就覺得意志消沉……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒想到",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}你們\n會特地前來探望，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我完全沒想過。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的非常",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "非常開心……♪",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……咦？",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可是……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "各位為什麼",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會知道我在哪裡住院啊？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "初音",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "有傳訊息\n給{player}的mimi啦。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n說是希望我們",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "一起去探望妳。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「本來是和她約在這個大廳，",
        "unit_id": 105831,
        "voice": "vo_adv_2208099_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只是和初音會合之前",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就先碰到栞了！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n事情就是這樣。」",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這樣子呀？",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n姊姊她",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會不會",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又睡過頭了？",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……還是說……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真是",
        "unit_id": 106031,
        "voice": "vo_adv_2208099_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "拿她",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "沒辦法耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n竟然遲到～",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n枉費我們還拜託秋乃",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "確認有沒有警察在監控耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈。",
        "unit_id": 103832,
        "voice": "vo_adv_2208099_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是抱歉……",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這麼說，",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳們成功再見到秋乃小姐了呀。",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「是的☆",
