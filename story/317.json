[
    {
        "type": "dialogue",
        "name": "凜、卯月、未央",
        "words": "到了～！！",
        "unit_id": 1,
        "voice": "vo_adv_0000317_000"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "呼、",
        "unit_id": 112611,
        "voice": "vo_adv_0000317_001"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "呼……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "終於到頂端了呀～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n真厲害呢～",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "哇……",
        "unit_id": 112511,
        "voice": "vo_adv_0000317_002"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "快看，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "大家。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n外面的",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "景色好美。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "真不賴呢，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "站在天際上。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "真的呢。",
        "unit_id": 112411,
        "voice": "vo_adv_0000317_003"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n這樣的景色，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "以前從來就沒有看過……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然我們有很多以前的事想不起來。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "吶，",
        "unit_id": 112611,
        "voice": "vo_adv_0000317_004"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "雖然這只是我猜的……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "但盆栽小花",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是不是",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "想要讓我們",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n看看這樣的景色呀？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "妳說盆栽小花嗎？",
        "unit_id": 112511,
        "voice": "vo_adv_0000317_005"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯。",
        "unit_id": 112611,
        "voice": "vo_adv_0000317_006"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "朝著目標的那片天加油吧～！　",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "的感覺？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n雖然我也不知道該怎麼解釋。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……原來如此。",
        "unit_id": 112511,
        "voice": "vo_adv_0000317_007"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "以最高處為目標的試煉，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "似乎也不壞呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "如果是這樣的話，我們",
        "unit_id": 112411,
        "voice": "vo_adv_0000317_008"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "或許在這趟冒險中又朝著頂尖偶像",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n邁進一步了也說不定！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……\n嗯，",
        "unit_id": 106011,
        "voice": "vo_adv_0000317_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然妳們三個人啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的是偶像呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "凱留？",
        "unit_id": 112411,
        "voice": "vo_adv_0000317_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是什麼大不了的事啦。",
        "unit_id": 106011,
        "voice": "vo_adv_0000317_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是看著妳們像這樣不顧一切地、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n樂觀正面地",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "朝著嚮往的天際向前邁進……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就覺得這或許是成為偶像必要的條件吧～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯～",
        "unit_id": 112611,
        "voice": "vo_adv_0000317_012"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這樣算是在誇獎我們嗎？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我想大概是誇獎吧。",
        "unit_id": 112511,
        "voice": "vo_adv_0000317_013"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "謝謝妳的誇獎，",
        "unit_id": 112411,
        "voice": "vo_adv_0000317_014"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "凱留！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011,
        "voice": "vo_adv_0000317_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才沒有在誇獎妳們咧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳們不要擅作主張地誤會好不好！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀哈哈♪",
        "unit_id": 105811,
        "voice": "vo_adv_0000317_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "害羞的小凱留，真可愛呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "簡直就是偶像等級的可愛！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇咿哇咿～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_0000317_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下等人來說，是永遠的偶像。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別、",
        "unit_id": 106011,
        "voice": "vo_adv_0000317_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別講那些聽不懂的鬼話啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心我真的宰了妳們喔！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊哈哈！",
        "unit_id": 112611,
        "voice": "vo_adv_0000317_019"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n凱留凱留真可愛呢～♪",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不過說到頭來，",
        "unit_id": 112511,
        "voice": "vo_adv_0000317_020"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我們也和【美食殿堂】的各位創造了一段美好回憶，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "真是一趟很棒的冒險。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嗯！",
        "unit_id": 112611,
        "voice": "vo_adv_0000317_021"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n而且",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "也再次整理好心情",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "能朝成為偶像這個目標邁進！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "今後也要為了成為一個優秀的偶像，",
        "unit_id": 112411,
        "voice": "vo_adv_0000317_022"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "再繼續加油了呢！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月、凜、未央",
        "words": "喔──♪",
        "unit_id": 1,
        "voice": "vo_adv_0000317_023"
    }
]