[
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎樣啊，惡代官大人！",
        "unit_id": 105311,
        "voice": "vo_adv_5015322_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我們已經破解你所有的陰謀了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然",
        "unit_id": 109511,
        "voice": "vo_adv_5015322_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是千鈞一髮。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "呵呵……",
        "unit_id": 11412,
        "voice": "vo_adv_5015322_002"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "呵呵呵呵……",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n呼哈哈哈哈哈哈！！！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你、",
        "unit_id": 109611,
        "voice": "vo_adv_5015322_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你突然做什麼？",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "我就認可你們的力量！",
        "unit_id": 11412,
        "voice": "vo_adv_5015322_004"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "　幹得好！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n我本來以為你們就像一般人類，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "不過你們真的做得很好！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "作為獎勵，",
        "unit_id": 11412,
        "voice": "vo_adv_5015322_005"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "也不是不能允許你們跟隨我。",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n只要跟隨我，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "我就給你們想要的權力！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們",
        "unit_id": 109611,
        "voice": "vo_adv_5015322_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "才不會",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為這種東西戰鬥！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們是",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了大江戶町",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而戰！！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "什麼啊，",
        "unit_id": 11412,
        "voice": "vo_adv_5015322_007"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "原來是想要大江戶町嗎？",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n那就把",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "這樣的町給你們吧！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "在王宮裡面",
        "unit_id": 11412,
        "voice": "vo_adv_5015322_008"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "也有被我引誘出慾望的棋子。",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n只要找他們，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "其他的町想要多少就有多少！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "引、",
        "unit_id": 109511,
        "voice": "vo_adv_5015322_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "引誘出慾望，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你連那種事都……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就是因為有像你這樣的人",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n才會讓大家這麼難過吧！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "來，",
        "unit_id": 11412,
        "voice": "vo_adv_5015322_010"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "收下大江戶町吧！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n然後，",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "你們就把這些想打倒我的愚蠢之人",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n全部給我解決！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "　呼哈哈哈哈哈哈～～！！",
        "unit_id": 11412
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "夠了，惡代官……",
        "unit_id": 105311,
        "voice": "vo_adv_5015322_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n是魔物變成的機關人偶。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這麼亂來的人偶劇，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就由我們來劃下句點！",
        "unit_id": 105311
    }
]