        "voice": "vo_adv_2008012_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "超強的吧♪",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "殺出條血路了！",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在那堆魔物中間",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "轟出一條路了唷，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們就從那殺出去吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果有魔物",
