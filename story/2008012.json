[
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "噗哈！",
        "unit_id": 104911,
        "voice": "vo_adv_2008012_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咳咳",
        "unit_id": 104911,
        "voice": "vo_adv_2008012_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咳咳！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n嗚～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個緊急的逃生出口，沒有經過什麼整理呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n到處都是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "灰塵呀，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把人家的衣服都弄髒了唷？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哭哭。",
        "unit_id": 104911,
        "voice": "vo_adv_2008012_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "明明就沒存多少錢了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這送洗的費用可要人命呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別抱怨了快點走吧，姐姐！",
        "unit_id": 101112,
        "voice": "vo_adv_2008012_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "從這洞穴逃出去應是在敵人的意料之外，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可以就這樣逃到安全區域才對！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不，",
        "unit_id": 107111,
        "voice": "vo_adv_2008012_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "事情看來並沒有那麼簡單。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "礙事的魔物可大搖大擺地到處逛大街呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是埋伏？",
        "unit_id": 107111,
        "voice": "vo_adv_2008012_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或是野生的魔物？雖然難以判別……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n總之看牠們殺氣騰騰，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不可能直接穿過去的吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_2008012_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就憑這數量的魔物……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若真以為這樣就能阻擋我克莉絲提娜‧摩根向前邁進的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可就讓人笑掉大牙啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 107111,
        "voice": "vo_adv_2008012_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不來較量較量，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看誰打倒的魔物較多嗎♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這看起來像是可以悠哉說閒話的狀況嗎？",
        "unit_id": 190711,
        "voice": "vo_adv_2008012_008"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n敵人沒多久就會闖進據點了吧，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n發現那裡沒人之後，當然就會開始搜索我們。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "敵人數量似乎也不少，",
        "unit_id": 190711,
        "voice": "vo_adv_2008012_009"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "若用人海戰術我們一下就會被找到囉。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n如果在這和魔物一隻一隻打的話，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n馬上就會被追上，從兩邊夾擊囉。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦……",
        "unit_id": 107111,
        "voice": "vo_adv_2008012_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然有在動腦呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "稍微對你刮目相看了哦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哈，",
        "unit_id": 190711,
        "voice": "vo_adv_2008012_011"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我可是專門靠圍事在混飯吃的打手啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "雖然九九乘法是背不出來，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但有關戰鬥就交給我吧！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……九九乘法，",
        "unit_id": 107111,
        "voice": "vo_adv_2008012_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你不會嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒問題吧？ ",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要我來當家教嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "只是打個比方啦！",
        "unit_id": 190711,
        "voice": "vo_adv_2008012_013"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n九九乘法而已當然懂，別看不起人啦！？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈。",
        "unit_id": 106112,
        "voice": "vo_adv_2008012_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然感情好是不錯，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但這可不是繼續悠哉的場合……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算有些勉強，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也得快點突破這群魔物囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡就，交給我來吧！",
        "unit_id": 106112,
        "voice": "vo_adv_2008012_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇喔？",
        "unit_id": 104911,
        "voice": "vo_adv_2008012_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n諾維姆妳該不會，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要用『那個』吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇～",
        "unit_id": 101112,
        "voice": "vo_adv_2008012_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等好久了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要讓我們好好看看妳帥氣的一面喔，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "諾維姆♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……在說什麼呢，{player}？",
        "unit_id": 105811,
        "voice": "vo_adv_2008012_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是呢～……",
        "unit_id": 105811,
        "voice": "vo_adv_2008012_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總感覺是還挺歡樂的氣氛就是了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦，",
        "unit_id": 105811,
        "voice": "vo_adv_2008012_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的嗎？\n{player}意外的很博學呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……欸，",
        "unit_id": 105811,
        "voice": "vo_adv_2008012_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你這不是一臉有聽沒有懂嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼還會說心裡有個底呀？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……說不定是那些被我們忘記的，",
        "unit_id": 105811,
        "voice": "vo_adv_2008012_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真正的『現實』的記憶，稍微回復了一點也說不定呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在被改寫之前的，那些記憶。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那樣的話就讓我",
        "unit_id": 105811,
        "voice": "vo_adv_2008012_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用『皇家裝備』的全力一擊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把魔物全都給轟飛囉。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然會變得肚子餓，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後走也走不動了也說不定就是。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒事沒事。",
        "unit_id": 106112,
        "voice": "vo_adv_2008012_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這裡就交給我吧，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也還不到真正的緊要關頭嘛……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們還得要想辦法逃到安全區域才行呢，",
        "unit_id": 106112,
        "voice": "vo_adv_2008012_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這裡還是先溫存體力較好。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家，稍微讓一下路！",
        "unit_id": 106112,
        "voice": "vo_adv_2008012_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要開大招來炸囉！",
        "unit_id": 106112
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是天樓霸斷劍。",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是被改變前的世界中，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我所用的主力武器喔。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼哼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這可是修改了數據的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "無敵外掛裝備唷♪",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然在世界被改寫時，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為被系統排斥所以不知道弄丟到哪去了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但拉比林斯達",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "發揮了她的權能，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n像這樣又替我仿造出來了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然平時收納在異空間中，",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但只要我想，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "隨時都能召喚出來。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然，",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "性能和原版比起來稍微弱化了一點！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這方面，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就靠我的技術和經驗",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "毅力來補足囉！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在之前的世界中，雖然沒什麼機會能夠派上用場，",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但如果是現在的我",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "，可是愛怎麼用就怎麼用啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們這群魔物！",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果還要那條小命的話",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就給我閃邊站！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然這麼說……",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但就只是數據的你們這些傢伙，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也不可能做得出程式設定以外的行動嘛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "數據不算是生命！",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因此你們連生物都算不上！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以我可不會手軟，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一次全把你們給轟飛啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "覺悟吧～！",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n世界第一大壞蛋的一斬，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們就好好品味然後蒸發吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看劍啊啊啊啊啊啊啊！",
        "unit_id": 106113,
        "voice": "vo_adv_2008012_037"
    },
    {
