[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "矛依未碰觸奇妙的結晶，各種回憶湧上心頭。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這些就是……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全部了嗎。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "回憶一個個浮現……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "令人懷念……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然也有過難受的時候……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但那時候真的很愉快。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管回想起幾次，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都覺得很開心。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我不能沉浸在那些回憶裡",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "佇足不前。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管我的未來會發生什麼事，",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我都不會逃避。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要繼續邁進。",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n創造出",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能夠超越這些愉快回憶的未來。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好了，",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快醒來吧，我！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再繼續睡懶覺，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會被尾狗刀笑的……！",
        "unit_id": 106116
    },
    {
        "type": "background",
        "background": "501322"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……嗯……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你啊。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你在擔心我嗎？",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝啦！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我一點事也沒有。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "──我現在",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "狀況絕佳！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "胸懷要在未來創造嶄新回憶的想法，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未不帶一絲迷惘地繼續前進。"
    }
]