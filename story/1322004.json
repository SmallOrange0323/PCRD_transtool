    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "電視上的偶像",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "出現在自己家裡這件事很怪？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "本來就是喔～？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這可是難得的體驗，你要好好品味喔♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開玩笑的啦。",
