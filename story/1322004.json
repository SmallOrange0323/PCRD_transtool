    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是說，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這對我來說也是很不得了的體驗呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我以前一直很嚮往這種事～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺有點像新婚夫婦",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那樣。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒什麼事♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "差不多煮好了……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我去試一下味道喔。",
        "unit_id": 102931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯？",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不太、",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好吃……",
        "unit_id": 102931
    },
    {
        "type": "still",
        "still": "132200402"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "奇怪了，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這食譜。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n明明和媽媽平時做的、",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我最喜歡的咖哩是一樣的食譜呀……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我猜應該不是。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n大概純粹是因為",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我不擅長做菜……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "比起那個，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在討論味道如何之前……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我切材料",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "或炒食材的手勢，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n怎麼看都不像",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「興趣是烹飪的說♪」",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘛……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種臨時抱佛腳的練習，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還是沒辦法蒙混過關吧……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是被大家知道",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我其實不擅長做菜……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦……",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不能被人家看到我沒用的地方呀。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即使",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真正的我其實一無是處，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n螢幕上的我也得要完美無缺，對吧……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……因為",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我可是偶像呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不對……？",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那你覺得呢……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然做不習慣導致手腳不俐落，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但拼命努力做的樣子充滿魅力……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來如此。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "危險的切菜手法，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n會讓人不禁想幫忙……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n可是，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就只是",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不擅長料理而已喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣也沒關係嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "自卑也會是",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的魅力所在……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是這樣嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}。",
        "unit_id": 102931
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "132200401"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……的確，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也許就像你說的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼一說，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我以前憧憬的偶像呀，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然身為偶像，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "歌卻唱得沒那麼好。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即使被周遭當作玩笑的哽，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她也會一起跟著笑。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她那樣的態度很有魅力，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且讓跳舞時的帥氣反差更明顯。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……不知何時，她開始被稱為",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "國民偶像。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果能把自卑也化為武器，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那就最強了呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……很好。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，謝謝你。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多虧有你，我的心裡舒坦多了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "包含丟臉的部分才是我。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我會試著不再隱藏，將完整的自己展現出來。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿……",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_056"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咕嚕咕嚕……"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊……",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_057"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n感覺一放下心來，肚子就餓了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然是失敗的咖哩，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
