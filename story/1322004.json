    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不要問也知道是最棒的吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "居然可以讓偶像在自己家中做菜，",
        "unit_id": 190011,
        "voice": "vo_adv_1322004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n超稀有中的超稀有之夢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n知道為什麼你可以做那種夢嗎？",
        "unit_id": 190011
