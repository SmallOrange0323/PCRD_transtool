    {
        "type": "dialogue",
        "name": "旁白",
        "words": "留守阿爾克絲鍊金堂的最後一晚。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n收拾完畢的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備好要回家後，跟望打了招呼。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，",
        "unit_id": 132212,
        "voice": "vo_adv_1322004_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "辛苦你了。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n謝謝你幫忙收拾店裡。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再次謝謝你，",
        "unit_id": 132212,
        "voice": "vo_adv_1322004_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你陪我",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一起留守阿爾克絲鍊金堂。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來",
        "unit_id": 132212,
        "voice": "vo_adv_1322004_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想進行最後的鍊金。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為我想要給你",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一起留守的禮物。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這可能會花點時間──",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 132212,
        "voice": "vo_adv_1322004_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的調製又搞砸了嗎！？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊啊～～～！！",
        "unit_id": 132212,
        "voice": "vo_adv_1322004_004"
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "叮咚～"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你好～♪",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了避免曝光，我小心翼翼地來，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n結果花了好多時間……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對不起，我遲到了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果被週刊或網路新聞報導",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「櫻井望熱戀曝光！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "躲在男朋友家約會！！」",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……之類的",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有的沒的，就傷腦筋了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦……？",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這是",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果跟我傳出誹聞，你會高興的意思嗎……？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……如果是這樣，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很高……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不、",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不對不可以啦！！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯、",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會傷腦筋對吧……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果真的引起話題，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就不能再像這樣",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來訪了呀。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我有點受到打擊呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "比起這個，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我今天來可是有重大的目的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你還記得嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你果然還記得。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我買了這～麼多的",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "食材喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸～",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你忘記了？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我買了這麼多的食材來耶！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算忘記了也給我想起來～！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實下個月，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我接到最近大受歡迎的烹飪節目的來賓通告。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我得在節目上做咖哩……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……通告的契機是這篇雜誌的報導。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這是我剛開始當偶像時的訪談，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那個，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我稍微念一下喔……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「嘿嘿嘿。",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "小望望的興趣是烹飪的說♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n尤其咖哩的風味更是不輸餐廳的說♪」",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不、",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我才沒這樣說……！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我又沒在偶像的人設上搖擺過！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是……",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當時的製作人擅自撰寫的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「小望望」也是，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "句尾的「的說」也是……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……還說我的興趣是烹飪，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這一切都是隨便寫的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只是一篇小小的報導，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我自己也忘記了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但烹飪節目的工作人員",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "似乎對這篇報導有印象。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因此",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才會發這次的通告給我……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我根本沒有擅長烹飪……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "甚至",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可說是很不擅長……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所、",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是這樣下去，應該會出糗……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "希望你能幫我試吃。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n試看看我做的咖哩的味道。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……那個，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果不好吃，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也可以老實說你的感想喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要知道哪裡不足，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也能好好練習。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就快開始吧……！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "烹煮咖哩，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開始！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，望開始做菜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她用著笨拙的動作將切好的材料放進鍋中。"
    },
    {
        "type": "still",
        "still": "132200401"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……攪拌攪拌……",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "攪拌攪拌……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒問題嗎……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}剛剛有笑吧？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚～～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "反正我就是笨手笨腳的～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啦……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鍊金術師？",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊～",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "確實是有點那個感覺呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "邊攪拌沸騰的大鍋爐，邊發出",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_025"
    },
    {
        "type": "dialogue",
