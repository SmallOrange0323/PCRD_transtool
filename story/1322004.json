        "words": "全新上市──」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "電視中的望",
        "words": "「香氣會引發戀情，",
        "unit_id": 1,
        "voice": "vo_adv_1322004_029"
    },
    {
        "type": "dialogue",
        "name": "電視中的望",
        "words": "也說不定哦。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102931,
        "voice": "vo_adv_1322004_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "廣告效果很好。",
