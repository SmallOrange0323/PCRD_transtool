    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1322004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是因為藥的力量喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……「能做最棒的夢之藥」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這是我用鍊金術做給你的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "騙你的。",
        "unit_id": 190011,
        "voice": "vo_adv_1322004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……真是的，",
        "unit_id": 190011,
        "voice": "vo_adv_1322004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你真的有夠純真耶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該不會喝了「變純真的藥」吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1322004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "差不多該起來的時間了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
