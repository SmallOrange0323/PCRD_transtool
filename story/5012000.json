    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，在蘭德索爾。\n{player}陪著【哞哞自衛隊】\n的真琴進行街道巡守，走在街上。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這邊看起來也沒有異常。",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n{player}你那邊怎……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "奇怪？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}！？　你跑去哪啦！",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂～！　{player}！",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n如果在就回應一下啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "竟然在那種地方！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，抓到你囉！",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別像小孩一樣亂跑啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然我沒生氣，",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但也別讓我擔心啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起這個，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你發現什麼了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在那邊",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看到了郵件配送打工時很照顧你的人嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "郵遞馬車的老闆",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還自己做馬車，這麼厲害。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……怎麼看起來沒什麼精神呢。",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "稍微問問看吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "啊啊，",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_008"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "是你啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "好久不見啊……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "咦，",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_009"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "你問我發生了什麼事？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "其實，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "有一點麻煩的事呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "為了今年的馬車競賽，",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_010"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "本來想說要大顯身手，而做了一台馬車，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n但騎手卻受傷了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那還真是可憐……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "唉……",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_012"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "這次優勝馬車所屬的郵務商行，可以得到",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n『蘭德索爾最快郵遞馬車』",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "稱號的說……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這稱號還真是直白……",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你想要那種東西啊？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "有了那個的話，",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_014"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "會很有宣傳效果喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "身為打造馬車的人，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "我希望所屬的郵務商行能夠",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "因此一舉成名！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "唉……",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_015"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "但就缺騎手……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n騎手……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "只要有騎手……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "對了，{player}！",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_016"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n你可以幫忙當騎手，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "替我們參加比賽嗎！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸……",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂喂，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "突然叫他參加，他會很困擾的？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這個嘛、店長。",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n{player}也有",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n很多事得做吧……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……咦，",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒那麼多事嗎！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那你想要參加競賽嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "拜託啦，{player}！",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_020"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "而且會有獎品喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "　如果贏的話，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "我就把獎品給你！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "獎品每年都不同……",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_021"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "但我打聽過今年的是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n獲得大概吃個一年都不成問題的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n超大量食材的樣子喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦～",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那還真不錯！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}也試著出賽如何？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "萬一",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "遇到危險的話，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我一定會保護你的！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼樣？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "咦，",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_024"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "你願意參加？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "太棒了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "　謝謝！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "　那就拜託你了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "競賽時馬車上",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_025"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "騎手會需要一位夥伴，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n若是兩位的話就夠了！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "你們的表現，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "我很期待唷！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "夥伴……",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是指我嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "對啊！",
        "unit_id": 1411,
        "voice": "vo_adv_5012000_027"
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "\n情侶一起",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "郵遞馬車的老闆",
        "words": "親密地參加馬車競賽不是很棒嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "情、",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "情侶！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這傢伙是優衣的……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣也不是情侶……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且我",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要擔任競賽中的警備工作，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不能參加啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉喔、{player}。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 104311,
        "voice": "vo_adv_5012000_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有沒有其他適合的人選呢……",
