[
    {
        "type": "background",
        "background": "501630"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "太棒了──",
        "unit_id": 192613,
        "voice": "vo_adv_9100125_000"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "居然不將大群的魔物放在眼裡，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n還貫穿巨神的腹部，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "站到我的面前。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "真是的。",
        "unit_id": 192613,
        "voice": "vo_adv_9100125_001"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "你們幾個",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "究竟想讓我見識幾次的奇蹟啊。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這才不是什麼奇蹟！",
        "unit_id": 105811,
        "voice": "vo_adv_9100125_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這就是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們的羈絆！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們會在這裡結束一切！",
        "unit_id": 106411,
        "voice": "vo_adv_9100125_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這也是為了在下面",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擋住魔物的大家！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "嗯──",
        "unit_id": 192613,
        "voice": "vo_adv_9100125_004"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "說到",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "擋住。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "在外頭戰鬥的七冠們，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "似乎也早已超過了極限。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n看樣子巨神即將就要",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "抵達蘭德索爾了啊。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊！",
        "unit_id": 100111,
        "voice": "vo_adv_9100125_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不知不覺",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "蘭德索爾已經這麼近了……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "照這樣下去，",
        "unit_id": 100211,
        "voice": "vo_adv_9100125_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "城鎮會變得亂七八糟的……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "我說過要燒毀世界了吧？",
        "unit_id": 192613,
        "voice": "vo_adv_9100125_007"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "城鎮之後……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "就將索爾之塔",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "給擊墜吧。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不可以！",
        "unit_id": 190011,
        "voice": "vo_adv_9100125_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是讓他這麼做，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「禁錮」將會無法結束的！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們絕不會",
        "unit_id": 105911,
        "voice": "vo_adv_9100125_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓你稱心如意……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯！",
        "unit_id": 100312,
        "voice": "vo_adv_9100125_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們要奪回你身上",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最後的索爾魔珠！",
        "unit_id": 100312
    }
]