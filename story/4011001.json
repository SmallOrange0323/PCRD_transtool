        "words": "小凱留～～！　",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿～～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡啦～～！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡這裡～～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然把我們叫出來到底幹嘛……？",
        "unit_id": 106012,
        "voice": "vo_adv_4011001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳該不會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又要帶我們去吃什麼詭異料理的店了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 105913,
        "voice": "vo_adv_4011001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡不是能用餐的店……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這裡究竟是……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "鏘～～！　",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽了可不要驚訝！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡就是本日開張的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「戰鬥試煉場」！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我去拜託克蕾琪塔小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請她幫忙建造了一個",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用來訓練冒險者們的設施♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913,
        "voice": "vo_adv_4011001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是一個可以和",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其他人進行模擬戰，小試身手的地方啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那還真是一個非常具有價值的設施呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就單純的訓練來說，",
        "unit_id": 106012,
        "voice": "vo_adv_4011001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "參加者和觀眾是不是都有點太投入了啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都讓我有點害怕了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實啊，",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "勝利者可以得到不錯的獎勵哦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以大家才會拚盡全力要分出勝負啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說",
        "unit_id": 106012,
        "voice": "vo_adv_4011001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要贏得越多就賺得越多？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦～～！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那還挺不錯的嘛！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不僅能打爆討厭的對手，",
        "unit_id": 106012,
        "voice": "vo_adv_4011001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還能得到獎勵對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳偶爾也會做些有建樹的事情嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿嘿～～",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算妳這樣稱讚我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也只能端出好吃的魔物料理回報妳而已啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該、",
        "unit_id": 106012,
        "voice": "vo_adv_4011001_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "獎品就是魔物料理吧……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是吧？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快跟我說不是！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_4011001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐似乎已經充滿幹勁了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人看起來也是興致勃勃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來我們不參加是不行了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就知道是這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以早就幫大家報名好了♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就快點參加看看吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了以更上一層樓為目標。",
        "unit_id": 105913,
        "voice": "vo_adv_4011001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了把獎勵賺飽飽！",
        "unit_id": 106012,
        "voice": "vo_adv_4011001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了戰鬥後的美味大餐！",
        "unit_id": 105812,
        "voice": "vo_adv_4011001_016"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "以第一名為目標，努力戰鬥囉～～！",
        "unit_id": 1,
        "voice": "vo_adv_4011001_017"
    }
]