    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "到底有多惡劣啊，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那個院長！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要趕快打倒他讓城鎮恢復原狀！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說呢，",
