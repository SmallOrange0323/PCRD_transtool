    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他用藥使自己的魔力遽增，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "導致魔力都洩漏了出來。",
