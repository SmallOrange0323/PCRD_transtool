    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "香甜入口即化、",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "蓬鬆柔軟的口感……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "舌頭和心",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "都要融化了……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟的味道，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我好好享受到了……♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也有做過",
        "unit_id": 104914,
        "voice": "vo_adv_5213073_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "重現弟弟模樣的",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可麗餅。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但能把弟弟的魅力還原到這種程度……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果沒有用極深的愛去觀察弟弟，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是不可能達到這種境界的！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒想到你對弟弟的了解如此深刻，",
        "unit_id": 104914,
        "voice": "vo_adv_5213073_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來萊拉耶爾小姐也……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咦……？",
        "unit_id": 126511,
        "voice": "vo_adv_5213073_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不、",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不是，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我並沒有那樣……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士只是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "重要的客人而已，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我並沒有對他抱持特別的感情，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "絕、",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "絕對沒有……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "萊拉耶爾小姐也",
        "unit_id": 104914,
        "voice": "vo_adv_5213073_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想當弟弟的",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐呢！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_5213073_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "姐姐？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "確實這個蛋糕，",
        "unit_id": 104914,
        "voice": "vo_adv_5213073_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "充滿了姐姐之力……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "身為弟弟的永久終身榮譽殿堂級姐姐，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也不能這麼輕易就認定別人是姐姐。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歉了！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104914,
        "voice": "vo_adv_5213073_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在我和璃乃之間！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果是「次女」的位置",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是可以的喔。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們姐妹一起把弟弟夾在中間，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好好地寵愛他吧♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那、",
        "unit_id": 126511,
        "voice": "vo_adv_5213073_008"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那個……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那、",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那我就恭敬地",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "接受了……？",
        "unit_id": 126511
    }
]