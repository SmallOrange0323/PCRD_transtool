[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼、呼……！",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，害你被捲進麻煩事裡，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n還得跟我一起逃跑，真是對不起是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我十二輩子都不會忘記將軍的恩情是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但是，我可無法眼睜睜地看著，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n盜賊們在城鎮裡鬧事是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以我想都沒想就出手了，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這也是沒辦法的事是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "身為忍者或武士，見義不為乃無勇是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但結果我們還是逃跑了，真是對不起是也……",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_004"
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們先在這附近找地方躲起來是也～",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "躡手躡腳、前腳後腳、豬肉水餃……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈呼呼呼，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "狀況總算是穩定下來了是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我們先暫時在這個洞穴中好好地休息一下吧。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "跟妮諾一起冷靜下來是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖說如此，這個洞穴有點昏暗呢。",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n感覺好像隨時會有躲起來的蛇或蝙蝠出現似的……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……我可以在將軍的身邊待一會嗎？",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿嘿，果然還是將軍的身邊能讓人放鬆呢。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我有帶醋昆布喔，如果將軍肚子餓了，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n記得要跟我說是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咦，將軍？",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n你好像有事情想問我呢，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是什麼呢？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "因為，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者跟武士都很帥啊！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "他們幫助弱小的人不求回報，真的是英雄呢。",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n他們是非常棒的人是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸、將軍問我有沒有看過",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n忍者或武士嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸嘿嘿嘿～其實我有看過是也。",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在我還小的時候，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n有去看過雜耍團是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個時候看到的忍者跟武士帥氣的模樣！",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n到現在還是令我印象深刻……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "想忘也忘不了是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且啊，如果有忍法的話就什麼都做得到。",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能站著睡覺、一隻手穿衣服、",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不用動手就能吃飯……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非常方便是也～",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸嘿嘿，開玩笑的是也。",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然放輕鬆這件事情，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n也很重要……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但也不只有這一點而已。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍一定是那種立志統一天下、讓世界和平，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n讓大家都露出笑容而天選之人是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以我希望能一直以厲害的忍法幫助將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "成為那樣的忍者或武士，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n就是我的夢想是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "未來我也會努力修練忍法的，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_025"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n請將軍多多指教是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸嘿嘿嘿，雖然我還不夠成熟，",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但此後也請將軍多多指教是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……！",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是的，將軍！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這可真是我最大的光榮是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "喂，這裡有聲音傳出來喔！",
        "unit_id": 811,
        "voice": "vo_adv_1030007_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哎呀，好像被發現了呢。",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咚！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然事已至此，就只能戰鬥了是也～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n出來一分勝負，小火開始慢慢打，途中大火燒一燒是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030007_031"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來也要繼續努力，一起統一天下吧～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後妮諾跟{player}平安無事地突破重圍了。\n雖然是一場很麻煩的戰鬥，兩人加深了彼此之間的羈絆後，\n開心地踏上回家之路。"
    }
]