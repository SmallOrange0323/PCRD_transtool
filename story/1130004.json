[
    {
        "type": "background",
        "background": "501000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──茶會結束後，草原恢復了寂靜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而草原上有著步未獨自一人的身影，她正在替茶會收拾善後。"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸嘿嘿，",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "茶會辦得很成功，太好了呢……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "花草茶跟點心都很好吃，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "而且大家也都很開心♪",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "準備的點心也被吃得一乾二淨……",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "藥草還剩一點呢。",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n這個分量",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "應該正好可以泡一人份的茶？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……要是用這些藥草",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n幫{player}前輩\n泡杯茶，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不曉得他會不會高興……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩！？",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n你、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你什麼時候開始在這裡的！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "來幫我收拾……",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也跟璃乃她們說了，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n畢竟最後茶會變成在款待我，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以至少讓我負責收拾善後……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩……",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那麼，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然有些不好意思，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但可以",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "麻煩你幫忙",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "收拾桌子嗎？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我老是",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "受到{player}前輩的照顧呢……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真想回點什麼禮，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好好傳達我的感謝，可是……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦！？",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n那、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒什麼事啦～～！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然還是太害羞了說不出口呀……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_009"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也不用現在立刻就說嘛……？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n反正今天我也已經很努力了…………",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？　",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩在發光……？",
        "unit_id": 113011,
        "voice": "vo_adv_1130004_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒想到前輩還會發光，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然很厲害呢……",
        "unit_id": 113011
    },
    {
        "type": "still",
        "still": "113000401"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_011"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為您、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n送上所點的柴郡貓鬆餅～！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚……",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_012"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "穿著這麼可愛的衣服讓我好緊張，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n感覺做什麼都不太順利呀……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n店裡的童話主題活動",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "能不能快點結束呢……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "步未，",
        "unit_id": 1,
        "voice": "vo_adv_1130004_013"
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "\n有新的客人進來囉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "歡、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "歡迎光臨，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "您……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……！？",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那不是{player}前輩嗎！？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n他、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "他他、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼會來這裡～～！？　",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要是這打扮被看到了，我……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n會害羞到死掉吧！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我還是",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "先去躲起來……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "躲、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "躲在可以偷看前輩的地方……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "麻煩妳去接待",
        "unit_id": 1,
        "voice": "vo_adv_1130004_018"
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "那位客人囉，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "\n步……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "妳、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "妳怎麼一副死到臨頭的表情呀！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不……",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒什麼……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n啊啊，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "媽媽，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請原諒女兒不孝，讓您白髮送黑髮人……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "雖、",
        "unit_id": 1,
        "voice": "vo_adv_1130004_020"
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "雖然不太懂是怎麼回事，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "總之",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "打工處的前輩",
        "words": "麻煩妳囉……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "事、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_021"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "事已至此，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只能做好覺悟了，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "步未！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n要好好款待{player}前輩才行！！　",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "歡、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_022"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "歡迎觀臨本店！！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請用",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "開水～！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_023"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒問題！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……咦，",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_024"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "奇怪了？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n該、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "該不會，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩沒發現是我？　",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這、",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這麼說也是……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我常常",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "被說長得很不起眼，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n有時候其他人甚至不會發現我站在旁邊……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……更何況，",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_026"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我跟{player}前輩，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n不久前才總算進展到互相自我介紹而已……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……嗯，",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_027"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我得轉換心情才行！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n換個想法，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這就代表我可以專心款待前輩了呢！　",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩在入學考的時候",
        "unit_id": 105531,
        "voice": "vo_adv_1130004_028"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幫了我大忙，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
