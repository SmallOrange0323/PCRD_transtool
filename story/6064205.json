[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あんた、",
        "unit_id": 114511,
        "voice": "vo_adv_6054205_000"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ダンスを踊ったことはあるの？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたしはよく",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お父様に連れられて行ってたから",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n少しは教えてあげられると思うわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "えっ！？　",
        "unit_id": 114511,
        "voice": "vo_adv_6054205_001"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "アキノさんと踊ったことがあるの！？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "そっか、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ほんとアキノさんに気に入られてるのね。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……すごいじゃない！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "素直でよろしい！",
        "unit_id": 114511,
        "voice": "vo_adv_6054205_002"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あまり固くやるつもりはないわ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "昔遊んだ時みたいに、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "楽しく踊りましょ！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "もう！　",
        "unit_id": 114511,
        "voice": "vo_adv_6054205_003"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ほんとにあんたは素直っていうか……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あたしもよ。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "一緒に踊る相手があんたで、",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nあたしもうれしい……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "なんてね！",
        "unit_id": 114511
    }
]