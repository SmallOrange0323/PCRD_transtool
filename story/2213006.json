    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "芙蕾雅──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在術士裡"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被稱為「菲絲雷斯」的少女。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她為了治療與貪吃佩可戰鬥時所受的傷而在沉睡時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n夢見了半年前發生的事情。"
    },
    {
        "type": "background",
        "background": "510410"
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "……緊急代碼確認。",
        "unit_id": 193731,
        "voice": "vo_adv_2213006_001"
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "\n",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "是使用祕密線路",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "進行的插播通話，",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "八斗神局長。",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "嗯。",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_002"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n而且",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "還是用備用末端裝置。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "是誰打過來的？",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "……",
        "unit_id": 193731,
        "voice": "vo_adv_2213006_003"
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "\n這個ID是……",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "……是阿澤爾德高級搜查官",
        "unit_id": 193731,
        "voice": "vo_adv_2213006_004"
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "打來的。",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "\n他應該從三天前，",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "就處於失聯狀態……",
        "unit_id": 193731
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……接起來。",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_005"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「啊──",
        "unit_id": 1,
        "voice": "vo_adv_2213006_006"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "啊──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "日安，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "八斗神局長。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「還有",
        "unit_id": 1,
        "voice": "vo_adv_2213006_007"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "貞奈特小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n看來妳別來無恙，真是太好了。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……阿澤爾德。",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_008"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n你的缺勤申請，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "提出時間有點晚啊？",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「非常抱歉。",
        "unit_id": 1,
        "voice": "vo_adv_2213006_009"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n我",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "稍微花了一點時間準備。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "……準備？",
        "unit_id": 193731,
        "voice": "vo_adv_2213006_010"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「是的──」",
        "unit_id": 1,
        "voice": "vo_adv_2213006_011"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「『潛入』的事前準備、",
        "unit_id": 1,
        "voice": "vo_adv_2213006_012"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n寫好辭呈，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n再來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "就是下定決心……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "以上。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "…………",
        "unit_id": 193731,
        "voice": "vo_adv_2213006_013"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……都說為人母後，",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_014"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "女生就會改變。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n看來",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "男性也不例外呢。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「這是理所當然的。",
        "unit_id": 1,
        "voice": "vo_adv_2213006_015"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n尤其是我家，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "幾乎算是父女單親家庭。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「而且……」",
        "unit_id": 1,
        "voice": "vo_adv_2213006_016"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「以正義、",
        "unit_id": 1,
        "voice": "vo_adv_2213006_017"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "以工作為由。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n我太常",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "把那孩子一個人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "留在家中了。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「如果因為這樣……",
        "unit_id": 1,
        "voice": "vo_adv_2213006_018"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n導致那孩子變成了『走失兒童』，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "回不了家的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n不管要放下什麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我都必須去把她接回來。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「不然，",
        "unit_id": 1,
        "voice": "vo_adv_2213006_019"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n我就再也不能",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "稱自己是那孩子的父親了吧。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_020"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "真可惜。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n像你這麼好的人才，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "可不多見啊。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "菲絲雷斯",
        "words": "局長……",
        "unit_id": 193731,
        "voice": "vo_adv_2213006_021"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "「哈哈。",
        "unit_id": 1,
        "voice": "vo_adv_2213006_022"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n很抱歉，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我違反契約辭職。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n不需要給我退休金喔。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "嗯，",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_023"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "畢竟是規則。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "……對了──",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "既然這樣，",
        "unit_id": 193631,
        "voice": "vo_adv_2213006_024"
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "乾脆就從內部來終結「禁錮」吧。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "如果你能順便",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "掌握超AI",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "和系統的話，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "我會用高價買下來。",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "\n救出女兒後，",
        "unit_id": 193631
    },
    {
        "type": "dialogue",
        "name": "八斗神",
        "words": "你也不想讓她過貧困的生活吧。",
        "unit_id": 193631
    },
    {
        "type": "background",
        "background": "502480"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_025"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……結果。",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_026"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n阿澤爾德高級搜查官",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "也消失了──",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n而且，",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "還是在他一直尋找的女兒面前。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……就算是這樣……",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_027"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "阿澤爾德高級搜查官的女兒，",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_028"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n肯定",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "是很幸福的吧……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n因為有人願意為了救出自己，",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "賭上性命……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "打擾了。",
        "unit_id": 195212,
        "voice": "vo_adv_2213006_029"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n……妳是在休息中嗎？",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……黎薩‧費妲。",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_030"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n離約好的時間，",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "還有點早吧？",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "唉呀，",
        "unit_id": 195212,
        "voice": "vo_adv_2213006_031"
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "對不起。",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "\n",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "黎薩",
        "words": "因為我稍微提早來了。",
        "unit_id": 195212
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_032"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "算了，",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_033"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "沒關係。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不過……",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "沒想到會像這樣，",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "再次和妳對談。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "而且，",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "還是由妳提出的。",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "黎薩‧費妲。",
        "unit_id": 193712,
        "voice": "vo_adv_2213006_034"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n妳不是",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "已經決定要站在尤絲蒂亞娜──",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「貪吃佩可」",
        "unit_id": 193712
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "他們那邊了嗎？",
        "unit_id": 193712
    },
