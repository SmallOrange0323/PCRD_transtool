[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在工作結束後返回蘭德索爾的歸途中，\n日和被突然出現的魔物襲擊。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚……！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我還可以的！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（這個魔物，非常強大！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這樣下去的話……！）",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n為什麼騎士先生會在這裡呢！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "說的也是！得先擊倒魔物才行呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_004"
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總算是結束了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，謝謝騎士先生幫助我！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是騎士先生再遲一點的話，我搞不好就被打倒了呢……嘻嘻",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生只是碰巧路過這裡呀？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但即使如此騎士先生有來幫助我，真的是太好了呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果剛剛對峙的是凶暴的魔物的話，",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也打算溜之大吉呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？剛剛是之前的回禮嗎……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那只不過是互相幫助幫助！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為那個時候，我也有受騎士先生幫助呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，這次得換我回報騎士先生才行呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這是作為騎士先生幫我的回禮！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有什麼困難儘管說，讓我來幫助騎士先生吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸～，",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不要這麼客氣呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算騎士先生拒絕，我也一定要回報騎士先生的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然這樣，騎士先生就要回敬我的回禮……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔唔～，居然用這招呀。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼那麼，我就再回敬騎士先生回敬回禮的回敬――",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔，好像全都是回禮回不完，",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n令人頭昏腦脹呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘻嘻。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣下去，就沒辦法從回禮的無限迴圈中跳出來了呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n總是幫忙人和被幫忙……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然不是壞事，",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但應該還有其他可以做到的事吧……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，靈機一閃！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然如此，那我和騎士先生兩人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一起去幫助其他人就好了呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們兩人去幫助其他人的話，",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n永無止盡的回禮這件事就不會發生了對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當騎士先生想幫助別人的時候，我出手相助！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n當我想幫助別人的時候，騎士先生出手相助！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "像這樣的方式，你覺得如何呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那麼，就這樣決定了呦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不、不行嗎……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「得決定聯絡方式要怎麼辦才好」……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生已經想到那一步去了呀！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "知道騎士先生也興致盎然，真是太好了呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那麼，我們來勾手指約定吧，勾手指呦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來呀，把小指伸出來嘛！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的小指？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "稍等我一下下呦。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等等呦……",
        "unit_id": 100111
    },
    {
        "type": "still",
        "still": "100100201"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哈哈哈！騎士先生嚇了一跳嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n其實那個呀，是手套呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來呀，那就開始了呦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一勾值千金！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n說謊就要吞千針！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是我們的約定呦？不可以毀約呦？",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今後還請多多指教啊，騎士先生！",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n兩人合力去幫助更多的人吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊，我們還在勾手指做約定的途中呢……",
        "unit_id": 100111,
        "voice": "vo_adv_1001002_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘻嘻。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n手～指勾完了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}在心中下了決定，\n要信守與日和一同立下的誓約。"
    }
]