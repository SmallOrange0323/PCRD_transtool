[
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「……………………」",
        "unit_id": 105921,
        "voice": "vo_adv_9101016_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇……",
        "unit_id": 105811,
        "voice": "vo_adv_9101016_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "連血都沒流，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就直接成為一道光消失了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那果然",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是魔物之類的生物囉？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀……",
        "unit_id": 105911,
        "voice": "vo_adv_9101016_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有掉落下什麼東西。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「記憶碎片」呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這個世界上，",
        "unit_id": 105911,
        "voice": "vo_adv_9101016_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有種叫做「記憶碎片」的東西。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "據說將其收集之後進行解放，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便會找回被封印對象的記憶，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓她成為夥伴。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "收集完成還沒成為夥伴角色的「記憶碎片」，",
        "unit_id": 105911,
        "voice": "vo_adv_9101016_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以讓她加入隊伍。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是收集到已經成為夥伴角色的「記憶碎片」，",
        "unit_id": 105911,
        "voice": "vo_adv_9101016_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n便可以使夥伴「才能開花」。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經由「才能開花」，",
        "unit_id": 105911,
        "voice": "vo_adv_9101016_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能使角色成長，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得更加強大。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果沒收集到一定數量的「記憶碎片」，",
        "unit_id": 105911,
        "voice": "vo_adv_9101016_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就不會產生效果，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但日後若還有遇到這樣的敵人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就可能再次獲得。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "收集「記憶碎片」",
        "unit_id": 106011,
        "voice": "vo_adv_9101016_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是變強的關鍵是嗎。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就加把勁來收集吧。",
        "unit_id": 106011
    }
]