    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "拉菲的弓箭",
        "unit_id": 113812,
        "voice": "vo_adv_6048208_000"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "變得那麼大……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "街上也陷入恐慌了……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "怎、",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "怎麼辦啊，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥……",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "說的也是呢，",
        "unit_id": 113812,
        "voice": "vo_adv_6048208_001"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "那可是能實現願望的天使弓箭啊，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n其實它並不想要做出這種事吧。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "好！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "茜里會努力",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "讓它舒暢一些的！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯！",
        "unit_id": 113812,
        "voice": "vo_adv_6048208_002"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "只要有哥哥和姊姊在，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n一定會有辦法的呢！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "讓大家見識",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "雙胞胎天使的力量！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嗯，",
        "unit_id": 113812,
        "voice": "vo_adv_6048208_003"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "雖然我很害怕，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "但那把弓箭一定也很害怕。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n只憑自己，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "它大概已經無能為力了吧。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哪怕是為了拉菲，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "也非得要",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "將它變回原樣不可呢！",
        "unit_id": 113812
    }
]