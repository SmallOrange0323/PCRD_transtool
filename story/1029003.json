[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被望約出來，\n來到碰面的地方。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "久等啦！{player}。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真早呢。你等很久了嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……話說回來，怎麼啦，瞧你一臉得意？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "發生了什麼好事？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你說你從那時開始就一直在學習關於偶像的事？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以現在非常了解偶像了？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，你也更加了解我了吧？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，我有點高興呢。謝謝！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你比其他的粉絲還了解我，",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……這樣不會有點言過其實嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你還真有自信呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你來猜猜看我接下來的工作是什麼。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果比誰都清楚的話，應該知道吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你不知道啊～\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正確解答是演員喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "已經決定下次要演舞台劇了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後啊……關於演戲的部分，",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n有件事想要拜託你，可以嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我沒有什麼表演經驗，所以不太有自信。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你可以當我的練習對象嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你願意幫我嗎？\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了，謝謝！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼首先把腳本讀熟吧。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拿去，這是你的腳本。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也才剛拿到而已，還不知道內容……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "演出的劇碼是「小紅帽」喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼有名的童話故事，你一定知道的吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼，你沒聽過！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是有腳本在，你不用擔心。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是主演小紅帽。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就麻煩你當大野狼和我演對手戲囉。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們趕快開始吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "數分鐘後――――"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒想到你第一次演戲，演技還挺不錯的。\n那麼終於要來到高潮的部分囉。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼你的耳朵那麼大呢？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼你的眼睛那麼大呢？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼你的嘴巴那麼大呢？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真開心……我對大野狼也……",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這什麼啊――！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「小紅帽」是人獸戀的作品嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n總覺得這個腳本不太對勁！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我邊看腳本邊覺得奇怪！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「大野狼幫助了迷路的小紅帽，\n小紅帽照顧著被獵人開槍誤傷的大野狼……」",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這根本不是",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「小紅帽」啊！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、這之後的故事發展是……？\n「兩人的關係從友情昇華為愛情。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n大野狼因小紅帽的親吻而解開詛咒，變回了人類的樣貌……」",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "親、",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "親吻！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這場戲竟然有吻戲！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也、也就是說……",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n 練習的話，就要和他……！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": " 可是，那是……那個……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？等等。",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n 正式演出的時候，大野狼是由其他演員飾演吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我就要和工作的對象演出吻戲……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n ",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要！我絕對不要那樣！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這、這個腳本寫著其他人的名字？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n也就是說……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這不是我的腳本！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來是我拿錯別人的腳本了。\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，抱歉喔。\n這個腳本是錯的――",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦……？\n欸、欸，你為什麼在做筆記啊？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "繼續學習關於偶像的事情……？\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔……你的筆記寫了什麼啊？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我看看……？\n「偶像為了配合戲劇的演出也會接吻」？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我才不會做那種事呢！\n不要寫奇怪的筆記！！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是不會接這種工作的！",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以你大可放心――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，我要你放心幹嘛啊！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我和你又不是那種關係……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，不是……那個，",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也不是說我討厭和你有關係啦……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……啊，",
        "unit_id": 102911,
        "voice": "vo_adv_1029003_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我又在說一些不必要的話了！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚、嗚……我、我得冷靜一點……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "無法冷靜下來的望，\n腦海裡怎麼也忘不掉吻戲的場景。"
    }
]