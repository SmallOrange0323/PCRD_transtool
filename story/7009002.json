    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n剛剛提到的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步真步王國？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "到底是什麼呀？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n應該不是",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "公會對吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所謂的真步真步王國就是，",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是公主而",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這個人是王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n的王國呦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步是公主，",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "{player}是王子的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "王國……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒錯。",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在這個非～常美好的國家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "眾多的人民",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n幸福又",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "快樂的生活著。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真步的王國的話，",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "應該是非常美好的國家吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有點嚮往呢～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼莉瑪",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也成為真步真步王國的子民吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家很歡迎喔。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我可不想被當作馬呦～？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣的話",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "獨角獸怎麼樣呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很適合強悍的莉瑪呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有王子先生\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和獨角獸莉瑪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "肯定非常華麗呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "的確，",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "獨角獸很有童話風格，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "很可愛呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請妳務必～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呃，",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "果然還是不要～～！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "又沒有長什麼角～～！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算沒有角，",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n毛茸茸的毛皮",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也是獨角獸級的呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇！　",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不要再摸了～！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "被真步摸起來太舒服了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一不小心就會湧上",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n成為獨角獸也沒關係的想法了啦～～！！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那不是很好嗎～",
        "unit_id": 101011,
        "voice": "vo_adv_7009002_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "才不好～！",
        "unit_id": 105211,
        "voice": "vo_adv_7009002_014"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一臉幸福的撫摸著莉瑪，\n真步繼續在塔中前進。"
    }
]