    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一名謎之少女突如其來地從天而降，\n而就在{player}接住了她的瞬間，一股劇烈的頭痛也同時襲來，\n最後他便失去了意識……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……之後，又過了三天。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……原來是這樣，",
        "unit_id": 100111,
        "voice": "vo_adv_2101003_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "竟然還發生了那種事情呀。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n可可蘿妳也真是辛苦了呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105913,
        "voice": "vo_adv_2101003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下之事不足掛齒……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比起這件事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為何主人的意識仍然無法恢復之事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n至今，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是無法找出原因。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是肉體上的傷亦或是異常，",
        "unit_id": 105913,
        "voice": "vo_adv_2101003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "皆並未發現。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n替主人進行診察的醫生大人是以",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n『或許就只是精神上的疲勞所造成的。』",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來解釋……",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "210100301"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……優衣小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_2101003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n優衣小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一位在使用恢復魔法上遠比在下更為優秀的人物。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能否麻煩您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "替主人還有那一位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看看呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "當然沒問題唷，可可蘿！",
        "unit_id": 100211,
        "voice": "vo_adv_2101003_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我會盡我所能努力試試看的。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "光之精靈唷――……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這孩子便是可可蘿妳所說的，",
        "unit_id": 100311,
        "voice": "vo_adv_2101003_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那位『從天而降的少女』嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她究竟是什麼人呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下",
        "unit_id": 105913,
        "voice": "vo_adv_2101003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是第一次見到她。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與女性的交友關係相當相～當的廣泛，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此或許是過去的舊識也說不定……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等他們兩個人醒來以後，",
        "unit_id": 100111,
        "voice": "vo_adv_2101003_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們再和他們問問看吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "結果怎樣？",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "still",
