    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真璃路過公園時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n彩羽跟苑正在玩的身影映入眼簾。"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……哎呀，",
        "unit_id": 132331,
        "voice": "vo_adv_5204067_000"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "那是隔壁鄰居。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "彩羽、",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "苑小姐，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "妳們──",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碰！"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "咦咦？",
        "unit_id": 132331,
        "voice": "vo_adv_5204067_001"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "撞到了！？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "沒事吧……！？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "唔唔……",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "痛痛痛。",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "喂，彩羽！",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_003"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n妳不要莫名其妙到處跑啦，",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "很危險啊……！",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……咦？",
        "unit_id": 132331,
        "voice": "vo_adv_5204067_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "欸嘿嘿，",
        "unit_id": 132531,
        "voice": "vo_adv_5204067_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "抱歉喔，小苑！",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n請原諒我吧──！！",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "等……",
        "unit_id": 132331,
        "voice": "vo_adv_5204067_006"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "怎麼回事……！？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "該不會是",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "撞到的瞬間交換了之類的……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "不不，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "不可能有那種事吧！？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "真是的，彩羽，",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_007"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n壞孩子要打屁股喔。",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯……",
        "unit_id": 132531,
        "voice": "vo_adv_5204067_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "一直以來抱歉了。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "會成為不讓小苑生氣的好孩子喔。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "咦……？",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_009"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "唔、",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯，",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "沒錯喔，",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那樣很好喔。",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽",
        "unit_id": 132531,
        "voice": "vo_adv_5204067_010"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "之後也會多幫忙家裡的喔！",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "會努力用功，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "社團也會加油！",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n不會挑食，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "每天也會捶小苑的肩膀",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "的！",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……欸！？",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_011"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽才不會做那種事……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_012"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "那樣的話……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "欸嘿嘿……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "唔",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_013"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "唔唔……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "我可是老眼昏花了啊～",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……啊？",
        "unit_id": 132531,
        "voice": "vo_adv_5204067_014"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "咿咿……",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_015"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "肩膀也",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "舉不起來了……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊嗚！？",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "腰、",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "腰",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "閃",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "到……",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "喂，",
        "unit_id": 132531,
        "voice": "vo_adv_5204067_016"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我才沒僵硬成那樣。",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊，",
        "unit_id": 132431,
        "voice": "vo_adv_5204067_017"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "小苑有反應了！",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "交換比賽",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "是彩羽贏了──♪",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……這竟然是比賽啊。",
        "unit_id": 132531,
        "voice": "vo_adv_5204067_018"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊，",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "真璃，辛苦了～",
        "unit_id": 132531
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……妳好。",
        "unit_id": 132331,
        "voice": "vo_adv_5204067_019"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……是交換比賽啊。",
        "unit_id": 132331,
        "voice": "vo_adv_5204067_020"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n演得還真像呢……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n因為過於沒有異樣感，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "我一瞬間都當真了。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對於苑和彩羽假裝交換卻沒有異樣感，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真璃嚇了一跳。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……前世說不定也曾發生過這種事。"
    }
]