[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，",
        "unit_id": 117811,
        "voice": "vo_adv_6076205_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "靈界",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "究竟是個什麼樣的地方是也？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n除了像小棉花糖這樣",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可愛的妖魔之外，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還有許多惡靈和",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可怕的妖魔，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是個會讓人",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "提心吊膽的地方嗎……？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔喔！",
        "unit_id": 117811,
        "voice": "vo_adv_6076205_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是極樂世界嗎？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這就",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很令人期待了！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然我甚感好奇，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但是眼前最重要的，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是這個世界的統一大任是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n為了能在樂土享福，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我希望活著的時候，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可以盡責地",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "走完一生是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你、",
        "unit_id": 117811,
        "voice": "vo_adv_6076205_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你說什麼！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看來那並不是一個",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可以安穩度日的世界是也……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "鬼雖是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很強勁的對手，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了能夠悠閒生活，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也只能努力戰鬥了！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦……",
        "unit_id": 117811,
        "voice": "vo_adv_6076205_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那裡對我們而言，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "果然還是個",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "未知的世界是也……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n雖然",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "什麼東西都沒辦法帶過去那個世界，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但唯有忠誠另當別論是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了能夠永遠成為",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的家臣，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我一定",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "會把忠誠帶過去的！",
        "unit_id": 117811
    }
]