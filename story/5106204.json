[
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這裡",
        "unit_id": 124111,
        "voice": "vo_adv_5106204_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是不是很陰暗啊……？",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n難以想像這是聖誕節的街道……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "──咦？",
        "unit_id": 124111,
        "voice": "vo_adv_5106204_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你問我是不是很害怕？",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "胡說什麼！",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我才沒有。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "拉菲、艾米",
        "words": "獻上天使的祝福！\n（變坦率吧～）",
        "unit_id": 1,
        "voice": "vo_adv_5106204_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 124111,
        "voice": "vo_adv_5106204_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "其實我很怕，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你一定要陪著我……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "牽我的手，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好嗎？",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "喂，艾米、",
        "unit_id": 124011,
        "voice": "vo_adv_5106204_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不可以過度使用變坦率的魔法喔～",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太寵姊姊對姊姊不是好事，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對吧，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "純小姐？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呃。",
        "unit_id": 124212,
        "voice": "vo_adv_5106204_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如、",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你的另一隻手空了，",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你也……",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "牽我的手……",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我並不是害怕。",
        "unit_id": 124212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……！！",
        "unit_id": 124011,
        "voice": "vo_adv_5106204_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "純小姐，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳又不小心被魔法波及了……！",
        "unit_id": 124011
    }
]