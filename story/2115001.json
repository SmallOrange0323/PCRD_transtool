    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……啊哈哈，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年以前也對我",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "說過類似的話，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "鼓勵了我呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "他說了「妳不用想著要去贖罪」、",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「畢竟都是多虧有妳，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我才會遇見大家啊。」",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……呵呵。",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_034"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真有騎士先生的作風。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……但是，",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_035"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "正因為如此……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這個世界",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被重置了無數次。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不管是快樂的記憶，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或痛苦的記憶，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "每次都會",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "消失的話。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就跟美空說的一樣，",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_036"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這的確是",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很殘酷的事呢……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……是啊。",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不只是回不了現實。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也像是毫無自覺的",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "過了奈何橋啊。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是的……",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_038"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了拯救大家、",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了不讓大家擔心，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也為了",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "守護「現在」重要的記憶。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我已經下定決心了，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不管會有多痛苦，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我都要站起來戰鬥。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以，",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我其實很想要立刻就趕過去。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "去跟怜和日和一起，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n把菲歐",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "給帶回來……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "安靜待在安全的地方，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有時會比在最前線戰鬥還痛苦。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也有",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只能看著少年他們陷入困境的時候。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以我了解",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "優衣的心情喔。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "感同身受。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_042"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我絕對不能",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "被厄莉絲跟美空抓到，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然腦袋明白這件事，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……沒事的，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_043"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n對手",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也沒多少餘裕。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "先不說戰力，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是指心力上的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……是這樣嗎？",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_045"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們都把克莉絲提娜跟似似花帶回來了，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n七冠湊齊了四個人，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還聯手起來。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就對手看來，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們可能會想出什麼強硬的辦法，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n讓我們回到現實世界。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那樣",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "他們肯定會很著急吧。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在準備不全的狀態下，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n打算只抓住少年",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來「創造新世界」的可能性，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在我看來是很大的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就算不能把優衣掌握在手中也有些方法。",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "例如把",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「現在的阿斯特朗」跟優衣整個壓縮，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n來迴避",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "重置",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "發動。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有、",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_049"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有這種方法呀……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要把阿斯特朗的龐大數據整個壓縮，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就像要把整個衣櫃的衣服都塞進旅行箱內。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想要從旁阻撓使計畫崩潰，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也非不可能。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "之所以要妳留在這裡，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是為了讓厄莉絲",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "去選擇那種不完善的方法。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原、",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "原來如此……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然也還有",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為妳必須療傷這件事，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也是因為",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想向優衣道歉。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒事啦。",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年他們當然也不是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無謀地衝出去而已。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n他們絕對會",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "平安無事把菲歐帶回來。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……說的也是。",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_055"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "必須盡心等待，要相信騎士先生他們……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯♪",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……只是……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……菲歐。",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n菲歐啊……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……？",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_058"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n拉比林斯達小姐，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了嗎？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n菲歐",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒事。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不是在講",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "菲歐本身的事，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也跟",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不是在說「現在」的事……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……菲歐她啊，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是作為保全程式安裝進來的……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也就是指",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "安全裝置。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "安全裝置……",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「之前」的阿斯特朗在設計上，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n嚮導小妖精是設定為無法成為攻擊目標，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也不會因傷害而破壞的。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果有那種嚮導小妖精會被破壞，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "發生例外的動作開始執行，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n為了不讓錯誤擴散到中樞，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該會進行中斷指令……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是的，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到底為什麼沒動作呢～",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是那時候有動作的話……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃、",
        "unit_id": 100213,
        "voice": "vo_adv_2115001_064"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唔，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉抱歉。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「現在」不是",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想那種事的時候呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……「之前」的紀錄也不在手上，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "根本沒辦法解析……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以說啊，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n為了不白費這段少年他們正在努力的時間，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我們也得來",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做各種準備呢。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「厄莉絲大人」如果有預想我們的行動，",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "並因此急躁的話就好了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若是我們太過安分，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒多久就會被識破。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是那樣──",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就只能",
        "unit_id": 106815,
        "voice": "vo_adv_2115001_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "奉陪她的期待了呢。",
        "unit_id": 106815
    }
]