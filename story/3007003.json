[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一個人完成給公會的委託任務後，\n怜很疲憊地回到了公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我回來了。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和還沒回來嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "歡迎回來。她剛剛才出門呢。",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳們沒有擦身而過嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有耶。……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該不會，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n她又跑去四處搜尋任務的委託人了吧――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我回來了～！怜、優衣，",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有事情想委託我們幫忙的人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我找到了喔～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……歡，歡迎回來。日和妳呀……",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真是的。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把對方趕回去也不太好。就聽聽看吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝！　",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你可以進來了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那就不客氣了。",
        "unit_id": 311,
        "voice": "vo_adv_3007003_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真不好意思，在你們忙的時候……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒關係的啦。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，能說明一下要給我們的委託內容嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這次想委託各位幫忙的，是往返火山期間的護衛任務。",
        "unit_id": 311,
        "voice": "vo_adv_3007003_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "各位是否有聽說過在這個時期，只有在火山才能夠採集到的稀有種類花朵的事情？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有聽過謠傳。那是很眩目逼人的紅色花朵，",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果把它送給心上人的話便能傳達愛意之類。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實我，想把那朵「結緣花」送給戀人……",
        "unit_id": 311,
        "voice": "vo_adv_3007003_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "然後……向她求婚。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "求婚！　好棒喔！",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……怜。那個，我……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唉……我說日和妳啊。為甚麼總是那樣輕易答應別人？",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n公會經營可不是做慈善事業啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣妳也是，太容易被人情綁住不是好事喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抱歉……",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……話雖如此，如果冷淡地拒絕這種委託的話，",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也會影響工會的信譽。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那我們就接下吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "非常感謝妳們！",
        "unit_id": 311,
        "voice": "vo_adv_3007003_017"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n請多多指教！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜……謝謝～！",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還以為妳會說不可以呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘻嘻。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，等這個任務結束之後隔天大家都得好好休息。明白嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好的～！好～！大家往貝利奧火山前進吧～！！",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_020"
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！",
        "unit_id": 100312,
        "voice": "vo_adv_3007003_021"
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是最後一匹了吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為這附近不太有人會靠近，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n比起城鎮附近來說魔物多了很多啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這沒什麼啦。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起這個，感謝你願意和我們一起前來。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "根據花店老闆所言，如果來到這個高度的話，",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n說不定就能找到！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家努力找吧～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喔，",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "喔♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請多多指教！",
        "unit_id": 311,
        "voice": "vo_adv_3007003_026"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──數小時之後"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也滿用心去找了，但還是找不到呢……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不愧是被稱為稀少種類…",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然還差一點點就會抵達禁止進入的管制區……",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只要不放棄一定能找到的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家加油吧～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……找到了。",
        "unit_id": 311,
        "voice": "vo_adv_3007003_029"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我找到了！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n看看這個！就在這裡盛開著！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……真的呢……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "恭喜恭喜！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "非、非常感謝！",
        "unit_id": 311,
        "voice": "vo_adv_3007003_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這就是結緣花……！",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能在火山開花真是了不起的事情呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。在這種對植物生長來說極為嚴苛的環境還能開花……真令人感受的生命的奧妙啊。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_033"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 311,
        "voice": "vo_adv_3007003_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣就好了。如果求婚成功的話，我會和戀人把從花朵取得的種子帶回這裡種植。這麼做的話，下一個想傳達內心想法的人也會來到這裡尋找花朵吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是個好主意。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，在魔物還沒出現之前下山吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜，妳看！",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有人正從底下爬上來呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們手上拿著的花～",
        "unit_id": 911,
        "voice": "vo_adv_3007003_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n該不會就是結緣的花吧！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我沒說錯吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n可以把這個花讓給我嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那、那是……",
        "unit_id": 311,
        "voice": "vo_adv_3007003_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請問，為甚麼會想要這朵花呢？",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請把理由告訴我們――",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……日和，優衣。看看他們的裝扮。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在火山穿著那麼周到的武裝，肯定不是一般人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n恐怕是傭兵。不要再多說了立刻保持距離吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，嗯……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……雖然不見得是恐怖的人……",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "知道了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真抱歉，這不是為了拱手交給你們的東西。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不好意思了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "欸～拜託啦！我們是傭兵耶！如果連這種小事",
        "unit_id": 911,
        "voice": "vo_adv_3007003_044"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n都做不好的話，可是很傷我們的自尊耶！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "我可以付你們錢！再考慮一下吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論如何都不讓步是嗎……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "麻煩你帶著那個人，馬上離開這裡吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們也會在阻止那些傢伙的行動後追上的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請你也小心。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道。真抱歉老是麻煩你。",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你們快走吧！　這裡交給我們！",
        "unit_id": 100312,
        "voice": "vo_adv_3007003_048"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "啊！喂！小伙子等一下嘛！",
        "unit_id": 911,
        "voice": "vo_adv_3007003_049"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抱歉",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_050"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "嗚哇！好刺眼！眼睛睜不開……！",
        "unit_id": 911,
        "voice": "vo_adv_3007003_051"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就在現在吧！　我們上吧，怜、優衣！",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "照這樣的話應該能順利逃走呢……",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_053"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "咦……？　",
        "unit_id": 811,
        "voice": "vo_adv_3007003_054"
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "欸～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "\n你們在前面有碰到我的同伴嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有分隊嗎……！",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_055"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯、嗯～……",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_056"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有碰到呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和……那種態度馬上就被拆穿了啦……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_057"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "欸～你們等一下啦！",
        "unit_id": 911,
        "voice": "vo_adv_3007003_058"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "咦？你們終於趕上來啦？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦？",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們被夾攻了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "對不起……都是因為我的委託……",
        "unit_id": 311,
        "voice": "vo_adv_3007003_060"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "事到如今只好乖乖的把花交給他們――",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "――你們給我等一下！",
        "unit_id": 411,
        "voice": "vo_adv_3007003_061"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n幹嘛讓這群人對你們保持警戒呀！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真的很抱歉，我的部下造成各位的困擾――",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……妳怎麼會出現在這裡？",
        "unit_id": 311,
        "voice": "vo_adv_3007003_062"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你……！還有、那花是……！",
        "unit_id": 411,
        "voice": "vo_adv_3007003_063"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "什麼嘛～原來是小姐認識的人啊！",
        "unit_id": 911,
        "voice": "vo_adv_3007003_064"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "如果是這樣的話，早點告訴我們不就好了嘛！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……真的非常抱歉！",
        "unit_id": 411,
        "voice": "vo_adv_3007003_065"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "其實呢……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳是這班人所屬的傭兵團團長的女兒……？",
        "unit_id": 311,
        "voice": "vo_adv_3007003_066"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我一直想對你坦白……",
        "unit_id": 411,
        "voice": "vo_adv_3007003_067"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n但一想到不知你能不能接受，就感到很害怕。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n所以想送你結緣之花再說明一切……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此！　有想過傭兵先生為甚麼",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_068"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n想要結緣的花，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來是這個原因喔。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "因為小姐說什麼要一個人上火山，",
        "unit_id": 911,
        "voice": "vo_adv_3007003_069"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n我們才擔心地跟上來啦！接著就發現你們已經拿到了這個花，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "所以想請你們賣給我，結果你們就一直逃跑，還真是狼狽啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛才對不起。我們不明就裡就誤會了……",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真丟臉……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_071"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "沒關係啦！",
        "unit_id": 911,
        "voice": "vo_adv_3007003_072"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "……不過之後的發展",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "\n就要看這兩個人了吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "………說實話，雖然現在還有點混亂，但對你的感覺是不會改變的。",
        "unit_id": 311,
        "voice": "vo_adv_3007003_073"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我衷心希望，妳可以收下這朵花！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……好的！",
        "unit_id": 411,
        "voice": "vo_adv_3007003_074"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我很樂意！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……！　二人的心意真的相通了！",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_075"
    },
    {
        "type": "dialogue",
        "name": "傭兵２",
        "words": "嗚喔喔喔！那位小姐終於……！！",
        "unit_id": 811,
        "voice": "vo_adv_3007003_076"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "恭喜恭喜！　",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_077"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "萬歲！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該死的魔物們，對聲音有所反應而聚集過來了嗎……！",
        "unit_id": 100312,
        "voice": "vo_adv_3007003_078"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……傭兵先生們，",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_079"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也能請你們幫忙一下嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "好啊！",
        "unit_id": 911,
        "voice": "vo_adv_3007003_080"
    },
    {
        "type": "dialogue",
        "name": "傭兵",
        "words": "如果能夠幫助小姐的話，我們當然很樂意啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在有困難的時候就要互相幫助幫助，對吧！",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_081"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～！一個接一個撂倒牠們喔！　",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喝呀～！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和一行人順利地打倒了魔物。\n幾天後，那位男性寫的信寄到了她們手上。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「……今後為了讓二人能變得幸福，",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_082"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我一邊接受她父親的鍛鍊，同時以成為未來的傭兵團團長作為目標。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次真的很謝謝妳們的幫忙。」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩人看起來很幸福真是太好了呢。",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_083"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "先前遇到傭兵們時還在想會變成怎樣的說……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唉……沒想到我也會向日和一樣粗心會錯意……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_084"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "打起精神吧，怜！　",
        "unit_id": 100111,
        "voice": "vo_adv_3007003_085"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和我一樣是不值得高興的嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是那個問題啦……",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_086"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……呵呵呵。",
        "unit_id": 100211,
        "voice": "vo_adv_3007003_087"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n對不起。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我忍不住……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拜託別再取笑我了啦～！",
        "unit_id": 100311,
        "voice": "vo_adv_3007003_088"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我有好好反省了～！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──日和她們在歡笑之餘，\n也感受到在不斷完成公會收到的委託的過程中，\n彼此之間的羈絆越來越深厚了。"
    }
]