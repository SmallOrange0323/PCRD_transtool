        "voice": "vo_adv_5098007_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n以後也陪她們共度時光吧。",
        "unit_id": 106812
