    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過呢？",
        "unit_id": 106812,
        "voice": "vo_adv_5098007_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n在重逢之前度過的時光，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也很珍貴喔。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n和少年你們",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在這個夏天所經歷的時光一樣珍貴。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以，",
