    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她們都是如此。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那個生物……",
        "unit_id": 106812,
        "voice": "vo_adv_5098007_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "叫小繆",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來著？",
