        "voice": "vo_adv_5098007_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n回答得很好♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
