        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "容易受到成長的環境影響。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "從這層意義上來說，",
