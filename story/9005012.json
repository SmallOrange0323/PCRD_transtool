    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲學會了畫漫畫的基礎。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再來就只差畫出她心中的畫面。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不好意思，流夏小姐，",
        "unit_id": 106412,
        "voice": "vo_adv_9005012_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跟妳借用了公會小屋。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哪裡，",
        "unit_id": 105611,
        "voice": "vo_adv_9005012_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不用客氣。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳不是想要一個可以畫圖的安靜場所嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不嫌棄的話",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "儘管用我們的小屋吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且，",
        "unit_id": 105611,
        "voice": "vo_adv_9005012_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然有點聒噪，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但這裡還有些閒人在。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該多少能幫上一點忙。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_9005012_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說聒噪也太失禮了吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我這個人一向都是很安靜的啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……那幾個孩子就另當別論了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我說妳……",
        "unit_id": 102711,
        "voice": "vo_adv_9005012_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳要把我畫進漫畫裡。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然後",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要畫出我跟那位大人的親熱蜜月……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我命中注定的人長得更美形，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "得修正才行……♪",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯。",
        "unit_id": 100911,
        "voice": "vo_adv_9005012_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "多加一點效果音",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "或是帥氣的讀音",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比較好吧？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒辦法，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我來幫妳標注好了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咆哮吧，畫筆！",
        "unit_id": 101311,
        "voice": "vo_adv_9005012_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚呀啊啊啊啊──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我早就想嘗試當個漫畫助手了喵～♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "【暮光流星群】的各位，",
        "unit_id": 106412,
        "voice": "vo_adv_9005012_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n還勞煩妳們幫忙，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的很感謝妳們。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這是紀念日的禮物對吧？",
        "unit_id": 105111,
        "voice": "vo_adv_9005012_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不用客氣啦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳會不會累啊？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我這裡有可以不眠不休工作的藥……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要試試嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那、",
        "unit_id": 101311,
        "voice": "vo_adv_9005012_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "截稿日前的創作者們夢寐以求的珍品！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然如此，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香也只能祭出那個魔法了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n截稿日延後魔法！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其名為",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「全力下跪磕頭」！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唔，",
        "unit_id": 102711,
        "voice": "vo_adv_9005012_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不對，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那位大人的容顏，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是更可愛、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更端正、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "更美麗的……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再改、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再改、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "再改～～～！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "漫畫這東西真有意思！",
        "unit_id": 100911,
        "voice": "vo_adv_9005012_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n把熾炎戰鬼煉獄血盟暗黑團的故事",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "畫成漫畫或許也不錯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "描述我這位團長",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "和副團長吉格魯特的征戰歷史……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……抱歉，",
        "unit_id": 105611,
        "voice": "vo_adv_9005012_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是有點聒噪，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "根本就吵翻天了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果妳需要安靜，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我再另外幫妳準備個地方如何？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不，",
        "unit_id": 106412,
        "voice": "vo_adv_9005012_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這裡很好。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想描繪的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是這樣的光景。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此",
        "unit_id": 105611,
        "voice": "vo_adv_9005012_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也來",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "幫點忙好了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那真是太好了，",
        "unit_id": 106412,
        "voice": "vo_adv_9005012_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "流夏小姐……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比起前去尋找吉祥物的那時候，",
        "unit_id": 105611,
        "voice": "vo_adv_9005012_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "她現在更有笑容了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……這是好事。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在熱鬧話語的圍繞下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲的禮物製作進度持續推進。"
    }
]