[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，\n千歌找{player}到鎮上碰面。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你來了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天我有點事情想拜託你。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "其實，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "接下來我想去尋找唱喚術的新歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果可以的話，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你可以跟我一起去嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以嗎！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要去的目的地已經決定了，那我們馬上出發吧。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天就請你多多指教囉。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……這麼說的話，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我好像還沒有詳細跟你說過",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "關於唱喚士的事情呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "由我來說有點奇怪，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但唱喚術跟唱喚士其實非常稀有。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這個能力是出生時偶然獲得上天授與，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n無法由父母繼承給孩子的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱喚時所需的歌曲，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也隨著唱喚士而改變。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們必須用一開始從各自的心中油然而生，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n專屬於自己的歌曲來唱喚精靈。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "用自己的歌聲成功唱喚精靈時，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才是能獨當一面的唱喚士。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n然後將那首歌",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "寫成樂譜。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "獲得了自己的歌曲後，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "再去唱其他唱喚士所留下來的歌曲，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "便能召喚出別的精靈。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們唱喚士就是像這樣，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n將我們自己的歌曲",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "託付給下個世代的夥伴們。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我也有把自己的歌寫成樂譜保存下來。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "至今為此，我一直都一邊旅行，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一邊找尋同為唱喚士的夥伴。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我希望能獲得許多歌曲，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "成為能保護許多人的唱喚士。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我現在也是像這樣祈求著，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一邊持續著旅程。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在我難得來到蘭德索爾這麼大的城鎮，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以正在從各式各樣的人們那裡收集資訊。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多虧如此，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這次我說不定，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n能與還在世的唱喚士見面呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還沒有遇見過自己以外的唱喚士，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以現在非常的期待喔。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……如果能遇到的話就好了呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_013"
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……如果資訊正確的話，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這附近應該住著一位失明的老婆婆。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那位老婆婆應該知道些什麼才對……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那邊有人影……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們去那裡看看吧！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嗯？是誰來了呢？",
        "unit_id": 611,
        "voice": "vo_adv_1042005_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，不好意思……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們――",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "――妳，",
        "unit_id": 611,
        "voice": "vo_adv_1042005_018"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是唱喚士對吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這年頭能碰到可真是稀奇呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n為、為什麼您會知道呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嗯，",
        "unit_id": 611,
        "voice": "vo_adv_1042005_020"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "聽到妳的聲音就知道啦。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "因為老婦我也一樣是唱喚士啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "您……！",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n沒想到",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "您竟然就是唱喚士本人……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我今天是因為有所請求才來的。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請把您的歌曲傳授給我！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……像我這樣老糊塗的歌曲如果能幫上忙的話，就隨妳喜歡吧。",
        "unit_id": 611,
        "voice": "vo_adv_1042005_023"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n樂譜的話就在這裡",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……拿去吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真的可以嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我以為需要有像試煉一樣的東西……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……老婦我啊，",
        "unit_id": 611,
        "voice": "vo_adv_1042005_025"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "以為這個世上",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "已經沒有唱喚士的同伴啦。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "沒想到有妳這麼年輕有力的唱喚士來到這裡。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n我當然也想要出點",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "微薄之力啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……謝、謝謝您！",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我一定會將您的歌曲發揮功效的！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "道謝什麼的就免了。",
        "unit_id": 611,
        "voice": "vo_adv_1042005_027"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n你們趕快回去你們應該要保護的地方吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……好的，那麼我們就失陪了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_028"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……喔喔，對了。",
        "unit_id": 611,
        "voice": "vo_adv_1042005_029"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "告訴妳一件好消息吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "在不久之前……",
        "unit_id": 611,
        "voice": "vo_adv_1042005_030"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "也有個年輕的唱喚士來到這裡。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n跟妳一樣，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是來尋求我的歌曲的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "除了我以外的",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "唱喚士……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "您說的是真的嗎！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就像老婦我一樣，我相信對妳來說，",
        "unit_id": 611,
        "voice": "vo_adv_1042005_032"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n知道有同伴存在是一件令人高興的事情吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n我只是想跟妳說這件事而已啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的，謝謝您！",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_033"
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}你聽到了嗎！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n除了我以外，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好像還有其他現任的唱喚士存在！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "竟然有跟我同世代的夥伴在……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我希望有一天能夠遇見那個人！",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你為什麼在笑呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……啊！",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我、我真是的……竟然因為太過高興，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就興奮過頭了呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是……我果然還是想遇見那個人呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果我找到了那個人的話，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你也能像今天一樣陪我一起去見他嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你……！",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……真是的，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我可不能像這樣一直興奮忘形呀。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "冷靜點……冷靜點……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你可以聽我說一點我自己的事情嗎…… ？",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……其實，我最近很害怕把情感表現出來。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "特別是唱歌時，必須要把情感帶入歌曲之中……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，我到目前為止從沒做過這種事。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "開始當偶像後，我便覺得害怕……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我呢……希望能透過我的歌讓聽眾開心。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因此才會想著，希望能讓大家都喜歡我的歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我從與望、紡希及{player}相遇後才開始這麼想的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是現在，我越是這麼想越擔心，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_045"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果唱不好該怎麼辦……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的心情會不會沒有傳達給聽眾……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "之類的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為這樣，讓我最近有時覺得唱歌很痛苦……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_046"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……我該怎麼辦才好呢……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "相信我的粉絲……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "連我自己都很意外，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "現在的我竟然有這麼多的粉絲……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那些人，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_049"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是因為喜歡我唱的歌，所以才支持我的吧？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我已經讓很多人，",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_050"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "變得喜歡我唱的歌了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這麼重要的事情我竟然都沒有發現……",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_051"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我真是，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還不夠格呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……但是，多虧了你讓我發現到這件事。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_052"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……感覺從明天開始，我又能好好唱歌了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……其實我下次有場個人現場演唱會。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_053"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果可以的話，你可以來看嗎？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_054"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那可不行喔！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我不喜歡你受傷。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你不用擔心。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_055"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這次的現場演唱會是風雨無阻照常舉行的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們約定好囉？請你一定要來喔。",
        "unit_id": 104211,
        "voice": "vo_adv_1042005_056"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n如果{player}肯來，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得我能更加更加努力準備演唱會！",
        "unit_id": 104211
    }
]