        "name": "宮子",
        "words": "\n這麼一來，就可以吃很多布丁冰棒囉～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "謝謝你陪我過來呢！　{player}！",
