        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還以為你變成變態來的。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔唔，",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_038"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如果是跟{player}的話……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚嗚嗚嗚。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "果、果然還是會很害羞！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "絕對不行！　拒絕來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "除此之外的方法……",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_039"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，看到了！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n裡面有動物的皮草來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這個洞窟",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_040"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好像是獵人的休息室。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有皮草在這邊，真是幫了個大忙～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我要把你跟我捲在一起。",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_041"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要是你再昏過去，我可受不了。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "呼……",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_042"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "跟剛才比起來舒服多了～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "像這樣跟你貼在一起很讓人安心呢～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}熱呼呼的，很溫暖來的！",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_043"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子因為死了的關係所以身體冷冷的，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "反而覺得這樣更加暖和～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯……",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_044"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子感覺",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好像有點想睡覺了……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁冰棒……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好想吃……來……的……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘶……嘶……",
