        "voice": "vo_adv_1082003_056"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘿嘿嘿♪　",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_057"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只要這樣貼在一起的話，就會跟剛剛一樣溫暖了。",
        "unit_id": 108211
    },
