        "voice": "vo_adv_1082003_050"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那個，我記得是在這附近……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好棒喔～！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_051"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "變得硬梆梆來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n趕快來吃吧～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……嗯～♪　",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_052"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有種冰冰涼涼的口感，好好吃來的～♪",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一開始很像是雪酪來的……",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_053"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不過放到嘴巴後，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n平常吃的布丁味道就一口氣在嘴裡擴散開來……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這的確是非常像布丁又不像布丁！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_054"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "超革命性來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……哈啾！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_055"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "雖然風雪停了，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n但果然在雪山吃冰冰的東西，還是會覺得冷呢……",
