        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "剛才好危險來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n如果我還沒死的話，就會死掉呢！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，你一直貼在我身上嗎？",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_047"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘿嘿，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "或許就是因為這樣吧。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "因為很放心才睡著來的。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "多虧了這皮草，",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_048"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你的臉色也變好了一點。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n而且，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我覺得氣溫也比剛才要來得溫暖一點呢。",
        "unit_id": 108211
    },
    {
        "type": "background",
        "background": "500541"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "果然風雪已經停了～！",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_049"
    },
    {
