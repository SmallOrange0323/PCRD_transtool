        "voice": "vo_adv_1082003_045"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……啊，",
        "unit_id": 108211,
        "voice": "vo_adv_1082003_046"
    },
    {
        "type": "dialogue",
        "name": "宮子",
