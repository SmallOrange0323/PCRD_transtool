[
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "──騎士先生……！",
        "unit_id": 133111,
        "voice": "vo_adv_2209003_000"
    },
    {
        "type": "still",
        "still": "220900301"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靠著格蕾斯與{player}通力合作，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n成功破壞了闖入居住區的蠻賊貪鯊號。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而倭的反擊卻斬碎了格蕾斯與薇歐莉特──"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "502112"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊、",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊啊……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "死、",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "死掉了……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "嗚哇～",
        "unit_id": 130213,
        "voice": "vo_adv_2209003_003"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "屍體四分五裂耶～",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n有夠血腥～",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不如說，",
        "unit_id": 130213,
        "voice": "vo_adv_2209003_004"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n妳們竟敢打壞我的小鯊鯊──！",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n我絕不原諒妳們！",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不過不過，",
        "unit_id": 130213,
        "voice": "vo_adv_2209003_005"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n現在人也死掉了──！",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀哈，呀哈哈！",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就算是女人跟小孩──",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "在賭局中輸掉也是會喪命的。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你連這種事都不懂嗎？",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "既然都學到一課了──",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你也去死吧。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我記得",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是叫做「陪葬」。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n當有大人物死掉時，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "身邊的人不是就該追隨一起死嗎。",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊、",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_008"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n再這樣下去……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這次……",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_009"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "一定要說出口，",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "阻止姊姊才行……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……動手吧，姊姊。",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_010"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n把他砍得四分五裂。",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_011"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "又來了……！　",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀哈哈！",
        "unit_id": 130213,
        "voice": "vo_adv_2209003_012"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n笨菜姊",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "好可怕～！",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼。",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再見了──",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "之後可別變成鬼跑出來啊。",
        "unit_id": 130013
    },
    {
        "type": "background",
        "background": "502112"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──什麼！？",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_014"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我趕上了。",
        "unit_id": 133013,
        "voice": "vo_adv_2209003_015"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n對吧，",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "你好，",
        "unit_id": 133013,
        "voice": "vo_adv_2209003_016"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n我變成鬼跑出來了。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這當然只是個玩笑。",
        "unit_id": 133013,
        "voice": "vo_adv_2209003_017"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳、",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_018"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳的腳……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不如說",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "全身都有點透明……！",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "難不成",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "真的是幽靈……！？",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "應該說",
        "unit_id": 133013,
        "voice": "vo_adv_2209003_019"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是亡靈才對。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不過，",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "兩者也差不了多少。",
        "unit_id": 133013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘖……！",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_020"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n原本以為已經贏了的賭局，後來才說不算數……",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n沒有比這更讓人火大的了！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "第二回合──",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我要「加碼」！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n管妳是亡靈還是幽靈，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我要殺到妳死為止！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……",
        "unit_id": 133013,
        "voice": "vo_adv_2209003_022"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「──【蠻賊三姊妹】，",
        "unit_id": 193711,
        "voice": "vo_adv_2209003_023"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n請稍等一下。」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳、",
        "unit_id": 130113,
        "voice": "vo_adv_2209003_024"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳是……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呃！",
        "unit_id": 130213,
        "voice": "vo_adv_2209003_025"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n這不是老土眼鏡女嗎～",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「……",
        "unit_id": 193711,
        "voice": "vo_adv_2209003_026"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "抱歉忙碌之中打擾。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n不過，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "能請妳們過來一趟嗎？」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊！？",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_027"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n究竟有什麼事，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "接下來才要一決勝負耶！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「阿剌克涅女士",
        "unit_id": 193711,
        "voice": "vo_adv_2209003_028"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "說有東西想讓妳們看，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n接下來會由我帶路。」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……",
        "unit_id": 130013,
        "voice": "vo_adv_2209003_029"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「……我就當作妳同意了。",
        "unit_id": 193711,
        "voice": "vo_adv_2209003_030"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "話說回來──」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「……公主‧薇歐莉特",
        "unit_id": 193711,
        "voice": "vo_adv_2209003_031"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "跟她的隨從，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n我還以為當時的暗殺失敗了……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "但原來是這麼一回事。」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "「算了，",
        "unit_id": 193711,
        "voice": "vo_adv_2209003_032"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "也不用在意。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "如果只有這點程度，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "算不上什麼威脅。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n隨時都能抹殺──",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "不對，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "應該說『超渡』比較恰當。」",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……呼。",
        "unit_id": 133011,
        "voice": "vo_adv_2209003_033"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "得救了。",
        "unit_id": 133011,
        "voice": "vo_adv_2209003_034"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "老實說，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我的體力已經被消耗得差不多了。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "她也……",
        "unit_id": 133011,
        "voice": "vo_adv_2209003_035"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "雖然",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "算不上沒事。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "公主，",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n妳能動嗎？",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……格蕾斯。",
        "unit_id": 1,
        "voice": "vo_adv_2209003_036"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n那個……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我的左手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不曉得掉到哪裡去了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "──來，",
        "unit_id": 133011,
        "voice": "vo_adv_2209003_037"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "這是妳的左手。",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133011
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "還有需要幫忙的事嗎？",
        "unit_id": 133011
    },
    {
