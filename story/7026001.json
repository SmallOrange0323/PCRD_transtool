        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "一樣的……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "這樣呀！",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_017"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜和大姐姐",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是一樣的呀！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是的！",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是一樣的！！",
