        "voice": "vo_adv_7026001_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦！？",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還好！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒事！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如你所見，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我活蹦亂跳得蹦蹦跳──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "…………",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………沒、",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒什麼。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚……",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "比起感到傻眼，沒反應更讓人難堪啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我居然硬想炒熱氣氛，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真是傲慢的想法……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "冷場還無法順勢救場的丟臉小丑，就是我……",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好想就這樣被埋進塔的牆壁裡，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變成無機物……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但這還只是開頭而已……",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "應該還有機會可以和露娜變得更要好……！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "機會不是等來的，",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而是爭取來的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "書上",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "有這麼寫著。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既然如此……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "透過共同的興趣",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "讓對話順利進行的高級技巧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n想和露娜變得更要好的話，就只有這個方法了！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼看起來，",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜也是出於某些原因而被歸類在邊緣人裡。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而她也擁有一個很重要的玩偶",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "作為精神支柱。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是說，我和露娜",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要好好聊過就能理解彼此！　",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的腦內模擬出來的情境是……",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒有朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我有一個玩偶朋友哦。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那就是",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個好朋友號！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……咦？",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜也",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和那個玩偶是朋友吧？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我很快就發現了",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們是一樣的呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_016"
    },
    {
        "type": "dialogue",
