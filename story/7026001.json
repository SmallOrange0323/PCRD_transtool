        "words": "那就是這個好朋友號！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……咦？",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_042"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露娜也",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_043"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和那個玩偶",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是朋友吧？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很快就發現了",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是一樣的呢！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_044"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "一樣的……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好！",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_045"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "目前為止都和剛才模擬的一樣！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n接下來，只要約她一起聊天──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不是哦。",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_046"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_047"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜的玩偶",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_048"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "跟露娜不是朋友哦。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "所以，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大姐姐和露娜──",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不一樣哦。",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_049"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………咦？",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_050"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……大姐姐，",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_051"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "妳好奇怪喔。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大、",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_052"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大受打擊──！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……大哥哥。",
        "unit_id": 111411,
        "voice": "vo_adv_7026001_053"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n那邊有樓梯哦。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "一起走吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………呵。",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_054"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵呵……",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_055"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我還以為能跟露娜變得更要好呢……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……嗚嗚嗚！",
        "unit_id": 104011,
        "voice": "vo_adv_7026001_056"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現實",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對邊緣人太嚴苛了～！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對和美好理想截然不同的無情現實，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n碧在心裡如此吶喊著。"
    }
]