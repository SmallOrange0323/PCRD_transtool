    {
        "type": "dialogue",
        "name": "兩人",
        "words": "啊哈！啊哈哈！\n呵呵！呵呵呵！",
        "unit_id": 1,
        "voice": "vo_adv_7026001_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
