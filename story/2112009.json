    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊……",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_033"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_034"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只是在集體潛意識裡的邂逅……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能夠像現在這樣。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n能夠，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "與你對話。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n能夠，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "觸碰到你……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這一刻，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_035"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我不知道已經等多久了……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一而再、",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_036"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一而再、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一而再、",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一而再──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n歷經數不盡的循環",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "與重試。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "每當重置的「條件」達成，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_037"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "便被迫去檢視那些紀錄。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n被迫將龐大的資料，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "烙印在我腦海中。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那些，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_038"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你與夥伴們牽起羈絆的光景。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n那些你和草野優衣，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如何走向生命終結的畫面。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……有時候，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "甚至……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還會有你，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "回應某人心意的紀錄……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我這個，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_039"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "從草野優衣複製出來的角色，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也在反覆體驗宛如無間地獄般輪迴的過程中……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "變質了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n再也，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無法復原了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然而──",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_040"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在我完全，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "被磨耗殆盡之前，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我終於像這樣，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "與你相遇了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……簡直，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如奇蹟一般……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_041"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不需要再輪迴了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我不會，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再離開你了。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_042"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會終結一切。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我會把你，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "從這個扭曲的世界救出來。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_043"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n選擇我",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "吧。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_044"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n讓我為你，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "實現願望──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──騎士先生。",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_045"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對。",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_046"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我，",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會毀滅阿斯特朗。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在未達成重置「條件」的狀況下，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_047"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n結束世界管理裝置的職務。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "然後，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_048"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再創造一個新的世界。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒錯──",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一個只有我和你的，",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_049"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "理想鄉。",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………！",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼──！",
        "unit_id": 1,
        "voice": "vo_adv_2112009_051"
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──理想鄉這種詞彙，",
        "unit_id": 107111,
        "voice": "vo_adv_2112009_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別隨隨便便掛在嘴邊啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人工智慧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以一介非人類的模仿者而言，",
        "unit_id": 107011,
        "voice": "vo_adv_2112009_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳的表現還挺出色的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不愧是吸收了我們的智慧結晶",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「米奈娃」的傢伙。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "不過，",
        "unit_id": 107311,
        "voice": "vo_adv_2112009_054"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "如果妳想毀滅世界，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n我們就不能坐視不管。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那當然。",
        "unit_id": 106811,
        "voice": "vo_adv_2112009_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n無論這個《阿斯特朗傳奇》，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "變成什麼模樣──",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟還是我們的作品嘛。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "七冠……",
        "unit_id": 129013,
        "voice": "vo_adv_2112009_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若妳以為驅逐我一次，",
        "unit_id": 106811,
        "voice": "vo_adv_2112009_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我就會放棄拯救少年的話，那還真是太小瞧我了呢～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不過……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗚～",
        "unit_id": 106811,
        "voice": "vo_adv_2112009_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "痛痛痛痛……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想不到一天之內",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "竟然要「縫合」自己兩次。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "某某人",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "完全都不懂得手下留情呢～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那有什麼辦法？",
        "unit_id": 107111,
        "voice": "vo_adv_2112009_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慘遭敵人洗腦了啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和妳互相廝殺還挺愉快的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這點我不否認……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107011,
        "voice": "vo_adv_2112009_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳要怎麼做呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "厄莉絲。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "即便是在夢中，",
        "unit_id": 107011,
        "voice": "vo_adv_2112009_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n尚未完全覺醒的妳，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n想要擊退我們所有人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想必也不是一件易事。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "說到底。",
        "unit_id": 107311,
        "voice": "vo_adv_2112009_062"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "要是在此發生衝突的話，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n可能會超越他能承受的容量，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "造成人格崩壞。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "雖然我個人",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
