    {
        "type": "dialogue",
        "name": "日和",
        "words": "步未……",
        "unit_id": 100113,
        "voice": "vo_adv_6042304_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很不簡單呢。",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "每次都能在不知不覺中靠近別人，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "完全感覺不到她的氣息。",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她一定",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是個非常厲害的忍者吧……！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然是這樣對吧！",
        "unit_id": 100113,
        "voice": "vo_adv_6042304_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她現在一定也在",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "某個地方觀察著我們唷！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我看看……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就在那棟建築物的陰影處！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才沒有呢，",
        "unit_id": 100113,
        "voice": "vo_adv_6042304_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "步未一定只是",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在隱瞞她的忍者身分而已！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "平常隱藏自己的氣息也只是",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "她修行的一部份！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "步未",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是帥氣呀～！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 100113,
        "voice": "vo_adv_6042304_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你是忍者！？",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你會用些",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼忍術嗎！？",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "見識看看那個！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": " 替身術！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來來，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "砰地一聲變出替身試試！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼逃走了！",
        "unit_id": 100113
    }
]