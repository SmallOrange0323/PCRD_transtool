[
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人進入山中，\n將發現的巨靈一個一個打倒。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這台魔力探測機，",
        "unit_id": 106012,
        "voice": "vo_adv_5013004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好精準啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n目前為止，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們幾乎都沒遇到",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "巨靈以外的魔物。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯！",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_001"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "因為機器只探測魔石，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "只要設定好頻率就能辦到！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你連這種事都會啊……",
        "unit_id": 106012,
        "voice": "vo_adv_5013004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真厲害。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "托探測機和大家的福，",
        "unit_id": 109411,
        "voice": "vo_adv_5013004_003"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我們收集了不少魔石碎片了。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "那麼我們差不多",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_004"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "可以回去密斯塔爾西亞了？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯～……",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_005"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那個",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "目前似乎還是有難度。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n因為我們還沒找到",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "魔石的核心……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "核心……？　",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_006"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "那是什麼啊？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "就是魔石的中心位置，",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_007"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "作用為建構出隱藏於石頭中的術式，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n可說是魔石的基礎唷。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "魔石會對魔力產生反應，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "基本上就是靠核心――",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "…………？？　？？",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_008"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "是露",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "的問題嗎？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n安前輩所說的話，",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露突然一句都聽不懂？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "簡單來說，",
        "unit_id": 106012,
        "voice": "vo_adv_5013004_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是魔石最重要的部份還沒找到",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的意思。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "喔～",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_010"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "原來如此。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n凱留真聰明。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "好孩子",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "好孩子",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "即使被妳誇獎，",
        "unit_id": 106012,
        "voice": "vo_adv_5013004_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不會感到高興……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不過，",
        "unit_id": 109411,
        "voice": "vo_adv_5013004_012"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "真苦惱呢。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "光是這樣繼續隨機打倒巨靈……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "咦？　",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_013"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "收集而來的魔石發出光芒，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "似乎指向了某個方向……！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "啊……！？　",
        "unit_id": 109411,
        "voice": "vo_adv_5013004_014"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "你看！",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n山頂上……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "光芒",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "四散開來形成一道裂縫……！",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "真的耶，",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_015"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "意思是要我們往那個方向前進嗎……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您認為呢？",
        "unit_id": 105913,
        "voice": "vo_adv_5013004_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼了？",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……強行呼喚你過來，真抱歉。",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為我有急事找你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我知道這麼做並不妥，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是這次請你原諒我吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我已經掌握到有訪客從異世界",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "穿越而來的消息。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然而，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為這個緣故，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個世界發生了很嚴重的問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛出現的光之裂縫，",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若放著不管，將會演變成重大事態。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那道裂縫……",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會創造出不應存在於",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這世上的魔物唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為這個緣故，",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "世界也跟著產生扭曲……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果不趕快打倒那些魔物，",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這些細微的異常狀況",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將漸漸失控，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n最後可能釀成毀滅這個世界的悲劇……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以你必須",
        "unit_id": 190011,
        "voice": "vo_adv_5013004_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幫助那幾個孩子",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "打倒魔物。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你們同心協力拯救這個世界吧！　",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託你了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你務必",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將這件事",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "轉達給可可蘿――",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……人、",
        "unit_id": 105913,
        "voice": "vo_adv_5013004_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您剛剛突然呆住，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下好擔心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是不是",
        "unit_id": 105913,
        "voice": "vo_adv_5013004_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身體不舒服……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您接獲來自愛梅斯大人的神喻？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913,
        "voice": "vo_adv_5013004_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人到底",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n向您說了",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼事呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那道裂縫",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會創造出強大的魔物嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "的確……",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_027"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n那道裂縫，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "很不尋常。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n周圍有魔力漩渦生成了……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……",
        "unit_id": 109411,
        "voice": "vo_adv_5013004_028"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "魔石的核心說不定就在那裡。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我們應該去查看一下……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5013004_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
