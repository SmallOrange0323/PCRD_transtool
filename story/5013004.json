        "name": "凱留",
        "words": "欸！　",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "中大獎了！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這都是露的功勞，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹得好！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "咦？　",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_064"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露被誇獎了？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎呀，",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "仔細想想，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳能幫上忙也是理所當然的事。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟你",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和安、古蕾婭一樣，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都是馬納歷亞魔法學院",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的學生嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "是的！　",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_066"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "安前輩和古蕾婭前輩都是",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n非～～",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "常優秀的學生唷！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想也是。",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "安擁有",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很強大的魔力，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n古蕾婭的力量也不容小覷……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "待在這麼優秀的兩人身邊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會覺得討厭嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "咦？　",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_069"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露沒想過這個問題。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "為什麼露要覺得討厭呢？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因、",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_070"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成績不好對吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n經常把補考、不及格之類的話",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "掛在嘴邊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "沒錯……",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_071"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露不僅被封為補考女帝，",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "還是不及格女王呢。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "而且補課女神的頭銜，",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "也快要加到我身上了。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳費盡千辛萬苦才能做到的事情，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那兩個人",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "輕輕鬆鬆就能辦到吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不會覺得反感",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_073"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是覺得自己愚蠢嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "嗯～？",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_074"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露聽不太懂。",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露就是露，",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_075"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "每天都過著充～",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "滿",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "青春活力的生活！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "所以",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "每天都感到非～",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "常",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "高興唷～！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_076"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是嗎。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該怎麼說呢？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "露，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳啊……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "嗯？　",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_077"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "什麼事？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "凱留？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳啊……",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_078"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比我想像中的還要…",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n腦袋空空呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "露還以為自己被誇獎，",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_079"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "沒想到馬上被批評了！？",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈哈。",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_080"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼關係嘛，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還有點羨慕妳呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "凱留～！　",
        "unit_id": 109211,
        "voice": "vo_adv_5013004_081"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳在這裡嗎～！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "啊，",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_082"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "是安前輩的聲音！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，對了對了，",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_083"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來說好分頭尋找妳的下落，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果就把他們給忘了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們趕緊去跟他們會合吧。",
        "unit_id": 106011,
        "voice": "vo_adv_5013004_084"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還得告訴他們，妳立下大功了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "是的！",
        "unit_id": 109311,
        "voice": "vo_adv_5013004_085"
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "\n……",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "大家～！　",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "我找到洞窟了唷！　",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "露",
        "words": "在這裡～！",
        "unit_id": 109311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "露和凱留順利和{player}一行人會合，\n並且往洞窟前進。"
    }
