        "voice": "vo_adv_5108422_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n看來神明大人這次終於滿足了呢。",
        "unit_id": 124511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也就是說，",
