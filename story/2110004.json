        "type": "dialogue",
        "name": "凱留",
        "words": "我也不能",
        "unit_id": 106012,
        "voice": "vo_adv_2110004_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放著這些傢伙們不管嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……而且我也很掛心陛下的狀況……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若是走穿越鄰近湖邊的大斷崖的那條路，",
        "unit_id": 104711,
        "voice": "vo_adv_2110004_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "便能大幅縮短路程。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這就得靠",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "凱留的飛行魔法了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼。",
        "unit_id": 106012,
        "voice": "vo_adv_2110004_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我的魔法很粗暴，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們最好要有心理準備啊！",
        "unit_id": 106012
    },
