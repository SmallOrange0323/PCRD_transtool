        "voice": "vo_adv_2110004_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳們真要",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "回去蘭德索爾嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "待在這裡",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還比較安全吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "凱留",
