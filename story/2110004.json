        "voice": "vo_adv_2110004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過既然對方，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能夠使用空間跳躍，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n老實說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我認為應該沒有哪個地方是安全的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯。",
        "unit_id": 105812,
        "voice": "vo_adv_2110004_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們得爭取時間。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我也很想",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再跟妳們好好聊聊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃遍",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡的美食……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_2110004_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要回去的人有",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "貪吃佩可小姐、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "凱留小姐、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雪菲小姐，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n以及【王宮騎士團】的各位，對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n至於王子先生和",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可可蘿小姐……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暫時還會留在這裡受您們照顧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必須讓主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好靜養才行……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是在跟貪吃佩可",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有大家討論過後的結論。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果所有人一起行動，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "風險實在太高了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖說如果真要投入戰鬥，",
        "unit_id": 106412,
        "voice": "vo_adv_2110004_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}應該也要",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "跟我們一起走才對。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就目前的狀況來看，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "城鎮上",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "似乎並不見厄莉絲和魔物的身影……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊。",
        "unit_id": 104311,
        "voice": "vo_adv_2110004_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n透過通訊魔法",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "與【動物苑】的夥伴聯繫後可知，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然事情造成不小的騷動，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但那些人似乎沒有出面稱王的樣子。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "假如真有危險，",
        "unit_id": 104711,
        "voice": "vo_adv_2110004_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們會抵擋在前，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為大家爭取逃跑的時間。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只是究竟能發揮多少效用，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這就不清楚了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來，",
        "unit_id": 101711,
        "voice": "vo_adv_2110004_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家身體狀況都還好嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳們應該還要再多躺著休息的……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯──老實說，",
        "unit_id": 106012,
        "voice": "vo_adv_2110004_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也很想再多休息幾天……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身為蘭德索爾的公主，",
        "unit_id": 105812,
        "voice": "vo_adv_2110004_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可不能老是丟著城鎮不管。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我得盡快，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趕回去才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_2110004_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我也……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不能再這樣",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "待下去了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "贊恩他……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐和{player}，",
        "unit_id": 106412,
        "voice": "vo_adv_2110004_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請好好療傷吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟接下來的情況，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看似會越來越險惡。",
        "unit_id": 106412
    },
