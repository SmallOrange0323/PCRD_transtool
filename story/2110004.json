        "type": "dialogue",
        "name": "真步",
        "words": "【慈樂之音】的各位，",
        "unit_id": 101011,
        "voice": "vo_adv_2110004_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳們有何打算呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果想暫時待在這裡，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好好休息也無妨喔……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 102913,
        "voice": "vo_adv_2110004_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖說我們",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也很想跟大家",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一起行動……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但我們，",
        "unit_id": 104211,
        "voice": "vo_adv_2110004_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "想針對製作人小姐她們被施加的洗腦魔法，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n去找出解除方法。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們認為，",
        "unit_id": 105411,
        "voice": "vo_adv_2110004_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這對怜大人她們",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "肯定會有幫助的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得也是。",
        "unit_id": 105812,
        "voice": "vo_adv_2110004_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果能解除克莉絲提娜小姐和似似花小姐的洗腦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她們肯定會願意",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再次助我們一臂之力的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！",
        "unit_id": 102913,
        "voice": "vo_adv_2110004_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n大家也是，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要多加小心！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們所有人，",
        "unit_id": 105812,
        "voice": "vo_adv_2110004_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定還會再平安相聚的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……大家都離開了呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣做",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的好嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我說",
        "unit_id": 101711,
        "voice": "vo_adv_2110004_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "霞啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家團結合作一起迎擊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的不可行嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果可行的話，",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實我也很想這麼做。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "敵人的真面目、力量和數量都還是未知數，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n很難擬定作戰計畫",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "更何況，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "？",
        "unit_id": 104311,
        "voice": "vo_adv_2110004_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n怎麼了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "臉色這麼難看。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我已經從怜她們和貪吃佩可她們那裡，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n詳細得知厄莉絲的事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n以及",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你們與",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【憤怒‧軍團】的戰鬥。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果我的猜想沒有錯的話，",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很可能……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有人向敵人通風報信。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在【美食殿堂】或",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【破曉之星】當中的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "某人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦──！？",
        "unit_id": 101711,
        "voice": "vo_adv_2110004_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "通、",
        "unit_id": 101011,
        "voice": "vo_adv_2110004_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "通風報信……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 104311,
        "voice": "vo_adv_2110004_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳是說內奸嗎！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不、",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n無論是在下等人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是【破曉之星】她們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n都是賭上性命一路戰鬥過來的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即便想靠著流通情報獲得利益，",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是在戰鬥中喪命",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不就血本無歸了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n說什麼向敵人通風報信，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下實在無法想像……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "抱歉、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "抱歉，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是我說明的不夠好。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說起來，",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我為何會說出這種話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n主要是因為我對原本計畫要向【憤怒‧軍團】據點",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "發動奇襲，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n結果卻反遭到對方襲擊的這件事",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感到耿耿於懷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事……",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉比林斯達小姐若沒有向",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真軌先生和諾維姆小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請求援軍的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "情況真的很危險。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對，",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是這件事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【美食殿堂】和【破曉之星】的奇襲",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "完全曝了光，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而妳們一無所知的埋伏卻大獲成功。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這也就是說……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人當中的某人，",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n把情報洩漏出去了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下等人視為目標的索爾魔珠，",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被美空",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "搶先一步給奪走了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可、",
        "unit_id": 105913,
        "voice": "vo_adv_2110004_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下還是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不敢相信……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會有這樣的事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我把話先說在前頭，",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當事人也有可能，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是在毫無自覺下把情報洩漏出去的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "例如使用類似通訊魔法的魔法",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來讀取想法，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n或是在其體內",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "埋藏可以收音的魔法道具之類的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或許是太樂觀的想法……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但這種可能性也是有的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "通風報信者……",
        "unit_id": 101011,
        "voice": "vo_adv_2110004_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來如此。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "妳才沒有阻止堅持要返回蘭德索爾的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "公主小姐她們。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "讓大家兵分二路，",
        "unit_id": 101711,
        "voice": "vo_adv_2110004_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n看哪邊的行動會曝光……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳是想這麼做吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是想賭賭看。",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，就像貪吃佩可所說的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "厄莉絲一旦展開行動，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n哪裡有誰、有多少人，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "全會被摸得一清二楚，毫無安全可言……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我、",
        "unit_id": 104311,
        "voice": "vo_adv_2110004_049"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說啊，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳不叫優衣她們",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來為公主她們送行，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n難不成就是因為……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然，",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是因為通風報信者，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n很可能就是【破曉之星】當中的某人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n確定可以排除在外的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就只有諾維姆一個人而已。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "暫時這樣吧。",
        "unit_id": 101411,
        "voice": "vo_adv_2110004_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們就先觀察看看……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "敵人究竟會對哪一邊",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "採取行動。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……這樣啊。",
        "unit_id": 104311,
        "voice": "vo_adv_2110004_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼這段期間，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就先專注於{player}他們的治療囉。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，{player}？",
        "unit_id": 101711,
        "voice": "vo_adv_2110004_053"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你要吃飯？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還是",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要我呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好～的♪",
        "unit_id": 101711,
        "voice": "vo_adv_2110004_054"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我會準備很多",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們家鄉的全餐料理喔～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "差不多是時候",
        "unit_id": 101011,
        "voice": "vo_adv_2110004_055"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "除了粥品之外，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也該讓王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嚐嚐",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "獸人族所精心烹調的料理了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是啊！",
        "unit_id": 104311,
        "voice": "vo_adv_2110004_056"
    },
    {
        "type": "dialogue",
        "name": "真琴",
