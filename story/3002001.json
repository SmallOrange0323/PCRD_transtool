[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哦哦哦！",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今天，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n睽違已久的慶典終於到來了～☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "小智姐、",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n快點快點",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄秀就要開始了，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n得趕緊找到好位子才行！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以的話最好是舞台正前方！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣一來，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "搞不好可以被選為",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　\n被壞人挾持的人質之類的角色，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n搞不好就有機會上台了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就算沒有，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我們也能從近距離",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看到純活躍的表現了～☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n跑起來的話小心會跌倒的喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要拉我啦，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n反正舞台又不會跑走，不用那麼急……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且再怎麼說，我們也有特別座的入場券了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "況且英雄秀，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n每次都沒什麼人來啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為和平的時期久了的關係吧。",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們【王宮騎士團（NIGHTMARE）】也是，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n很久沒有什麼實戰經驗了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "實際上，也沒有什麼名氣呢。",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "曾經是舉國上下所舉辦的公演，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如今的英雄秀，已經變成純粹演給小朋友們看的節目了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "應該隨處都有，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不錯的位子可以坐吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以拜託妳了，乖一點好吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "收到！",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這是託小智姐的福才能弄到手的入場券，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會聽話點的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "今天",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "能邀請我來真的非常感謝，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n謝謝妳～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "與其說是撿到便宜，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不如說本來入場券就會多出來了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要分給認識的朋友也是有限的，只好自己買了而已。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能好好道謝很了不起喔，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n好孩子好孩子♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哎！？",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n摸摸頭還是請妳饒了我吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊……",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n怎麼越想討人嫌，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就越是惹人憐愛呢♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不要啊～",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我最不會應付的就是打針和摸摸了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n英雄的守則第13條，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n『任何英雄都有弱點』！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那我的弱點是什麼呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過我要自稱英雄還差得遠呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……唔！",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………。",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長～！　",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在做些什麽好玩的事情啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼不把我叫來一起玩呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不管是戰爭或是革命還是虐殺，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n任何事情我都樂意幫忙的喔！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果能夠逗樂我，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就服從你！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "依照約定，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可以以客座身份，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓你進【王宮騎士團（NIGHTMARE）】喔！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是太無趣的話，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那可就糟蹋一切了喔！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "☆",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "喔！？",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那是怎麼回事，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n有人在搗亂！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英、英雄秀已經，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n開始了嗎……！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不是，這不是什麼秀！　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那個瘋女人，到底在想什麼！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是當真要砍下去了，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n難道要打算讓我們傳統的儀式染上鮮血嗎！？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那是……",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不知道為何總是出現在【王宮騎士團（NIGHTMARE）】的據點裡，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n像是惡之女幹部一樣的存在！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那位阿姨，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也要上台演出嗎～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她姑且也算是，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n【王宮騎士團（NIGHTMARE）】的一員喔。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是一個完全感覺不到正義感的人，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也不想承認她是我們的伙伴。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉，妳待在這裡。",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……純，我來幫忙！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不用了",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "客人們都已經進來了。",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小智……小智團員，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳就在觀眾席上做好防備，以免讓他們受到波及。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "到時有個萬一，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就麻煩妳進行避難疏導了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說得倒是挺從容的嘛！　",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要是在過去，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n哪還有什麽『萬一』啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！　",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真開心呢！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳看看！孩子們的表情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這些相信著絕對正義的守護者的人們，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都被我擊敗，變得一副慘不忍睹的模樣了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "告訴這些",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可愛的小朋友們！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這世上，根本沒有什麽『絕對』",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不斷尋找過，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但到現在我見都沒見過，聽也沒聽說啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "『絕對』是存在的。",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不用刻意尋找，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在這個世界上到處都有。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，不要擺出那種表情了……",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以叫我『克莉絲』的人，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只能是我的朋友！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "欸，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳可以做我的朋友嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不行吧，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我還是有自己性格很差的自覺的！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才沒有什麼『絕對』，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果不能做我的朋友至少做我的敵人吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看吧，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳還是相信著『絕對』。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，妳放心吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正義，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是絕對會贏的。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……喔！",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太厲害了！　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n標榜『絕對攻擊，絕對防禦』的副團長。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n克莉絲提娜迴避了所有的攻擊！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我在訓練或是實戰中",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_053"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也是一次都沒有有效擊中過！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也正因如此！",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "團長……純，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n將克莉絲提娜誘導至舞台上的木箱上，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是為了要『把木箱踢飛』！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果不是對克莉絲提娜本人的話，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n攻擊就行得通！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n打得到！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，如果時機過了的話就沒有任何意義了！　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_056"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n純利用了那一瞬間，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n用熟練的經驗完美演繹了出來！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太棒了！　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_057"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n看來我能從團長身上學的東西，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還有很多呢……☆",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哦哦哦！",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_058"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n太厲害太厲害了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "果然英雄是無敵的～☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "切……",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n什麼嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是壞人嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊～……",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是的，我才在想除了團長以外都太沒意思了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道這是，演戲還是什麼東西嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是英雄秀。",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_061"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是能帶給孩子們夢想，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是我們最重要的使命。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳不介意的話，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也來協助我們吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，我有作為英雄的資質嗎？　",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果只是扮家家酒的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就你們自己去玩吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "興致都沒了。",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這次，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就放過妳一馬！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "走在夜路上，",
        "unit_id": 107111,
        "voice": "vo_adv_3002001_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n自己多加小心吧！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這次的戰術，下次不會再管用了",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呼。",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_066"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總算，是撤退了嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那傢伙，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_067"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還挺厲害的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要牽制住她也是挺辛苦的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純！　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_068"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n果然，妳是最棒的！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "甚至利用了克莉絲提娜副團長的突襲，",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_069"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n讓英雄秀的氣氛更加高漲了！　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是完美的計劃，我們都為妳喝彩♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呃，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這不好說……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如妳所見，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是飾演『凶惡怪人』的角色。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "瞧，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_071"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是一副壞人的模樣吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "飾演英雄的其他團員們，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_072"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n卻都拿克莉絲一點辦法都沒有。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一下子，就都被擊倒了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "情勢所趨，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_073"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我只好把克莉絲擊退了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "欸！？　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_074"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n啊，確實是呢。　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n比較像英雄的那些人，都在舞台上跌跌撞撞的！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那、那該怎麼辦？",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_075"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是要，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n中止英雄秀的演出嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "欸～，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_076"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那我可不要！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這可是幾個月才有那麼一次",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n的樂趣啊～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那倒是……",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_077"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小智，就由妳上台演出吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳來的話，看上去也比較像正義的一方……",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_078"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳也夠精明，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n即使是即興演出，也能飾演英雄吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "從今天起，",
        "unit_id": 104711,
        "voice": "vo_adv_3002001_079"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳就是『白色猛虎』了……☆",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦哦，",
        "unit_id": 100511,
        "voice": "vo_adv_3002001_080"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是新英雄的誕生！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "能親臨歷史的瞬間，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我與有榮焉……☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦咦……？　",
        "unit_id": 103711,
        "voice": "vo_adv_3002001_081"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
