[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在散步的{player}，碰巧遇到鈴奈時……"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦，這不是秀才嗎！",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂喂喂，待會有空嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n你知道接下來那邊要舉行時裝秀嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎？秀才也知道啊！",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真高興～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？ 你問為什麼人家會很高興？",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為人家也會出席那場時裝秀呀。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以希望秀才能夠來喔～",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想讓你看看人家模特兒的樣子。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為了秀才，人家已經事先拿到入場券了――",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這張給你，絕對要來看――",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇，好刺眼……",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個是之前的？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "發生什麼事了？到底怎麼回事！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016008_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呀～！！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，秀才你終於來了～",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶，可以幫人家補習嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拜託～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n考試快要到了～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果很多科不及格，",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家說不定會被迫辭去模特兒的工作？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有趣的活動也差不多要開始了，",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n現在辭職不就損失很大嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你問是什麼事情？",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個嘛……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊！有了，有了！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看看那邊的海報？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "椿丘時裝發表會！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就像是時裝秀之類的活動。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家下次會出席這場活動喔～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像是相當盛大的活動……",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為被拜託出席，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就一口答應了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？太草率了嗎？",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家身邊的人都是這樣喔？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，對了～",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才也來嘛～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拿去，票給你！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是相關人員專用的票，所以是特等席喔！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n可以清楚地看到人家模特兒的樣子！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "絕對要來喔～",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n沒來的話，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會超級生氣喔！",
        "unit_id": 101631
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。活動當天――"
    },
    {
        "type": "still",
        "still": "101600801"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇～好厲害！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n到處都是人！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "女顧客１",
        "words": "呀！",
        "unit_id": 1,
        "voice": "vo_adv_1016008_021"
    },
    {
        "type": "dialogue",
        "name": "女顧客１",
        "words": "\n鈴奈～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客２",
        "words": "真的讚到爆！",
        "unit_id": 1,
        "voice": "vo_adv_1016008_022"
    },
    {
        "type": "dialogue",
        "name": "女顧客２",
        "words": "\n超可愛的～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客２",
        "words": "\n呀！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家好～人家是鈴奈喔～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n謝謝大家～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "時裝秀果然很好玩～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不知道秀才有沒有來看？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才在哪裡呢？",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家看看……？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在這麼多的人群當中，",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n果然還是找不到吧？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……啊！發現秀才～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在那麼遠的地方還能找到，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家該不會是天才？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然之前沒能在人群中找到朋友……",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難道因為是秀才，人家才能找到？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂～秀才～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n……從這裡叫的話，好像聽不到。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼對他眨個眼好了！",
        "unit_id": 101631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "結束了～！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂喂喂，秀才！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n你覺得人家模特兒的樣子如何？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很厲害對吧？",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就算讀書不行，但人家很努力在當模特兒喔！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～對了！",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家剛從伸展台對你眨眼，有注意到嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈～說什麼呢～",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "眨眼而已就臉紅，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才太可愛了～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的？",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也對人家模特兒的樣子",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n神魂顛倒嗎～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～？你說真虧人家能找到你？",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對呀，人家也很驚訝。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n畢竟人很多。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是無論有多少人，",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家都覺得能找到秀才喔～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為啊，秀才是人家重要的――",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_037"
    },
    {
        "type": "dialogue",
        "name": "女顧客們",
        "words": "啊！",
        "unit_id": 1,
        "voice": "vo_adv_1016008_038"
    },
    {
        "type": "dialogue",
        "name": "女顧客們",
        "words": "\n是鈴奈！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客們",
        "words": "\n幫我們簽名～～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇、",
        "unit_id": 101631,
        "voice": "vo_adv_1016008_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇哇！？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
