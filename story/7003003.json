[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸欸，",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "望望會經常去約會嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "約會！？",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個嘛，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該不常",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼突然這樣問？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個嘛。",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我一個很要好的模特兒朋友，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n最近就很熱衷呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "似乎，",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是和嚮往已久的男孩約會的樣子。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像很開心的樣子呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我就在想，",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是大家都常常約會",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就我一個人還什麼都不知道。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家……",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會是怎樣的呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為偶像是禁止戀愛的，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n至少我是",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對約會完全不瞭解呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "唔——",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "回想起那開心的樣子，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就覺得好羡慕啊～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　欸秀才，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們一回到蘭德索爾就來約會吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這點子很不錯吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸欸！？",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　和{player}約會！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以的啦！！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為、",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為什麼啊？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要問為什麼，",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們給人的印象很重要，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是被人目擊到和他約會，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可能會傳出一些奇怪的謠言～也說不定。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔唔～",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這就好比是在對自己說的一樣，好內疚啊……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊一一",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "望望都這麼說了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那還是作罷好了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然如此",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那我和望望來約會就沒問題了吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家都是女生就沒關係了吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和我？",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊啊～",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣應該就沒事了吧？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了！",
        "unit_id": 101611,
        "voice": "vo_adv_7003003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那我們就約好了哦～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然一談到約會就會讓自己感到緊張，",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但應該是更輕鬆的才是……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可能是我自己自我意識過剩了吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是……",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不錯吧，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "約會。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也好想，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和{player}約會呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，{player}！？",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎、",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼了嗎！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　幹嘛盯著這邊。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　我的表情不停變化問我是不是發生了什麼事嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒、",
        "unit_id": 102911,
        "voice": "vo_adv_7003003_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒事啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，快點，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要快點追上鈴奈才行。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "走吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望一邊臉紅，\n一邊拉著{player}的手走去。"
    }
]