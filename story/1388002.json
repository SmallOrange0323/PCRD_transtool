[
    {
        "type": "background",
        "background": "502223"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人來到了墨丘利度假村的泳池區域。"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天也滿熱鬧的呢。",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們馬上……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "從昨天的部分繼續吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n走吧……♪",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要不要先去",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "漂漂河看看呢？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "其實我之前",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就很在意了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也順便借游泳圈吧。",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n之前就在想",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "靠著游泳圈載浮載沉的",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該也很有趣呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "水一直在",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "流動呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n雖然很理所當然……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但什麼都不做",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就會一直前進",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺很厲害呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你也趕快",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "抓住這邊。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟這裡人很多，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要小心別被沖散了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "水溫也冰冰涼涼的，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好舒服啊……♪",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也可以就這樣一──直漂下去呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後似乎就會",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "繞完整整一圈，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "回到這裡。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就這樣順著水流慢慢漂，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以悠悠哉哉地欣賞",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n泳池邊的風景，感覺很棒呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟散步走過去比起來，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又是",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "完全不同的感受。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那朵花。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是熱帶地區的花嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n顏色鮮豔，看起來好漂亮……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊！",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那邊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你看……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是滑水道！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "速度很快呢……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唉呀……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "游泳池的客人１",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1388002_009"
    },
    {
        "type": "dialogue",
        "name": "游泳池的客人１",
        "words": "不好意思。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "游泳池的客人１",
        "words": "\n不小心撞到……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我才感到抱歉……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊。",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在，那邊……！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}，請看那邊。",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有噴泉──",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那邊有……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊…………",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經結束了……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "剛才有噴水池，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看起來好漂亮。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也想讓{player}看看……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經結束了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明是想要一起探索「快樂」的，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有點",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "小失望……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不會，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟水聲很大聲，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n泳池的人也越來越多了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "多到只要稍微有點距離，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "聲音就聽不到了……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊。",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想起來了。",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "之前",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "遊俠測驗集訓的時候……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有做過不發出聲音，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只靠暗號溝通的練習。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "在危急關頭",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "表達「停下」",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「快離開」",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "之類的……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "向夥伴發出信號的練習。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那時是",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟喵特一起練習的……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天要不要",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "把那個用在遊玩上呢？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不是為了應對危險……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而是當作",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一起享受今天一整天的暗號",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……你",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "覺得如何？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好啊！",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那麼，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首先",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要決定暗號是什麼呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "遊俠那時候",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有的是揮手，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有的則是要發出聲音……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是聲音會被蓋住，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "比手畫腳的話",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也可能會注意不到。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "用輕輕觸碰當作暗號如何？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "即使隔著游泳圈也能傳遞訊息……",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n像這樣",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "，輕輕",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "戳你",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "覺得如何？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首先，",
        "unit_id": 138812,
        "voice": "vo_adv_1388002_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "戳",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一下。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這個……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就當作是「往邊邊移動」",
        "unit_id": 138812
