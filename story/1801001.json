    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n真的非常感謝您！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別這麼說，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我不能做會讓店家困擾的事情嘛！",
