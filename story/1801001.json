[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "治好了幼兒化的問題，重新回歸打工的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在送完貨返家的途中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看到了正在修行的日和。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔喵喵喵──！！",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_000"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼、",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只憑現在的我……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "面對那些人根本……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊咧？",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你已經可以照常工作了呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也不能太勉強自己喔？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生的病剛好……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那種狀況能說是生病嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總之，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "突然勉強自己的話會出問題的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有什麼問題的話我也可以幫忙，所以要告訴我喔。",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有困難的時候，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就要互相幫助幫助……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦……？",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我沒事呀？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我跟平常的我一樣充滿活力！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你看你看，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "充滿活力的姿勢！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼樣？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好厲害呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然我面對騎士先生，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就沒辦法隱瞞自己呀。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以換個地方說話嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛好我也覺得想休息一下了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──嗯，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就挑這裡吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n看出去的風景也好，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺能夠放鬆下來呢♪",
        "unit_id": 100111
    },
    {
        "type": "still",
        "still": "180100101"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……要說到我沒有活力的原因呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就是之前，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們不是和【憤怒‧軍團】的人戰鬥過嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也變成公主型態戰鬥的那時候……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……其實啊，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那時候我是有點自信的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n只要有了公主型態的力量，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就不會輸給卡里莎他們。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我要用這個力量守護大家……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我卻守護不了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不只是卡里莎，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "連阿澤爾德也很厲害。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n原本以為我們是不相上下，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "結果並不是這樣……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那時我好不甘心。",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不對，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "直到現在，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我還是很不甘心……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生也……？",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "放、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "放心吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可沒有就這樣放棄了喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種心情揮散不去，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也很討厭嘛……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以呀，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我不想再輸了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會更加努力喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想變得更強，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "強大到不會輸給他們！",
        "unit_id": 100111
    },
    {
        "type": "still",
        "still": "180100102"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……所以，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生也打起精神吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "把我的活力，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "傳送給騎士先生──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……這樣呢♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不客氣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有困難的時候就要互相幫助幫助，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對吧♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "傳過去了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n好～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "收下更多活力吧──！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n唔喵──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣如何呀──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……和騎士先生說過話後，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就有精神了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生也恢復活力了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這個話題就到此為止！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們一起變強吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "強大到不會輸給【憤怒‧軍團】的成員們！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n只要一起特訓，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總會有辦法的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個嘛……",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說來我沒有想過這個問題──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n總之，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為了不忘記至今以來的努力，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我和平常一樣在鍛鍊自己……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過以過去相同的做法，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n感覺好像對變成公主型態時的能力",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有什麼幫助。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺需要一些",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和至今為止不同的全新練習……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嗯～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過到底該怎麼做才好呢～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生也幫我一起想的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定能找到答案的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "事不宜遲，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們就趕快一起想吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也來用力想想看！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嗯～",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "…………嗯嗯嗯──",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……不行，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "完全想不到啦──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一直這樣煩惱也不是辦法……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總之先變身看看吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要上囉，騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「轉換‧公主型態！」",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……之類的～",
