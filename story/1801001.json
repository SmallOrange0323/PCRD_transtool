        "name": "日和",
        "words": "嗯……",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_061"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吃得好飽呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這種滿足感……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我現在好像能懂，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n佩可吃飯時總是一臉幸福的那種心情了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_062"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n挑戰那個大胃王餐點成功了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼大份量的餐點，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_063"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我從來沒有吃完過……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺這似乎是還蠻厲害的事情呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "成長……？",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_064"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這也是成長啊。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n挑戰然後完成新的事物，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是成長呢……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我決定了！",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_065"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這樣的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我要來挑戰更多的新事物！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘗試各式各樣的挑戰，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "去做到更多原本做不到的事情！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼一來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想公主型態一定也會變強吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、不過，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大胃王挑戰就只限這一次吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不然可能會給店家添麻煩呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且呀，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_068"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是每天都吃那麼多，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n肯定會變得胖嘟嘟的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我不太想讓騎士先生",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看到那樣的我呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有，",
        "unit_id": 100111,
        "voice": "vo_adv_1801001_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒什麼！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比起那個，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一起決定接下來要挑戰的事吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天直到早上都要跟我一起開作戰會議喔──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夜幕低垂的街道上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n繚繞著日和和{player}暢談的話音。"
    }
]