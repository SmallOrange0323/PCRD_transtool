[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "被困在裡面",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "的這種說法完全不對呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果要出來的話，隨時都能出來喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "反倒是若長時間待在這裡的話，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就會產生精神上融合之類的不好影響……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n想讓你們盡量早點離開呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呣！？",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳是，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才的？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，被什麼結晶？　",
        "unit_id": 100131,
        "voice": "vo_adv_2010099_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一樣的東西所困住的妖精小姐！",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊哈哈。",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妖精呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "已經很久沒有被這麼叫過了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔呣……",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "照這樣來看妳們幾個，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n來到了保存著我的肉體的地方了呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "上一次物理上的接觸啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是多久以前了呀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真令人佩服呀。",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真不愧是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n曾經攻略過索爾之塔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "偉大的女孩子們……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳們幾個，乍看之下",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "和普通人沒什麼兩樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但果然是特別的存在也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是。",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還好這次是妳們幾個，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n如果被懷有惡意的人，物理性的接觸可就傷腦筋了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果不小心肉體被破壞了，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "又或是受到奇怪的干涉，甚至操縱可就不妙了嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀真是的……",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "該和涅比亞討論一下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不把警備從頭檢討可不行。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃～、",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咳咳……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在妳想事情時打斷非常抱歉，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳該不會是叫做",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "『菲歐』這樣的名字吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯？　",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是唷，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在的我叫做愛梅斯喔……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n怜，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳想起來我的事情了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不……",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不知道為什麼，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "見到妳之後",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "腦海中就浮現出那個名字了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦……",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不錯嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看來腳踏實地讓大家進到夢境中的成效出來了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，還不到能完全取回記憶的樣子就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "記憶……？",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從剛才開始就說些讓人聽不懂的話，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳究竟是何人？　",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我們熟識的人嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡又是何處？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又是為何將我們移動到這裡？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳問題還真多呢～",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明我不希望妳們待在這太久的呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正，這也是如同夢境一般的情景嘛……",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n醒來後就會全都忘光了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "詳細跟妳說明也沒什麼太大的意義。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是。",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不知道是偶然又或是有什麼其他的理由，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就當作是對到達這裡的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們幾個表示敬意……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就盡可能的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和妳們說說話吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也當成是妳們踏破了索爾之塔上層的獎勵，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想送給妳們什麼小禮物一樣的感覺就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但現在的我也沒有那種權限，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "除了給妳們些建言之外就什麼都辦不到了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在{player}似乎也正忙著呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像沒有能作夢的空閒……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想找人講話卻煩惱沒對象呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們來的正好也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嚴禁太過於冗長的話題唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺不舒服的話可要告訴我唷，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我馬上就會讓妳們醒過來的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "了解。",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "老實說只是在這個地方，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就能感受到身體的狀況有些奇怪的感覺……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以個人的角度，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也並不打算逗留太久。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "願意和我們談上幾句的話就很感謝了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有幾個問題希望妳能回答……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "首先，",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳知道優衣她人在哪裡嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n她是我們的伙伴。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算妳不特別說明，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我當然也知道優衣她是誰唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是個樂觀又溫柔的好孩子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那種善良的孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管在『那邊』還是『這邊』都已經很難看到了呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "『那邊』？　",
        "unit_id": 100131,
        "voice": "vo_adv_2010099_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "『這邊』……？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這部分就別在意了，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會解釋很久呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果真有興趣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且妳還記得的話……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n之後再向{player}問問看吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}那邊，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像也已經整合好了不少情報的樣子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "比起不管說了什麼都只會被當成做夢而忘記的我，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓他來和妳們說明也比較合適呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}……",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就連他，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳也認識嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯唷，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是從上輩子就開始的孽緣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是賦予我人生的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "恩人唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於妳剛才的提問我的回答是，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優衣她並不在這個地方唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只有那孩子現在還醒著。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在……",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為擔心突然間就睡著的妳們，正試著把妳們叫醒，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還試著對妳們用恢復魔法呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓她太擔心也不太好意思，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我們趕緊把話說完，讓妳們回到那孩子的身邊吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100331,
        "voice": "vo_adv_2010099_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正在做夢嗎……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "保有意識的夢境，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是所謂的清醒夢嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼就只有優衣沒有在這個夢境裡？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100131,
        "voice": "vo_adv_2010099_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明大家都在一起的呀。",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳們幾個不管什麼時候都湊在一塊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就連這個世界被再構築的，那個決定性的瞬間，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳們幾個仍然在並肩作戰著呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}和我，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有妳們三個人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有其他的大家一起同心協力……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在想起來，不管什麼事都很讓人懷念呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總而言之。",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我的這個領域竟然被從物理接觸，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這可是整個世界再構築以來第一次發生的奇事……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不知道到底會發生什麼事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以就讓優衣稍微迴避了一下呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是我主動將她排除的，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了不讓她踏進這個領域而進行了一些處理唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然像是在排擠她一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有點可憐就是了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過。",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "優衣在那場戰鬥的最後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在那最終的局面，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "完成了『某個重要的責任』呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "絕對不能夠讓那孩子想起來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "平時，讓她做夢的時候我也是很謹慎的，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只讓她回想起幸福的回憶，顧慮著這點小心辦事的唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "絕對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不能讓那孩子把『禁忌的記憶』給想起來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "溫柔的那孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很有可能會壞掉呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……？　",
        "unit_id": 100131,
        "voice": "vo_adv_2010099_045"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是怎麼回事？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳的意思是優衣她做了什麼事情嗎，",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吶？",
        "unit_id": 100131
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不用太在意，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "關於這件事真的要請妳們敬而遠之唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為不想讓妳們做什麼推測，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不會說得更詳細了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怜、",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "日和……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還請妳們，多留意一些優衣她的狀況。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果真有那麼個萬一，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請以友人的身分，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在身邊好好支持她。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於『沒被選上的』妳們來說，",
        "unit_id": 190011,
        "voice": "vo_adv_2010099_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這樣請求妳們或許是件很殘酷的事也說不定……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但還是拜託妳們了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請一定要好好保護那孩子的心靈。",
        "unit_id": 190011
    }
]