[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}正在散步時，\n發現有個抱著頭發愁的女孩子。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯……",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n成功組織公會這點是不錯，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但沒想到",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "居然連擊退魔物都做不到……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這一切",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都是因為我欠缺作為司令官的能力。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果我可以給出更正確的指示……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好吧！",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣一來只能進行特訓了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只要我變強，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼公會也會變強的！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……但是城鎮中有人太危險了呀。",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n沒辦法，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "到城外去特訓吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎麼了閣下？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "找我何事？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "城鎮外面很危險……嗎？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這我當然知道。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就是因為危險，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "才能達到訓練的效果不是嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼……？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你說小孩不可以一個人外出……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我、",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我才不是小孩呢！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是莫妮卡‧拜斯溫特！",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n隸屬光榮的純白之翼，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是傑出的軍人喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才不是遊戲！",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下這呆板的語氣是什麼意思！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看來閣下",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是不相信了！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我沒有撒謊，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我真的是軍人！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我父母在哪？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我家在哪……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要問這些？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為了送我回家……？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不是說了嘛，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不是小孩！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔唔唔……",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n看來閣下",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是想要激怒我是吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "算了，閣下請自便！",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我要去特訓。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算阻止我也沒用的！",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡的話",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很寬敞很適合訓練呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……閣下是怎樣，",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然跟過來了？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不用擔心，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "即使出了城鎮，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也不會馬上就遇到魔物的──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "魔、",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "魔物！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說人人就到呀……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說逃走嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那好，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下自己一個人逃吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是軍人。",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "即使面對魔物也絕不會逃跑。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n就算孤身一人也要奮力一戰。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了……發什麼呆呢？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說「真拿妳沒辦法」是什麼意思？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……唔！？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是什麼……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n有股力量湧出來了！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有這股力量，",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "面對魔物也不用懼怕啦！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n看招！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼哼，",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的實力如何呀？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很棒是吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是吧，",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很厲害對吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n閣下也終於肯認可我是軍人了呢……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "欸？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說小孩居然這麼強讓人很驚訝？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我才不是小孩！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂、喂！",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_027"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼抓我的手！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有說你可以碰我嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊……？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_028"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為很危險，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以你要送我回家？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔、",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_029"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔唔唔……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我都說了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不要把我當小孩！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_030"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就這麼想戲弄我嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這讓我很不開心！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼，",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那種東西",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我才不……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這……這是糖果嗎？",
        "unit_id": 105311,
        "voice": "vo_adv_1053001_032"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……真、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真沒辦法。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n既然你都這麼說了，",
