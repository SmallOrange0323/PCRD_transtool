[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喝呀啊啊啊啊！",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_000"
    },
    {
        "type": "background",
        "background": "500154"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到達！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抵達發出求救訊號的地點囉～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "講得好像不關你的事一樣呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明你也相當活躍不是嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像是用那個奇怪力量來強化我們之類的……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒事，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是一點傷都沒受哦！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n別看我這樣，我可是相當強壯的哦♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你擔心我。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……哎呀，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以鬆懈下來呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "需要幫忙的人呢～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你在那裡呀？救援的人來囉～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀！",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n什，什麼？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳，是誰？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯？",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個～妳是……魔物嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過～妳剛才說的是人類的語言吧？",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n基本上魔物們呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該完全不懂人類的語言才對吧～？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真沒禮貌，人家才不是魔物！",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然被誤會是沒辦法的事～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "即使如此我的內心也是人類喔？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪～，妳沒事嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太好了……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉呀，是小鈴！",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳不是去找援軍嗎，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n回來的可真快呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯，因為我在山路上遇到這傢伙！",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有那位華麗的人也是夥伴！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是來幫我們的喔～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是這樣嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n唉呀，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "{player}真的在！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n太好了～♪\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你這個人呀～",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還真是認識不少人呢……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才是我失禮了，我在這裡向妳道歉。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是【伊麗莎白牧場】的人嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，不過我只是這邊的食客就是了。",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是我集合大家，帶他們逃到了這個馬廄。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為事出突然，",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n也很難讓大家逃離牧場。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為只有我一個人睡過頭，待在宿舍……",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才沒有被前往馬廄的魔物群堵住退路，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n而順利逃脫了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算只有小鈴也好，",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我希望妳能順利逃脫。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "結果小鈴妳又跑回來了。",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴真是奇怪呢，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n明明平常老是在逃離麻煩的工作。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就算是我，",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也知道什麼時候是不能逃避的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "【伊麗莎白牧場】的各位是我的家人，",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才不想拋棄你們離開呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……家人嗎。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "家人可是很重要的呢～要拼命去守護才行。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等下由我大鬧一場引起魔物注意，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家請趁這時候趕緊離開。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不知道為什麼我很容易被魔物們盯上……",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要我吸引魔物的注意力，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家應該就能趁這個機會逃走了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可、可是……？",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳這樣太危險了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會死掉的唷？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了守護人民而奉獻生命，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n本來就是『我們』的職責呀！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……這裡的人是全部的生還者嗎？",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有人還沒逃到這裡來嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "奇怪？",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽與栞不見了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。真陽說，\n她很擔心牧場裡養的牛隻跟羊群們……",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以就往牧草地那邊過去了。",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為對她來說，動物們也是她的家人。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小栞……",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n她一臉被逼到絕境的樣子，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n往魔物群裡衝進去了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為守護牧場的和平是她的使命，",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n她是這麼說的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對……",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那個，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "本來應該是我的職責。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "栞是因為，",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n看不慣我老是偷懶，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n才會來幫我忙的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為小栞是很認真的人～……",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還有。",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_038"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n那孩子，不是撫養了撿來的魔物的小孩嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n替牠取名叫喵特。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "她似乎認為，這次魔物會襲擊牧場……",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_039"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說不定是因為魔物想帶回喵特～。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果是這樣的話就是自己的責任，",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n她才會抱著喵特，去魔物那邊的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n覺得只要把喵特交給魔物，說不定它們的目的達成就會離開了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不，我覺得和喵特無關～……",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "襲擊我們的魔物，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有不同種族的呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比起在尋找什麼，",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n更像是毫無目的搗亂的感覺。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯嗯！",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_043"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n鈴鈴說的沒錯！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總之，魔物們似乎只是遇到什麼就肆意破壞。",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_044"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只要好好地迴避，也不是那麼危險？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇哇，真陽！",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太好了太好了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n妳還活著♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_046"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我才不會拋下動物們還有鈴鈴妳就這樣死掉呢～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "然後我把動物們往山路放生了，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_047"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n與其讓牠在這裡等死，我覺得這樣做比較好……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "運氣好的話可以逃過一劫，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_048"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n受到附近的聚落保護",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過在事情解決之後，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_049"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n需要去找回來就是了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過我們家牧場的動物都很健康又結實。",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_050"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不會被魔物幹掉的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來失去理智抓狂的只有魔物。",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_051"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "動物都有好好聽我的話，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n大家肯定都很機靈的去避難了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剩下的就是，鈴鈴們能逃過一劫就可以放心了。",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_052"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然牧場的建物損壞了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過命還在就有機會～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞也是，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳看，平安無事呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是驚險萬分呢，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_054"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n她倒在一群魔物中間……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果我沒發現她，把她扛走的話，那可是會被踩扁的唷？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "…………",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "小栞！",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "妳這個笨蛋，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要這麼亂來呀～……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對、對不起……",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_057"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓妳擔心了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是因為我體弱多病，",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_058"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不知道何時會死。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果拼死守護大家，",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_059"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n可以讓大家活下去的話……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那我好像也就有誕生的價值了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是的。",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_060"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n絕對不能再想這種傻事了呦，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n栞？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳不用這樣犧牲自己……",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "【伊麗莎白牧場】的所有人，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n都覺得栞的出生是有價值的呦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_062"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n莉瑪，真陽，鈴，大家……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211,
        "voice": "vo_adv_2004004_063"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過，說教就等之後再說吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "總之，我們快點去避難吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的。",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_064"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n既然這樣，方便逃脫的方向我還是知道的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我來帶路吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看來魔物似乎是以山裡的「某個地點」為中心",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_065"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n四處作亂。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想只要能離那裡越遠，就會越安全。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～……",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不好意思，打斷妳一下，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳剛剛說的「某個地點」，大概是在哪裡呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我總覺得魔物們的行為很不自然。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可能是有人",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n藉由魔法什麼的在操控它們。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是這樣的話，那個操控魔物的人……",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自然會處在魔力流動的中心位置才對。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要說可疑的地方，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該就是那個山裡的『某一地點』了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果魔物們只是被控制的話，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要打倒使用魔法的人就能解決了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要突擊那個地方，去打倒那個人喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我覺得這應該比打倒所有魔物",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還要簡單許多吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過要是我去那個地方的話，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就沒辦法保護大家了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要緊。",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_073"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n逃跑這麼點事，我們還是能做到的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我先不提……",
        "unit_id": 102611,
        "voice": "vo_adv_2004004_074"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪與真陽還有小栞都很厲害。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴也是很厲害的人……",
        "unit_id": 103811,
        "voice": "vo_adv_2004004_075"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明能逃走的，卻回來了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯……",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就和【伊麗莎白牧場】的人一起避難吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會一邊大鬧吸引敵人的注意力，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一邊想辦法打倒操控魔物的人。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我初次和你見面的時候也是這樣子呢。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種被大量魔物襲擊的情形，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對我來說還蠻常見的喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果不想辦法從根本解決問題的話，",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_079"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣的事情就會一直重複發生……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想趁這個機會完美地解決這個問題。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟我又不像是白雪公主那種童話故事裡的公主。",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_080"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我已經受夠生命被他人威脅的情況了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想要更閒適、更悠哉地生活……",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_081"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每天就是吃些美食，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n享受和平的日子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且呀～",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_082"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我都會把被我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n打倒的魔物吃掉喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣日復一日一直被襲擊的話……",
        "unit_id": 105811,
        "voice": "vo_adv_2004004_083"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n每次打倒魔物都得再吃掉它們，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是我這種大胃王也會吃不消的。",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "200400401"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_084"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那麼就往那個方向前進吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥先不用提，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_085"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然不知道那個孩子是誰。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過自我介紹就等之後再說吧～？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "事不宜遲，快點動起來！",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_086"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我喊預備起時～就要一起衝了喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟我來！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場就像我的後花園，",
        "unit_id": 103311,
        "voice": "vo_adv_2004004_087"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我連地上哪裡凹凸不平都知道！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n好啦衝了～預備起～☆",
        "unit_id": 103311
    },
