        "words": "櫻"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "收到了來自法蘭秀秀製作人的聯絡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n關於聯絡內容提及的事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n櫻正打算向{player}詢問一下意見。"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "其實，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_000"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我收到了製作人的聯絡。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "他說街頭個人演唱會的流程都安排好了，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "要我準備舉辦",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "演唱會。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這真是太棒了呢，",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "櫻小姐。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "請務必也讓我",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "來觀賞您的演唱會。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "請問演唱會的",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "日期是什麼時候呢？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "演唱會的舉辦日……",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_002"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "就是今天！！！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "您是說……",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "今天嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "沒錯，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_004"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "就是今天。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "總是這樣。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "老是那麼突然。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n每次都是當天才講！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "呼……",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_005"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "話說回來，薇歐莉特，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n妳待在這裡沒關係嗎？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n以公主的身分來說。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒問題。",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_006"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我是瞞著格蕾斯──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "瞞著我的護衛騎士",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "過來的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "嗯，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_007"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "這可不叫做沒問題哦。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………",
        "unit_id": 133014,
        "voice": "vo_adv_1361003_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呵呵──",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_009"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一定馬上就能找到我的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這是她平時讓我困擾的回禮，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而且更重要的是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我還想再與櫻小姐及",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生見面啊。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "妳真是說了讓人開心的話呢～",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_010"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "薇歐莉特。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不過……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "真的沒問題嗎，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "騎士先生？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "既然你們兩個都說沒問題了，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_011"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "那應該就沒問題吧。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "比起我的事情……",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_012"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "櫻小姐您",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "打算怎麼辦呢？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "如果完全沒有準備",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而被迫上場的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我認為",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "即使中止或延期也是沒有辦法的事。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不。",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_013"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "不會中止也不會延期。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n我會舉辦個人演唱會喔，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "薇歐莉特。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "既然決定要辦，",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_014"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "那就只能上了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "雖然有種被製作人",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "耍得團團轉的感覺，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n但跟這比起來，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "身為偶像，能舉辦演唱會這件事更讓我感到開心嘛。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "所以直到演唱會開始前，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_015"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我都要來練習。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "如果兩位願意的話",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "可以來看看嗎？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好的，",
        "unit_id": 133111,
        "voice": "vo_adv_1361003_016"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我很樂意……♪",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "那個……",
        "unit_id": 911,
        "voice": "vo_adv_1361003_017"
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "難、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "難道說……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "你是……！",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_018"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "前陣子，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "在森林裡遇到的……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n那個……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "你們好。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "妳、",
        "unit_id": 811,
        "voice": "vo_adv_1361003_019"
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "妳好……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "\n那個……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "之前的事，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "應該不是",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "幻覺，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "對吧……？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "……",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_020"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "沒錯。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n如果可以的話，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "希望你們能幫我保密，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "會對我有很大的幫助……",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "那當然！",
        "unit_id": 911,
        "voice": "vo_adv_1361003_021"
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "受到妳的幫忙，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "我才不會做出那種以怨報德的事。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "太好了……",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_022"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "謝謝你！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "這個，",
        "unit_id": 811,
        "voice": "vo_adv_1361003_023"
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "該道謝的應該是我們才……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "不，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "還是算了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "\n話說回來，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "你們在這裡做什麼……？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "其實，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_024"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我要舉辦街頭演唱會了！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "因為我",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "是個偶像！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "偶像……",
        "unit_id": 911,
        "voice": "vo_adv_1361003_025"
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "還有，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性1",
        "words": "街頭演唱會……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "雖然因為是很突然的決定，",
        "unit_id": 136111,
        "voice": "vo_adv_1361003_026"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "再加上我在王都幾乎毫無知名度，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n所以感覺會是場很辛苦的演唱會呢。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "……如果是這樣的話，",
        "unit_id": 811,
        "voice": "vo_adv_1361003_027"
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "那就由我們來招集人群！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "雖然也別抱太大的期待啦，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性2",
        "words": "但我們一定會能拉多少算多少！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "咦，",
