        "name": "旁白",
        "words": "\n這時很耳熟的聲音"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "突然響了起來──"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "──大家快起來！",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～",
        "unit_id": 132912,
        "voice": "vo_adv_5158006_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "睡得好飽啊～",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呼啊……",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們似乎平安回來了呢。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "不是的，大家。",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_003"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n蘭德索爾變奇怪了啊！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n好好看看周圍！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是真的呢……",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "救、",
        "unit_id": 3911,
        "voice": "vo_adv_5158006_005"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "救命啊……！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這個聲音是……",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n聖誕老人？",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "把禮物拿來──！",
        "unit_id": 1614,
        "voice": "vo_adv_5158006_007"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "咿～！",
        "unit_id": 3911,
        "voice": "vo_adv_5158006_008"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "等等，",
        "unit_id": 51411,
        "voice": "vo_adv_5158006_009"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我不是聖誕老人啦～",
        "unit_id": 51411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n救命啊──！",
        "unit_id": 51411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "來吧，",
        "unit_id": 1611,
        "voice": "vo_adv_5158006_010"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "是追加的禮物！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n不寫作業的話，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "妳就會被退學喔──！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "騙人，",
        "unit_id": 105011,
        "voice": "vo_adv_5158006_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不要啊……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "聖誕禮物居然是作業……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這是場惡夢啊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗚",
        "unit_id": 100811,
        "voice": "vo_adv_5158006_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇～",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n四處逃逸的我，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是多麼豔麗啊……！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "魔物會來追我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是沒辦法的呢！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "會講話的魔物！？",
        "unit_id": 132912,
        "voice": "vo_adv_5158006_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這是怎麼回事啊～！？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "總之，",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們去救人吧。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嘿呀……！",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "什麼，",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "復活了？",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "啊哈哈，",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_016"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "真遺憾啊～",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n攻擊對那些魔物不管用～",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "喔。",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n因為那是夢的產物啊！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "吐舌鬼！？",
        "unit_id": 132912,
        "voice": "vo_adv_5158006_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這是你做的嗎！？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "因為你們妨礙我，",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_018"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "所以我就把夢搶走了。",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n透過附身在那個坎卜斯身上！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "咦？",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_019"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n那是怎麼回事啊！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "自己去想啦，",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_020"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "笨蛋──！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n啊哈哈！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "你才是笨蛋吧！",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_021"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n像那樣子一直把舌頭吐出來，",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "很噁心啊！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "好過分！",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_022"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n我不會原諒你了喔！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在不是吵架的時候啊！",
        "unit_id": 132912,
        "voice": "vo_adv_5158006_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要想辦法處理這個狀況才行……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吐舌鬼說他附身在你身上。",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_024"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有什麼頭緒嗎？",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "這麼說來，",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_025"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "我是在牢房遇到那傢伙的。",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "我不記得",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "那之後發生的事情……",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "……他說不定真的附身在我身上，",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_026"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n然後用了我的惡魔的力量……？",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 132912,
        "voice": "vo_adv_5158006_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "弗洛艾。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你之前說了，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在角被折斷的狀態下使用力量的話很危險吧……？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "嗚哇，",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_028"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "所以惡夢才會侵蝕現實啊……！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "不妙，",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "這樣下去",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "會沒辦法區別惡夢跟現實的！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "吐舌鬼，",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_029"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "現在立刻住手！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n不要說聖誕節了，",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "連你自己都很危險啊……！",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "誰會停下來啊──！",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_030"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n我要就這樣",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "把一切都破壞掉！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "再繼續下去",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_031"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很危險。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n只能阻止吐舌鬼了。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "我不會讓你妨礙我的！",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_032"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n接招……！",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾、伊緒、弗洛艾",
        "words": "「騎士……！？」\n「你還好嗎……！？」\n「你沒事嗎……！？」",
        "unit_id": 1,
        "voice": "vo_adv_5158006_033"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "啊哈哈，",
        "unit_id": 18811,
        "voice": "vo_adv_5158006_034"
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "我破壞掉那傢伙的愛了。",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "年幼鬼魂、吐舌鬼",
        "words": "\n掰啦～",
        "unit_id": 18811
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "站住──！",
        "unit_id": 52412,
        "voice": "vo_adv_5158006_035"
    },
    {
        "type": "dialogue",
        "name": "弗洛艾",
        "words": "\n我不會讓你逃跑的喔──",
        "unit_id": 52412
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士！",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_036"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你還好嗎？",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗚……！？",
        "unit_id": 132811,
        "voice": "vo_adv_5158006_037"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "居然會從騎士的口中",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說出這種話來……",
