    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我身為教育者，既然以嚴格的態度對待他們，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也得給予相對應的幫助。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不然的話……",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_085"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就只會變成一個惡人而已。",
