    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "噫！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_073"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就說了",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要突然站在我背後啦！",
