    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "誘！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_075"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我才沒有在誘惑好嗎！！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起這個……",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_076"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉了啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "抱歉什麼？",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_077"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳果然",
