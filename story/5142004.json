        "voice": "vo_adv_5142004_089"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "知道了嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊、",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_090"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……不過，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_091"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我果然還是很意外啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n而且……",
