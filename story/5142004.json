        "words": "……哦？",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_103"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳剛才害羞了？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳害羞了嗎？",
