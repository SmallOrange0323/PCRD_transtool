    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "惠理子越來越有教官的模樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看著訓練順利進行，{player}鬆了口氣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是，就在某一天……"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有什麼……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…………",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我說謊了。",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "其實……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我帶的班有一位新兵，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n從訓練中脫隊了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "當然不是因為訓練時害他受傷之類的原因喔？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只是……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "他開始跟不上訓練了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "訓練期間也快過一半，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n必須更加緊腳步才行。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "每天的訓練內容",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也勢必會變得更加嚴苛……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以每一期，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到了這個時候至少會有一個人脫隊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然只要認清這種事是在所難免的就好……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是難得他們懷抱著想成為騎士的夢想而來，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我卻沒辦法幫助他們實現……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感覺",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有點難過呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我、",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "才沒有溫柔呢！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我只不過",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是覺得他們有點可憐而已。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也很煩惱對待他們的方式。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "會太嚴格",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "或是太溫柔嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "之類的……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "東想西想後，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我反而不太能夠面對那些新兵了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "～",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "培育人",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也是很辛苦的呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然被培育的那一方，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "應該比我辛苦多了……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在這種時候，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我應該要更嚴格，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還是更溫柔。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n該採取哪一種態度……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "──你們在說什麼？",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子！？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳從什麼時候開始站在我背後的？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就在剛剛而已。",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "比起這個，真琴……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n妳剛才，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和這位大人單獨談話了對吧……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳是什麼意思？",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "該不會，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是打算介入我和這位大人之間……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，沒有沒有，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我沒有這種想法啦！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真的嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是、是啊……",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是說真的啦！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以別這樣瞪著我！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣啊。",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就相信，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳說的那些話吧……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "姑且相信。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好了，我們走吧，",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n得去監督新兵長跑才行。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "再見啦──！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝謝你聽我說！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……呼。",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n惠理子那傢伙，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要牽扯到{player}就會很嚇人啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她對新兵們的態度也很恐怖呢……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但是……",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "惠理子那班都還沒有任何人脫隊呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "明明訓練方式那麼嚴格，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n感覺至少會有一人受挫放棄的說。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說不定她也是有……",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "獨門訣竅之類的嗎。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……好。",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我就去看看",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她是怎麼對待新兵的吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "最右邊的垃圾蟲。",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n妳的速度變慢了啊。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "照妳那個樣子天都要黑了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "是、",
        "unit_id": 711,
        "voice": "vo_adv_5142004_028"
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "是的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "索菲",
        "words": "我會努力的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唉呀唉呀，",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才這點程度就精疲力盡了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是因為平常都作為一隻垃圾蟲在地上爬，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所以忘了腳該怎麼使用了嗎？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "喬",
        "words": "真、",
        "unit_id": 711,
        "voice": "vo_adv_5142004_030"
    },
    {
        "type": "dialogue",
        "name": "喬",
        "words": "真的非常抱歉！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還差一點就要達成進度了呢。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "作為獎勵，就讓你再跑３圈好了。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "感謝我吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "呼，",
        "unit_id": 711,
        "voice": "vo_adv_5142004_032"
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "呼……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "謝、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "謝謝",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "路克",
        "words": "教官！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真琴",
