    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是對這位大人出手了……？",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就說不是了嘛！",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_078"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我想說的是……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_079"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "誤會妳了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n本來還以為妳是個自作主張的傢伙……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但原來妳也有溫柔的一面呢？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_080"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳看到了剛才的互動是嗎。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒什麼大不了的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就如同我跟他說的一樣，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這也是作為教官為了獲得好評而做的事。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳幹嘛特地找藉口啊。",
        "unit_id": 129811,
        "voice": "vo_adv_5142004_081"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n才沒有教官會因為在意評價而幫忙縫鎧甲襯衣呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唉……",
        "unit_id": 129911,
        "voice": "vo_adv_5142004_082"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "隨妳說吧。",
        "unit_id": 129911
    },
