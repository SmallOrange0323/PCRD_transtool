[
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯嗯，已經中午了啊。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真糟糕，最近老是提不起勁啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "上次被叫到王宮去，\n在國王面前表演之後……",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "身體好像就變得重重的，總會賴床到太陽曬屁股的啦",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我該不會有一點憂鬱吧……\n這真是太不像我了。牧場一早就有很多工作，",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我得趕快起床，好好工作才行。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有很多牛等著我去照顧的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚嗚，什麼事都不想做。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣會被寄住在【伊麗莎白牧場】的\n莉瑪莉瑪或栞栞擔心的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n雖然那些孩子，大概只會靜靜地在旁邊守護而已。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴的話，\n感覺就會說",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "「明明平常老是叫我工作～」",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種諷刺我的話。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "實際上也是那樣沒錯啦。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是見不賢而內自省啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "默默地做「平常的工作」，應該多少可以靜下心來的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以得趕快起床，起來工作才行。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n從出生以來，我都是這樣一路做過來的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯？\n怎麼，馬廄那裡好像很吵鬧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n發生了什麼爭執嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "明明【伊麗莎白牧場】的特色\n就在於總是很和平～",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總覺得，全部都亂了步調啦。\n為什麼會變成這樣的啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不行。不能就這樣放著不管，",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我可是【伊麗莎白牧場】的經營者。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "得提起勁才行。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且……\n感覺不是什麼紛爭或魔物襲擊啊。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好像，可以聽到笑聲……？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_016"
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……大家～怎麼啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦、",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "早安……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來【",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "伊麗莎白牧場】做什麼呀？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然，{player}的話隨時來玩都沒關係的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱歉，",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不知道老哥有什麼事，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但我好像有點身體不舒服，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n沒辦法陪老哥啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是，\n老哥專程爬到這山上的牧場來。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是說……改天再來，是不是太不近人情啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯？\n抱歉，我有點不懂意思。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛那是搞笑劇嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雙、雙關語？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n為什麼會想在這個時機逗我笑呢？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我沒能好好反應，真是太抱歉啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n話說回來……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛的笑點在哪裡的啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？\n為、為什麼突然開始笑？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我說了什麼有趣的事嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我說過本人不笑的話，就沒辦法逗其他人笑嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我以前說過這種話嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我竟然裝作一副都懂的模樣，說過這種臭屁的話啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊？\n怎麼啦，{player}？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我坐在這裡就好了嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "拍手？\n雖然不知道為什麼要這麼做……",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啪啪啪♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔喔。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n{player}要表演",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n私房的搞笑短劇嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為、為什麼啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n之前我的確是喜歡搞笑……啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在變得好像有些摸不著頭緒。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n究竟什麼是搞笑，有什麼意義，又有什麼價值。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "實在有點煩惱的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔喔？\n老哥不理我就開始表演相聲啦！",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是單方面地想搞笑是不行的啦。\n得感受觀眾的興致和氣氛才行！",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過算了。\n……啊、",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈……♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊嗯，非常有趣啊。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我從以前就笑點很低的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊……感覺很久沒笑成這樣了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總覺得放下了心中的大石頭啦♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝啦。\n{player}是來幫我打氣的對吧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_040"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不是從寄住在【伊麗莎白牧場】的孩子們那裡，\n打聽到我很沮喪，所以很擔心？",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是啊？只是單純喜歡我搞笑，",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_042"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n所以自己也想試看看？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣啊……不管是謊話還是客套話，總覺得很高興啊♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸嘿嘿。\n搞笑絕對不是治百病的仙丹。",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_043"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是可以幫助人\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_044"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "暫時忘記現實的苦悶與不順心。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就跟甜甜的點心一樣的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然不是這個世界上不可或缺的東西。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_045"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但沒有搞笑的話，總會有點寂寞的吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝老哥……",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_046"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然我還是有點沮喪，不過心情稍微輕鬆一點啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為背負著國家或是世界\n這樣沈重的責任，而變得",
        "unit_id": 103311,
        "voice": "vo_adv_1033007_047"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
