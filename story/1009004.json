[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}出來買東西，\n有個人突然跑到他面前。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵呵呵……",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "想不到是吉格魯特呀。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "小心「機關」的眼線。不要放鬆警覺呦。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我會繼續調查「機關」的。",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼，我先失陪了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你在做什麼呀？",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這時候應該要說出暗語的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你不要說你忘記了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "什麼……你說你真的忘記暗語了！？",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真是的，拿你沒辦法……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽好了。「吾等乃飛舞於煉獄，一陣疾風」。",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "別再忘記了喔？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然你仍舊沒有想起前世記憶的徵兆，",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n但毋需著急。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "命運本身就是變化無常的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "當時機到來時，應該就會想起來了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼，",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我要繼續去調查「機關」――",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、這道光芒是什麼！？",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n難道是「機關」的攻擊！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好、好刺眼……！",
        "unit_id": 100911,
        "voice": "vo_adv_1009004_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚哇哇哇哇！？",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "萬象的根源瑪那呦……！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_010"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "請降臨我所祈求之物",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "至此吧――！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "謝謝您的惠顧―！",
        "unit_id": 1231,
        "voice": "vo_adv_1009004_011"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "謝謝！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_012"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嘻嘻嘻……終於到手了！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_013"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n神滅的巴哈姆提亞劇場版DVD，附店面限定贈送特典！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……還好我有預約了！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我得快點回家打開掛軸海報來看看！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_014"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不對，應該要先複習一次本篇劇情才對吧……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "但是我也很在意映像特典的評論音軌！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_015"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "一次附贈工作人員版和聲優版兩款真是太棒了！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……多虧這個作品開闊了我的視野！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_016"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那時我學會了獲得全新創造力自由翱翔的重要性……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不對，先等一下……話說回來，我還沒有在社交平台上投稿",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_017"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n有關昨天在阿斯特朗中進行的活動……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "先把投稿寫完吧。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我的「熾炎戰鬼煉獄血盟暗黑團」活動記錄……",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_018"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n讀者不停地增加，要是内容停止更新了，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "身為疾風之冥姬的我不能不管……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "回城鎮吧。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "什麼！？你是誰！？",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_019"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你，為什麼會知道這個暗語！！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……等一下？",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_020"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n知道這個暗語，應該只有一人……！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "難道，你是閃光的吉格魯特……嗎？",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_021"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你……",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_022"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "竟然和我生活在同一個世界、",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n同一個時代之中嗎！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我們是以靈魂羈絆連繫著的盟友！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_023"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n所以才發生了這樣的奇蹟呀！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呵呵呵……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "哈哈哈！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "沒想到除了在阿斯特朗，",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_024"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n連在這裡都能遇見轉世的人。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我真的非常高興呢！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這樣的奇蹟，即使是神也無法輕易地做到！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_025"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n我們之間的牽絆就算世界改變，也會不朽不滅的！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "女高中生１",
        "words": "咦，這不是柊同學嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1009004_026"
    },
    {
        "type": "dialogue",
        "name": "女高中生１",
        "words": "\n日安。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "欸！？",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_027"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "日、日、日安……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "聽、聽好了吉格魯特！？這個只是我暫時的樣貌而已！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_028"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n真正的我，名叫安妮羅潔‧馮‧修特……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "女高中生２",
        "words": "啊，杏奈同學。日安。",
        "unit_id": 1,
        "voice": "vo_adv_1009004_029"
    },
    {
        "type": "dialogue",
        "name": "女高中生２",
        "words": "\n……旁邊這位先生是……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "日、日安……！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_030"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那、那那個……！！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n他、他是我的……表哥。今天碰巧遇到……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "糟了……這裡是上學的必經之路！這樣下去的話，",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_031"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這個身體和靈魂的連繫會中斷的……！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "吉、吉格魯特呦！柊杏奈是我隱身於這世上的假名！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_032"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "真的只是假名而已！拜託你了，請你一定要記住！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "那就此失陪了！",
        "unit_id": 100931,
        "voice": "vo_adv_1009004_033"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "「吾等乃飛舞於煉獄，一陣疾風」！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\nAuf Wiedersehen！",
        "unit_id": 100931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1009004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1009004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "杏奈呢，看起來就像道地的魔族，",
        "unit_id": 190011,
        "voice": "vo_adv_1009004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但其實她似乎不是呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果她一直以來和你說那些事情都是她的想像的話……",
        "unit_id": 190011,
        "voice": "vo_adv_1009004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然十分可惜，但那樣子也算是件很了不起的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是轉世投胎什麼的……",
        "unit_id": 190011,
        "voice": "vo_adv_1009004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她竟然能那麼流暢地想出那些劇情啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n到底平常都在妄想些什麼呀……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，不過在這裡說著長篇大論也沒用呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1009004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
