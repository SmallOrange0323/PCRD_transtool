        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不想再繼續",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給最喜歡的人添麻煩了。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "成年之後，",
        "unit_id": 105831,
        "voice": "vo_adv_1075007_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
