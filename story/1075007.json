        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我告訴他我想讓他成為我的騎士，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n結果卻害他",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我不知情的情況下碰到很大的困擾。",
