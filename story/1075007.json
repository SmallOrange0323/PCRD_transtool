        "voice": "vo_adv_1075007_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會緊張也不奇怪！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我今天",
