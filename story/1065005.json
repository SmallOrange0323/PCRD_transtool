[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天，閒得發慌而外出散步的{player}，\n在街上偶遇嘉夜。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喲，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天為什麼在這。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n難不成",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你現在很閒嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來陪我練武吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天我也是很閒的說。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不論公會還是幫派都沒有工作。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我沒提過嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是幫派成員唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然這麼說，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打手的工作是透過【公會管理協會】取得，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n至於幫派工作，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "平時就是當當分店的店員，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n或是看管地盤的警衛而已。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "特別不妙的事，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大致上還是老大會統整喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "以前情況好像還滿糟糕的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是現在一切和平。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "托老大的福，所以讓我有些閒得發慌的日子。",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就是今天。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個時候就要來做打架的練習，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也就是練武！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果你方便的話一起來吧。",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "反正你很閒吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就走吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "鎮外有個好地方！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……嗯，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天就在這附近吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這裡超寬敞的，可以吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們就馬上開始吧……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼……",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈！！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……光看著我練習你也很無聊吧？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n難得有機會，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你來練劍如何？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "空揮之類的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯……",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺滿不錯的呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你有個好老師吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "釣魚的師傅？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我不是在講釣魚的事……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "持竿和拿劍很像，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是這樣的意思嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……不是嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……吶，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我剛剛想到。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為了以備不時之需，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n徒手戰鬥也來練一下比較好吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你有時候",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "莫名的會一直發呆，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "危急時如果自己不能保護自己是不行的",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看好，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我來教你，先擺好姿勢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "然後握拳……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒錯沒錯。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n腳與肩膀同寬，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "正面直接出拳！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在胳膊伸直前握緊拳頭，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一邊扭轉手臂瞄準出拳。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那樣打擊的效果會更好。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你也來試試。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "腋下的固定方式",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看起來有點鬆懈呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "露出破綻的傢伙的側腹……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就要這樣！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你在說什麼啊。",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這樣就忍不住了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼可能打倒對方？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果有敵人搔你癢那該怎麼辦？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不打倒的話就一直在那邊被搔癢嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不要在意我，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n繼續，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "繼續！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一、",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "二、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "二……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n很棒！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很棒！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟著",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "節拍！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這還只是個開始而已！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咕嘰咕嘰咕嘰～！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈哈，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉抱歉。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n因為你的反應很有趣，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不知不覺就想這樣做。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是在戰鬥過程中完全不知道會發生什麼吧？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "假如現在，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們也可能突然被魔物襲擊唷。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……啊？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "魔物？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n喂喂，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的有傢伙要襲擊我們了嗎！？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的……",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這還真讓人困擾啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "適合練習對象正好出現了呢！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看起來那樣子我也沒辦法！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為事情的確好像會變得好玩，我也控制不了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "上囉，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我才不會害怕呢！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "倒不如說我很興奮！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你退下吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我來跟這傢伙單挑！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "才一擊就要倒了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難不成這傢伙，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在我攻擊之前就已經變弱了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無所謂了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就這樣一口氣打倒它！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "兩位！",
        "unit_id": 1011,
        "voice": "vo_adv_1065005_029"
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "沒事吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有干擾來了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喲。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你們是什麼人？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "我們是受到",
        "unit_id": 1211,
        "voice": "vo_adv_1065005_031"
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "【公會管理協會】委託，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "\n要討伐那裡的魔物。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "但是要擊殺時功虧一簣被它逃掉了。",
        "unit_id": 1211,
        "voice": "vo_adv_1065005_032"
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "所以才追到了這裡，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "遇見了你們。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "那傢伙是個強敵！",
        "unit_id": 1011,
        "voice": "vo_adv_1065005_033"
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "讓我們一起戰鬥吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_034"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "給我等一下。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在和這傢伙戰鬥的是我吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你該不是要插手我跟它的單挑吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果你要打的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "首先得打倒我再說！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "和魔物單挑打架……！？",
        "unit_id": 1011,
        "voice": "vo_adv_1065005_035"
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "但是那個傢伙可是很危險的！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "……但這個孩子，",
        "unit_id": 1211,
        "voice": "vo_adv_1065005_036"
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "很有魄力呢……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "或許，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "或許沒問題吧……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "────咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "怎麼了那傢伙。",
        "unit_id": 1011,
        "voice": "vo_adv_1065005_037"
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "\n難道是",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "對那個孩子敞開心房了嗎……？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我才不是要救你啦！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n是在大意些什麼啊！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "已經結束了嗎……",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是掃興。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這樣的話就不能代替練習了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "竟然才一擊就打倒了……",
        "unit_id": 1211,
        "voice": "vo_adv_1065005_040"
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "妳真的很強呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "幫了大忙呢。",
        "unit_id": 1011,
        "voice": "vo_adv_1065005_041"
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "這裡是打倒那個魔物的一半報酬。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "\n我們當成訂金先收下了，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "和妳一起平分吧。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的可以收下嗎。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我其實只要能",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和魔物打架就好。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這其實是你們的獵物不是嗎？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n很抱歉被我搶走了呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呀啊！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不要突然抓我肚子啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "幹嘛啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你有什麼想說的嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哇呀！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你突然做什麼啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打手啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可是禁止偷襲的唷！？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哇呀！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說別這樣啦！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是剛才的報復是不是？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我只是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "給它致命的一擊而已唷？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "接下委託工作的那些人都已經說了可以，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那麼就應該可以吧……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_048"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是這樣嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "與其說順著事情發展，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但打倒魔物的人",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "確實是我呢……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "知道了。",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然你們這麼說的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那我就收下嘍。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也是難得的機會，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我領收報酬了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "是啊，",
        "unit_id": 1011,
        "voice": "vo_adv_1065005_050"
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "請妳一定要收下。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "冒險者1",
        "words": "\n多虧了妳幫了大忙。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_051"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多謝啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "那麼，",
        "unit_id": 1211,
        "voice": "vo_adv_1065005_052"
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "我們還要提出討伐的報告，先回到鎮上嘍。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "冒險者2",
        "words": "\n要小心回去唷。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……他們走掉了呢。",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊──啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有種奇妙的心情呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並不是為了那些傢伙或是金錢戰鬥的……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯……",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_055"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我只是自己想跟魔物打架而已。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實不想從那種打架中",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "得到金錢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "今天我能夠戰鬥，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且他們也很高興的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算是好事一件吧……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且你好像也為我高興呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_057"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "話也不是這麼說啦……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "作了一件好事嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打倒魔物是我擅自想做的事，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n真的要說報酬的部分",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "應該由他們全部收下才對吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣被我中途介入，",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_058"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我有一種從人家那邊奪走任務的感覺。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n覺得對他們很不好意思……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你也為我高興，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且做了好事吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就好了！",
        "unit_id": 106511,
        "voice": "vo_adv_1065005_059"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n練習也結束了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們拿報酬",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "待會好好玩樂去吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘉夜帶著燦爛的笑容，\n和{player}一起朝著鎮上走去。"
    }
