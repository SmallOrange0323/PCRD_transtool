[
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "……原來如此，",
        "unit_id": 16011,
        "voice": "vo_adv_5090203_000"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "挺有本事的嘛！！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n不過，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "還沒完呢！！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 121611,
        "voice": "vo_adv_5090203_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我們打得那麼辛苦，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n傷口居然瞬間就治好了！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "他利用「龍之卵」產生的大量魔力，",
        "unit_id": 106511,
        "voice": "vo_adv_5090203_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n來瞬間治癒傷害嗎……！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "哈哈哈！",
        "unit_id": 16011,
        "voice": "vo_adv_5090203_003"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "這不是愈來愈有趣了嗎！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n讓我",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "重整一下架式！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "還可以陪你們玩下去呢！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "臭老頭……！",
        "unit_id": 121611,
        "voice": "vo_adv_5090203_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那傢伙，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "暫時是",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "撤退了是吧……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "賭場王強得跟怪物一樣，",
        "unit_id": 106511,
        "voice": "vo_adv_5090203_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n為了不讓他重整態勢，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們要乘勝追擊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就照這個步調持續發動攻勢，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "痛揍那個傢伙吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好、",
        "unit_id": 121511,
        "voice": "vo_adv_5090203_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好的！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n要加油喔……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "祈梨……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有大家……！",
        "unit_id": 121511
    }
]