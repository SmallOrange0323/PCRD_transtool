    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了贈送「錄音鈴聲鬧鐘」給克蕾琪塔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可與{player}來到雪山上"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n採取材料「重複草」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然成功找到了「重複草」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是兩人卻被風雪給吹落了雪山──"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗚嗚。",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……{player}，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你不要緊吧……？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來你沒有受傷……！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不要緊喔。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "積雪",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像緩衝了力道呢……☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……！",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不過現在還不是慶幸的時候。",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣下去",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就要結冰了……！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "風雪這麼大，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒辦法下山……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能見度太差，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也找不到路回去……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連我們人在哪都不知道。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼……",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的耶……！！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【王宮騎士團】的山屋！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們快過去吧！！",
        "unit_id": 127911
    },
    {
        "type": "background",
        "background": "500953"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是幸好。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還好門沒有鎖，不然就沒救了……！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n簡直就是九死一生呢……！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "屋裡還有柴火跟暖爐呢！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該能用它們取暖了……！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就麻煩你了！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我先用",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這台無線電",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟王城聯絡喔！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……是的，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "事情就是這樣，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請大家放心。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "祝大家",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "平安夜愉快☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再見～",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗚嗚，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王城的大家",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都好擔心我……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回去後",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要再好好跟大家道歉才行。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……好了，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，你那邊怎麼樣了呢？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好厲害☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好溫暖喔，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "火真是太偉大了☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣就能安心了。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們應該可以平安撐到明天了！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的感到",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很自責……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要再跟你道一次歉。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都要怪我，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才會落得這種處境……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我的錯……",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都是我在那時貪心，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n想要採第二株「重複草」……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果只是要送克蕾琪塔小姐禮物，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一株就已經夠了……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我就是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n想再準備",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一份禮物……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……呼。",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我都說得這麼明白了，",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你應該",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也發現了吧？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這下子沒辦法給你驚喜了。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……不過",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還是希望你盡量",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "裝作不知……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦──！？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等等等等……",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等一下，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}！？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你你、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你為什麼！！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼要脫衣服啊！？！？！？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼～！？！？",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你你你你、",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你要我也……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "脫了！！！？？？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對吧，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒聽錯吧！？！？！？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會吧！！！？？？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你、",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你本來就",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n偶爾～會做出一些大膽的舉動……！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但今天這樣",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會不會太大膽了點！！？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對、",
        "unit_id": 127911,
        "voice": "vo_adv_1279003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了，我在書上看過……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n人在感覺到性命危險時，",
        "unit_id": 127911
    },
    {
