    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "現在是工廠的休息時間──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}跟碧一起前往街上的玩具店。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇～～～～！",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n店裡有賣好多種玩具……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是我們之前做的，會發光的玩具！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "架上沒剩幾個，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看來是賣得很好！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太好了……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "架上還有很多其他工廠製作的玩具……",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n每一個都好帥氣……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我也想把「有我在喔好朋友號V4」",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n改造成不會輸給它們的帥氣模樣！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我小時候不曾玩過這種玩具。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n畢竟是在精靈之森長大的。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在製作「有我在喔好朋友1號」之前，",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我天天都是找植物說話。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看到擺在架上賣的玩具，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "讓我感到非常新鮮。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n如果我小時候有玩過玩具，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在工廠工作所感受到的感慨應該也會不一樣吧。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不要！",
        "unit_id": 111,
        "voice": "vo_adv_1167003_007"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我不喜歡這個──！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真是的，",
        "unit_id": 411,
        "voice": "vo_adv_1167003_008"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "你不要任性啦！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那對母子……",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是怎麼了啊……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這是你想要的系列的玩具對吧？",
        "unit_id": 411,
        "voice": "vo_adv_1167003_010"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n既然只剩一個，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "就買這個忍耐一下吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可是……",
        "unit_id": 111,
        "voice": "vo_adv_1167003_011"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可是……！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "那我什麼都不買給你囉？",
        "unit_id": 411,
        "voice": "vo_adv_1167003_012"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "這樣沒關係嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那是……",
        "unit_id": 111,
        "voice": "vo_adv_1167003_013"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我知道了，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就選這個……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "那媽媽去買晚餐的食材了，",
        "unit_id": 411,
        "voice": "vo_adv_1167003_014"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n你就拿那個去跟朋友玩吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "………………",
        "unit_id": 111,
        "voice": "vo_adv_1167003_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗚嗚……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗚嗚……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個小孩……",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n沒能買到想要的玩具……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的……！",
        "unit_id": 116711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "唉……",
        "unit_id": 111,
        "voice": "vo_adv_1167003_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你還好嗎？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個玩具……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你討厭嗎……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不……",
        "unit_id": 111,
        "voice": "vo_adv_1167003_020"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我並不討厭，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "而且是想要的系列……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n但店裡只剩下",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這個會折磨英雄的壞蛋……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不過，",
        "unit_id": 111,
        "voice": "vo_adv_1167003_021"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "如果沒有這系列的玩具，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就沒辦法跟朋友一起玩。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "雖然想要的是別的，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "但最後還是請媽媽買了這個……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣啊。",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "英雄的玩具很受歡迎，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以已經賣光了呢。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然是壞蛋的玩具，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過有它就可以跟朋友一起玩了對吧？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "應該是……",
        "unit_id": 111,
        "voice": "vo_adv_1167003_023"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可是，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "總覺得會被排擠耶……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "畢竟就算能一起玩，",
        "unit_id": 111,
        "voice": "vo_adv_1167003_024"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我也是演壞蛋。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我只能徹底成為這個角色了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來小孩子的朋友圈",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也是相當嚴厲的世界呢……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "即使不是在精靈之森長大的，",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我肯定也會從小就是個邊緣人。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩法居然會因為持有玩具的種類",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而產生變化……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "再這樣下去，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "他也會……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "踏上邊緣人的道路……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我不想讓他體會到",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "跟我們相同的心情……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "BB團有我們兩個就足夠了……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟邊緣人之路",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是修羅之路！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且，",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們現在",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "正在玩具工廠工作。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "身為正在製作玩具的人，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我無法坐視不管……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我希望他能透過玩具結交朋友，",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_030"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n跟大家和樂融融地一起玩！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_031"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也是這麼想的對吧？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "好朋友號",
        "words": "…………",
        "unit_id": 7211,
        "voice": "vo_adv_1167003_032"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對吧！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大姊姊……",
        "unit_id": 111,
        "voice": "vo_adv_1167003_034"
    },
    {
