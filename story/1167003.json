        "name": "少年",
        "words": "妳是在跟口袋裡的玩具說話嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那是什麼？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它叫做",
        "unit_id": 116711,
        "voice": "vo_adv_1167003_035"
    },
    {
        "type": "dialogue",
        "name": "碧",
