        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "正確來說，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "它的名字是",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
