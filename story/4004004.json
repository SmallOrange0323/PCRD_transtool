        "voice": "vo_adv_4004004_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011,
        "voice": "vo_adv_4004004_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果這傢伙到底是什麼啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
