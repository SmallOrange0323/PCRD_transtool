    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有這種麻煩的限制真好呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_4004004_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你沒有體驗過這種事吧？",
