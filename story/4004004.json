    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該沒有被實際安裝才對……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，為什麼會勾起這樣的記憶呢？",
        "unit_id": 190011,
        "voice": "vo_adv_4004004_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許是最近很累的關係……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不能這麼說呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "得更加油才行！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊。什麼啊，",
        "unit_id": 190011,
        "voice": "vo_adv_4004004_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還在啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經可以回去囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯，雖然努力回想但就是想不起這個記憶的主人是誰，\n處在焦躁的心情下，暫時無法轉換心境。"
    }
]