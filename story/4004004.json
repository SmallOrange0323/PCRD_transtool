        "voice": "vo_adv_4004004_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "　剛剛那個是夢啦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……你嚇到了呢？",
