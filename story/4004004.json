        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能和莉瑪一起戰鬥真的太好了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為想分享這份感動，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來握手吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "貪吃佩可！",
        "unit_id": 105211,
        "voice": "vo_adv_4004004_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我才是，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請讓我和妳道謝！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這個由蹄和手所締結的羈絆，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是永遠不會斷掉的！",
