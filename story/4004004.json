        "type": "dialogue",
        "name": "莉瑪",
        "words": "　謝謝～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就像女子會一樣，好期待～！",
        "unit_id": 105211
