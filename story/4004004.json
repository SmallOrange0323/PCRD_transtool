        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我自己也很驚訝啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "馬上忘掉也沒關係唷。",
