[
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "阿斯特賴亞大陸上最大的活火山，貝利奧火山上──"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事情為什麼會變成這樣啊！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_001"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在不時噴起巨大煙塵的這片土地上，迴盪著祈梨的吶喊聲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n時間回溯到幾個小時前──"
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你來的正好！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n反正你現在一定很閒吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要賦予小哥",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "協助我進行特訓的這項光榮任務！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜有打手的工作，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大又去和貴族們聚餐，兩個人都不在，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以我閒到發慌想找個人陪什麼的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才沒有這回事喔？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我發現到了一件事……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那就是暴力至上！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "暴力可以解決所有問題！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看看嘉夜夜就知道了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她光憑著暴力就成了正式幹部喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "值得慶幸的是，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們龍人族擁有一種",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "叫做「覺醒」的能力。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然我只是轉述老大的話啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然如此，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要我早一步",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "掌握好覺醒的方法，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n大家肯定",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就會對我刮目相看的！",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為了達成目的，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的確是說過要進行特訓啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算是這樣，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "為什麼非要選在這種火山地帶啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這也熱過頭了吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸？",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜開始覺醒的時候，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n總覺得變得超級厲害……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然也很可怕啦。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼嗯哼嗯，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在這種地方就算我的力量急速提升，噴出火焰來，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n也不會引發火災？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "原來如此，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "以小哥來說是個不錯的點子呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好～！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我就要盡情地覺醒！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈～哈哈哈哈哈～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥要看好了喔～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……覺醒，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼做來著？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "熱死了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不經大腦衝動行事就會落得這種下場啊……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這下該怎麼辦啦小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～嗯……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然我曾經被老大騙去艾爾皮斯島，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n有和海裡的魔物戰鬥過的經驗啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這次也只要像上次那樣做就行了嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "乾脆，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓小哥陷入危險怎麼樣？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "開個玩笑",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而已啦～",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊哈哈哈……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "魔魔魔、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "魔物出現了！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而且看起來超級強的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之現在",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "先找個地方躲起來等它離開吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "它發現我們了！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n往我們這裡來了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哇啊啊啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼辦才好……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥要我自己一個人逃走嗎……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那樣的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥要怎麼辦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在這種地方是不可能找得到幫手的！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥也要和我一起逃走！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在做什麼！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n啥？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當誘餌什麼的……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "絕對不行！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就算你自告奮勇做那種事，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也完全高興不起來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不行……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種事……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種事，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我絕對……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "絕對不會認同！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "由我……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "由我來保護小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這……",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是什麼？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這股噴湧而出的力量……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n該不會是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥的……？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不光是那樣……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這該不會就是",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "龍人族的力量……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在不是想這種事的時候！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n再這樣下去小哥就要……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然這樣也只能拚了！",
        "unit_id": 106611,
        "voice": "vo_adv_1066007_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n要上囉！",
        "unit_id": 106611
    },
    {
