[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在矛依未等人的決定下，樂園的餘波終於獲得解決。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可是，作為代價，矛依未放棄了解放之力。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗨，{player}。",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在樂園事件中，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "受到你不少的關照呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦，",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說什麼也沒做？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還是沒變，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個謙虛的傢伙呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不過，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我非常感謝你啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在那之後，我花了幾天觀察城鎮的狀況，",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n似乎已經沒有被囚禁於回憶中的傢伙了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能夠成功",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是太好了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天就做當作是道謝和慶祝！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我請客，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們一起去吃頓飯吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n之後，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們一起到終於恢復平靜的城鎮閒晃，如何！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不安？",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個嘛……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "陽光也太強了吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有點耀眼過頭了喔。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這究竟是……",
        "unit_id": 106113,
        "voice": "vo_adv_1250004_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔呀啊啊！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "510160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，{player}為了調查作業的資料，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了圖書館。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "救、",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "救命啊！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要被殺掉了──！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔，",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還記得我嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是同校的矛依未！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事根本不重要，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快救救我！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我現在",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "正被一個很不妙的傢伙追著……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個既心機又喜歡挖苦人的",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妹妹頭男……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再這樣下去",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會被那傢伙……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "找～到妳了。",
        "unit_id": 1,
        "voice": "vo_adv_1250004_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔噫噫！",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾、",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "真是的，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_013"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳開口說要我教妳念書，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n竟然還落荒而逃，這樣不行吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳不這麼認為嗎？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可、",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我果然還是",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很討厭念書什麼的……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "沒什麼可是不可是。",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_015"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "如果只是逃跑就算了，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "不要還給其他人添麻煩啦。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "對不起喔，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我朋友她……",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "哎呀？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "……",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_016"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "你是",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我們學校的學生吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "嗯",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "～",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "來寫作業啊，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這樣啊，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "真了不起～",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n我是她的指導者，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "但結果如你所見。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我也嚇了一跳呢。",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_017"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "哎呀～",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "世界",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "遠比我想像的來得小啊。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "對了，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_018"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這也是某種緣分，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "你也一起來念書吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "放心吧，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_019"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我很聰明的。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n除了作業以外，不擅長的科目我也能教你喔。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你在說什麼啊，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事當然不行！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我認為有你在場，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_021"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "她肯定也會",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "提起幹勁吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "再加上，她大概無法做出認識的人就在面前，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_022"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n卻還落荒而逃的丟人行為吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂、",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我都說不要了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有沒有在聽啊，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "是妳先向他求救的呦？",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_024"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "快認命吧？",
        "unit_id": 106231
    },
    {
        "type": "still",
        "still": "125000401"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔、",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咿咿咿……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "光是閱讀文章，頭就痛了起來……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n一看到數字，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就感覺要吐了……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我還是第一次見到",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_026"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "有人說出這種漫畫般的台詞。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "你呢？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "有不懂的問題嗎？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "我看看，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_027"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這裡啊──",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "矛依未，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_028"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳那邊如何？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊，",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我懂了自己什麼都看不懂……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "哎呀，",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_030"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這邊完全不行呢～",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "說起來，妳為什麼會突然想要念書？",
        "unit_id": 106231,
        "voice": "vo_adv_1250004_031"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n講得婉轉一點，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "妳的頭腦不好吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106131,
        "voice": "vo_adv_1250004_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "根本一點都不婉轉！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
