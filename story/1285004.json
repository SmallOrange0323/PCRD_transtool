        "voice": "vo_adv_1285004_067"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們剛剛",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是睡著了嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這種山頂上睡著很危險呢……！",
        "unit_id": 128511,
        "voice": "vo_adv_1285004_068"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n還是趕快回家取暖吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 128511,
        "voice": "vo_adv_1285004_069"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不小心就理所當然地邀你去家裡了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "實在不好意思再讓你繼續陪我了呢。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這兩天謝謝你。",
        "unit_id": 128511,
        "voice": "vo_adv_1285004_070"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n多虧你，我新年過得很開心喔。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還許了新的願望呢♪",
        "unit_id": 128511
    },
    {
