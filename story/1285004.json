        "voice": "vo_adv_1285004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "寒假期間裡，只有兩個人獨處的圖書館……",
        "unit_id": 190011,
        "voice": "vo_adv_1285004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這情境就算不是霞，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也會忍不住心跳加速呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1285004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她竟然不惜編造藉口，\n也想要跟你見面，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是有勇氣呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你聽好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1285004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "霞在「那邊」的世界時，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n個性很內向畏縮，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以輪到你帶領她的時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就要好好拉她一把喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……雖然說",
        "unit_id": 190011,
        "voice": "vo_adv_1285004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要是你實際做出行動，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n霞的心臟感覺會大爆炸就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就先這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1285004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500400"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦……？",
