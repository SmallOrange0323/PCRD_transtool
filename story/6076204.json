[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "博士的",
        "unit_id": 117811,
        "voice": "vo_adv_6076204_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "發明技術，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一點也不輸給",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "東國的",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "機關技術呢。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "像我的笛子",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能夠藉由笛聲",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喚來妖魔是也，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不知將軍的裝備",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "具有什麼樣的能力呢？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個裝置，",
        "unit_id": 117811,
        "voice": "vo_adv_6076204_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我之前就一直覺得",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很不可思議是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n為何",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可以將捕捉到的",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大量小棉花糖們",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "全都吸進去呢……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到底是根據什麼樣的原理呢。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "博士真是個",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "充滿謎團的人物是也……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦……",
        "unit_id": 117811,
        "voice": "vo_adv_6076204_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "原來背上的",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "捕獲機",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還具有這樣的功能是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "初次遇到小棉花糖時，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n將軍也是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "追著牠的反應",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "才趕來的吧！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "的確，",
        "unit_id": 117811,
        "voice": "vo_adv_6076204_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妖魔是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "靈界的居民……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以會具有",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們不知道的攻擊能力是也。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "話說回來，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我的制服也是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "博士製作的，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "同樣能夠抵擋妖魔的攻擊！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "萬一將軍陷入危機，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就由我來當",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你的盾牌吧──！",
        "unit_id": 117811
    }
]