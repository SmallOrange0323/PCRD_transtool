    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾近郊的平原上，{player}和怜"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在接受志那都的劍術指導。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不需要多餘的力氣。",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "只要更敏銳、準確地掌握中心，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "並且斬斷……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "僅此而已。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……與其用言語說明，",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "還是直接嘗試比較快吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我會用風之力",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "把樹葉颳起來。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "試著全部切開吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……開始。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼、",
        "unit_id": 100312,
        "voice": "vo_adv_5136066_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n嘿咿……",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔！！",
        "unit_id": 100312,
        "voice": "vo_adv_5136066_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……會感到困難，",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就代表還有多餘的動作。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "只要順著風勢揮劍即可。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n想像讓劍身乘著風揮舞的感覺──",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "居居居居居、",
        "unit_id": 1,
        "voice": "vo_adv_5136066_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "居然～～～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 100311,
        "voice": "vo_adv_5136066_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從對面跑過來的是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到會在這裡遇見你們！",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是驚訝不已，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "情非得已是也！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "與他的夥伴們，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是美好的一天是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "話說回來，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "終於",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "被我找到了！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳是說",
        "unit_id": 100311,
        "voice": "vo_adv_5136066_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "找到什麼？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哼哼哼。",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n那邊那位",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "身穿黑衣的人！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………我？",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不用說我也明白。",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳就是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "者！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我是……",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "忍者？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哼哼哼，",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我都看出來了是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "毫無破綻的架式，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非比尋常的氣息……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n妳臉上戴著的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是叫做包面的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者面罩吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "尤其",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "妳用了操縱風的招式！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那正是忍法，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "風遁之術！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "等……",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_016"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "等一下。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我不是忍者。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我的確能使用風之力。",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那不是忍法也不是風遁。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哎呀失禮了！",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者必須要隱瞞身分才行！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是我太不識相了！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我懂的。",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍就是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "率領忍者的人！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n她也是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的其中一位家臣吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也就是",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "王牌、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "殺手鐧、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "護身刀！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我也不會",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "把忍法的事情洩漏出去的，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "無須擔心！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……原來，",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_021"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她是這個世界的妮諾嗎。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n對於東國的愛",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "居然會是以這種形式呈現。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟妳那邊的妮諾不一樣嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_5136066_022"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……是啊。",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_023"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她是「俳句大師」。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n不只是蘭德索爾，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她也在世界各地四處旅行。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……然後",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_024"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "將各地的絕美景色詠唱成俳句。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她創作出為數眾多的名句，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n獲得了世人的高度評價。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "很多人都受到她的影響，",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_025"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n使得俳句在蘭德索爾也蔚為風潮。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就連我也不例外。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都也是？",
        "unit_id": 100311,
        "voice": "vo_adv_5136066_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那還真是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很有影響力呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不過。",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_027"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這樣下去可沒有辦法修行。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……妮諾。",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_028"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n既然妳說我是忍者，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那就用妳的雙眼再次看清楚了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔唔？",
        "unit_id": 103011,
        "voice": "vo_adv_5136066_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對我的挑戰，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "下戰帖嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好呀，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我接受！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "──隱忍於嚴冬，",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_030"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "荒涼寂寥寒風中，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "吾所執之劍……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那麼在下，",
        "unit_id": 135614,
        "voice": "vo_adv_5136066_031"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就此告辭！！",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗚哇！",
        "unit_id": 100311,
        "voice": "vo_adv_5136066_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的眼前",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "變得一片白……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
