        "voice": "vo_adv_1076005_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下馬上來救您！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風之精靈……",
