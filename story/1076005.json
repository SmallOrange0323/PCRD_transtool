    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "習得了加護，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此後就能自由自在地在水中呼吸了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您看，",
