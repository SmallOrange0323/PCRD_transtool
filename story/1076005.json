[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在初夏的某一天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿為了找東西，一個個地打開衣櫃。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……怪了？",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下把它收到哪了呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要是這個抽屜也沒有……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這裡嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來放在這裡！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平常都沒機會穿，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以完全忘了放在這。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來您醒了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是不是吵到您了呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實在下",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正在找泳衣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為夏天",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很快就要造訪蘭德索爾了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今年",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的活動",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然不包含度假，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是想到海邊去一趟……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是只有在下獨自前去，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想請主人也一起走一趟……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您意下如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就知道",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您一定會答應的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……您還記得之前",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們一起在",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海裡散步的事情嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能來到海邊真是太好了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對於凱留小姐所施予的神奇魔法，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得好好道謝呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇哇，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "維持姿勢好難呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像是散步在沒有重力的",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遙遠宇宙中，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n某顆星球上的感覺。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下的故鄉",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在深山裡……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讀了很多書，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是一直在幻想呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在我們的頭頂上，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n延伸到",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比在天空還更遙遠的那端，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂的大宇宙……",
        "unit_id": 107611
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……身體",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "輕飄飄地浮起來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天空與地面的界線也變得模糊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一種未知的全新感受。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那之後，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下閱讀了很多文件，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得知在大陸近海的海溝，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會出現那種如太空般的情景。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "據說連白天的",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太陽光也無法抵達，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此總是籠罩在黑暗之中。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "書上還寫道，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一到了晚上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那裡會出現其他海域看不到的特殊景象。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那道海溝中",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獨有的海洋生物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎一到了晚上",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會一起發光。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此文獻",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稱該地為「星海」。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "光是閱讀文獻，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就無法抑制心中的雀躍之情……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了讓主人看到那美麗的景象，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下才會像這樣開始做準備。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請放心交給在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下定會帶您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一覽那神秘的光景。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下是",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在深山中長大的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈族。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對於在下這樣的人來說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大海是一個陌生的地方。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下既然是服侍主人的嚮導……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論您要去哪裡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的使命就是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "引領您前往那個地方。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若能成功引導您前往星海，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下相信在往後的冒險中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您將更能夠感到安心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下一定會",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在此趟旅程中展現身為嚮導有所成長的一面。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這之前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下得先學習新的加護。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上次到海邊去的時候，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在凱留小姐的魔法的幫助下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們能夠一起在海中漫步。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次由於不確定她是否能抽空幫助我們……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是能夠習得擁有和那種魔法",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相同效果的精靈加護，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下相信能夠成為",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克服海洋阻礙的第一步。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天在下想在蘭德索爾",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "附近的水域修行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若您不介意，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下希望主人也能",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一同前往……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在這裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人的泳裝，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是最先準備好的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下可沒有忘記",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的泳裝放哪喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人所有衣物的位置",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都記起來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1076005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您先填飽肚子吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下馬上去",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為您把早餐拿過來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "準備好了之後",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就動身吧。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "501370"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……一、",
        "unit_id": 107612,
        "voice": "vo_adv_1076005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "二……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "三、",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "四……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 107612,
        "voice": "vo_adv_1076005_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "暖身運動",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣應該就差不多了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也已經準備好了呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的！",
        "unit_id": 107612,
        "voice": "vo_adv_1076005_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先集中精神……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……風之精靈啊！",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請賜予我們",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "舒適的空氣外衣！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就像凱留小姐的魔法一樣，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在身體的表面覆蓋了一層空氣膜。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣應該就沒問題了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯。",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只憑眼睛是看不出效果的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們趕緊",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "下水看看吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……預──",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "備！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咳、",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下搞砸了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝、",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "空氣外衣",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "弄厚一點是不是會比較好呢……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多嘗試幾次看看吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您陪在下練習到最後……！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下要開始了！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風之精靈啊！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多嘗試幾次後，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下開始抓到訣竅了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然在下是第一次此用這類的加護，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經漸漸看到希望了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還沒辦法潛到水底，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過照這情況繼續嘗試，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "下一次……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在開始修行之前，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下誠心做了一個護身符，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望能夠萬事順利……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在剛剛潛水的時候，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不小心掉進水底了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個護身符是由曬乾的草木編織而成的，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n長時間泡在水中",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會散掉。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是什麼重要的東西，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這不是個好兆頭……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想要馬上拿回來，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過還得休息一下",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才有體力下潛……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可、",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖說加護的力量變強了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但畢竟還沒有完全習得……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……既然主人都",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "風之精靈啊！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "千萬不要太逞強……！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下再休息一會",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會一起下去……！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您萬事小心……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊！？",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "果然",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "加護還不夠完整……！？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下馬上去救您！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n風之──",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可、",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說起來這",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全都是在下的錯，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是在下弄丟了護身符，也仍沒有完全習得加護！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要在下在安全的地方看著主人痛苦掙扎，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下做不到！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "加護雖然還不完整，",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是為了主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
