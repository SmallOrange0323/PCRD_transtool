        "voice": "vo_adv_1076005_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想要拯救主人的心情。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此在下完美",
