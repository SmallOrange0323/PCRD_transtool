        "voice": "vo_adv_1076005_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請賜予在下加護",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拯救主人……！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 107611,
        "voice": "vo_adv_1076005_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……！　",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才加護",
