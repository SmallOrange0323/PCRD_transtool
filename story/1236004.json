        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "得回去家裡",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好好地在床上睡一覺才行。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_065"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼了──？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你的眼神怎麼那麼難過。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是因為要和我分開所以很寂寞嗎？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真拿你沒辦法～",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_066"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那麼",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就護送你回家吧♪",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟讓你一個人走夜路",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也會擔心嘛。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……咦？",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_067"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你要送我回家？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "謝謝你。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過沒問題的。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為我",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可是【王宮騎士團】的一員啊。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……我啊，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_068"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能對自己喜歡的事物說出喜歡之後，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還注意到了",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一件很重要的事。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那就是，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_069"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要享受喜歡的事物，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n和平是很重要的──",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是這件事。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在能讓大家安心，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_070"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和平的世界裡，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n才能去蜜月旅行、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "享受變裝、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "熱衷裁縫，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對吧。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以至少，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_071"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在我能力所及的範圍內也好，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我想要",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "守護這個和平的世界……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是這樣想的。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_072"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就算這麼說，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在還只是不成熟之人的夢話罷了。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "既然說出來了，就要努力才行呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會說到做到的。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_073"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那我們就回去吧！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……啊，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在結束前可以靠近一點，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "把我的變裝印在你的心底喔♪",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "開玩笑的！",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_074"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管表現出了捉弄人的態度，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是發誓要守護和平而注視著蘭德索爾的智，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看上去非常的耀眼奪目。"
    }
]