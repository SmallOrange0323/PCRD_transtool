    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "經歷了發生各種事故的萬聖節夜晚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n智和{player}正坐著休息。"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呼～",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天還真是累人呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以一整天都穿著這身服裝，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感覺有點開心。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "過了萬聖節之後就沒有什麼機會可以穿了呢。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哈哈，",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那樣就不是變裝了吧！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "既然你那樣說的話……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我要不要偶爾只在你面前穿呢……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "開玩笑的♪",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "欸……",
        "unit_id": 123611,
        "voice": "vo_adv_1236004_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好刺眼！？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這道光是……",
        "unit_id": 123611
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……好，做好了。",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這邊的裝飾應該這樣就可以了吧？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "嗯，",
        "unit_id": 1231,
        "voice": "vo_adv_1236004_005"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "完美！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "不過小智，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "突然拜託妳",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "真是抱歉……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "都已經是萬聖節活動當天了，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "還手忙腳亂的。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n如果知道妳要和男朋友約會，我就不會找妳幫忙了……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不、",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不是的，他不是我的男朋友……！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我和{player}",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是剛好在那邊遇到後，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他就說要幫我，才跟著過來的……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "哎呀，原來是這樣啊？",
        "unit_id": 1231,
        "voice": "vo_adv_1236004_007"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "因為你們很般配，我就以為一定是情侶。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什、",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼般配，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "才沒有……！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……首先，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "交男朋友這件事對我來說還太早了……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "才沒有那種事呢，",
        "unit_id": 1231,
        "voice": "vo_adv_1236004_009"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "小智妳也已經不是小孩了啊♪",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……也、",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是呢……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等等，{player}。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你從剛剛開始就在默默分裝糖果呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "對呢，",
        "unit_id": 1231,
        "voice": "vo_adv_1236004_011"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我們快點準備好吧！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n我朋友的孩子們也說他們要變裝，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "非常興致勃勃呢♪",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "呵呵，",
        "unit_id": 1231,
        "voice": "vo_adv_1236004_012"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我小時候也很憧憬公主呢～",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "有點想回到那時候好好享受變裝啊……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "這種想法很孩子氣對吧。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那、",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那種事情……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……啊，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "聊著聊著手上的工作就停下來了呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}你把糖果袋給我吧？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我跟你分工。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "飲料。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這是你幫忙的回禮，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我請客♪",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "裝糖果的工作看起來也快要完成了呢～",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣應該能在小朋友們抵達前處理好。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……那個，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我可以問你一件事嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}你，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也覺得變裝什麼的……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……是很孩子氣的事嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就、",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是呢！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n現在就連大人，也有很多喜歡動畫或遊戲的人，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n會對那些產生憧憬也是再自然不過的事對吧！！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……啊，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……！！",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……哈哈，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真不愧是你呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n表面上感覺沒想什麼，其實觀察力很敏銳啊。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你說的沒錯。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n……我其實對變裝很有興趣。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n包包裡面也裝著變裝的服裝……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我很猶豫。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n該說是有點無法鼓起勇氣……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是很害怕呢……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……商店街的人",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都是從以前就認識我了。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他們是不是會認為，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n現在的我是個成熟穩健的道場孩子呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……什麼的，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也可能是我太自以為是了。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過至少，",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他們已經不覺得我是小孩了。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n從他們叫我幫忙準備讓孩子們享樂的萬聖節活動這點來看，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是證據了……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我對於被當成大人沒有什麼不滿唷。",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果我說其實我想要變裝的話，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n會不會被商店街的大家覺得很幼稚，而對我感到失望呢……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以才說",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我很猶豫……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼羞恥的事情，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我怎麼會對你說出來呢……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哈哈。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天果然還是別變裝了吧！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好了，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們繼續幫忙吧！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……咦？",
        "unit_id": 103731,
        "voice": "vo_adv_1236004_029"
    },
    {
