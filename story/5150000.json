[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的城鎮迎來了預料外的酷暑。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在【美食殿堂】的公會小屋裡，除了有享受著假日的{player}外，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n還有一位小小的妖精正在悠閒地放鬆著。"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呼～",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……好熱。",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好熱，熱死人了！",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "怎麼會這麼熱啊！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就算現在是夏天，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也要好好拿捏分寸啊！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "熱成這樣，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不是只能窩在家裡了嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你知道嗎？",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n最近城鎮的居民幾乎都沒外出哦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "聽說這是很罕見的異常氣溫呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這樣連想來個惡作劇都沒辦法做啊。",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我好不容易可以出門了耶～？",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_005"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n最近都沒在惡作劇，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "卻還要繼續忍下去，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這簡直就是我的個人特色陷入危機啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你也是這麼想的吧？",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈！",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那你願意讓我對你惡作劇吧～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看我的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "搔癢攻擊～！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n看我",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "搔遍你全身上下～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就算不惡作劇，",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我還是我？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這番話讓人好心動哦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你就是像這樣讓許多人……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "對吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n像你這樣罪孽深重的男人，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就用讓腳上襪子破洞的不起眼～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "惡作劇反擊～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……唉，",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不行。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n這麼無聊的惡作劇無法滿足我。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然我要是說出什麼",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "很不過癮之類的話，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "可能會被菲歐罵就是了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說回來，",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還真是難得呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n只有我和你獨處。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "貪吃佩可、凱留和可可蘿都不在吧。",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "在這種大熱天還要工作",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是辛苦呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "幸好我是自由又無拘無束的惡作劇妖精～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……不過，",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也因此我才會閒得發慌。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "唉～",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n有沒有什麼好玩的事呢～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──有哦～♪",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀啊！？",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n突然跑出人來啦！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵♪",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嚇到了嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "竟、",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "竟敢出其不意來嚇我，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還滿行的嘛。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "怎麼看",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳都是非法入侵，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過我就當作沒看見吧。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呃～妳是帆稀對吧。",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "龍人族的帆稀。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有什麼事？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "有好玩的事是什麼意思？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那條尾巴是怎麼回事？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "睡覺時不會覺得角很礙事嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那隻小龍不會咬人嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳的好奇心真旺盛呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以請妳先等一下下嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關於這件事",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也想知會愛梅斯一聲～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要找她的話，",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "由我透過嚮導小妖精專用的頻道幫妳叫她來吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都不用也沒關係啦～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "外頭很熱，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只靠通訊叫她來也不太好吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以說，",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就用這個方法♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哼哼哼哼～♪",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下首歌──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等等，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n為什麼你會在這裡！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可沒有找你來耶！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼？",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是要找我過去？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帆稀她嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是利用了我和你的連結吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對她",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的是不能掉以輕心呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以說，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是要我去",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "【美食殿堂】的公會小屋吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……可是別看我這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可是也有很多事情要忙耶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過算了。",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n最近也沒去看涅比亞過得如何，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就去露個臉吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟你都特地像這樣跑來拜託了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "待會見囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不這麼說，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就沒有一種",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "替在這裡的對話劃下句點的感覺呢。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──「索爾生成系統」。",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "帆稀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可終於醒啦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說你啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你在切斷連接後未免也太慢才醒來了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這下不是變成我先抵達，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後話題都已經要開始了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然因為透過睡眠進行連接，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n導致要醒來會出現時間差，這一點是莫可奈何啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "簡單來說，你只要醒來後能再更快一點起床就好了。",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每天早上都讓小可可蘿叫醒你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太令人羨慕了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳的嫉妒心完全透露出來囉，",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_034"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們差不多",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可以回到正題了嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n虧我像這樣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "耐人尋味地說了句",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「索爾生成系統」，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n然後就被擱在一邊令人有些難為情呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……抱歉了。",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就麻煩妳再繼續說吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那為了讓大家好懂，我就從頭開始說起。",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "首先啊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大家都不覺得很奇怪嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是近日來",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "蘭德索爾的天氣。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "豈止覺得奇怪啊。",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_039"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "簡直熱到",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讓人很厭世。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對吧對吧～",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我猜這個氣溫",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "恐怕是超過了",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這座城鎮「被設定的上限」吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n……畢竟",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "到目前一直過得很舒適對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳又說些",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很可疑的話出來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哈哈哈♪",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n然後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接下來才是重點～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原因……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我覺得",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該是出在這裡吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那是……",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_043"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "系統控制台？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n而且這裡寫著",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "環境系統……！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯。",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n環境系統",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「索爾生成系統」。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n原本好像是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "霸瞳皇帝在管理的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "功能方面",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就正如其名，用來進行環境調節。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n設定天氣和氣溫……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "此外，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n某種程度上",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "似乎還能改變城鎮的構造呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……那個人可是自稱為神，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並把這座城鎮打造成讓龐大的人口",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能居住的環境呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像是整頓自來水設備等等基礎建設……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我並沒打算讚揚他啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以妳的意思是，霸瞳皇帝離開了神的座位後，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個環境系統也被遺棄……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才像現在這樣",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "狀況不佳，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是這麼回事～",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣啊……",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼妳會察覺這件事？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯。",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別想用「嗯」",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來裝傻啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我是在問妳為什麼環境系統狀況不佳，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳卻能察覺到這一點啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……因為",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "環境系統正好就在那裡啊……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要說得好像是什麼格言一樣啊！",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是受不了妳。",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "系統控制台",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n本來可不是「一般人」該碰的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而妳這個人哦……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "放心放心～",
        "unit_id": 106711,
        "voice": "vo_adv_5150000_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哎呀，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個環境系統",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n為了讓「一般人」無法隨意亂操作，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以設下了超～嚴密的鎖定機制～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我完全摸不到唷～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但看來妳有試著去摸個兩下呢……",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n感謝妳告訴我這件事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正我大概也沒有管理權限，",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等等就把這件事丟給晶去煩惱──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──奇怪？",
        "unit_id": 190011,
        "voice": "vo_adv_5150000_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個系統……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連我也有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "管理權限？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這是怎麼回事啊？",
        "unit_id": 190911,
        "voice": "vo_adv_5150000_059"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "快讓我看看～！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哦～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這就是環境系統啊～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就來調降一點氣溫吧，",
