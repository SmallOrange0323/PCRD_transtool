[
    {
        "type": "background",
        "background": "501500"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 15811,
        "voice": "vo_adv_1211003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……你得親自",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟那個傢伙做個了斷。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "需要力量的話",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可以無限出借給你。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是一直",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "相信著你喔……！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一定要贏啊……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了讓大家再次一起享用美食！　",
        "unit_id": 121111
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──故事先回溯到幾個小時前。\n凱留相信了霸瞳皇帝所言，\n將沉睡的{player}背在身上攀登索爾之塔。"
    },
    {
        "type": "still",
        "still": "121100301"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼、",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼哈……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……凱留小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再怎麼利用魔法強化肉體，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n背著主人前進應該還是太辛苦了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在這附近",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先休息一下如何？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……妳在說什麼啊，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們才剛開始爬而已不是嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說這點程度而已，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點也不辛苦啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至今這段時間，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們經歷了那麼多誇張的冒險，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這點程度只是小事，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小事而已。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……仔細想想，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們至今一起經歷了許多次冒險呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不論做什麼，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是去哪裡，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "身邊總是有這傢伙和貪吃佩可。",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳還記得嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上了「迷人南國之旅」這廣告詞的當，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n跑去瑪爾傑海岸那邊度假的事。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很是令人懷念呢。",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當時在下被魔物抓走，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n多虧了各位前來拯救。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那時候打倒的魔物",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都做成烤肉享用了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n非常地美味。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有這回事呢……",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那時候還覺得魔物料理聽起來就很噁心……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在就很遺憾地，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大多照吃不誤幾乎不覺得不對勁了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從那之後……",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "作為【美食殿堂】，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還去了些很不妙的地方冒險。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「雲海山脈」那次還不熟悉爬山，爬得很辛苦……",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過山頂附近的魔物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n肉真是好吃到下巴都快掉下來了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在「密林大樹」那裡，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n取得了被譽為世界第一美味水果的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "密林果實嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為外皮實在太硬，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還費了好些工夫去找食用的方法呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們還曾經打倒過龍吧。",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把龍的尾巴做成關東煮，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家一起享用……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是我人生裡吃過最美味的關東煮了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……對了對了，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們還去了很多地方冒險呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n像是樹海、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有火山、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪原、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以及沙漠等等。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到哪裡都被迫享用了魔物料理……",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然很不甘心，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但現在倒是吃得很習慣了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……",
        "unit_id": 106411,
        "voice": "vo_adv_1211003_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳平常都會對魔物料理抱怨，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n其實是很喜歡的嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不不，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才沒有喔！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我怎麼可能",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會喜歡上魔物料理啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在也是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "常常一看那外表就覺得哇～我不行。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不願意承認……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可做的魔物料理是真的好吃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我現在已經不會抗拒到死也不願意吃了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唉。",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是沒有遇到這些人，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我本來是絕對不會考慮吃魔物的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……總之，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然經歷過許多事，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這些以往的冒險都是快樂的回憶呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得沒錯。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是度過了許多快樂的冒險。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "未來的冒險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曉得又會如何變化了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下也曾想過，",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萬一主人和貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就這樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直沉睡，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會變成什麼樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若是",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位就這麼沉睡下去……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟該如何是好……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼一來……",
        "unit_id": 106411,
        "voice": "vo_adv_1211003_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n【美食殿堂】就……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……【美食殿堂】不會有問題的！",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n和以前一樣，不會改變！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對會把那兩個貪睡蟲叫起來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n對吧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下真是失態……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確是這樣呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我……",
        "unit_id": 106411,
        "voice": "vo_adv_1211003_032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許是有點太喪氣了呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在我沒事了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n多虧凱留，我已經醒悟了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話說回來……",
        "unit_id": 106411,
        "voice": "vo_adv_1211003_033"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留妳真的是很喜歡貪吃佩可和他呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這也是早就知道的事了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哼。",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我只是覺得，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有他們在的時候，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吃飯吃起來比較香而已。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是他們讓我知道",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家一起吃飯的美味。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "他們得負起責任，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要醒過來負責才行。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是為了我的美味料理才幫助他們，",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和喜歡討厭什麼的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "完全沒有關係喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是不坦率呢。",
        "unit_id": 106411,
        "voice": "vo_adv_1211003_037"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為了美味料理出手相助……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這種原因，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許倒是很符合【美食殿堂】的風格呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得對。",
        "unit_id": 105911,
        "voice": "vo_adv_1211003_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了美味的料理……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一定要",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拯救他們兩位。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這還用說。",
        "unit_id": 106011,
        "voice": "vo_adv_1211003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去把那兩人給敲醒吧！",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "501500"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──時間再次回到現在。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我的命運，",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n自從遇到你們就改變了。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有你和貪吃佩可在的世界，",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對現在的我而言，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經無法去想像了。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "平常就算撕了我的嘴也說不出口……",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但對於你們拯救了我這件事，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我真的感謝在心。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝你們。",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "告訴了我，大家一起吃的料理，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是那麼地美味。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了能夠和大家",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再次一起享用美味料理……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以你自己的力量",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "贏得勝利吧！",
        "unit_id": 121111
    },
    {
        "type": "background",
        "background": "501500"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "唔",
        "unit_id": 100011,
        "voice": "vo_adv_1211003_046"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "哦哦哦哦──！",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來吧！",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_047"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "我要，",
        "unit_id": 100011,
        "voice": "vo_adv_1211003_048"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "超越我自己！",
        "unit_id": 100011
    },
    {
        "type": "background",
        "background": "501500"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 15811,
        "voice": "vo_adv_1211003_049"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "藉著和大家的",
        "unit_id": 100011,
        "voice": "vo_adv_1211003_050"
    },
    {
        "type": "dialogue",
        "name": "{0}",
        "words": "羈絆之力。",
        "unit_id": 100011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……沒錯。",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們藉著連結在一起而前進。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "即使是一個人無可奈何的事，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要有了大家的羈絆",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就能超越過去。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……謝謝您。",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝您借給我們力量。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多虧了和陛下的連結，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才能夠保護我最喜歡的人們。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這麼一來漫長的夢境應該就結束了。",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實在是有夠愛睡。",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等你醒過來，",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最先開口的一定會是我，",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──開口對你說早安！",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 121111,
        "voice": "vo_adv_1211003_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等你和大家打過招呼……",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再一起去享用",
        "unit_id": 121111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "美味的料理吧！",
        "unit_id": 121111
    }
