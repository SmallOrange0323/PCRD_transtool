[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "突、",
        "unit_id": 114511,
        "voice": "vo_adv_5054322_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "突然冷起來了……",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該不會",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是那傢伙搞的鬼吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "早知如此，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起時髦性，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我就會穿更具功能性的服裝來了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……而且，",
        "unit_id": 114411,
        "voice": "vo_adv_5054322_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太過寒冷，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我甚至都有點眼花了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在那一邊，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好像有幾個眼熟的身影……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃，",
        "unit_id": 114611,
        "voice": "vo_adv_5054322_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "振作一點！",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那是冒牌貨啦！！",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊啊！",
        "unit_id": 114411,
        "voice": "vo_adv_5054322_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就想說",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「為什麼各位都像",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n喝了酒的優花梨，走路搖搖晃晃的呢？」",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這下我的疑問",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "得到解答了呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "什麼嘛秋乃！",
        "unit_id": 114611,
        "voice": "vo_adv_5054322_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我才不會喝到走路搖搖晃晃的呢！？",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我作為成熟的大人，",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在飲酒上，可是很有分寸的！",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個……",
        "unit_id": 114411,
        "voice": "vo_adv_5054322_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……就、",
        "unit_id": 114511,
        "voice": "vo_adv_5054322_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是說啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那、",
        "unit_id": 114611,
        "voice": "vo_adv_5054322_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那是什麼微妙的反應啊……",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的，",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你也幫我跟她們說說啦！",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好了好了，",
        "unit_id": 114511,
        "voice": "vo_adv_5054322_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那種事先放一邊！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要認真戰鬥囉！",
        "unit_id": 114411,
        "voice": "vo_adv_5054322_009"
    }
]