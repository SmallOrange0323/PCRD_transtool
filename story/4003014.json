        "voice": "vo_adv_4003014_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是會冒出祕密小房間的門然後東西就藏在裡面呢……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想過了各種可能性，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是什麼事都沒發生！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼……！？",
        "unit_id": 105811,
        "voice": "vo_adv_4003014_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說好的極致的甜點呢～！！？？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是妳自己講的吧……",
        "unit_id": 106011,
        "voice": "vo_adv_4003014_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真的什麼都沒有嗎……？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼會有這種事？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那我們在拚什麼呀，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "太扯了吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105811,
        "voice": "vo_adv_4003014_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼可以這樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家那麼辛苦才打倒的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n居然無法與甜點相見……",
        "unit_id": 105811
