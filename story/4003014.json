        "voice": "vo_adv_4003014_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "強得亂七八糟……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不行……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔力用光了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也動不了了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳沒事嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105811,
        "voice": "vo_adv_4003014_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可？",
        "unit_id": 106011,
        "voice": "vo_adv_4003014_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "回我話呀？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105811,
        "voice": "vo_adv_4003014_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛才那個",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是古文書記載的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「試鍊」對吧……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得是啦，",
        "unit_id": 106011,
        "voice": "vo_adv_4003014_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那又怎麼樣了嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………啊！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有……",
        "unit_id": 105811,
        "voice": "vo_adv_4003014_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有……",
        "unit_id": 105811
