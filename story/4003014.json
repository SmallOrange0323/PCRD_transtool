        "voice": "vo_adv_4003014_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳……！！",
