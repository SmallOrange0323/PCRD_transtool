    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過看到那些孩子時",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得很溫暖呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然沒辦法對本人們說出口……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我明明故意不明確說出來的……",
        "unit_id": 114011,
        "voice": "vo_adv_6050203_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確是那樣啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可愛這個詞最貼切不過了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起可怕還是可愛比較好，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011,
        "voice": "vo_adv_6050203_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果本人們沒有放棄的話一定可以的。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是我也能幫上忙就好了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是如果變得太恐怖，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就有點困擾了……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 114011,
        "voice": "vo_adv_6050203_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n嗯～",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
