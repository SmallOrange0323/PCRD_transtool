[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼……",
        "unit_id": 110811,
        "voice": "vo_adv_5140203_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這次的戰鬥時間縮得超級短呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "都怪公會管理協會挑些毫無根據的毛病，",
        "unit_id": 111011,
        "voice": "vo_adv_5140203_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n說什麼每次戰鬥前的閒聊都太長了之類的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "把時間縮到這麼短的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那群人就不會抱怨了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們趁亂，",
        "unit_id": 110911,
        "voice": "vo_adv_5140203_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "將對手塑造成銀河級的壞蛋了呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "碰巧經過的路人不曉得事情原委，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也會想說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「哦～好朋友社",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這次是在為人類而戰啊」對吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "砰～！",
        "unit_id": 1,
        "voice": "vo_adv_5140203_003"
    },
    {
        "type": "dialogue",
        "name": "羅塞塔",
        "words": "\n劇透也完美迴避！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，",
        "unit_id": 111011,
        "voice": "vo_adv_5140203_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就這樣保持節奏上吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n正好秋乃",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "透過通訊魔法聯絡我了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n說是接送用的飛空艇，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "已經在中庭等我們了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太神了吧。",
        "unit_id": 110811,
        "voice": "vo_adv_5140203_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕起來了！",
        "unit_id": 110911,
        "voice": "vo_adv_5140203_006"
    }
]