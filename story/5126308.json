[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔唔……",
        "unit_id": 127211,
        "voice": "vo_adv_5126308_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好強的魔力……！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看來牠終於開始使出全力了嗎……！？",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 127211,
        "voice": "vo_adv_5126308_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真不可思議呢。",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明面對著這麼恐怖的魔物，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我卻一點都不害怕。",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不得了耶凱留寶，",
        "unit_id": 127311,
        "voice": "vo_adv_5126308_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也是一樣的心情！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為身邊",
        "unit_id": 127311
