    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有凱留寶和秀才在，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家完全不怕呢！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哼，",
        "unit_id": 127211,
        "voice": "vo_adv_5126308_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真虧妳能毫不害臊地",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大方說出這些話～",
        "unit_id": 127211
