[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨著在塔裡逐漸前進，來自魔物們的襲擊變得越來越激烈。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔呃～",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛才的魔物真是難纏。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要有小希希和老哥在，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就什麼都不可怕啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……沒有……",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希？",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵──！",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完全找不到鯛魚燒的食材喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n快點出現一兩隻會掉紅豆",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "或砂糖的魔物喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會、",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "會有這麼剛好符合需求的魔物嗎……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要我沒獲得任何成果就回去，我辦不到喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "至少讓我",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "找到能取代紅豆或砂糖的食材……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這是……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "搞不好",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "行得通喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳為什麼要盯著被打倒的魔物看？",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……妳該不會是。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳猜對了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要做出以魔物為食材的鯛魚燒喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "冷、",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "冷靜點啊小希希！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳做這種東西，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n沒有人會買的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老、",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就知道你會這麼說喵。",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒內餡的可能性有無限大！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "凡事都要嘗試看看喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵喵喵喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種不被常識所侷限的創意與行動力。",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比起鯛魚燒內餡，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "身為搞笑藝人的可能性，才更是無限大啦……！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完成了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即興魔物鯛魚燒，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請享用喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚嗚，",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不能浪費食物呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嚼，嚼……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……咦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這個",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "意外地",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好吃……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈！",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這就是鯛魚燒所隱藏的實力喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……難道說，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這就是",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我在尋找的食材……？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎怎怎喵會！",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "究極的鯛魚燒居然就在這裡喵──！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種濃厚的調味和堆積在胃裡的負荷感，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n與其說是點心，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是不是更像是配菜啊……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要把鯛魚燒的可能性調低喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "能夠輕鬆食用的點心感，才是鯛魚燒的本質，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唯有這點，我不可以退讓喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……可是，",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "加點砂糖會不會就比較像是點心喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "並不會啦！",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚嗚，",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真沒辦法，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只好放棄做魔物鯛魚燒了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "塔還很高喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這就代表我不能在這種地方妥協喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "未知的食材在呼喚我喵──！",
        "unit_id": 104611,
        "voice": "vo_adv_7020003_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "她那不氣餒的堅強心靈，",
        "unit_id": 103311,
        "voice": "vo_adv_7020003_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我真想學習。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能讓我打從心底吐槽的安心感……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小希希是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真陽有點神情複雜地凝視著珠希。"
    }
]