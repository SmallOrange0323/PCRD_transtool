        "name": "凱留",
        "words": "\n魔力的等級完全不同……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "──咦！？",
        "unit_id": 130911,
        "voice": "vo_adv_2203005_077"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n這股氣息，",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "難道是……！",
        "unit_id": 130911
    },
    {
        "type": "background",
        "background": "501780"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "萊拉耶爾殿下！",
        "unit_id": 130911,
        "voice": "vo_adv_2203005_078"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n您您您",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "您還好嗎……！？",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_079"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒事。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n只不過……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我已經很久沒有像這樣，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n拿出真本事來使用「皇家裝備」了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "剛才的，",
        "unit_id": 126011,
        "voice": "vo_adv_2203005_080"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就是萊拉耶爾小姐的",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "「皇家裝備」之力……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對吧？。",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不僅一口氣，",
        "unit_id": 106011,
        "voice": "vo_adv_2203005_081"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓那些蜘蛛全部蒸發，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們幾個甚至還",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "毫髮無傷……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是不得了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但相對地，",
        "unit_id": 105911,
        "voice": "vo_adv_2203005_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來也筋疲力竭了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_083"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只是小事罷了，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各位，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請你們別擔心……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我透過庫露露",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_084"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "利用魔法，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n掌握了你們的狀況。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "多虧如此，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我才能把握這個",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將魔物一網打盡的好機會。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "咦咦咦！？",
        "unit_id": 130911,
        "voice": "vo_adv_2203005_085"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n是、",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "是這樣嗎～！？",
        "unit_id": 130911
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……然後，",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_086"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士、",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "貪吃佩可公主……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我想要向你們，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好好地謝罪。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "謝罪？",
        "unit_id": 126111,
        "voice": "vo_adv_2203005_087"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該道歉的人",
        "unit_id": 105811,
        "voice": "vo_adv_2203005_088"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我才對喔？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖說我本來不曉得，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但還是啃掉了城堡裡重要的柱子！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126111,
        "voice": "vo_adv_2203005_089"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "關於那件事，",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_090"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就請妳別在意了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n多虧有克蘿茜她們，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才沒有造成嚴重的損傷，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還在可以修復的範圍內。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我想謝罪的，",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_091"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是比那更早的事。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我們……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_092"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是因為我，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "太理所當然地接受各位的好意了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那是指……",
        "unit_id": 125811,
        "voice": "vo_adv_2203005_093"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n哥哥他們",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "被委託去驅除魔物的事，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是嗎？",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒錯。",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_094"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就算過去我們多麼歌頌著和平，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "多麼不習慣戰鬥……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但想保護自己的國家，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是應該要靠自己的雙手才對。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "相反的，",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_095"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你們總是不顧自身的危險，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不僅肯定庫露露的想法，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也就是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「想奪回大家的笑容」，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n甚至還",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "挺身而出",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "拯救了她。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我不可能",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_096"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不相信你們各位。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萊拉耶爾小姐……！",
        "unit_id": 105811,
        "voice": "vo_adv_2203005_097"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106011,
        "voice": "vo_adv_2203005_098"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105911,
        "voice": "vo_adv_2203005_099"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這果然代表……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有人陷害貪吃佩可小姐和普蕾西亞小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n運氣好的話甚至想試圖毀掉王城……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……沒錯。",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_100"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不僅如此，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n在這座「大夢想樂園」中……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在我們的世界──",
        "unit_id": 126511,
        "voice": "vo_adv_2203005_101"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「吉歐‧提格尼亞」中",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "召來了魔物的某人，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n和這次的騷動有關係……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我實在",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不由得這麼想。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不過，",
        "unit_id": 125811,
        "voice": "vo_adv_2203005_102"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "妳說的那個某人",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "究竟是……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "總之，",
        "unit_id": 126011,
        "voice": "vo_adv_2203005_103"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說到有可能會",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "做出壞事，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就會想到之前",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "什麼三姊妹",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "的那群人──",
        "unit_id": 126011
    },
