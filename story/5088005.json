[
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是曾經在牧場發生過的事──"
    },
    {
        "type": "background",
        "background": "500152"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這次只是個教訓，",
        "unit_id": 102611,
        "voice": "vo_adv_5088005_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你們休想再來偷我們的起司！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "啾……",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_001"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "各位，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我們走。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "頭目！",
        "unit_id": 15912,
        "voice": "vo_adv_5088005_002"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "我們不能只有挨打的份啊！",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "繼續打下去我們沒有勝算。",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_003"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "撤退吧，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "啾三。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "啾……",
        "unit_id": 15912,
        "voice": "vo_adv_5088005_004"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "總有一天",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_005"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我一定會雪恥。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n然後終有一日，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "牧場的起司我會一個不剩地奪走……",
        "unit_id": 15911
    },
    {
        "type": "background",
        "background": "500123"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時光飛逝，在咲戀育幼院的屋頂裡──"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "頭目、",
        "unit_id": 15912,
        "voice": "vo_adv_5088005_006"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "頭目。",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "\n您怎麼了？",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "有心事嗎？",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我在想，時機差不多成熟了……",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_007"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n這陣子讓你們",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "吃苦了。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n都是我虧待你們，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "抱歉。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "那麼",
        "unit_id": 15912,
        "voice": "vo_adv_5088005_008"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "我們終於……",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "沒錯。",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_009"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "我們會追隨頭目",
        "unit_id": 15912,
        "voice": "vo_adv_5088005_010"
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "直到最後一刻。",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "\n對吧，",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "各位。",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾三",
        "words": "\n我沒說錯吧？",
        "unit_id": 15912
    },
    {
        "type": "dialogue",
        "name": "啾",
        "words": "啾！",
        "unit_id": 15915,
        "voice": "vo_adv_5088005_011"
    },
    {
        "type": "dialogue",
        "name": "啾太",
        "words": "啾！",
        "unit_id": 15913,
        "voice": "vo_adv_5088005_012"
    },
    {
        "type": "dialogue",
        "name": "啾也",
        "words": "啾！",
        "unit_id": 15914,
        "voice": "vo_adv_5088005_013"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "好，",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_014"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "去準備吧！",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "整理行囊，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "拿好武器。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n聽好了，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我們今夜就從這裡出發，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "小心不要被發現了。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "手下們",
        "words": "啾！",
        "unit_id": 1,
        "voice": "vo_adv_5088005_015"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我們被趕出牧場後，",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_016"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "好不容易流落到這個地方……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n但辛酸的時刻就要結束了。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "我們用廚房的鍋碗瓢盆武裝。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n即便在這種屋簷下，手下也增加了。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "如今正是……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "回鄉的好時機。",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "啊啊……",
        "unit_id": 15911,
        "voice": "vo_adv_5088005_017"
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "好懷念起司的味道，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "還有令人難以忘懷的牧場香氣……",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "\n光是回憶，",
        "unit_id": 15911
    },
    {
        "type": "dialogue",
        "name": "啾二",
        "words": "鬍鬚就蠢蠢欲動了呢。",
        "unit_id": 15911
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天也是綾音在育幼院內巡邏。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉，",
        "unit_id": 102311,
        "voice": "vo_adv_5088005_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是什麼啊？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗯？",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_019"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這不是腳印嗎。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n是從哪裡延伸過來的呢？」",
        "unit_id": 2111
    },
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這裡是",
        "unit_id": 102311,
        "voice": "vo_adv_5088005_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "美咲原本要留宿的房間啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n果然，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "腳印的主人就躲在這裡吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「可能喔。",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_021"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不但有奇怪的聲音，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "柱子上還有傷痕，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n所以她後來才住到妳們的房間吧？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒錯……",
        "unit_id": 102311,
        "voice": "vo_adv_5088005_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但那時候並沒有任何腳印。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "地上也沒有掉這種東西……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是什麼紙呢？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "上面畫著起司。",
        "unit_id": 102311,
        "voice": "vo_adv_5088005_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還有像文字的符號……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉看得懂嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗯……",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_024"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "日期糊掉了讀不出來……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我看看喔？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……漫長流浪的最後終於來到這個安居地。",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_025"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n但是起司不夠。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沒辦法讓大家再繼續餓著肚子了……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n他們似乎是從某個地方流浪到這裡的。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「下一頁是……",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_026"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n尋找可當武器的東西。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "鍋子、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "叉子、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "刀子……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n為了提前準備終將來臨之日，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我下達了武裝指示。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "結果會如何……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「這篇好像是最新的日記。",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_027"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我繼續",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "唸喔。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n庭院好熱鬧。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "起司的氣味乘風飄來。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n好想回家。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "好想回去吃起司。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "也想讓大家吃起司。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「故鄉的味道，",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_028"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "牧場的味道，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "那個起司倉庫的味道……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我們一族",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "靈魂的味道……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n起司、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "起司、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "起司、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "起司……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是",
        "unit_id": 102311,
        "voice": "vo_adv_5088005_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "之前在這裡的那些傢伙的日記吧……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗯，",
        "unit_id": 2111,
        "voice": "vo_adv_5088005_030"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "根據內容，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "最新的一頁",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "應該是在物產展第一天吧。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這麼說的話……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一定是胡桃跟美咲說的",
        "unit_id": 102311,
        "voice": "vo_adv_5088005_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個老鼠啦！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n牠們很大、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很強又很壞，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還最喜歡起司！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們走吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "得趕緊通知大家才行！！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喔！",
