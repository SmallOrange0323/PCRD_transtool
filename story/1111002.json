        "name": "鏡華",
        "words": "啊，",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_057"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "洗手間的看板！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n太好了！　",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只要在下個角落轉彎……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然{player}跟過來是在預料之外……",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_058"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是已經再也忍耐不住了……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總之進去吧！　",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太好了～。",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_059"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這樣就可以――",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃，",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_060"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n有好多人……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都在排隊……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎、",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_061"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼會……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好不容易快要趕上了……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "已經沒辦法忍耐了……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒事……",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_062"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才怪",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呢……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n差不多已經……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "快要",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "忍耐",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不住了……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚……",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_063"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這樣下去的話，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你也好大家也好，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都會笑我的……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？　",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_064"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等等，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "突然間是要做什麼啊！？",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你說交給你……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你該不會，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要帶我去洗手間……？",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_065"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請、",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要那麼搖晃……！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要是搖晃得太大的話……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個、",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚～……！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……大家都在看我",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_066"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……好、",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好丟臉……！　",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是……",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_067"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個人，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "完全不在意周遭，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n很拼命的跑著……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "平常明明那麼孩子氣的……",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_068"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "像現在這樣困擾的時候",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_069"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總是會",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "全力的幫助我……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n真的",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很可靠呢……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你的背",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_070"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是寬呢。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n有點像是大人……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "有一點帥……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也不一定呢。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_071"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那邊有空著的洗手間！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n非常感謝你，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "已經沒問題了！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……那個，",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_072"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請放我下來啦！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你為什麼會",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "想要走進女洗手間啦！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唔嗯～！",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_073"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那麼拼命的想要解釋，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n總覺得反而很可疑！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！　",
        "unit_id": 111111,
        "voice": "vo_adv_1111002_074"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "虧我還覺得你有點變帥了！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你果然還是",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "變態可疑分子！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "用很大的音量叫完後，\n鏡華就衝進了洗手間裡。"
    }
