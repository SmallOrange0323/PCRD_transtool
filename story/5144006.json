[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在鮮花祭的前一天晚上，鈴莓被幫派抓去當作人質。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而{player}和龍次"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n都還沒有察覺到這件事。"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "結果，",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_000"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "老大還是沒有來約定的地點……",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "他該不會",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "是決定放棄這個村子了嗎？　",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "村裡目前也很平靜。",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_001"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "要是能這樣子平安結束，",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "那就再好不過了。",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "早安，",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "龍次先生。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你已經開始進行早上的作業了嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "啊啊，",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_003"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "是鏡華和陰柔男啊。",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "你們才是，",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "怎麼這麼早就來了，",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n還可以再睡久一點呀？",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "啊？",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_004"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "沒有，",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "我沒看見。",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "她不是和你們待在一起嗎？",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "昨天晚上，",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "她說要先做好洗衣服的準備再睡覺，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以叫我們先去睡……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在那之後，",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "她好像沒有回到房間。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明她平時總是比我早起，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以會來叫我起床。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "那傢伙，",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_007"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "是在昨晚",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "說要去做洗衣服的準備是吧？",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "那她要洗的東西",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "現在在哪裡？",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "關於這個",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也有一點奇怪。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那些衣物到處散落在地上，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n甚至還有花瓣掉在四周……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "……",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_009"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "讓我看一下。",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是這種花瓣。",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "和村裡種的花",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "似乎是不同品種。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "糟了，",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_011"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "可惡！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n他們用怪物去襲擊小姑娘了嗎！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦，",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你說的怪物是指什麼？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "……",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_013"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "果然",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "只能全部說出來了！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "跟我過來吧，",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "我們還需要借助老頭子的力量！",
        "unit_id": 6312
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個～！",
        "unit_id": 130811,
        "voice": "vo_adv_5144006_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請放開我，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼你們要做這種事呢～！？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "呵呵呵，",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_015"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "反正事情結束後我們就會把妳給收拾掉了。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "我就告訴妳，讓妳當作上路的伴手禮吧。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "我們接下來要去襲擊村莊。",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_016"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "但是，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "儘管對方只是偏遠鄉下的孱弱農民，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n如果我們正面進攻的話，在數量上還是會輸。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "不過，",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_017"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "要是他們為了找妳而分散開來……",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "妳不覺得要解決他們就輕鬆多了嗎？",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "對於身為賓客而且深受信賴的妳，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "村長也無法置之不管。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你是為了這種目的，",
        "unit_id": 130811,
        "voice": "vo_adv_5144006_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而把我抓起來的嗎！？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "竟然打算",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "利用村民們的溫柔！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "只要能贏就好了啊，",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_019"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "能贏就好！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "等我把村裡的傢伙全部收拾掉，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "接著就換觀光客們了。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "剩下的值錢東西和作物，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "我們會全部拿來有效運用的！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "……特別是",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_020"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "這個村子的土壤，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n非常適合用來量產這種「魔物植物」啊！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "魔物植物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 12012
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是、",
        "unit_id": 130811,
        "voice": "vo_adv_5144006_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是昨天襲擊我的魔物對吧……！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "魔物為什麼會聽人類的話！？",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "妳很在意嗎！？",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_022"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "那我就連同這點也告訴妳吧！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "要馴服魔物",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "雖然需要長期的訓練或才能，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "但這傢伙經過了品種改良，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "會立刻就聽從於人類！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "不枉費我在龍次那傢伙搞砸後，",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_023"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n還是耗費苦心把種子偷出來！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "哼哈哈哈～！",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "魔物植物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 12012
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要、",
        "unit_id": 130811,
        "voice": "vo_adv_5144006_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是這種魔物大量增加，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可就大事不妙了！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得想想辦法才行～！？",
        "unit_id": 130811
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "……也就是說",
        "unit_id": 511,
        "voice": "vo_adv_5144006_025"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "你受到了幫派威脅，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n所以沒告訴大家，會有危險的魔物植物來攻擊村子是吧？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "而鈴莓小姐",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "也因此被綁架了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "沒錯，",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_026"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "全部都是我的錯……",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "之後不管有任何懲罰我都接受！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n但是現在",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "想先請你幫忙尋找小姑娘！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "村長先生，",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你不會棄鈴莓不顧吧……！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有錯的人既不是鈴莓也不是龍次！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n而是做出卑鄙行動的幫派啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "放心吧，",
        "unit_id": 511,
        "voice": "vo_adv_5144006_028"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我當然會派出人手。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "要是有什麼萬一，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "我也沒臉面對咲戀小姐。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "老頭子……",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_029"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "你也是",
        "unit_id": 511,
        "voice": "vo_adv_5144006_030"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "為了村子著想才會陷入兩難的吧？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n坦白說你的判斷並不正確，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "但是有錯的當然是威脅人的那一方。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你，",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "村長先生……！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只要很多人一起去找，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "應該就能找到的！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n得在她有什麼危險之前，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "救出她才行！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我",
        "unit_id": 100512,
        "voice": "vo_adv_5144006_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "先去請【王宮騎士團】支援！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "找人的部分就要麻煩大家，",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但為了以防萬一還是有備無患！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "是啊，麻煩妳了。",
        "unit_id": 511,
        "voice": "vo_adv_5144006_034"
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "走吧，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "男丁們出發去尋找鈴莓小姐！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "\n不管是鋤頭還是鐮刀都行，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村長",
        "words": "把能當武器的東西拿在手上！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性村民們",
        "words": "喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_5144006_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們也走吧！",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_036"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還差一點點",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就能舉辦鮮花祭了，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們絕對",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要把鈴莓小姐帶回來！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_037"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "老大，",
        "unit_id": 911,
        "voice": "vo_adv_5144006_038"
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "村裡的人開始行動了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "\n跟預想中的一樣，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "他們似乎打算分頭找人。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "看起來，",
        "unit_id": 811,
        "voice": "vo_adv_5144006_039"
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "作為賓客來訪的小鬼們似乎也混在裡面……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "反正只是來湊人數的吧？",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_040"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "總之，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "就想辦法處理掉。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "只要像對村民一樣對付他們就好了吧。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "不過，",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "記得別殺了村長和龍次，把他們帶到這裡來。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "我要確認村子財產的所在位置，",
        "unit_id": 2514,
        "voice": "vo_adv_5144006_041"
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n而且也得和龍次做個了斷。",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "\n……",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "幫派老大",
        "words": "你也這麼覺得對吧？",
        "unit_id": 2514
    },
    {
        "type": "dialogue",
        "name": "魔物植物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 12012
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "那個魔物植物的花瓣，",
        "unit_id": 1411,
        "voice": "vo_adv_5144006_042"
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "\n好像一路朝著森林的方向。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "他們一定",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_043"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是把鈴莓小姐藏在森林深處了！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n畢竟要是在村子裡，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很快就會被發現了。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_044"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "結果他們還是留下了花瓣，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真是糊塗呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "或許他們是不輸鈴莓的",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "冒失幫派也說不定。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "小姑娘，",
        "unit_id": 911,
        "voice": "vo_adv_5144006_045"
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "\n太瞧不起大人可是不行的喔。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "尤其，",
        "unit_id": 811,
        "voice": "vo_adv_5144006_046"
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "是拿著武器的大人啊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "出現了是吧！",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_047"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "\n",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "我要把你們全都……！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等等！",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_048"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這些人之所以會出現，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是因為被他們發現我們來找人了！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "沒辦法了，",
        "unit_id": 1411,
        "voice": "vo_adv_5144006_049"
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "我們兵分二路吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "\n這些傢伙我們會想辦法應付！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "\n你們",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性村民",
        "words": "趕快去鈴莓那裡！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「雖然說得很瀟灑，",
        "unit_id": 2111,
        "voice": "vo_adv_5144006_050"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n但大叔你們",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "在戰鬥方面是外行人吧？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也留下來戰鬥！",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n雖然很擔心鈴莓，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但如果是交給哥哥他們就沒有問題！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "抱歉了，",
        "unit_id": 130711,
        "voice": "vo_adv_5144006_052"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "綾音小姐！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這裡就交給他們，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們先往前進吧！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "感謝你們，",
        "unit_id": 6312,
        "voice": "vo_adv_5144006_053"
    },
    {
        "type": "dialogue",
        "name": "龍次",
        "words": "要平安無事啊！",
        "unit_id": 6312
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "居然會交給小鬼處理而自己逃跑，",
        "unit_id": 911,
        "voice": "vo_adv_5144006_054"
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "你真是墮落了呢，龍次！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "我怎麼可能這麼輕易地放你們走……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉……",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_055"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "全力揮～擊！！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "幫派手下1",
        "words": "噗哺啊！？",
        "unit_id": 911,
        "voice": "vo_adv_5144006_056"
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "那、",
        "unit_id": 811,
        "voice": "vo_adv_5144006_057"
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "那傢伙是怎麼回事啊！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "幫派手下2",
        "words": "\n不是說他們只是來湊人數的嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大叔。",
        "unit_id": 102311,
        "voice": "vo_adv_5144006_058"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n太瞧不起小孩子可是不行的喔？",
