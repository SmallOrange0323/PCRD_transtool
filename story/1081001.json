    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太好了。",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在這時期，不知道會發生什麼事情。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子！　",
        "unit_id": 2411,
        "voice": "vo_adv_1081001_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "要是你就那樣掛掉就好了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "呸呸。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說話別那麼兇。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有爸爸，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算你說",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「呸」，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n其實也吐不出口水吧？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個。",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在萬聖節這時期，現實與靈界會變得比較接近，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以魔物會受到惡靈之類的影響，變得很容易失控。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以，",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我很不希望你一個人獨自行動……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊。",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你現在是要回蘭德索爾對吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們就一起走吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也有事要去那裡一趟。",
        "unit_id": 103111
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為在這時期魔物很容易失控，",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以想換一些新裝備。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n現在我就是要去拿訂製的裝備。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哦哦哦！　",
        "unit_id": 2411,
        "voice": "vo_adv_1081001_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那些穿著萬聖節Cosplay的女孩，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "還真是大膽呢！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n大腿實在太耀眼了！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "而且，",
        "unit_id": 2411,
        "voice": "vo_adv_1081001_010"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "居然大剌剌地把胸部秀出來，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "真是太不知羞恥了！\n",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔齁齁，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好想埋在那胸部中間！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這種話偷偷說出來就好。",
