        "voice": "vo_adv_1081001_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 103111,
        "voice": "vo_adv_1081001_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你說我看起來好像沒什麼精神嗎？",
        "unit_id": 103111
