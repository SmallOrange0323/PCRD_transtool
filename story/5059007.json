        "words": "啊！",
        "unit_id": 100111,
        "voice": "vo_adv_5059007_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "找到了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喂",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "【美食殿堂】的各位！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "闖進精靈族之村的魔物皆順利討伐完畢，",
        "unit_id": 100311,
        "voice": "vo_adv_5059007_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n「黑色風之精靈」也消失無蹤，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們想說儀式應該結束了而趕來一看……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 115611,
        "voice": "vo_adv_5059007_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "居然在煮飯。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n很有貪吃佩可他們的風格呢。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_5059007_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "優衣～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怜還有日和，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們要不要一起吃飯呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我要我要！",
        "unit_id": 100111,
        "voice": "vo_adv_5059007_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我肚子都餓扁了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "受不了",
        "unit_id": 100311,
        "voice": "vo_adv_5059007_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……看來事情都進行得很順利，真是太好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看到這幅景象，我就放心了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們是不是被當成無論到哪都在吃飯的",
        "unit_id": 106012,
        "voice": "vo_adv_5059007_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n悠哉集團了啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們這群人……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……呵呵。",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼了？",
        "unit_id": 115611,
        "voice": "vo_adv_5059007_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "──可可蘿，",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳好像很開心的樣子。",
        "unit_id": 115611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇～！",
        "unit_id": 100111,
        "voice": "vo_adv_5059007_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我可能是第一次看到",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可可蘿笑成那樣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_5059007_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "平時她給人的感覺很成熟，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或說是穩重……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如今",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼講……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "天真無邪的，相當惹人憐愛。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼模樣呀？",
        "unit_id": 105812,
        "voice": "vo_adv_5059007_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳也讓我看看吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也給我瞧瞧啦！",
        "unit_id": 106012,
        "voice": "vo_adv_5059007_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好了，可蘿仔，快給我笑！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不然我搔妳癢喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜、",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託妳們不要捉弄在下了，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位……！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您救救在下……！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼事呢，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_016"
    },
    {
        "type": "still",
        "still": "505900701"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的！",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……貪吃佩可小姐。",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼？",
        "unit_id": 105812,
        "voice": "vo_adv_5059007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……凱留小姐。",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_5059007_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很慶幸",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能與各位相遇。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕不會再次放開這份羈絆。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "往後還請各位──",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──多多指教了。",
        "unit_id": 115511,
        "voice": "vo_adv_5059007_026"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "我才要請妳多指教。",
        "unit_id": 1,
        "voice": "vo_adv_5059007_027"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【美食殿堂】重新維繫起險些失去的羈絆了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那張餐桌上所綻放的笑容，要比從前要來得更加開朗。"
    }
]