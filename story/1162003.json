[
    {
        "type": "background",
        "background": "500732"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當過了正中午，「聖學祭」進入午休時間後──"
    },
    {
        "type": "background",
        "background": "500770"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在一般學生禁止進入的老舊校舍中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有一個小心緊戒著周遭、身穿白色制服的人影。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那位女學生，拿出了藏在制服內側口袋的信封。"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "很好，",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_000"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這裡沒有人在……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "嘿嘿，",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_001"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那就趕快來確認一下內容物──",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "咦咦～",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_002"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "人物拍得好小！",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "而且還微妙地有一點糊！　",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "真是的……",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_003"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n娜塔莉明明是書記，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n卻不太會用轉印魔法嗎……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "但是……",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_004"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n哈～",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "她穿這樣果然很適合呢……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n克蘿依的女僕裝",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我要按讚7兆次，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這是永久保存版……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "嗯喔喔喔喔！？",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_005"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你、",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_006"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你是……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n你是，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我想想，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那個……",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我忘了你叫什麼名字，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "但你是從月光學院來的特別插班生……！",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "咳。",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_007"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你來這種地方做什麼？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n這裡可是禁止進入的區域，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你有獲得許可嗎？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "啊？",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_008"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "沒什麼，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我手上的這個東西，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "並沒有什麼特別的。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這是你不需要知道的東西，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n是本學生會最重要的機密，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不管是誰都不能知曉。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "請、",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_009"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "請你不要光憑猜測就說出不確定的情報！",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "像那樣的東西──",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_010"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你是想說我在聖學祭期間裡放著會長職責不管，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n在沒有人的地方偷偷欣賞那種東西嗎？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "並不是好嗎。",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_011"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n你太冤枉我了，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "真不像話。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我有事要做，要先回聖學祭去，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "失陪了。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "…………",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_012"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你……",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_013"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你有什麼事嗎？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n為什麼要跟著我？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "什麼？",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_014"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你迷路了？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "是嗎。",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_015"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "在學校裡迷路了。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "雖然我很少聽說這種事，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n但看你那老實至極的表情，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "似乎不是在說謊呢。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "雖然我沒有義務幫助敵人，",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_016"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "但也沒有理由放著迷途羔羊不顧。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你如果想跟著我走，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "就自己跟上來吧。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不過我在趕時間，",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_017"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我並不是你的嚮導，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "所以沒空管你──",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "──走那邊",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_018"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "要小心一點。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n這棟建築物很老舊，",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "到處都有可能會崩塌。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n輕易地走到牆邊是很危險的。",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_019"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "瑪麗亞？",
        "unit_id": 7111
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "…………",
        "unit_id": 7111,
        "voice": "vo_adv_1162003_020"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "叫得挺熟的嘛，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_021"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "月光學院的同學。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n雖然我和你是同年級生，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "但我沒有理由被你這樣稱呼。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n請你稱呼我為學生會長。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "什麼？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_022"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這是因為──",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "因為……",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_023"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我也沒辦法啊……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n要是看得清楚對方的臉，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我就說不出想說的話了……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "如果需要表現得嚴厲，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_024"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "看不清楚臉剛剛好……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "反正我",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "也不是沒戴眼鏡就走不了路的大近視眼……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "──這是我個人的私事，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_025"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n不需要你來干涉。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "而且我的意思是，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_026"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你這樣太裝熟了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我們學生會和好朋友社……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "自稱好朋友社的你們，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "目前處於交戰狀態。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n不需要我多說，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我們應該是敵人啊。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……你為什麼要歪頭，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_027"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我並沒有說什麼難懂的話。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "還有，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_028"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你為什麼要露出沉穩的微笑。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我並沒有說什麼有趣的話。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "咦，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_029"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這個人是怎樣……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n搞不清楚他在想什麼……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n好可怕，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "救命啊娜塔莉！　",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……我在趕路。",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_030"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n請你不要輕易向我搭話。",
        "unit_id": 7112
    },
    {
        "type": "background",
        "background": "500760"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "…………",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_031"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_032"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……你為什麼都不說話？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_033"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "雖然我說了不要輕易向我搭話，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_034"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n但你一直默默走在我背後，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "也會造成我的負擔。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我允許了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "月光學院來的插班生，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "適當地說說話吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "…………",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_035"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這是最重要機密。",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_036"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "換別的話題。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "朋……",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_037"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "誰知道呢。",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_038"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n這要看人如何定義這個詞吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "在這寬廣的世界中，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_039"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "也是會有人把僅在同間教室上課而已的關係，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "稱呼為朋友吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n如果以這種詮釋方法來看，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我和她就會算是朋友。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "順帶一提，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_040"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我們剛入學沒多久的時候，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我曾經有借給她看她忘了帶的教科書。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n也就是說",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我們兩人",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "並肩共享了同一本書。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "哎呀，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_041"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "聽起來會很像在炫耀嗎？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n我並不是故意的，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "失禮了，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "失禮了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那麼，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_042"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你又如何呢，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "月光學院的同學？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "她──",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_043"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "二年級的克蘿依，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "本質上是一匹孤傲的狼。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n就算她會在名為學院的社會之中",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "姑且置身於人群裡，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "但還是和會輕易對他人搖尾巴的家犬不一樣。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "她那高尚的精神，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_044"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n就算是敵人，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我也抱有一定的敬意。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……是喔。",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_045"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "算了，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_046"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "畢竟這要看人怎麼定義嘛。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n既然你這麼自稱，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n那就代表在你的觀點看來是如此吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不過，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_047"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "究竟她又是怎麼想的呢？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "順帶一提，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我可是有跟她兩人並肩看過同一本書──",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "哎呀，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我又不小心開始炫耀了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "失禮了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那麼，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_048"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你能夠具體舉出與她共渡的深刻回憶，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n來證明你的說法嗎？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "唔……",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_049"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你說她幫助了迷路的你？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "哎呀，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我好像有聽過這種情節呢。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n你這個人",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "是把迷路當作人生志業了嗎？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "總之，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_050"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "這作為人際關係的證明還太薄弱了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n要是幫助迷路的人友情就會成立的話，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n那不就代表",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我現在和你也算是朋友了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_051"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你不需要那麼老實地感到開心，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n恕我拒絕。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "來吧，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_052"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "沒有其他例子了嗎？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我的意思是……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "就是，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那個，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "其他跟她有關的事件。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "殺手筆劍？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_053"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那是什麼？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n是她當作禮物？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "送給你的東西？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "該怎麼說呢……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "雖然我不太清楚，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "但她的品味真是獨特呢。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "其他的呢？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_054"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n例如",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "她對食物的喜好，或是常去的地方呢？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n她最近熱衷於什麼興趣？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "身高、體重、三圍呢？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……什麼？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_055"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "要是稱讚她的髮型，她就會一邊生氣一邊高興？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "…………",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_056"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "呃，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_057"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你說什麼，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那樣不就單純只是個萌角色嗎？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n高尚的孤獨一匹狼，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "居然會有這麼平易近人的一面……？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "什麼？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_058"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你有被她邀請到家裡去過？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "哼，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "說什麼傻話……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那是你聽錯了吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "她不可能做出那種像毒婦般的行為。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "真受不了……",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_059"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n看來你的情報",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "嚴重缺乏可信度呢。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "真是太浪費我的時間了，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "月光學院的同學。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "不過幸好現在",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_060"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "已經看得見出入口了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n只要走到外面去，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你應該就認得路了吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "午休時間就快結束了，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_061"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "聖學祭也將進入下半場。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "雖然說",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "已經看得出會是誰輸誰贏了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "接受破滅吧，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_062"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "好朋友社。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那麼，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_063"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "再會了。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "…………",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_064"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……你有什麼事？",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_065"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n為什麼要繼續跟著我？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "是嗎，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_066"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "你有預感還會再迷路是吧。",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n唉……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "隨便你吧。",
        "unit_id": 7112
    },
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪。",
        "unit_id": 116211,
        "voice": "vo_adv_1162003_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n怎麼了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你說要去上一下洗手間，人是跑哪去了？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好像莫名花了很多時間。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_1162003_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "和瑪麗亞嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼，怎麼回事？",
        "unit_id": 116211,
        "voice": "vo_adv_1162003_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙又來挑釁了嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n還好嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你要是有被她說一些冷言酸語就跟我說，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我會去幫你討公道的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是哦……",
        "unit_id": 116211,
        "voice": "vo_adv_1162003_070"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那傢伙",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不知道是想怎樣。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n她常常在瞪著我──",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "──啊，",
        "unit_id": 116211,
        "voice": "vo_adv_1162003_071"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她在那裡。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "來",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你看看，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她瞪著我們的表情嚴肅到很誇張對吧？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n她從以前就是這樣，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不知道為何我很受到她討厭。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪～",
        "unit_id": 116211,
        "voice": "vo_adv_1162003_072"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我到底是做了什麼啊？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n為什麼我得被那樣瞪著看？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "超級意義不明的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "啊啊，",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_073"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "克蘿依就在那裡……！",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n雖然我沒戴眼鏡看不清楚……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "嗚",
        "unit_id": 7112,
        "voice": "vo_adv_1162003_074"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "模模糊糊的……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n看不清楚，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "可惡，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "我要努力看見……",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "看見……！　",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了將克蘿依的身姿清楚烙印於近視的眼裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n瑪麗亞和平時一樣皺緊了眉頭，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她努力地嘗試使視線聚焦，就像是在瞪人一般。"
    }
]