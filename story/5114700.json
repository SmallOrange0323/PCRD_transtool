        "name": "ミヤコ",
        "words": "あ。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "とうがらしって書いてあるの。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "危ないところだったの。",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_014"
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "\nオマエが先に食べてくれて助かったの。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "ミヤコ",
        "words": "うぅ～～",
