[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和鏡華約好，\n今天兩人要一塊去野餐。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}，你遲到了。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n早就已經超過我們約好的時間了喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！請振作一點！",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明難得可以兩人一同出遊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你竟然遲到了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我不要再理你了。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n野餐，我自己一個人去就行了",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要跟過來。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我已經決定了，今天的野餐我要自己一個人去。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我要跟你分開行動。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……說不定會有魔物出沒？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沒問題啦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這附近的安全度很高，是安全區域。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才沒有那麼容易，就會遇上魔物呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "懂了的話，就快點放我自己……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇！",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n真、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的有魔物！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "往，",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "往這邊過來了！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n誰、誰來救救我呀……！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}你",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "受傷了！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都是為了要保護我才……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？趁現在趕快攻擊嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可、可是，以我的魔力……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……又是這樣，先是你的劍發了光，",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n接著我的魔力就提升了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這、這樣的話，說不定能夠打贏！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "宇宙藍色──閃光！",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_011"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "得、得救了……",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}，",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你的傷沒事嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……只是小擦傷",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而已嗎？　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太好了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？問我嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯、嗯……我沒事。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這都是多虧有你的保護，我才會沒有受傷呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "只是，那個……",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n說、說起來有些不好意思，但是我腳軟了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好像沒辦法自己站起來……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要、要做什麼？那個手？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……是要扶我一把嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是，呃……",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不、不用麻煩了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為……媽媽說過，",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "第一次牽手的對象，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n得要挑個可靠一點的男人……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……是呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n目前來看，的確算是相當的可靠。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n才、才沒有那回事呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你可是相當可靠的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "剛認識你的時候，雖然既怪，又可疑，還是個變態先生。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但總是幫助我……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "今天還從魔物的手中救了我一命。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且……剛才那樣，好像有點帥……",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、不對！",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n沒事！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不管怎樣！",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n目前為止，你還算是個可靠的人，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以……可以再借我一下你的手嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總、總算是有辦法站起來了……",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……{player}的手，",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n好溫暖呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？　我，我的臉很紅嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、不是，這個是……那個、呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚……什麼都沒有啦！",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "比起那種小事。快點，要走囉！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你問要去哪？",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那不是當然的嗎？要去野餐呀。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可是連你的便當都帶來了呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊。但是，有點擔心會不會又冒出魔物來呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036005_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不然，就回去蘭德索爾再一起吃吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果兩人還是回到了蘭德索爾，並且在廣場前一起吃了便當。"
    }
]