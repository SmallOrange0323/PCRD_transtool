    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔……",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像沒有什麼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n適合的物件呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且，蘭德索爾這個地方，",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "基本物價太高了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n但畢竟是王國的首都，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這也是無可奈何的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "王宮附近的地價",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n貴得嚇人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "房租",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也是我難以負荷的金額。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖說如此，",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要是離城鎮的中央區太遠會很不方便。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n聽說最近",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "治安也不是很好。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "女孩子一個人生活",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "又好像",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有點危險？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也不能就這樣",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一直借住在親戚家呀……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "【拉比林斯】的活動",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好像也開始被懷疑了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唉……",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要不要拜託公會長，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n用她那個「物件變更」的神祕能力",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n幫我蓋一間獨棟豪宅呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我這樣做牛做馬的，",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也想要一些犒賞呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n咦？\n{player}？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哈囉～☆",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好巧喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你在這裡做什麼呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔？",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n難道是察覺到姐姐的氣息，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "稀里糊塗的被吸引過來的嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我和{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n被命運的紅線緊緊相繫著呢！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我早就知道啦♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "放心吧！",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐我也是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這個宇宙最愛{player}的人～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿～",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}你這個害羞鬼！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n真可愛♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在大庭廣眾下",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n和姐姐相親相愛很難為情嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你青春期到了吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒事的。",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們是姐弟，沒什麼好難為情的呀！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱抱～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n好過分，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算是玩笑話也很殘忍！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是靜流姐呀～！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊……",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太好了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你想起來了呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}你好壞心眼呀！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我還以為",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你又忘記我了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n打擊太大，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "心臟差點都要停了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "先不說這個了。\n{player}，你在做什麼呀？",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來找房屋仲介有什麼事嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這種店會幫忙",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n介紹、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "媒合一些公寓住宅喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡是由",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n管理不動產的公會直營的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "需要找住處的時候",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就會到這裡來。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一直以來",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都是在親戚家叨擾著～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "名義上",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n說是借住到工作告一個段落，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個工作好像要延長了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也不太想給親戚們添麻煩。",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在考慮",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要不要租間公寓一個人住……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我一直沒有看到什麼",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不錯的物件。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你住在哪裡呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是住在老家嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我要不要",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n搬到{player}的附近住呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後我就能",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n天天登門去照顯你了……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔，",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你是四處住飯店呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很花錢呢……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣啊。",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}的情況確實是如此。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真辛苦啊～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有固定的居住地很沒有安全感吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔。",
        "unit_id": 104911,
        "voice": "vo_adv_1049005_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你是想找一間便宜的物件，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在那邊生活看看……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n，所以才到",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這間房屋仲介來的吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
