[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}，",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你聽得見嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n回答我呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喂……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "傳不過去……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我好想盡可能",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "告訴他小可可蘿的事情……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像這種時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無法直接干涉世界",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真讓人不甘心……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他竟然還不能運用公主騎士的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "力量……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是因為失去了",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿的記憶嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……對你而言，",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和小可可蘿之間的羈絆",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是一切的開端。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為喪失了「初始羈絆」的關係，",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才沒有辦法跟我溝通，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以及施展公主騎士的力量……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……名為",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "羈絆的連結……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一旦失去",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟會造成如此巨大的影響……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿……",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我相信",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們和小可可蘿。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們在這世界連接起來的羈絆，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要比任何事物都強韌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我只能祈禱……",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我會懷抱信心",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "持續祈禱下去的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "求求你，",
        "unit_id": 190011,
        "voice": "vo_adv_5059003_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託了──",
        "unit_id": 190011
    }
]