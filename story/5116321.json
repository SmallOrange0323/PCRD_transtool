[
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這股壓迫感……",
        "unit_id": 125411,
        "voice": "vo_adv_5116321_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家要小心。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這和以往的氛圍完全不一樣。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠之前應該是下意識地壓抑住自己的力量吧。",
        "unit_id": 125411,
        "voice": "vo_adv_5116321_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如今似乎因為失去理智，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "進而解放出潛能。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是直接中招，勢必會受到極大的傷害。",
        "unit_id": 125311,
        "voice": "vo_adv_5116321_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以牠那股蠻力再加上靈活度，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們必須想個辦法……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果能降低牠的速度，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "削弱牠的力量就好了。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 125311,
        "voice": "vo_adv_5116321_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠似乎是因為吃了果實才使力量提升，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣一來蛀牙就變得更嚴重了。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是啊。",
        "unit_id": 125411,
        "voice": "vo_adv_5116321_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們趕緊阻止大猿吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這也是為了避免引起",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不必要的衝突。",
        "unit_id": 125411
    }
]