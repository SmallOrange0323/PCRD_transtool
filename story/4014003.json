        "name": "普蕾西亞",
        "words": "吃",
        "unit_id": 126111,
        "voice": "vo_adv_4014003_067"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n燒烤。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n很多。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好──！",
        "unit_id": 180411,
        "voice": "vo_adv_4014003_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那就",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趕快切一切處理好，",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家一起吃燒烤吧♪",
        "unit_id": 180411
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "咦，",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_069"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "也就是說，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n比起我是喪屍這件事，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n品牌魔物牛那邊才是更重要的消息？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "……………………",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_070"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "……啊、",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_071"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "啊哈哈♪",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "明明在佐賀也要小心不要被人發現是喪屍，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n在王都竟然有接受喪屍的人，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n我真的沒想到。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "而且，",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_072"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "在蘭德索爾的話",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "喪屍也不特別對吧？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "明明我幹勁十足來到蘭德索爾，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "這會不會",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "太厲害了？",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n啊哈哈！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "總覺得，",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_073"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "有像大家這樣的人在的話，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n我就能努力進行",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "在王都的個人活動了！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n啊，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "當然之後也要",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "小心不要被發現我是喪屍就是了。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "謝謝你！",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_074"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "既然在蘭德索爾失去了我的特色，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n那就再一次作為「一無所有的我」挑戰吧，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "說不定這是個好機會。",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "在蘭德索爾的偶像活動，",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_075"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "會努力的！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "我是櫻。",
        "unit_id": 136111,
        "voice": "vo_adv_4014003_076"
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "總算是打倒了魔物，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "太好了太好了♪",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n雖然被人發現了我是喪屍，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "但因為都是些不拘小節的人，",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "結果沒問題！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "\n偶像的個人活動也要努力囉──",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "喔──！",
        "unit_id": 136111
    },
    {
        "type": "dialogue",
        "name": "櫻",
        "words": "待續！",
        "unit_id": 136111
    }
]