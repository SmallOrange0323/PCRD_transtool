[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了找尋有關自己記憶的線索，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與初音一同來到了露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n此刻，兩人仰望著這座高聳入雲的塔。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這裡有關於{player}記憶的線索對吧！",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n好高喔～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "都看不見塔頂耶。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對了！",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也許能試著用我的超能力",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "瞬間移動上去？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要是能瞬間移動，",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也比較好幫你找到",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n記憶的線索吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "既然這麼決定，",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就趕快來試試看吧～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抓著我。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "準備好囉～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦～！",
        "unit_id": 1,
        "voice": "vo_adv_7022000_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "居然能在這種地方遇見你們，也太巧了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咦？",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好怪啊～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我剛剛明明看到{player}跟初音美眉",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n在這裡的呀……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等一等。",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "讓在下數數質數，鎮定下來。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這座露娜之塔有不少傳聞。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才那狀況有沒有可能是看見幻影魔法之類的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那可真…………",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "噢",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "──────！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真叫人熱血沸騰呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不枉我大費周章",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來找新魔法的點子！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等著瞧吧，",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難攻不落的露娜之塔，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看最可愛最強的\n七七香今天怎麼攻略你……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我原本打算移動到塔上的，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "結果卻回到了原來的地方。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什、",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼～～！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n師傅！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然有美少女和{player}從塔上掉下來啦～～！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這難道也是幻影魔法！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸！？",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來剛才聽到的是小七七香的聲音呀。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "講話了！？",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n難、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難不成",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳是初音美眉本尊！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼剛才的",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法是初音美眉施展的囉！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "厲害啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我從沒看過這種魔法耶！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若不介意，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能否也將此招傳授給在下！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這個嘛……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯唔，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n一用力量就變得好想睡。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對不起唷，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我要睡一下了～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕～",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "睡著了！？",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是怎麼回事啊？{player}！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "使用時需要付出代價……",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來這魔法相當強大呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕～",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但這睡臉",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也太安詳、太可愛了吧～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "光看著就好療癒～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉呀，",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在不是看到入迷的時候。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你們",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼會在這裡……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來是這樣！",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡有和你記憶相關的線索呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我原本",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是來找創造新魔法的靈感，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但聽你這麼說後，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n七七香我怎麼能不拔刀相助呢……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖是這麼說啦……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕～",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還是先等初音美眉睡醒，",
        "unit_id": 101311,
        "voice": "vo_adv_7022000_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再來想要怎麼辦吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是七七香與{player}兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便在高聳入雲的露娜之塔入口前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n默默聽著初音安詳的打呼聲。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕～",
        "unit_id": 101211,
        "voice": "vo_adv_7022000_026"
    }
]