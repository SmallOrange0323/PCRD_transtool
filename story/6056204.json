    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的漁夫們",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那精湛的廚藝，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是太精采了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來在下",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今後也得精益求精，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n做出能夠滿足大家的料理。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 111911,
        "voice": "vo_adv_6056204_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是只有在大間",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才吃得到的道地美味。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n大間的漁村",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以及這風味沒有消失，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是太好了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等明年這個時候，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也用大間的魚",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來慶祝新年吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵……",
        "unit_id": 111911,
        "voice": "vo_adv_6056204_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晚點在下",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會向漁夫們請教料理方法，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請主人拭目以待。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜、",
        "unit_id": 111911,
        "voice": "vo_adv_6056204_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜師嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是這樣能為主人們帶來喜悅……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是開個玩笑而已？",
        "unit_id": 111911
    }
]