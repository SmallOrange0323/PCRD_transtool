    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音與{player}\n一起前往森林，然而……"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿──噫！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "輕易地打倒了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你真的可以提高",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n身旁的人的力量呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好厲害呀～",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "簡直就像我的超能力一樣呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "魔物的集團",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物的集團",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇！ 感覺魔物的數量非常多呢！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這不使用超能力的話，可能沒辦法……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "逃跑吧！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抓住我！ 用超能力一飛就到了喔！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……瞬間移動！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，順利地逃跑了呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "耶～，勝利勝利！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼～……",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但是，我為了逃跑而使用了超能力，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不休息一下的話……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喂，這個地方很舒服，要在這裡午睡嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好啦好啦，機會難得，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你也一起睡吧～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～♪",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n喂，很舒服吧？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，我們午睡吧――！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n休息吧～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你說什麼？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你睡不著？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說回來，你臉很紅喔？ 怎麼了？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "該不會是發燒吧？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我幫你量體溫！ 把額頭露出來！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？ 你說如果我靠近，你的臉會變得更紅？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那個……怎麼回事？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然不太清楚，但你睡不著對吧！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那麼就交給我！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "與睡覺有關的事，我可是專家喔～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，該怎麼做你才睡得著呢……？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n想要我為你做點什麼嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來如此！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼我要數了喔。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n一隻羊，兩隻羊，三隻羊……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "四隻羊，五隻羊……",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，好喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那麼，我就唱首小初音特製搖籃曲……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n睡吧～睡吧～嗯呀嗯呀呀～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼嚕！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，不行！ 我自己睡著了！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是……我已經到極限了……",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n呼嚕呼嚕……呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n要一直在我身邊喔……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "超恢復！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n因為睡得很飽，精神百分百喔☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你也有睡嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！ 我說了夢話！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也、也就是說我舒服地睡到說夢話的地步？？？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了～",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你也有睡的話，我也很開心喔♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮☆",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我狀態非常好，感覺好像充飽電了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "搞不好超能力也變強了！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇！ 又是魔物！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵～♪ 但是，我已不是剛才的我了喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "現在的話，可以用充電後的超能力輕而易舉地打倒魔物唷！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿──噫！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "魔物飛得好遠！",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好厲害，好厲──害！ 是超出我想像的力量呢～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿，是多虧了睡在你旁邊嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦、咦？",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n人跑去哪裡了？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ 莫、莫非……",
        "unit_id": 101211,
        "voice": "vo_adv_1012005_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我把他和魔物一起打飛了──！？",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500022"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "嗚、嗚哇！ 魔物進到城鎮裡了喔！？",
        "unit_id": 311,
        "voice": "vo_adv_1012005_032"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "有人跟著一起喔！",
        "unit_id": 711,
        "voice": "vo_adv_1012005_033"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n可能是魔物召喚師！？ 把魔物引進來的就是你吧！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n我要帶你回去，認命吧！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受到不白之冤，\n而四處躲避騎士團……"
    }
