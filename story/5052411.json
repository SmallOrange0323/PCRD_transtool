    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "與魔法提督Lovely★莫妮卡",
        "unit_id": 114211,
        "voice": "vo_adv_5052411_000"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n共度的時光即將結束了……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "現在想想，時間還過真快呢。",
        "unit_id": 114311,
        "voice": "vo_adv_5052411_001"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "雖然在接連不斷的激烈戰鬥當中，",
        "unit_id": 114311,
        "voice": "vo_adv_5052411_002"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "也曾差點灰心喪志。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "但",
        "unit_id": 112311,
        "voice": "vo_adv_5052411_003"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "能一路努力到現在，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n都是多虧了有魔法少女夥伴，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "以及……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "眾人的溫暖聲援……！",
        "unit_id": 112311,
        "voice": "vo_adv_5052411_004"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "如果你也",
        "unit_id": 112211,
        "voice": "vo_adv_5052411_005"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "因為挫折想放棄，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n或是遇到討厭的事時，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "希望你能回想起來。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "回想起我們魔法少女，",
        "unit_id": 112211,
        "voice": "vo_adv_5052411_006"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "充滿愛與希望的活躍表現……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "怎麼了？",
        "unit_id": 114211,
        "voice": "vo_adv_5052411_007"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "你說你不想道別？",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "呵，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "我們",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "永遠都在你們的心中。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "而且",
        "unit_id": 114211,
        "voice": "vo_adv_5052411_008"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "戰鬥也還沒結束。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n在這個世界上，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "還充滿著需要我們幫忙的人！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "倘若這個城鎮、",
        "unit_id": 114211,
        "voice": "vo_adv_5052411_009"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "這個國家",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "面臨危機，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n我們無論多少次都會前來相助的！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "在那之前，",
        "unit_id": 114211,
        "voice": "vo_adv_5052411_010"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "要暫時道別了！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我很期待",
        "unit_id": 114311,
        "voice": "vo_adv_5052411_011"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "下次見面喔！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "請絕對",
        "unit_id": 112311,
        "voice": "vo_adv_5052411_012"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "不要忘了我們……！",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "掰掰，",
        "unit_id": 112211,
        "voice": "vo_adv_5052411_013"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "要保重喔！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "……欸，",
        "unit_id": 4211,
        "voice": "vo_adv_5052411_014"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "大家",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "在做什麼啊？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n我們的戰鬥",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "不是還要持續下去嗎……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
