[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很好……",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n準備完全♪　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "牙也刷了，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n頭髮也特別梳過了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不管從哪個角度看，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都是個可愛的少女偵探……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不對，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是位威風凜凜的名偵探♪　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然最近生活的步調亂掉了，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以肌膚看起來有一點糟糕。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但自從試擦了真步借我的乳液以後，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n現在可也是光滑透亮了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "結果昨天",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才向{player}……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才向助手先生說明完了工作的內容後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就解散了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從今日開始，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n得重新開始「闇影」的調查了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔～",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "昨天在助手先生回去了之後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n才發現到了自己睡到頭髮亂糟糟",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的這件事……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太丟臉了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "人際關係最重要的就是第一印象，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這件事",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明前陣子才在書上看到的啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n現在應該也還不算太遲，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓他見識見識自己帥氣的一面吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才不想被助手先生",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "認為是個不中用的偵探呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "得加點油才行。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……但是。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太慢了吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才剛開始就遲到？",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是不是沒幹勁呀？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是昨天稍微跟他聊聊時，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n感覺他是會盡全力工作的……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「雖然還不太懂偵探的工作，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但絕對會學起來。」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「會努力當助手的！」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "等等，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有模有樣地說了這種話呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然聽起來像是幹勁十足，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "難不成是我看走眼了嗎。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗚嗚。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n以前也曾為了調查而埋伏監視過，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以本來對耐心等待還有一點自信的呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼搞的，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這次為何覺得心裡有點不安呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若是和{player}的話，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也許就能像我最喜歡的推理小說一樣……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "出現讓人心跳不已的",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大顯身手這種事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我原本有點期待的說。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼呢，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這還真不可思議。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明和那個人",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也才剛認識而已。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……唔哇！？",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊、",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事到如今還真是瀟灑的登場呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓你老闆在這乾等，你膽子可真大！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼會遲到？",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n若有什麼話要說，最好趁現在喔！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n一大早就被捲入了場不可思議的事件，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以才遲到？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你是不是瞧不起我呀，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種藉口會有人相信嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我稍有點興趣……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "詳細說給我聽吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就在你平時住的那個",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【咲戀育幼院】裡，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n準備早飯時",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "發生了事件呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哦。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在準備早餐時，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "菜刀突然折斷了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而那折斷的刀刃，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "又不小心傷到了你的手，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n為了處理傷口而拖到一些時間……？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n給我看看你的手。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "確實，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這傷口看起來像是不久前才劃到的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n看來不是在說謊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是發生殺人事件",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就放心多了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要我推理一下這到底是怎麼回事",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你以為我是誰呀，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我可是【哞哞自衛隊】所自豪的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "名偵探喔？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼都先問偵探可是犯規呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "首先你得試著自己思考看看。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就讓我來聽聽你的推理吧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "放棄的也太快了……",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就再試試，努力想想看啦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為我們有思考的能力。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若不能有效的去運用它，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你不會覺得太浪費了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那樣的判斷",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說不定是最聰明的回答呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟沒有出現壞人就可以結案了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是若就單純以事故來想，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n卻挺不自然的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若這就是全部的說明，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n會讓人覺得即使是正解",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也無所謂唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偵探這職業，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是一種需要分析出任誰都能接受的解釋的工作。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了希望能找出真相的委託人",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而編織出一個",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能讓人心滿接受的故事呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若你覺得這單純是件",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不幸的事故且可以接受，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那我也不會再",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多說些什麼囉。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你這表情看來是不太能夠接受呢，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真拿你沒辦法呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但這也是名偵探的工作，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就讓我來告訴你真相吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "首先在開始陳述推理前，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "得先和你確認一件事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你提到了準備早餐",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這部分，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n負責料理的人，是助手先生嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你看起來也不是會做料理的人……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n今早是與你住在一塊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n名為可可蘿的人負責做料理的對吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇哇……",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你說，可可蘿才不會是犯人",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你可還真是信任人家呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但從最親近的人開始懷疑，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是基本中的基本喔？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請放心。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "依我的推裡，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "犯人並不是可可蘿喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就直說了。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "犯人就是你喔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你能使用不可思議的力量，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_053"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來強化身邊人的戰鬥力吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_054"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因為我對你做了某個程度的調查，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以才知道的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_055"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n話已經說得這麼白了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是你也能猜到真相了吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_056"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n真相就是你那詭異的力量，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不小心強化了可可蘿喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大概是無意之間想著、",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_057"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「煮早餐要加油唷～♪」",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之類的吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你那力量因此產生作用，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_058"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n強化了可可蘿的手部力量。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可可蘿可能只是打算",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_059"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n用與平時一樣的力道做料理而已吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但因為她手部的力量被強化的緣故，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n菜刀便因為負荷不了而斷掉了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這就是真相了吧。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_061"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_062"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這也沒經過現場調查……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以究竟能不能稱為正解",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有待商榷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能確定的就是。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_063"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你擁有的那詭異的力量，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並非全然有益……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的這麼一回事唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然是有用，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_064"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "甚至像是奇蹟一般的力量，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但也必須確實掌握使用上的拿捏。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要不然下次，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_065"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說不定就不是受點小傷就結束了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這就是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在今次的事件中所給你的教訓。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_066"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是在替我鼓掌嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真是令人害臊呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不錯不錯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_067"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你那表情看來心滿意足了呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "身為偵探能做出讓委託人滿意的推理，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是再好也不過了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好吧。",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_068"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n推理遊戲就在這先告一段落吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n得要開始工作了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對我們來說，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_069"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有著其他更應該解決",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "的事件呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼我們也該出發去調查囉，",
        "unit_id": 101411,
        "voice": "vo_adv_1014002_070"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你接下來的活躍，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我很期待唷。",
        "unit_id": 101411
    }
]