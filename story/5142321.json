[
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔喔！？",
        "unit_id": 129811,
        "voice": "vo_adv_5142321_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼回事？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那傢伙的身體",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "發出了劈哩啪啦的聲音！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "牠似乎是在累積雷電的力量。",
        "unit_id": 129911,
        "voice": "vo_adv_5142321_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不趕快阻止的話，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "肯定會觸電……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要一擊就會讓我們全滅的。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "得想辦法",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "干擾那傢伙才行。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "干擾是吧……",
        "unit_id": 129811,
        "voice": "vo_adv_5142321_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n看起來，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙好像是在使用大招的同時累積力量呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是說，",
        "unit_id": 129811,
        "voice": "vo_adv_5142321_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "只要妨礙那傢伙，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不讓牠使用大招就好了吧？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我知道了。",
        "unit_id": 129911,
        "voice": "vo_adv_5142321_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n雖然耍小伎倆很麻煩，",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但這裡就按照妳說的方式做吧。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，",
        "unit_id": 129811,
        "voice": "vo_adv_5142321_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳同意是嗎？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "太好了！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "「大招妨礙作戰」──",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就此展開！",
        "unit_id": 129811
    }
]