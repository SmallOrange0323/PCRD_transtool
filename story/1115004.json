        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在在這裡回答我――",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "電話嗎？",
