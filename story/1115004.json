    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而且還是緊急電話……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不好意思等我一下。",
