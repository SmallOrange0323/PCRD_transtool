    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "躺在小子的腿上。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊……",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_095"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我還是第一次在男人的腿上醒來啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "深切體會到，",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_096"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是個有趣的男人啊……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來你剛剛，",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_097"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n問了我",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼選擇了你對吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是一時興起，",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_098"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我剛剛自己是這麼想的。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n再讓我說一次吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和{player}一起度過的無聊時光也不錯。",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_099"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是這麼想的喔♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜就這樣躺在腿上，\n悠閒地享受無聊的時光。"
    }
]