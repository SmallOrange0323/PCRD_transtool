        "voice": "vo_adv_1115004_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還要好的條件吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n問我為什麼，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要這樣嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
