    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真想看看我從旁邊出手，",
