[
    {
        "type": "background",
        "background": "500038"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "燈光點綴了街道，\n聖誕約會也快接近尾聲了。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經晚上了啊。",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在開始才是約會的重頭戲！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然很想這麼說。",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但今天已經讓我過得很開心了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我懂為什麼一般庶民們會為聖誕節如此狂熱了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感謝你啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幹嘛露出一副很意外的表情。",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我有禮地道謝有這麼讓你感到意外嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也可以如你所願的，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "華麗地用劍對你訴說喔？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵……",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "開玩笑的啦☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天選擇了你真是太好了。",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我真的這麼想唷。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到現在才問嗎。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想想。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若我回答是因一時興起的話，這樣對話就結束了吧，",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那樣就太無聊了啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 111511,
        "voice": "vo_adv_1115004_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好刺眼啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是燈飾的光嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這道光是……",
        "unit_id": 111511
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "新產品發表會",
        "unit_id": 1,
        "voice": "vo_adv_1115004_009"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "也要到了尾聲了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n在最後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "請這位人物來為我們致詞吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼，",
        "unit_id": 1,
        "voice": "vo_adv_1115004_010"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "請從這裡上台！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n在全世界表現活躍的――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――由我自己來做自我介紹吧。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然應該已經有很多人知道我，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過再一次報上我的名字吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是克莉絲提娜‧摩根。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n能在這個場合致詞",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我感到很榮幸。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在我們企業的新產品發表會露臉……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n果然周圍的人會覺得困惑啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說的也是。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "企業的代表，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼可能親自蒞臨這種普通小鎮的百貨公司。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n排行程的時候",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也被追問了很多次原因。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對我來說",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本只是想去見見晶，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過也撲了空。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "本來至少在聖誕節想和朋友盡情玩樂，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這空出來的時間要怎麼安排啊？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我空出了一天休假可不是小事耶？　",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "關於這次的新商品，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在那邊的男生，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好像在哪見過啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好像是",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在晶的店裡面的人……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀，視線對上了。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n注意到我的視線了嗎？　",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "直覺很準的小子啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就這樣要走了嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼啊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好難過啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明就有聊過一次天啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好像在趕時間的樣子……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是有什麼事嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那、",
        "unit_id": 1,
        "voice": "vo_adv_1115004_022"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那個……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "克莉絲提娜小姐？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不好意思。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再次――",
        "unit_id": 107131
    },
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨――！",
        "unit_id": 1,
        "voice": "vo_adv_1115004_024"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1115004_025"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "是常來的小哥，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "你想找的是那個吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n放在那邊的櫃子裡喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "唉呀，",
        "unit_id": 1,
        "voice": "vo_adv_1115004_026"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "小哥你也很懂嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n即便在這樣的日子裡啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "欸，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "咦……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是今天發售的新格鬥遊戲作品啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你要買嗎，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過在大家都在慶祝聖誕節的時候來看新遊戲，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還真是不解風情的傢伙啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼了？　",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼目不轉睛的？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我剛剛有好好宣傳唷♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然電視台攝影機的數量和採訪陣容都比平常少，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過這樣反而會變成話題吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過你剛剛還真是冷淡啊，小子。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你剛剛和我視線對上了吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明明對我揮個手之類的也好。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是說怎麼樣。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不記得我了嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像我這麼華麗的美女",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該不會忘記才對吧？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "之前在晶的可麗餅店攤前面見過吧？",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "忘記的話",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就再讓你記住我。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是克莉絲提娜‧摩根。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n目前在某個企業擔任代表。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶是我的舊識，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也是朋友唷。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然我都介紹完自己了，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就走吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n唉呀別在意我。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你快點去買你剛剛要買的東西就好♪",
        "unit_id": 107131
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打擾囉！",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個國家的文化，不能穿鞋進家裡啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個國家的住宅每個都小而別緻呢。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "與其說是有很奇妙的懷念感，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不如說感覺讓人安心。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂小子，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼愁眉苦臉？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n「這家人怎麼沒倒茶給客人喝呢」",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n厚臉皮的話我是不會說啦，安心吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的房間在哪？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不要拖拖拉拉的，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "快點帶路吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我的時間可是很寶貴的喔。",
        "unit_id": 107131
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是你的房間啊。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只有最低限度所需的東西，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "給人這種印象呢？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過有好好整理嘛，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "值得稱讚。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果是像小子你這樣年紀",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想應該有更多五花八門的東西啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "床借我隨意坐一下吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n――來做吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在裝什麼傻。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我都特別來到你的房間了喔，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "能做的事情",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是只有一件嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別對我說這種軟弱的話。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n小子你若是個男人，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就盡全力",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "試著讓我開心看看吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "準備吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n遊戲機和……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "手把要兩個喔。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼突然拍手？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是奇怪的傢伙。",
        "unit_id": 107131
    },
    {
        "type": "still",
        "still": "111500401"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――又是我贏了啊。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我已經連續贏17次了。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還真是沒出息，小子。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為是晶的熟人還讓我期待了一下，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不夠不夠，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣還不足以讓我感到開心。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過……",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不知道是不是為了觀察我的動作，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你途中就開始轉為守勢了吧？　",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個還不錯喔。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "防禦時的對應能力。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還有，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在最後關頭使出預料外的一擊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有潛力。",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也許好好鍛鍊就會變成人才。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107131
    },
    {
        "type": "still",
        "still": "111500402"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――想不想來【圓桌武士】？",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你如果喜歡遊戲應該知道吧？",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在各國的遊戲大賽中表現活躍的專業玩家隊伍。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個就是我成立的組織呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n聚集優秀的玩家，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來挑戰各式各樣的遊戲大賽。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結果意外地，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有不錯的成績呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然一半是因為自身興趣成立的，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過剛好興趣和利益有不錯的結合。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有時候，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己也會參加大賽之類的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是個相當不錯的隊伍喔。",
        "unit_id": 107131
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如何，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要不要接受我的提議啊？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀不好意思，",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該先提報酬才對。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想想，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "契約金是……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣的話如何？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哪個貨幣比較好？",
        "unit_id": 107131,
        "voice": "vo_adv_1115004_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n無論美元或歐元，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "選擇你喜歡的就好了喔？",
