        "voice": "vo_adv_1115004_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡單來說的話，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n{player}，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我對你有興趣。",
