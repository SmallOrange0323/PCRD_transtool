        "voice": "vo_adv_1354001_019"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是什麼──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n只是個",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "水桶，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "對吧。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n是要",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "用這個",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "來玩嗎……？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "裝進沙子，",
