        "voice": "vo_adv_1354001_022"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我知道了。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n如果這是你想做的事──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就來做吧。",
