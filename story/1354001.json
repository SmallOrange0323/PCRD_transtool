        "voice": "vo_adv_1354001_023"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "完成了。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "雖然這大小，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "只能讓狗或貓",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "居住。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不過──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_024"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "蓋在這種地方，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "馬上就會被海浪沖垮的。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………？",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_025"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "無法理解。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n既然",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "都會垮掉──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──打從一開始",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_026"
