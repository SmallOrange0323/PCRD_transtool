    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在海風吹過的沙灘上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}手拿海灘球，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與安涅默涅對視著。"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_000"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "請。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──呼！",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_001"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}托起的球，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被安涅默涅控制的藤蔓擊落，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n深深陷入沙灘中。"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不讓對方碰到球──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_002"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就獲勝。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n對吧。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_003"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "剛剛，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是我贏了吧。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_004"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "果然",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "很難呢。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n難以理解。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這真的──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_005"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是對他的",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "犒勞嗎？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "皇女的想法，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我搞不懂──",
        "unit_id": 135411
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天早晨，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和安涅默涅兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次造訪蘭德索爾附近的海岸。"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_006"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "在回到吉歐‧格黑納之前，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "還要在這",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "待這一陣子？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129711,
        "voice": "vo_adv_1354001_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此番乃難得「度假」之良機，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝便盡情享受",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這片刻悠閒之時吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "可是──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_008"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我沒有什麼",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "特別想做的事。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n休息的話，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "在吉歐‧格黑納",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不也一樣──？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……嗯。",
        "unit_id": 129711,
        "voice": "vo_adv_1354001_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吉歐‧格黑納",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因騎士閣下之付出，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "得到莫大幫助。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n為報此大恩，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝當好好慰勞",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "咦──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_010"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我不要。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──是說。",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_011"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n即使您跟我說──要慰勞他，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n我也不曉得──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "該做些什麼。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "毋須煩惱。",
        "unit_id": 129711,
        "voice": "vo_adv_1354001_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "即便詢問本人，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦不會被視為失禮之舉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n騎士閣下，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可是如此？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──唉。",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_013"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "真拿您沒辦法──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我，",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_014"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "姑且問問──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "你──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "有想要我",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "做的事嗎？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "玩──？",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_015"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n我，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "跟你嗎？",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_016"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "沒",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_017"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "有──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我會遵從的。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n因為",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是皇女的命令。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不過──",
        "unit_id": 135411,
        "voice": "vo_adv_1354001_018"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "詳細內容",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "就交給你了。",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "因為，",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我不曉得──",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "你",
        "unit_id": 135411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "喜歡玩什麼。",
        "unit_id": 135411
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這",
