    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一如往常的咲戀育幼院。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了送別即將出門的咲戀，鈴莓等人聚集在了一起。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼鈴莓。",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我暫時不在家的這段期間，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家就拜託妳囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「好，",
        "unit_id": 2111,
        "voice": "vo_adv_5088000_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "包在我身上！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼是噗吉回話啦～",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "被拜託的人是我耶～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他是想說能照顧大家的不是只有鈴莓而已對吧，",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "噗吉？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「沒錯。」",
        "unit_id": 2111,
        "voice": "vo_adv_5088000_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是說只有我的話會靠不住對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「…………」",
        "unit_id": 2111,
        "voice": "vo_adv_5088000_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "噗吉？",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "噗吉，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你有聽到嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我拜託鈴莓照顧大家，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過鈴莓就拜託大家囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311,
        "voice": "vo_adv_5088000_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我和胡桃還有噗吉會看好她的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "放心吧！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦！？",
        "unit_id": 102111,
        "voice": "vo_adv_5088000_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不用我看著，鈴莓姐她應該也",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒問題……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒問題……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「就算是名演員也演不下去嗎～」",
        "unit_id": 2111,
        "voice": "vo_adv_5088000_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼這樣～",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看來我能放心出門了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那我就……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "打擾了～！",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是誰呢？",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該沒有客人預訂要來啊……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來了～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我這就過去～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀？",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳是……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "叫做美咲！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是想拜咲戀小姐為師而來的！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜師……？",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我在看了那本完美的成熟淑女特輯後，",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就想拜咲戀小姐為師。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼說來之前是有接受過採訪呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我接受的好像是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "經濟雜誌的採訪，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒想到妳竟然會看那種艱深的雜誌呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我看的是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "時尚雜誌的特輯啊……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……那個編輯，",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "居然敢騙我。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個……",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這不是美咲的錯，妳不用在意喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過真傷腦筋呢。",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就算突然說要拜我為師，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我也不知道能教妳什麼，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n而且我現在又必須要長期出差。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這、",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣啊……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說得也是呢……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n畢竟我是突然找上門來的……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過妳都特地過來了，",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就這樣讓妳空手而回我也很過意不去。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳樂意的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就請參觀一下育幼院吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然我得出門去，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但或許有什麼能讓妳",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "參考的地方也說不定呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是，",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣不會造成妳們的困擾嗎……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有這回事喔。",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為小美咲妳是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來拜訪咲戀大小姐的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "重要客人嘛。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「非常歡迎有更多人來",
        "unit_id": 2111,
        "voice": "vo_adv_5088000_031"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "照顧鈴莓小姐喔！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "拜託請不要在客人的面前這麼說啦～",
        "unit_id": 102511,
        "voice": "vo_adv_5088000_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……？",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳應該很快就會明白了，不用在意喔。",
        "unit_id": 102311,
        "voice": "vo_adv_5088000_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n比起那個，美咲，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "既然妳都難得過來了，我們就一起玩吧♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_035"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我又不是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來玩的……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想想喔……",
        "unit_id": 102811,
        "voice": "vo_adv_5088000_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳就以候補徒弟的身分，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n從了解我的人那邊打聽我的事情，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳覺得這麼做",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼樣？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "自己這麼說還挺不好意思的！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果是關於咲戀媽媽的佳話，",
        "unit_id": 102111,
        "voice": "vo_adv_5088000_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那我有很多可以說喔。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來如此！",
        "unit_id": 105011,
        "voice": "vo_adv_5088000_038"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也就是在拜師前先打聽底細！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……啊，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不是。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我是說……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這就是拜師前的預習、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呢！",
        "unit_id": 105011
    },
