        "voice": "vo_adv_7006000_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像來了呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂～！\n{player}！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
