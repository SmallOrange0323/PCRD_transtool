        "type": "dialogue",
        "name": "咲戀",
        "words": "而且因為{player}",
        "unit_id": 102811,
        "voice": "vo_adv_7006000_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n他住在我經營的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【咲戀育幼院】裡面嘛，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那個、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "自然而然地",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就……",
