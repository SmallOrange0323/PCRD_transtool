    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別、",
        "unit_id": 102811,
        "voice": "vo_adv_7006000_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別說成這樣！！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可可蘿不在的時候，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幫忙照顧一下而已！",
        "unit_id": 102811
    },
