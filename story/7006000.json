    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個女孩。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對了，",
        "unit_id": 102811,
        "voice": "vo_adv_7006000_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你不知道呀。",
