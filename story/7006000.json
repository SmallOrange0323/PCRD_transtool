        "voice": "vo_adv_7006000_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "明明就不是僕人，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n卻還是跑到男性的寢室，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "早上溫柔地叫醒他……",
        "unit_id": 103211
