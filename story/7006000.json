    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哦、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n的確",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有一起去吃過炒麵麵包之類的。",
        "unit_id": 102811
    },
