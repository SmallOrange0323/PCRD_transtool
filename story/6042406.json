        "voice": "vo_adv_6042406_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她卻讓我覺得很有親切感呢。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是為什麼啊？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊！",
        "unit_id": 106612,
        "voice": "vo_adv_6042406_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽你這麼說好像有一點！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "日和",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "和祈梨……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這就表示，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的名字被抄襲了吧？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯～",
        "unit_id": 106612,
        "voice": "vo_adv_6042406_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是這樣嗎？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我認識的人裡面不太有那種類型的女生呢……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過如果是徒手戰鬥的無腦打架狂的話我倒是認識一個！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼？",
        "unit_id": 106612,
        "voice": "vo_adv_6042406_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "單純這個詞和我這種有深謀遠慮、",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "擁有軍師頭腦的人\n恰恰相反吧。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥真是沒有看人的眼光。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你問我擅長的戰略？",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當然是",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "先唰唰唰地進攻",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再咻咻咻地解決敵人啊！",
        "unit_id": 106612
    }
]