    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "原來如此──",
        "unit_id": 131111,
        "voice": "vo_adv_5148076_000"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小蘭法",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是在聽貝殼的聲音啊──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "感覺",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "很有她的風格呢。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "然後，",
        "unit_id": 131111,
        "voice": "vo_adv_5148076_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小美空在吹的……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n是所謂的瓶子笛子嗎？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是的♪",
        "unit_id": 131213,
        "voice": "vo_adv_5148076_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n因為蘭法姐不理我，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以我就在那邊吹笛子★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯呼，",
        "unit_id": 131111,
        "voice": "vo_adv_5148076_003"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也就是說妳是在找小蘭法麻煩嗎？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那也很有",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小美空的風格呢──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是",
        "unit_id": 131213,
        "voice": "vo_adv_5148076_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不知道為什麼，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "蘭法姐",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n稱讚我說「聲音很棒呢」了啊──",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "呵呵呵。",
        "unit_id": 131111,
        "voice": "vo_adv_5148076_005"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小蘭法",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "她更厲害呢──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "然後……",
        "unit_id": 131111,
        "voice": "vo_adv_5148076_006"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小騎士跟小莉莉是在……",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這是在做什麼啊？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……在看了蘭法小姐的行動之後，",
        "unit_id": 131611,
        "voice": "vo_adv_5148076_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也拿起手中的香蕉，貼在耳朵上聽起來了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因為我",
        "unit_id": 131611,
        "voice": "vo_adv_5148076_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也想聽兄長大人聽的東西，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n所以我拿起香蕉，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "正準備將它放到耳邊。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "原來如此原來如此──",
        "unit_id": 131213,
        "voice": "vo_adv_5148076_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……香蕉是會有聲音的嗎？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不成熟的我",
        "unit_id": 131611,
        "voice": "vo_adv_5148076_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "什麼都沒聽到……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n如果能成為像兄長大人一樣的一流的冒險者的話，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我覺得我應該也能聽到香蕉的音色了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我還不夠成熟。",
        "unit_id": 131611,
        "voice": "vo_adv_5148076_011"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我要繼續累積修行，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "總有一天……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空、涅婭",
        "words": "「很有莉莉的風格呢──★」\n「很有小莉莉的風格呢～」",
        "unit_id": 1,
        "voice": "vo_adv_5148076_012"
    },
    {
        "type": "still",
        "still": "end"
    }
]