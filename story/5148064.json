    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "戀愛……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那是種什麼樣的感情呢……",
