    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……真沒想到，",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_001"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "會是這種程度的苦戰呢。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "這是代表……",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "妳們在之前的戰鬥中",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "都手下留情了嗎。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了！",
        "unit_id": 106011,
        "voice": "vo_adv_9006605_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n重要的人被當成人質，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n當然會豁出去吧──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_003"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……重要的……",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_004"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "「嗯～",
        "unit_id": 106715,
        "voice": "vo_adv_9006605_005"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "可是～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "\n我感覺",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "反而是妳",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "手下留情了呢～？」",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "…………",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "帆稀小姐？",
        "unit_id": 105911,
        "voice": "vo_adv_9006605_007"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "「我是完全不認識",
        "unit_id": 106715,
        "voice": "vo_adv_9006605_008"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "這個叫芙蕾雅的人啦……",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "\n但總～有種",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "很可疑的感覺呢～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "\n剛剛偷襲的攻擊魔法",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "好像也是特意錯開了一點點～？」",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105811,
        "voice": "vo_adv_9006605_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣的話……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……遠野帆稀。",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_010"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "看來妳似乎是因為剛復活不久，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "所以眼睛看得相當不清楚呢。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "剛剛的攻擊，",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_011"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "只是因為我太專注在偷襲上了。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "下一擊",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "我就會把你們徹底解決掉。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "感覺",
        "unit_id": 126011,
        "voice": "vo_adv_9006605_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "敵人",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還很有幹勁……！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是",
        "unit_id": 106011,
        "voice": "vo_adv_9006605_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果不把這傢伙轟飛，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就進不了阿剌克涅的巢穴啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "轟飛、",
        "unit_id": 126111,
        "voice": "vo_adv_9006605_014"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n吧。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好！",
        "unit_id": 105811,
        "voice": "vo_adv_9006605_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了把重要的人",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給帶回來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "……也對呢。",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_016"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "既然你們要帶走一人的話，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "減去一人作為交換才合理吧。",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "那麼──",
        "unit_id": 193711,
        "voice": "vo_adv_9006605_017"
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "\n就請妳死在這裡吧，",
        "unit_id": 193711
    },
    {
        "type": "dialogue",
        "name": "芙蕾雅",
        "words": "尤絲蒂亞娜公主。",
        "unit_id": 193711
    }
]