[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喝呣呣呣呣……！",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔～。",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行呀，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然沒有",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『皇家裝備』就什麼力都使不上了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這牆不管是踢還踹，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "連一動也不動呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我呀，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來是這麼無力的呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖得消耗大量的卡路里，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但相對的能給予我無敵戰鬥力的『皇家裝備』……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個特性似乎被敵人給知道了的樣子，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n二話不說就被沒收了呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然因此不會消耗什麼卡路里，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以不會一下肚子就餓扁了就是。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這樣，貪吃的小貪吃佩可……",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個綽號",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就感覺沒有意義了呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變回了無能為力，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只靠自己什麼也做不到的公主殿下呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變回總是應付著無趣……",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只能從窗口眺望人們的生活而心生羨慕的，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那時候的尤絲蒂亞娜……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗯？",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　怎麼，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有蝴蝶在飛……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是、",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是從哪裡跑進來的呀？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明就連窗戶也沒有，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是完全密閉的",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王宮地下監獄唷……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請讓讓。",
        "unit_id": 1,
        "voice": "vo_adv_2009005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛那是",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "誰的聲音？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n難道是，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這隻蝴蝶在……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說話嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以我說，",
        "unit_id": 1,
        "voice": "vo_adv_2009005_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請讓開。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n一直傻傻杵那裡，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很礙事呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然不知道是怎麼回事，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我明白了！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n稍微",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "往牆邊閃唷～！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很好。",
        "unit_id": 1,
        "voice": "vo_adv_2009005_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這麼聽話真是幫了大忙……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n尤絲蒂亞娜‧F‧阿斯特賴亞。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不，",
        "unit_id": 1,
        "voice": "vo_adv_2009005_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如今是被叫做貪吃佩可來著？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n喪失了身分成了流浪之身，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n被命運給戲弄悲劇的公主……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我有事情要找妳。",
        "unit_id": 1,
        "voice": "vo_adv_2009005_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n監視牢內囚人的獄卒正好去交接，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "會有一段時間無人看管。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n儘管時間不長……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但能否和我說說話呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃～……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯。",
        "unit_id": 1,
        "voice": "vo_adv_2009005_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這個姿態",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "似乎讓妳太驚訝和疑惑了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n連對話都有點困難了呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那沒辦法……",
        "unit_id": 1,
        "voice": "vo_adv_2009005_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n基於禮儀，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也讓妳看看我的真面目吧。",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "200900501"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然不知道妳，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n已經知道多少有關於我等的知識……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但這個名字",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是否曾在哪有耳聞呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變貌大妃，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似似花？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有聽過唷！",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個穿著亮晶晶盔甲的，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫做真軌的傢伙曾經說過……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……您與那傻瓜，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "曾在哪兒有見過嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如此如此這般這般……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我們，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才會決定要去找人家說是『七冠』",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的妳。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而在路上，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們遇上了那連半條命都快沒了的真軌喔。",
        "unit_id": 105813
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……保住了小命呢，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那傢伙。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的。",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然應該是很嚴重的傷勢，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但說起話來很有精神唷。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且還非常的擔心，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳的事情呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哼、",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哼嗯……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過嘛，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他的事現在不管怎樣都好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也沒有什麼在擔心他呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為他打都打不死吧，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那種單細胞生物。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這話講得還真狠……",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是嘛，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來也沒有什麼能悠哉閒聊的時間呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這些事就丟一旁，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "先來談談更為重要的事情吧？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似似花。",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳也被囚禁在王宮之中，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然有聽說過這件事……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但看起來好像沒事呢，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這真是太好了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並非真的沒事唷。",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "此時此刻，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的本體仍被做為動力源連接在某個魔法裝置之上，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n依舊不停地持續嚐著如同被生吞活剝般的苦痛。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "本、",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "本體？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在在我面前的這個妳是……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是分身。",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是在即將被魔法裝置連接前的瞬間，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n悄悄地剝離出肉體的一部分，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "偷偷逃離成功的唷。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "順帶一提，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我擁有能變身的能力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是為這世上存在的、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無數的生物我都能變為其貌。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "僅管需要些許的修練，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算是無機物",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也能夠變身。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我才會以變貌大妃的別名被稱呼著呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個變身能力，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "分身也理當俱備。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "藉此躲避著監視的目光，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "時而為蟲或小動物……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n偶為觀賞植物的一片葉，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或變身為出入人員的裝飾品等等，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n如此這般在人們的眼皮之下得以移動。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "由於此王宮的地下監獄",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "設置著強力的結界，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要有些許動靜便會通知獄卒。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n各種監視、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "感知裝置也是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "時常都在啟動狀態。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "僅管某種程度下，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我還能夠用魔法進行干擾……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像這樣短時間內與妳交談還能辦到，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但如果是要讓妳逃獄之類的事就難辦了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在妳眼前的這個我，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說到底終究是分身……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要將『七冠』",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的權能，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n將那所有的力量發揮出來是不可能的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "曾有耳聞，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "過去，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "拉基尼卡東和克莉絲提娜……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n其他的『七冠』，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n似乎曾經從這個地下監獄成功逃脫了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "警備的層級也提升了許多。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要靠自身之力逃脫是不可能的吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也有稍微構思過了幾個對策，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但是至今仍未找到有效的方案。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的。",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n全都是其他",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "『七冠』的錯。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我算是例外……",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所謂的『七冠』就算只是普通地生活，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也會給人添上麻煩呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是無可救藥。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒有很仔細聽誰說明過，所以還不太瞭解，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個『七冠』",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟是什麼？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就是，",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要知道這件事才會開始調查的。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所謂『七冠』，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "即為創造了這世界的七柱之神……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如此這般的東西。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只需這樣子理解就行了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是、",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是神嗎？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常的有人性就是了……？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個嘛，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過就是有著如同神的權能的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "普通的人類而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如同神一般的立場，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能實現如同神一般的奇蹟的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n七位超越者……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請這麼想吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟關於我們的事情，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "目前也沒什麼意義呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在比起那些，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是先打破眼前的困境吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "儘管我為遭人囚禁之身，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但也在某種程度上",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "派遣分身收集情報。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是沒能完全把握現況。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能不能勞煩您，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "回答一些我存有的疑點呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想要將情報補足。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為儘管是中世紀幻想的世界觀，",
        "unit_id": 107011,
        "voice": "vo_adv_2009005_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n情報依舊是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "貨真價實的至寶。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦、",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是說，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也沒什麼關係就是了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是一個人抱著膝蓋躲在角落也沒用，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n至少多個說話的對象也很高興了。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105813,
        "voice": "vo_adv_2009005_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來也沒什麼時間了，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就大致概略的說明囉。",
        "unit_id": 105813
    }
]