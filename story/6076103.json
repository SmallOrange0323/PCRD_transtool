[
    {
        "type": "background",
        "background": "501420"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "博士說了不少艱澀難懂的事……",
        "unit_id": 117711,
        "voice": "vo_adv_6076103_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真的會有大災難發生嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "實在毫無頭緒……",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我說你啊，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你是",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "怎麼想的呢～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣啊～",
        "unit_id": 117711,
        "voice": "vo_adv_6076103_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "既然你這麼說，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "他肯定是個值得信賴的人～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很有識人的眼光呢～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然我聽不太懂博士所說的，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但我願意相信他，好好加油～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不愧是稱職的助手～！",
        "unit_id": 117711,
        "voice": "vo_adv_6076103_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "擁有如此強烈的責任感，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的很令人敬佩～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖說我",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對博士的研究",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也不是很了解，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但我對小棉花糖的責任感",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是不輸給任何人的！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們一起加油吧～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 117711,
        "voice": "vo_adv_6076103_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你也是嗎～？",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也搞不太懂呢～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我不認為他是壞人～",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這只是我的直覺啦～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然博士",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有些與眾不同，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "姑且就先做我們能夠做的事吧～！",
        "unit_id": 117711
    }
]