[
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "獄蜂那小丫頭，",
        "unit_id": 138212,
        "voice": "vo_adv_5213331_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "竟還不知悔改，操縱魔物為傀儡嗎？",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而如今奴家等人",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "已煥然一新，",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "英姿颯爽。",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "區區小蟲之輩，",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "連絆腳石都算不上。",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是，",
        "unit_id": 138012,
        "voice": "vo_adv_5213331_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也不能忘了心懷警惕。",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "敵人",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "似乎會使用毒與火。",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n而且在後方",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還有獄蜂待命……",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "因此我們也不能過度消耗力量。",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯，",
        "unit_id": 138111,
        "voice": "vo_adv_5213331_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過不必擔心。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n因為我們已經",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不再只是三個人了。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的，",
        "unit_id": 105811,
        "voice": "vo_adv_5213331_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "接下來我也要一起戰鬥！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嚼嚼嚼。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……這股全新的力量，",
        "unit_id": 138312,
        "voice": "vo_adv_5213331_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在就將其解放！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在的我，肚子和心靈都已經滿滿的了，",
        "unit_id": 138312,
        "voice": "vo_adv_5213331_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不管面對什麼對手都不會輸喔──！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喝啊啊──！",
        "unit_id": 138312
    }
]