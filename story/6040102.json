        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……雖然不知道她是從哪邊得知",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們要開始經營溫泉的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是啊。",
