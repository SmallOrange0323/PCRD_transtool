        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場被建造出溫泉的時候，",
        "unit_id": 103311,
        "voice": "vo_adv_6040102_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還想說該怎麼辦呢，",
