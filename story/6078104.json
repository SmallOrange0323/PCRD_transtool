    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "吶，",
        "unit_id": 101812,
        "voice": "vo_adv_6078104_000"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "我覺得這個據點的名稱，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "取叫「祕密的校舍」比較好，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "靜流說",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "想叫「姐姐與弟弟的愛之巢穴」，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n空花則說",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "「高深莫測被虐狂之館」比較好。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "你覺得呢？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "果然叫這個最好對吧！",
        "unit_id": 101812,
        "voice": "vo_adv_6078104_001"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n呵呵，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "我就知道你會這麼說♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "那麼，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "要馬上和老師",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "來上一堂",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "祕密課程嗎？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "……",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "首先從數學開始喔♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "真是的，",
        "unit_id": 101812,
        "voice": "vo_adv_6078104_002"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "{player}很喜歡姐姐是吧？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "但是，",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "這個名稱沒包含和我和空花，有點令人在意呢。",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "就叫「姐姐",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "與老師",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "與被虐狂",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "與可愛的你的愛之巢穴」",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "好了♪",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "你要選這個……？",
        "unit_id": 101812,
        "voice": "vo_adv_6078104_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "真的嗎……？",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "確實",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "這是能令人感受到強大威力的名稱……",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "\n但連我們也被拖下水當作是被虐狂……",
        "unit_id": 101812
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "我會有點困擾……",
        "unit_id": 101812
    }
]