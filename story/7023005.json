        "voice": "vo_adv_7023005_065"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我已經是英雄了嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以……",
        "unit_id": 100511,
        "voice": "vo_adv_7023005_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "日和，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不對……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "師父！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請妳收我為徒！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什、",
        "unit_id": 100111,
        "voice": "vo_adv_7023005_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼──！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "師、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "師父～！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "叫我師父……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣我會有點困擾耶～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我現在還不能獨當一面啊。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不、",
        "unit_id": 100511,
        "voice": "vo_adv_7023005_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不行嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～",
        "unit_id": 100111,
        "voice": "vo_adv_7023005_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "師父是沒辦法……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以先當朋友嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n然後，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "下次碰到需要幫助的人，我們可以一起去幫忙。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有困難的時候",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就要互相幫助幫助嘛。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "互相幫助幫助，",
        "unit_id": 100511,
        "voice": "vo_adv_7023005_070"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會當成來幫大家忙，",
        "unit_id": 100111,
        "voice": "vo_adv_7023005_071"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而妳可以當成是英雄的修行。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "休假的時候我們就一起出去",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "努力幫助別人，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳覺得怎樣？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我知道了！",
        "unit_id": 100511,
        "voice": "vo_adv_7023005_072"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n那就",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "麻煩妳了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "到時候，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}也要一起喔！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_7023005_073"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那下次",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "放假的時候，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n大家一起到城裡去吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "耶～！",
