    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像會有東西跑出來的氛圍！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大家，",
        "unit_id": 104711,
        "voice": "vo_adv_5006204_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可別鬆懈警戒。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為不知道會有什麼東西跑出來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗚嗯，",
        "unit_id": 107111,
        "voice": "vo_adv_5006204_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但不出來也很令人困擾呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都走了這麼遠了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可不行什麼都沒有啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像",
        "unit_id": 103711,
        "voice": "vo_adv_5006204_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還可以繼續往前走的樣子。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n小心地前進吧。",
        "unit_id": 103711
    }
