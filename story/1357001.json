[
    {
        "type": "background",
        "background": "502520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於複製品世界中的薩拉莎莉亞，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在返回基礎世界之前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n日和與{player}決定先在這裡待幾天，然而──"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是啊！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n其實，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我對",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不對……！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我、",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我有個朋友正在單戀……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n然後啊，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個女生、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才才才、",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才不是朋友！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明說的就是我！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一不小心就含糊過去了！？　",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊！",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明只要",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "直接傳達給他就好了！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我這個笨蛋──！　",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚喵啊啊啊啊，",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦──！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "下定決心要出擊了，才跟他攀談的……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "卻開始奇怪的諮詢，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n根本不知道該怎麼說……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉～！？　",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時間回溯到不久之前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n廣場上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和獨自反覆地自問自答著。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……騎士先生",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "常常在幫助大家，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n對我就不必說了，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還為了拯救埃拉她們的世界，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這麼拚命努力。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對誰",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都一視同仁、溫柔的",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一直",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼認真的騎士先生──",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "…………喜歡他。",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我……",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我已經",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "無法裝作不知道自己的感情了！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "決定要抬頭挺胸地活在未來……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "接下來",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該怎麼辦才好呢……？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喜、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喜歡上他，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之後的事……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我根本沒想過啊……！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "告白、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "應該……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要告白吧。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n要、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要嗎……？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要試著告訴他嗎……？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要說、",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「我",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喜歡你！」",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗎……！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚喵啊啊啊啊啊，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不可能不可能！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在不可能！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這比從索爾之塔上掉下來還更需要勇氣啊～～～！？",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "過……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼時候告白比較好……？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不用這麼緊繃也能傳達心意的日子，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的會來臨嗎？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想向騎士先生傳達心意，但我完全不知道，",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼時候才是正確的時機啊……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……嗯？",
        "unit_id": 135511,
        "voice": "vo_adv_1357001_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有人在煩惱的聲音……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦哦。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n是日和啊。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳在這裡幹嘛？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！！",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來得正好！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉，拜託妳幫幫我！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我不知道該怎麼做！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……因為這樣，",
        "unit_id": 135511,
        "voice": "vo_adv_1357001_017"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以妳就想跟我諮詢一下，對吧。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "即使知道自己喜歡騎士先生，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我卻不曉得該怎麼做、",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想怎麼做……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸，埃拉……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳覺得呢？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這樣啊……",
        "unit_id": 135511,
        "voice": "vo_adv_1357001_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原來如此♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n能夠清楚對我說出「喜歡騎士先生」的日和……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n非常坦率，很棒喔♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唉唷，",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別調侃我啦～！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "別看這樣，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我可是認真的……！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我完～全沒有調侃妳的意思！",
        "unit_id": 135511,
        "voice": "vo_adv_1357001_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n能看到妳的成長，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大姐姐很開心！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我是認真的喔？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "況且妳看起來也不是只憑氣勢在行動呢。",
        "unit_id": 135511,
        "voice": "vo_adv_1357001_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳的迷惘就是成長的證據，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "知道嗎。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然氣勢很重要，",
        "unit_id": 135511,
        "voice": "vo_adv_1357001_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但光憑氣勢上場很危險喔！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要好～好判斷時機才行呦♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是，",
        "unit_id": 135712,
        "voice": "vo_adv_1357001_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果不憑氣勢，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
