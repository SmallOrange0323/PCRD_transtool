    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這附近的話，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "來往的人也比較稀疏呢。",
