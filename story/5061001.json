        "voice": "vo_adv_5061001_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先不說這些，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次輪到妳實現諾言囉。",
