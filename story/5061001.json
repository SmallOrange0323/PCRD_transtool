        "voice": "vo_adv_5061001_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也有可能出現預料之外的效果。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這點還請妳做好心理準備。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我還是第一次穿玻璃鞋！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然感覺會破掉所以有點恐怖，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但跟書上一模一樣！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n竟然連這都能重現，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似似花妳果然是天才！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……看來高興到完全聽不進去了呢。",
