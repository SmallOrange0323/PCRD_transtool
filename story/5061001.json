    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她們應該也認不出妳吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝妳幫我這麼多忙！",
