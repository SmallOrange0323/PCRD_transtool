    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莉瑪在鎮上突然受邀參加舞會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由於這邀約實在太出乎預料，她不禁感到驚慌失措。"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "您真的要邀請我這種人去參加",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "舞、",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "舞會嗎……？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真、",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的可以嗎？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我可會當真的哦？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "那當然，",
        "unit_id": 2512,
        "voice": "vo_adv_5061001_001"
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "主人就是在尋找像您這樣的女性。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "\n請您務必要來參加。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "騙人騙人！",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種事真的有可能會發生嗎！？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n簡直就像是故事中的女主角一樣！　",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "實在太過湊巧了，簡直讓我懷疑這是不是一場夢，但是……",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算是夢又怎樣！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種機會",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "絕不會再有第二次了！　",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果不嫌棄我的話，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請務必讓我參加舞會！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "哦哦，",
        "unit_id": 2512,
        "voice": "vo_adv_5061001_005"
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "能聽到您這麼說，我真是太感激了。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "我的主人肯定也會很高興的。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "那麼這張邀請函，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "還請您收下了。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "非、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "非常感謝！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "對了，",
        "unit_id": 2512,
        "voice": "vo_adv_5061001_007"
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "有一件事必須先告訴您。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "舞會是社交場合，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "\n請您前來參加時，務必穿著與其相襯的服裝。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "您指的是……",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "像這種禮服，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是嗎？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "正是如此。",
        "unit_id": 2512,
        "voice": "vo_adv_5061001_009"
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "那麼",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "僕人",
        "words": "就恭候您的大駕光臨了。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該怎麼辦啊──！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "明明是個難得的機會，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "卻碰上這種問題！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "神明實在是太壞心眼了……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果是故事裡的話，這時候就會出現魔法師婆婆，",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為我準備好禮服與玻璃鞋了……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不可能會那麼順利的吧。",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n果然",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只能放棄了嗎……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──我找妳很久囉，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "莉瑪。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳似乎很喜歡",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "用人類的樣貌逛街呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "魔、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "魔法師婆婆！？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳真的來幫我了嗎？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……妳說誰是婆婆了？",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對不起！",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是妳聽我說，似似花！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其實──",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是這麼一回事呀。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然是在那種狀況下，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會將我看成來幫忙的魔法師，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也是理所當然的呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以說呢，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呃……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳不用說我也能明白，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「希望妳能幫我準備禮服」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳想這麼說對吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真不愧是似似花，",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "完全看穿了我的想法。",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我想跟妳商量一下……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "辦得到哦。",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "變出禮服這種小事，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "簡直是輕而易舉。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的嗎！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算辦得到，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也還沒答應要幫妳。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n既然要我幫忙的話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就必須給我與其同等的報酬。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說得也是呢，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我真是的，竟然完全只想到自己……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這也是為了禮服，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還有為了舞會，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不管什麼事我都做！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳的這種個性，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我非常中意哦。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然說是報酬，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但也沒什麼大不了的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只是要請妳用身體來回報而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "用、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "用身體……？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳要對我做什麼嗎？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個……",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可、",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可以請妳",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不要弄痛我嗎？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳到底把我當成什麼人了？",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這並不是件難事，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只是要請妳試用看看這個而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這是……",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "變身蘋果？",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過這是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "改良型的試製品。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n與之前的相較起來，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "減輕了變身時的痛苦，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在運動能力的強化、",
