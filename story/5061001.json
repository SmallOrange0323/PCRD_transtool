        "voice": "vo_adv_5061001_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼這些是改良型變身蘋果。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n以防萬一，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我先多給妳一些。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請妳一天吃一顆。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有，",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會先通知牧場的人，說妳會暫時外出一段時間。",
