        "voice": "vo_adv_5061001_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算沒演變成這種情況，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我還是打算請妳使用看看就是了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似、",
        "unit_id": 105214,
        "voice": "vo_adv_5061001_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似似花！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝妳，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我願意使用！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n只要能去舞會，",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算是一百個我也吃給妳看！",
        "unit_id": 105214
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來談妥了呢。",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就換個地方說話吧。",
