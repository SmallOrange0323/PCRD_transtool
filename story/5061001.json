        "voice": "vo_adv_5061001_042"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一定會去實現夢想的！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我要出發──",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔哇！？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "扭、",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_043"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "扭到腳了！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真的沒問題嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_5061001_044"
    },
    {
        "type": "background",
        "background": "500660"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "終於，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我終於到了……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "到我所嚮往的地方！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊～",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_046"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "多麼壯觀的宅邸……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這種美跟王宮有些不同呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一想到我馬上就要進到這裡面，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就不禁感到心跳加速♪",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼就",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_047"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "馬上──",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請等一下。",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_048"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "噫！",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_049"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是羅伊德大人的宅邸，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不歡迎無關人士進入。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那、",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_051"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我是來參加舞會的",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……妳、",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳看……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那是邀請函……",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_052"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣啊，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您也是……",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那、",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_053"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "非常抱歉，我竟然對正式來訪的客人如此失禮。",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_054"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我是羅伊德大人的侍者，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "名為瑪莎。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n能請您告訴我您的名字嗎？",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好的，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我叫作莉瑪！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這次能夠受到邀請，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我感到非常榮幸！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "那麼莉瑪小姐，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_056"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我來帶您去宅邸吧。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n請跟我來。",
        "unit_id": 1514
    },
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇啊！",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_057"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不只從外面看很壯觀，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n裡面也非常豪華呢！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就像是在做夢一樣。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "光是能夠來到這裡，我就已經滿足了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "莉瑪小姐是第一次來到貴族的宅邸呀。",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_058"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是的。",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_059"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，果然",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "像我這樣的人，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "並不適合",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "參加舞會嗎？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "不，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_060"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "請不用在意您的出身。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "羅伊德大人",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "對於身世方面也並沒有特別要求。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "太好了。",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我還想說要是參加舞會前，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就直接",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "被判喪失資格的話，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那該怎麼辦才好呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "哎呀，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_062"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "您來得正好呢。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n羅伊德大人，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "有參加者來訪了。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "嗯，",
        "unit_id": 2511,
        "voice": "vo_adv_5061001_063"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "啊啊，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "這樣啊……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "初次見面，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我是這間宅邸的主人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "羅伊德。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n謝謝妳",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "特地來參加這次舞會。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不、",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_064"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不會，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我才是呢，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "竟然能受邀來到如此壯觀的宅邸，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n真的非常感謝您。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "該怎麼說呢，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_065"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然很有氣質，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也完全沒有居高臨下的討厭感覺，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "總覺得他看起來並不開心……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "明明他是這次舞會的主辦人，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_066"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼會這樣呢？　",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "那麼",
        "unit_id": 2511,
        "voice": "vo_adv_5061001_067"
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "我就先告辭了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "\n瑪莎，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "羅伊德",
        "words": "之後的事就麻煩妳了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "一切都交給我吧。",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_068"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "那麼莉瑪小姐，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "雖然我們邀請您",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "來到了這裡，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n但是很遺憾，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我們無法馬上讓您參加舞會。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_069"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那、",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那是什麼意思？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "想要參加舞會的話，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_070"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n必須具有與之相符的禮節與教養。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "從現在開始的幾天內，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_071"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我們要請您接受各式各樣的課程，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n並將所學的事情牢記在心。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "或許您會認為我們太自作主張，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_072"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "但是",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "這可是必要的過程。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n當然您也可以拒絕接受課程。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "即使無法參加舞會，",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_073"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我們仍會竭盡全力招待您的。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n請問您意下如何呢？",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "莉瑪小姐。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "原來如此，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_074"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "原本還覺得一切太過順利了，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "原來是這麼一回事啊。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我的答案早就決定好了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_075"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "決定要接受課程！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "我了解了。",
        "unit_id": 1514,
        "voice": "vo_adv_5061001_076"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "那麼請容我重新招呼您──",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "歡迎您",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "來到社交界的入口。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我一直以來嚮往的",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_077"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "輝煌世界，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我完全沒想過在未來的某一天，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "竟然有機會能來到其中。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為了回報連禮服都幫我準備好的似似花，",
        "unit_id": 115812,
        "voice": "vo_adv_5061001_078"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我絕對要",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好好把握這個機會！　",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對著憧憬的世界，莉瑪立下了堅定的決心。"
    }
]