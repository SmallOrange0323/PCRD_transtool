[
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲她",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有好好記得我們的事呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好高興喔♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還有呀，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "她說自己的成績比平均分數還高呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲好厲害喔！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是呀。",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "看來她也有在好好努力，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那我就放心了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我和姊姊還靈魂互換過呢。",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "現在回想起來，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還真是不可思議。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且，",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不光是我們，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還把鎮上的人們都捲進來了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是幸虧",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這件事能順利解決呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也多虧了拉菲，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們才能變得這麼幸福。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是呀。",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "拉菲",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是名副其實的幸福天使。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說回來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她居然問「妳們有沒有認真在當天使呀？」……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們又沒有跟她約定過一定會做。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "拉菲她心裡很明白的啦。",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊肯定會願意當天使的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "而且，",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實我也滿喜歡天使的活動的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就算我們沒有拉菲那樣的力量，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們一樣擁有一顆身為天使的心呀！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……妳說得對。",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也得好好努力，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n免得和她重逢的時候，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓她見笑。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯嗯！",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那我們",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一起來吃",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n拉菲寄來的糖果吧？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……慢著，茜里！",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我想起來了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是「大天使的眼淚」！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "「大天使的眼淚」……？",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "之前",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "在找有什麼道具能恢復伊莉亞的魔力時，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我在書上看過這個東西。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這是一種會被高價收購的",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "夢幻道具……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "居然輕易地把這麼珍貴的東西送給我們……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n看來她果然是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真正的天使啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔……",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果是那麼珍貴的東西，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們也不好意思吃掉呀。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎麼辦，姊姊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要是賣掉了，我們就可以一夜致富呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不了，",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們還是留著吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這畢竟是拉菲成長的證明，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "會想讓人好好珍惜嘛。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我就知道姊姊妳會這麼說。",
        "unit_id": 100611,
        "voice": "vo_adv_5048601_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那我們",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "去吃點甜食吧，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就當作是代替糖果♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n也算是",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為了拉菲慶祝一下吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的，",
        "unit_id": 102211,
        "voice": "vo_adv_5048601_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里就妳這張嘴特別會說。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天就破例一次吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "希望我們的幸福",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也能傳達給拉菲就好了。",
        "unit_id": 102211
    }
]