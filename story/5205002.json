[
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "華音與紡希──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}成了這兩名奴隸的主人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而這兩人卻是最合不來的。"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "真是個嘴巴沒個停的傲嬌粉紅！",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_000"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "還在胸口開個愛心洞什麼的，真是莫名其妙～！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啥～！？",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我才不想被毫無品味還只會",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "耍嘴皮子的豎捲髮說──！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "可惡──！",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一下啦，騎士先生！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要把魔卡拿出來？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們可",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒有在吵架喔！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "正是如此，",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_004"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "喔呵呵呵呵！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "所以趕快收起那片可恨至極的板子，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n不，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "當場把它敲碎如何！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "「",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_005"
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "當然會啊～♪」\n「那是當然的～♪」",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希與華音",
        "words": "哼！",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_006"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_007"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "儘管如此，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這實在不合理至極……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n為何本小姐",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "必須要跟這種粉紅又狂妄的丫頭，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n去找三流的雜碎們不可？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "別再嘮叨了，快點找啦。",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這地方我們不熟，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以這是只會耍嘴皮子的華音派上用場的機會喔？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "還真敢說啊，妳這──",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──你們",
        "unit_id": 18711,
        "voice": "vo_adv_5205002_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是奴隸與主人吧？",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼？",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n有什麼事？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才剛見面就突然──",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "──很抱歉，但請你們就此消失吧！",
        "unit_id": 50811,
        "voice": "vo_adv_5205002_012"
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "──上吧，",
        "unit_id": 18711,
        "voice": "vo_adv_5205002_013"
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "我的奴隸啊！",
        "unit_id": 18711
    },
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔！？",
        "unit_id": 134811,
        "voice": "vo_adv_5205002_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你突然",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是要幹嘛！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哦～",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_015"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呵呵呵♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n竟然突然就被襲擊了，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "看來妳似乎相當遭人怨恨呢♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是因為妳平時素行不良吧？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "向我學學如何？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才沒有遭人怨恨！",
        "unit_id": 134811,
        "voice": "vo_adv_5205002_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n說到底我可是偶像！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的工作是傳遞",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "歌曲與舞蹈，才不是什麼怨恨的！",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……偶像？",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_017"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哦～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "相當不錯的職業嘛。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "讓妳當襯托本小姐的伴舞也是可以的喔？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "襯托華音這種事我絕對不要！",
        "unit_id": 134811,
        "voice": "vo_adv_5205002_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n──這就是",
        "unit_id": 134811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "最後一擊了！",
        "unit_id": 134811
    },
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "二人組",
        "words": "咕啊啊啊啊啊啊",
        "unit_id": 1,
        "voice": "vo_adv_5205002_019"
    },
    {
        "type": "dialogue",
        "name": "二人組",
        "words": "啊啊啊啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……差不多就這樣吧。",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "姑且",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "先用絲線把他們綁起來吧。",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "雖不及我的程度，",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_021"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "但相當能幹嘛。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n用絲線束縛的效率也是既迅速",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "又美麗……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不過，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "偶像是像這樣的存在嗎……？　",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我說",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你們，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼要襲擊我們？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "黑暗精靈跟",
        "unit_id": 50811,
        "voice": "vo_adv_5205002_023"
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "女哥布林",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "到處在宣傳著啊……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "\n說會給予",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "在這個結界中",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "最後勝出的人",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "奴隸",
        "words": "從異世界來的「最強奴隸」……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "從異世界來的",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "最強……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "奴隸！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那該不會是……！！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──喂，你！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "黑暗精靈那幫人",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在哪裡！？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "那些傢伙應該正在那邊，",
        "unit_id": 18711,
        "voice": "vo_adv_5205002_025"
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "\n召集像我們這樣的人，",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "主人",
        "words": "把剛剛的話宣傳出去……",
        "unit_id": 18711
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……唔！",
        "unit_id": 134812,
        "voice": "vo_adv_5205002_026"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "等一下，傲嬌粉紅！",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_027"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "她無視本小姐走了。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "還真～～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是忙碌呢，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "庶民們。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "為什麼我必須為了庶民",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_028"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "而移動這雙玉足？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不如",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就拿那個粉紅頭來當誘餌、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我知道了啦，不要用魔卡！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "咦！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205002_029"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "你不由分說地做什麼！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是要去追粉紅頭吧！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n我",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "會跑著去啦！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "所以別擅自封印啊啊啊啊──",
        "unit_id": 134912
    },
    {
        "type": "background",
        "background": "502390"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "聽好了，奴隸們！",
