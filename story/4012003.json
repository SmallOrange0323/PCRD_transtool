[
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "總覺得",
        "unit_id": 132412,
        "voice": "vo_adv_4012003_000"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n可可蘿跟小苑很像，讓人好安心～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_4012003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小個嬌小的精靈族，而且服裝是綠色的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若以",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要素來看，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下和苑小姐的共通點或許很多。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這麼說讓在下很開心呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "耶～！",
        "unit_id": 132412,
        "voice": "vo_adv_4012003_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n彩羽也很開心～！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913,
        "voice": "vo_adv_4012003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "彩羽小姐！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別突然這樣跳……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想充滿活力地蹦跳，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n最好先整理好服裝，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不然",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不得體。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913,
        "voice": "vo_adv_4012003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好把腰帶束好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鞋帶也都鬆了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下幫您繫上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "看吧，",
        "unit_id": 132412,
        "voice": "vo_adv_4012003_005"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不光是外表，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "可可蘿連這種地方都跟小苑一樣！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘿嘿～",
        "unit_id": 132412,
        "voice": "vo_adv_4012003_006"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "最喜歡妳了～♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n可可蘿姑姑～♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "姑、",
        "unit_id": 105913,
        "voice": "vo_adv_4012003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "姑姑……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？",
        "unit_id": 105913
    }
]