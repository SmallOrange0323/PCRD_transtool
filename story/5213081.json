[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……啊！？",
        "unit_id": 104711,
        "voice": "vo_adv_5213081_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n鎧甲……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒事吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n抱歉，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剛才的事還請別放在心上……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104711,
        "voice": "vo_adv_5213081_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "吉歐‧格黑納的料理，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還真是驚人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n彷彿有股蛋白質的洪流充滿全身，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在油脂映照下閃耀的表面，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看似如岩壁般堅實，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n實則柔嫩，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "甚至讓人產生一種肉體被填滿，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "逐漸被鍛鍊打磨的感覺。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "令人佩服，",
        "unit_id": 104711,
        "voice": "vo_adv_5213081_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "皇女。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣直接震撼身體，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像是連血肉都為之躍動的料理，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也是第一次品嚐到。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "能得恁這般勇將讚許，",
        "unit_id": 129711,
        "voice": "vo_adv_5213081_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家此番準備也算是值得了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "來吧，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "別只是一口。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此乃奴家用心烹製之料理，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下亦",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正翹首以待，目光熠熠呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不、",
        "unit_id": 104711,
        "voice": "vo_adv_5213081_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不了！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳的心意我十分感激，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但我等一下還有",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "巡視會場的公務在身！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "先失陪了！！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "遺憾。",
        "unit_id": 129711,
        "voice": "vo_adv_5213081_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "純閣下那番失態之姿，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若僅止於一見，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實乃可惜之餘興呢。",
        "unit_id": 129711
    }
]