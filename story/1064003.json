    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼找工作嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就算沒有任何經驗，",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也會",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好好努力的！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n為了媽媽！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……啊……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_010"
    },
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這就是",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "公會的布告欄啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只要從張貼的公告裡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n找一個自己做得來的工作就行了嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有好多種工作啊……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你有什麼",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "推薦的嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擊退魔物……",
