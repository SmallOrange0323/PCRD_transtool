        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "今天我還搞砸了好多事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……謝謝你，{player}。",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_035"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的會有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "適合我做的工作嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那怎麼行……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_036"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "啊！",
        "unit_id": 1411,
        "voice": "vo_adv_1064003_037"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n找到了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n剛才的小姑娘！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你是……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_038"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛剛受到波及",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "停下馬車的車夫先生……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛才，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很抱歉……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "沒事！",
        "unit_id": 1411,
        "voice": "vo_adv_1064003_039"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n妳不用放在心上。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "比起這個，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "妳是不是很擅長使用冰系魔法呀？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_040"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……嗯，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "算是吧……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "那正好！",
        "unit_id": 1411,
        "voice": "vo_adv_1064003_041"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n妳能幫我把這個吞拿金槍鮪肉塊",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "冷凍起來嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "喔，",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_042"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以啊……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "哇，",
        "unit_id": 1411,
        "voice": "vo_adv_1064003_043"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "太神奇了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n凍得硬邦邦的呢！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這點小事",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_044"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒什麼大不了的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "這行得通！",
        "unit_id": 1411,
        "voice": "vo_adv_1064003_045"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n嘿，小姑娘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "妳願不願意來我們運送公會工作呀！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "如果能把鮮魚和肉類冰鎮起來的話，",
        "unit_id": 1411,
        "voice": "vo_adv_1064003_046"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "就能維持新鮮度賣出去了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n報酬一分都不會少給！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n如何？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "拜託啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦！？",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_047"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這個嘛……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_048"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然無法加入你們的公會，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但我偶爾可以過去幫忙，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣你們願意讓我工作嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲開始在運送公會工作了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不光是冰鎮鮮魚和肉類，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n將雪菲製作的冰塊送往港口，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n食材就能在保有新鮮度的狀態下運送，評價非常好。"
    },
    {
        "type": "background",
        "background": "500366"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太好了……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_049"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這麼一來，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也能為家計貢獻一份心力了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當然了，",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_050"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "關於那些記憶……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想了解「以前的我」的心情",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是很強烈的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只不過，",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_051"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n「現在的我」",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是大家的夥伴，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這點更加重要。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n要能夠抬頭挺胸地",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "作為這個公會……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "【美食殿堂】的一員，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "尋找記憶",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_052"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就等到一切上軌道後再說吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_053"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好好努力的！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n努力製作冷凍吞拿金槍鮪……！",
        "unit_id": 106412
    }
