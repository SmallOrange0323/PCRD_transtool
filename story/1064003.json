    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不知情呀！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "【美食殿堂】的家計",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "居然這麼拮据……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐還去做兼職和家庭代工！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}，",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你也有在打工呀……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就只有我一個人",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "像是白吃飯的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣不行！",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以，我也要工作！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個嘛……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確實是……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有點傷腦筋。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "起碼……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「現在的我」是沒有工作經驗的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有什麼工作……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是我也做得來的嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……拜託你了，{player}。",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你能教我",
        "unit_id": 106412
