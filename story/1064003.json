    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412,
        "voice": "vo_adv_1064003_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "目前好像還沒有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在這座城附近的委託。",
        "unit_id": 106412
