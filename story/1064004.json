    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n作為學校活動的一環，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}觀看了花式滑冰的比賽。"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "好的，",
        "unit_id": 1,
        "voice": "vo_adv_1064004_009"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "阿賀斗紫布菜選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n究竟有沒有辦法",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "完成她最擅長的跳躍呢！？",
