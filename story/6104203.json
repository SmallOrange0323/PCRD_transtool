[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要談和的話，",
        "unit_id": 107111,
        "voice": "vo_adv_6104203_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n首先必須要",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "化解對方心中的芥蒂呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "與獸人族加深交流的點子啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這提議雖然簡單但卻不錯呢。",
        "unit_id": 107111,
        "voice": "vo_adv_6104203_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n共同用餐作為互相理解的方式",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可說是簡易明瞭。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "叫大廚過來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們來請他們吃一頓宮廷主廚做的豪華全餐吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此，",
        "unit_id": 107111,
        "voice": "vo_adv_6104203_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這點子不錯。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在進行觀光導覽時，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n順便來一場包含了熱門偶像演唱會的觀光之旅……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這提議值得好好考慮一番。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我馬上就來",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "寫商業計畫書吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從小子你口中說出這提議還真是讓我驚訝。",
        "unit_id": 107111,
        "voice": "vo_adv_6104203_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的確，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有時比起千言萬語，這種方法更能清楚地表達自身想法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "得先跟小子你交心才行。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不會讓你逃走喔？",
        "unit_id": 107111
    }
]