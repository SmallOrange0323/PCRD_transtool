[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是怎麼回事，",
        "unit_id": 106011,
        "voice": "vo_adv_0000331_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這地方。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然已經到處調查過不少地方了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但總感覺有種很特別的氛圍呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是……",
        "unit_id": 105911,
        "voice": "vo_adv_0000331_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼了嗎？　",
        "unit_id": 105811,
        "voice": "vo_adv_0000331_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管是相當古老之地，",
        "unit_id": 105911,
        "voice": "vo_adv_0000331_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然而看來此處，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是一座神殿的模樣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明是這麼大的神殿，可是以前卻沒有被人發現過呀……",
        "unit_id": 105811,
        "voice": "vo_adv_0000331_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真是不可思議呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此處被施加了僅有被選中的人，",
        "unit_id": 105911,
        "voice": "vo_adv_0000331_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才能發現的魔法，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此才至今",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "皆沒有任何人能夠找著吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此呀～",
        "unit_id": 105811,
        "voice": "vo_adv_0000331_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說我們，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被這座神殿認同了這樣講沒有錯吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 106011,
        "voice": "vo_adv_0000331_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "照這樣講，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那這神殿不就隨便讓我們搜刮了嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很遺憾的是，",
        "unit_id": 105911,
        "voice": "vo_adv_0000331_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳說在這座神殿之中，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有著相當嚴峻的試鍊",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在等著來訪之人到來。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_0000331_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是還抱有一點期待的我傻了嘛……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而相對的，",
        "unit_id": 105911,
        "voice": "vo_adv_0000331_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能夠跨越此試煉之人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就能將那蘊含龐大力量的道具，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n納入囊中――有著如此的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳聞記載。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有這種事妳還不早一點講！！",
        "unit_id": 106011,
        "voice": "vo_adv_0000331_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然如此，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "絕對要讓這座神殿後悔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "認同了我們的這件事啦！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿～。",
        "unit_id": 105811,
        "voice": "vo_adv_0000331_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留看起來幹勁十足呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就讓我們一起全力跨越這場試煉吧☆",
        "unit_id": 105811
    }
]