[
    {
        "type": "background",
        "background": "501473"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然跟閣下",
        "unit_id": 133212,
        "voice": "vo_adv_5160401_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "相處的時間也很長了，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但是這還是第一次",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓你看到我的新年和服裝扮呢。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼樣，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還挺不錯的吧？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "光是穿著傳統的服裝，",
        "unit_id": 133212,
        "voice": "vo_adv_5160401_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就會讓人想抬頭挺胸啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不管是什麼時候，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都不能做出不配這服裝的行為！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別擔心，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對我而言是小事一件！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好啦，",
        "unit_id": 133212,
        "voice": "vo_adv_5160401_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們去新年參拜吧，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "引路就交給你了。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n新年參拜之後，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "享受所有擺在參拜道路上的攤販吧！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "甜酒、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "鼈甲飴、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "糰子、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "迷你長崎蛋糕……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "味道很香呢！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……什麼，",
        "unit_id": 133212,
        "voice": "vo_adv_5160401_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我表情鬆懈了！？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n……這也沒辦法吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我很期待甜點，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "跟閣下的新年參拜也……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒什麼。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一年之計在於元旦。",
        "unit_id": 133212,
        "voice": "vo_adv_5160401_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好的一年",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是從好的新年開始的。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今年也請多多指教！",
        "unit_id": 133212
    },
    {
        "type": "background",
        "background": "502116"
    }
]