        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2009009_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是主人您所喜好的人們，",
