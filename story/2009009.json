        "type": "dialogue",
        "name": "可可蘿",
        "words": "就只是如同這樣眺望著舞台感官也自然感到愉悅了呢♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從腦門直到指尖，",
        "unit_id": 105913,
        "voice": "vo_adv_2009009_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全都洋溢著幸福感。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這便是人們口中所稱的偶像呢。",
