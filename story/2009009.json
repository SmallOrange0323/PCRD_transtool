        "voice": "vo_adv_2009009_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【王宮騎士團】的那兩位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎朝著在下等人的此處追了過來的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到就在附近……",
        "unit_id": 105913,
        "voice": "vo_adv_2009009_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一面混入人群之中，悄悄地遠離此處吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2009009_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若可行還想悠閒地，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n繼續留在此處享受著那幾位偶像所帶來的歌曲呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但卻處於無法如此的立場著實令人有所不甘呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    }
]