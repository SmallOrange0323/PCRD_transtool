        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管只有短短一瞬然而卻望向了主人您的方向，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n接著交頭接耳地談起話來了呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2009009_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您可真是有著相當廣大的人脈呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n竟能和那登上如此盛大舞台",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的偶像成為友人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
