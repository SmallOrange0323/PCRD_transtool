        "voice": "vo_adv_2009009_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論與誰都毫無偏見，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n進而結交良好的友誼也是主人您的優點呢。",
