[
    {
        "type": "background",
        "background": "502320"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說帆稀，",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳可以",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要那樣嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那樣是哪樣～？",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我什麼都沒有做喔～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳一邊跟在我後面，",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一邊時不時睜開眼睛盯著我這邊吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我有注意到喔？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦～？",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我不明白妳在說什麼呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "…………",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看，就是剛剛！",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就是在說不要那樣猛然睜開眼睛！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "人……",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是會眨眼的喔……？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哪可能有那種魄力超強的眨眼。",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正就是那樣吧，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳對嚮導小妖精很好奇吧？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳心想著",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真想調查啊～之類的吧？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真的是有事都沒辦法瞞過愛梅斯呢～",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是嘛，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟愛梅斯的存在可是特殊到",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "連與涅比亞都不同對吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n因為很稀奇，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以我忍不住就增加了眨眼次數……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳堅持要說是眨眼呢……",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "比起那個，愛梅斯，",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳差不多該休息了吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n一路跑下來累了吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我會幫妳擦防曬乳喔～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "依照剛才的發展，",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我是不可能會說",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「那就麻煩妳」的吧？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是怎樣？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該不會因為是夏天而很興奮吧？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳那對翅膀",
        "unit_id": 131811,
        "voice": "vo_adv_5150062_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也會好好幫妳塗的喔～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就說不要露出那個眼神了！",
        "unit_id": 131711,
        "voice": "vo_adv_5150062_013"
    }
]