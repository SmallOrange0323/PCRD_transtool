[
    {
        "type": "background",
        "background": "501862"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和七七香離開蘭祭的會場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n走向洋溢著萬聖節氣氛的蘭德索爾市區。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n萬聖節的燈光裝飾在他們面前逐漸點亮。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇～",
        "unit_id": 123711,
        "voice": "vo_adv_1237004_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "玩得好開心……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "點燈了！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n很有萬聖節的感覺呢～♪",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你問是什麼感覺？",
        "unit_id": 123711,
        "voice": "vo_adv_1237004_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嘻嘻♪",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像是能在天色這麼暗的時候外出走動，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還可以做很多事情，有種非日常的感覺！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 123711,
        "voice": "vo_adv_1237004_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說【暮光流星群】居然覺得這樣就非日常？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這個嘛，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼說也沒錯，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是傷腦筋啊！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個嘛，",
        "unit_id": 123711,
        "voice": "vo_adv_1237004_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "平常也是很開心啦……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過這種活動會讓我熱血沸騰啊！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還有點燈不是有種正在發動什麼潛藏的力量的感覺嗎？",
        "unit_id": 123711,
        "voice": "vo_adv_1237004_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯沒錯，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是這樣就是這樣……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等等，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喂！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你幹嘛發光啊！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且光好像還越來越強……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚喔！",
        "unit_id": 123711,
        "voice": "vo_adv_1237004_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好刺眼！",
        "unit_id": 123711
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈囉～打擾了～！",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡就是你的房間啊……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那就馬上來搜索～",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "開玩笑的開玩笑的。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "抱歉啊，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n說要跟你商量事情就跑來了。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯……",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實呢，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我抽中啦！！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n下一次巴哈姆提亞活動的參加資格！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀～費了我一番工夫啊……",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n因為是用抽的所以靠關係也沒用呢～",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我靠自己努力順利得到手了！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呢……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "接下來才是問題啊～",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這場活動",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以Cosplay。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我也是可以Cos已經出過的角色去啦，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是既然要去，就會想Cos新角色不是嗎？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在煩惱的是……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個Cosplay的角色啦……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我想穿我常Cos的莉莉艾利的新衣服去……",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是我也喜歡新角色貝爾蒂埃啊～！！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是說，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "貝爾蒂埃是冷酷傲嬌型的角色，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n跟我完全相反……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一點也不像啊。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣我還可以Cosplay嗎～",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我一直在煩惱。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個算是、",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "煩惱嗎……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該算是抱怨吧。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n啊哈哈，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "謝謝呀，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "跟你說了之後心情暢快多了。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實不管怎麼說我都沒辦法Cos啦，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "市面上也沒賣她的服裝……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "做做做、",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "做是要……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "做、",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "做什麼！？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你是說，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "Cosplay貝爾蒂埃嗎……？",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我不是說了嗎，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "市面上也沒賣她的服裝……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想！",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我其實很想啊！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣啊……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說的也是。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n動手做就好了嘛！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "說什麼市面上沒有賣",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種話……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n在我想Cosplay的心情之前都是藉口嘛！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會來找你，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "搞不好其實是希望你像這樣從背後推我一把，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n……大概吧。",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好～！",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然決定好了，就著手準備做衣服吧！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "快沒有時間了，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我有決心熬夜……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你要幫我嗎？",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n可是……",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這時候就該乖乖接受你的幫助！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好～",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然要做，",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就要做出最棒的衣服！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我先回去準備需要用到的東西！",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n等我一～下下就好！",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n喝！",
        "unit_id": 101331
    },
    {
        "type": "background",
        "background": "510091"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好，",
        "unit_id": 101331,
        "voice": "vo_adv_1237004_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以呢～",
        "unit_id": 101331
    },
    {
        "type": "dialogue",
        "name": "七七香",
