[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在日和一行人成立公會「破曉之星」後，\n他們接下了搬運貨物的委託，朝著精靈之森前進。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，謝謝你今天一起來喔！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘻嘻……真的謝謝喔！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓人覺得很放心呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才不是小事呢！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定會好好的回報恩情，敬請期待喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能接到委託雖然很好，",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但這可不是只靠我們就能處理的數量吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，日和太輕易答應了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對不起……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是呀，託日和的福我們的委託才能毫不間斷，",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我和怜呀，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n真的很感謝妳呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的，優衣太寵她了……",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……請停一下。前面好像有什麼。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "盯……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "糟糕了！　有老婆婆倒在那裡！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n得去幫她才行！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和等一下！",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜，騎士先生，我們快追上去吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣！",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……唉唉，就知道會變成這樣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也跟上去吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "嗚嗚嗚…",
        "unit_id": 611,
        "voice": "vo_adv_3007002_011"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "…",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆！妳沒事吧?",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_012"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你、你們是……？",
        "unit_id": 611,
        "voice": "vo_adv_3007002_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們是因為受人之託而正在運送貨物的途中喔。",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆妳呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我在旅途中跟我的兒子們走散了……",
        "unit_id": 611,
        "voice": "vo_adv_3007002_015"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n不知道他們能否安全到達精靈之森呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "精靈之森？　和我們的目的地一樣呢！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆，我們帶妳一起去吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。如果這樣下去的話抵達精靈之森的時間會有延遲。",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "替老婆婆療傷後我們應該和她分道揚鑣才對。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這孩子說得對呀！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_018"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你們也有自己的計劃吧？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n所以……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那樣是不可以的！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n見到有困難的人而棄之不管，我辦不到。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "拜託了！　不會造成大家困擾的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是沒有關係啦……",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡就交給公會長判斷吧。",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會有什麼妖魔鬼怪出現，不前進的話也不曉得啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說的也是。",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果有為人子女的把老婆婆拋棄在這個森林中，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那傢伙也不會是什麼好東西啊。保持警戒謹慎前進吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……今天有很多魔物出沒呢。",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n明明這條路線不應該有那麼多魔物出沒的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜妳看。那個魔物，會不會是……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣也查覺到了嗎？　",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個恐怕是人類披著魔物的皮。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是野賊們常用的手法。那個老婆婆，感覺很不對勁啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我、我兒子就在那裡！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎！？ ",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我去看看狀況！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘠喔喔～！",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_027"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n（到底是怎樣啊媽媽！這群人很強耶！）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又有魔物嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不管來多少隻都是一樣喔！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘠喔～",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_029"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！\n（竟然一擊就把我打倒了！！）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊、",
        "unit_id": 611,
        "voice": "vo_adv_3007002_030"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊啊……！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是千鈞一髮呢……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆，妳沒事吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這、這樣的話……！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "糟糕了！　似乎想對日和不利！",
        "unit_id": 100312,
        "voice": "vo_adv_3007002_033"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和！　快逃呀！",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_034"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不要靠近我喔！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老、老婆婆，請冷靜下來！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n現在附近沒有魔物了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "――嘠喔喔～！！",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_037"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "\n（上吧你們！）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "――嘠喔喔～！！",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_038"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "\n（這次輪到我們了！）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "被包圍了嗎……！",
        "unit_id": 100312,
        "voice": "vo_adv_3007002_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，我們怎麼辦……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "遵命！　",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆請留在這裡！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "等、等一下！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "OK！　",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_043"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆妳不用拿什麼武器之類的沒關係！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請躲在我身後就好！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_044"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不要拿走我的刀啦！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "絕不會讓魔物傷害老婆婆的！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_045"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n衝啊～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "糟糕！！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和離開了老婆婆！",
        "unit_id": 100312,
        "voice": "vo_adv_3007002_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n先收拾周圍的小卒吧！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！　",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_048"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們上吧，騎士先生！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "――嘠喔～",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_049"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "！\n（噫～！！）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這是最後一匹了！　喝啊！！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_050"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "――嘠喔～！",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_051"
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "\n（哇啊啊！！）",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很意外地輕鬆解決掉了啊……",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嘛，這也是多虧了日和吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "即使沒有我們，",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_053"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n也能一個人不斷地打倒魔物呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "魔物？",
        "words": "請妳原諒我！饒我一命吧！",
        "unit_id": 1611,
        "voice": "vo_adv_3007002_054"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "魔物居然會說人類的語言！？",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_055"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "可惡！我投降啦！是我們輸了！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_056"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "老婆婆，妳怎麼了!?",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_057"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們打敗魔物了喔？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我說日和啊……那個老婆婆，",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_058"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "似乎是與扮成魔物的人一夥，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n打算欺騙我們的呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦咦咦咦！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是真的嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎真的嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是開玩笑的話，那個老婆婆不會在這時候向我們投降吧。",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_060"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "居然是這樣……我，被人欺騙了呀……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "被騙的只有日和妳喔。我們從一開始",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就懷疑了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嘛話雖如此，能平安解決也都是多虧日和啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也認為，正因為日和很真誠地相信老婆婆，",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_063"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n所以才能突破所有的埋伏呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣，怜……！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_064"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果真的是這樣就好了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "求求妳……我把這個送給妳，請放過我吧！",
        "unit_id": 611,
        "voice": "vo_adv_3007002_065"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n這是我費盡千辛萬苦才得到的東西……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就是這顆寶石喔！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "欸！我把這個送給妳！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這個是！索爾魔珠！　與夢中所見一模一樣……！",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那這個我們就收下了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那麼……",
        "unit_id": 611,
        "voice": "vo_adv_3007002_067"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話雖如此，也不可能就這樣放他們一馬吧？",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想這些肯定也是不曉得從誰手上偷來的東西。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大家分工合作把這些人全員給綁好吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣・日和",
        "words": "遵命！",
        "unit_id": 1,
        "voice": "vo_adv_3007002_069"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……在自衛團時有聽說過，那群野賊",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n似乎是在那一帶做盡壞事的集團。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此……",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_071"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "提起精神吧，日和。",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_072"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……要再吃一個鯛魚燒嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是認為用食物可以讓我打起精神就大錯特錯了喔……？",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_073"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……那我不客氣了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嚼，嚼……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯～！　好好吃喔～！",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_074"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……咦？　怜妳看。那個袋子，好像在發光？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的耶……我都沒注意到。",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_075"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒記錯的話這裡頭是那個老婆婆所說的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在森林中的時候沒有發光過對吧……？",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_076"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且這個光，感覺好像在夢中看過……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊……然後當我們把它拿到塔的底下來，",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_077"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就發出這麼強的光芒……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也就是說……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個，是真正的索爾魔珠喔！　好厲害～",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_078"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "噓－！　別大聲嚷嚷！",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_079"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "換言之在這個世界裡，除了這個以外也有其它索爾魔珠存在。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如果將它們全部拿到手，就能夠登到塔上了！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼那麼，今後就得去更多的地方冒險，",
        "unit_id": 100111,
        "voice": "vo_adv_3007002_080"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n把所有的索爾魔珠找出來才行呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然那個夢，真的不只是一個夢……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007002_081"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，一點都沒錯……！",
        "unit_id": 100311,
        "voice": "vo_adv_3007002_082"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "親眼目睹了索爾魔珠光芒的日和、優衣和怜3人，\n對於在前方等待著的冒險，心中雀躍不已──"
    }
]