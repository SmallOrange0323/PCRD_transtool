[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "早安，少年",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不是早安，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而是該說午安的時間了呢。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "太陽已經完全升起了……",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然今天也有【王宮騎士團】的工作，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但已經完全遲到了。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n多虧了充足的睡眠，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n已經從身體不適中康復了喔。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然身體的關節各處還有些疼痛呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別看我這樣，平常也有在鍛鍊，應該很快就能恢復精神了喔。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "受你關照了呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝你，少年。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真的幫大忙了喔，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我會好好的答謝你的。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然已經說過很多次……",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要是有煩惱的話，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n隨時都可以找我商量。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別看我這樣，我可是出身於騎士世家。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n騎士啊，是相當重情重義的喔。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我家是來歷十分有傳統的名門，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n多虧如此，家訓也相當嚴格。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我總是穿戴著盔甲，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也是因為這個家訓的緣故。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然也有人會嘲笑，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n覺得這是個愚蠢的家訓。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我認為，將自己決定的事堅守到底，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是非常帥氣的生存方式……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別這麼說，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望至少能讓我向你道謝。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說我們互相認識，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是因為擔心倒在路邊的人，而護送對方到家裡……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並不是能輕易辦到的事喔。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為這是個欠缺仁義道德及人情的世界呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n多半人都認為無論別人在哪裡做什麼，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n都與自己無關……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或是不看、不聽、不說，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n佯裝成不知道的樣子。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因此你的溫柔，是非常稀有的。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……真的是個好孩子呢，少年。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話說回來。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你知道我的頭盔在哪裡嗎？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，起床之後就沒有看見了……",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要睡的時候與鎧甲一起脫下了，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n應該是放在枕邊才對。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "卻只有頭盔不見了。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不戴著它的話無法靜下心來，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若是你有線索的話希望能告訴我。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說，在屋內戴帽子之類的話，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是違反禮儀的……？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說的也是呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n暫且戴著遮住眼睛的面具，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在似乎也只有你在……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "算了。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就算不戴頭盔也好。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為昨天，我倒下的時候身上被泥土弄髒了……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以洗了頭盔，正在等它晾乾嗎？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然也想洗鎧甲。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但在睡著的我旁邊發出碰撞聲的話，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好像會把我吵醒，所以決定延後了嗎。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝你的體貼。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "個人來說的話。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n頭盔及鎧甲對我而言，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就像是內衣一樣……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然讓像你這樣的男孩子來幫我洗，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我感到很難為情。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但你也是出於好意對吧，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不會責備你喔。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n反而是害羞的我比較奇怪呢。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "比起那個。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你，從剛剛開始就在做些什麼？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊，在準備料理嗎。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n切菜的手勢看來很危險呢……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我來吧，別看我這樣，我平常都是自己煮飯的。",
        "unit_id": 104713
    },
    {
        "type": "still",
        "still": "104700601"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "作為受你照顧的回禮，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望至少能讓我為你做飯。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n請坐著等待吧。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n今天的菜單是……唔嗯、唔嗯？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你問我有沒有什麼要幫忙的？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光是坐著等待也很閒啊。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這樣的話就一起做飯吧，少年♪",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可以幫我把蔬菜的皮削掉嗎，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我來準備肉類吧。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得，好像有點像新婚夫婦呢。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不對，真抱歉。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你和我的年齡差，就如同大人跟小孩一樣，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n應該要表現得，像親子才對……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "忘了吧。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得只要和你在一起，就好奇怪。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該說是會不自覺的意識到嗎……",
        "unit_id": 104713
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我這樣的外表，所以不會有男性接近呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n面對異性，似乎還不能怡然自得的相處。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然【王宮騎士團】中也有男性，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但果然還是習慣不來啊……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "由於做事一板一眼，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我似乎常被認為「團長很沉默寡言」。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n其實我只是很怕生而已呢。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真不可思議啊。",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像這種煩惱，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n平常是不會對任何人傾訴的。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我明明是總是威風凜凜的，",
        "unit_id": 104713,
        "voice": "vo_adv_1047006_044"
    },
    {
        "type": "dialogue",
        "name": "純",
