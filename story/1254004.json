[
    {
        "type": "background",
        "background": "501690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "栞與喵特結束任務，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並在獵人公會的場地內進行了訓練後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在樹陰下享受短暫的休息時光。"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有沒有哪裡會癢癢的呀～？",
        "unit_id": 125414,
        "voice": "vo_adv_1254004_000"
    },
    {
        "type": "dialogue",
        "name": "喵特",
        "words": "咕嚕嚕♪",
        "unit_id": 2312
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 125414,
        "voice": "vo_adv_1254004_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你聽到了剛才的……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n呃，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我在替喵特",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "梳理毛髮……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喵特的毛很長，",
        "unit_id": 125414,
        "voice": "vo_adv_1254004_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我會每天替牠梳理，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以免毛髮打結。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你看。",
        "unit_id": 125414,
        "voice": "vo_adv_1254004_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n多虧如此，牠的毛髮才會這麼滑順。",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "像這樣把臉埋進毛髮裡，",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還能聞到太陽的香氣……",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵♪",
        "unit_id": 125414
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天",
        "unit_id": 125414,
        "voice": "vo_adv_1254004_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是個好天氣呢──",
        "unit_id": 125414
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "…………",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果數值下降，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就又要住院了……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "前陣子才剛出院的……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我能夠",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "順利從學校畢業嗎？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說到底，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的病真的",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能治好嗎……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "在這樣的狀態下，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我究竟該怎麼去想像……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "自己未來的志願還有夢想呢？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "光是為了撐過今天就竭盡全力了，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "根本沒辦法去想像",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「明天的自己」",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有「未來的自己」呀。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……不對，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不是的。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這或許只是我刻意不去想而已。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很害怕……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明天",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有未來……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……唉。",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喵～",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "貓叫聲……？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n到底是從哪裡傳來的──",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……啊！",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n該不會是",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "從這個排水溝傳來的？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然沒錯，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠究竟是怎麼跑進去的呢？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要搬開這個水溝蓋，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該就能救牠了……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……呼、",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "水溝蓋太重了，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "喘不過氣了……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "心臟也跳得好快，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我應該沒辦法",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "再繼續搬了……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "得找人來幫忙才行……",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_018"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "…………",
        "unit_id": 1031,
        "voice": "vo_adv_1254004_019"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "…………",
        "unit_id": 1231,
        "voice": "vo_adv_1254004_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不敢",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟其他人搭話。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "該怎麼辦？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只能靠自己努力了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n再試一次──",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "！",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……！",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "拜託你了！",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_024"
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "救了這隻貓。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇哇，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠在",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "磨蹭我的腳……！",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果摸牠，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該會被牠咬吧……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n還是",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠會用爪子抓我呢……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "…………",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好、",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好柔軟……！",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好溫暖……！",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好乖好乖♪",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這隻貓",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒有戴項圈呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且渾身髒兮兮",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "又很瘦弱……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該不是被人飼養的貓。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "耳朵上沒有記號，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "應該也不是這個地區的貓。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣的話，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠應該是隻野貓吧。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是被人給棄養的嗎……？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠在打噴嚏，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有可能生病了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……雖然還不清楚",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "接下來應該怎麼辦，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不過我打算",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "先帶牠去一趟動物醫院。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不好意思，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "把你給捲進來。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果有你一起的話……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就放心了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "幸好",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "小貓咪只是輕微的感冒呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只要提供牠充足的飲水、",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "餵牠吃飯，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "再給牠吃藥，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n馬上就會恢復健康了……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "問題是……",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_035"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這之後的事情呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算沒辦法養牠，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也能照顧牠到找到領養人為止。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "打算去拜託媽媽，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓牠先由我們家照顧。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "當然，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_036"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我覺得會被反對。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我會請姊姊幫我，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n試著說服媽媽",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "到她願意接受為止。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "之後",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_037"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "再利用公佈欄",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "和社群網站，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n找找看有沒有人",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "願意當牠的家人。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我現在能做到的",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也只有這些事情。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那真是",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_038"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "太好了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這樣的話，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就老實地",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "接受你的好意了♪",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後過了一個月的某一天──"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊！",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_039"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你來了呀！",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "關於喵特的事，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_040"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我有點話想跟你說。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n牠在那之後變得相當有活力喔。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_041"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我原本沒打算替牠取名的，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可是姊姊",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "幫牠取了這個名字……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在我的家人",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都是這樣叫牠的。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為這個關係，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_042"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對牠放了不少感情……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不管是照片還是影片，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "拍攝的對象都變成是喵特了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你看，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_043"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個影片。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這是我抱著喵特的時候……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n原來貓的身體可以伸得這麼長呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_044"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠的身體軟趴趴的，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "甚至讓人懷疑",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n「牠真的有骨頭嗎？」……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "人家說「貓咪是液體」，還真的是呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這部影片也很可愛喔。",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_045"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是喵特在睡午覺的樣子，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠露出肚子睡覺……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓人忍不住",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就把臉埋進牠的肚子裡了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠只有在餵飯時，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_046"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "叫聲會變得很撒嬌，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "摸牠時會發出",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼嚕呼嚕的叫聲……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們全家人都被牠",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "迷得神魂顛倒了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但這",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "並非只有我們家的人而已，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n其實……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "其實",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_048"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們幫牠找到領養的人了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經決定",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一週後在公園見面。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我會在那裡",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "與喵特道別。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "到時候",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_049"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會由我負責去見對方。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n然後",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就是……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……太好了。",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_050"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "果然能懂",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我的想法呢♪",
        "unit_id": 103831
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳就是栞小姐吧。",
        "unit_id": 1,
        "voice": "vo_adv_1254004_051"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n然後",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這隻貓是……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我家以前",
        "unit_id": 1,
        "voice": "vo_adv_1254004_052"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "也有養過貓……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "花色和這隻貓是一樣的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n我一定",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "會很細心養育牠的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_053"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "麻煩妳了。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最後",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以讓我再抱抱牠嗎？",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "當然可以。",
        "unit_id": 1,
        "voice": "vo_adv_1254004_054"
    },
    {
        "type": "still",
        "still": "125400401"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好溫暖……",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_055"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明才短短一個月……",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_056"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就長大了",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "相當多呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "替你擦眼眶、",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_057"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "餵你吃飯、",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "給你抱抱……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這些都是我第一次經歷的事情，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以很拚命去做……",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n每天",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都咻地一下就過去了呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你身體突然狀況變差的時候，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_058"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我雖然做好了心理準備，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但你憑著自己小小的身體",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "熬過了難關呢。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原本是我救你的，",
        "unit_id": 103831,
        "voice": "vo_adv_1254004_059"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但卻感覺被拯救的人",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是我自己。",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也不會認輸，",
        "unit_id": 103831
    },
    {
        "type": "dialogue",
