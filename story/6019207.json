[
    {
        "type": "background",
        "background": "500680"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是不是不在意被曬黑呀？",
        "unit_id": 110211,
        "voice": "vo_adv_6019207_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我倒覺得不管擦多少防曬乳都嫌不夠呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "烈陽可是淑女的大敵喔！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那就拜託你一下了……",
        "unit_id": 110211,
        "voice": "vo_adv_6019207_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你不會是想趁機",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "摸淑女的肌膚吧？　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唉……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好吧，這次就允許你這樣做。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要是敢碰奇怪的地方，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我絕對不會放過你喔～？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是、",
        "unit_id": 110211,
        "voice": "vo_adv_6019207_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是那樣嗎？　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然你那樣說，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我今年就試試看曬黑吧？　",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我討厭",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "曬傷後刺痛的感覺，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我還是乖乖擦上防曬乳吧！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "竟然懂得淑女的辛苦，",
        "unit_id": 110211,
        "voice": "vo_adv_6019207_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是個不得了的紳士呢。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然如此，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要不要體驗看看這份辛苦啊？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "特別允許你直接碰觸我的肌膚喔。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來幫我擦防曬乳吧！",
        "unit_id": 110211
    }
]