[
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊緒與{player}兩人，\n在沙灘上一邊休息，一邊討論游泳的練習。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要學會游泳真是辛苦呢〜",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為想到溺水的話該怎麼辦，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總是感到不安呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天是因為與你在一起的關係嗎，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛不可思議地覺得平靜。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我潛到水中也不感到害怕，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這還是第一次。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "相反地，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛還有點興奮呢！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然今天的目標是學會游泳，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但卻有種",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "想向廣闊大海挑戰的感覺！　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得來到海邊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們稍微玩一下吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然這樣說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但無法立刻就會游泳可以玩水，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該怎麼辦呢……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯？　",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你在四周張望什麼呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n海之家有什麼呢？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雙人泳圈……？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果我們坐上雙人泳圈，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就可以一起享受大航海的樂趣了！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "決定好的話，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那我就買了唷！",
        "unit_id": 110111
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼―！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼……",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為雙人泳圈體積大，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要完全充滿空氣也是很累人呢～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剩下一點就可以完成，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "接下來可以麻煩你嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝呢！",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好的，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麻煩你用力把它充滿唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼―！　",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請跟我說。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "做的很好呢！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣就完成充氣了！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們就乘坐泳圈出航吧！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n前面就交給你嘍！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊哈哈，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有了這個―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就算不會游泳",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也能大航海冒險―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "潛入海底的話，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n能看到各種顏色魚兒在游泳，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一定非常漂亮吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣也很開心～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又學到了不會游泳也能享受海洋的方法呢♪",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我有點太興奮過頭了嗎？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那是因為很開心，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不自覺就划過頭了呢〜",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你現在",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不也看起來超開心的嗎〜？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒有離海灘太遠，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n而且坐在泳圈上，所以不會感到害怕沒問題的。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對不會游泳的我們來說，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這可是很了不起的呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作夢也沒想到可以這樣航海冒險～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就這樣兩人在廣闊的大海中漂浮著，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n感覺好像",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "世界上就只剩下我們，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總覺得好浪漫～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我和你兩個人，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就這樣一直飄到盡頭吧？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我亂說的啦，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太出去外海的話被急流沖走會很危險，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n回到淺灘吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這樣漂流下去的話――",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "！？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喂，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該不會……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊―――！！",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我看到前面了，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是魔物的背鰭！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "會被吃掉啦～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就算你叫我不要亂動，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是我好害怕～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊啊～，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然是老師但是不會游泳真對不起大家～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會努力成為大家的榜樣，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "努力練習游泳的，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要吃我啦～！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這個時候你叫我冷靜，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我沒辦法呀～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為什麼你這麼冷靜呀～",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n就跟你說，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要我冷靜下來是……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的耶……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就像你所說，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_034"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只是海面突出的岩石堆而已。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為太慌張了，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以誤看成魔物的背鰭。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嘿嘿，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛剛很不像老師吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n剛剛讓你一直看到我丟臉呢……",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咳咳！",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_036"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們重振精神，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n回到海濱處悠閒玩水吧。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀……？",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們游了一陣子，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_038"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有經過剛剛的折騰，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我的腳已經顫抖地動不了啦。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被海浪推回來無法前進呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣下去真的漂走啦～！",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_039"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哇，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_040"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真快―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你一個人就可以這麼快速前進呢，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這麼多精力是藏在哪裡呢。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "果然不愧是男孩子。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好可靠呢～",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果世界真的只剩下我們兩人，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_042"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只要跟你在一起，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "無論發生什麼事我都能冷靜唷。",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明明我才是老師，",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣是不是太依賴你了呢……？",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不！　",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_043"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒什麼事！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來吧，",
        "unit_id": 110111,
        "voice": "vo_adv_1101002_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "努力划水吧―！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "加油、",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "加油―！　{player}！",
        "unit_id": 110111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "總是在教室面對面上課的伊緒，\n這時候，第一次看到{player}的背影。\n他的背影，比伊緒想像的看起來更可靠。"
    }
]