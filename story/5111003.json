[
    {
        "type": "background",
        "background": "501930"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "未菈帶路所抵達的目的地，是旅館的前面。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這種地方是你們的根據地？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就只是一間旅館耶。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這還真是……",
        "unit_id": 124812,
        "voice": "vo_adv_5111003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完全沒想到呢。",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "呵呵，",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_002"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "你們以為會是一棟邪惡的宮殿嗎？",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "我說過了吧？",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_003"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "我們既不是侵略者，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "也不是大壞蛋。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "我們原本只是冒險者……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "不需要什麼鋪張的城堡。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "在經歷無數冒險之後，",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_004"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n回到旅館時",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "感覺最令人安心，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "你們懂吧？",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "正因為是隨處可見的普通旅館，",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_005"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n才會成為我和亞斯來能感受到幸福的",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "回憶場所。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……這樣啊。",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們就趕快和亞斯來做個了──",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "樂園守護者",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 17111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那、",
        "unit_id": 124812,
        "voice": "vo_adv_5111003_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那是……！",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不安與恐懼的魔物……",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且還是一大群。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還想說一路上都沒看到半隻，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "卻在這最糟糕的時機出現了。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "不是我召喚它們的。",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_009"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "它們是樂園守護者……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n是防止我們的理想不受破壞、",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "守護幸福的存在。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就是從人身上跑出來的魔物啊……",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然對手是魔物，就沒什麼好顧慮的了！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要盡情地大鬧一場囉！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你、",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你在說什麼啊！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我怎麼可能那麼做！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳沒時間應付這些小嘍囉了不是嗎？",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n打掃就交給我們吧。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對啊！",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳快點去做個了斷，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "取回重要的胸針吧！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們……！",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "知道了！",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}，謝謝你！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們一定要追上來喔！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "滾開滾開──！",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大壞蛋諾維姆要登場",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "了──",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "──咦？",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_017"
    },
    {
        "type": "background",
        "background": "501940"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這、",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡是……",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "花田？",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我、",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我剛剛",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是走進了旅館裡，",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對吧？",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "這裡是我和亞斯來",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_019"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "第一次的冒險時抵達的花田。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "沒錯，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_020"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "所以我把這代表我們幸福回憶的地方",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "實體化了。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我們一輩子都忘不了……",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "這景象非常美麗吧？",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "亞斯來……！",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_021"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "好了，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_022"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "妳總算來了啊，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "矛依未。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n妳終於下定決心了嗎？",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對，",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的答案，你好好聽著！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快給我把這傢伙變回胸針！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊，好痛，",
        "unit_id": 106211,
        "voice": "vo_adv_5111003_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，給我等一下～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n妳這樣對我，會不會太過分了啊？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "少囉嗦！",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "竟然隨便使用我的回憶！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我絕對饒不了你！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "嗯，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_026"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "看來妳不太中意的樣子呢。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "看來我做錯了，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我道歉。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "不過，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_027"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "像這樣與幸福的回憶面對面，妳應該了解了吧？",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "未來是不確定的，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_028"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "而且可能受到他人影響，變成我們不希望的模樣。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "正因如此，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_029"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "只要持續觀看",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "永遠幸福、溫柔又美好的過去，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "就不會受傷、",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "也不必受苦，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "難道不是嗎？",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對，",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯……",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我現在也仍然為與尾狗刀離別這件事感到悲傷。",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也很想回到和尾狗刀一起做壞事的那段時光。",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然這傢伙是冒牌貨，",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但和他聊天的這段時間真的很快樂……",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但即使如此……",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和緊抓著幸福回憶不放相比，",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我更想要在未來與搭檔重逢！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再創造新的回憶！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "阻礙我的人，",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我將讓他嚐到大壞蛋的怒火！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n明白了嗎！？",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "矛依未……",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_034"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "妳和我是有著相同境遇，如同鏡子般的存在。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "可是，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "可是為什麼我們會如此不同呢？",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "我相信我們正在做的事情並沒有錯……",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_035"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "然而，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "妳那堅信未來的模樣……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "讓我覺得有些耀眼。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呵呵──！",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳發現我滿溢的壞蛋魅力了嗎？",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳很有品味嘛！",
        "unit_id": 125013
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "未菈……",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_037"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "看來妳",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "稍微被矛依未感化了呢。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "亞斯來，",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_038"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "不是的……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "我……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "矛依未，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_039"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我本來希望",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "讓妳透過幸福的時間",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "了解在回憶中生活有多棒。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "甚至使用了將回憶中重要的人實體化的",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_040"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "這種",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "特殊方法。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "但是",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_041"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我卻無法改變妳的心意。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "再這樣下去，妳會阻礙我們的目標吧。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "所以──",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_042"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "亞斯來……！",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_043"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "不能那麼做！",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我要奪走",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_044"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "妳的回憶。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊……",
        "unit_id": 125013,
        "voice": "vo_adv_5111003_045"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "矛依未……",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_046"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "啊啊，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "怎麼會這樣……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗚哇！",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是怎麼回事？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這真的是旅館裡面嗎？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘉夜、",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那邊好像有人……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "騙人，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "倒在地上的，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是矛依未……？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂，我說你們！",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明說自己是樂園的引導者，說要救人，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那這是怎麼回事啊！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我們溝通過了。",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_050"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "然而，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我們沒能互相理解。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "所以",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "為了讓她不再繼續感到痛苦──",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我把她的回憶全都奪走了。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把回憶……",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "全都？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "現在的她",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_052"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "回憶全都消失了，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "因此向未來邁進的意志也消失了。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "就像",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_053"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "陷入了時間停止的狀態。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "雖然感受不到幸福，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_054"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "但也",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "感覺不到痛苦。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "這也",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "可說是另一種救贖吧。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "抱歉，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_055"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "都怪我力量不足，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "所以沒能讓妳成為樂園的居民……",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你這傢伙，",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在開什麼玩笑──",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "對不起……",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_057"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "我沒能",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "阻止亞斯來……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "真的，",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "很對不起……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "未菈……",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_058"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "亞",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_059"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "斯來……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "這麼做是不對的……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "這樣子根本稱不上是幸福。",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n沒必要做到這種地步啊！",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我也感到十分遺憾啊。",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_060"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "但是，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "為了實現和妳共同的目標，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n讓所有人都成為樂園的居民，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "這也是不得已而為之。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "希望妳能原諒我。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "啊……",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_061"
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "那時候",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "你也是這樣……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "說是為了",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "目標……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "\n你真的是",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "一點都沒變呢……",
        "unit_id": 9011
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "那時候……？",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_062"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "唔，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我不明白妳在說什麼。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "未菈",
        "words": "…………",
        "unit_id": 9011,
        "voice": "vo_adv_5111003_063"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "好了，",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_064"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "就只剩下你們了。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "抵抗是沒有意義的，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "至少",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "要讓你們幾個",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "成為樂園的居民──",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "混帳，給我閉嘴！",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喝啊啊──！",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_066"
    },
    {
        "type": "background",
        "background": "501940"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "……唔。",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_067"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "說什麼都沒用嗎？",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我們其實並不想跟你們戰鬥的。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算你們不想，",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_068"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們倒是挺想的！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我知道了。",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_069"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "就像你們擁有堅信的事物一般，",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "\n",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我也有必須達成的使命。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "既然你們打算刀劍相向──",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "那我也",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_070"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "要做出相應的對策了。",
        "unit_id": 17211
    },
    {
        "type": "background",
        "background": "501940"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_071"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不愧是前冒險者，真難纏。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_072"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但感覺這傢伙的強大不僅於此。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我有不好的預感……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別掉以輕心了！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "我並不想再繼續傷害你們。",
        "unit_id": 17211,
        "voice": "vo_adv_5111003_073"
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "請你們",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "亞斯來",
        "words": "收起武器吧。",
        "unit_id": 17211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔，",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_074"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那高高在上的姿態，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有點討厭耶。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好像自己已經贏了一樣。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "身為偶像，",
        "unit_id": 124811,
        "voice": "vo_adv_5111003_075"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我比任何人都更能看見未來的希望，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "並且持續給予許多人勇氣！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以我不會在這種地方止步不前！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我才不管你們發生過什麼事。",
        "unit_id": 124911,
        "voice": "vo_adv_5111003_076"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也是靠著這雙拳頭活到了現在。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我絕對不會屈服於過去！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜、望",
        "words": "喝啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_5111003_077"
    }
]