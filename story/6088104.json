[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "秋乃小姐的活力……",
        "unit_id": 121411,
        "voice": "vo_adv_6088104_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的很旺盛耶。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n她就是咲戀小姐的勁敵……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣的話，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n感覺秋乃小姐身上也有許多值得我學習的地方。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "開始製作服裝或飾品感覺也不賴。",
        "unit_id": 121411,
        "voice": "vo_adv_6088104_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n那我就跟鈴奈一起創業吧。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是那樣的話，",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我還得更努力用功讀書……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還是當我沒說好了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 121411,
        "voice": "vo_adv_6088104_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "爆炸？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你在胡說些什麼啊。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "像她那麼幹練的人怎麼會引發爆炸？",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n想開玩笑也不要亂講話好嗎。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "拜秋乃小姐為師……",
        "unit_id": 121411,
        "voice": "vo_adv_6088104_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我怎麼覺得……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n有種超級不好的預感呢……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好像會工作得暈頭轉向……",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可能是因為認識優花梨小姐，才會這麼想吧。",
        "unit_id": 121411
    }
]