[
    {
        "type": "background",
        "background": "500354"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你覺得怎麼樣，",
        "unit_id": 121311,
        "voice": "vo_adv_6088207_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這是秋乃小姐幫我準備的服裝。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n請說說你的感想。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真不愧是秋乃小姐。",
        "unit_id": 121311,
        "voice": "vo_adv_6088207_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "竟然連這種服裝都有，\n真讓人驚訝……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你是指我",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很可愛嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請不要突然說這種話！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是啊！",
        "unit_id": 121311,
        "voice": "vo_adv_6088207_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在物產展上被大批客人圍繞著，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n總覺得",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "像是在參加祭典一樣。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n在這種時候，服裝也是很重要的呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "秋乃小姐的眼光",
        "unit_id": 121311,
        "voice": "vo_adv_6088207_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "果然獨到。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "能夠發想出新點子的人真是厲害。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不知道我",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是不是也有這種才能……",
        "unit_id": 121311
    }
]