[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天。\n當{player}正自己一人在散步時……"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "{player}大人……{player}大人……",
        "unit_id": 711,
        "voice": "vo_adv_1027006_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是我……",
        "unit_id": 711,
        "voice": "vo_adv_1027006_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "惠理子喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您問我",
        "unit_id": 711,
        "voice": "vo_adv_1027006_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼會變成這副模樣……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n果然還是會令人在意呢……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……不是的，",
        "unit_id": 711,
        "voice": "vo_adv_1027006_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我並沒加入【王宮騎士團】呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n而且",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也不算是穿著鎧甲……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實呢，",
        "unit_id": 711,
        "voice": "vo_adv_1027006_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是我在鍊金術的實驗途中，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不小心將自己的靈魂固定在這副鎧甲上……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n結果就變成這個樣子了……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您看……",
        "unit_id": 711,
        "voice": "vo_adv_1027006_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "正如您眼前所見，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n鎧甲內部是空的。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……嘻嘻。",
        "unit_id": 711,
        "voice": "vo_adv_1027006_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我被{player}大人看光光身體內部了呢……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "該怎麼說，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣子……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也算是相當美好的經驗呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您不要慌張……",
        "unit_id": 711,
        "voice": "vo_adv_1027006_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n實驗失敗是常有的事呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……那麼，",
        "unit_id": 711,
        "voice": "vo_adv_1027006_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我還有接下來的實驗……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我先走了……",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――次日。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……………………",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "喵～",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "喵～",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "喵～",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子？",
        "words": "\n喵～",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 102711,
        "voice": "vo_adv_1027006_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "惠理子在這裡。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡……",
        "unit_id": 102711,
        "voice": "vo_adv_1027006_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請看看您的腳下。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對，",
        "unit_id": 1711,
        "voice": "vo_adv_1027006_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也許我看起來像一隻貓……",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n但我是貨真價實的",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "惠理子喔。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我實驗又失敗了……",
        "unit_id": 1711,
        "voice": "vo_adv_1027006_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n結果與貓互相交換了人格……",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "喵～！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "摩擦摩擦……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "貓",
        "words": "舔舔……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "什……！",
        "unit_id": 1711,
        "voice": "vo_adv_1027006_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳在做什麼……！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不只在我的{player}大人",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "身上磨蹭……",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n竟、",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然還敢舔他……！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過是食肉目",
        "unit_id": 1711,
        "voice": "vo_adv_1027006_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "貓型亞目",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "貓科",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "貓亞科",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "貓屬，",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n竟敢像貓那樣撒嬌……",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就算是我也",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還沒做過這種事呀……！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就算那是我的身體……",
        "unit_id": 1711,
        "voice": "vo_adv_1027006_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也無法原諒妳！",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我必須要盡早找到恢復原狀的方法才行……！",
        "unit_id": 1711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "――次日。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "{player}大人……",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真不愧是{player}大人呢。",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這種程度的事情無法令您動搖呢……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您冷靜……",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然是這個樣子……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但我還是大人您的惠理子喔。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我實驗又失敗了……",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這次靈魂跑到了魔物體內……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "唉呀！",
        "unit_id": 411,
        "voice": "vo_adv_1027006_020"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "魔、",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "魔物啊！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "魔物進到城鎮裡了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "快找【王宮騎士團】，或【哞哞自衛隊】的人！\n請他們收拾魔物！",
        "unit_id": 311,
        "voice": "vo_adv_1027006_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "糟糕了……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "事情變嚴重了呢。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n真麻煩……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "叫我跟您走",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗎？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n原來如此……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是要逃跑呢……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我明白了。",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果是跟{player}大人在一起的話……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n不管到哪裡都可以……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "平安無事地逃走了呢。",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n真是非常感謝您，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕哦哦哦哦哦！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這魔物真吵呢。",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_026"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘰歐歐歐歐歐！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 1611,
        "voice": "vo_adv_1027006_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n雖然牠擁有我的外表，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但牠仍是魔物。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您不用客氣。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀？",
        "unit_id": 102711,
        "voice": "vo_adv_1027006_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "靈魂已經回到原本的身體了呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看來是藥效消失了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……那麼，",
        "unit_id": 102711,
        "voice": "vo_adv_1027006_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "立刻來進行……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "下一個實驗吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……為什麼要阻止我？",
        "unit_id": 102711,
        "voice": "vo_adv_1027006_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "科學的發展總是伴隨著危險……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "的呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我要繼續實驗……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦……？",
        "unit_id": 102711,
        "voice": "vo_adv_1027006_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要愛惜自己……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您在擔心我嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您真是溫柔的人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……不過",
