[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼咿、",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "累、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "累死了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "逃、",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "逃到這裡來就沒問題了吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也不能總是逃跑，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真想找個地方躲起來。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "牧場的視野太好了，沒有可以躲藏的地方啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這樣的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "或許只能潛伏在山中了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗚哇！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊、",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊嚇死人了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為什麼從草叢裡跑出來啦，{player}！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為這邊是捷徑，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要去牧場的時候會從山中橫越？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是哦……？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要走這種山林小徑，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "反而才辛苦吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}的腰腿都很健壯呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說，現在不是閒聊的時候！",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我正被追趕～快幫幫我！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n拉著我的手逃到遠方去！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咿……",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n腳步聲接近了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒有空從容地說明了，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總之什麼也別問，照我說的做！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "拜託了啊～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇哇！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n咦，為什麼要抱住我？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是、是要抱著我逃到遠方去嗎……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}也是，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n受到【哞哞自衛隊】的傢伙們委託，來追我的嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，我不就是飛蛾撲火嗎！",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n徹底被抓住了啊～嗚啊啊啊",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "太過分了！",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你這個叛徒！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我還以為，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只有{player}是我的夥伴的～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n被你道歉我也無可奈何啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}你這笨蛋～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我還覺得你是一個不錯的傢伙……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我明明相信著你～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n連你也想把我硬帶出去，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你是敵人對吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是連{player}都與我為敵，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那我就沒人可以信賴了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "四面楚歌啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n【伊麗莎白牧場】的大家，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也都在為追捕者那邊加油。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我好孤獨啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好難過。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚……",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n放手，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "放開我啦～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}你這笨蛋～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我明明相信著你！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚嗚。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n像這樣被緊緊抱住的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n以我的力氣是無法掙脫的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "投降投降。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是我輸了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我已經認命了，所以放開我吧。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不僅很痛，而且總覺得心情變得很奇怪……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對待女孩子啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "希望你能更加溫柔一點。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呵呵呵♪",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n放鬆力氣了呢，這個笨蛋！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n趁這個機會逃跑！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呀嗯！",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "？\n不、不要抓我的脖子啦～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n會窒息的！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "知、",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "知道了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不會再逃跑了！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那個表情，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎樣？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你在同情我嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果你覺得我有點可憐的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就放了我吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，不覺得可憐？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊是這樣啊……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也想過會是這樣的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯……雖然為了定期報告，我必須下山，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到【哞哞自衛隊】的據點露臉才行。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但因為太麻煩了，所以我一直不想去呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "結果啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好像讓【哞哞自衛隊】的大家",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很擔心的樣子。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為也沒有收到報告書，所以不知道詳細狀況，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n她們擔心",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "該不會是發生了什麼事情？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因此大家全副武裝地過來調查了……",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒想到卻看見我在房間裡無所事事，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以生氣地對我窮追不捨呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真討厭～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n被抓到的話會被罵的～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n會被訓話到死的……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "【哞哞自衛隊】雖然是個寬容的公會，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不過正因如此，罰則也是依個人斟酌決定。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "感覺大家會憑著憤怒的情緒，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n而給我嚴酷的懲罰。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "像是遭受烹刑之類的～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我沒有犯下那麼嚴重的罪吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不想死啊～！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "抽泣……",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我只是想要和平地，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n悠悠哉哉地生活而已。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明我只是想盡量避開",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "討厭的事情、痛苦的事情而已啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為什麼要摸我的頭？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你果然把我當成小孩子在對待吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都說我已經是大人了～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_042"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然能讓我抬頭挺胸這麼說的事一件也沒做啦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……唔～",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_043"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你說「我會陪妳一起道歉的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以不要哭」？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才沒有哭啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀，算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_044"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n即使像這樣繼續逃跑，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n狀況似乎也只會漸漸惡化。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "讓大家擔心，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_045"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也覺得有些抱歉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會向【哞哞自衛隊】的大家，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_046"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好好道歉的",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "仔細想想。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_047"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不用特地下山，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n大家都已經來到了牧場……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "省了下山的功夫，也算挺幸運的。",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_048"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就順便報告一下近況，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "完成工作～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就這麼辦吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀，",
        "unit_id": 102611,
        "voice": "vo_adv_1026005_049"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然福氣是等著不用忙就會來拜訪的呢～♪",
        "unit_id": 102611
    }
]