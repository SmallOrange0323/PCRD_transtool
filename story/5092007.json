[
    {
        "type": "background",
        "background": "500840"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "海盜島的生活迎來尾聲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n霞等人搭乘船踏上蘭德索爾的歸途。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以上就是",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在那座島嶼",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所發生的事情。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "這樣啊，",
        "unit_id": 7511,
        "voice": "vo_adv_5092007_001"
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "那個年輕人他……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "還有高登也是，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "人類真是難以理解呢。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先不管高登先生，",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "至少隨從先生他不會再傷害任何人了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在也獨自在船艙裡",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "乖乖地待著呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "這樣啊。",
        "unit_id": 7511,
        "voice": "vo_adv_5092007_003"
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "那我去巡邏順便找他聊聊天吧。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可以嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_004"
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "畢竟我在島上幾乎沒有派上用場呢。",
        "unit_id": 7511,
        "voice": "vo_adv_5092007_005"
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "而且",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "引導年輕人",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "也是我的工作呀。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我知道了。",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你才剛清醒沒多久，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不可以太勉強喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "別擔心，",
        "unit_id": 7511,
        "voice": "vo_adv_5092007_007"
    },
    {
        "type": "dialogue",
        "name": "教授",
        "words": "我可是有在鍛鍊的！",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊。",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "剩下兩人也很快就會醒來吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過還是會把他們綁到抵達蘭德索爾為止。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得很久沒有做像偵探的工作了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "最近都淨是一些不相干的工作。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不相干的工作？",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒事沒事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在自言自語……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不管怎麼說，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是趟好旅行呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要是能因此",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "增加往後的偵探委託，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n對我來說就是最好的酬勞了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的呢。",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然說原本是為了治療爸爸，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "結果卻",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "得到更多的收穫。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我很少和公會成員以外的人",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一起行動，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以和初次見面的人一起",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "到新的地方",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對我來說很新鮮呢。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在島上的那些日子",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對我的將來",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "會帶來好的變化，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我有這樣的預感。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯？",
        "unit_id": 2413,
        "voice": "vo_adv_5092007_015"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "也就是說",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "還好我有騙妳嗎？",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n嘎哈哈！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我做的果然是對的選擇！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你是不是想再反省一下？",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不、",
        "unit_id": 2413,
        "voice": "vo_adv_5092007_017"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不用！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不需要勞煩您了！",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "杏奈妳覺得呢？",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯，",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一想到安妮羅潔‧馮‧修特帕魯這個名字，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n接下來會如何轟動世界，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就感到無比的愉悅。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的充滿刺激的旅程啊。",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "趁這股激昂還沒冷卻下來，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n回家之後我要馬上動筆。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "標題就叫……",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「冥風戰記　 ",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "霸道靈海航路」！",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵呵呵，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這可會是驚人巨作！　",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對了，",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_022"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n讓以忍和霞作為模特兒的角色",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也登場如何？　",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我平常也很少和【暮光流星群】以外的人",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_023"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "混在一起，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "和兩人相遇",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也給了我很多新的刺激呢。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對了，",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "以她們兩個為主角的外傳感覺也會很有趣。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "天啊，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "想寫的東西太多了，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我手癢的快忍不住了！　",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "話說那個海盜寶藏啊，",
        "unit_id": 2413,
        "voice": "vo_adv_5092007_025"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "雖然說是一番佳話，",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不過就不能再多給一點好康嗎？",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "有形體的東西",
        "unit_id": 2413,
        "voice": "vo_adv_5092007_026"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "只有鑰匙感覺有點少耶。",
        "unit_id": 2413
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是啊，",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_027"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "通過測驗拿到的鑰匙，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n如果也有什麼有趣的機關就好了呢。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我本來煩惱要不要說，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過應該沒關係。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們看，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "把表面鍍金的地方刮掉以後……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "底下在閃閃發亮。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "霞，",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這該不會是……",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這把鑰匙是用寶石加工製作的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n單獨一把應該也有相當高的價值。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真、",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_032"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗎？",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔、",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喔～",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感覺滿好的嘛，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳該不會",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "打算拿去賣吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我驚！",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_034"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那、",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那怎麼可能！",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這可是充滿重要回憶的紀念品耶！",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不用那麼慌張啦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就算妳把它賣掉，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們一起度過的時間，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "結下的情誼，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也絕對不會消失不見的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這正是",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們一起獲得的寶物呢！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗚嗚，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然是我自己講的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是感覺好丟人……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼會呢，",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我覺得很感動呢。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n好期待和公會的夥伴",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "講這趟旅程的事情。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對了，",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_038"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我之前還和忍說了，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n要是我們四個之後",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還能再去旅行就好了。",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你們",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一定也會參加吧？",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好呀，",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽起來滿有趣的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對吧？",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_040"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比方說火焰化身之龍居住的火山、",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "引誘旅人的食人森林、",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓無數船隻陷入地獄的魔之海域等等……",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……杏奈，",
        "unit_id": 122012,
        "voice": "vo_adv_5092007_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很可惜，這些全部駁回。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "目的地就由我和忍來決定吧！",
        "unit_id": 101411,
        "voice": "vo_adv_5092007_042"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為、",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_043"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為什麼啊！",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你一定贊成我的意見對吧？",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對吧！",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特！",
        "unit_id": 121912,
        "voice": "vo_adv_5092007_044"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "像寶石般的回憶留在心中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n霞等人又再次回到了日常。"
    }
]