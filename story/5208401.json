[
    {
        "type": "background",
        "background": "501651"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "成功了……",
        "unit_id": 135712,
        "voice": "vo_adv_5208401_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "贏了……！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣一來就沒問題了吧……！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這個世界",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經不會有危險了吧……！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不，",
        "unit_id": 135512,
        "voice": "vo_adv_5208401_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這種事",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "即使是身為管理者的我也不曉得……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不對，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我已經不是管理者了呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……未來的事誰都不曉得。",
        "unit_id": 135512,
        "voice": "vo_adv_5208401_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n不只有幸福的事，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也有可能",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "會發生不幸的事或災難。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512,
        "voice": "vo_adv_5208401_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這不就是",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "自由的未來嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉……！",
        "unit_id": 135712,
        "voice": "vo_adv_5208401_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳說得沒錯！",
        "unit_id": 135712
    },
    {
        "type": "background",
        "background": "501652"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 108912,
        "voice": "vo_adv_5208401_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我們贏了。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "辛苦妳了，",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都……",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都？",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "霸瞳皇帝……",
        "unit_id": 135613,
        "voice": "vo_adv_5208401_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "最後擋在我們面前的果然是你嗎。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n有沒有靈魂並不重要。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "請你安息吧。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……志那都？",
        "unit_id": 108912,
        "voice": "vo_adv_5208401_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳在",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感謝他嗎？",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不是的。",
        "unit_id": 135613,
        "voice": "vo_adv_5208401_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但若不是為了克服那傢伙帶來的恐懼，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n讓大家都團結在一起，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那我們的未來的確也到此為止了。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……呵呵，",
        "unit_id": 135613,
        "voice": "vo_adv_5208401_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "抱歉。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n現在就先跟仰望同一片天空的盟友，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "一同分享勝利的喜悅吧──",
        "unit_id": 135613
    },
    {
        "type": "background",
        "background": "501651"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "埃拉，",
        "unit_id": 500096,
        "voice": "vo_adv_5208401_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "辛苦妳了。",
        "unit_id": 500096
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "辛苦妳啦，",
        "unit_id": 135512,
        "voice": "vo_adv_5208401_011"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都！",
        "unit_id": 135512
    }
]