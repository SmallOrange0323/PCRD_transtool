        "type": "dialogue",
        "name": "秋乃",
        "words": "\n在女僕的指導下",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "做出的蛋糕。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "除了烤火雞，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我還想讓你嘗嘗我做的其他料理……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以，才做出了",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "磅蛋糕……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "仔、",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_058"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "仔細看的話，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好像有點烤焦了？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是因為烤箱溫度沒調好！？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還是因為",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在最後塗太多奶油了！？　",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗚嗚……",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了不輸給夢裡的自己，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我都鼓起勇氣行動了……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "早知道會這樣，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就不該把磅蛋糕拿出來的……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？　",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_060"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n蛋糕有點烤焦了，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可能不是那麼好吃，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你不吃也沒關係的……！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……！？",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_061"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "無論是夢境",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_062"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是現實……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n{player}大人總是",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "溫柔地包容著我呢……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……{player}大人能滿意",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是太好了。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n明年的聖誕節，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我可要做出",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n讓你大吃一驚的完美蛋糕喔。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好啦，",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們回到大家身邊吧！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還沒有交換禮物，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "派對",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在才正要進入重頭戲呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──兩人回到了熱鬧的派對。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n派對會場中，\n參加者們的歡笑聲不曾停歇。"
    }
]