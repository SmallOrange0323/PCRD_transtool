        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人吧？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n居然在這裡遇見你，真巧呢！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我現在",
        "unit_id": 103231,
        "voice": "vo_adv_1144004_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正要去一個聖誕派對。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n{player}大人",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在這裡做什麼呢？",
        "unit_id": 103231
