    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總、",
        "unit_id": 114411,
        "voice": "vo_adv_1144004_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總覺得{player}大人，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好像在發光……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呀，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呀啊啊啊！",
