        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣一來{player}大人，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不就沒辦法享受聖誕節了……",
