    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我好像有點能體會咲戀那種焦躁不安的心情了……！　",
        "unit_id": 114411
