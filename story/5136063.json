[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "人們在蘭德索爾的街道上穿梭不止。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而大吾的身影也在人群之中。"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘖……",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_000"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這一帶",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "也比想像中要來得平靜啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "如果再更亂一點，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "就不缺打架對象了。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "看來是騎士團還是誰把這邊控管得很好啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不過，",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_001"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "找不到打發時間的對手也沒辦法。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n那就沒理由再繼續待在──",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喂──",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大骨～！！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是大吾！！",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_003"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我還以為是誰，結果是妳啊！",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_004"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n妳在這種地方做啥？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我正在跟人介紹蘭德索爾的街道哦──！",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_005"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "哦，",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_006"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "還是老樣子在幫助人啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n雖然不知道妳是在跟誰做介紹──",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎呀呀，",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n要好好地叫出人家的名字才行哦～？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這個人不叫大骨，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是大酷才對吧♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "都說了我叫大吾啊──！！",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱歉抱歉！！",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n照著平時對話的感覺就不小心這麼說了♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈哈哈！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊，",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉果然也認識啊？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "認識太吾。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "算是啦♪",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_011"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "為什麼麻煩的傢伙變多了啊……！！",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_012"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "聽好了！！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n本大爺的名字叫大吾，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "大",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "吾！！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不對，",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_013"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那種事一點都不重要。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……妳是何方神聖？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我一看就知道了。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳很強對吧。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯──還滿強的？",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "如果想知道我的真實身分……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n就等比出個高下之後",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "再說吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "正合我意。",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_015"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n雖然我對妳的真實身分沒什麼興趣……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n不過有架可打",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "那就行了！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我想想～",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我的真實身分說來話長，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n首先要從世界的構成開始……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "結果還是要說啊！",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_017"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這個我行我素的女人是怎麼回事！！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "來自「複製品世界」的另一個自己，",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_018"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是嗎。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "老實說聽起來超級可疑的……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎──一時之間很難以相信對吧？",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟我",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "感覺比日和更像大姐姐嘛？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "才沒有咧。",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_020"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "這樣一看就能明白了。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "即使乍看之下不一樣，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但是在氛圍之類的",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n本質部分有種相似感啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是說啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我一開始也嚇了一跳……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但是很快就和她變得要好了♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們很意氣相投嘛──♪",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "當然囉？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我是比較成熟的姐姐呢～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦～",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉也表現得很興奮耶？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就像剛才，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳整個人都黏在了攤販前面！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不不，",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_024"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "到處吃美食是旅行的醍醐味吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n不去在意熱量和預算那些，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n稍～微放縱一下……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "的感覺？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是這點，",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種寬以待己的地方！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個樣子",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺不成熟，反倒很孩子氣哦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好痛痛痛！",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_026"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這句話狠狠地戳到了姐姐我的痛處……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……所以說",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_027"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳們到底是來幹嘛的啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "不是找我有事嗎……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和，",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_028"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳聽好囉？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "能夠寬以待己，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n也是大人的特點哦？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這個",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是千真萬確的！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦──",
        "unit_id": 100111,
        "voice": "vo_adv_5136063_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我怎麼感覺",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉的臉上常常沾著食物醬汁之類東西……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好痛痛痛！",
        "unit_id": 135512,
        "voice": "vo_adv_5136063_030"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n其實這也是痛處之一啊……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……啊──",
        "unit_id": 190711,
        "voice": "vo_adv_5136063_031"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我差不多該走了。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n妳們好好相處啊。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "埃拉、日和",
        "words": "等一下啦大門！！",
        "unit_id": 1,
        "voice": "vo_adv_5136063_032"
    },
    {
        "type": "dialogue",
        "name": "大吾",
