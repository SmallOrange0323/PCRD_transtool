[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蕾琪塔為了讓腦袋冷靜一下一個人在街上散步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在這時候，有個壞消息傳進了她的耳裡。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊～真是受不了！",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "怎麼會變成這樣！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我不祥的預感果然應驗了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "訂購的高級起司竟然出了差錯！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "早知道就不該特地去向國外的知名品牌下訂單……",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不僅運送過程出了意外，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還搞錯數量……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可沒聽說壞事會接踵而來啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要現在過去取貨嗎……？",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還是要用高價把市場上的貨全部買下來……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不管哪個方法都來不及吧……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話雖如此，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也想不到要去哪裡才找得到那種等級的起司……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大姐大姐，",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳在為起司煩惱嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "既然如此，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要不要試試看我們家的起司呀？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……抱歉，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我現在可沒時間陪小孩玩",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n店家扮家家酒。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我在趕時間，失陪了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等一下！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我已經是出色的大人了啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且，我還是【牧場】公會的公會長啊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我今天是來賣我們牧場最受歡迎的起司的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這麼說的話，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳是想向我推銷自己家的產品是吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我確實也可以更改活動方向，主打自產自銷，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n如此一來，當地產的普通起司也不是不可行……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果是街上店家叫貨也就算了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳的商品究竟合不合乎我的聖誕節活動的標準，我對此抱持著很大的疑問。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "若不是送禮或高級料理用的那種等級就沒有意義了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不相信的話，就試吃看看吧。",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n大姐只要吃過之後就絕對會愛上的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來吧來吧，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "請用請用！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "反正我也是為了轉換心情才到街上來的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我就稍微奉陪一下吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這這這這是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "她露出了好可怕的表情啦……",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n難道……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞砸了嗎……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難不成",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的牧場又要被沒收了嗎……！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒想到在蘭德索爾就有如此美味的起司……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "關於【牧場】的起司，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我本以為只是那些討人厭的貴族在那邊起鬨而已，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是我太小看它了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "調查的不夠徹底……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……妳，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "叫什麼名字？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我叫真陽啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "拜託，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原諒我吧！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n唯獨放過牧場",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有我這條",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小命啦……！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼？",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……妳在說什麼啊？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真陽小姐，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請妳務必要將妳們家的起司賣給我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n讓我用在下次的聖誕節活動上。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的嗎！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "當然沒問題啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……咦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "賣給妳……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n直到剛才",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳不是還皺著眉頭的嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那是我在對自己的無知感到羞恥。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "很抱歉，我以為妳是可疑的旅行商人，所以小看妳了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "事不宜遲，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以立刻跟妳商量進貨的相關事宜嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔？",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "平時的話……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大概是這個價錢啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啥啊啊啊啊啊啊？",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳是在我耍我嗎！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦，",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我做了什麼壞事嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對啊，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "壞到不行，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "壞透了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然把如此高品質的起司，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n用那種低廉的價格賣出去，簡直是腦袋有問題！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是這樣嗎……？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我想要以便宜的價格，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓更多人能夠",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "享用到美味的食物，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n讓大家都露出滿足的笑容啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說的我都理解，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也認為那是個很了不起的志向。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要做出這麼棒的起司，勢必得花上不少時間和金錢才對。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果妳今後也想繼續提供好吃的起司給大家，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n最好趁能賺錢的時候多賺一點。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一味的賤價售出",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對支持妳的客人也很失禮。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "即使價格稍微貴一點也願意買。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳身邊",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "應該有客人抱持這種想法的吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是啊。",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大姐說得很有道理啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我們才剛認識不久，",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但我從妳無欲無求的樣子來看，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算大賺了一筆，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳也肯定不會胡亂揮霍吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那是當然！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不是抱著那種心態在做起司的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此，多賺的錢",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就拿去投資設備或發獎金給夥伴吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如此一來，就會產生好的循環，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "到最後也一定會回饋到客人身上。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大、",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大姐，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好厲害的啦……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "從來沒想到那麼遠過……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "商人會有這樣的考量是理所當然的。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n販售方法就交給我來想吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳只要",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "專心做出美味的起司就可以了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我知道了！",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我相信大姐啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "麻煩妳了！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說起來",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還不知道大姐叫什麼名字啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "抱歉介紹晚了。",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我叫克蕾琪塔。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我是擔任蘭德索爾的行政長官的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾琪塔‧凱許。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好好記清楚囉，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真陽小姐。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "克蕾琪塔……",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那就是克蕾克蕾囉！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "再次跟妳說聲請多指教了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "克蕾克蕾！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾克蕾！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "突然就幫人家取綽號，妳的距離感也太奇怪了吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾克蕾的發音",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "聽起來好像我很可憐一樣！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在馬上換掉！",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n否則",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可能要重新考慮一下我們之間的合作關係了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "請等一下起司！",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難得我們有這份起司之緣，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為是透過起司牽起的緣分，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以今後也請",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "多多起司牽絲啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咿咿咿！",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好冷、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在太冷了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "冷到冷笑話都要涼了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔，",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "克蕾克蕾也很不錯嘛？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才、",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才不是！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我只是不小心被妳影響……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是說，",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要不要和我一起組一個搞笑團體啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們外表上看起來也很像一對互補的好搭檔！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我絕對拒絕！",
        "unit_id": 118011,
        "voice": "vo_adv_5132062_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "談判破裂、談判破裂！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n聽妳說胡話聽得談判都糊了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n怎麼搞得好像是相聲的結尾一樣！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈！",
        "unit_id": 103311,
        "voice": "vo_adv_5132062_043"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "克蕾克蕾果然很有搞笑的才華呢！",
        "unit_id": 103311
    }
]