    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位――！",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n謝謝大家今天",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來參加我們【慈樂之音】的聖誕演唱會～！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "希望今晚",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕老人",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n會到訪各位的家裡～♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "下雪的聖誕節。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【慈樂之音】的聖誕演唱會就在狂熱的氣氛中落幕了。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結束了，",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "辛苦妳了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然妳可能已經聽膩了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過還是請妳接受這個掌聲吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人！",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳覺得我們的演唱會",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼樣！？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很棒喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【慈樂之音】有這麼大的進展，真是太好了……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "非常謝謝！",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希和千歌她們",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也都很感謝製作人。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然這麼說有點突然，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是真的很謝謝妳當我們的製作人！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈。",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為我最討厭無聊了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要是有趣的事，我都願意做。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天可是令人愉悅不已的聖誕節喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然我不是聖誕老人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過能夠為興奮的國民們",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "帶來一些歡樂也不錯……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎呀～",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身本來覺得太吵，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "打算來抱怨個幾句的，\n沒想到",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這個叫做什麼演唱會的東西還挺有看頭的嘛。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n果然聽你的話過來看是對的。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔，",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在那裡。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n剛剛的偶像女孩。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？　",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是迷路的小朋友嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡禁止工作人員以外的人進入喔！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小妹妹。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳叫誰小妹妹阿！",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身可是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統御黑夜之人，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞‧奧恩斯坦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在妾身的眼裡",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們才是小妹妹呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那還真是失敬了。",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲提娜。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "伊莉亞‧奧恩斯坦……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯～",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個名字好像在哪裡聽過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n到底是在哪裡呢……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不，",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的事情不重要。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我們要找的是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那邊那位偶像女孩。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……喂",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有事情要辦就快一點。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦？",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這不是小子嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}！\n你來看",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕演唱會啦！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不。",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你不用道謝啦！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也很希望{player}你來看……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔喔。",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來妳送了他相關人員才有的票啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難怪他能夠在後台出入自如呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真可惜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我本來打算等一下要去修理那群警衛的說……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身只不過是跟在{player}後面",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就自然而然地進來了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然還是要送那群警衛很嚴～厲的處罰當作禮物才行。",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且今天又是聖誕節……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人，",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請手下留情……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是個可怕的聖誕老人啊。",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？　",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼好像，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有什麼奇怪的聲音傳來……？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次又是怎麼了？　",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "鈴鐺的聲音……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家快看！　",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個是……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "馴鹿！？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n馴鹿在天上飛耶！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "後面拉著的該不會是雪橇吧？",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n簡直就像是……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔？　",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來他似乎打算要降落在這裡。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "呵呵呵！",
        "unit_id": 3911,
        "voice": "vo_adv_5029000_029"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n聖誕快樂！　",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "小姐們！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……聖誕",
        "unit_id": 102913,
        "voice": "vo_adv_5029000_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "老人？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身還是第一次親眼看到……",
        "unit_id": 104412,
        "voice": "vo_adv_5029000_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次可是貨真價實的非法入侵。",
        "unit_id": 107111,
        "voice": "vo_adv_5029000_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n給你一點教訓後，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再請你離開這裡。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "望",
