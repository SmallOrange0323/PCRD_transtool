    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果是在故鄉，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我一聽到音樂，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "身體大概就會自然地動起來了，但是……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呃，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_061"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "又是{player}～！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_062"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "以跳舞來說，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個節奏有點太獨特了喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你為什麼要在這種地方演奏啊～！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n附近的人",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也都嚇了一跳喔～！？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……是說，{player}，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_063"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你一直",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "跟在我後面對吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_064"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "像是日頭的光芒啊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還有像苦瓜的東西啊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "以及這段演奏……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你是打算重現",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_065"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "從我這裡聽來的故鄉特色吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我這麼努力想忘掉故鄉的事情，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_066"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你為什麼要讓我想起來啊～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_067"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_068"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原來如此……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n{player}因為喪失記憶，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "什麼都不記得了對吧。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "像是遺忘的痛苦，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_069"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有悲傷，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}都比我",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還要了解這些心情啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "會因為想起故鄉",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_070"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而感到寂寞，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是因為那是很重要……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也是我最喜歡的故鄉。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_071"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為會寂寞，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就勉強自己忘記……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣是不對的吧。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以為了不讓我",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_072"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "忘記故鄉，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n{player}才會那麼努力地為我做了這些事情吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_073"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n{player}的體貼",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "讓我的內心深處都暖起來了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是我在故鄉也不曾感受過，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_074"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "非常奇妙的暖意喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總覺得寂寞的感受",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "漸漸地消散了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_075"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我開始有精神了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得身體",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "蠢蠢欲動的～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n讓人想跳起舞來了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_076"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "把手伸出來～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們一起跳舞吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算會再度感到寂寞，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_077"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n只要能像這樣，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "牽著{player}的手一起跳舞，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n一定就沒問題了……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "用故鄉的諺語來說就是──",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直啦～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_078"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "香織和{player}一起不斷地唱歌跳舞。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她乘著那活潑的節奏，遙想自己最喜歡的故鄉。"
    }
