    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不對～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這道光",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是從哪裡來的……",
