[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}正在蘭德索爾的街道上散步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時，他在來來往往的行人中發現了熟識的身影。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "…………",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……唔嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "果然還是沒辦法恢復平常的活力呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n是因為我沒睡多少嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊……！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨呵～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這聲招呼好有活力喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，男孩子",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣打招呼時，要說「嗨齁」才對喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你就記起來吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以說，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你今天有什麼事嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "正在做【哞哞自衛隊】的巡邏工作喔～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你遇到什麼麻煩了嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可以跟我說說看喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算不是要跟【哞哞自衛隊】商量的事也沒關係，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "畢竟{player}跟我是好朋友啊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n被你看到",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我丟臉的一面了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我的優點就是很有活力，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "被別人看到我消沉的樣子時，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就會覺得很丟臉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你可以不用在意喔～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為這不是什麼大不了的事情，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我馬上就會恢復正常了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你很在意？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為我和{player}是好朋友……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘻嘻，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我講過的台詞",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "被你拿去說了啊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你這麼希望我跟你說嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真的不是什麼大不了的事情喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我啊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "做了一個很懷念的夢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是跟我的……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "故鄉有關的夢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}還記得嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我之前也有提過～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在我",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "無法回到故鄉，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一個人露宿在外時，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "發生了很多事情，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "後來受到了【哞哞自衛隊】的收留喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我想說在找到返回故鄉的方法之前，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就在這座城鎮繼續生活～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是到頭來，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我還是找不到回去的方法～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我沒事的喔～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n因為我在食衣住上都沒有問題，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也有找到工作，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有了重要的夥伴啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但到了最近，",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我突然做了故鄉的夢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就莫名地寂寞起來了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這就是徹頭徹尾的思鄉病吧。",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真不像我的作風呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "希望你能笑著聽過就好～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈……♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n好癢喔……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "很舒服呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n能夠從掌心",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感覺到{player}的溫柔喔……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你怎麼突然做出怪表情～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難道你是想",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "讓我開心起來嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n{player}好溫柔喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "謝謝你這麼擔心我～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為這真的是",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "無可奈何的事情，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你可以不必這麼在意喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "多聽我聊～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你對我的故鄉",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這麼感興趣嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那就包在我身上～！",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我會讓{player}更加了解我的故鄉，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我很希望你能喜歡上那裡～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個嘛～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不管身在哪裡，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在我的故鄉隨時可以看到海，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大海總是閃閃發光的喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "日頭……",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "太陽公公超級耀眼的，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n湛藍的大海就是",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "接受了那道陽光的照耀，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才會閃閃發亮的～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還有很多在這邊看不到的植物，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是非常色彩繽紛的地方喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也有各種稀奇的食物喔～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n可以捕到很多魚，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "受到日頭的恩惠種植出來的蔬菜別有一番風味！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n像苦瓜、豬肋排和鳳梨，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有很多好吃的東西喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "鎮上總是很熱鬧～",
        "unit_id": 101711,
        "voice": "vo_adv_1017009_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要豎耳傾聽，就能聽見三線的聲音，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有會配合那個節奏跳舞的人們……",
