    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這裡是、哪裡……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "明明是沒有看過的風景……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得，好懷念喔……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有人走在前面……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我好像、知道……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個是，我的爸爸和媽媽……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "父母「消失」之後，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我連爸爸和媽媽的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n長相和名字都不記得了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "他們就像打從一開始就不存在一樣，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n從各種紀錄和記憶中不見了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是因為其他所有人都有爸媽……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以，我也應該有爸爸和媽媽才對……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然咲戀媽媽她們，也到處去調查……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是沒有收穫……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n除了我以外，好像也有這樣的人……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個現象被稱作「消失」，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是現在弄得城鎮裡人心惶惶的異變之一……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是，我應該存在的爸爸和媽媽……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我想大概沒辦法和他們見面吧，所以已經放棄了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說不定不是因為「消失」，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這種莫名其妙的超自然現象……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "或許是我的爸媽，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n他們只是不要我了，所以把我丟掉之類的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我因為那樣而傷心，所以把爸媽給忘掉了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就算找到了，說不定就得認清這種討厭的事實……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以，我才沒有積極地去找他們……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且【咲戀育幼院】的大家，都很溫柔……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "明明想說就這樣，一直找不到爸媽也沒關係……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n明明想說就維持現狀就好了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "明明一直假裝自己不在乎的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是我，其實是對自己說謊……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "其實，我真的非常非常想見到他們……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n爸爸……！媽媽……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我好寂寞，好想見到你們……！",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n想要你們看看我、抱抱我、叫叫我的名字……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "爸爸、媽媽，不要離開我……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我沒辦法觸摸到爸爸和媽媽……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼手會透過去……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n他們兩人好像都沒有注意到我……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "他們沉著臉，不知道要走到哪裡去……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "等、等等我……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要走，我在這裡啊！",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "快注意到我，爸爸、媽媽……！",
        "unit_id": 102111
    },
    {
        "type": "background",
        "background": "500121"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "爸、爸……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n媽、媽……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咦、咦？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我睡著了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，哥哥……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那個、我、那個……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對喔，我正在看家……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為哥哥來看我，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以讓哥哥陪我一起玩……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "玩得太開心，然後就累到睡著了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好、好丟臉……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n好像小孩子……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥是看我睡著了，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以把我抱到寢室的床上吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝、謝謝哥哥……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "給哥哥添麻煩了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥是擔心我好像做惡夢才叫醒我的嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、不好意思……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不太記得了，好像是什麼可怕的夢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起，我馬上就忘記夢的內容了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我只記得是很可怕很寂寞，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n而且很悲傷的夢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要摸我的頭嘛……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，說的也是呢……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就只是場夢，沒有必要害怕呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻，做了惡夢就哭了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我真的是，好像小孩子……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可以稍微撒嬌一下嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請緊緊地抱住我……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得，我的身體，在顫抖……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "拜託哥哥，不知道為什麼我非常害怕……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n嘻嘻，哥哥好溫暖……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝哥哥這麼擔心我……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，我沒事了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為【咲戀育幼院】的大家，",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n還有哥哥，都很溫暖……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不是孤單一人……",
        "unit_id": 102111,
        "voice": "vo_adv_1021007_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n身邊的人這麼溫暖，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
