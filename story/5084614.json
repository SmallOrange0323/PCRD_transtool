    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉──",
        "unit_id": 101311,
        "voice": "vo_adv_5084614_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要睡到哪時候呢。{player}。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒辦法和你相見之後，",
        "unit_id": 101311,
        "voice": "vo_adv_5084614_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我就無法集中精神在新魔法的開發上，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n難得買來的漫畫也慢慢堆成小山了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不論是對身為魔法少女還是御宅族的我而言，這都是很嚴重的事態哦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "讓我遭受這種心情的人是你，所以你得好好負起責任。",
        "unit_id": 101311,
        "voice": "vo_adv_5084614_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒錯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "負起責任，和七七香一起……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不行哦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們之間還不是那種關係……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……不小心做了無聊的妄想。",
        "unit_id": 101311,
        "voice": "vo_adv_5084614_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我好像跟不太上這個沒有你的世界呀。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n{player}，Come back！",
        "unit_id": 101311
    }
]