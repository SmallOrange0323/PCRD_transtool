        "words": "難道她是沙灘棒球的女神嗎……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……？",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_070"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他還不投球嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n難不成是",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還需要",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "做什麼準備……？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對了。",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_071"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我記得孩子們在玩球時，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n在打球之前，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都會像這樣做對吧……",
        "unit_id": 113511
    },
    {
        "type": "still",
        "still": "113500201"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "像這樣",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_072"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "用球棒",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "指向空中──",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦……",
        "unit_id": 312,
        "voice": "vo_adv_1135002_073"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那不是……",
        "unit_id": 1,
        "voice": "vo_adv_1135002_074"
    },
    {
        "type": "dialogue",
