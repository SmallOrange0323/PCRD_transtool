        "voice": "vo_adv_1135002_075"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "居……",
        "unit_id": 1,
        "voice": "vo_adv_1135002_076"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "居……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "居然是全壘打預告！？",
        "unit_id": 911,
        "voice": "vo_adv_1135002_077"
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "我的天……",
        "unit_id": 911,
        "voice": "vo_adv_1135002_078"
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "那些光芒，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "\n那個連太陽都為之祝福的身影……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "\n絕對沒錯……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "她是沙灘棒球的……",
        "unit_id": 911,
        "voice": "vo_adv_1135002_079"
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "女神……！",
