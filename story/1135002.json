[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美里跟{player}繼續在沙灘上散步。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那裡",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "聚集了很多人呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n看起來好熱鬧。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "現在正在舉辦沙灘棒球活動！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_001"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n請大家踴躍參加！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哇，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "居然還有這樣的活動。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "其他還有全壘打大賽、",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沙灘搶旗，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟擲遠比賽呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……他們看起來好開心。",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我、",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我有露出想參加的表情嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "其實我平常看大家練習的時候，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n就有點想嘗試看看。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可是，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "當大家都在認真練習時，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也不好說出那種話呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "難得有這個機會，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我想試試看。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "而且，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要是身為顧問",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "卻沒揮過棒的話，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n會有點不好意思。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "達令～！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_006"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你要展現帥氣的一面喔～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好，",
        "unit_id": 312,
        "voice": "vo_adv_1135002_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "交給我吧，甜心！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "咦？",
        "unit_id": 312,
        "voice": "vo_adv_1135002_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我居然揮空了！？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "討厭，",
        "unit_id": 1,
        "voice": "vo_adv_1135002_009"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "達令你振作一點啦～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "好，",
        "unit_id": 1411,
        "voice": "vo_adv_1135002_010"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "接下來換我了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "看好了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "別看爸爸這樣，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "爸爸可是曾經參加過全國大賽的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "好厲害～！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_011"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "爸爸加油！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "哼！",
        "unit_id": 1411,
        "voice": "vo_adv_1135002_012"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "喔喔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "這棒打得不錯……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀呀，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "男性參加者果然很多呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我參加的話",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒問題嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說得也是。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "畢竟是我自己說想試的。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n要是現在退縮的話，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就沒資格當老師了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你要看好囉。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師我",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要上場加油了！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家好！",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我叫美里。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請多多指教！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "咦，",
        "unit_id": 1,
        "voice": "vo_adv_1135002_017"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "那麼可愛的女性要參加？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "\n動作一看就知道是外行人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "就投個好打的球──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "不，",
        "voice": "vo_adv_1135002_018"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "她的眼神非常認真。"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "\n她是帶著決心站上打擊區的。"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "\n要是放水就太失禮了……"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "我會認真投！"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿！",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_019"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "一好球！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "完全沒打到球呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "希望這次能勉強打中。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "兩好球！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唉呀呀，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "又揮空了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家平時",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都是打那麼快的球呢……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是太厲害了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂，",
        "unit_id": 312,
        "voice": "vo_adv_1135002_024"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那位大姐……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n雖然不曉得她有什麼理由，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但她是認真的吧？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1135002_025"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "投手也是知道那點，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n才會盡全力在投。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嘿！",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_026"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "三好球！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_027"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "打者出局！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唉呀呀，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我居然連一次都沒打中。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "三球就出局了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "擊球真的很難呢……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我站上打擊區",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "才知道。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "實際試一次後，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的非常有趣。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "大姐，",
        "unit_id": 312,
        "voice": "vo_adv_1135002_030"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳對沙灘棒球有興趣嗎？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不嫌棄的話，由我來",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "教妳擊球吧～？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "不不不，",
        "unit_id": 1411,
        "voice": "vo_adv_1135002_031"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n這件事就交給曾經參加過全國大賽",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "的我吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "不，",
        "unit_id": 1,
        "voice": "vo_adv_1135002_032"
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "沙灘棒球",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "可不只有擊球。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "\n如何，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "妳要不要",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "投手",
        "words": "來試試投球的部分？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 113511,
        "voice": "vo_adv_1135002_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝大家",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對我",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這麼親切。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "喂，達令！",
        "unit_id": 1,
        "voice": "vo_adv_1135002_034"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "要教也是先教我才對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "甜、",
        "unit_id": 312,
        "voice": "vo_adv_1135002_035"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "甜心……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
