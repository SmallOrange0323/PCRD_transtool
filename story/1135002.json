    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "……我辦不到。",
        "unit_id": 911,
        "voice": "vo_adv_1135002_080"
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "\n我無法對著女神投球……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "\n就當做……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "是我輸了……",
        "unit_id": 911
    },
