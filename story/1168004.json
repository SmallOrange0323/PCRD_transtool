        "name": "珠希",
        "words": "剛才那是什麼夢喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "每次都這樣，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是超神奇的現象喵……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我能夠幫助到{player}，",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這樣是很棒……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過……",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是夢裡的事情，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這次都是受{player}幫助喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是也因此",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_063"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓我學會了很多事情，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n幻影貓的裝備也有所提升了喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我總有一天",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_064"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要讓{player}也目睹我夢中的光景，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n向你報恩喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在那之前，",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "勸你還是別離開我視線比較好喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，「珠希鯛魚燒店」遺憾地閉幕了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不過最後一個鯛魚燒的贈品，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n是張寫著「我還會回來的喵」的信紙。"
    }
]