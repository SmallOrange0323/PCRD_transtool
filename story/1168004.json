    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "離開了呢喵……",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一邊製作玩具，",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一邊還要準備鯛魚燒，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "進貨販售一手包辦……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的是每天都忙翻了喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然是為了重建鯛魚燒工廠而開始做這門生意的，",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但到頭來，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我覺得自己是為了看到那些笑容而努力的喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，也很感謝你這段日子的幫忙喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真不知該怎麼說……",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我總是受到{player}的幫助，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n卻都沒有給你相應的謝禮……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個是……",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我最後要犒賞你的鯛魚燒喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我多放了點料……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼樣喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n看到這麼大一個鯛魚燒，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是不是有點興奮喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……喵？",
        "unit_id": 116811,
        "voice": "vo_adv_1168004_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n為什麼鯛魚燒在發光喵！？",
        "unit_id": 116811
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "看那邊，",
        "unit_id": 1,
        "voice": "vo_adv_1168004_008"
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "好像是外賣鯛魚燒店耶。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "\n哇～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "是店員在公園四處奔走著賣鯛魚燒。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "\n來吃吃看好了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "大姐姐，",
        "unit_id": 1,
        "voice": "vo_adv_1168004_009"
    },
    {
        "type": "dialogue",
        "name": "客人1",
        "words": "我要一份鯛魚燒！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人2",
        "words": "不好意思！",
        "unit_id": 1,
        "voice": "vo_adv_1168004_010"
    },
    {
        "type": "dialogue",
        "name": "客人2",
        "words": "\n待會我們這邊也想買～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好喵！",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我馬上就過去喵！！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵～～～！",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天是一年一度的美食活動，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以比平常忙上許多喵……！　",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不只是等客人上門，",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n而是派出店員到公園裡面四處販售鯛魚燒……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n店長這點子",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "的確是很棒沒錯喵！　",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可是，",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "執行起來很累人喵……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我一直東奔西跑，累死了喵……！　",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "算了，",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "店長說會依銷售額發給我獎金……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我可不能繼續唉聲嘆氣！！　",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "話雖如此……",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一個人兜售真的太操了喵……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "稍微",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "休息一下喵……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵！？",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n為什麼{player}你會跑來喵！？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……什麼？",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是店長要你",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "過來幫我的？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那真是太感謝了喵！！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以，",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，你手上拿的那個是什麼喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n溜冰鞋？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這也是店長給你的喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "原來如此喵。",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n整天跑來跑去太累了，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以要我穿上這個喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "店長說",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要在今天的美食活動",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "拿下銷售第一，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n熱血沸騰喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了獎金，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也加把勁喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……什麼喵？",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n{player}，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼你的表情看起來那麼不安喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你說沒什麼……",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那如果你遇上什麼困難，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就馬上來找我喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好！",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有了溜冰鞋，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "該趕快繼續幹活了喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "先這樣，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}也要加油喵！！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈♪",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n可以用滑的實在太輕鬆喵♪",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "盒子裡的鯛魚燒已經賣光了，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "先回去一趟喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "客人3",
        "words": "欸……",
        "unit_id": 1,
        "voice": "vo_adv_1168004_026"
    },
    {
        "type": "dialogue",
        "name": "客人3",
        "words": "剛才有個男生在樓梯那邊跌倒了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人3",
        "words": "\n不知道他",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人3",
        "words": "有沒有受傷？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人4",
        "words": "他好像不習慣穿溜冰鞋，",
        "unit_id": 1,
        "voice": "vo_adv_1168004_027"
    },
    {
        "type": "dialogue",
        "name": "客人4",
        "words": "\n鯛魚燒全都打翻了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "客人4",
        "words": "\n真可憐……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯喵？",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n該不會是在說那傢伙喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n是在樓梯那邊喵！",
        "unit_id": 104632
    },
    {
        "type": "still",
        "still": "116800401"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "後輩，",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你坐在這種地方",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "做什麼喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我聽說你在樓梯跌倒了……",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "幸好看起來並沒有受傷喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104632,
        "voice": "vo_adv_1168004_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，我還是第一次看見你這麼沮喪喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
