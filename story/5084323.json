        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如此一來，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就只剩一個敵人了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這次輪到我們展現實力了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_5084323_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該輪到在下與雪菲小姐活躍一下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n發揮不輸給凱留小姐努力的表現了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們倆，",
        "unit_id": 106011,
        "voice": "vo_adv_5084323_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好做啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要保護我唷～♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……凱留也真是的，",
        "unit_id": 106411,
        "voice": "vo_adv_5084323_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "簡直當自己是公主殿下了哪。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_5084323_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下與雪菲小姐身為騎士，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可要好好守護凱留公主殿下呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎呀，",
        "unit_id": 106011,
        "voice": "vo_adv_5084323_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這話讓人聽了心情很好嘛……♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留",
        "unit_id": 106411,
        "voice": "vo_adv_5084323_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有時候也是挺孩子氣的呢……",
        "unit_id": 106411
    },
    {
