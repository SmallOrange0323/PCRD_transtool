    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "瞪著這裡……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳是在怕什麼啊。",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別把膽怯寫在臉上。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "抬頭挺胸避免被人小看。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以【王宮騎士團】派出的和平大使身分登場。",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是克莉絲提娜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "請多指教。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我、",
        "unit_id": 100512,
        "voice": "vo_adv_5104001_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我是同為",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "【王宮騎士團】的茉莉！\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請多指教！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……我有聽說王宮會派大使過來，",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n卻偏偏是傳聞中的副團長前來啊。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "居然知道我，真是光榮呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是前副團長，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若是你能改變一下認知就幫大忙了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "這可真是失禮了。",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_036"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "「前」副團長閣下。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "我是負責主持這場會議的老虎族族長。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "你們的名號就連蘭德索爾外都聽過。",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_037"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "對我們",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "獸人族來說非常熟悉呢。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咿……！？",
        "unit_id": 100512,
        "voice": "vo_adv_5104001_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n總、",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總覺得",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有股很強的氣勢……！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "那麼，",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_039"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n為何【王宮騎士團】的成員會出現在這裡？",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "這是為了決定獸人族未來的會議。",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_040"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n沒理由讓你們參加，",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "請離席。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好啦，別這樣講嘛。",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不會說過去的事就讓它過去，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我們可以向著未來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "積極溝通吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "……至今為止不斷欺壓獸人族，",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_042"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "\n現在卻來跟我們談和平，",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "實在太可笑了。",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啥？",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這傢伙",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是誰啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "我是老虎族族長的副手，",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_044"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "\n與族長一同來參加本次的首領會議。",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "真要說起來，",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_045"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "我們會在蘭德索爾舉辦首領會議，",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "\n只是為了正式向王宮表明抗議罷了。",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "什麼不提偏偏提和平這種",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_046"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "莫名其妙的事……",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "族",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_047"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "長，",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "請務必多加留心，",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "\n他們說不定是打算讓我們大意，",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "好藉機暗算各族要人。",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請等一下！",
        "unit_id": 100512,
        "voice": "vo_adv_5104001_048"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我們真的是來與",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "獸人族談和平的！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "這種話怎能相信。",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_049"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "\n",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "誰知道",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "什麼時候會被",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "那隻狂犬攻擊啊！",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔……",
        "unit_id": 100512,
        "voice": "vo_adv_5104001_050"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "確、",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "確實如果是阿姨……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不、",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不對！",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有這種事……",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "吧？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "身為族長副手，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來你是有能力正確評價對手的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跟一些蠢貨截然不同。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "等等，",
        "unit_id": 100512,
        "voice": "vo_adv_5104001_052"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克莉絲提娜阿姨！？",
        "unit_id": 100512
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "你們的那種態度，",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_053"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n就是在看不起我們。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "從過去一路累積的憤怒及因緣……",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_054"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "那對",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "每個種族來說意義都不同。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "會將其混為一談說出和平這種傻話，",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_055"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "\n現階段我們根本沒什麼好談的。",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "人族這是在小看我們嗎？",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "確實，",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被當成是發言傲慢也沒辦法呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然你都這麼說了，",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們也得好好展現才行。\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所謂真正的誠意。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "妳說誠意……？",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_058"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "怎麼，",
        "unit_id": 8711,
        "voice": "vo_adv_5104001_059"
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "妳是要向我們低頭謝罪嗎？",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "\n",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "我們的恨可沒有廉價到妳一個人低頭",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "輔佐",
        "words": "就能既往不──",
        "unit_id": 8711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人們害怕無法理解的事情。",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們過去被",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "歷史性的斷絕隔開，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一路互相憎恨。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雙方都對那道牆壁對面的人幾乎一無所知，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "或許、",
        "unit_id": 8611,
        "voice": "vo_adv_5104001_061"
    },
    {
        "type": "dialogue",
        "name": "老虎族族長",
        "words": "是這樣沒錯……",
        "unit_id": 8611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼，",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們該做的事情只有一個。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n靠著理解對方",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來消除恐怖。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以──",
        "unit_id": 107111,
        "voice": "vo_adv_5104001_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "獸人族和人族，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓我們為了互相理解，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "進行異文化交流吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
