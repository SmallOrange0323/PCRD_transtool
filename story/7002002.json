        "words": "並不是第一次",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "來這座塔對吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n之前有和誰來過了？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "【哞哞自衛隊】的兩個人，",
        "unit_id": 102211,
        "voice": "vo_adv_7002002_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還有【破曉之星】的……？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嘿。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "原來如此。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你，",
        "unit_id": 102211,
        "voice": "vo_adv_7002002_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還真的是認識了不少女性朋友呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "並、",
        "unit_id": 102211,
        "voice": "vo_adv_7002002_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "並不是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說這有什麼不對的地方哦？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然沒有想說什麼……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "唔唔～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里，",
        "unit_id": 100611,
        "voice": "vo_adv_7002002_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要是能成為哥哥第一次一起來的對象就好了～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊也是這麼想的對吧？",
        "unit_id": 100611,
        "voice": "vo_adv_7002002_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要是能先和我們說一聲就好了！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是啊……",
        "unit_id": 102211,
        "voice": "vo_adv_7002002_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哎、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦！？　",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才不是呢！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才沒有那麼想呢！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 102211,
        "voice": "vo_adv_7002002_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你想和誰一起去哪裡",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是你的自由！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也沒有對你說三道四的權利！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦～？　",
        "unit_id": 100611,
        "voice": "vo_adv_7002002_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然可能沒有權利，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但是傳達自己的心意",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是個人的自由對吧？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔唔～",
        "unit_id": 100611,
        "voice": "vo_adv_7002002_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "剛才還真是可惜啊～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "比之前更有進展了呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "按這個步調繼續下去……",
        "unit_id": 100611,
        "voice": "vo_adv_7002002_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是相當期待哦～♪",
        "unit_id": 100611
    },
    {
