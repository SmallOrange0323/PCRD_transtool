[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依里和{player}正被魔物追趕著。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為什麼會有魔物啊！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都是你不好！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n說什麼採到比較多四葉幸運草的人就贏了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n把我帶到這種地方來！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？你也不知道有這種魔物在？",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣啊。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那就原諒你――",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不對，就算我原諒你，",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n現在的狀況也不會好轉啦！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "趕快逃吧！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n回到城鎮的話，牠就不會追來了吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……對了！比賽的內容也調整一下吧。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "先逃到城鎮的人就贏了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n預備，開始！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "………………",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_007"
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼、",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "太好了！是我贏了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊啊，好累啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n想不到會出現那麼強的魔物……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呵呵，也是呢。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n雖然嚇了一跳，但意外地很開心。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要道歉啦。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你又沒有錯。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n也不是故意的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過全力跑過之後，有些口渴呢。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而且肚子也餓了，我們要不要去哪吃頓飯啊？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣的話前面有間餐廳，我們就去那邊吧。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "………………",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦！？仔細想想，",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n兩個人一起吃飯……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像約會一樣呢！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、不，等等！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n先不管約會還是吃飯的事情，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天的我好像很自然地在說話！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不久之前我還總是會覺得害羞……",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n現在好像變得可以滿輕鬆地交談了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說回來，最近好像也不會覺得",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n羨慕茜里了呢～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……欸？我在說什麼？",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "討厭，我講出聲音來了嗎！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "其實也沒什麼……",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因為我妹妹茜里有很多朋友，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n以前我總是很羨慕她……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過和你說話的時候很開心，",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然和其他人還沒辦法這樣交談……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但既然已經可以和你開心聊天，感覺好像也夠了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在已經不用拜託伊莉亞，",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n幫我改掉怕生或許也沒關係了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，哥哥，終於找到你了～",
        "unit_id": 100611,
        "voice": "vo_adv_1022006_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真是的！我找好久耶！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "原來和姊姊在一起啊。",
        "unit_id": 100611,
        "voice": "vo_adv_1022006_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那下次要不要和茜里兩個人，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n一起做些快樂的事呀？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我開玩笑的♪　",
        "unit_id": 100611,
        "voice": "vo_adv_1022006_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊哈哈，哥哥臉紅了，真可愛～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "搞、搞、搞什麼……！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n兩個人自己在那耍親密……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……等、",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等一下！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這傢伙正要和我去吃飯呀！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "原來是這樣啊。",
        "unit_id": 100611,
        "voice": "vo_adv_1022006_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……咦？可是姊姊妳，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不是不擅長和哥哥相處嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在家的時候也老是抱怨哥哥不是嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1022006_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n感覺一起去吃飯也不會開心吧……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "才、才沒有那種事！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我、我對……{player}……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸……",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_032"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可惡！為什麼我說不出話來！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n剛剛明明還很正常的！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚……嗚……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊妳怎麼了！？",
        "unit_id": 100611,
        "voice": "vo_adv_1022006_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為、為什麼哭了！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒事嗚……",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_036"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我沒事……嗚……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇、哇，你在做什麼啊……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我、我已經不是小孩子了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "～～～～～～！！",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……我還是想改善怕生這一點。",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n接下來要更努力進行公會活動！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "實現這個願望，然後――",
        "unit_id": 102211,
        "voice": "vo_adv_1022006_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n向{player}率直地說出我的感受！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然依里對公會活動燃起熊熊鬥志，\n但她不知道其他公會成員的活動目的，\n正好也是{player}……"
    }
]