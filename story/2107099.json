    {
        "type": "dialogue",
        "name": "旁白",
        "words": "謀反失敗的豪紳「前」議長"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被關進了蘭德索爾的地牢中。"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "…………",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_000"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_001"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_002"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "囌囌……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……唔唔！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_003"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "嗚嗯嗯嗯……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "怎、",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_004"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "怎麼會有這麼難喝的湯……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這種東西",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不是給人類吃的食物！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "喂！",
        "unit_id": 711,
        "voice": "vo_adv_2107099_005"
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "\n少在那裡嫌東嫌西的，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "你這逆賊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "你、",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_006"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "你這傢伙！？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n不過是區區一介擔任獄卒的士兵，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n膽敢對吾輩",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "口氣這麼大……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "吵死了！",
        "unit_id": 711,
        "voice": "vo_adv_2107099_007"
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "\n就算你原本是有權有勢的貴族，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "\n現在也只不過是個囚犯而已啊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔、",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_008"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔唔唔……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "膽敢把吾輩",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_009"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "關進這種充滿霉味又骯髒的地方……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n不可饒恕，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不可饒恕啊，尤絲蒂亞娜……！　",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "但是……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_010"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "今後吾輩會怎麼樣呢？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "會被審問嗎……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "或是……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "被處刑嗎……？　",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾輩居然會……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_011"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "被處刑！？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "這種事",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是不可以發生的！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n不可以發生的……！　",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "咳！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_012"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "欸，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那邊的傢伙……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不對，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "先生！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "啊啊？",
        "unit_id": 711,
        "voice": "vo_adv_2107099_013"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "你……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_014"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "你有沒有",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "什麼想要的東西啊？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n財產、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "地位、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "權力……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾輩什麼都可以給你。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n……只要你",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "把吾輩放出這裡……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "少囉嗦！",
        "unit_id": 711,
        "voice": "vo_adv_2107099_015"
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "\n我是不會背叛公主和純團長的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "嗚……！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_016"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n為、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "為什麼！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n為什麼要順從像那樣的小姑娘們……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "因為她們",
        "unit_id": 711,
        "voice": "vo_adv_2107099_017"
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "為了保護蘭德索爾，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "拚了命在努力啊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "\n和你們這些利慾薰心的",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "獄卒",
        "words": "貴族可不一樣──",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……！？",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_018"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "什麼……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_019"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n發生了什麼事……？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n那個獄卒，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "究竟",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "上哪去了……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "誰知道──",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不曉得他究竟是上哪裡去了呢？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "──咿！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你好啊，",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "豪紳先生。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "拯、",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_023"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "拯、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "「拯救者」大人……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n為什麼您會在這裡……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n您該不會是打算",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "要把吾輩滅口吧！？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請放過吾輩！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_024"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請您放過吾輩吧！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n吾輩還沒有",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "說出任何關於您的情報！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n今後也絕不會",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "說出口的……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀，",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是這樣子嗎？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我還以為",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在對方問你之前，你就會自己全部說出口了。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對我而言，不管你有沒有說，其實都是無所謂的。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我只是……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有點",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為你感到悲哀。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要是我不伸出援手……",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你可能就得一輩子",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都待在這監獄裡度過，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這樣實在是",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太過可憐了。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "喔、",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_028"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "喔喔……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n那麼……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒錯，",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我之所以會來這裡……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是為了拯救你呀，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "豪紳先生。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "太感謝您了，",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_030"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "「拯救者」大人！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n吾輩一定會",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "顛覆蘭德索爾王家，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "向那個小姑娘復仇的！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "只要能",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "借助您的力量，一定可以……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……唔嗯，",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這麼說起來，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我之前是那麼說的呢。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……？",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_032"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n毀滅蘭德索爾王家，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n並取得塔的管轄權，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "不正是我們的目的嗎……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──索爾之塔",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真正意義上的「管轄權」，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n並非是",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人類能夠藉由政治來左右的。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對「偶像」進行調整，",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "順從「神諭」，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "並且",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "侵蝕「塔」。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n──為了不被輪迴之圓環所吞沒，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "過程必須非常慎重。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我是因此，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "才會如此忙碌……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那……",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_035"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那麼，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "為什麼？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "前陛下被打倒之後……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您為什麼",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "會來找上吾輩呢？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "為什麼您要威脅其他貴族，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "將吾輩",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "拱為議長呢……？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵。",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n關於這點──",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然無須向你說明原因，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但我想想……",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「因為你的個性很扭曲」，",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就姑且這樣向你解釋好了。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您、",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_038"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "您要做什麼……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "咿",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你問我",
        "unit_id": 192612,
        "voice": "vo_adv_2107099_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要做什麼？",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n正如我剛才所說──",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我會拯救你的，",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "豪紳先生。",
        "unit_id": 192612
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_040"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n住、",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "住手……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請您住手啊……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "請您住手啊！",
        "unit_id": 191411,
        "voice": "vo_adv_2107099_041"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "彌勒大人────",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "…………",
        "unit_id": 192611,
        "voice": "vo_adv_2107099_042"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "請你安息吧──",
        "unit_id": 192611,
        "voice": "vo_adv_2107099_043"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "豪紳先生。",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "在「神」完全甦醒之前，",
        "unit_id": 192611,
        "voice": "vo_adv_2107099_044"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n無須見到即將到來的地獄便消失的你──",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "毫無疑問地，",
        "unit_id": 192611
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "已經受到了拯救呀。",
        "unit_id": 192611
    },
    {
        "type": "background",
        "background": "500163"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而另一方面，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在某個遠離蘭德索爾的海邊──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……海邊",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n早知道我要特地前來這種地方，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n應該要帶泳裝來的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話雖如此，",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一個人泡海水浴",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該也是無聊至極吧……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說──",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那邊的傢伙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳要不要和寂寞到不行的克莉絲提娜大人",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一起玩玩啊？",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "210709901"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦？",
        "unit_id": 192011,
        "voice": "vo_adv_2107099_050"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n妳該不會是……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在對我",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "說話嗎？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡也沒有其他人了吧。",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算有別的人在，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也只會對妳搭話啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "哇啊～",
        "unit_id": 192011,
        "voice": "vo_adv_2107099_052"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是熱情♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "難道說，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "妳是想挖角我當偶像",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之類的嗎？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真令人傷腦筋呢～★",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果妳有這個打算，",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要我讓妳參加徵選也不是不行，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的審查可會有點嚴厲喔？",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n【憤怒‧軍團】。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊哈★",
        "unit_id": 192011,
        "voice": "vo_adv_2107099_055"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n原來已經被發現了呀～♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別裝傻了。",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n明明是妳放出了情報，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把我引誘來這裡的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "妳說的",
        "unit_id": 192011,
        "voice": "vo_adv_2107099_057"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是沒有錯啦～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "唔～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "反觀迷宮女王，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n都不太會對明目張膽的情報做出反應呢～",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原來妳的目標是拉比林斯達啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過抱歉啦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳現在只能先滿足於我了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然沒有觀眾，稍微欠缺了熱烈氣氛──",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但飛濺的海水反射著光芒，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以舞台來說並不壞。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們開始舉行宴會吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "咦～～～",
        "unit_id": 192011,
        "voice": "vo_adv_2107099_060"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我現在",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "正在度假中欸──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了……",
        "unit_id": 107111,
        "voice": "vo_adv_2107099_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以我的角度來說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我也自認沒有不懂禮節到",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會砍向身穿泳衣的對手。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我只等妳五分鐘，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳去換個衣服做準備吧。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……再來到另一方面，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在深夜無人的王宮之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似似花的本體坐在王座上，\n靜靜地微笑著。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呵呵。",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_063"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真那所設置的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個王座，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n坐起來",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是一樣舒服呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_064"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……模索路晶。",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_065"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為她這個人很難應付……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先前共享情報的時候，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我還以為她多少有撒謊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是就她離開街道後的去向看來，",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看樣子她真的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n並不是以搜索米奈娃為最優先呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是真是如此……",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_067"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就太不符合妳的作風了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我只能說妳實在太過愚昧了，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晶。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正巧",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_068"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如妳自己所推測的一樣，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要是就這樣回歸「現實」……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等待著我們這些《阿斯特朗傳奇》",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n開發者的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就只有世人非議，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以及司法究責吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然在「現實」那一側，",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_069"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們一樣持有遠遠超乎常人的能力……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但如果說",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要與政府及國際組織全面為敵，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "情勢還是太過不利了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要能夠將超級AI米奈娃",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_070"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "化為囊中物，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不只在阿斯特朗……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就連在「現實」那一側，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們也將獲得絕對的力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "操縱媒體和社群網站，",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_071"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或從政府機關中",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "刪除七冠的相關資料，這點程度……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對米奈娃而言，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可說是輕而易舉吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不僅如此──",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要操弄虛擬貨幣，",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就能獲得無窮的資產。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要支配通訊設備，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就能獲得無限的情報。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要控制自動兵器，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就能獲得無敵的軍隊……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這些全部",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都將歸米奈娃所有。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在網路極高度發展的「現實」世界當中，",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n米奈娃比核子武器還要強大且危險……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以說是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "近似於「不具有意識的神」一般。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "擁有此等力量的存在，",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_074"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n必須由身持堅強意志的人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "來正確地進行管理。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n比如說",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就像是──",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我這樣的人……",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_075"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵……",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_076"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就如這王座──",
        "unit_id": 107011,
        "voice": "vo_adv_2107099_077"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "蘭德索爾的實權一般，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n米奈娃也必定",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會成為我的囊中之物。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而且，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "{player}也會……",
        "unit_id": 107011
    },
