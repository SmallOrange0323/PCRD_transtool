        "voice": "vo_adv_2107099_079"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n這究竟是……！！？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "謎之少女們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2107099_080"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "妳們這些人！",
        "unit_id": 191011,
        "voice": "vo_adv_2107099_081"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n快放開我的主人！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "謎之少女們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2107099_082"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "妳們無意回答我的問題是嗎。",
        "unit_id": 191011,
        "voice": "vo_adv_2107099_083"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "既然如此，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我只好訴諸於這把劍了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "──喔喔喔喔喔！",
        "unit_id": 191011,
        "voice": "vo_adv_2107099_084"
    },
