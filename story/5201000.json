    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "她對我們的聲音有反應……？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這就表示",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "有人在裡面……！　",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那邊的傢伙，",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_070"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n是妳奪走了那個身體吧？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "雖然那不是",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_071"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我的身體，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "但我們可要請妳回答妳這麼做的意圖！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n還有",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這個城鎮的異狀也是！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "兩者之間應該不會沒關係吧？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 52711,
        "voice": "vo_adv_5201000_072"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "她剛剛",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_073"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "看著我……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "笑了？　",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──",
        "unit_id": 52711,
        "voice": "vo_adv_5201000_074"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……！",
        "unit_id": 52711
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這是……！？",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_075"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n為什麼妳……！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "等一下！",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_076"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n妳到底──！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與陌生樣貌的「愛梅斯」邂逅。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隨後，{player}和菲歐便被光芒籠罩。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對{player}而言，這道光有股熟悉的感覺。"
    },
