[
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──那是發生於過去，",
        "unit_id": 1,
        "voice": "vo_adv_5201000_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "確實存在過的記憶。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你終於醒來了！",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_001"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我是妖精菲歐。",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_002"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n我會告訴你阿斯特朗的各種事，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "所以你要仔細聽喔！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "某個少年",
        "unit_id": 1,
        "voice": "vo_adv_5201000_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "被帶到了未知的世界，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n並與一名嚮導小妖精",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一同踏上冒險。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我希望少年你",
        "unit_id": 106831,
        "voice": "vo_adv_5201000_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "代替我在阿斯特朗做些事。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "把打倒各區域Boss後所獲得的魔珠收集起來，",
        "unit_id": 106831,
        "voice": "vo_adv_5201000_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "前往塔的最上層。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n這就是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "遊戲的破關條件。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這麼做的目的是",
        "unit_id": 1,
        "voice": "vo_adv_5201000_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "破關《阿斯特朗傳奇》，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n也就是引導公主前往索爾之塔的塔頂，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "並實現她的願望。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n他",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在這趟旅程中──",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "──這樣啊！",
        "unit_id": 107111,
        "voice": "vo_adv_5201000_007"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n原來你就是晶的公主騎士！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "你就叫我「誓約女君」吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "遭遇眾多強敵。",
        "unit_id": 1,
        "voice": "vo_adv_5201000_008"
    },
    {
        "type": "background",
        "background": "501650"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "我不會再有所保留了。",
        "unit_id": 107011,
        "voice": "vo_adv_5201000_009"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n一定會在這裡",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "打倒你們，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n以我的全力──！",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "跨越諸多苦難。",
        "unit_id": 1,
        "voice": "vo_adv_5201000_010"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "……我相信",
        "unit_id": 107311,
        "voice": "vo_adv_5201000_011"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "你們。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "立於無數願望之上。",
        "unit_id": 1,
        "voice": "vo_adv_5201000_012"
    },
    {
        "type": "background",
        "background": "500230"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "初次見面。",
        "unit_id": 106911,
        "voice": "vo_adv_5201000_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n晶的公主騎士……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的名字是",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "霸瞳皇帝……",
        "unit_id": 106911
    },
    {
        "type": "background",
        "background": "501650"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "──騙人。",
        "unit_id": 106912,
        "voice": "vo_adv_5201000_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這是騙人的吧。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "怎麼可能有這種事！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的願望是",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "創造新世界，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓一切都按照我的意思……",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "少年在最終",
        "unit_id": 1,
        "voice": "vo_adv_5201000_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "獲得了太陽與星星的祝福。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "──歡迎你們",
        "unit_id": 191112,
        "voice": "vo_adv_5201000_016"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "來到索爾之塔。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n跨越諸多試煉而來的",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "勇敢冒險者啊，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n很高興",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "能見到你們。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "……認證完成。",
        "unit_id": 191112,
        "voice": "vo_adv_5201000_017"
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "我認可妳是公主。",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "\n現在，",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "公主連結程序",
        "unit_id": 191112
    },
    {
        "type": "dialogue",
        "name": "米奈娃",
        "words": "即將開始執行……",
        "unit_id": 191112
    },
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那曾經走過，",
        "unit_id": 1,
        "voice": "vo_adv_5201000_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "卻失去了的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「過去」──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──喂！",
        "unit_id": 1,
        "voice": "vo_adv_5201000_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你快醒醒啦！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你終於醒來了！",
        "unit_id": 1,
        "voice": "vo_adv_5201000_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唉，",
        "unit_id": 1,
        "voice": "vo_adv_5201000_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你在看哪裡啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這邊啦、這邊啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n把你的視線再往下移一點！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_022"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "早安。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你該不會是在想「我難道還在夢裡」吧？",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_023"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n這既不是你做的夢，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "也不是我讓你做的夢喔。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你好像意識還不是很清楚。",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_024"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真拿你沒辦法，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "姑且讓我確認一下吧。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你知道我是誰嗎？",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_025"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "嗯，",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_026"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "很好。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "看來你還記得──",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "還擁有關於我的記憶呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……呵呵♪",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_027"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你睡迷糊了嗎？",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_028"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n還是說，其實妖精在你眼中看起來都長一樣？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "現在對你惡作劇一下，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "讓那傢伙背黑鍋好像也不錯呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我說你啊……",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_029"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "算了，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這也不能怪你。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那麼，首先就來自我介紹吧。",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_030"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我是菲歐，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n曾經存在於",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "《阿斯特朗傳奇》",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "的嚮導小妖精。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "也有人稱呼為嚮導妖精，",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_031"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不過反正沒什麼很大的差別。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "因為種種原因，嚮導小妖精幾乎都被消除了，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "但我和涅比亞想辦法存活下來了。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這是我原本的模樣。",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_032"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你平時見到的「愛梅斯」，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是我們嚮導小妖精的",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "原型……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "也就是類似於祖先的存在喔。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "至今為止，",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_033"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我都在不知名的原因下",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "被困在「愛梅斯」的體內，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n無法變回我原本的模樣……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "但今天早上，",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_034"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我就忽然變成這樣了，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n真是嚇了我一大跳呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "契機……",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_035"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……我好像",
        "unit_id": 134011,
        "voice": "vo_adv_5201000_036"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "做了一場夢。",
