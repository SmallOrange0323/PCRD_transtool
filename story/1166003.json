[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "嘉夜的導覽大受好評，讓這門生意相當成功，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n工作接二連三地上門。然而──"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊～好累～！",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最近每天都在導覽導覽導覽！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就因為這樣，我完全沒辦法打架。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並不是討厭做導遊的工作。",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n看到大家樂在其中，我也覺得很開心。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我可是打手啊！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我想打一場會讓人熱血沸騰的架啊！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "妳心情挺差的啊，",
        "unit_id": 1111,
        "voice": "vo_adv_1166003_003"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "嘉夜。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你知道的話就閉嘴吧。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我可不知道現在的自己會做出什麼事情喔？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "我是求之不得，",
        "unit_id": 1111,
        "voice": "vo_adv_1166003_005"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "但我也不想被老大盯上……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "事情就是這樣，有工作上門啦，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "是導遊的工作。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜託饒了我吧……",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_006"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "很遺憾，",
        "unit_id": 1111,
        "voice": "vo_adv_1166003_007"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "妳好像沒有拒絕的權利喔。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "這次的客人是",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "從外地來蘭德索爾旅行的貴族。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "\n這份工作就交給妳和平常那位小哥一起負責。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "老大好像本來就是為了和這種權威人士打好交情，",
        "unit_id": 1111,
        "voice": "vo_adv_1166003_008"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "\n才會開始這門生意的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "她就是為了這件事，",
        "unit_id": 1111,
        "voice": "vo_adv_1166003_009"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "才會讓妳紮實地累積工作的經驗吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "妳可不能搞砸這件工作啊，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "嘉夜。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道啦，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真受不了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "貴賓偏偏",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在這種時候上門嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是提不起勁……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "希望對方至少是個正常的傢伙啊。",
        "unit_id": 116611
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呃～",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是今天為你擔任導遊的嘉夜。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n請多指教。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哼，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_013"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "因為對方特別向我推薦你們，我本來還在期待來的會是什麼樣的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n沒想到導遊居然是你們這種小丫頭和年輕人啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "算了，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_014"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們可要讓我好好享受啊？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘖，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在最糟糕的時機來了個最糟糕的客人……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管怎麼樣，這時候也只能用和平常一樣的方式撐過去了啊。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哼，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_016"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "所謂的蘭德索爾",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "也沒想像中那麼了不起嘛。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n沒想到高貴的我都到這裡來了，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "卻不能進入王宮。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不好意思，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那邊並不在導覽路線內。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "就這點程度的小事，我希望你們能先打點好啊。",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_018"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "妳自豪的那什麼導覽也只是吵鬧而已，一點都不有趣。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "會對這種程度的東西心存感謝的，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_019"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n大概是身分和格調都很低下的人吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "高貴的我實在是沒辦法理解啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這個……",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "傢伙……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哎呀哎呀？",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_021"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我好像感覺到了一股反抗的氣氛啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們總不該",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "對客人擺出這種態度吧？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哼，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_022"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你和那個小丫頭不一樣，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "既順從又機靈啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n好，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不用再介紹城鎮了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "接下來請你們為我做城鎮外部的導覽吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我明、",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "白了。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我來為你帶路──",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "喂喂喂，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_024"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們是打算要高貴的我在外頭走動嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "喂，年輕人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你就來揹我吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "等等，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這再怎麼樣都太……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哼，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_026"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "既然如此，你們只要能備好一台馬車就行了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "立刻準備好。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "怎麼？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們辦不到嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然如此，就讓我來……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不了，",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_028"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我對妳實在是沒什麼好感啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "就這一點來說，這傢伙既順從又好使喚。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……抱歉，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都是因為我，才讓你承擔了所有的麻煩。",
        "unit_id": 116611
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈哈哈！",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_030"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不錯不錯，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這樣挺舒適的！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你看起來寒酸，卻出人意料地結實嘛！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你覺得如何？",
        "unit_id": 2511,
        "voice": "vo_adv_1166003_031"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "要不要繼續當我的馬？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n我會讓你每天替我做牛做馬。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "世上沒有比這還要更加光榮的事情了！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……啊，",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_032"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我到底在做什麼啊？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "重要的死黨被這樣對待，",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我卻只是在旁邊看著。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "工作當然很重要。",
        "unit_id": 116611,
        "voice": "vo_adv_1166003_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也很清楚這是必須忍耐的事情。",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
