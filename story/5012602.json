[
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總覺得好像出現了個不妙的傢伙，",
        "unit_id": 104311,
        "voice": "vo_adv_5012602_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒有問題嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n步未。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒、",
        "unit_id": 105511,
        "voice": "vo_adv_5012602_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒沒、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒油……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝尼……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚嗚，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好可怕喔～～！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒事沒事，",
        "unit_id": 101411,
        "voice": "vo_adv_5012602_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "辛苦妳了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n發生了什麼事",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我之後再詳細問妳――",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偵探工作最有趣的地方就是推理，",
        "unit_id": 101411,
        "voice": "vo_adv_5012602_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但若沒有情報是無法推理的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果有像步未這樣，",
        "unit_id": 101411,
        "voice": "vo_adv_5012602_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n會帶來情報的人就輕鬆了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但世事並不會這麼順利。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呃……",
        "unit_id": 105511,
        "voice": "vo_adv_5012602_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那麼到底該怎麼辦……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要打聽情報進行調查。",
        "unit_id": 101411,
        "voice": "vo_adv_5012602_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在開始大家一起試試看吧。",
        "unit_id": 101411
    }
]