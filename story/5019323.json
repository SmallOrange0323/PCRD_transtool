[
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "已經破壞結晶了，",
        "unit_id": 110211,
        "voice": "vo_adv_5019323_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n應該",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不會再下那種冰冷的雨了！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉，",
        "unit_id": 110011,
        "voice": "vo_adv_5019323_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "再撐一下……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n再一下下你就能見到晴吉了，冷靜點！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "對不起……",
        "unit_id": 11611,
        "voice": "vo_adv_5019323_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦……",
        "unit_id": 110011,
        "voice": "vo_adv_5019323_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個聲音……？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難道這是",
        "unit_id": 110211,
        "voice": "vo_adv_5019323_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雨吉的心聲……？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "對不起……",
        "unit_id": 11611,
        "voice": "vo_adv_5019323_005"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "對不起……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "我並不想那麼做……",
        "unit_id": 11611,
        "voice": "vo_adv_5019323_006"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n我並不想跟你吵架的……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n不過，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "晴吉一定不會原諒我……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "我好孤單喔……",
        "unit_id": 11611,
        "voice": "vo_adv_5019323_007"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n我還想再跟你一起玩……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "晴吉……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……雨吉",
        "unit_id": 110011,
        "voice": "vo_adv_5019323_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n原來害怕見到晴吉呢。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "吵架後，",
        "unit_id": 110211,
        "voice": "vo_adv_5019323_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "變得孤單一人，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "覺得很難過……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "剛才的屏障和結晶",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來是因為這樣子啊。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然如此，",
        "unit_id": 110011,
        "voice": "vo_adv_5019323_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "身為和好的前輩，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我們得教教他該怎麼做才行！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈……",
        "unit_id": 110211,
        "voice": "vo_adv_5019323_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說的沒錯！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我們教教她吧，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所謂的朋友，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n才不會因為小小的吵架就分道揚鑣！",
        "unit_id": 110211
    }
]