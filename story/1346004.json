    {
        "type": "dialogue",
        "name": "電影院的客人1",
        "words": "\n我下次也想和男朋友來看～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "什麼──！！？",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_054"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我沒聽說有這種陷阱啊！！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_055"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒有，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是這樣……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n要說是認知的分歧，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還是不幸錯過呢……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "的很抱歉，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實我",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_056"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為私人的原因，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "幾乎不記得電影的內容……！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我剛才是隨便配合你的話講，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起！！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我不想讓團長失望，",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_057"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不想破壞開心的氣氛！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我的想法很膚淺吧，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的非常抱歉！！！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦……？",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_058"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那樣我當然是很感激……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是你沒關係嗎？",
        "unit_id": 104033
    },
    {
        "type": "still",
        "still": "134600401"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚哇啊……",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_059"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n不不不不，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個……！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "作為主角的男性",
        "words": "「別開玩笑了。",
        "unit_id": 1,
        "voice": "vo_adv_1346004_060"
    },
    {
        "type": "dialogue",
        "name": "作為主角的男性",
        "words": "\n這樣將來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "作為主角的男性",
        "words": "可要忙著當小鬼頭的保母啦。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "「哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1346004_061"
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "你不願意嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "\n有時候這種人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "反而會成為溺愛小孩的父母喔。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這哪裡是動作大片啊！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要騙人看不同類型的電影也不是這樣的啊！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n明明就把心力放在主角和女主角的戀愛過程上面不是嗎！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n團長，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你居然能面無表情地看完啊！！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "甜蜜蜜的戀愛要素多到我都要消化不良了……！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_063"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我居然指著這個，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說我也想要有那種夥伴！？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我真的那麼說了嗎！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對團長說！？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我瘋了嗎！？　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "「哪天我們說給小孩聽吧。",
        "unit_id": 1,
        "voice": "vo_adv_1346004_064"
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "\n爸爸和媽媽拯救了世界",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "作為搭檔的女性",
        "words": "的故事。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咿啊啊啊啊啊啊啊！！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_065"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n住手啊啊啊啊啊啊！！！　",
        "unit_id": 104033
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1346004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "做為像電影一樣拯救了平行世界的獎勵，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個夢再適合不過了對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1346004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "碧這個人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以旁觀者的角度看來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真的是個熱鬧又有趣的女生呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然她本人那樣說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是身邊的大家也都對她印象很好吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也做得很好。",
        "unit_id": 190011,
        "voice": "vo_adv_1346004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "多虧有你，對碧來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這大概會是她難忘的回憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……從各方面來說都是。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟，",
        "unit_id": 190011,
        "voice": "vo_adv_1346004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽到「想談一場像電影一樣的戀愛」這種話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當然會想要滿足她嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……雖然要忽略",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她本人沒有這個意圖這點就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也成長了許多，",
        "unit_id": 190011,
        "voice": "vo_adv_1346004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以理解這種浪漫了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不枉費我一路看著你走來啊～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之後也照這樣繼續努力吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1346004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為你是碧",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無可替代的搭檔啊。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500980"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "碧，",
        "unit_id": 134511,
        "voice": "vo_adv_1346004_072"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不可以邊駕駛邊打瞌睡啦，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請快點起來～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是、",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_073"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒睡！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n下次我會好好看電影……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你們兩個都還好嗎？",
        "unit_id": 134511,
        "voice": "vo_adv_1346004_074"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n你們好像突然同時失去意識，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "害我嚇了一跳。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不，",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_075"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很好，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一直醒著！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也沒有做什麼奇怪的夢，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對吧，團長！？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒有沒有！",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_076"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那一定",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是你誤會啦～！！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇～",
        "unit_id": 134511,
        "voice": "vo_adv_1346004_077"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請不要在駕駛艙內亂動～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧一行人拯救世界的冒險，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣劃下句點。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而跨越時空建立起來的羈絆，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將存在於各人的心中，\n持續閃耀直到永遠。"
    }
]