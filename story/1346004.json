    },
    {
        "type": "still",
        "still": "134600401"
    },
    {
        "type": "dialogue",
        "name": "作為主角的男性",
        "words": "「你就是我新的搭檔？",
        "unit_id": 1,
        "voice": "vo_adv_1346004_030"
    },
    {
        "type": "dialogue",
        "name": "作為主角的男性",
        "words": "\n不是要當小鬼頭的保母？」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這座位是怎麼回事！？",
