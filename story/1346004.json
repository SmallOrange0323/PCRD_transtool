    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "等一下，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我連有這種東西都不知道啊！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要立刻離開，",
