[
    {
        "type": "background",
        "background": "500980"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧和{player}坐上巨型克蘿茜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在傳送門內的異空間中前進。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很快就能回到蘭德索爾了呢。",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n感覺已經好久沒回去了！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n希望大家也都平安……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是啊。",
        "unit_id": 134511,
        "voice": "vo_adv_1346004_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "回去之後我有好多話想跟大家說！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n例如碧和騎士先生的結婚典禮！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不不不克蘿茜小姐！",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那不太好！",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n百分之百會讓人誤會的，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以希望妳能保守秘密～！",
        "unit_id": 134612
    },
    {
        "type": "background",
        "background": "500802"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "我們從打倒的宇宙蓋登中",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_003"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "成功收回一部分米奈娃的力量。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "不過或許是皇帝消滅後的影響，",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "力量好像正在急速消失。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "但是只要趕緊處理，",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_004"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "應該就能打開門，",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n送你們回到原本的世界。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n這部分的工作",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "就交給我們吧。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我知道了！",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在那之前，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們會努力盡我們所能來幫忙的。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是啊，",
        "unit_id": 134511,
        "voice": "vo_adv_1346004_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "敵人的攻擊",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "四處破壞了許多建築物。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "在回去的門打開之前，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們就來幫忙重建城市吧。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "好，",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_007"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "拜託你們了。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "……雖然戰爭結束了，",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "但是要過上和平的日子還為時尚早。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "應該會需要花上很長的時間來重建。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "不過……",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_008"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "現在我們可以",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "慢慢開始往前走了。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "我感覺將肩膀上的重擔卸下來了。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "真的很謝謝你們。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "師傅，",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "之後妳打算怎麼辦？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "和大家一樣啊。",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_010"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n為這座城市，",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "以及",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "「我們的世界」的重建付出全力。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "在那之後……",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "……我想去找他。",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "妳說的，",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是這邊的團長嗎……？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "其實……",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_013"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "在最後的戰役時，",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n我看到一道光",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "離開蓋登的身體飛向天邊。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "我覺得只要追著那道光走，",
        "unit_id": 53011,
        "voice": "vo_adv_1346004_014"
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "就能再次見到他。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "\n",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "我沒有明確的證據，",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "冥",
        "words": "可是我有這種感覺。",
        "unit_id": 53011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我知道了……",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太好了。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n雖然我們只能幫到這邊，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但是妳要加油喔！",
        "unit_id": 134612
    },
    {
        "type": "background",
        "background": "500980"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果是師傅，",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一定能再次見到那邊的團長。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們也在自己的世界",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "做我們能做的事情吧。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯……",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可以看見前方越來越亮了。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們已經到了嗎？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沒有沒有，",
        "unit_id": 134511,
        "voice": "vo_adv_1346004_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好像還要",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "再一下子喔？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n妳是不是看錯了？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是，",
        "unit_id": 134612,
        "voice": "vo_adv_1346004_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的眼前真的變得好亮……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "究竟發生什麼事了啊～～！？",
        "unit_id": 134612
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧和{player}約在車站前碰面。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然還沒到約好的時間……",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "依團長的個性，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "說不定就快要來了……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n天啊天啊天啊，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我開始緊張了……！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我可是三個小時前就來了！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n畢竟，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和團長去看電影可是重要活動啊！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n當然需要充足的時間做好心理準備吧！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "兩個人去電影院……",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "聽起來就好充實！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在和朋友進行的活動之中",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是親密度最高的吧？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我居然會有這一天，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真是做夢也想不到……！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真慶幸我有鼓起勇氣約他……！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那一天我放手一搏以不成功便成仁的氣勢突擊他，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n實在是太感激我自己了……！　",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……對了，",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一個衝動就預訂了電影票，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但是完全沒先查過最重要的電影是什麼。",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我記得，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好像是充滿極限震撼演出的動作電影……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊嗚咿！！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團、",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長！？",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n呃，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "早、",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "早安啊！！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天在這個好日子裡，",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你願意",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "答應我自私的邀約，",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我實在是",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "開心又幸運……",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總之我非常高興！！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇啊啊啊……！",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "心意相通呢！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n這就是電影的力量……！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還沒開始看電影我就感動了……！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好，",
        "unit_id": 104033,
        "voice": "vo_adv_1346004_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請多指教！",
        "unit_id": 104033
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們一起欣賞會令人雙手緊握、",
