        "voice": "vo_adv_7002004_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里，已經精疲力盡了～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "既然決定休息了……",
        "unit_id": 102211,
        "voice": "vo_adv_7002004_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咻。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 100611,
        "voice": "vo_adv_7002004_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那是什麼啊？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼哼哼……",
        "unit_id": 102211,
        "voice": "vo_adv_7002004_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個啊，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n是今天我才從雜貨店買的，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "最新款遊戲機哦！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是濃縮了機能的小型遊戲機。",
        "unit_id": 102211,
        "voice": "vo_adv_7002004_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這時候拿來玩豈不是正好嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好厲害――！",
        "unit_id": 100611,
        "voice": "vo_adv_7002004_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n如此一來",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就能在外頭盡情地玩了♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說的一點也沒錯……",
        "unit_id": 102211,
        "voice": "vo_adv_7002004_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你似乎也挺感興趣的呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼哼哼，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你的心情～我能夠理解！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "機會難得，",
        "unit_id": 102211,
        "voice": "vo_adv_7002004_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "讓你來玩玩看。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我也是第一次玩，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "詳細操作方式我也不是很清楚。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們就一起來試試吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "…………",
        "unit_id": 100611,
        "voice": "vo_adv_7002004_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵，",
        "unit_id": 100611,
        "voice": "vo_adv_7002004_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "和哥哥聊開來",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n姊姊看上去開心極了♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真好，",
        "unit_id": 100611,
        "voice": "vo_adv_7002004_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也想和哥哥好好地相處呢♪",
        "unit_id": 100611
    }
