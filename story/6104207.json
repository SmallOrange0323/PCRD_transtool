[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本還以為是簡單而無趣的任務，",
        "unit_id": 123811,
        "voice": "vo_adv_6104207_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒想到這地方出乎意料地危險呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們可是在充滿危險的",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "許多火藥庫當中跳了支舞，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個結局可以說是挺不錯了吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 123811,
        "voice": "vo_adv_6104207_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且是我討厭的字眼。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大家牽起手來融洽地享受和平，這種事實在是無趣至極。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像這種扮演正義夥伴的戲碼，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我以後都不想再參加了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 123811,
        "voice": "vo_adv_6104207_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別愁眉苦臉的嘛。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有這種走錯一步就會炸飛一切的刺激感，才能讓人確實感受到自己活著，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n並因此感到愉悅不是嗎♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你難道不這麼覺得？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊，",
        "unit_id": 123811,
        "voice": "vo_adv_6104207_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要維持與獸人族間的和平，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "種族間彼此的努力是不可或缺的吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是很不巧，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我被託付的任務就到此為止。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n之後就由你們去加油吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會來見證",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們所做的努力的。",
        "unit_id": 123811
    }
]