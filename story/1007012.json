[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "宮子為能夠吃到布丁而感到心情愉快，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和{player}一起來到了蘭德索爾的鬧區。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "總算能吃到布丁了～♪",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子要把整個蘭德索爾的布丁",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有一個算一個全部吃光光喲～！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "第一個就挑那間店喲！",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n再來是",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "位在對面角落的店家……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "反正要把",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所有店都繞過一遍喲──！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "十分鐘後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}拿著大量布丁，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n走在宮子身後。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}走太慢了啦～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子想去的店還很多來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "加油哦！",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n說老實話，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子很想馬上把布丁吃掉。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是因為",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "想和你一起吃所以才忍著的。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以說，",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你手上有多重，宮子的忍耐就有多重哦。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你就好好體會吧！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗅嗅……",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "從那邊",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "傳來了某種感覺很好吃的香氣！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是什麼呢～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是什麼來的～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘿嘿嘿……",
        "unit_id": 1,
        "voice": "vo_adv_1007012_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你們感情還是一樣好啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "好久不見啦！",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_007"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n幽靈小姑娘的跟班。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "可別說你",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_008"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "忘了我們是什麼人啊？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "看來你還記得。",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_009"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "那麼事情就簡單了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "你說不記得了？",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_010"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n膽子可真大……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "我們是和那個幽靈小姑娘做交易的旅行商人！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "當時真是承蒙關照。",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_011"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "拜你所賜，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們虧了一大筆錢。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n所以說……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們無論如何",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "都想向小兄弟你好好表達一下謝意。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n呵呵呵呵……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦？",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}……走散了嗎？",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真不敢相信他竟然會離開宮子身邊！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真是個需要關照的傢伙來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}，",
        "unit_id": 100711,
        "voice": "vo_adv_1007012_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你跑哪去了──？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………是去上廁所嗎？",
        "unit_id": 100711
    },
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在宮子察覺到不對勁的這個時候──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被帶到了旅行商人們的據點。"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "好了，",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_015"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "進去！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n在牢裡乖乖待著！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "小兄弟手上的包裹就由我們先保管吧。",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_016"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "要是被你帶什麼怪東西進去",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們可承受不了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "那可不行。",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_017"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "畢竟小兄弟你",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "是誘餌啊。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們透過先前的遭遇全都摸清楚了。",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_018"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n那個小姑娘",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "很在乎小兄弟你的樣子。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "也就是說……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "只要有你在，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "那個女孩就一定會自己跟過來。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "沒什麼，",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_019"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "我們又不是要讓你嚐嚐苦頭。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n你現在不也一點都沒受傷嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n小兄弟你啊",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "只要乖乖待在裡頭就行了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "……然後",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_020"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "將你和小姑娘一起賣掉就大功告成啦。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "這就是所謂的捆綁銷售。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "那還用說！",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_021"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n反倒是你們帶來的那些痛苦，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n讓我們不賺一筆回來就不甘心啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "為了今天，",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_022"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們甚至還另外準備了護符。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "是比之前更厲害的護符。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "儘管是筆龐大的開銷……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "哎，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "要賣時再把那些錢加上去就行了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "那麼，",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_023"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "接下來只需要等小姑娘找來這裡……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n不過她會發現嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "為了讓她能追過來，",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_024"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我暗中放出了情報。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n沒問題的。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "那應該就行啦。",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_025"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "話說",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "這小兄弟帶著的包裹是什麼啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "哦，",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_026"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "那是布丁。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "全都是布丁。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "這樣啊？",
        "unit_id": 1411,
        "voice": "vo_adv_1007012_027"
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "好吧，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "反正剛好有點餓了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "就拿布丁來填肚子吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n順便報復一下前陣子的事。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "說得也是……",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_028"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
