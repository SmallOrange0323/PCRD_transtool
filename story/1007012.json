        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "但是",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們也──",
