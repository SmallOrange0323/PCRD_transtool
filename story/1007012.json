    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "比較吵鬧多話的不是嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人２",
        "words": "\n這也是因為布丁造成的嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "別緊張。",
        "unit_id": 4911,
        "voice": "vo_adv_1007012_057"
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "畢竟",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "旅行商人１",
        "words": "我們手上有人質。",
