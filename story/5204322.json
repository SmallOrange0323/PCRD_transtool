        "voice": "vo_adv_5204322_000"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "……唔！？",
        "unit_id": 132411,
        "voice": "vo_adv_5204322_001"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n奇怪，",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "沒有用啊！？",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "等等，",
        "unit_id": 132511,
        "voice": "vo_adv_5204322_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n針筒的液體",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是不是變了……！？",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "那、",
        "unit_id": 132311,
        "voice": "vo_adv_5204322_003"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "那個是",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「雙刃之劍的祕藥」……！",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哇──",
        "unit_id": 132411,
        "voice": "vo_adv_5204322_004"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好帥的名字！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽也想喝──！",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不，",
        "unit_id": 132511,
        "voice": "vo_adv_5204322_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "給我住手。",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n光從名字來看就很不妙吧……！",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "正是如此啊。",
        "unit_id": 132311,
        "voice": "vo_adv_5204322_006"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n那是變得越強大，",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "就也越傷害自身的",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "高風險祕藥……！",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "原來如此，",
        "unit_id": 132411,
        "voice": "vo_adv_5204322_007"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "換言之，",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "接下來就是",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "耐力比賽了。",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "也就是說",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "輪到我出場了啊，",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "真麻煩。",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不，",
        "unit_id": 132311,
        "voice": "vo_adv_5204322_008"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "苑是我們之中最弱的吧……！",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "退到後面來啦！",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯，",
        "unit_id": 132511,
        "voice": "vo_adv_5204322_009"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我的防禦確實跟紙一樣弱，",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "但忍耐力我可是不會輸的喔。",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……跟像妳們這樣的脫韁野馬兩人的生活，",
        "unit_id": 132511,
        "voice": "vo_adv_5204322_010"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n能夠忍受的也就只有我了吧？",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……苑。",
        "unit_id": 132311,
        "voice": "vo_adv_5204322_011"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊哈哈哈，",
        "unit_id": 132411,
        "voice": "vo_adv_5204322_012"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "露易被說是脫韁野馬～♪",
        "unit_id": 132411
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "彩羽也是啦！",
        "unit_id": 132311,
        "voice": "vo_adv_5204322_013"
    }
]