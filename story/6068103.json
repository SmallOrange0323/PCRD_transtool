    {
        "type": "dialogue",
        "name": "碧",
        "words": "我還沒辦法",
        "unit_id": 116711,
        "voice": "vo_adv_6068103_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好好跟工廠的大家說話……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想更加融入職場，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "結交打工夥伴，但……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能不能跟我一起思考",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "結交打工夥伴的訣竅……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是經由共同興趣讓對話順利進行的",
        "unit_id": 116711,
        "voice": "vo_adv_6068103_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "高級技巧呢……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對於根本沒辦法跟人交談的我來說，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那或許還太早了……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我遲早得學會那種技巧才行，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對吧……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你是指從人類最低標準的禮儀重新審視自己會比較好對吧！",
        "unit_id": 116711,
        "voice": "vo_adv_6068103_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們得開始練習打招呼1000次才行……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那麼，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "首先由我開始……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "日、",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "日安……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此！",
        "unit_id": 116711,
        "voice": "vo_adv_6068103_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要用拚命工作的態度",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來獲得認同是吧！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "千里之行始於足下……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟擺脫邊緣",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒有捷徑呢。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那麼，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我馬上住進工廠展開24小時完全不休息的打工生活……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不行嗎？",
        "unit_id": 116711
    }
