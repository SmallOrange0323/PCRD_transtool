        "voice": "vo_adv_9003504_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是沒有他幫忙剛才就危險了呢。",
        "unit_id": 102912
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n應該要跟他說聲謝謝。",
