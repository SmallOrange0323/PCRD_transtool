        "unit_id": 190711,
        "voice": "vo_adv_9003504_006"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n那不是得要有人保護他嗎！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我現在就過去，老兄──！！",
