        "voice": "vo_adv_9003504_004"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n拉基拉基兄怎麼了？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "他沒跟妳們一起嗎！？",
