        "voice": "vo_adv_9003504_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "跑走了。",
        "unit_id": 105412
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這人真是慌慌張張的呢──",
