        "words": "嗯，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "已經這個時間了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆差不多也要買完東西回來了吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "打掃和洗衣服也都做得很好，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n真不愧是拉姆的妹妹，得好好地誇獎她才行呢。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "呼，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "好忙碌好忙碌。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "被誇獎就害羞的雷姆也好可愛。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n光是想像她那個樣子，就讓人湧出了力量，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是個",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "讓姊姊感到無上幸福的孩子……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――真是的，",
        "unit_id": 211,
        "voice": "vo_adv_1098002_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳不要再管我了啦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "嗯，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "吵吵鬧鬧的是怎麼了？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――我最討厭姊姊了！",
        "unit_id": 211,
        "voice": "vo_adv_1098002_008"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……看起來",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n是相當激烈的爭執呢。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "姊姊真是壞心眼！",
        "unit_id": 211,
        "voice": "vo_adv_1098002_010"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "\n我明明也在",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "拼命努力啊！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "我、",
        "unit_id": 415,
        "voice": "vo_adv_1098002_011"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "我只是想幫妳忙……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "那個就叫多管閒事！",
        "unit_id": 211,
        "voice": "vo_adv_1098002_012"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "什麼都能像那個樣子……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "什麼都做得到的姊姊，",
        "unit_id": 211,
        "voice": "vo_adv_1098002_013"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "\n才不會懂我的心情啦！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "……！",
        "unit_id": 415,
        "voice": "vo_adv_1098002_014"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "啊……",
        "unit_id": 211,
        "voice": "vo_adv_1098002_015"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "……哼、",
        "unit_id": 211,
        "voice": "vo_adv_1098002_016"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "哼！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_017"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是隨她高興想說什麼就說什麼了呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_018"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你看到了啊，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_019"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這興趣真糟。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那兩個人",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "明明一直都很要好的啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "姊姊才不會",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_020"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "懂我的心情……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這句話讓人感同深受。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_021"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n都快讓拉姆的小鳥心臟爆炸了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "什麼？",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_022"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你說小鳥是指很小的鳥兒？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你在瞧不起拉姆嗎？",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_023"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那點事，拉姆當然知道啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "比起那種事……",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_024"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那邊的妳，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "快說給拉姆聽聽吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "咦？",
        "unit_id": 415,
        "voice": "vo_adv_1098002_025"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "\n啊，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "拉姆姐姐……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "妳們大吵了一架呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_026"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是第一次和妹妹吵架嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "妳怎麼會知道……？",
        "unit_id": 415,
        "voice": "vo_adv_1098002_027"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "很簡單。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_028"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n拉姆",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "第一次被雷姆拒絕的時候，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "也被像那樣子的說過。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "被妹妹討厭很令人害怕對吧。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_029"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "簡直就像是",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "全身要被撕裂的感覺。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "……",
        "unit_id": 415,
        "voice": "vo_adv_1098002_030"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "嗯。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "我，",
        "unit_id": 415,
        "voice": "vo_adv_1098002_031"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "\n想幫忙那孩子。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "可是，",
        "unit_id": 415,
        "voice": "vo_adv_1098002_032"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "我是不是幫倒忙了……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不是這樣的。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_033"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n只是，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "兩人不可能會總是都牽著手。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是偶爾會想放開牽起的手，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_034"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "一個人邁出步伐而已。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "如果妳有心想和好，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_035"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n儘管會感到不安，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "也請妳暫時等待。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆去幫妳和她聊聊。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_036"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "拉姆姐姐嗎？",
        "unit_id": 415,
        "voice": "vo_adv_1098002_037"
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女 2",
        "words": "為什麼要這麼幫我？",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那還用說。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_038"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "因為拉姆",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_039"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是可愛雷姆最棒的姊姊啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_040"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_041"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你還站在那裡做什麼？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n別發呆了，快跟上來。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那孩子房間在哪，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_042"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆可不知道啊。",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "……",
        "unit_id": 211,
        "voice": "vo_adv_1098002_043"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "姊姊。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "進去囉。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_044"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "哇！？",
        "unit_id": 211,
        "voice": "vo_adv_1098002_045"
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "\n咦、",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "咦，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "拉姆姐姐！？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "嗯，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_046"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是拉姆喔。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n不只是拉姆，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "還有其他人就是了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "話說回來，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_047"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n有關於剛才的爭吵……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "唔唔……",
        "unit_id": 211,
        "voice": "vo_adv_1098002_048"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看來妳很後悔呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_049"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n畢竟說了與心相違背的重話啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "少女 1",
        "words": "與心相違背……",
        "unit_id": 211,
        "voice": "vo_adv_1098002_050"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "沒錯，",
        "unit_id": 109811,
        "voice": "vo_adv_1098002_051"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "與心相違背。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
