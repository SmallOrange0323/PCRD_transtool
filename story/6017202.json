        "words": "我很想知道。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那裡賣的食材和雜貨品項很豐富吧。",
        "unit_id": 109711,
        "voice": "vo_adv_6017202_001"
    },
    {
        "type": "dialogue",
