        "voice": "vo_adv_6017202_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不過，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "和情同家人的夥伴",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
