[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "沒想到",
        "unit_id": 1,
        "voice": "vo_adv_5031003_000"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "2區竟然在如此膠著的狀態結束了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n所有選手並列",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "進入了3區！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n森林裡的視野很差，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這段賽程絕對會讓大家陷入苦戰！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然主人",
        "unit_id": 111911,
        "voice": "vo_adv_5031003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和一群女性",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起來到中繼站的這種情況實在讓人無法接受，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是大家並列進入3區的狀況，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是激烈呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "純小姐穿著這身鎧甲，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來會比在下",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還難跑呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我平時生活、",
        "unit_id": 104711,
        "voice": "vo_adv_5031003_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "訓練時都是穿成這樣子。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以沒問題的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "現在勉強搶先可沒什麼效率呢。",
        "unit_id": 104811,
        "voice": "vo_adv_5031003_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還是先保存體力比較好……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先走一步囉～",
        "unit_id": 102611,
        "voice": "vo_adv_5031003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "什麼！？",
        "unit_id": 104711,
        "voice": "vo_adv_5031003_005"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "沒想到！　",
        "unit_id": 1,
        "voice": "vo_adv_5031003_006"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "突然取得領先的是鈴選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴好～～～～厲害！　",
        "unit_id": 105211,
        "voice": "vo_adv_5031003_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "老實說我還以為妳會是最後一名呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她很靈活地在樹與樹之間穿梭呢。",
        "unit_id": 103811,
        "voice": "vo_adv_5031003_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n是因為鈴的個子很嬌小……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "的關係嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她的動作對森林很熟悉呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我知道了！　",
        "unit_id": 105211,
        "voice": "vo_adv_5031003_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "一定是她為了彌補平時偷懶的份，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n一個人練習過了吧！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哎呀，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴真是見外～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為自己常常偷懶跑來撿橡實",
        "unit_id": 102611,
        "voice": "vo_adv_5031003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以對森林很熟，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這種話實在說不出口呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊也在唷～！",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_011"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "哎――――呀！　",
        "unit_id": 1,
        "voice": "vo_adv_5031003_012"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "追趕在鈴選手身後的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "是禊選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿。",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊常常和【小小甜心】的大家來森林玩呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n要在這跑步太簡單了，簡～單！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "從那邊的樹木之間穿過去的話就可以抄近路唷！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "抄近路！？　",
        "unit_id": 104811,
        "voice": "vo_adv_5031003_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這可不能當作沒聽到呢！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀啊啊啊！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這、",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這個又白又黏的是什麼……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿嘿，",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那是蜘蛛魔物的巢穴唷～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n惡作劇大成功～！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "接下來是～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！　",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鎧甲姐姐，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "妳如果這樣繼續跑的話會撞到樹枝唷！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_5031003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是可愛的搗蛋鬼。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我才不會上妳的當，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚啊！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就說了嘛……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "妳撞得好大力，沒事吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5031003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳在擔心我嗎？　",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳真溫柔呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊幫妳看看有沒有腫起來！　",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "看――招！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哇！　",
        "unit_id": 104712,
        "voice": "vo_adv_5031003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小姐！　",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "把那個還給我！",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有那個我就沒辦法跑步了啊！",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？　",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣子啊～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n好像也沒有腫起來，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那禊就走囉！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等、慢著！　",
        "unit_id": 104712,
        "voice": "vo_adv_5031003_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "頭盔！　",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不要把頭盔拿走啊──！",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "美冬選手和純選手，",
        "unit_id": 1,
        "voice": "vo_adv_5031003_024"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n似乎都因為禊選手的妨礙",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "而動彈不得的樣子～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n可可蘿選手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "跑向她們兩位，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "伸出援手了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "目前第一名是",
        "unit_id": 1,
        "voice": "vo_adv_5031003_025"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "鈴選手，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "第二名是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "禊選手……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "奇怪？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n沒看到鈴選手的身影呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "該不會是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "掉進禊選手的洞穴陷阱裡了吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊什麼都沒做唷～？",
        "unit_id": 100411,
        "voice": "vo_adv_5031003_026"
    },
    {
        "type": "still",
        "still": "503100301"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼～",
        "unit_id": 102611,
        "voice": "vo_adv_5031003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "睡得真舒爽。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "鈴選手她竟然！　",
        "unit_id": 1,
        "voice": "vo_adv_5031003_028"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "在大樹的空隙間",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "擺出午睡的姿勢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n她的動作就像在某本繪本裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "出現的兔子一樣！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "小鈴妳在做什麼啦～！　",
        "unit_id": 105211,
        "voice": "vo_adv_5031003_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好不容易第一名了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道自己的極限啦。",
        "unit_id": 102611,
        "voice": "vo_adv_5031003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就到此為止了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我躺。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好想回家。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒問題的，小鈴！　",
        "unit_id": 105211,
        "voice": "vo_adv_5031003_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳的極限不應該只有那樣啦！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不可以放棄！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
