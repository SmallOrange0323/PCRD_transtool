[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛蜜莉雅等人\n來到阿斯特賴亞大陸，已經過了數天。"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "對這個世界的事情，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "現在還沒辦法說是已經很清楚的了解。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然雷姆和愛蜜莉雅大人",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "已經徹底融入這裡，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "但還無法確定這裡的人是否真的善良。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "放鬆戒心悠悠哉哉的雷姆也好可愛。",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "本來，愛蜜莉雅大人",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就是個不會懷疑他人的人。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "所以為了代替那兩人，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n至少只有拉姆",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "要對這個世界保持警戒才行……",
        "unit_id": 109811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "原本",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是這麼想，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n所以才決定先跟蹤那什麼【美食殿堂】的人看看……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看那個，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那家攤販的肉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超大塊的耶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳別因為那種事就大呼小叫的啦！",
        "unit_id": 106012,
        "voice": "vo_adv_1098001_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣會不會太丟臉了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1098001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的肚子叫了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明白了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這就去買。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔，",
        "unit_id": 106012,
        "voice": "vo_adv_1098001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也別那麼寵他啦～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_009"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "已經觀察了一陣子，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n但他們一直在邊走邊吃呢……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "從早上到現在都要中午了，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_011"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n到底是想吃幾餐啊……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "偶爾看他們停下腳步，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_012"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "沒想到就坐在長椅上聊起天了……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "以偷聽的內容來看，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_013"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n說的就是下次要吃什麼，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "或之前吃的那個很好吃……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "聊的內容，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_014"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n不全都是關於食物的話題嗎。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "把他們當成危險人物，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_015"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n對他們這樣抱持警戒的拉姆真像是個傻瓜。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "唔……",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了嗎～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 105913,
        "voice": "vo_adv_1098001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這不是拉姆小姐嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1098001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一個人在做什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總是和妳形影不離的妹妹也不在啊。",
        "unit_id": 106012,
        "voice": "vo_adv_1098001_020"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那是……",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_021"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "好吧，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那就直接說清楚好了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆在跟蹤你們。",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦！？",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟蹤我們嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012,
        "voice": "vo_adv_1098001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這句話我可不能當作沒聽到呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳為什麼要跟蹤我們？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣子，",
        "unit_id": 106012,
        "voice": "vo_adv_1098001_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本就像我在做的事情一樣啊……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_1098001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問為什麼要跟蹤我們？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是有什麼要緊事的話，",
        "unit_id": 105913,
        "voice": "vo_adv_1098001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要和我們說就行了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這種事怎麼可能會說啊。",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_028"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只是，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "請你們別誤會了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這說到底，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_029"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n都是拉姆的獨斷獨行。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n和雷姆和愛蜜莉雅大人她們無關，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "懂嗎？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "她們兩人想和這些人好好相處，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_030"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n被討厭的只有拉姆就夠了，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這是必要處置。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_031"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "什麼？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n你在盯著人看什麼啊？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真下流。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……那是當然的啊。",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_032"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n因為，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "拉姆是雷姆的姊姊呀。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……這發言就像是什麼都看穿了呢。",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_033"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n乍看下好像什麼都沒想，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是大意不得。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "總之，",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_034"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你們如果想懷疑愛蜜莉雅大人或雷姆就搞錯對象了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n疑心病重的是拉姆，你們要怎麼想拉姆都無所謂。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問怎麼了，",
        "unit_id": 105913,
        "voice": "vo_adv_1098001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也是這麼想的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉姆小姐",
        "unit_id": 105913,
        "voice": "vo_adv_1098001_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是個重情義的人呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是說啊～♪",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也覺得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉姆非常了不起喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為從剛才開始，",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n拉姆就一直在擔心愛蜜莉雅和雷姆啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這不是非常替家人著想嗎♪",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_039"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "――！",
        "unit_id": 109811,
        "voice": "vo_adv_1098001_040"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "請不要隨便摸拉姆的頭。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗯！",
        "unit_id": 105812,
        "voice": "vo_adv_1098001_041"
    },
    {
        "type": "dialogue",
