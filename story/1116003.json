[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望跟{player}兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聖誕節熱鬧的\n蘭德索爾街道上散步。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看你看，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是玩具店！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看到這麼多玩具排在一起，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就算長大了，還是覺得興奮呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那邊在賣蛋糕呢！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像很好吃！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算只有一次也好，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想要試試一個人吃掉整個蛋糕呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過絕對會被阻止吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸、",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是這樣嗎？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸嘿嘿……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚――",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是有點興奮過頭了啊？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是沒辦法啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為這可是跟{player}的約會啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不可能冷靜的啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以的話想要浪漫地度過，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "得稍微自重一點呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "深呼吸",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "深呼吸。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總而言之，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要不要去喝些熱的東西呢？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那邊有很多店家呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那邊有咖啡店呢？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還有很多好像很美味的店呢，讓人眼花撩亂呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看你看，那個好厲害呢！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像是有名的甜點店在辦活動呢。",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是不是在用表演",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "推銷商品啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為是最適合銷售甜點的日子嘛。",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好像很有趣呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "稍微去看看吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個人是一起工作過好幾次的主辦人呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個舞台是不是也是她策畫的呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要不要去打個招呼呢？",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說不定可以拿到甜點呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那家店的甜點很好吃呢♪",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳好！　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "久疏問候，好久不見！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "咦？　",
        "unit_id": 1211,
        "voice": "vo_adv_1116003_013"
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "小、",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "小望小姐？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "怎麼了，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "為什麼在這裡呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶然看到妳所以過來打個招呼……",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳沒事嗎？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "臉色看起來不太好呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "嗯，",
        "unit_id": 1211,
        "voice": "vo_adv_1116003_015"
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "我沒事……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "不對，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "完全不是沒事呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "那個，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "接下來妳可以上台表演嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……咦？",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_016"
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "其實",
        "unit_id": 1211,
        "voice": "vo_adv_1116003_017"
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "本來預定今天要在舞台上表演的偶像，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "\n剛剛說突然生病，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "沒有辦法上台了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "就算想要找替代的人，",
        "unit_id": 1211,
        "voice": "vo_adv_1116003_018"
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "但大家也都正在忙，找不到人……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "我知道這是很無理的要求，但是可以拜託妳嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就、",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算妳突然這麼說……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "應該",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有很多粉絲是為了那位偶像而來的吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果知道她不能來",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定會很難過吧？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "【慈樂之音】是",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "『為了大家而歌舞而戰的公會』，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種狀況什麼事都不做的話……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n有能幫忙的事情的話我也想要幫忙。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算是我很信賴的主辦人，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也不能沒經過製作人擅自地接下工作。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的話對花寶貴的時間來陪伴我的",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}也會很抱歉。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……雖然覺得很抱歉，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這次還是讓我拒絕吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有喔？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼突然地被拜託上台，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不能隨便答應嘛。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……唉，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你的這種地方，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的很狡猾呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總會讓人踏上坦率正直的路呢。",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我這麼煩惱反而像是笨蛋呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有辦法跟我的製作人用通訊魔法",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聯絡嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "當、",
        "unit_id": 1211,
        "voice": "vo_adv_1116003_028"
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "當然！　",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "活動企劃人員",
        "words": "請稍等一下！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喂喂，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是我，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "望。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就去表演吧，",
