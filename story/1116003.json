    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "雖然聽到主推不能出場的時候，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "\n真的打從心底覺得很難過，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "觀眾２",
        "words": "但是真幸運啊！",
