        "voice": "vo_adv_1116003_063"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "衣服也亂糟糟的。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……謝謝你呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_064"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在街上到處尋找之後才在樹下重逢甚麼的，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是不是太剛好了啊？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "老天爺也會做這種老套的事情呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只是，",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我不討厭這種老套呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n命中註定的浪漫發展，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n正好符合聖誕節啊！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望偷偷地獨自"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n心滿意足的笑了。"
    },
