    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要好好思考有可能遇到{player}的地方。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
