        "voice": "vo_adv_1116003_058"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼～",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "終於找到了……{player}！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了……",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_059"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到處找來找去",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都找不到你，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還想說會不會已經見不到你了呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一直很不安呢……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_060"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果是在這裡，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果是在我們兩人一起努力活動過的這棵樹下，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n應該就能見到了吧，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是這麼想的。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總覺得好像心靈相通了一樣，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n有一點害羞呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是{player}你的錯喔。",
