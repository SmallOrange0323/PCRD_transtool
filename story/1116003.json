        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難得的約會，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就要這樣結束了嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n什麼都還沒有做到。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "連禮物都還沒有交出去……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要……",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "絕對不能發生那種事！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才不要就這樣結束！",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在可不是沮喪的時候，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在找到他之前都要繼續尋找！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n偶像可是不會輕易放棄的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好好想想？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116003_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只是到處亂跑是沒有用的，",
