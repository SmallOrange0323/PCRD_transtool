[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在阿斯特賴亞大陸的某個地方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "三位少女、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一位身為公主騎士的少年，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與一名嚮導小妖精正在走著。"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "噹噹噹～噹♪",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_000"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "歡迎來到阿斯特朗♪",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你以為",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_001"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我會像這樣歡迎你嗎！？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n太慢了──！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n你啊，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "登入的速度實在太慢了！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你看，",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_002"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "日和、優衣和怜都已經到齊了。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我們今天要去打倒Boss吧？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真是的～！",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_003"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n不守時的傢伙可是會被討厭的喔？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "唔～",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_004"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你又隨口道歉，打算蒙混過去。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n你老是這個樣子耶！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真拿你沒辦法……",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_005"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "算了，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我就原諒你。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n畢竟我是寬宏大量的嚮導妖精嘛！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "好了，",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_006"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "大家都在等我們。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n要出發去蒐集索爾魔珠囉！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "──跟著我來吧♪",
        "unit_id": 134011,
        "voice": "vo_adv_1340001_007"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "睡著了嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼我會做夢……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明不可能會的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是身體有什麼不適嗎……？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……嗯～",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，夢",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好像是類似記憶重組的東西吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難道說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是我累了……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至今我一直都盡量不去在意，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過這副身體",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是屬於",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「愛梅斯」的吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「愛梅斯」……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這毫無疑問是活在這個世界的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一個女孩的帳號。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然繼承了她的身體，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但也不能過度操勞呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來放鬆一下吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……這種時候，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就要找他吧♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "歡迎，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你總算來了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是，為什麼啊？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我沒說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「好的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了」吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛才是基於直覺反應打招呼的對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種事我可是知道的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先不說這些。",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今天我有事情想要拜託你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──幫我揉揉身體。",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當我沒說。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我剛才的說法有誤。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是按摩！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想請你幫我按摩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你一臉「怎麼那麼突然」",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的樣子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我偶爾也是會有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想慰勞自己的時候嘛！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然是你，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該也做過按摩的打工吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就想說請你幫個忙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n陪我維護……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "陪我放鬆一下吧♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就知道你會這麼說。",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你扳了手指",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又轉動肩膀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看起來",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幹勁十足呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n難不成",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "手法很專業嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的技能樹到底變成什麼樣子了？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你是不情願嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會找你來當然是有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正當理由的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……因為我做了一個夢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就拜託你囉。",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想想，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在你幫我按摩的期間，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就來確認嚮導小妖精的功能部分──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──嗯嗯！？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒什麼喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你繼續吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這傢伙的按摩技術是怎樣啊！",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這不是害我發出怪聲了嗎……！　",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不行不行，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要專心要專心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先把控制台全部打開，來確認功能",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n得確認一下",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個按摩是否會對身體的感覺造成異常──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哇啊……！？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……呼、",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呼。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝、",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "謝謝你……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "按摩",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經很夠了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "身體似乎完全沒問題。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也做了很多系統的確認，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但沒發現什麼奇怪的地方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是說，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會做夢果然只是偶然……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個控制台是什麼？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有打開這種東西嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──登出？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「登出」！？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n…………",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒什麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不需要在意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我只是有點驚訝，",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為這是現在沒在運作……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "理應不會運作的功能。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有這個功能其實並不奇怪。",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為這副身體",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原本是屬於玩家的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於只存在這個世界的我來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是毫無關係的功能呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "老實說……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許有點",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "遺憾。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果真的可以登出，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在「另一邊」見到你的話……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──！？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是怎麼回事？",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "控制台自行啟動了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是什麼都沒碰喔！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "意識",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "逐漸遠離了……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該不會──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的──",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}──！",
        "unit_id": 190011,
        "voice": "vo_adv_1340001_050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "菲歐的意識如同被引導至某處般遠離世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她所抵達的地方是──"
    },
