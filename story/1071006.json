[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結婚模擬演習開始後過了幾天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n難得休假不用工作的克莉絲提娜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不知為何眉頭深鎖。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天小子要工作……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是時候來挑戰看看「那個狀況」的模擬演習了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "老實說，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有些提不起勁。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然好不容易潛入了「結婚」的內部，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但現在準備面對的恐怕是……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "整座城寨的大本營。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我連該如何進攻，都毫無頭緒。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果可以，真希望能避開與之一戰……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和小子共度的人生，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "發生什麼始料未及的事都不奇怪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若要以不在計畫內為由，放棄去面對，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣決定恐怕過於草率。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是不得不來面對",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n「家庭主婦」的模擬演習啊──！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "歡迎光臨，盡量看喔！",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果在比較早的時間帶來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "商品會比較齊全嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "唷，這位大姐，",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_009"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "妳頭髮很漂亮耶！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……是嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼哼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最近確實有在好好進行保養哪♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其實我自己也能明顯感受出變化。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在小子開始會幫忙弄乾我的頭髮後，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n髮絲摸起來的滑順度完全不同……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呵呵♪",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好～",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就來像個專業的家庭主婦，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "準備些費工夫的好料，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好好慰勞小子吧☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大叔，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "麻煩你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n幫我打包那邊價格較高的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要買兩人份。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "這必須",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_015"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "經過燉煮才能吃喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n要花費上不少時間，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "妳確定要買這個嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我有的是時間。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "謝謝惠顧～！",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟就算是沒什麼大不了的東西，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他也都一副很感激的樣子啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真期待小子那張開心的臉哪……♪　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "對了，",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_019"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "大姐。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "如果我認錯人，還請別介意，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "但妳是不是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "那位克莉絲提娜啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我確實是，怎麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "果然沒錯！",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_021"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n我就一直在猜想會不會是本人。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "慈樂之音的著名製作人，",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_022"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "怎麼會大白天跑來這種地方呀？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "稍微來看看而已。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_023"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "想必是趁工作空檔來逛一下、喘口氣吧？",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_024"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "那就",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "慢慢逛吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "果然，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一般不會把我跟家庭主婦聯想在一起",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "若說家庭主婦的本質，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是想著讓對方開心，因而下工夫完成事情的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跟製作人",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這一行確實有共通之處。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "莫非，家庭主婦……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其實是",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相當適合我的工作……！？　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼說起來，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要取悅的對象只有小子一人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是說，我現在是小子專屬的製作人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說了不像我會說的話……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真教人難為情哪……！　",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，等到{player}回家後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們倆便同桌享用克莉絲提娜親手做的料理──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你中意真是太好了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我今天進行了家庭主婦的模擬演習。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為時間多的是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我試著從熬湯頭開始做起。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想這應該能滋潤你疲憊不堪的身體才是。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很意外嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別看我這樣，我的家世還不錯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n或許是舌頭被徹底訓練過一番的關係，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大部分的料理我都做得出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……茶也很好喝？",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你發現了嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其實是我在田裡除草時，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "發現那邊長了很多藥草。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想說直接丟掉很浪費，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就拿去稍微曬了一下，並試著烘焙成茶葉泡泡看。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果你覺得好喝，代表成功了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下次",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或許可以嘗試烘焙更久一點……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──這麼說來！",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n樹果也都相當成熟了喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我試著把果實拿來醃漬了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n大約醃一個禮拜，就會軟得恰到好處。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且除了果實本身以外，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "醃漬過後的汁液也很有利用價值喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以拿去加進麥酒裡……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也能在備料時用在肉上──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──怎麼？",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……看起來很開心？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說我嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果在你眼中是如此，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那我應該是真的很開心吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "老實說吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我原本其實對這個家庭主婦模擬演習，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感到有些提不起勁。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟有誰會想到，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個主張及時享樂的克莉絲提娜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟能待在家中一整天呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不管是什麼事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都得親身體會一次看看才知道呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當正面去面對一件家事時，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "下一個課題和點子就會像拔番薯一樣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一個個接連冒出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最關鍵的是做事流程以及所下的工夫。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要找對切入點，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就能夠效率加倍地做出成果。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這一切和所謂無聊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可謂無緣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n更何況……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以在如此近的距離下，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看到對方開心的表情……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……噢，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒什麼。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總而言之──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "家庭主婦的工作，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有趣得令人驚訝呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們現在可以說是平安通過了",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這場結婚模擬演習的最大難關──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……怎麼了？",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n會辣？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "肉會辣嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不記得有加會辣的調味啊……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我嚐嚐看。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──這是……！",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "肉被施加了會變得超辣的魔法……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟是誰做出這種──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難不成……！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "慈樂之音的著名製作人，",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_059"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "怎麼會大白天跑來這種地方呀？",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那家肉舖牆上貼的海報……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是將慈樂之音視為勁敵的偶像……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "上面還有親筆簽名……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我原本還以為老闆只是個追星大叔……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那傢伙，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真敢啊……！　",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大叔，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "──喔！？",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "昨天謝謝你賣給我那麼棒的肉啊。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想來跟你道個謝。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "喔……",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_066"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "喔、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "好。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "很、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "很好吃對吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好吃到我都不禁想拔劍了呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "咿、",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_068"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "咿呀──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你難道以為只要傷害到身為慈樂之音製作人的我，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你主推的偶像就能夠大紅大紫嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "咿啊啊……",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_070"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "對不起、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "對不起……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是欠缺思慮。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好啦，你想怎麼選！",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_072"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是要發誓不會再犯第二次？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還是想被砍成肉塊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "擺在自己的店裡銷售？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我話先說在前頭……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_073"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為我把那塊上等好肉也讓我老公吃了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我今天心情超級好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可以花時間慢慢料理你喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "我再也不敢這麼做了～～！",
        "unit_id": 1411,
        "voice": "vo_adv_1071006_074"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n真的很抱歉～～～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哼。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_075"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_076"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再也不敢……",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_077"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算讓那個大叔發下這種誓……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有人對我進行騷擾，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_078"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "根本是稀鬆平常的事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n大叔那種的還算是小意思了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且不只是和慈樂之音相關的事。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_079"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對需要站在前線的我而言，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可說是隨時都在樹立敵人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不如說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "周遭幾乎只有敵人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嫉妒、",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_080"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "敵意、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "惡意……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我早已習慣別人對我抱持著這些感情了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "甚至我根本覺得無所謂。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_081"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有種就儘管放馬過來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看我用反擊把他們通通一刀兩斷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至今為止……我都是抱著這種想法一路走來。",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_083"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至今為止……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_084"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不曉得小子他舌頭的疼痛，",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_085"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有沒有減緩了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071006_086"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天，克莉絲提娜踏在歸途上的步伐，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n是前所未有的沉重──"
    }
]