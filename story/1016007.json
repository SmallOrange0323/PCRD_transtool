[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}正在散步時――"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……該怎麼辦呢？",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，這不是秀才嗎！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，能剛好在這裡遇到你，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n真的太好了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我說我說，可以跟你商量一下嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家有個模特兒夥伴，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n最近交了第一個男朋友喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是呢――她說不知道該怎麼跟男朋友相處。",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以就來找人家商量了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家既沒交過男朋友，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n也沒有約會過，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以沒辦法給她建議……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，難得她來拜託人家了，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n多少會想給她點建議對吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n成為人家的男朋友吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人――家――是――說――！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n裝成人家的男朋友一天，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一起去約會！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣的話，說不定就能掌握一些線索？",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是這樣，要先把下次的休假時間空出來喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n麻煩你囉～",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂～秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "非常準時！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不愧是秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家？",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也是剛到喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼趕快來約會吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～？你說還沒決定要做什麼嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒問題，人家已經想好約會行程了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "首先，先去各種商店，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n逛逛街之類的。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家想先看看現在正流行什麼樣的服飾。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，出～發！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_014"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "走滿久了呢～",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "腳都痠了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且也快到中午了～",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "休息一下吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那、那個……",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家有做便當帶來，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就吃那個好嗎？ ",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可以吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就在這附近吃吧～",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "給你，這是秀才的份喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然人家還挺有信心的……",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n如、如何？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "騙人！？那不是很糟糕！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家應該沒有放毒進去啊！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？你是說很好吃的意思？",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "直接那樣說不就好了嗎～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n嚇死人家了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說什麼呢，好好笑～",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才說得太誇張了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家反而覺得有點假。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……呃，可是，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不會不高興啦？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "別看人家這樣，平常也是有在做菜的。",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果是簡單的料理，人家大致上都會做喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是……能合秀才的胃口",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是太好了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是人家第一次",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n做菜給弟弟以外的男孩子吃，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以非常緊張……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說好要去約會後，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家一直很在意各種細節呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "像是去哪裡秀才會高興、",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "便當裡放什麼秀才會開心之類的～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想得太多，覺得腦筋都要秀逗了……",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，包含這些事情在內，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n今天過得很開心唷～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "――啊！原來如此！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家好像懂了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為對方著想，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n拼命地思考對方的事，才是最重要的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣的話，無論做什麼都會很開心對吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你，秀才！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n多虧了你，人家好像可以給模特兒夥伴不錯的建議了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "下次再讓人家回報你吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！ 再來約會一次吧！",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n下次人家一定會比這次更有幹勁！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一定會帶給秀才滿～滿的開心，",
        "unit_id": 101611,
        "voice": "vo_adv_1016007_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n所以好好期待吧！",
        "unit_id": 101611
    }
]