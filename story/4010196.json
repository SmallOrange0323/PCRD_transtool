        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……太……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "太好了～～～～～～～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n謝謝你～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這真是最棒的生日！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "到此",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
