        "voice": "vo_adv_4010196_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嚇我一跳……！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣突然握住我的手，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很犯規耶？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣子，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "總覺得……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "變得所向無敵了！　",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "生日之力！",
        "unit_id": 101332,
        "voice": "vo_adv_4010196_009"
    },
