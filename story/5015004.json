        "voice": "vo_adv_5015004_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼回事？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n他的動作突然變慢了……？　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿、咿咿咿咿咿！",
        "unit_id": 109511,
        "voice": "vo_adv_5015004_067"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n我覺得",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "他一直在追著我來啊啊啊……！！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這種厭惡感",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "又帶給空花全新的快感……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是好機會！",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妮諾！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "　拜託妳支援撤退！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "交給我吧！",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_069"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n忍法！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　煙霧彈！！！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "哼……",
