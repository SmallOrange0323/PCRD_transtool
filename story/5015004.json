        "voice": "vo_adv_5015004_070"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "是煙霧彈嗎！？",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咳咳……",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_071"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來、",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "各位！！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n趁現在逃走……",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咳咳咳！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳、",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_072"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳為什麼自己吸進最多煙啊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊，真是的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "總之撤退吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n步未就交給閣下了！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "讓她們逃了啊……",
