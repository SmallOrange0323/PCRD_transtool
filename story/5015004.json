        "voice": "vo_adv_5015004_073"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "算了。",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n這樣也算",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "給那些人類殺雞儆猴了吧。",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "這樣一來就沒人敢再違抗我，",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_074"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "我的統治就是真理……",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "呵呵…",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "哇哈哈哈哈哈！！",
        "unit_id": 11411
