[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出了茶館後，【純白之翼 蘭德索爾分部】和\n{player}來到了傳來尖叫的地方。\n那裡聚集了許多人，有兩個人在正中間。"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "惡代官大人……",
        "unit_id": 2511,
        "voice": "vo_adv_5015004_000"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "就是這裡。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "喔，",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_001"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "這裡就是",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n無視我的命令，那個沒禮貌的店家嗎。",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……引起騷動的",
        "unit_id": 105511,
        "voice": "vo_adv_5015004_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像是那間店呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "男人們",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像正在說些什麼……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊，",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我認識其中一個人！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "他是大江戶町的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "町長！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n他出身於蘭德索爾，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很努力的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "想讓這個町\n有更好的發展，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是個好人喔♪",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "旁邊那個被稱為惡代官的人",
        "unit_id": 100811,
        "voice": "vo_adv_5015004_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明顯的很不美麗呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n好像不是人類，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也好像不是魔族。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……我也",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒有見過……",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n總覺得",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非常可疑！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "惡代官……",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在剛才書店看到的《武士之路》書上，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "寫說是東國的官員，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但做盡壞事，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n被東國的英雄制裁了呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "正因為如此的暴虐無道，",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個詞好像就成了",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "東國壞人的代名詞。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可、",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "管理這個町的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是町長，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再說了，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個町",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "根本沒有惡代官！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那、",
        "unit_id": 109511,
        "voice": "vo_adv_5015004_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "那麼說來，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n那個同名的人",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "到底是什麼人啊……？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "上納金遲繳第二天……",
        "unit_id": 2511,
        "voice": "vo_adv_5015004_010"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "這次就給予規勸。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n那麼，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "我去喊老闆出來……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "沒那必要，",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_011"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "現在就毀了這裡。",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "怎麼可以……！？",
        "unit_id": 2511,
        "voice": "vo_adv_5015004_012"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n上納金遲繳",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "不是最多可以延一週的……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "我已經",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_013"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n說沒有必要了……",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "你沒聽見嗎？",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "可、",
        "unit_id": 2511,
        "voice": "vo_adv_5015004_014"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "可是……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "不，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "我知道了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "嘻嘻嘻……",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_015"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "這個城鎮裡",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n不需要違抗我的人……",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "哈～哈哈哈哈！！",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個惡代官",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "打算毀了那間店！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "去阻止他吧，",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "全部的人跟我來！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我對這種粗暴的行為",
        "unit_id": 100811,
        "voice": "vo_adv_5015004_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n是不太感興趣的，不過……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "嗯？",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_019"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "　你們有什麼事？",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到此為止了，壞人！",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你如此欺負百姓，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我身為榮耀的【純白之翼】一份子，絕對饒不了你！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要逮捕他，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "然後交給【王宮騎士團】！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要你老實",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n繳納",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "年貢！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "是別的城鎮的人嗎……",
        "unit_id": 2511,
        "voice": "vo_adv_5015004_022"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "不能反抗惡代官啊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "惡代官大人認真起來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n會毀了大江戶町的……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "你們現在立刻離開！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "原來是這樣啊……",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "各位，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們放心吧！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n因為我們有",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天下的英雄，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也就是將軍陪同！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "將、",
        "unit_id": 2511,
        "voice": "vo_adv_5015004_024"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "將軍……！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n是說統一天下，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "帶領國家邁向太平之世的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "東國之王……！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "妳、",
        "unit_id": 11411,
        "voice": "vo_adv_5015004_025"
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "妳說什麼！？",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "　我可沒聽說這個城鎮有將軍啊！",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "只聽說就是稍微威脅一下，隨我勒索錢財，",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "惡代官",
        "words": "\n這和說好的不一樣啊！！",
        "unit_id": 11411
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 109511,
        "voice": "vo_adv_5015004_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感覺他的",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n態度突然改變了呢。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "《武士之路》上記載",
        "unit_id": 105311,
        "voice": "vo_adv_5015004_027"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種人畏懼權力……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還真是典型的惡代官呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就用你的眼睛看仔細了！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這位就是",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "天下的將軍大人！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將、",
        "unit_id": 109611,
        "voice": "vo_adv_5015004_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n你太內歛了！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　",
