[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～",
        "unit_id": 128411,
        "voice": "vo_adv_5134308_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "睡得很舒服～！！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n雖然還是一樣搞不清楚自己夢到了什麼！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但果然",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是要飛到宇宙空間比較好嗎？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……好，",
        "unit_id": 128511,
        "voice": "vo_adv_5134308_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就這麼辦吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n剛剛的那些夢就當作不存在。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n看來還是本來的作戰計畫比較合理，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那我們就不更動了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不，",
        "unit_id": 128311,
        "voice": "vo_adv_5134308_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳是說我巨大化之後，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再用光束破壞隕石的預知夢比較合理嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "冷靜地思考的話，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我覺得這兩個都差不多喔？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "祈梨，",
        "unit_id": 128511,
        "voice": "vo_adv_5134308_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這只是很初階的推理喔。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這次事件從起因開始，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是討壓歲錢後，\n卻被搞錯導致隕石掉下來。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如此不合理，狀況又很莫名其妙的事件。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以說，",
        "unit_id": 128511,
        "voice": "vo_adv_5134308_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事情就是這樣……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事到如今再說那些枝微末節的事也沒有辦法！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n現在只能盡力去做我們能夠辦到的事，沒有別的方法了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們就當作根本沒有那些夢吧……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣妳明白嗎……？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "感覺",
        "unit_id": 128311,
        "voice": "vo_adv_5134308_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她好像整個人都要精神錯亂了呢……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "得在小霞崩潰之前，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "趕快把事件解決掉比較好。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "說得也是呢！",
        "unit_id": 128411,
        "voice": "vo_adv_5134308_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n為了在這次",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "夢到正確的預知夢……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "全力地……！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕────────！",
        "unit_id": 128411,
        "voice": "vo_adv_5134308_007"
    }
]