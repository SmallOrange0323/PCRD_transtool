[
    {
        "type": "background",
        "background": "501630"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "嗚欸欸欸欸欸！！！",
        "unit_id": 191411,
        "voice": "vo_adv_9100117_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豪紳先生！",
        "unit_id": 105811,
        "voice": "vo_adv_9100117_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n他被打飛了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太、",
        "unit_id": 106411,
        "voice": "vo_adv_9100117_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太厲害了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這就是魔法少女的力量嗎……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了啦，",
        "unit_id": 106011,
        "voice": "vo_adv_9100117_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在不管那種笨蛋了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比起那個，可蘿仔，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有發現索爾魔珠嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有的。",
        "unit_id": 105911,
        "voice": "vo_adv_9100117_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是第五顆了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "哎呀。",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_005"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n豪紳先生，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "看來你被教訓得很慘呢。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "呵呵──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "簡直就像一塊破抹布。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "彌勒……！",
        "unit_id": 105811,
        "voice": "vo_adv_9100117_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的夥伴被傷成這樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有什麼好笑的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "呵呵……",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_007"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "打從一開始我就對豪紳先生不抱任何期待。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n只是有趣的人變得更有趣了，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n所以我盡情活用了而已。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "比起這個。",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_008"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n你們從我這裡搶走了",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "嚮導小妖精的進化體……",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n看來是她招來了不速之客啊。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哼！",
        "unit_id": 190011,
        "voice": "vo_adv_9100117_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n之前還真是承蒙你關照了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看見你有好好收到謝禮，我很高興呢！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "嗯，",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_010"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "彼此彼此──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n我才要對你們的勇猛果敢",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "表示感謝呢。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說什麼……？",
        "unit_id": 100311,
        "voice": "vo_adv_9100117_011"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "仔細想想，",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_012"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "從【憤怒‧軍團】被摧毀的那個晚上開始──",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n你們屢次逃出我的手掌心，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "一路反抗到現在。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "這種頑強、",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "僥倖的程度，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "簡直能稱得上是「奇蹟」了。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "呵呵……",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_013"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "哎呀，",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "太人令愉快了。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n在這個學問與研究揭示各種現象",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "而被體系化的末世裡。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n只有毫無道理的「奇蹟」",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "才能讓人感受到神的存在。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "來吧。",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_014"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n在我奪走你們的靈魂之前。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n把你們的價值、",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "勇猛果敢、",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "「奇蹟」",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "──再展現給我看看吧。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嗄喔喔喔喔喔！！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105911,
        "voice": "vo_adv_9100117_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又有新的一群魔物了……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可、",
        "unit_id": 100111,
        "voice": "vo_adv_9100117_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n索爾魔珠就在它們身上對吧！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等一下，日和！",
        "unit_id": 100211,
        "voice": "vo_adv_9100117_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這次",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像是很多隻魔物",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "守著一顆魔珠……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "光是要擊倒一隻，",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_018"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "你們似乎就消耗了不少。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "那這次就同時讓兩隻",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "當你們的對手吧。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼會……",
        "unit_id": 106411,
        "voice": "vo_adv_9100117_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "已經",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒時間了！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "用不了多久，",
        "unit_id": 192613,
        "voice": "vo_adv_9100117_020"
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "世界就會在巨神的火焰中化為灰燼。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "\n",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "這次就用你們臨終的模樣",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "彌勒",
        "words": "好好取悅我吧。",
        "unit_id": 192613
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼！",
        "unit_id": 106011,
        "voice": "vo_adv_9100117_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他休想如願以償……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剩下的三顆索爾魔珠……",
        "unit_id": 105811,
        "voice": "vo_adv_9100117_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們快點奪回來吧！！",
        "unit_id": 105811
    }
]