        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "趕快回去吃事先留下來的布丁吧～♪",
        "unit_id": 108211
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁布丁～♪　",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子的布丁正在等著我～♪",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯？　",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那是什麼聲音？　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "今天伊莉亞她們應該不在才對……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……咦，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}！？　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你怎麼會在這裡……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_024"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你、你手上拿著的……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是宮子的布丁！？",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "地、地上也有被吃的精光的容器～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "空的、",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_025"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "空的、",
