    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}正在鬧區買東西，\n此時，跟平常不太一樣的宮子來到了他的身邊。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}！　終於找到你了～！",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有件事想要問你所以才到這裡來的。",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n{player}有害怕的東西嗎？",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我、",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我沒有什麼特別的意思喔！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有點好奇而已！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好啦，快點回答吧！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "魔物嗎～？",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "都幾歲的人了，居然還會害怕魔物，真是沒用來的～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "幽～靈～？　",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你怕那種東西嗎～？　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真是沒用的傢伙來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "幽靈什麼的到處都有喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子啊，總是看得到喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好土唷，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你這個笨蛋！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家本來想像的是更恐怖的東西，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "害我失望了呢！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就當是為了沒用的你，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只好告訴你宮子害怕的東西來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n現在的你，一副很想知道的表情喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子很溫柔來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "把耳朵挖乾淨聽得更清楚一點喲！",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你可別跟其他人說喲！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "把耳朵靠過來吧！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一直以來我都沒跟你說……",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "其實宮子啊……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "最害怕布丁來的……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那、那是以前的我啦！　",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "最近才開始討厭的喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真的啦～！",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊啊啊啊啊，布丁好可怕來的～！！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只要一想到布丁，我就會覺得不太舒服喔！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n特別是萬聖節限定的布丁最可怕來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "明明就只是個布丁，卻使用了最上等的南瓜呢！",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那滑順濃醇的甜味跟生奶油簡直就是絕配，驚為天人喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可以說是只有這個時期才能吃到的",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "特別布丁來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊？",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那表情……你不相信我嗎？　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子真的很怕布丁來的！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚……",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "光是說了布丁的事我就快要掛了……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我要回去了……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "呵呵呵……",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "看來進行得很順利呢。",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "超完美來的！　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子是個天才來的！！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "　",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "演技派來的～！！！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只要說成這樣，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為了讓宮子感到害怕，",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n應該就會特地準備很～多的布丁才對喲！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "萬聖節限定布丁……",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好期待來的～",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊嗚……",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一想到布丁的事，就突然好想吃喲。",
