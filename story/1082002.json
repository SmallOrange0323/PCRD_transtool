    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "作戰失敗來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚嗚嗚，",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_029"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家不行了……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "對任何事情都提不起勁……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子的未來是一片黑暗來的……",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我的人生只為了萬聖節限定布丁存在的說……",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_030"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦！　真的嗎！？",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "太好了～",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "{player}果然是個好人來的～！",
        "unit_id": 108211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可以吃到布丁了～♪　",
        "unit_id": 108211,
        "voice": "vo_adv_1082002_033"
    },
    {
        "type": "dialogue",
