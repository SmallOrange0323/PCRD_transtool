[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【惡魔偽王國軍】的成員們，\n被伊莉亞召喚而來到了古城。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼現在開始【惡魔偽王國軍】的",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n征服世界會議！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍一行",
        "words": "征服世界會議？",
        "voice": "vo_adv_3014003_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。奴家的外表還是個小孩。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n加上主君，戰力只有6個人。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果一股腦地就想征服世界，也是前途堪慮。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以奴家想聽聽看大家的策略。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "允許你們呈報作戰計劃，儘管說說看。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "首先是忍！有沒有什麼想法？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "首先把所有男人都給殺了。",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。男性的戰鬥力的確比較有偏強的傾向。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "所以說先把這個小毛頭給殺了！",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n嗚喔喔喔喔喔－－－－－！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不要胡鬧了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唉唷！忍好恐怖！",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼啊，原來不是忍的意見，而是骷髏老爸的啊。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "下一個！宮子！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯～？",
        "unit_id": 100711,
        "voice": "vo_adv_3014003_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子覺得布丁很重要～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "布、布丁？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "把全世界的布丁都收集到這裡來！",
        "unit_id": 100711,
        "voice": "vo_adv_3014003_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這樣大家就會為了想吃布丁",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n而乖乖聽話了～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "首先要掌控糧食的流向啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "但就算大家乖乖聽話也拿不到布丁～！",
        "unit_id": 100711,
        "voice": "vo_adv_3014003_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子會全部吃光光～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這、這真是暴政啊……",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "下一個！茜里！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里覺得要征服世界的話，制服很重要喔～",
        "unit_id": 100611,
        "voice": "vo_adv_3014003_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為了征服，制服很重要？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……啊，衣服的制服啊？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n原來如此，軍隊的確可能需要有統一的軍服。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，怎樣的制服比較好呢？喜歡比較短的裙子嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_3014003_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n兩件式可以露出肚子的比較好對吧～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥、哥哥，你的視線好色喔～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那種軍裝應該一點都不適合戰鬥……",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n駁回茜里的提案！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "下一個是依里！妳要如何作戰？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個的話……缺乏戰力的話，長期作戰很困難，",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以還是速攻比較好。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「開始瞬間就具攻擊性！」是作戰的基本。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔喔！非常認真的戰略嘛！",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是可靠～",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過防禦也是很重要呢。",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有句話說得好「徹底守備即勝負關鍵」。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "把防禦和恢復還有除去都加入卡組當中……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯、嗯……？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n說得好說得好……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卡組？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "結果還是要看使用什麼樣的玩法呢。",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "考量卡片能力、穩固盤面，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n做到發動連續攻擊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那不是卡片遊戲的必勝法嘛！",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也駁回依里的意見……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "主君怎麼想呢？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，也就是說信任奴家。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不愧是奴家的僕人。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你應該只是懶得思考吧？",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼！是那樣嗎！？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那種態度怎麼行呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔喔！真是可靠！",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "具體來說是怎樣呢？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……沒有任何具體的提案啊。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這個笨蛋－－－－！！！！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "從剛剛就一直批評，",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那伊莉亞有什麼意見嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，那當然了！那最後就讓奴家說出超棒的提案吧。",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聽好了。那就是……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "主君和奴家結為夫妻！",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_033"
    },
    {
        "type": "dialogue",
        "name": "忍一行",
        "words": "欸！",
        "voice": "vo_adv_3014003_034"
    },
    {
        "type": "dialogue",
        "name": "忍一行",
        "words": "？"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在剛剛的戰鬥中，奴家變回原本的樣貌不是嗎？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "奴家思考了一下原因，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "應該是因為主君的關係。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "奴家不知道詳細原因，也不知道因何而起，",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但只要主君在奴家身邊，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n奴家一定可以變回原本的樣貌！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣等於實現了征服世界！",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不管是人類還是魔物還是神明，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n都沒有什麼好怕的了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哇哈哈哈哈哈！如何？很棒的意見吧！？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不行！",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_039"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不行啦～",
        "unit_id": 100611,
        "voice": "vo_adv_3014003_040"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不可以～！",
        "unit_id": 100711,
        "voice": "vo_adv_3014003_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不行！",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為、為什麼？",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們不想征服世界嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那根本無所謂！",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_044"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而、而且那傢伙和伊莉亞結為夫妻……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n太不要臉了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你是宮子的僕人～",
        "unit_id": 100711,
        "voice": "vo_adv_3014003_045"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n工作是要幫宮子拿布丁來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不可以和哥哥結婚～",
        "unit_id": 100611,
        "voice": "vo_adv_3014003_046"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "！！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你和伊莉亞結婚的話，",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_047"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我看到那是不吉利的運勢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "無法贊成。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……什麼呀，",
        "unit_id": 104412,
        "voice": "vo_adv_3014003_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳們在忌妒奴家嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不是！",
        "unit_id": 102211,
        "voice": "vo_adv_3014003_049"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才不是呢～！",
        "unit_id": 100611,
        "voice": "vo_adv_3014003_050"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不是喔～！",
        "unit_id": 100711,
        "voice": "vo_adv_3014003_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是！",
        "unit_id": 103111,
        "voice": "vo_adv_3014003_052"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不管是征服世界還是讓伊莉亞回復原貌，\n看來都還蠻遙遠的呢。"
    }
]