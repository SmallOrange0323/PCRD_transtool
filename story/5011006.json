    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}遭到魔物抓走。\n惠理子憤怒發狂地攻擊魔物。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這傢伙、",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這傢伙、",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這傢伙！　",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把我的……",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還回來！",
        "unit_id": 109011
    },
    {
        "type": "background",
        "background": "500601"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呼、",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呼……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對手是黏黏稠稠的巧克力……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不管怎麼斬，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "都完全無法造成傷害……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "醜陋可愛",
        "words": "――咕哦哦哦哦哦！",
        "unit_id": 11011
    },
    {
        "type": "background",
        "background": "500601"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "唔，",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "從尾巴射出了可可果。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被那種東西打中會造成致命傷呢……",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼辦！　",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼辦！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "都怪我，哥哥才會……！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃，",
        "unit_id": 109111,
        "voice": "vo_adv_5011006_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "振作點！",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n首先來思考打倒魔物的辦法吧。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔、嗯……",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說得也是呢，姐姐。",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃……",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我覺得小可是因為",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n來到這個會場聽太多惡言惡語，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以可可亞才會變成魔物。",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來如此……",
        "unit_id": 109111,
        "voice": "vo_adv_5011006_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n而且就算變成魔物以後，",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "似乎也因為聽到惡言惡語而變得更強了。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯。",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要用比至今的惡言惡語",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n還更多的幸福話語灌進牠的心中，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "或許就能阻止牠的失控了？",
        "unit_id": 101111
    },
    {
        "type": "still",
        "still": "501100601"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯！　",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那一定就是",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "魔物的弱點了。",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "看我用愛的力量",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "射穿你！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃、靜流、惠理子",
        "words": "上啊啊啊啊啊啊―――！",
        "unit_id": 1,
        "voice": "vo_adv_5011006_013"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500601"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗚嗚……",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼會這麼慘。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n全身都是巧克力黏答答的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和這比起來，{player}大人呢……！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒什麼大礙。",
        "unit_id": 109111,
        "voice": "vo_adv_5011006_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "似乎只是受到撞擊而有點頭暈。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呼，",
        "unit_id": 101111,
        "voice": "vo_adv_5011006_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太好了～",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "魔物的話，",
        "unit_id": 109111,
        "voice": "vo_adv_5011006_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "已經被我們打倒了，放心吧。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}",
        "unit_id": 109111,
        "voice": "vo_adv_5011006_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就躺在姐姐的大腿上",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好好休息吧。",
        "unit_id": 109111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "比起自己，居然先關心我們的樣子……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，我比較擔心{player}大人的身體。",
        "unit_id": 109011,
        "voice": "vo_adv_5011006_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓我好好看看",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您的身體吧……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_5011006_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喂～！　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳想趁亂做些什麼啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "三人再次圍繞著{player}展開爭論，\n但她們臉上都充滿了開朗的笑容。"
    }
]