        "voice": "vo_adv_2107005_048"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈，果然是這樣。",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_049"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n用這種露了餡的手法，未免也太無趣了吧，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "七冠小姐？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的能力為你們所知……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你認為這就是我的弱點嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "可可蘿？",
