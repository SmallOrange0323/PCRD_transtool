[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──似似花的祕密據點──"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……唔……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖說是分身，",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n被迫吃了那麼多可麗餅，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還是會覺得胸口悶悶的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……話說回來……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……豪紳議長。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真沒想到",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他會採取那麼武斷又強硬的手段……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我早已清楚知道",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他是個無能的人。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就我的推測，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應當是有人在議長背後暗中操控……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而他是遵照指示來行動的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想不到這項行動",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會敗得如此一塌糊塗。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這麼一來，就沒有讓他繼續逍遙法外的價值了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的推測是否正確，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要之後透過審問等方式，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該就會知道了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就等到守衛鬆懈時……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再來進行吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再說……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "豪紳議長的叛亂",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也不是完全沒有作用。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這次的騷動，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不僅讓王宮更加團結一致，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也加深了",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "貪吃佩可對我的信任。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無論是防止真那脫逃，",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是扮演替身的任務……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n以及，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次騷動中失勢文官們的後任人選之中，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要適度安插我的分身頂替……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呵呵，",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那麼這個國家的實權",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "儼然就掌握在我手上了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你明白嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "議長。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所謂的陰謀，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是在無聲無息中進行的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不讓任何人有所察覺……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這才是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陰謀啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "蘭德索爾的實權。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真那的知識與魔力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這一切可以說都已經是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的囊中物了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "接著，",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最後……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是完成我最大的目的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要得到「她」……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就能結束",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這項「禁錮」了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……米奈娃。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "她現在到底",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在哪裡啊……？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「她」沒有待在索爾之塔，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n目前唯一的線索，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就只有{player}了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n魔法的警報裝置",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有了反應……",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我早就料到你差不多會來找我了，",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "【憤怒‧軍團】。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正好我也覺得",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "老是避著不見面很麻煩。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就在這一帶",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好好來教育你一下吧……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n讓你親身體會到七冠的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可怕之處。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "…………",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_021"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……好了，",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_022"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n變貌大妃的祕密據點就在這一帶嗎……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕噗嚕。",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "若根據情報分析的結果，",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_023"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "她的祕密據點似乎有好幾個。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "其中最接近蘭德索爾的，就是這裡了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嗯，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就算這座森林不是她的據點，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "只要繼續徹底搜查就行。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊──",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_024"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "變貌大妃小姐──？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我送貨來囉──？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是替妳把庭園翻成荒地的服務喔──",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哼。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……我是隨便說說的啦。",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_025"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "反正",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "她也不可能那麼容易上當就跑出來。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "……噗嚕噗嚕？",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "呿、",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_026"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "幹嘛用異樣的眼光看我。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我只是覺得要引誘她出來很麻煩而已。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……那麼，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我們差不多要開始囉。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "──上吧！",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_027"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "垃圾魔獸！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔！！！"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈、哈──！",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_028"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "盡情破壞吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n樹木統統給我連根拔起，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "把那傢伙從地下的祕密據點",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "趕出來吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔！！！"
    },
    {
        "type": "dialogue",
        "name": "史萊姆們",
        "words": "噗嚕噗嚕……噗嚕？",
        "unit_id": 191612
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啥？",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_029"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你們從剛剛就在吵什麼啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n是肚子餓了嗎？",
        "unit_id": 191611
    },
    {
