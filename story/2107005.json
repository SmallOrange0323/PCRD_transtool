    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若提高威力，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是有可能強行擊潰。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只是……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣就太浪費魔力了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且更重要的是，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣一點都不優美。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要運用我的權限……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就可以想到",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好幾種陷害他的手法。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在智慧上，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他的程度似乎是比豪紳議長來得好一些。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是否要讓他好好嘗嘗",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "膽敢取笑我使用「露了餡的手法」的屈辱呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可們？",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_2107005_062"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "呿，",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_063"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "呼……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "喂，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "怎樣啊！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳的分身全都被我擊倒了喔！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "辛苦你了。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_064"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話雖如此……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你看起來好像很喘的樣子呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這對小孩子來說，是不是負擔太大了？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "少囉嗦！",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_065"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我才不像妳老是裝模作樣呢，蘿莉老太婆。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "又是那句",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "胡言亂語……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈哈。",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_067"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我可是都知道喔？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳的弱點就是容易被煽動！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "換句話說！",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_068"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n只要我多說點屁話，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳就會氣得上鉤",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "而忘了逃跑！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……唉。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_069"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我還以為你要說什麼呢……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是無聊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不管你說我什麼……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我都不痛不癢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來我真的太高估你了。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_070"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這簡直就像是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在跟小丑說話……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啥！？",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_071"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳才是小丑吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n蘿莉老太婆！！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "………………",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……請你更正。",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我才24歲而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n沒理由叫我老太婆……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈！",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_074"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "24歲？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳可是比我多活了一倍的歲數耶！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n不叫老太婆要叫什麼，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "老──太──婆──！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我沒說錯吧？",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_075"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n都24歲了，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "還敢穿得一身超級粉紅！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "丟臉也該有個限度吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "老太婆！",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_076"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n蘿莉老太婆！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n滿腦子粉紅泡泡的小丑蘿莉老太婆！！",
        "unit_id": 191611
    }
]