        "voice": "vo_adv_2107005_054"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "看我把你們打得一個都不剩！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n上吧，垃圾魔獸！",
