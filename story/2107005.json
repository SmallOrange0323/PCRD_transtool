        "voice": "vo_adv_2107005_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這張胡言亂語的嘴巴！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就由我們來當你的對手吧。",
