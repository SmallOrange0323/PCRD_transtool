    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不是？",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_030"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啥，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "難道你們是擔心那個？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我們像這樣大鬧一番，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "變貌大妃那傢伙可能會",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嚇到逃走",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是嗎？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘿，",
        "unit_id": 191611,
        "voice": "vo_adv_2107005_031"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "笨蛋。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n這點小事",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我怎麼可能不會想到。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我可是已經確實查到",
        "unit_id": 191611
    },
