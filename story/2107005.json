        "voice": "vo_adv_2107005_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "………………",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此……",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個名叫卡里莎的少年，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看來不止是會說大話而已。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我這邊的攻擊幾乎無法對",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他所使喚的魔獸群造成傷害，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他似乎是施展了某種特殊的強化魔法……",
