        "voice": "vo_adv_2107005_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我還有不少問題想要請教。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n為何要捉捕",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們七冠呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
