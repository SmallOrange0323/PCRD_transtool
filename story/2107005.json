    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這不是廢話嗎",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "蠢──蛋。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "………………",
        "unit_id": 107011,
        "voice": "vo_adv_2107005_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊，",
        "unit_id": 105811,
        "voice": "vo_adv_2107005_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
