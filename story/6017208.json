    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我想趁在蘭德索爾的時候，",
        "unit_id": 109711,
        "voice": "vo_adv_6017208_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "學習一些這裡的文化。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n有沒有什麼參考文獻",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可以了解這裡的文化和風土民情呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這份文獻紀載的是",
        "unit_id": 109711,
        "voice": "vo_adv_6017208_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "東國……這塊土地的內容吧。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗯，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "裡面有出現",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "忍者和武士這幾個單字。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n我記得",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴也曾經提過一樣的東西……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這是會搬上劇場演出的那種",
        "unit_id": 109711,
        "voice": "vo_adv_6017208_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "兒童文學著作對吧！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n如果是住在這個城鎮的人",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "小時候都會看的書籍，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n應該相當有參考價值。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "謝謝你。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "盟、",
        "unit_id": 109711,
        "voice": "vo_adv_6017208_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "盟約外典第666章",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗎……？",
