    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "ここのところたい焼きの売り上げが頭打ちなのにゃ。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "ここは一つ新しいたい焼きを開発して、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "販路を拡大するのにゃ！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それはいいにゃ！　",
        "unit_id": 104611,
        "voice": "vo_adv_6106201_001"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "中身はお魚を丸ごとぜいたくに使って、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n中身はたくさん生地も薄く……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "って、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "つまり焼き魚だにゃ！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "これじゃたい焼きとは言えなくなっちゃうにゃ～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "激甘たい焼きってことかにゃ？",
        "unit_id": 104611,
        "voice": "vo_adv_6106201_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それなら、",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "プリンみたいにカラメルを塗ってみるのはどうかにゃ！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "カリカリさくさくあまあまで女の子には大ウケするはずにゃ♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "にゃるほど、",
        "unit_id": 104611,
        "voice": "vo_adv_6106201_003"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "おにぎりみたいにおかずを具にするんだにゃ？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "おやつだけじゃなくお昼ご飯にもできちゃうのにゃ！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nこれなら販路拡大間違いなしにゃ！　",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キミってば冴えてるにゃ♪",
        "unit_id": 104611
    }
]