        "type": "dialogue",
        "name": "真步",
        "words": "是為了感謝居住在不可思議之國的聖獸先生",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n給予農作物豐收而舉辦的祭典喔。",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "聖獸先生",
        "unit_id": 110611,
        "voice": "vo_adv_1106001_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總是會用溫柔的眼神，",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一直",
        "unit_id": 110611
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "守護著",
