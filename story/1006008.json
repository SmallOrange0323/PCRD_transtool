    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里覺得怪怪的……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n已、已經……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不行了――！？",
