        "voice": "vo_adv_1006008_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里在正式演奏時也會加油喔！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里在正式演奏時也會好好加油的，",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以哥哥也一定要來聽喔！",
