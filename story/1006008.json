    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……呼。",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "完全不行……",
