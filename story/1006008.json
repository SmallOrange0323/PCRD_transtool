    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣下去的話，我就糟糕了……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，哥哥！",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你好，真是巧呢。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為見到哥哥了，茜里終於有精神了呢 ♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸！？",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嘻嘻，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n任何事都會被哥哥看透呢。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實……這次因為社團活動",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里要參加遊樂園的儀隊演奏……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以我一直在練習，",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是怎麼樣都吹不好……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有了！",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里現在來試吹一曲，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥要告訴我感想喔！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！謝謝哥哥！",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不愧是哥哥！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "只要告訴我感想就好了。",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為茜里一直都是自己一個人在練習，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n自己也不知道吹得好不好……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒有哥哥就搞不定。",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯？拜託啦。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，茜里馬上吹囉？",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎、怎麼樣……？",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我吹得好嗎……？",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真的嗎？",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太好了！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嘿嘿。",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里只要想到是為了哥哥吹的，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就能比平時更加輕鬆地演奏。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "正、正式演奏時是在大庭廣眾面前……",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里只要一想到被很多不同的人看，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就會開始心跳加速……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後茜里就會因為太過緊張，",
        "unit_id": 100631,
        "voice": "vo_adv_1006008_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n無法順利演奏。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，因為被哥哥誇獎了，所以整個都有自信了！",
