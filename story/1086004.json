    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並守護她喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟這可是難得的聖誕季節啊。",
