    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥知道嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "記、記憶……",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒聽過那東西，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是什麼？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯……",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是『闇影』偶爾會掉落的，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "某人的記憶結晶嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還有那種東西啊～",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥明明喪失記憶了，卻只知道些奇怪的事呢？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "『闇影』掉落的就表示……",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是那個消失的，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和我一模一樣的『闇影』掉的嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "然後，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不知不覺間掉進我的衣服裡……嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀？",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有、有什麼東西在發光啊，哥哥！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇哇！",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個叫做記憶碎片……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "的東西也在發光！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這怎麼回事？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好耀眼～！",
        "unit_id": 108611
    },
