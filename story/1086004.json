        "type": "dialogue",
        "name": "綾音 ",
        "words": "我的話還好，",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_079"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但是哥哥很重所以搬得很辛苦？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇！仔細一看，哥哥就睡在我旁邊！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "以胡桃的力氣來說，",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_080"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "把哥哥搬到這裡就是極限了吧。",
