    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然有點早，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但還是祝你聖誕節快樂♪",
