        "voice": "vo_adv_1086004_078"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是胡桃的字。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我突然睡著了，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以她努力把我搬到床上……的？",
        "unit_id": 108611
