        "voice": "vo_adv_1086004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不該讓現在的你看到的重要回憶，要怎麼辦呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，對於綾音……",
        "unit_id": 190011,
        "voice": "vo_adv_1086004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你基本上似乎一直",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n都只是扮演著可靠又溫柔的哥哥。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以應該沒有播放出",
        "unit_id": 190011,
        "voice": "vo_adv_1086004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n世界的真相或是深刻的心理陰影等內容的可能性。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但就算如此，也得小心才行。",
        "unit_id": 190011,
        "voice": "vo_adv_1086004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為你可是特殊的存在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以取回記憶的工作也該仔細慎重地進行……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算對現在的你說這些也很莫名其妙吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之也好。",
        "unit_id": 190011,
        "voice": "vo_adv_1086004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然和噗吉所說的意思上不一樣，",
