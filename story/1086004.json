[
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音受到與自己一模一樣的『闇影』所託付，收下要送給父母的禮物後，\n便立刻前往自己的家。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音的父母溫柔地迎接離家出走的女兒，\n並為禮物感到非常開心。\n接著，還邀請了綾音一起參加慶祝聖誕節的派對。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音因不忍拒絕，而久違地與父母一塊用餐。\n綾音和父母自始至終都帶著笑容，幸福的氣氛就這麼持續下去。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在用餐過後，父母雖然很捨不得地挽留了綾音，\n但是「我必須把別人託我買的東西送回去才可以」\n綾音如此說道，便返回了【咲戀育幼院】。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我回來了～……",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀哇！",
        "unit_id": 108511,
        "voice": "vo_adv_1086004_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "歡迎回來，綾音……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎、怎麼了嗎？　",
        "unit_id": 108511,
        "voice": "vo_adv_1086004_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "難道受傷了嗎？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為何會被{player}哥哥背著呢……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我沒有受傷，別擔心。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是感覺",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有點累了……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這、",
        "unit_id": 108511,
        "voice": "vo_adv_1086004_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣啊……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們是有接到聯絡，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我記得好像是綾音和父母一起吃飯了……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我本來以為是不能太深入的問題，",
        "unit_id": 108511,
        "voice": "vo_adv_1086004_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以才沒有多問什麼……",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是綾音，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳和父母的關係不好嗎……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是的……",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n爸爸和媽媽",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都非常地寶貝我。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是我",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒辦法坦率地接受他們的愛情。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃的爸爸媽媽因為『消失』，\n所以不見了……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我得多注意才行。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那種話題，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是別說太多比較好呢。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "畢竟胡桃",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就算想見爸爸媽媽也見不到啊。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……欸嘿嘿。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒事的，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我很有精神喔。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 108511,
        "voice": "vo_adv_1086004_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果有什麼煩惱就和我商量喔，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為我們是家人啊。",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n謝謝，胡桃。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我真的打起精神了。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你可以不需要再背我囉，哥哥，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很抱歉一直跟你撒嬌。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿咻。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有什麼東西掉了！　",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有叩咚的聲音！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉……",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是呢，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉我一直都好好拿在手上。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是什麼呢？　",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音，",
        "unit_id": 108511,
        "voice": "vo_adv_1086004_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳腳邊有什麼閃閃發光的東西掉了喔……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "閃閃發光？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是像寶石一樣的東西掉了！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這是什麼東西？",
