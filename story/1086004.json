    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "請你要守護我喔。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_088"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n求求你……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "請你要愛我喔，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥。",
        "unit_id": 108611
    }
