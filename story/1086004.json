        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你不可以在這裡睡，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不然胡桃會沒地方睡的。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快起來，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "回自己的房間睡吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……唔啊！？　",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_082"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥、哥哥？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為什麼要抱住我呢？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我、",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_083"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我可不是玩偶喔……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚嗚。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_084"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "傷腦筋，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "靠我的力氣沒辦法掙脫哥哥啊。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "被抱住後覺得好溫暖、",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好開心，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "又開始想睡覺了。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "算了，也好。",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_085"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就這樣子",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n被當成玩偶抱住再睡一下吧。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為發生了悲傷的事情，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "感覺變得好無助……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "正好是想盡情撒嬌的時候。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_086"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就這樣抱住我。",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "治癒我、",
        "unit_id": 108611,
        "voice": "vo_adv_1086004_087"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "拯救我……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "從這盡是難以理解",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "又充滿悲傷的世界裡，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就算僅僅在夢中的時間也好，",
