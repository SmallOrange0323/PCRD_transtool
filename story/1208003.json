[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "參加完活動的流夏一行人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n逛到了蘭德索爾的擺攤市集。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～！",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真好吃！",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在雪景中享用蕎麥麵真是別有韻味啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為之前一直在運動，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我的肚子早就空蕩蕩的了，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n幸好還有攤販市集啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然已經填飽肚子，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感覺整個人都活過來了，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來要做什麼才好呢？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這點子不錯。",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "畢竟除了食物外，\n市集還有在賣各種東西，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們就隨意逛吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n搞不好能夠找到很棒的吉祥物。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "射擊遊戲、抽籤",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "和賣玩具的，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有各式各樣的攤販啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果我有拿到紅包，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可能會不由自主拿來亂花。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我已經變成給紅包的人了。",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "杏奈和七七香也都會吵著跟我要紅包，真傷腦筋。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真希望等她們有能力自己賺錢後，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就能從領紅包一族畢業啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，你看。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這裡不是剛好有個在賣熊手的攤販嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "據說熊手是",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能夠把福氣搜刮起來的吉祥物，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看起來也很華麗，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種喜氣的感覺很不錯啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難得見到，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們就去看一下──",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小弟弟，你沒有要買的話就回去吧！",
        "unit_id": 1,
        "voice": "vo_adv_1208003_009"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……！",
        "unit_id": 416,
        "voice": "vo_adv_1208003_010"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "對、",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不起。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喂喂，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對方是小孩，火氣不需要這麼大吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你們有什麼事？",
        "unit_id": 1,
        "voice": "vo_adv_1208003_012"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我很忙的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n沒時間",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "跟窮小孩瞎耗。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……",
        "unit_id": 416,
        "voice": "vo_adv_1208003_013"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗯……",
        "unit_id": 416,
        "voice": "vo_adv_1208003_014"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我妹妹",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "最近才剛出生。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "為了祈禱",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妹妹能夠幸福，我才想買熊手，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n但我的零用錢完全不夠……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "熊手對小孩子來說",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的確是有點貴啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n畢竟做得越豪華，價格也就越高。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要不要試著",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跟你爸媽商量一下？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗯……",
        "unit_id": 416,
        "voice": "vo_adv_1208003_017"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可是",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我想偷偷買起來，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "讓他們嚇一跳……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣會讓人很想為他想點辦法啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總不能擅自買給別人家的小孩……",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦？",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，這個嘛，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想應該不至於做不出來……",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n小哥你",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難不成……",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這種想法很棒。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但熊手的裝飾要怎麼辦？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n就算想做，我們也沒有那個技術啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "即使真的能做出來，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也會花費太多的勞力和時間。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "身邊的東西，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是指花草和樹果嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣或許行得通啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小子，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你等一下。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們來幫你做個熊手。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那、",
        "unit_id": 416,
        "voice": "vo_adv_1208003_024"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那我跟你們一起去。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "因為我也可以幫忙摘花。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎？",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這就出發吧。",
        "unit_id": 120811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_026"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種花挺不錯的啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在冬天也開了不少。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大姐姐，",
        "unit_id": 416,
        "voice": "vo_adv_1208003_027"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這個葉子怎麼樣？",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是有趣的形狀。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那就也拿來用吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "太好了～！",
        "unit_id": 416,
        "voice": "vo_adv_1208003_029"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不知道有沒有其他好東西掉在地上？",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是啊。",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每種材料都很漂亮，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "把這些組合起來後，我想成品應該很不錯，但……",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就是說啊。",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果要找不必花錢的材料，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n而且又要表現出裝飾品般的華麗感",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "和魄力……",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "奇怪？",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說到這個，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那孩子",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "跑去哪裡了？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗚哇啊啊──！",
        "unit_id": 416,
        "voice": "vo_adv_1208003_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個慘叫聲是",
        "unit_id": 120811,
        "voice": "vo_adv_1208003_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那孩子的……！",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要走囉，小哥！",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咿",
        "unit_id": 416,
        "voice": "vo_adv_1208003_035"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "救、",
        "unit_id": 416
    },
    {
