    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "歡迎回來。",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n一直努力工作辛苦你了～",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "要先洗澡？",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "先吃飯？",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "還是",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "吃蛋糕？",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嘿嘿，",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_001"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "因為今天是美美的生日，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美就去街角的蛋糕店",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "買了蛋糕和蠟燭♪",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美一直在等",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥回來喔！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗯♪",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "插好蠟燭～",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "點火……",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "預～",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "備，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "呼～～～！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "謝謝你，",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美長大一歲了，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n是不是又離哥哥更近了呢？",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "等美美再長大一點，",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_004"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "希望有一天，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n可以跟哥哥一起吃不是扮家家酒的蛋糕！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "美美想要有很大的草莓，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "上面放著巧克力做的熊熊裝飾的那種～♪",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇，",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "這個大盒子難道是",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "蛋糕？",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好厲害好厲害♪",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n還有巧克力做的兔子～！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "謝謝你，",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_006"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "那麼，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "從哥哥回來的時候開始，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n再來一次扮家家酒！",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "生日真開心♪",
        "unit_id": 102031,
        "voice": "vo_adv_4010166_007"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "扮家家酒也很好玩。",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n美美，",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "最～喜歡",
        "unit_id": 102031
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥了♪",
        "unit_id": 102031
    }
]