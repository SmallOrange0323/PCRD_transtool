[
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們終於",
        "unit_id": 106411,
        "voice": "vo_adv_9053155_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "回到精靈的祭壇了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "從村裡拿來的供品食物，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還滿重呢……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也準備了",
        "unit_id": 105811,
        "voice": "vo_adv_9053155_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我途中在海岸釣的魚！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有滿滿現採的新鮮食物……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說妳……",
        "unit_id": 106011,
        "voice": "vo_adv_9053155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我想妳應該知道，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這絕、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不可以吃掉喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討、",
        "unit_id": 105811,
        "voice": "vo_adv_9053155_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討厭啦，小凱留真是的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我知道啦～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為這是要給精靈的食物啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得好好地供奉才行！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "供奉的食物",
        "unit_id": 106411,
        "voice": "vo_adv_9053155_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "放在這裡就好了嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼就冒昧地",
        "unit_id": 105911,
        "voice": "vo_adv_9053155_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由在下來",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n執行供奉的儀式吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不覺得整個氣氛都出來了嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_9053155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n天色也很陰沉，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "整個暗了下來……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不是有點太暗了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等等，",
        "unit_id": 106411,
        "voice": "vo_adv_9053155_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n上面……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_9053155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上面怎麼了……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊啊啊！？",
        "unit_id": 106011,
        "voice": "vo_adv_9053155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是之前打倒過的那隻魔物嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實在有夠煩人！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不是又盯上了食物！？",
        "unit_id": 105811,
        "voice": "vo_adv_9053155_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……！",
        "unit_id": 105911,
        "voice": "vo_adv_9053155_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牠是察覺到精靈若藉由供品取回了力量，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n魔物就會被壓制吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔！",
        "unit_id": 106011,
        "voice": "vo_adv_9053155_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳就這樣繼續進行儀式！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n煩人的傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就要給牠狠狠的一擊讓牠好看！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雪菲，要上囉！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好！",
        "unit_id": 106411,
        "voice": "vo_adv_9053155_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n媽……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我一定會守護",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐的！",
        "unit_id": 106411
    }
]