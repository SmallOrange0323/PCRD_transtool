        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n剛剛給的只是普通的水……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "雪小姐的話，",
        "unit_id": 132512,
        "voice": "vo_adv_4012014_007"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "剛剛",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "非常滿意地回去了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "咦，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "普通的水？",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n好驚人的安慰劑效應啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……精神強悍到頂點了嗎。",
        "unit_id": 132512,
        "voice": "vo_adv_4012014_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那孩子一定活得很幸福吧。",
        "unit_id": 132512
    }
