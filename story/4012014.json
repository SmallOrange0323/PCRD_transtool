[
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗨。",
        "unit_id": 100811,
        "voice": "vo_adv_4012014_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我有訂購",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能讓自己變得更美的藥，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n商品準備好了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "歡迎光臨……",
        "unit_id": 132512,
        "voice": "vo_adv_4012014_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "啊啊，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "雪小姐。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "都準備好了喔。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n請稍等一下，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我看看，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "有了有了，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "在這邊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 100811,
        "voice": "vo_adv_4012014_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "自從下訂以後，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就一直等著今天的到來！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n能讓擁有究極之美的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更加美麗的藥……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "立刻",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就來試試吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵……",
        "unit_id": 100811,
        "voice": "vo_adv_4012014_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美是不是很耀眼？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "目睹到美",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會發不出聲吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那我就",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "照照鏡子吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我看看啊……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哦哦……",
        "unit_id": 100811,
        "voice": "vo_adv_4012014_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真美。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗、",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "壯麗、",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "亮麗……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n無論如何用言語表達都無法形容，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是這麼回事吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會超越頂點吧……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是多麼地罪孽深重啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵……",
        "unit_id": 100811,
        "voice": "vo_adv_4012014_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "謝",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "謝，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我很滿意。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n接下來",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就去街上",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n把我的美分給大家吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再見。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
