[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "步未為了拯救陷入危機的惠理子而現身。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但惠理子卻以非常訝異的眼光看待"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一路隱身跟蹤到這裡的步未。"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩筆記。",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一不小心就在{player}前輩們的",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "面前現身了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "本來我只打算遠遠地在旁邊看著，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不想打擾他們的探索的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩對我說",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一個人太危險了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳也一起走吧，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是我這種人跟在旁邊",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不會妨礙到他們嗎？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我真的很不安……",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎怎、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼辦啊～～～！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……妳剛剛說",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳叫步未是嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呀！",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是的！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我要再次",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "向妳道謝，謝謝妳剛剛",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n從危險之中救了我。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果我就這樣踩空的話，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "恐怕是無法安然無恙的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請妳別這麼說！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "像我這種人",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "做這樣的事是我太多管閒事……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "先不管這個。",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "步未小姐……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳真的，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "從一開始就一路跟在我們後面嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n從進入塔之前就跟在後面了？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是的……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……我完全",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有感覺到一點氣息。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳沒有說謊吧？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？　",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我說的是真的……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "平常就很不起眼……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大家都不太會注意到我的存在。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不太會注意到……",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "總覺得這不是那麼簡單的等級……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "很平常……！？",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "步未小姐，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳常常像這樣",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "跟蹤",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這位大人嗎！？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不不、",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不是的！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我並不是在跟蹤他～！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗚……",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "果然還是這樣～……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n雖然是躲起來的我不好，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過我得更努力",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "增加",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "自己的存在感才行……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔……",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為每次都不敢出聲叫你，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n最後就變成",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只站在旁邊盯著你看……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我就是為了改變這一點，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "才像這樣做筆記……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "筆記……",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話說我從剛剛就一直很在意，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n步未小姐，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那上面寫了些什麼？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦！？",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這個是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "當著前輩的面，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有點不方便說……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳的意思是那個不能給{player}大人看？",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……很可疑喔。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不是那樣的……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n那個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這個、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有點像日記……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "日記……！？",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難不成這女孩，",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一邊寫日記一邊……！？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也就是說，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我剛剛的一舉一動，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n全都被這個女孩看得",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一清二楚了嗎……！？　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "故意把臉弄髒讓他幫我擦拭，",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n假裝暈眩想抱住他，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n甚至還用藥物",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "引發突發事件等等……！？　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "糟糕了……",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "萬一、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那種東西被其他人看到的話，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我作為『破壞者』將無法為人表率了……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還會被【暮光流星群】的大家",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "取笑！　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且最重要的是，",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我不能讓{player}大人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓我的命中注定之人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "發現我背地裡這麼拼命地在向他示好……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_025"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "惠理子……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳怎麼了嗎？　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是不是哪裡不舒服……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……請別在意。",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我剛剛只是在想些事情而已。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請妳不要客氣，",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_027"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n有什麼事情都可以告訴我喔……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "既然你們願意讓我一起跟著，",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_028"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我會努力",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幫、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幫上忙的……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呀！？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊哇哇哇、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我把筆記弄掉了……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看來令人擔心的人是妳啊。",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "拉住我的手",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "趕快站起來——",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊……！？　",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "剛剛、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "瞬間瞄到筆記裡",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然有我的名字……！？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難不成這個女孩，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是故意讓我看到裡面的內容……！？　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不但有著連我都沒能覺察的隱身技巧，",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n還有那本慣用的筆記……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "果然不是個簡單的人物……！　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "謝謝妳！",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_032"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "惠理子小姐！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "惠理子小姐果真是個很溫柔的人呢……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸嘿嘿……♪",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這麼放鬆自然的微笑……",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "她竟然能對我這街上人稱『破壞者』，\n眾人敬而遠之的人露出這種笑容……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難不成這個女人",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "手上握有我的把柄",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗎……！？　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "惠理子小姐，",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_035"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然她在戰鬥時有點可怕，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但在前輩面前也會有點少根筋……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然把她拿來跟我比較可能有點失禮，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過總覺得",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有種共鳴……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "步未……",
        "unit_id": 102711,
        "voice": "vo_adv_7012003_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是個不容小覷的女人！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不可掉以輕心……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "到時候有個萬一，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就親手……！　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "既強韌、",
        "unit_id": 105511,
        "voice": "vo_adv_7012003_037"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "又美麗、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還這麼溫柔體貼。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要是能跟她做朋友就好了……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，兩人之間對彼此產生了稍有偏差的奇妙誤會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n重新啟程繼續他們在露娜之塔的探索之旅。"
    }
]