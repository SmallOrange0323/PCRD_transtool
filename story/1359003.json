        "type": "dialogue",
        "name": "剎鬼",
        "words": "……可別忘了我們約好了，",
        "unit_id": 135911,
        "voice": "vo_adv_1359003_071"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有個想讓你",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "見的人……",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "………………",
        "unit_id": 135911,
        "voice": "vo_adv_1359003_072"
    },
    {
        "type": "background",
        "background": "502640"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n醒過來的剎鬼帶著{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了某個地方。"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這個村子的墓地。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_073"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我想讓你見的人就在這裡……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "啊，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有了，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就在那裡。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我的妹妹，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_074"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就在這塊墓碑下面。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我想",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "讓她",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看看你。",
        "unit_id": 135912
    },
    {
        "type": "background",
        "background": "502400"
    },
    {
        "type": "background",
        "background": "502640"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……是啊。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_075"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n但並不是長相……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "該怎麼說，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "應該是",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "給人的感覺吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "非常地相似。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "話雖如此，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_076"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也就只是這樣罷了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "說到底那個幽靈",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "根本不是鬼族。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……不過，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_077"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我無法放著她不管，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這也是事實。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……打掃",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_078"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "差不多就這樣吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "謝謝你的幫忙。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……這位小哥",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_079"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也在幫妳祈禱呢。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n真是太好了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_080"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那麼。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "接下來才是重點。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我們鬼族",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "有在墳墓前立下誓言",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "的習俗。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不光是這次的事件。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_081"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "都是因為我太沒用了，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n才會讓身為外人的你",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "幫了我這麼多次忙。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所以我發誓。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_082"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n這份大恩情，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我會用一輩子來──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……怎麼了。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_083"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我可是很認真的啊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你有在聽我說話嗎。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_084"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我必須為這件事做個了斷。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n從外人那──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……啊……？",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_085"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "…………",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_086"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "呵。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "哈哈！",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_087"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n啊哈哈哈！",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "的確",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_088"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是呢──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "把死黨的好意，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "硬說是人情債，也太不知趣了……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "真",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_089"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "抱歉啊，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "剛才的介紹似乎不太對。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n讓我再重新，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "把你介紹給我的妹妹。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這傢伙──",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_090"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是我的死黨公！",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "經歷了靈玉事件與殭屍村救援事件後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與剎鬼建立了堅定羈絆的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n作為剎鬼的死黨公受到了鬼族的歡迎。"
    }
