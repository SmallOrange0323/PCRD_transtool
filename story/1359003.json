[
    {
        "type": "background",
        "background": "502640"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──「有個想讓你見見的人」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}接受了剎鬼的提案，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次回到吉歐‧尼布爾黑爾的鬼族村莊。"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "…………好昏暗啊。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n吉歐‧尼布爾黑爾的天空。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還真是奇妙。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_001"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n明明是我出生的故鄉。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我的事",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_002"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也不是什麼急事。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就先休息一下吧，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……這沒什麼大不了的。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_003"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n黎薩公的箭矢，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不過是擦傷程度而已。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "剎鬼大人！",
        "unit_id": 1414,
        "voice": "vo_adv_1359003_004"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "非常抱歉，才剛回來就打擾您，",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "有事情要報告……",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "說吧。",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_005"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "我們收到通報，在夜叉山巔山麓上的殭屍村莊，",
        "unit_id": 1414,
        "voice": "vo_adv_1359003_006"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n正遭到一群漂流過來的怪物襲擊。",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "希望能盡速前往救援。",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是那裡嗎……",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_007"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n年輕一輩的呢？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "他們的話，",
        "unit_id": 1414,
        "voice": "vo_adv_1359003_008"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "因為正在進行其他地區的救援，",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "以及「深邃庭園」的警戒……",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "如果要動員的話，",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "只能從這個村莊裡最低限度的人員分派出去。",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "現在把他們叫回來",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_009"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "應該也來不及。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是派守衛村莊的你們出去也划不來──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "沒辦法，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_010"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我就去出個差吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n又要麻煩你們看家了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "……遵命。",
        "unit_id": 1414,
        "voice": "vo_adv_1359003_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "抱歉啊，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你就在這喝杯茶休息一下吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_013"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我說啊，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n「返魂靈玉」的事情我是很感謝你。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但正因為這樣，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_014"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我不能在還沒償完債之前又欠下人情。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n這樣子，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "會積欠太多啊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就算你不在意，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_015"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我也會",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "在意。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你這笨蛋，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_016"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "別跟我扯歪理──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_017"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "嘖。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "沒時間了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "隨你便吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不過，",
        "unit_id": 135912,
        "voice": "vo_adv_1359003_018"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要是有危險記得大聲叫我。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不對，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還是立刻拔腿就跑吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這是條件。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "知道了嗎？",
        "unit_id": 135912
    },
    {
        "type": "background",
        "background": "502440"
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍們",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喂喂。",
        "unit_id": 135911,
        "voice": "vo_adv_1359003_019"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n你們這群骨頭們居然在別人的地盤上",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "橫行霸道。",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "明明只剩骨頭了還想擋路。",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──就把這當作招呼。",
        "unit_id": 135913,
        "voice": "vo_adv_1359003_020"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n粉碎吧！",
        "unit_id": 135913
    },
    {
        "type": "background",
        "background": "502440"
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍們",
        "words": "──嘎喔喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍們",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──嘖。",
        "unit_id": 135913,
        "voice": "vo_adv_1359003_021"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n一群接著一群……",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喂，",
        "unit_id": 135913,
        "voice": "vo_adv_1359003_022"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我來吸引魔物們的注意。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你趁機",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "去找來不及逃跑的人，把他們帶回鬼族的村子去。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……別擔心。",
        "unit_id": 135913,
        "voice": "vo_adv_1359003_023"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我馬上就跟上。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "來吧，",
        "unit_id": 135913,
        "voice": "vo_adv_1359003_024"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我負責開路。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──快去……！",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的女殭屍",
        "words": "這裡，",
        "unit_id": 422,
        "voice": "vo_adv_1359003_025"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的女殭屍",
        "words": "在這裡！",
        "unit_id": 422
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "太、",
        "unit_id": 314,
        "voice": "vo_adv_1359003_026"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "太好了！",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "我們",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "得救了！",
        "unit_id": 314
    },
    {
        "type": "background",
        "background": "502430"
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "噫，",
        "unit_id": 314,
        "voice": "vo_adv_1359003_027"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "有隻魔物",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "追過來了！",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍們",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的女殭屍",
        "words": "不行，",
        "unit_id": 422,
        "voice": "vo_adv_1359003_028"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的女殭屍",
        "words": "前面也有",
        "unit_id": 422
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的女殭屍",
        "words": "魔物！",
        "unit_id": 422
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "啊啊，",
        "unit_id": 314,
        "voice": "vo_adv_1359003_029"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "完蛋了……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "\n",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "我們都要死在這裡了……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "………………"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "……這、",
        "unit_id": 314,
        "voice": "vo_adv_1359003_030"
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "這不是沒有人嗎！",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "\n",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "剎鬼大人怎麼可能來這種地方……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "骷髏飛龍們",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "來不及逃跑的男殭屍",
        "words": "噫噫噫噫！！",
        "unit_id": 314,
        "voice": "vo_adv_1359003_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒那個必要。",
