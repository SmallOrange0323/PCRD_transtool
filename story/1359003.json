        "voice": "vo_adv_1359003_033"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n──",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "「六角納骨‧",
        "unit_id": 135913
    },
