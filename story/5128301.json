        "unit_id": 127611,
        "voice": "vo_adv_5128301_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n如果被那個破舊的外表給騙了，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是會嚐到苦頭的喔。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過，",
        "unit_id": 127611,
        "voice": "vo_adv_5128301_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "無論是什麼樣的對手……",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n如果敢擋在我面前，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我都會將其一刀兩斷的。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咲戀，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "準備好了嗎？",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
