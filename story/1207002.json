        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不用擔心，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你也會馬上就學會怎麼溜的。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "溜冰",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_055"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有一點訣竅。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "首先是……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想想。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一小步一小步向前踏步看看。",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_056"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不用擔心，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會握住你的手",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不讓你跌倒的。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n準備～",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "小步走小步走、小步走小步走♪",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……對對，",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_057"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很棒喔！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n做得很好♪",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯，",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_058"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對不起。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我染上可可蘿小姐的語氣了……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_059"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你遲早",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以學會靠單腳來保持平衡的。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n能夠照自己的意思溜冰很快樂喔。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n要在冰上跳舞也不是夢想。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_060"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說跳舞",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只是開玩笑的。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不會跳啦。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_061"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等一下……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你在那裡打拍子是什麼意思……？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這裡有這麼多人在，",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_062"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n要在這裡溜會很難為情……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
