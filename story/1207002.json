        "voice": "vo_adv_1207002_041"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果只是這個廣場的地面，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我應該能夠讓它結冰。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n大家",
