    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_040"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
