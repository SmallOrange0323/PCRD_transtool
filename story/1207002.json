    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n啊～",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "要是這個遊戲場能夠整個都結冰，應該會很好玩的說……",
