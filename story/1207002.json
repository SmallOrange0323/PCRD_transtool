        "voice": "vo_adv_1207002_052"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你還好嗎！？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我看你摔了一大跤……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有沒有哪裡會痛？",
