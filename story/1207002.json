        "voice": "vo_adv_1207002_048"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……可是……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
