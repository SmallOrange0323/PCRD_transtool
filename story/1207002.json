    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就像變成了剛出生的小鹿一樣。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟你才剛學而已，",
