[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲獨自一人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n寂寞地坐在【美食殿堂】公會小屋室內的沙發上。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "歡迎回來！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我看你回來得相當早……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "已經到處去拜完年了嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……是喔。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你那樣盯著我看",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是怎麼了嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……咦？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你問我有什麼煩惱嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的表情看起來有這麼嚴肅嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那個，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只是在想點事情而已。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不是什麼大不了的事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我知道了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你想想。",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "新年",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是要到處去向",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n至今認識的人打招呼說",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「今年也請多指教」嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以可可蘿小姐才回去老家了，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n貪吃佩可和凱留她們",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在也都在王宮。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家都有我不知道",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且只屬於自己的過去。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和大家在一起時，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就會變得比較少",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "去想自己的過去，但是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "像這樣自己獨處後，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我又會開始",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "去東想西想……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……對不起，明明是難得的新年，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我卻把氣氛搞得這麼感傷。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為都沒找到有關於「以前的我」的任何線索，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以我可能有點焦急了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你說去找……",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……去玩新年會玩的遊戲？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯，",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說得也是。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「以前的我」",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也有兒時的經歷啊，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n說不定會知道新年的遊戲。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且……",
        "unit_id": 106412,
        "voice": "vo_adv_1207002_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "新年吃了好多東西，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "稍微運動一下也確實比較好。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好啊，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我去準備，你等我一下！",
        "unit_id": 106412
    },
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "欸……",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n漂浮在天空上的那個是什麼？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……放風箏？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個是用這麼細的線",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "來操縱的東西嗎？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n真的沒有用魔法？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……感覺很不可思議，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但很令人感興趣。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也要玩嗎！？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是說呢……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這或許能夠得到什麼線索……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我玩玩看！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼、",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "放風箏……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好累人。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我從剛才就一直在跑步……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我知道是用線來",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "控制風箏。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n可是",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我如果不跑起來，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "風箏感覺就會掉下來……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，又有風來了……！",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n啊、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呀啊！？",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………嗚。",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚、",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好痛喔～！！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "葛～格～！！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯嗯。",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來我……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該是第一次放風箏吧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你拿的那個是什麼？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "劍球？",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……這個要怎麼玩？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……原來如此。",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n只要利用離心力",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "把這顆球插到棒子上就行了對吧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真有趣。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟我懂劍術，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這我應該就會玩。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我看穿了！",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……啊。",
        "unit_id": 120711,
        "voice": "vo_adv_1207002_029"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯嗯，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛才的是……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我在練習。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "下次一定行！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
