[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了收齊公會管理協會的年度活動紀錄，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}造訪了王宮──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──好了，",
        "unit_id": 107111,
        "voice": "vo_adv_9004012_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n和我一同",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "駛向怒海狂濤的大海吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等，",
        "unit_id": 104711,
        "voice": "vo_adv_9004012_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我應該說過好幾次了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我還有職務在身，不能離開這裡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你",
        "unit_id": 107111,
        "voice": "vo_adv_9004012_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "已經到啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒什麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我從那邊的小不點聽說了有趣的事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "聽說",
        "unit_id": 106113,
        "voice": "vo_adv_9004012_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們在前陣子的年底期間忙碌得四處奔波。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我是聽似似花說的哦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "聽說你們為了找尋吉祥的食材，",
        "unit_id": 107011,
        "voice": "vo_adv_9004012_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以造訪了充滿回憶的城鎮。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你們在順道前往的大間鎮",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再次挑戰釣上金槍鮪。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107111,
        "voice": "vo_adv_9004012_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是釣金槍鮪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然我不像你們，未曾為了尋求美食",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而旅至前人未到的秘境，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我也已嚐遍了大多數的高級食材。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只有在當地才能品嚐到的極致美味，",
        "unit_id": 107111,
        "voice": "vo_adv_9004012_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就用自己的力量收入囊中──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我覺得這樣的經驗很不錯。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼做也能排解一時的無聊吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不能太麻煩大家哦，",
        "unit_id": 106812,
        "voice": "vo_adv_9004012_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "克莉絲。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年是有事要辦，才會來王宮的吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n目標就是──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個信封，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣子。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好，",
        "unit_id": 106812,
        "voice": "vo_adv_9004012_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個就確實交給你了哦。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣一來，就沒我的事了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然很想這麼說啦……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過剛才妳們說的釣魚，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "找我如何呢？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來一決勝負吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哦……？",
        "unit_id": 107011,
        "voice": "vo_adv_9004012_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我沒有意見，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就這麼辦吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我也想看看",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳那張哭喪的臉。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈！",
        "unit_id": 106113,
        "voice": "vo_adv_9004012_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "挺不錯的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像很有趣啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就以這四人",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來進行釣魚比賽吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_9004012_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "原來如此。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是個溫柔的人呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n作為代替的人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她將那三人希望我和少年能夠參加的期待一肩扛下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n使事情有所轉折，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "並將之導為她該做的事情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年",
        "unit_id": 104711,
        "voice": "vo_adv_9004012_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "似乎也覺得不太方便，這點還真是抱歉呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小克莉絲會邀請我，是因為……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然只是我的猜想，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但她大概是想要讓我好好休息，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才以釣魚當作理由的吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但",
        "unit_id": 104711,
        "voice": "vo_adv_9004012_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "守護這裡是我的工作。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是值得誇耀的職務。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，雖然無法一同前行，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我會為你送行的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n祝你一路順風，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你的背後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我今後也會守護好的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106811,
        "voice": "vo_adv_9004012_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最後就",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "稍微幫少年",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一點小忙吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n做個通往你下個目的地的捷徑吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──物件變更。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "連接座標……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是這附近嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好了，",
        "unit_id": 106811,
        "voice": "vo_adv_9004012_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你就走吧！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n願你開造的未來",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "獲得太陽與星辰的祝福。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一面用力地回應著她們溫暖的目光與聲援，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一面前往了下一個目的地──"
    }
]