        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "我們的戰鬥方式，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "你有好好記下來了嗎？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "呵呵，",
        "unit_id": 17512,
        "voice": "vo_adv_5118302_001"
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "那當然。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "畢竟我可是得到了充分的時間來學習呢。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "\n就讓我先給你們一個忠告吧，",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "莫夫",
        "words": "現在的我與剛才已經不是同一個人了喔。",
        "unit_id": 17512
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "感謝你的忠告。",
        "unit_id": 125711,
        "voice": "vo_adv_5118302_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只不過……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這句話，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就原封不動地奉還給你吧。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "畢竟現在的我們，也和剛才截然不同了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就算你會預測我們的行動，",
        "unit_id": 125511,
        "voice": "vo_adv_5118302_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們也會不斷地超越！",
        "unit_id": 125511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n現在就證明給你看吧！",
        "unit_id": 125511
    }
