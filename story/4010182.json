[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……晶",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_000"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "似乎不在這裡呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "看來，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是故意裝成被我給網住的樣子。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "她真的是，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "只有在迷宮裡到處逃跑這招最擅長呢。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "虧我還親自來到這裡，",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_001"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真可惜啊。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "原本還打算好心收下她的一隻手或一隻腳。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……嗯？",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_002"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這是",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "什麼，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這不自然的箱子跟……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "紙條？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "「哈囉～",
        "unit_id": 1,
        "voice": "vo_adv_4010182_003"
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "真那！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "抱歉囉～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "我人沒在那裡。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "\n至於說到我為什麼要把你叫出來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "是因為今天是真那的生日不是嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "\n哎呀～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "可喜可賀！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "所以我想說",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "一定要來慶祝一下！」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "「所以啦，生日快樂！",
        "unit_id": 1,
        "voice": "vo_adv_4010182_004"
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "你有為此高興嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "\n可以的話真想親眼看看真那你開心的表情呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "\n畢竟你看，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "會幫你慶生的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "也就只有我而已了吧？」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "…………",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_005"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……居然給我開這種玩笑。",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_006"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "這邊的箱子……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "難道裡面放了炸彈嗎？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n雖然這應該不是晶會選的手段……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "什麼，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "連這裡也有紙條？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "「居然把我的生日賀卡",
        "unit_id": 1,
        "voice": "vo_adv_4010182_007"
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "給撕掉了，好過分～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "\n但是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "這邊這個箱子最好還是別丟掉比較好哦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "\n因為這是由另一個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "會慶祝你生日的人……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶的信",
        "words": "少年送給你的。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_008"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "真令人不快，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是那孩子送的？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "難道他特地",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "在「另一邊」打聽的嗎。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "狐狸的玩偶。",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_009"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n以及……",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "「祝你生日快樂」",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是嗎",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "哼……",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_010"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "別說晶了，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "連這位公主騎士在想什麼我也無法理解。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……唉。",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_011"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n突然變得好沒勁。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "把時間浪費在這種無聊的事情上。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "……",
        "unit_id": 106931,
        "voice": "vo_adv_4010182_012"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "而且還平白多了個不必要的東西。",
        "unit_id": 106931
    }
]