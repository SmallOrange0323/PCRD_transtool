[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "クリスマスの準備を進めていたぺコリーヌは、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n街中で偶然、知り合いの姿を見つけた。"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "おや？　",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_000"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あのかわいらしい後ろ姿は……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ツムギちゃーん！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "はい？　",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_001"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "あ、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ペコリーヌ、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "さ……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "は？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "え、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "何？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ツムギちゃん？　",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_002"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "どうかしましたか？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "なにこれ、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_003"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "なんなんですかこれはー！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わわっ！　",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_004"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ちょ、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ツムギちゃん落ち着いて……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "何言ってるんです、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_005"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "これが落ち着いてられますか！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ペコリーヌさん、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "なんなんですかこの服は！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あ、",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_006"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "え、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "と……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "これはクレジッタさんがクリスマスのイベント用にって",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\nあつらえてくれたんです……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "けど……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ど、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "どこか変、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ですか？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "変？　",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_007"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "もうっ、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "バカを言わないでください！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "これは至高にして最高の芸術品ですよ！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "見るからに豪華ですが、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_008"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "王族だからといって",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いたずらに",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n高級感をアピールするのではなく、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n気品と可憐さがバランスよく表現されています。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "まさにペコリーヌさんのために生み出されたデザインです！",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_009"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それにこの生地……",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_010"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "めったにお目にかかれない最高級品ですよ！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "こんな生地でドレスが仕立てられるなんて、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nなんて幸せな縫製職人でしょう、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "うらやましい！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "当然、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_011"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "仕事も丁寧で完璧ですね。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "今の私じゃまだこの域には……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "あー！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "尊敬と悔しさでどうにかなりそうです！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ツ、",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_012"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ツムギちゃん！　",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "落ち着いて、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "落ち着いてください！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "はぁ、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_013"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "はぁ……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "すみません、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "お見苦しいところをお見せしました。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n全く、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "とんでもないものをお召しになってますね、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ペコリーヌさん。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "これは全ての縫製職人を虜にする魔性の服ですよ！",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_014"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いやー、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_015"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "気分転換に街に出て正解でした。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ここのところずっと仕事に追われてボロボロでしたから……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "好きでやってる仕事なので",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_016"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "イヤになることはないのですが、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n睡眠不足と疲労でパフォーマンスが落ちるのはキツいです。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "でも、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_017"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "この服を見たおかげで疲労感が一気に吹き飛びましたよ！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "うふふ、",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_018"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "やる気とアイデアがみなぎってきました！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n速攻で帰って再開します！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ノゾミさんたちみたいに",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_019"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "イベントのお手伝いはできませんが、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "当日は私も楽しませてもらいますね！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "今日はありがとうございました。",
        "unit_id": 105411,
        "voice": "vo_adv_5132065_020"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それでは失礼します！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あ……",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_021"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ツムギちゃん。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "行っちゃいましたね……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "なんだか怒涛のようでしたけど。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あまり意識したことはなかったけど、",
        "unit_id": 127911,
        "voice": "vo_adv_5132065_022"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "こんなにも人の心を",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n動かすことがあるなんて……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "服ってすごいですね☆",
        "unit_id": 127911
    }
]