[
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被人叫出去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而來到了【墨丘利財團】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這麼突然把你找來，",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是抱歉呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個……",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是有關於優花梨的事情。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "她正在禁酒？　",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "的事情你知道吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊――！　",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這裡的計算又錯了！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這不是又要從頭開始算了嗎！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好樣的，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我就做給你看！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "她自從不喝麥酒以後，",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n出現了許多的轉變……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的，",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以我就說申請書要早點送來了啊！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n為什麼每次都要拖到最後一刻才送來啊～！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是【墨丘利財團】的業務，",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我是很不想這麼說，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是工作……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "進展得非常順利。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "創立新事業？",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這個試算是怎麼回事，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不會想得太美好了嗎！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好啊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我現在就直接去",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "找他談談！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……優花梨她",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n任何工作都會接手完成。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯。",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我十分清楚自己說了奇怪的話。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "世界上",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有所謂的平衡啊……？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨工作越是精明能幹，",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就越是有人會光明正大的混水摸魚……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也會有什麼事",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "都推給她去做的人出現……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊――",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "珠希，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳又在走廊上邊走邊吃鯛魚燒了吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n秋乃，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還有很多文件想讓妳過目，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n麻煩妳不要想逃走！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……咳咳。",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總而言之。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "現在的優花梨",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總是把自己逼得很緊，讓人看不下去。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n你可以想辦法幫她一下嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，",
        "unit_id": 104811,
        "voice": "vo_adv_1034012_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "麻煩你了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n若對象是你，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "想必優花梨也會讓自己放鬆點吧。",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}居然會主動邀請我去吃飯，",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n真是難得呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實我還有工作沒做完……",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是美冬把我趕出公會小屋了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的。",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "她到底是什麼意思嘛。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我哪有時間悠悠哉哉的……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不行啦！？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你還太早了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你是叫我喝嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……不，",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我就算了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我已經……",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不喝麥酒了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喝水就行了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你、",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你那眼神是什麼意思？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是說真的喔？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這次我",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "絕對連一滴酒都不會碰的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我已經",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不想再見到麥酒了！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "來，你久等的麥酒！",
        "unit_id": 1411,
        "voice": "vo_adv_1034012_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "………………………………………………",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "吞口水。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不行不行……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "店員先生，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個我們不喝，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以請你收回去嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "好，",
        "unit_id": 1411,
        "voice": "vo_adv_1034012_024"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "麥酒",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "再一杯是吧～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為什麼！？",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_025"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這是我請妳喝的。",
        "unit_id": 1411,
        "voice": "vo_adv_1034012_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我就說我不喝了啊！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "唔嗯～",
        "unit_id": 1411,
        "voice": "vo_adv_1034012_028"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "老實說，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們也覺得很傷腦筋啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n自從客人妳",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "開始禁酒以後，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "本店的營業額就下降了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "原來我有喝這麼多……？",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這是兩碼子事！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是不會喝的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我只要喝酒，",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就會給周圍造成麻煩啊……！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "優花梨，",
        "unit_id": 311,
        "voice": "vo_adv_1034012_031"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是我請妳喝的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n拜託妳喝吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦！？　",
        "unit_id": 103411,
        "voice": "vo_adv_1034012_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "常來這裡光顧的先生！？",
        "unit_id": 103411
