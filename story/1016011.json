[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "甄選會當天。{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n陪著鈴奈來到了甄選會的會場。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊……",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "緊張得全身僵硬了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家從來沒有在甄選會上這麼緊張過呢～",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n雖然有和秀才一起",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "學習貴族階級的禮儀，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但還是有點不安呢……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這次甄選會的相關人士，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "調調肯定也不一樣。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你想想，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家平時參與的活動都是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "「哈嚕──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天大家也要一起嗨喔！」",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "的感覺嘛。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我明白了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吸氣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吐氣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "奇怪？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "深呼吸",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是吸、",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吸、",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吐",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等等等一下！",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你怎麼在發光呀──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n標準的深呼吸",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是會讓身體發光的嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的～！？",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯──",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要挑哪一本好呢──？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n超級不知所云～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這不是秀才嗎！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕──！",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好巧喔，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "居然會在這裡碰到！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你在閒晃逛街嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然這麼巧",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家有一事相求！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n陪人家買一下東西啦！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你聽了可不要笑喔？",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "其實呀，人家……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在在找參考書。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不是，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "完全不是！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "學習的參考書啦！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是覺得跟人家的形象不太搭呀？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是的，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家要氣呼呼了喔！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然不是很擅長，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但人家也是",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "會好好思考學習的事的。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……偶爾──",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "會",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啦。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個呀，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的學校",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "前陣子剛考完試，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天考卷發回來了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "然後呀……",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "成績真的是慘到笑不出來……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n於是",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我就得補考了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "國文、",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "數學……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有英文跟物理。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還是是化學呀……？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之就是",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這兩個很難的其中一個！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "平時啊，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的成績悽慘歸悽慘，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但這次完全是不同級別的！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "最近模特兒的工作太忙了，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n完全沒有時間可以讀書",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也是一部分的原因……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們不是高二嗎？",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你不覺得上課內容突然變得很難嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "明年升上高三以後，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n會不會變成教科書上都寫國語，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但卻完全看不懂它在寫什麼？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "會讓人有種「這真的是國文嗎？」",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "的感覺，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家現在就已經心驚膽顫了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "唔……",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "學校的朋友",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也是這麼鼓勵人家的……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n可是，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不想把工作當成藉口。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "畢竟人家還是學生，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想去學校",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也想讀書。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然課堂內容超級不知所云，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "方程式是啥？的感覺……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就算是不擅長的事、",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可能不適合人家的事，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n總之",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家還是想開開心心地去做。",
        "unit_id": 101631
    },
    {
        "type": "still",
        "still": "101601101"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……啊！",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看你看！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "鏘鏘──！",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這本Ageage的封面",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超可愛的吧？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這是考試前一天拍的！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "從早到晚拍了整整一天，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家都累壞了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "根本沒有心力準備隔天的考試啦！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "的感覺！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這場拍攝超級好玩，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個封面",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也很喜歡呢！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "然後隔天，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n在學校跟朋友一起哀號",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "考卷完全看不懂，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n在教室有一搭沒一搭的閒聊",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也很有意思。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "無論是身為Ageage的專屬模特兒美波鈴奈進行拍攝，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n或是身為SERENA學園二年級美波鈴奈度過校園生活……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還是在阿斯特朗作為弓箭手鈴奈和秀才一起冒險，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "都想盡情享受每一個自己！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然人家還沒有認真思考過畢業後的出路，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但人家",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不打算去上大學，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "高中畢業後就專心當模特兒。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以呀，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "把模特兒的工作當作藉口，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不珍惜現在僅有的學生生活，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n對人家來說是很沒道理的事！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "盡情享受所有能享受的事物！",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這就是人家的原則！",
        "unit_id": 101631
    },
    {
        "type": "still",
        "still": "101601102"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你呀，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "果然有了秀才的加油，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家就會超級幸福的呢！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是這麼一回事，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拜託你！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "幫人家挑參考書！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "肯定很熟悉這一塊吧？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有呀，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_037"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家現在突然想起來了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "剛才人家說要補考的科目有四科，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但人家的日本史也不及格……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "「墾田永年私財法」",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是什麼阿斯特朗的法術絕招嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但是卻出現在學校的考卷上？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎？",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n總之就決定",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "去家庭餐廳點飲料自助吧囉！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_040"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "最近那裡又出了新口味聖代喔！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家請你吃那個",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當作謝禮吧！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果是秀才教人家讀書的話，",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_041"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家有種一定會及格的感覺！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "搞不好可以考個讓老師也跌破眼鏡的高分！",
        "unit_id": 101631,
        "voice": "vo_adv_1016011_042"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家每一科都要考100分，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "請多指教啦♪",
        "unit_id": 101631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "補考五科……",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反倒有點厲害了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管放心吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這次的夢只到這裡為止，",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但在補考之前的每一天，你都陪著鈴奈讀書，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n最後總算是通通及格了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以說啊……",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "模特兒的活動讓那孩子相當忙碌，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只有和你在一起的時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她能以真實的自己度過快樂時光。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她的青春比一般的高中女生還要忙碌，",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今後你要繼續陪在她身邊，成為她的精神支柱喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了教會鈴奈，",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在的你可要好好努力喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那下次見了，",
        "unit_id": 190011,
        "voice": "vo_adv_1016011_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "秀才。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯、",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_050"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯嗯～～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "奇怪？",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_051"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "本來不是在做深呼吸的嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不知道什麼時候，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家好像作了一個秀才在教我讀書的夢……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "看來秀才的深呼吸",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_052"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超級有放鬆效果的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真不愧是秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "夢裡的人家",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_053"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "考了個慘兮兮的分數……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為有秀才的鼓勵，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家才有幹勁努力。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊！",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_054"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說到這個，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "甄選會馬上要開始了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就連現在，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_055"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家對貴族的時裝秀還是抱有不安。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不知道人家可以做到多少事，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但人家已經不會再迷惘了。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_056"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "早就準備好要放手去做了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以人家會全力以赴，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "把自己的全部展現出來！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_057"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就像夢裡的一樣。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才總是在面前",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為人家加油打氣。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_058"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哪怕是貴族的時裝秀，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "上場的時候，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家的腦海裡也會浮現出秀才待在觀眾席裡的身影。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_059"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我去去就回！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_060"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓你久等了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "甄選會結束了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶吶，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_061"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你聽人家說！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家被選定為",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "活動的壓軸了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝啦！",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_062"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家表現得很讚喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "心裡想著",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_063"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "希望秀才在這場活動上也能盡興，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n自然就做出很流暢的表演了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會照著這個步調，",
        "unit_id": 101611,
        "voice": "vo_adv_1016011_064"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "正式上場時也會超級努力的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n當天",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你也要像平時那樣",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "替人家加油打氣喔～♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴奈在甄選會上出色地奪下壓軸寶座，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到活動當天為止，她不斷地磨鍊自己的舞台能力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n更是卯足了幹勁。"
    }
]