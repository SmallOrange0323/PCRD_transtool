    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓你久等了～！",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抱歉，我遲到了！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我就是",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿～地",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "去幫困擾的人們……！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得你說",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想在生日跟我見面～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可是可是，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我非常期待……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚喵……",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊啊──！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我睡著了！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得生日",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "可以跟你在一起的～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抱歉，",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你一直陪在我身邊吧？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿嘿……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "記得",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "之前你還讓我躺在你腿上吧。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不行啊，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我老是給你添麻煩。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真、",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是的～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好狡猾～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也想看你的睡臉！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "既然如此，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就要這個當生日禮物！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來，",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "快睡快睡！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "枕頭……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "有個肯定能讓你安眠的",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "柔軟東西☆",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "510271"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵，",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如何？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n初音枕頭的感覺？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "馬上就想睡了吧？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你☆",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這表情真不錯～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n平常都是你看到我睡著的樣子，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺真新鮮♪",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "等你醒來，",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就一起繼續慶祝生日吧。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "吃吃蛋糕，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "眺望夜空，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "冷了就牽手～♪",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……或是用超能力",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "飛到空中。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "開玩～笑的、",
        "unit_id": 101231,
        "voice": "vo_adv_4010229_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啦。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嘿嘿，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "來過個快樂的生日吧……☆",
