[
    {
        "type": "background",
        "background": "501610"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "經理要我們來海邊，所以我們就來了，",
        "unit_id": 122511,
        "voice": "vo_adv_5096700_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但到底有什麼事呢？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "被找來的",
        "unit_id": 122411,
        "voice": "vo_adv_5096700_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好像不只有我們耶！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳看，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次參加競賽的大家也都聚集在這裡！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的耶。",
        "unit_id": 122611,
        "voice": "vo_adv_5096700_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n大家都穿著泳裝，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "感覺已經做好萬全準備了……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "歡迎光臨！",
        "unit_id": 419,
        "voice": "vo_adv_5096700_003"
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n破曉小隊的各位，",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "先前的大賽",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "真是承蒙各位的關照！",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 122611,
        "voice": "vo_adv_5096700_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼我們",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會被叫來這裡呢？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這個集會到底是……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "先前對各位造成困擾，我深感抱歉。為表達我的歉意，",
        "unit_id": 419,
        "voice": "vo_adv_5096700_005"
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "我設置了一個貨真價實、",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "可以堂堂正正比賽的場地！",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "那就是這片──",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "極限沙灘搶旗賽場！",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦～！",
        "unit_id": 122411,
        "voice": "vo_adv_5096700_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這是",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們在最後比賽的遊戲對吧……！？",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和，",
        "unit_id": 122611,
        "voice": "vo_adv_5096700_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳看。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好像有點不一樣。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總覺得好像增加了各式各樣的機關……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此。",
        "unit_id": 122511,
        "voice": "vo_adv_5096700_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "簡而言之就是讓場地變得更具技術性，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n並在通往終點的路上追加了意外事件啊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "為了讓在激戰中脫穎而出的各位也能享受競賽，",
        "unit_id": 419,
        "voice": "vo_adv_5096700_009"
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "我",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "真心誠意地準備了這個場地！",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "各位會參加的……",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "對吧？",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……感覺強硬地營造出了",
        "unit_id": 122511,
        "voice": "vo_adv_5096700_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無法拒絕的氣氛呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好的──！",
        "unit_id": 122411,
        "voice": "vo_adv_5096700_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我要參加～♪",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n感覺好像很有趣──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……果然。",
        "unit_id": 122511,
        "voice": "vo_adv_5096700_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就知道日和會這麼說。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 122611,
        "voice": "vo_adv_5096700_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也想挑戰看看呢。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "難得夏天來到海邊，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為了不後悔，我想用盡全力享受。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n而且能和怜、日和比賽……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也感到很開心。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣……",
        "unit_id": 122411,
        "voice": "vo_adv_5096700_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿～",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳說的話真是令人開心呢──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過不過，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是不會輸的喔──？",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也行。",
        "unit_id": 122511,
        "voice": "vo_adv_5096700_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再次展現彼此的所有實力也不錯。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是不會手下留情的喔。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "那麼，聚集在此的各位，",
        "unit_id": 419,
        "voice": "vo_adv_5096700_016"
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "你們準備好了嗎？",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "\n以南島為舞台，",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "狂熱的極限沙灘搶旗！",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "在此",
        "unit_id": 419,
        "voice": "vo_adv_5096700_017"
    },
    {
        "type": "dialogue",
        "name": "經理",
        "words": "開幕──！",
        "unit_id": 419
    }
]