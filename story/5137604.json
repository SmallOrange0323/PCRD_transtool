    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "暇を持てあましたノウェムとオクトーは、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nたまたま鉢合わせたダイゴに話しかける。"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なあなあ、",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_000"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "タンゴって",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "なんでそんなにケンカしたがるんだ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "そりゃ俺より強いやつがいるのが気に入らないから……",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_001"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "って待て。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "なんだそのタンゴってのは。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんな理由でケンカふっかけてるの？",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_002"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "はー、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ダンゴってば単純だねえ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "単純で悪いか……",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_003"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "っ",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "て待てやコラ！　",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "誰がダンゴだよ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "はー、",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_004"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "タンボは単純でいいよなあ……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\nオマエもちょっとは見習ったらどうだ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オクトー",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "えー、",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_005"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ボクにはちょっと無理かなあ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "タンポみたいに考えなしには動けないよ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "だからなんだよさっきから！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_006"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n俺はダイゴだ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "お？　",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_007"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "悪い悪い。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "でもさあ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "もし強いヤツらを全部倒しちゃったら",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "テンポはどうすんだ？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n戦うのやめるのか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "それってむなしくない？",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_008"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "戦いだけが人生じゃないよ、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "サンポ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "オ～",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_009"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "マ～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "エ～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "ら～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\nわざとやってるだろ！？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\nいい加減にしろよコラ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "あはは、",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_010"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "バレたか。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "いやー、",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_011"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "どこまで気付かないか",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "試したかったんだけどねえ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "最初から気付いてるんだよ！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_012"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "もしかしてお前ら、",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "俺にケンカ売ってんのか？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "そうカッカすんなって。",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_013"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n頭に血が上りすぎだぞ、",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ディアゴ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "俺はディアゴじゃねえ！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_014"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\nいい度胸だ……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "ケンカ売ってんなら買ってやるよ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "まあまあ、",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_015"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "これは訓練みたいなもんだって。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "平常心を保つ訓練。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ね、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "タイコ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "俺はタイコじゃねえ！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_016"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\nもう我慢できねえ！　",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "覚悟しろテメェら！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "挑発に弱いのが",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_017"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "オマエの弱点なんだよなあ。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "そんなにカッカしやすいと",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_018"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "足をすくわれるよ？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\nダイゴ。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "うるせー！　",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_019"
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "俺はダイゴじゃねえ！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "……あ？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ダイゴじゃないってさ。",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_020"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "じ",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ゃあもしかして",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "ダイコンか？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "ほら、",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_021"
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "足をすくわれた。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "だからもうちょっと冷静に……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "ダイゴ",
        "words": "うがあああああああ！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_022"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "うわっ！　",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_023"
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "キレた！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "ノウェム",
        "words": "めっちゃくちゃ暴れてるぞ！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "オクトー",
        "words": "逃げろ逃げろ～！",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_024"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "笑いながら走って逃げだすノウェムとオクトーであった。"
    }
