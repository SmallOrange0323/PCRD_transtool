[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為像是黑色泥濘一樣的東西到處氾濫，\n使得蘭德索爾的城內陷入了大混亂。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而這場正在舉行當中的祭典營運本部中，\n以各個公會的會長為中心，不論是誰都急迫地想要處理好這場異變。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃，麻煩妳了。",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種事情，果然",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是比較適合秋乃妳來做唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好的好的，",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就包在我身上吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "注意～！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還請大家肅靜一下，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "聽聽我這邊說的話！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "從現在開始，",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們要開始進行避難的指引唷！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n還請各位務必要遵守我們的指示，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不急躁、不躁動、不奔跑",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "地來行動！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵呵呵！",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我等紫藤家引以為傲的飛空艇，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也已不惜餘力地全艦出動，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n現在",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正在蘭德索爾的廣場上待機！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請各位遵守指示",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "迅速地朝著廣場移動，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n然後搭乘上飛空艇！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼要抵達安全的避難場所",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也只不過是轉眼之間的事情囉，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵呵呵☆",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不時就摻在中間的，",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個尖聲大笑有必要嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "總而言之。",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們【墨丘利財團】會負責帶領各位，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還請大家",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "遵照的我們的指示來行動。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在搭乘飛空艇時，",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還請大家先行禮讓高齡者與病患，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n又或是年幼的孩童們優先進行搭乘。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……快點，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨妳也趕緊起來",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幫忙指引避難啦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "耶嘿嘿嘿嘿～",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒事的沒事的！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我還醒著啦！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n認真又嚴肅的優花梨小姐，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n哪有可能會在工作中發酒瘋",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "又或是打瞌睡",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "的嘛～☆",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不。",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我充其量只是以客觀的角度來發表意見，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但現在的優花梨根本就在發酒瘋喔。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咕嚕咕嚕咕嚕！　",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "噗哈～☆",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是呀～？　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喝點酒也是當然的嘛～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這可是祭典喔～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n工作告一段落了嘛，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "當作放鬆",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就乾個一小杯～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "犒賞一下自己☆",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "原本是這麼想但一開始喝起來，",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就完全停不下來了呀～？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還不是因為這陣子都忙到完全回不了家啊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "想晚上在家小酌一番都沒辦法嘛！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嘻嘻嘻，",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "久久沒喝了還真是全身舒暢呀～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這才是活著的感覺啊！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然在年輕人的面前有點丟臉，",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "停不下來也不想停下來啊！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n今天要給它一路喝到掛囉囉囉！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……她這樣沒問題嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n已經醉醺醺了呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嘻嘻。",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨平時是一位相當溫和並且文靜的人，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所以只是喝了一點就變成了這副德性",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還挺讓人意外的呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但反而",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣更可愛的感覺呢♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "她不是只有喝一點喔。",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n為了今天慶功宴所準備的酒桶，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "已經都空了好幾桶囉。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可是嘛，",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看起來不太像是能辦什麼慶功宴的局面了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒關係囉，優花梨。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一點不剩全都喝光也可以。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝妳啊美冬，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "最愛妳囉～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "I LOVE YOU～☆",
        "unit_id": 103411
    },
    {
        "type": "still",
        "still": "201300101"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "Yay～",
        "unit_id": 103411,
        "voice": "vo_adv_2013001_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今晚要給它喝個通宵囉～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n來來秋乃妳也喝點喝點嘛，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎麼可以逼未成年喝酒呀我～！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哈哈哈哈哈……☆",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……優花梨的事，",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n現在先放一旁不去管她好像比較好呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是啊。",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還真是異常事態呢，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n竟然會有秋乃比優花梨還可靠的狀況發生。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "本小姐",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是可靠得如泰山一般穩重",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "唷！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵☆",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "給我等一下，",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【墨丘利財團】！　",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在是能開開心心聊天的時候嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n既然讓我們負責集合逃亡的人們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "並準備移動，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那妳們也要趕緊指引他們啊！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，",
        "unit_id": 104811,
        "voice": "vo_adv_2013001_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一如往常地動作還真是迅速呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真不愧是咲戀啊，",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣才稱得上是我的大摯友……☆",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那可真是我的榮幸呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但實際上",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我什麼也沒做，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "主要都是【王宮騎士團】願意出手幫忙呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼說這也是他們的本業。",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是呢，",
        "unit_id": 103711,
        "voice": "vo_adv_2013001_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "本來就是為了在出事時",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能夠確實地行動而訓練的嘛。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "反過來講",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "若在這情況下什麼事也做不到，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那老百姓用血汗錢所繳的稅金可就真的都白繳了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在祭典會場中全部區域進行警備的，",
        "unit_id": 103711,
        "voice": "vo_adv_2013001_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n【王宮騎士團】的各小隊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也都已經用通訊魔法",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n連絡上囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在各自的管轄內，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "大家都會盡自己最大的努力協助才對。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但和純小姐還有『王宮』裡的長官們，",
        "unit_id": 103711,
        "voice": "vo_adv_2013001_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n都還連絡不上的這一點挺令人在意的……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過嘛，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "基層的我們",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "除了盡自己最大的努力以外也沒他法了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n謝謝妳，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可真是幫大忙了唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒有沒有。",
        "unit_id": 103711,
        "voice": "vo_adv_2013001_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是【王宮騎士團】的原・副團長，\n咲戀小姐您的一聲號令，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "其他所有人才會願意遵從指示的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這是您所立下的功績，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請您挺起胸膛自豪吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要自豪，",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也等到大家都沒事避難成功了以後再說吧。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "智，",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這麼叫來著的吧……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個地方能夠拜託妳嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很在意我們家的那群孩子，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以得暫時",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先回【咲戀育幼院】看看她們的樣子如何唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2013001_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請交給我吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "您一個人沒問題嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n需要的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這邊能指派幾位警備的人與您同行？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒問題的，",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我自己能保護好自己。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，",
        "unit_id": 102811,
        "voice": "vo_adv_2013001_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之後的事就麻煩妳了！　",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就先失陪了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "綾音、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "胡桃……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我的家人啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "拜託妳們一定要沒事！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊哈哈。",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀她還真是的，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "完全成了一個媽媽樣了啊……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "比起那身處在貴族的社交場上而渾身不自在的妳，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這陣子反而更顯得有生氣呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "反而這樣的咲戀，",
        "unit_id": 103211,
        "voice": "vo_adv_2013001_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "更棒呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n讓本小姐，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為妳的前途獻上祝福吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "讓我們守護下來吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "將我們",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這所愛的一切……！",
        "unit_id": 103211
    }
]