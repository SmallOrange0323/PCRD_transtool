    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "嗯。",
        "unit_id": 107231,
        "voice": "vo_adv_5201075_000"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "大家都提議了吧。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "各位開發成員",
        "unit_id": 107231,
        "voice": "vo_adv_5201075_001"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "已經各自提出想要實裝的企劃，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n從現在起，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "開始最終決定。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "接著這句話我再三強調過──",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "──直率的意見",
        "unit_id": 107231,
        "voice": "vo_adv_5201075_002"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "才能做出更好的內容。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "各位，",
        "unit_id": 107231,
        "voice": "vo_adv_5201075_003"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "請記住這句話",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "再各自陳述意見。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "關於教授提議的戰鬥競技場，",
        "unit_id": 107131,
        "voice": "vo_adv_5201075_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以目前的系統來說不太行。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會變成只有強者",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n能夠站在巔峰的內容，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣是沒辦法運作下去的。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "強者立於人之上",
        "unit_id": 107331,
        "voice": "vo_adv_5201075_005"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "乃是理所當然，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n我認為切磋琢磨想要追過前面的人",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "才是遊戲的醍醐味。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "克莉絲妳提議的金錢遊戲",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "和這個也沒多大差別吧？",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很遺憾地，",
        "unit_id": 107031,
        "voice": "vo_adv_5201075_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "兩款都可能會造成過度的憎恨與紛爭。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "必須重新設計，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是先暫緩實裝會比較好。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "說是這麼說，",
        "unit_id": 107331,
        "voice": "vo_adv_5201075_007"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "似似花。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "妳提議的",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "魔物馴服系統",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n也是問題多多喔。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "要是採取了每種怪物都能馴服的形式，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "反而會讓玩家產生依戀，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "作為敵方出現的時候下不了手。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "依戀這種話從你口中說出來",
        "unit_id": 107031,
        "voice": "vo_adv_5201075_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是意外呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過確實，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這個提議可能和我們追求的真實性",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會搭不起來。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "變身系統你們覺得如何？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不行呢。",
        "unit_id": 106931,
        "voice": "vo_adv_5201075_009"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "要是實裝了能變身成其他東西的系統，",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n毫無疑問",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "會變成氾濫的為惡手段。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "我能想出無數用這系統做壞事的方法。",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不愧是真那大人。",
        "unit_id": 107131,
        "voice": "vo_adv_5201075_010"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那算得上是稱讚嗎，",
        "unit_id": 106931,
        "voice": "vo_adv_5201075_011"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "克莉絲？",
        "unit_id": 106931
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那不然看看我的！",
        "unit_id": 106831,
        "voice": "vo_adv_5201075_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "看看我的點子怎麼樣？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那等人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5201075_013"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "「以角色為棋子的AUTO戰鬥型棋盤遊戲。」",
        "unit_id": 106931,
        "voice": "vo_adv_5201075_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「在自動生成的地下城裡",
        "unit_id": 107031,
        "voice": "vo_adv_5201075_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無限挖掘素材的探索遊戲。」",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "「在海邊打棒球，",
        "unit_id": 107331,
        "voice": "vo_adv_5201075_016"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "沙灘棒球。」",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "其他還有好多方案啊……",
        "unit_id": 107131,
        "voice": "vo_adv_5201075_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是不是挺有趣的？",
        "unit_id": 106831,
        "voice": "vo_adv_5201075_018"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對吧！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "不行。",
        "unit_id": 106931,
        "voice": "vo_adv_5201075_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "廢案。",
        "unit_id": 107031,
        "voice": "vo_adv_5201075_020"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "不通過。",
        "unit_id": 107331,
        "voice": "vo_adv_5201075_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "為什麼啊～！？",
        "unit_id": 106831,
        "voice": "vo_adv_5201075_022"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n一起做好多遊戲放進去嘛～！",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "晶……",
        "unit_id": 107131,
        "voice": "vo_adv_5201075_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳啊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是打算把想到的遊戲都放進去而已吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "對呀？",
        "unit_id": 106831,
        "voice": "vo_adv_5201075_024"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n能玩各種遊戲的話才更好吧。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "那麼誰來負責開發？",
        "unit_id": 107231,
        "voice": "vo_adv_5201075_025"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "晶，",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "這些項目內容明顯與至今為止製作的類型都不一樣。",
        "unit_id": 107231
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……",
        "unit_id": 106831,
        "voice": "vo_adv_5201075_026"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "大家一起？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "駁回。",
        "unit_id": 1,
        "voice": "vo_adv_5201075_027"
    }
]