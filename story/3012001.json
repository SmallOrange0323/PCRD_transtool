[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這裡是冒險的櫃台窗口──"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不能承接討伐魔物的工作！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是怎麼一回事？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "真是抱歉呢。",
        "unit_id": 411,
        "voice": "vo_adv_3012001_001"
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "如果小孩子想接下討伐魔物的工作，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "\n則必須要取得家長的同意才行。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可不是小孩子。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是接受過嚴格訓練後，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n被派遣到這個國家、充滿榮耀的──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "話說回來，妳的爸爸和媽媽，",
        "unit_id": 411,
        "voice": "vo_adv_3012001_003"
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "\n他們到哪兒去了呢？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……姆姆姆，就說我不是小孩子了……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n妳真是個死腦筋的傢伙。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "算了，我就先放棄吧。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "下次我重新來過。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "呵呵，妳能理解真是太好了呢。",
        "unit_id": 411,
        "voice": "vo_adv_3012001_006"
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "那麼，妳記得下次要帶爸爸或媽媽，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "櫃台的女性",
        "words": "\n一起過來辦手續呦。我等妳回來呦～。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯～，我本來以為包含事前調查在內都能獨自處理……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒想到連承接工作都辦不到……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒辦法……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只好暫時先加入已經設立的公會了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "算了……加入不認識的人所組成的公會，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也是調查工作的一部分。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要正面思考才行。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這麼一來，就要考慮參加的公會了……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那邊的冒險者們，你們想不想讓我加入公會呢？",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我保證能成為",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你們的戰力呦。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要是你們懷疑的話，就讓我用經歷千錘百鍊的劍術──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "啥呀，我可沒有閒功夫",
        "unit_id": 1011,
        "voice": "vo_adv_3012001_012"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n陪妳玩家家酒啦。小孩子就回家睡覺去吧。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那邊的先生，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你們想不想讓我加入──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "啊哈哈，小孩子是不行的……",
        "unit_id": 1111,
        "voice": "vo_adv_3012001_014"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "哎？",
        "unit_id": 1111,
        "voice": "vo_adv_3012001_015"
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "怎麼了？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n妳幹嘛這麼生氣……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "等、等一下。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男冒險者",
        "words": "嗚哇～！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我身上背負著非常重要的任務，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要調查這個國家的情報",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "並且回報給祖國。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……可惡，沒有想到會在這種地方",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "白白浪費我的時間。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是仍然無法加入公會，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不能承接討伐魔物的任務的話，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就完全走投無路了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我得想個辦法才行……有沒有其他手段呢……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "其實也沒必要加入其他公會呀。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n只要我自己成為公會長，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "從頭建立一個公會不就好了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只要不是我自己一個人的話，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n應該也不會受到討伐魔物的年齡限制。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過最大的問題是公會成員的部分，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我有辦法立刻找到人嗎……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔！在那邊的那群人，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有戰士和治療師，而且還有舞者呢！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看她們四散各自閒坐，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n應該還沒有參加特定的公會吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很好。死馬當作活馬醫。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那邊的小姐們！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯？",
        "unit_id": 100811,
        "voice": "vo_adv_3012001_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是的。",
        "unit_id": 103011,
        "voice": "vo_adv_3012001_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚、嗚呀",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_029"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "。",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哈哈哈，話說回來呀，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_030"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n沒想到這麼快就能找到像這樣",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n職業平衡度絕佳的成員，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我運氣真不錯。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，這一定也是上天的指示，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要我完成",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "祖國給予的任務吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "然後呢，我們要做些什麼？",
        "unit_id": 100811,
        "voice": "vo_adv_3012001_032"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這附近的農地好像被魔物破壞了。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_033"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們的任務，是趕跑那些魔物。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "魔物立刻就現身了呢。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_034"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雖然是最低等級，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過拿來當練習對象正適合。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要上囉！妮諾負責前線。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_035"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雪和空花則在後方支援。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚、",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_036"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚呀呀！！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等、",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_037"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "等一下。空花妳為什麼要上前線！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳要遵照作戰方案退到後方。危險呀──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚呀",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_038"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──喂，妳沒事吧！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_039"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻、嘻嘻……空、",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_040"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花被當作祭品，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n送給魔物了……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔喔，她看起來很開心呢！",
        "unit_id": 103011,
        "voice": "vo_adv_3012001_041"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼，被攻擊了還這麼開心……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_042"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "世上怎麼可能有這種人……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "到我的生命結束為止，我都得在同伴面前，",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_043"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "遭受凌辱對吧！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "──啊！她該不會受到混亂攻擊之類的……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_044"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妮諾，妳一邊注意敵人的攻擊一邊到前線去。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_045"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雪在後方負責支援。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "交給我吧！",
        "unit_id": 103011,
        "voice": "vo_adv_3012001_046"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍法・分身之術……咻趴趴趴！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哇喔！是在魔物四周迅速周旋，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_047"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n讓敵人攻擊無法命中的作戰吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "太棒了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "從遇到她時我就有感覺了，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_048"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n從那個服裝，還有身手來看，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妮諾的武藝應該相當高超。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……頭、頭好暈。",
        "unit_id": 103011,
        "voice": "vo_adv_3012001_049"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我要休息一下。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "笨、笨蛋！妳在幹什麼呀。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_050"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是這樣子停在敵人眼前的話……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳看，果然吧。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_051"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不妙了，雪！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n快點對妮諾使用防禦的輔助魔法……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉……怎麼會這麼可愛啊。",
        "unit_id": 100811,
        "voice": "vo_adv_3012001_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n在鏡中的我真是可愛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算被魔物襲擊了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n也依然是如此可愛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雪，妳在戰鬥中看著鏡子幹什麼？",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_053"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "趕快集中精神戰鬥呀──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳別妨礙我呀。",
        "unit_id": 100811,
        "voice": "vo_adv_3012001_054"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我正在享受自己的可愛呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳說啥──",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_055"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛……太可愛了",
        "unit_id": 100811,
        "voice": "vo_adv_3012001_056"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我真是……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妮諾，快閃開！",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_057"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍法‧雲隱之術！",
        "unit_id": 103011,
        "voice": "vo_adv_3012001_058"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻咻",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……總算趕上了。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_059"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "她逃跑的速度真不是蓋的。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哎呀！話說回來，空花怎麼了──！？",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_060"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太棒了！",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_061"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……嘻嘻……（流口水）。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為、為什麼，明明被魔物包圍，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還能這麼一派輕鬆……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看來她很耐打呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是……",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_063"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，我怎麼會這麼可愛……",
        "unit_id": 100811,
        "voice": "vo_adv_3012001_064"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻、",
        "unit_id": 104511,
        "voice": "vo_adv_3012001_065"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "統一天下！",
        "unit_id": 103011,
        "voice": "vo_adv_3012001_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……或許我，",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n完全看走眼了也說不定……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過呢，既然都已經組成公會那也沒辦法。",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "總之這次就──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "撤退！",
        "unit_id": 105311,
        "voice": "vo_adv_3012001_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "暫時撤退──！",
        "unit_id": 105311
    }
