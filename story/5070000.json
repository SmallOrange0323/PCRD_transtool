    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "第一學期最後一天，月光學院教室。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n學生們各自談論著自己的暑假計畫。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家看起來很快樂是一件令人開心的事，",
        "unit_id": 101811,
        "voice": "vo_adv_5070000_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但暫時見不到面的事實讓人覺得好寂寞呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們也覺得",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "見不到小伊緒很寂寞～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "乾脆大家一起天天出來玩吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那樣不就是最快樂的暑假嗎！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個點子讚到不行〜！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "伊緒有老師的工作要做，沒辦法天天一起玩吧？",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "再說鈴奈不是也說妳有模特兒的工作要做嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對耶對耶！",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我差點忘了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "聽說趁著暑假，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像要去",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "各種地方攝影呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_5070000_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "鈴奈的工作似乎很順利，真是太好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作業不可以忘記做喔？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗚……",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳啊，",
        "unit_id": 101811,
        "voice": "vo_adv_5070000_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要露出那種表情。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "唸書",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "跟工作一樣重要喔？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "或許是吧，",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過是我多心了嗎，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n感覺作業的量不是普通的多耶……？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊！",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我也有同感！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個習題……？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之類的",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超重，讓我嚇了一跳！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那種量哪做得完啊〜！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這是為了盡量追上其他學校的進度喔，",
        "unit_id": 101811,
        "voice": "vo_adv_5070000_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是，伊緒。",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我認為",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有比作業更加重要的東西耶〜？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "畢竟今年的夏天",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就只有這麼一次。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對啊對啊！",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不是都說～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "學生時期的暑假無可取代……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之類的嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "攝影的工作人員",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也這麼說了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "{player}也是這麼想的對吧！",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對吧？",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n既然秀才都這麼說了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "肯定沒錯～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就算玩累了忘記做作業，",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也是沒辦法的事呢～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "暑假很長，",
        "unit_id": 101811,
        "voice": "vo_adv_5070000_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只要用力玩，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "用心寫作業就行了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家一定辦得到喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然小伊緒都那麼說了……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我就",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "努力看看好了。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀，",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "反正你們每天都像是在放暑假一樣，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n至少真正的暑假得努力一下才行呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要那麼說的話，",
        "unit_id": 101611,
        "voice": "vo_adv_5070000_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲自己也是半斤八兩吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳幾乎都跟我們在一起不是嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那是…………",
        "unit_id": 105011,
        "voice": "vo_adv_5070000_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "確實是呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我知道了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我知道了啦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也會好好努力的。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看到大家充滿幹勁，老師很開心呢。",
        "unit_id": 101811,
        "voice": "vo_adv_5070000_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓自己度過一個美好的暑假吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我很期待再次見到",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "成長後的大家喔。",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "離開月光學院後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當{player}懷著對暑假的期待走在路上時──"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_5070000_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在那之後，我們……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我無法繼續說下去了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦咦～～！？",
        "unit_id": 104914,
        "voice": "vo_adv_5070000_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我很想聽後面的部分說！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我不曉得的弟……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是惠理子熟人的事情！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話不能那麼說啊，",
        "unit_id": 102711,
        "voice": "vo_adv_5070000_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我今天還沒從靜流那裡聽到",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我命中注定……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咳咳，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是靜流熟人的事情。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n都我在說",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "很過意不去。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不如說，我反而想聽靜流講各種事情……",
        "unit_id": 102711,
        "voice": "vo_adv_5070000_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我對靜流的話題",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "非常感興趣。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會一邊品茶的，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請妳儘管說吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的！？",
        "unit_id": 104914,
        "voice": "vo_adv_5070000_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那麼，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我希望妳聽我說前幾天的事情……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我不會再上妳的當了！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "平時都是我在說，完全套不出情報……",
        "unit_id": 104914,
        "voice": "vo_adv_5070000_026"
    },
    {
        "type": "dialogue",
