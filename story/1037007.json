[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "家庭訪問！",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n開玩笑的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我來打擾囉～♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如先前",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "通知的內容……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我是前來【咲戀育幼院】進行監察的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n【王宮騎士團】團員，智。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天還請",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "多多指教。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "奇怪？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n沒有半個人……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是我搞錯日期了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n或是最近",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "常發生的文件流程失誤？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還沒有",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "通知他們會有人來監察之類的……？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯～",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "與其說是最近警察機構的功能不完全所造成的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還不如說是最近王宮",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都沒有把該做的事情做好呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣會對現場帶來不良影響，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真希望他們能振作一點啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀算了……",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不好意思～？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n請問",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有沒有人在呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒人",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "回話。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是感覺到有人在的氣息，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n應該不是沒人在。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但也不像是刻意無視我的樣子，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而且也沒有理由無視我吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們【王宮騎士團】，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_010"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n與【咲戀育幼院】的關係……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然也不是說很好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為先前克莉絲提娜所引發的騷動，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_011"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以我們似乎有被警戒著。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過基本上，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們都是隸屬於【公主騎士】旗下的公會。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是因為這樣，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n內部調查……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "監察的工作，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就是要進到相關的公會裡確認狀況。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最近我",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "都是在做這方面的工作呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "明明是想要到更為嚴酷的戰場上，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n運用自己的劍術大顯身手的說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，不過……",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為聽說{player}，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n現在是住在【咲戀育幼院】裡。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "想說或許可以見到他，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而自願申請擔任監察工作的人也是我就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但看來",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是白跑一趟了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來我的確不如自己所想的那麼精明呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那該",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼辦呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n總之就沿著那氣息，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想辦法跟這裡的居民接觸一下好了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我看看。",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n對面那邊好像",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有人在的感覺……？",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不好意思……？",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "果然呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我就想說有人的氣息，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n床上有一個人正在睡覺。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這裡是",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "寢室嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n看起來沒什麼生活感呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我也不想白跑一趟，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然很可憐，但還是把他叫醒，問一下狀況吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個～",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不好意思，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請你起床。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "奇怪？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這個躺在床上的人，是{player}！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這裡是",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}的房間啊？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我該怎麼辦？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}的睡臉，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n原來是這樣的啊……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n呀，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我的心臟跳得好快。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然本來就算是娃娃臉了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但睡著的時候看起來更幼小了呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……呃，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼可以看他看呆了啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}～",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "快醒來快醒來。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n已經快要中午了唷，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你還真是一個貪睡鬼呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣也太懶惰了吧，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊……",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "醒來了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}，早安♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……呀！？",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喂，{player}？\n你是睡昏了嗎？",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我不喜歡你這樣抱我啦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真、",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你真的很讓人頭痛耶，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "快點起來啦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "早安！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n怎麼一副很吃驚的表情啊～\n{player}。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你不知道我為什麼會在這裡對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看來公會果然是沒有好好跟",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【咲戀育幼院】聯絡上呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯！",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我今天是有任務在身，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以才會來【咲戀育幼院】訪問的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "簡單來說，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是來監察的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n來調查預算是否如報告書內所記的方式使用，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n之類的事情。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果發現有問題的話，就當場糾正，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "視狀況，有可能還會需要刀劍相向呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哇哇？",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n沒事啦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你不用這麼警戒。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也知道【咲戀育幼院】的經營者……",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n咲戀小姐",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是個很正直的人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且她，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是前一任【王宮騎士團】的副團長呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我有從資深的團員口中，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n聽過一些有關她的好評。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以說，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖說是監察，也只是一個名目而已……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只要簡單地四處看一下，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n提交「沒有問題」的報告就好，不是很難的工作。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是因為這樣，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n才會把監察的工作，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n交給像我這樣的基層人員囉。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在王宮不知為何在擴張軍備，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n財政上也有些困難……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以好像有在規劃，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要找理由刁難各公會，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看能不能刪除一些經費的樣子～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_049"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然這只是我的個人意見……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【咲戀育幼院】",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n收留了無處可去的兒童，是個非常棒的公會。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以的話，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我希望讓你們能保有充裕的經費。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以不會將你們放到",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "削減預算的名單當中。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是這麼想的，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n希望",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以讓你放心唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我並不是",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}你們的敵人唷。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_053"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是說，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咲戀小姐今天好像不在呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在這邊待這麼久也不太好，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n今天我就先回去呦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n改天會",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "再來拜訪的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那你可以回去繼續睡囉，{player}。",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "吵到你了啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_056"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也很高興終於可以看著你的臉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好好地說話了……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那麼，",
        "unit_id": 103711,
        "voice": "vo_adv_1037007_057"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "下次見囉。 ",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n晚安囉，{player}。",
        "unit_id": 103711
    }
