        "type": "dialogue",
        "name": "千歌",
        "words": "帶來了同為唱喚士的夥伴！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "來，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請過來吧！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_5202007_057"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "原來是這樣嗎。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n我瞧瞧……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "喔喔，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這可真是。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是嗎是嗎，",
        "unit_id": 611,
        "voice": "vo_adv_5202007_058"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n妳們",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "終於見到面了嗎。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_059"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請問，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這是什麼意思？",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "還會是什麼意思，",
        "unit_id": 611,
        "voice": "vo_adv_5202007_060"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n就是我之前跟妳提的",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "年輕唱喚士啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那邊的她，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "正是那位唱喚士。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "紡希、雪菲、千歌",
        "words": "什麼！？",
        "unit_id": 1,
        "voice": "vo_adv_5202007_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是蘭法小姐",
        "unit_id": 105913,
        "voice": "vo_adv_5202007_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在從千歌小姐那裡聽說前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是都不知道",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唱喚士的存在嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "啊……",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_063"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "這個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "在來到「這個世界」後",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_064"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "沒多久……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n我為了尋找安靜的地方，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "而四處",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "遊蕩……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "雖然老婆婆",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "有向我搭話，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我下意識地……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "下意識地",
        "unit_id": 106412,
        "voice": "vo_adv_5202007_065"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "逃走了……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "唔……",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_066"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請等一下。",
        "unit_id": 134411,
        "voice": "vo_adv_5202007_067"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這難道是說……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐現在，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n其實擁有樂譜，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只是不知道",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "怎麼使用？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "這",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_068"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n那個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "唔唔……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "是的。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……我明白了。",
        "unit_id": 134411,
        "voice": "vo_adv_5202007_069"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "既然如此，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天就來場課外教學，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "跟我一起",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "學習樂譜方面的事吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "順便也把我的樂譜交給妳。",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_070"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我有帶著空白的譜紙和筆，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "馬上就開始進行吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好、",
        "unit_id": 134311,
        "voice": "vo_adv_5202007_071"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n千歌老師……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就是說啊。",
        "unit_id": 611,
        "voice": "vo_adv_5202007_072"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "雖然我聽聲音",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就知道她是唱喚士，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "但她實在太沉默寡言了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我也很傷腦筋。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "用年輕人的話來說，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就是「陰沉角」",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "吧？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "結果那時候，",
        "unit_id": 611,
        "voice": "vo_adv_5202007_073"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我就只有把樂譜塞給她……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "不過，看來她們彼此",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "都找到好夥伴了呢。",
        "unit_id": 611
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "過去尋尋覓覓的夥伴，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "其實就近在身邊──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n感受到這段緣分是如此不可思議的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌與蘭法。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在峽谷中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這兩名唱喚士所交織出的歌曲"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優美地迴盪。"
    }
]