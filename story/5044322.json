[
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "唔～！",
        "unit_id": 13511,
        "voice": "vo_adv_5044322_000"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "沒想到追求到這種地步都不行……！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n看樣子，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "是那邊的你在礙事吧！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "要是沒有你，",
        "unit_id": 13511,
        "voice": "vo_adv_5044322_001"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺現在應該",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n正享受著呦齁齁的後宮！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n不可原諒，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "不可原諒啊！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "這全都是你的錯～！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "事情為什麼會變成那樣啊……",
        "unit_id": 113111,
        "voice": "vo_adv_5044322_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔哇～",
        "unit_id": 113311,
        "voice": "vo_adv_5044322_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣牽怒也真是夠了……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這就是所謂的搞錯對象了，",
        "unit_id": 113211,
        "voice": "vo_adv_5044322_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "花心星！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "去給我從頭來過吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "喂喂，",
        "unit_id": 13511,
        "voice": "vo_adv_5044322_005"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "和那種男人相比，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "本大爺才更有魅力吧！？",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n看看我這個尖挺的外型！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "輝光閃閃的眼眸！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "熾熱燃燒的靈魂！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n連逗女孩子開心的說話技巧都很完美喔！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真煩悶。",
        "unit_id": 113211,
        "voice": "vo_adv_5044322_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "煩人。",
        "unit_id": 113111,
        "voice": "vo_adv_5044322_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "整個就很煩。",
        "unit_id": 113311,
        "voice": "vo_adv_5044322_008"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "哦哦──！",
        "unit_id": 13511,
        "voice": "vo_adv_5044322_009"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "這就是所謂的欲拒還迎吧！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n呀齁哦哦哦！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "謝謝妳們的支持──！！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔哇！",
        "unit_id": 113311,
        "voice": "vo_adv_5044322_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "討厭～這傢伙是怎樣！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不管說什麼都只會提升他的力量嘛！！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "既然如此，",
        "unit_id": 13511,
        "voice": "vo_adv_5044322_011"
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "就來比比看誰才是好男人吧！",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "\n哦哦，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "妳們等著啊，",
        "unit_id": 13511
    },
    {
        "type": "dialogue",
        "name": "覺醒‧花心星",
        "words": "可愛的小妞們～～～～！！",
        "unit_id": 13511
    }
]