[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞在傳說的吸血鬼的傳頌之地，受到推崇而成為了此地之主。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n伊莉亞坐上王座後，魔物們紛紛來到她的跟前。"
    },
    {
        "type": "still",
        "still": "512000201"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "伊莉亞大人，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_000"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "萬歲～！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "\n伊莉亞大人，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "萬歲～！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈！",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看到了嗎？{player}啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身之前雖然沒有清楚告訴過你，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但妾身原本",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可是像這樣受到魔物們崇敬的存在。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如何？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有再次認識到妾身的偉大了嗎？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯。",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你果然是個可愛的傢伙。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你不需要尊稱妾身為大人喔。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為你是特別的啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳心情真好呢，",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不對，雪，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳稱呼妾身還不加上大人嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不然妳就在那裡跟魔物們",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一起對妾身下跪也可以。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧來吧，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "像它們那樣俯首崇敬妾身。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳在說些什麼啊？",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n它們是因為我亮麗的秀髮太過耀眼，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才睜不開眼睛低下頭的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "它們明明是在喊伊莉亞大人萬歲啊！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_008"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不過",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然是暫時享受了被人奉承的感覺，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但說要妾身領導這些傢伙，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟該做些什麼才好啊？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "若是行程，",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_010"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "已經都安排好了。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說來聽聽吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "關於傳說的吸血鬼復活",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_012"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "並降臨於此地的消息。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "已經透過生活於黑暗之物的情報網",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "傳到各地去了。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喔～",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳變得那麼有名了呀，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "這是當然的。",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_014"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n傳說的吸血鬼復活，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是我們魔族以及黑暗魔物們的夙願。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "而這樣的伊莉亞大人所在的這塊地，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "正是我們的憧憬之地。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "現在也不斷有想申請移居至此地者前來。",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_015"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "希望伊莉亞大人",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "可以謁見它們。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身來到這裡還未滿一天的時間，它們就已經過來了嗎！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "謁見……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "太拘謹的儀式讓人很提不起勁啊……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "還請您見諒。",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_017"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "與來自各地的來訪者們建立良好的關係，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n若能順利讓它們服從，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "不僅能提升伊莉亞大人的地位、",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "宣揚您的名聲，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n還能加速傳說的復活吧。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果在這裡被它們討厭，",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不僅會降低伊莉亞的地位，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "名聲一落千丈，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還會毀了讓傳說復活的機會呀。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳為什麼要給妾身製造壓力！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這反而更令人提不起勁了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眷屬啊，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你有沒有什麼好辦法？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "由你來擔任妾身的發言人進行謁見啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這真是個好辦法！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "交給我吧♪",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我會讓大家",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都變成我美貌的俘虜的！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就交給你們了！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身就坐在那裡表現出妾身的威嚴吧！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "！？",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……這些玩笑先撇開不談。",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然這是讓妾身完全復活的捷徑，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那也只能去做了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "去把那些前來謁見妾身的傢伙",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都帶過來吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是！",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_027"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n那麼，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我去將它們帶過來。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來看看，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟會是些什麼樣的傢伙──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_029"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "啊，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_030"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "失禮了。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n不小心就順著習性大聲吼叫了……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來那是習性啊……",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_031"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "伊莉亞‧奧恩斯坦大人。",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_032"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n此次恭喜您復活。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n能拜見您的尊容，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "真是我的榮幸……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不需要那麼拘謹，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "抬起頭來吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "真、",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_034"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "真不愧是流傳於傳說之中的吸血鬼大人……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n連對我等這些區區的魔物都如此寬宏大量……！",
