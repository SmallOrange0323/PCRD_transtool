        "type": "dialogue",
        "name": "布拉德",
        "words": "伊莉亞大人，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "下面的來客還在等──",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "嗨，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_073"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "打擾啦……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "哦，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_074"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "妳就是傳說的吸血鬼啊。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n什麼啊，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "還以為會是怎麼樣的怪物，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n結果這不是和人類沒兩樣嗎……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺來了個很好懂的傢伙呢。",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_075"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過我是分不出它和其他魔物有什麼不同就是了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊～",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_076"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你就是那個吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聽到傳說的吸血鬼復活的傳聞，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以企圖打倒妾身，來藉此宣揚自己的名聲吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "真是佩服，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_077"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "本大爺的野心",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "也全都被妳看透了啊！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "沒錯，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "本大爺",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "就是來終結那個什麼傳說的！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "光是沒帶大蒜來，就令人感到療癒了。",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_078"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "為、",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_079"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "為什麼會感到療癒！？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那還用說？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_080"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "客人專程來這一趟，當然要好好招待了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就讓它見識見識",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_081"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "統御黑夜之人的力量吧……！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳其實只是想宣洩",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_082"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對大蒜的仇吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "哼，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_083"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "雖然不太懂怎麼了，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n但這可以當成是妳接受挑戰了吧！？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好。",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_084"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──就稍微陪你玩玩吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "……！",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_085"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n好驚人的氣魄……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "真是佩服……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n哦哦，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "我得注意保持距離才行啊……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_086"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "長得那麼高大，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "個性倒是挺膽小的啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "那當然，",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_087"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "我可是知道的喔。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n傳說的吸血鬼",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "可以將脖子伸長到很驚人的距離來吸血對吧？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "聽說甚至能遠遠伸到那掛在天空上的月亮啊！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_088"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "而且",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_089"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "眼睛還會射出將一切燃燒殆盡的奇怪光線，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n口中可以吐出能腐蝕任何東西的氣息對吧！？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n我怎麼可能會隨便接近妳……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇～",
        "unit_id": 126311,
        "voice": "vo_adv_5120002_090"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞好厲害～！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也稍微離遠一點好了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "慢著，雪，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_091"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身可做不到那種事啊！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且眷屬啊，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你為什麼要雙眼充滿期待地看著妾身！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂，你這傢伙！",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_092"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是在哪裡知道那種傳說的！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "咦？",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_093"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "就是鎮上賣的",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n《詳解傳說的吸血鬼》這本書上寫的啊？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "\n……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "妳看，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "就是這本。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "……！",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_094"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "拿來給妾身看看！",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_095"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "上面寫了什麼？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n「傳說的吸血鬼幾乎已克服了任何弱點，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n會用白木樁蓋房子，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在太陽底下跳踢踏舞……」",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這什麼鬼啊！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_096"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟是誰寫出這種東西的……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "哦哦，伊莉亞大人！",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_097"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "這麼說來，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "今天天氣很好，要不要外出散步──",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──作者，",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_098"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "布拉德。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "…………",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_099"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "罪魁禍首就是你啊────────────！",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_100"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我只是",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_101"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "將調查傳說時發現的事實，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "稍微加筆記錄下來，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "以方便流傳而已……！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "朱色之嚙──！",
        "unit_id": 126211,
        "voice": "vo_adv_5120002_102"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "唔喔喔喔喔喔喔！？",
        "unit_id": 9811,
        "voice": "vo_adv_5120002_103"
    },
    {
        "type": "dialogue",
        "name": "看似兇惡的魔物",
        "words": "為什麼連本大爺都攻擊────！？",
        "unit_id": 1611,
        "voice": "vo_adv_5120002_104"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞與各式各樣接獲復活消息而來的訪客進行交流，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而她所付出的那些辛勞也有了回報。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聚集於此地的黑暗之物數量因此大幅地增加了。"
    }
]