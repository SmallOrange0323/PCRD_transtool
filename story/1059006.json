[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，在下先前因身體不適造成您的困擾了，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n多虧您的照顧，在下已經康復了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經沒事了，所以請不用讓在下騎到您的脖子上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣很像小孩子，令人覺得害羞。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下可以自己走路唷？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "(嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在下前幾天得了感冒……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人有點過度溫柔。)",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "(雖然很高興主人能珍惜在下。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但在下好像給主人添了麻煩，心裡覺得很難受。)",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "(真要說起在下的使命……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明是要保護和引導主人的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在反而像是主人的寵物，或是妹妹、女兒之類的。)",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "(能夠得到主人滿滿的愛，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下真的覺得很幸福……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這樣下去是不行的。)",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "(在下必須讓主人想起，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是可靠又能獨當一面的『嚮導』。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n存在的意義就是要讓主人依靠、讓主人撒嬌。)",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，您知道銀行是什麼嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至今在下和主人工作存下的錢……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也算是有微薄的收入。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然扣掉生活費和伙食費就所剩無幾了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過我們也有了【咲戀育幼院】這個棲身之所，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n省下的住宿費也開始存了起來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把全部的財產都放到錢包裡帶著走，實在是有點危險。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下正在考慮，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是否要利用銀行這種可以存放財產的機構。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，因為您沒有證明身分的東西……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以就用在下的名義來開個帳戶。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "存摺就寄放在主人那邊，您有需要的時候，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要領出您想要的金額即可。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果您覺得不放心，在您熟悉之前，存摺就由在下來保管。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天在下想要教您如何使用銀行。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，很像『嚮導』吧……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，現在在下想前往銀行所在的大街上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不是那邊喔，大街是在對面",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哎呀？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "…………",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，有隻汪汪呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人很在意牠嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，請把在下放下來。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n牠似乎是有人飼養的狗，所以應該沒有危險性，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但被咬到的話就麻煩了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會保護主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，請慢慢地把在下放下來……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有人當坐騎是很輕鬆，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但在下還是用自己的雙腳走路比較安心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且萬一發生了什麼事，在下也能迅速對應。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "狗",
        "words": "…………",
        "unit_id": 1811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這隻汪汪好像沒什麼精神呢……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎有點虛弱。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠戴著項圈，在下認為牠是有人飼養的。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但牠是不是和飼主走散了呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "汪汪迷了路，在巷子裡徘徊……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，好可憐喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過來，汪汪。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不要怕喔，在下並非你的敵人喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。是不是有點孩子氣呢？",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下從小就把狗叫做汪汪，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以把汪汪叫做『狗』反而覺得不自然。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "順便一提，在在下的故鄉有很多像這樣的小動物。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在協助父親工作的時候，在下經常會照料牠們喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而照料牠們的要領也可以適用於主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下自覺偶爾會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n把主人當成動物或是嬰兒來對待…….",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您覺得不愉快的話，",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下感到非常抱歉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，雖然也有其它地方的人吃牠們。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下又不像佩可小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一看到動物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就清一色立刻把牠們當作『食物』來看待。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果吃掉這麼可愛的動物，一定會遭天譴喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "乖、乖……♪　",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不要擔心，我們會幫你找你的主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正好銀行所在的大街上，有各式各樣的機構。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "飼養寵物的人都有義務向相關機構登記的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以我們去那裡調查的話，大概就能知道飼主是誰了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下來抱抱你，汪汪……♪",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，抖得這麼厲害……",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和你的主人分開讓你感到恐懼不安呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白你的心情。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下之前也一直無法遇見主人喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正因為如此，在下現在非常幸福。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們走吧，主人。",
        "unit_id": 105913,
        "voice": "vo_adv_1059006_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但願永遠……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能像這樣與主人並肩同行的話，在下就覺得很幸福了。",
        "unit_id": 105913
    }
]