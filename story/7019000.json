[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聳立的巨大建築物……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}跟莫妮卡一起仰望露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有閣下記憶的線索對吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我總是受到閣下的幫助，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n所以我這次",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會幫忙進行調查。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣上儘管放一百二十個心吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在那之前……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "躲在那棵樹後面的人是誰！！",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n快現身",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "報上姓名！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉，",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我原本沒有躲起來的意思……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不是可疑人士。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那、",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那種事一點也不重要！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳到底是何方神聖……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯嗯！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你好啊，",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳是……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳靠那麼近",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是怎麼了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……我原本還以為是幻覺，",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但並非如此。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "果",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "然",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然能遇到【王宮騎士團】的團長閣下，",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n真是太幸運了！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我叫",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "莫妮卡‧拜斯溫特！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我是個軍人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "隸屬於光榮的純白之翼！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我聽過妳種種英勇事蹟！",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "守護蘭德索爾的最強之盾與劍……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那就是指妳！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然侍奉的國家不同，",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但同樣身為守護人民的公僕，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請多多指教！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "純白之翼……？",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n呃",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這麼說來，",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我曾經看過一群小孩創造虛構的公會在玩。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不破壞小孩的夢想也是",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "正義夥伴的職責。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這裡就……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我叫純。",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真虧妳不辭千里來到這裡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n請務必",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "告訴我關於那支部隊的各種事蹟。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔喔……",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我終於跟純閣下握到手了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這是我夢寐以求的願望之一！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳的手很像軍人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很強壯……！！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不需要那種掃興的吐槽！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……更重要的是。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這座塔裡",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "應該有很多危險的魔物吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你也請純閣下",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "幫忙如何？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且我",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很想拜見純閣下的劍技。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可不能放過",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種大好機會……！　",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呃……",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你們是打算",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "爬上那座塔嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "沒錯。",
        "unit_id": 105311,
        "voice": "vo_adv_7019000_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "聽說那裡面有他的記憶的線索！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我打算跟他一起行動",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好保護他！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……這樣啊。",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是怎麼一回事？",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年居然找這麼小的女孩當護衛？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n平時的少年",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該不會做出這種事……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫非是某種扮家家酒？",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n仔細一看，她比茉莉更加嬌小……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是在玩就說得通了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這其中或許是有什麼原因。",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n初次見面且",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不曉得狀況的我",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不適合過問太多。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "幸好今天沒當班。",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟基於個人理由幫忙是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "屬於濫用職權。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我就以我的意志",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "保護他們吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我明白了。",
        "unit_id": 104711,
        "voice": "vo_adv_7019000_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也一起行動吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n請你們",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "多多指教。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莫妮卡踮起腳尖。純彎腰蹲下。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}跟握過手的兩人一同"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n探索起露娜之塔。"
    }
]