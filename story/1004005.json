    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}在散步時，\n拿著大量行李的禊走了過來。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥、哥哥！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們去探險吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊為了探險做了各種準備呦！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "裝備超齊全的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥問禊要去哪？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不知道為什麼要去？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真是的～那些事情怎樣都好啦！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n總之禊想要跟哥哥去冒險嘛！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是這樣，我們出發吧！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "和哥哥一起去探險～！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n呀哈哈哈～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯，禊超開心的！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "其實呀～",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊的爸爸是探險家喔～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "他常常因為探險出門旅行，",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以很少待在家裡頭，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過禊最喜歡爸爸了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "想到自己可以像爸爸一樣去探險，",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊就超級開心的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且探險總是讓人很興奮吧！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，我們一起來尋寶吧～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……哥哥問有沒有寶物？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊不知道。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過只要我們隨便到處走走，",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n寶物應該就會自己跑出來吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸？要禊說一下目的地？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n其實禊沒有特別去想耶。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣子比較像在冒險吧！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，那邊好像有什麼東西！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "說不定是寶物！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥，我們過去看看吧～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚嗚……？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n什麼東西都沒有？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是剛剛真的有看到會動的東西呀……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚哇！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是、是魔物！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──呱歐歐歐歐歐！\n──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且還超級多！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這裡是魔物的巢穴嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "怎、怎、怎麼辦！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊和哥哥，被包圍住了？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥你才要冷靜一下吧……",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？看到哥哥慌慌張張的樣子，",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊好像反而冷靜下來了？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就、就是說啊！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n只要兩人合作，一定可以找到辦法的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，好可靠喔～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "在探險裡遇到危機是家常便飯。",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以禊可是做了很多準備……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！對了、對了！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊有為了探險而準備的行李！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "只要使用這些東西……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯……",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "找到了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "只要用這個煙霧彈的話！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，快趁現在！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我們逃走吧～！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哈、",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哈呼……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "逃到這邊應該就能放心了？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "魔物也沒有追上來，",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n看來我們是成功逃走了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真是好危險呀～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸──！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "明明就非常有趣呀～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿～不要這樣誇獎禊嘛～♪",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呀哈哈哈！真是超有趣的～！",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒想到居然會跑到魔物的巢穴裡，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n真的很有探險的感覺對吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "下一次要去哪裡呢～",
        "unit_id": 100411,
        "voice": "vo_adv_1004005_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "吶吶，哥哥你覺得哪邊比較好？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然遇到了危險，\n但是禊完全沒有學到教訓。"
    }
