    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒事啦，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們早就習慣戰鬥了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來吧，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}，把力量借給我！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來了來了，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別看我這樣，我可是個大忙人。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能不能不要來妨礙我呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是難纏的對手。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "獵人先生，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你沒事吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有沒有受傷？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_061"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我很抱歉！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦、",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦咦！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為什麼要突然這樣……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把頭抬起來啦！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_063"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我原本",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "看不慣你們兩個。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n以為只是把狩獵當作消遣的有錢人，而瞧不起你們。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "但是，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_064"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我發現你們比我更加優秀，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "所以覺得很掃興，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n才做了多餘的事讓你們陷入了危險……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "真的是，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "非常抱歉！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你沒有錯。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我正在做的事，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "取決於個人看法不同，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可能會被當成是有錢人在找事情消遣。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是非常認真地",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "投入這項消遣喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然你未必會理解我們這些小輩的想法。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "……妳真是",
        "unit_id": 911,
        "voice": "vo_adv_1145001_067"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "了不起呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "像妳這種人，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "就是天生的上位者吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你太抬舉我了啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_068"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們繼續狩獵吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還沒抓到最重要的獵物呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "不，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_069"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "狩獵已經結束了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_070"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "你們打倒的這隻魔物，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_071"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "可是超高級的雞啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n這麼大隻的雞，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "可是相當罕見的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦、",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_072"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦咦！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這真是出乎意料的發展……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有這個量的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就能讓孩子們吃個夠了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是意外之喜呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_073"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "獵人先生。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我實在是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不需要這麼多。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你不嫌棄的話，要不要和我平分呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "可、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_074"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "可以嗎……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這種超高級的食材……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這可是你們打倒的耶？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以喔。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_075"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說是條件好像有點奇怪，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但能不能分給我一些\n獵人先生",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "獵到的野生食材呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n除了烤雞以外，我想讓料理的變化豐富一點呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "啊啊，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_076"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "當然可以。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我這裡正好有已經熟成的肉。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n妳想拿多少就拿多少吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那真是感激不盡。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_077"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "若是可以，我希望今後",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還能再和你進行交易，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你意下如何呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "……哈哈，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_078"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "在結束一場大戰後",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "還想著交易的事，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "真讓人佩服啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我們今後就是商業夥伴了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "請多指教啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_079"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請多多指教囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，咲戀獲得了目標獵物，還確立了新的進貨管道，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n如字面上所述，以一石換取了二鳥。"
    }
