    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "慎重地瞄準目標……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
