    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我看看……",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這不是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "超級稀有的蘑菇嗎！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n它作為珍餚之一，在美食家之間很有人氣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但在市面上卻很少出現。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真虧你認得出來呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "那、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_047"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "那個小鬼，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "竟然認得連我都不知道的蘑菇……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這個女人也好，這些傢伙到底是怎樣……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n可惡，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "真掃興啊……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "嗯……",
        "unit_id": 911,
        "voice": "vo_adv_1145001_048"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "那個是……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "不會錯的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "就是今天的目標，高級雞！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "他們好像還沒有發現。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "雖然從這裡瞄準有點遠，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_049"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我要一箭解決牠，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n在這兩個傢伙面前展現我身為獵人的威嚴。",
