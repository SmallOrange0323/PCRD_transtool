[
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在臨近聖誕的某天夜晚，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n咲戀一個人待在大廳，對著記帳本發愁。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉──",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "育幼院的聖誕派對就快要到了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但無論計算多少次預算都不夠用……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原本預期的籌款計畫失敗的打擊不小呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "本來平時在各種事上都讓孩子們將就著，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "想說至少聖誕節可以過得豪華一點，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓他們好好享受的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然禮物的部分總算是準備好了，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但照這個情況來看，派對菜單會變得很淒涼呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然如此就去請求父親大人的金援……",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種時候請他出手幫忙",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n太不優雅了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡的孩子們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就如同我自己的小孩一樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我必須先盡自己最大的努力！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "錢也不會突然湧進來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "到底該怎麼辦……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "咲戀媽媽？",
        "unit_id": 211,
        "voice": "vo_adv_1145001_005"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳還沒睡嗎……？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我吵醒妳了嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "沒有喔，",
        "unit_id": 211,
        "voice": "vo_adv_1145001_007"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我只是起來上廁所。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣啊。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳可以自己去嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不害怕嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "可以的唷！",
        "unit_id": 211,
        "voice": "vo_adv_1145001_009"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "咲戀媽媽才是，還好嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳最近好像常常工作到很晚……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒事喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很強壯的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "快上完廁所回房睡覺吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯。",
        "unit_id": 211,
        "voice": "vo_adv_1145001_011"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "咲戀媽媽也別太勉強自己喔？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們還要一起",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好～好慶祝聖誕節呢。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……唉。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "竟然被小孩子擔心了，真丟臉呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，也多虧如此，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我下定決心了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我要讓孩子們過上最棒的聖誕節。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓你們知道你們咲戀媽媽是很厲害的！",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "──就",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這麼一回事，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以我才和你一起來到了山腳下的村莊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然沒有預算就過個沒有預算的聖誕節。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話雖如此，想度過不寒酸的聖誕節，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就必須要有相應的努力和決心呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是說，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "自己能籌備的東西就不要花錢買！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個方法最省錢了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只有我一個人實在是應付不來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才把你也叫來了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你已經算是育幼院的一員了嘛？",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不好意思啦，來幫幫我吧！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能不計得失出手幫助的你，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在這種時候真的相當可靠呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別擔心，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會給出相應的回報。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你可不能不收喔？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就算我們關係再親近也還是要掌握分寸。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當然，我也會邀請你來派對，你就放心吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "另外，我在籌備聖誕節的事情",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要對孩子們保密喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想用孩子們不曾見過的豐盛大餐，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "給他們一個驚喜呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們現在要一起去狩獵。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說到聖誕大餐的主角，非烤雞莫屬了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要將烤雞擺上桌，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就能讓聖誕節的層次完全不一樣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要準備足夠這麼多人",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n吃的烤雞，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對錢包是一大傷害。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "儘管如此，我還是希望能讓大家都吃到。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那樣的話，自己去狩獵就行了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且要挑最高級的那種雞喔！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們現在要進入的山裡，有很多野雞棲息。",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且牠們的肉可是要在",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n高級食材店或餐廳才看得到的夢幻食材喔。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽說那裡也有魔物出沒，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不能算絕對安全。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我們本來就因為工作的關係經常出入危險的地方嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我向管理這座山的村莊申請入山許可，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n他們就很親切地為我介紹了一個獵人作為嚮導──",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "說想入山狩獵的，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_029"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "就是你們嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是我們沒錯……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你就是作為嚮導的獵人吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n突然拜託你真是不好意思，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "請多指教囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "……哼，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_031"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我只是因為工作關係不得已才奉陪的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n醜話說在前頭，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "別小看山了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我已經數不清見過多少次像你們這樣的傢伙死在山裡了。",
        "unit_id": 911,
        "voice": "vo_adv_1145001_032"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n外行人就別做多餘的事，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "知道了嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會銘記在心的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "嘖，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_034"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "真是惹人厭的女人。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "帶男人來這裡玩狩獵遊戲？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n真是的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "也不會為我們這些被迫奉陪有錢人消遣的可憐人想想。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "不過，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_035"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "我就看看妳那份餘裕能維持多久。",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "呼、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_036"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "呼……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_037"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這兩個傢伙是怎樣……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n為什麼能在第一次造訪的山路上",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這麼暢行無阻啊！　",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "喂、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_038"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "喂你們兩個！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "跑太前面了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "給我謹慎點前進！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們有點太躁進了呢。",
