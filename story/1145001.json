    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "哇呀──！",
        "unit_id": 911,
        "voice": "vo_adv_1145001_052"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "是、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "是魔物──！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是被獵物的叫聲引來的吧。",
