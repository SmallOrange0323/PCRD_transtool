        "voice": "vo_adv_1145001_056"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這應該逃不太掉呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要上囉，{player}！",
