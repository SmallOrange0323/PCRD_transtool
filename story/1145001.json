        "voice": "vo_adv_1145001_045"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這樣啊……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "妳懂得不少嘛。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "話說，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "你這傢伙從剛剛開始就在鬼鬼祟祟的做什麼？",
