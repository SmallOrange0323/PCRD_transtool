    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "獵人先生說得沒錯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會注意的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "妳、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_040"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "妳知道就好，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "知道就好。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "可惡，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_041"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "竟然還這麼從容，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "真讓人不爽。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "嗯？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "那個是……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "來得正好，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "等一下就讓妳哭出來。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "哦，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_042"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "快看那裡。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "那裡長著的蘑菇，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n是難得一見的高級品喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "要不要順便採回去？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "騙妳的啦，",
        "unit_id": 911,
        "voice": "vo_adv_1145001_043"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "那是長得像高級蘑菇的毒蘑菇。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n妳看起來是有一些冒險經驗，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "但知識方面又懂多少呢，大小姐？　",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個是……",
        "unit_id": 102811,
        "voice": "vo_adv_1145001_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然長得很像，但這是毒蘑菇呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為了不把毒蘑菇賣給客人，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我平時就有在好好學習這些容易混淆的知識。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "這、",
