        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "雖然完全不是牠的對手，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n但我得爭取到讓這兩個傢伙逃跑的時間！　",
