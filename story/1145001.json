    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "喂、",
        "unit_id": 911,
        "voice": "vo_adv_1145001_055"
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "喂混蛋魔物！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "你的對手是本大爺！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "給、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "給給、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "獵人",
        "words": "給我放馬過來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀哎呀，",
