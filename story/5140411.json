[
    {
        "type": "background",
        "background": "502224"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "美衣子～！",
        "unit_id": 129511,
        "voice": "vo_adv_5140411_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊哈哈，",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "球跑到妳那邊去了～！",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "克蘿依。",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼事？",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒發育得真好啊。",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是這樣呢。",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我要什麼時候才會變成那樣呢？",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦……",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不，我哪知道……",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過妳想變成那樣嗎？",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我現在也在思考這件事。",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "外表上的差異，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "每個人都各不相同，沒有優劣之分。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我對這個尚在發展中的狀態，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也感到相當地滿足和喜愛。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，也對呢。",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要是發育了就沒辦法混進小小甜心中，",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n跟她們一起玩辦家家酒了呢。",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那樣很困擾呢。",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是不會困擾，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但美美她們一定會非常惋惜吧。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會惋惜嗎……",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該沒有影響吧……",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳們兩位，",
        "unit_id": 129511,
        "voice": "vo_adv_5140411_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼都一臉沉重的樣子？",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "特別講座今天就要結束了，",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可不是感到悲傷的時候！",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "打起精神撐到最後吧！",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "目標是",
        "unit_id": 129511,
        "voice": "vo_adv_5140411_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "獎學金！",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕地上吧！",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮",
        "words": "喔喔～！",
        "unit_id": 1,
        "voice": "vo_adv_5140411_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等～等～等～\n等一下，",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個啊，",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我現在突然注意到了。",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n獎學金的事情，",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這次一丁點都沒有提到吧？",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 129511,
        "voice": "vo_adv_5140411_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是這樣嗎？",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔嗯……",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然很令人不悅，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但修女一直以來都會分別使用糖果和鞭子來隨意驅使我們，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過終於連糖果都捨不得給了……",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是不景氣的時代。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼，",
        "unit_id": 129511,
        "voice": "vo_adv_5140411_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這次就不是公會活動了啊……",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "既然這樣，",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那這次是什麼活動？",
        "unit_id": 129511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "誰知道……",
        "unit_id": 129411,
        "voice": "vo_adv_5140411_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "慈善活動？",
        "unit_id": 129411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "慈善活動啊……",
        "unit_id": 129511,
        "voice": "vo_adv_5140411_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔嗯，",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算擺脫了地獄的詛咒，",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n到頭來我們的命運還是會將我們導向正人君子呢。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這也是因為我們與生俱來的善良本性吧。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒辦法了，",
        "unit_id": 129311,
        "voice": "vo_adv_5140411_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "上吧，同志。",
        "unit_id": 129311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n作為善人開始這最後一天吧。",
        "unit_id": 129311
    }
]