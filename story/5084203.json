    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔、",
        "unit_id": 106411,
        "voice": "vo_adv_5084203_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好害羞……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在可不是給妳害羞的時候啊，",
        "unit_id": 106011,
        "voice": "vo_adv_5084203_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看那邊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "另外還有許多組魔物的足跡在。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看來它可能還有其他夥伴吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來相關報告似乎尚未",
