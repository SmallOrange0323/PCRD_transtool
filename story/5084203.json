        "voice": "vo_adv_5084203_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳到【公會管理協會】那裡。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管仍不清楚敵人的數量，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但就此繼續進行偵察……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抑或是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "視情況將魔物們都給討伐完畢，可能較好。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說、",
        "unit_id": 106411,
        "voice": "vo_adv_5084203_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說得也是。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……繃緊神經往前進吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次戰鬥也很期待妳的表現喔，",
        "unit_id": 106011,
        "voice": "vo_adv_5084203_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
