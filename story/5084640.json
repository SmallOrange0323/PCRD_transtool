[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂，",
        "unit_id": 104412,
        "voice": "vo_adv_5084640_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "早就叫你快點醒來了啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n放著妾身不管，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "打算睡到什麼時候？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n吾之眷屬啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……只要那傢伙不在，",
        "unit_id": 104412,
        "voice": "vo_adv_5084640_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就覺得無趣得無以復加。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "心上就像空了個大洞，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "感到好不安，無法冷靜。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n回過神來，才發現妾身想的全是那傢伙的事情……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "能讓妾身執著到這種地步……",
        "unit_id": 104412,
        "voice": "vo_adv_5084640_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在這漫長的吸血鬼一生中，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這還是頭一遭呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……等到海枯石爛並不符合妾身的性格。",
        "unit_id": 104412,
        "voice": "vo_adv_5084640_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就由身為統御黑夜之人的妾身",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "親自出一份力。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之頭號眷屬，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身一定會抓住你、帶你回來的！",
        "unit_id": 104412
    }
]