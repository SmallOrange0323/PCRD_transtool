[
    {
        "type": "background",
        "background": "509001"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鳳凰與{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為某個理由，\n而從吉歐‧格黑納來到了蘭德索爾附近的農村──"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咿～～～～～～～～～！！",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_000"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "受死吧啊啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1347001_001"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為什麼～～",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_002"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為什麼偏偏是我遇上這種事────！？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "蠢貨！",
        "unit_id": 1,
        "voice": "vo_adv_1347001_003"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "那個雞屁股",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "逃去哪啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "不對，",
        "unit_id": 1,
        "voice": "vo_adv_1347001_004"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "是雞翅！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "雞胸軟骨！",
        "unit_id": 1,
        "voice": "vo_adv_1347001_005"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "唔唔唔唔唔，",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_006"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "竟然用雞的",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "可食用部位名稱來稱呼作為神的我，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n何等不敬……！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "話說！",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_007"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n我明明是要在這個世界的農村享用好吃的米才對，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n為什麼事情會變成這樣啊啊啊！",
        "unit_id": 134713
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "事情要回溯至"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "昨天在吉歐‧提格尼亞所發生的事件──"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "唔唔唔……",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_008"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "唉，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n果然",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "好像無法變成人類的樣子……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n明明",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "貪吃佩可已經幫我取回一部分權能了……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那個超巨大的人偶……",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_009"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "巨、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "巨型？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "巨型的克蘿茜，我似乎把力量全都用來搬運她了。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n雖然還能正常說話……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "真是的！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不論我是個多麼莊嚴、優雅且可靠的神，",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_010"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n盡是被捲入麻煩事，我會很困擾的！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n我可不會再上人類花言巧語的當了！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你又來了，",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_011"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我才剛說完，你又講那種表面好聽的話……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咳咳。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "算了，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "要是想獻上供品，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那我就鄭重接受吧，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "畢竟我肚子也餓了。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我想想……",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_012"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "吉歐‧提格尼亞的甜食雖然也不賴，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n但既然要吃，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我想要更能填飽肚子的東西……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "對了，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "米！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我想吃米飯！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "以前",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_013"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "真陽請我吃的米，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n那還真是相當好吃呢。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "雖然我不能接受她把我當成小雞就是了。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這就是所謂的事不宜遲吧。",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_014"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你的心態值得嘉許♪",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n那麼騎士先生，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我賜予你把我放在肩上走的權利！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n啾啾～♪",
        "unit_id": 134713
    },
    {
        "type": "background",
        "background": "509001"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "真是相當恬靜的地方呢。",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_015"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n農田裡金黃色的稻穗結實纍纍……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "呵呵呵，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "彷彿就像在等待我一樣啊！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就、",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_016"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就算是生米我也無所謂了！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n趕快",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "請那邊的農民把米分給我們吧！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "……啥？",
        "unit_id": 1,
        "voice": "vo_adv_1347001_017"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "你們有什麼事？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我是",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_018"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "鳳凰，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "是偉大的神鳥！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n我就賜予你們",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "向我獻上米的權利吧！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你們該感到榮幸……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "你這",
        "unit_id": 1,
        "voice": "vo_adv_1347001_019"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "害鳥！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n是盯上咱們好不容易",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "才種好的稻子嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n大夥！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "有害鳥──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "快出來快出來！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "害害害害",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_020"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "害鳥？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不敬也要有個限度啊！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n你沒看見這不染塵垢的美麗羽毛嗎？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n這是作為神的……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "呀──！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "鋤頭！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不要用鋤頭啊──！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "什麼？",
        "unit_id": 1,
        "voice": "vo_adv_1347001_021"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "那不是麻雀嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "因為牠一臉渴望地",
        "unit_id": 1,
        "voice": "vo_adv_1347001_022"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "看著咱們的稻子，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n咱還以為是哪種害鳥啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我、",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_023"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我才沒有露出那種眼神啦～！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n雖、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "雖然",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "肚子確實有點餓了……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "那你早說啦？",
        "unit_id": 1,
        "voice": "vo_adv_1347001_024"
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "\n白飯的話咱們多～的是啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "給你！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "哇哇，",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_025"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "在碗裡堆得像山一樣的白飯……！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n咳咳。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "明白了就好！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "很好。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n那份供品，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我鳳凰就吃個精光吧！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嚼嚼……",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_026"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯嗯嗯，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這米飯的甜味！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n是新米！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "剛煮好的！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "好幸福～！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "多吃點。",
        "unit_id": 1,
        "voice": "vo_adv_1347001_027"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "再多吃點。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "細嚼慢嚥地吃啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯咕嗯咕，",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_028"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啊，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "又添了新的飯……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n嚼嚼、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啊呣啊呣。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "已、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "已經吃不下了。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "別說肚子了，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "快連喉嚨都塞滿……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "什麼啊，你已經飽啦？",
        "unit_id": 1,
        "voice": "vo_adv_1347001_029"
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "\n呵",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "呵",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "呵……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "那就……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民１‧農民２‧農民３",
        "words": "受死吧啊啊啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1347001_030"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯咕咕！？",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_031"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n為為為、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為何、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為什麼？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "等等啊～～～！？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "呵呵呵……",
        "unit_id": 1,
        "voice": "vo_adv_1347001_032"
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "滿滿",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "填進肚子裡的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "\n那些米，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "想必浸滿了上好的湯汁吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "如果是在比大江戶還更遙遠的地方才能",
        "unit_id": 1,
        "voice": "vo_adv_1347001_033"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "吃到的「蔘雞湯」，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n那個魔物肯定也會滿足的吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯唔！",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_034"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n那、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那麼用力勒我脖子的話！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不行！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n米要從嘴巴……！？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嘔噁噁～",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "什、",
        "unit_id": 1,
        "voice": "vo_adv_1347001_035"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "什麼？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n從那害鳥的嘴裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "流出了神祕的白色液體……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n在、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "在閃閃發光……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為、",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_036"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "為什麼要接住！？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "啊……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n的、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "的確，糟蹋食物的話會讓生產者生氣吧。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "應該說，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我剛剛就差點被殺了啊。",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "等……",
        "unit_id": 134713,
        "voice": "vo_adv_1347001_037"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦咦咦？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "就算不可以糟蹋食物，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n但你那樣也太……！",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "用、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "用那邊的水桶──",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n……",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗚噗、",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嘔噁噁～",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……話說，",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_038"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦、",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "咦？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "變回人類的模樣了？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n是多虧吃了米嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "哦哦……",
        "unit_id": 1,
        "voice": "vo_adv_1347001_039"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "變成小姑娘的樣子啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n原來不是害鳥嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "所以我不是說了好幾遍了嗎────！",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_040"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1347001_041"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "真抱歉啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n雖說是因為不知道，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "但咱們做了很不好的事啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "其實最近",
        "unit_id": 1,
        "voice": "vo_adv_1347001_042"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "咱們因為奇怪的魔物",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "破壞田地而感到很困擾啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n咱們總是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "獻上美味的米飯料理",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "就能請它回去，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n所以想",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "作為供品……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "豈、",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_043"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "豈有此理，明明我才是收受供品的一方，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n竟想把我料理成",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "什麼「蔘雞湯」去獻祭！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n還有到底是怎麼一回事啊，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那種貪吃鬼魔物！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "這、",
        "unit_id": 1,
        "voice": "vo_adv_1347001_044"
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "這個腳步聲……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "說到就到！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "\n是那傢伙！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "那傢伙來啦！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "什、",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_045"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "什麼那傢伙？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那是……！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那個……",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_046"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不是祟神嗎！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "精靈或諸神由於喪失力量，",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_047"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n而化為沒有理性的野獸，就是祟神。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n可以說，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "跟過去的我是一樣的。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "雖然我受到了騎士先生你們的幫助，",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_048"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "但要是走錯了一步……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "騎士先生也",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_049"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那樣想嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "啊啊啊啊，",
        "unit_id": 1,
        "voice": "vo_adv_1347001_050"
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "已經完蛋啦～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "\n「蔘雞湯」也沒有如願，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民2",
        "words": "什～麼料理都沒有！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "壽司、燉飯、炒飯、",
        "unit_id": 1,
        "voice": "vo_adv_1347001_051"
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "香料飯也都已經給它吃過啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n咱們已經想不到什麼米飯料理啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "\n那個貪吃鬼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "農民1",
        "words": "對已經吃過一次的料理根本不屑一顧啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……好吧，",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_052"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n既然如此，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那就交給我吧！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "同樣身為神，",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_053"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我無法置之不理！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "讓它吃上美味的米飯料理，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "像我一樣",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "取回力量吧！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "妳",
        "unit_id": 1,
        "voice": "vo_adv_1347001_054"
    },
    {
        "type": "dialogue",
        "name": "農民３",
        "words": "會做料理什麼的嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "對於作為神的我來說，",
        "unit_id": 134712,
        "voice": "vo_adv_1347001_055"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "沒有什麼不可能──！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
