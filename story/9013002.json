[
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯……",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "比上不足，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "比下有餘。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n既然不能隨著性子行動，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哎呀哎呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這該如何是好呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "──涅妃‧涅羅皇女。",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_001"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n能在這樣的地方見到您，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "真是深感榮幸。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請容我冒昧，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "看您好像遇到了什麼困擾呢。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這不是格蕾斯閣下嗎。",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "見汝別然無恙，甚感欣慰。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想必汝已有所耳聞，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家正為了貪吃佩可公主，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在暗地裡製作國際博覽會的地圖呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不巧，",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家的隨從兼顧學習，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此刻正伴於萊拉耶爾公主身旁。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "憑藉奴家這纖弱",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "又不明經世事之身，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想於街道獨自漫步",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恐有危險疑慮，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正感到一籌莫展呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "說起來真是羞愧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "原來如此。",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_004"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如果是這樣的話，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "請容我僭越，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就由我陪伴您吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "剛好很閒──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "不",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "剛好手邊沒有事情需要處理。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "即使是不同世界，",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_005"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "守護騎士的立場都是相同的。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我會代替安涅默涅氏，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "完美地完成這項任務。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這番提議真是幫大忙了，",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無疑是雪中送炭。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家感激不盡。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "格蕾斯閣下呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還請汝協助了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不過──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝無須同默涅般，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此繃緊神經。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論何時都有自己的步調，",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若在宴會場合更是如此。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這才是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "格蕾斯閣下的真本領所在──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "是這樣嗎……",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_008"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "您寬大的心胸，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "格蕾斯真是感激不盡。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那我就不客氣了，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "接下來會以得意忘形的狀態與您同行，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n還請多多指教。",
        "unit_id": 133012
    },
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "涅妃‧涅羅皇女，",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_009"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "那邊的攤販",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n有販賣吉歐‧提格尼亞產的棉花糖喔。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n這可是祭典的經典項目呢，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我們一起分享共食吧。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並非由砂糖融化製成的棉花糖，",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_010"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "而是自森林中自然生長的天然甜點，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這樣嗎──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "聽了更是覺得",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "很不可思議的一片土地啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那麼，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就由奴家與格蕾斯閣下一人一半……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "噔燈！",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_011"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n棉花糖中居然！",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "被切斷的手腕……！？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "到底是誰做出這種事情……！",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵，",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這不是格蕾斯閣下的手腕嗎。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n如此美麗的纖纖玉手，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "有著不輸給棉花糖的潔白呢──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝身體重要的部分，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還是還給汝吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "…………",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_013"
    },
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "東國的怪談說書……",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_014"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n僅憑肢體動作與敘事口吻，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便能描繪逼真恐怖的氛圍。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這戲真是演出絕倫。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但是涅妃‧涅羅皇女，",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_015"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "還請您多留心。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n在這樣的地方，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "會引來真正的幽靈現身。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "快看，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "您的背後……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "「小格蕾我，",
        "unit_id": 133014,
        "voice": "vo_adv_9013002_016"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "現在",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就在您的背後──」",
        "unit_id": 133014
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來如此──",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_017"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在說書過程中，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不時撫摸奴家纖細的頸項，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n如靈異現象般冰冷的指尖。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這刺激感也是，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "使演出構成恰到好處。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……是不是呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "格蕾斯閣下呀♪",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……嗯～",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_018"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "完全不為所動。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "完全沒有嚇到。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "安涅默涅氏的話，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "肯定會出現尖叫反擊加上尿褲子的反應的……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但這樣子，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "反而燃起我的鬥志了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不愧是冥府的守護騎士閣下……",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "明明已看透奴家底細，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n卻不受奴家冰冷的態度影響，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "依然嘗試著各種法子。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不錯的氣魄。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "但是我已經開始，",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_020"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "想要聽見新鮮的悲鳴聲了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "該怎麼做……",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哎呀？　",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……涅妃‧涅羅皇女，",
        "unit_id": 133012,
        "voice": "vo_adv_9013002_021"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我們先暫時休戰吧？",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "發現了其他",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "可以瞄準的目標。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵──",
        "unit_id": 129711,
        "voice": "vo_adv_9013002_022"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "格蕾斯閣下還真壞呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那接下來，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家和汝兩人",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就組成「搭檔」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n讓這場宴會更加熱鬧精彩吧──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如此一來蘭德索爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n關於「漆黑無表情幽靈」與「銀色顏藝全裸異夢」的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n全新怪談就此誕生，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不過，這又是另一段故事了──"
    }
]