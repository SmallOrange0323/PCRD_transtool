[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是喔～",
        "unit_id": 123511,
        "voice": "vo_adv_6102203_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你偶爾也會",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看直播啊？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你有什麼推薦的影片嗎？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n什麼類型的都可以喔？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我只是要用來打發時間而已。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你是不是",
        "unit_id": 123511,
        "voice": "vo_adv_6102203_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把我當成小孩子了？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這種影片說不定很適合睡前看。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "況且我這麼重視睡眠，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就來看個幾支影片試試吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "慈樂之音的官方頻道",
        "unit_id": 123511,
        "voice": "vo_adv_6102203_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "前陣子剛建立對吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我有看過一些喔，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "像是製作人訪談之類的。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過我跟智說了這件事之後，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "她不知為什麼一臉一言難盡的表情。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你說有個影片",
        "unit_id": 123511,
        "voice": "vo_adv_6102203_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是一個少女幽靈跟觀眾討布丁，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不然她就會",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "詛咒觀眾？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "什麼啊，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好奇怪的影片。\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這個嘛，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我不想被詛咒，所以應該不會去看吧，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對。",
        "unit_id": 123511
    }
]