[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪真的是個好人呢。",
        "unit_id": 112711,
        "voice": "vo_adv_6040205_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n能老好人到那種程度，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是很少見的。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果大家都能察覺這點就好了呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "才不要，好讓人害羞。",
        "unit_id": 112711,
        "voice": "vo_adv_6040205_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說得也是。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果莉瑪真的很煩惱的話我會說的。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也就是說，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那一天並不會到來。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為大家一定會",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "發現莉瑪的優點啦。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為孩子們很敏銳呢。",
        "unit_id": 112711,
        "voice": "vo_adv_6040205_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明孩子們都不會怕，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大人們卻會怕她，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是奇怪呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在跟她說話之前才是最麻煩的就是了……",
        "unit_id": 112711,
        "voice": "vo_adv_6040205_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就像你說的一樣。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟莉瑪說過話之後",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是把莉瑪當成魔物對待的傢伙，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就由我來\n訓斥他一頓。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然這很不像我會做的事就是了。",
        "unit_id": 112711
    }
]