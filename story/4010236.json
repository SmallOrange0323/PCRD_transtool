    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘿咻──",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這樣就過關了。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你小子也挺厲害的嘛。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "看起來一副乖乖牌的樣子，",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n想不到這麼擅長射擊遊戲啊。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "接下來去把那台夾娃娃機清空好了。",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_001"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你說要幫我慶祝生日對吧？",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那麼",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就得一直陪我玩到我滿意為止喔♪",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "聽好了，",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這間遊樂中心",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "的獎品內容",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n跟其他地方可不一樣。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "仔細看看那些獎品。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "沒錯，",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_003"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "實物在這裡。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那種效果器",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "用來做失真效果音色很棒。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我之前也有打算要買，",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但它上市沒多久就停產了。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真沒想到竟然能在這種地方看到它。",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_004"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我猜店家也很清楚",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這東西的價值不凡。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你看兌換券上還掛著大到令人傻眼的秤錘對吧。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈哈，",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "老闆大概是既期待又怕受傷害吧。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過話說回來──",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真的想夾到這東西，一般至少得玩個100次以上吧？",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "金錢、時間、毅力",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "以及技術──",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這是考驗著每一個環節的硬仗。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你要夾？",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我看你也不像是會想要這種東西的傢伙啊……",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n不過有意思。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我會見證你的",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這場挑戰到最後。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哈哈，",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "還真讓你夾到了。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真虧你能堅持到現在。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你就那麼執著於這個獎品嗎？",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n雖說性能確實挺不賴的……",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊？",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_008"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n……",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊哈哈哈，",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我還想說你難得這麼認真，原來是這麼回事啊！",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那麼，",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我就不客氣地收下囉。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "既然如此──",
        "unit_id": 130031,
        "voice": "vo_adv_4010236_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我們回去吧，",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n義弟費盡苦心才幫我拿到手的東西，豈有不試用看看的道理。",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我今天就用你的戰利品",
        "unit_id": 130031
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來彈奏一曲給你聽吧！",
        "unit_id": 130031
    },
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510205"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥♪",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_010"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我們今天去了水族館、",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_011"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "又去購物、",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "還吃了生日午餐！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……可是可是，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "還沒有要說掰掰對吧？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "哇～！",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_012"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "謝謝你的禮物！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n不管是第一次收到的圍裙",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "還是今年收到的禮物，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n我全部都會好好珍惜的！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "欸欸，",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_013"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我可以打開嗎？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "應該可以吧？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n我要開囉～！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "哇！",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_014"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是項鍊！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "這是",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜的誕生石對吧！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……好美喔。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "成熟的東西……",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_015"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嘿嘿，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "原來如此。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_016"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "現在已經學會做很多種料理了，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n雖然不是很明顯，",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但確實有在長大對吧。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "欸，",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_017"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n你幫我",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "戴上這條項鍊好嗎？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "拜託♪",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……怎麼樣？",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_018"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n適合我嗎？",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嘿嘿、",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_019"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嘿嘿♪",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我爸爸",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "也會幫我媽媽戴項鍊喔。",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "他說這是",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "夫唱婦隨的祕訣！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜的夢想呢，",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_020"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n就是能夠",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "跟大哥哥永～遠在一起！",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n所以──",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "等露娜再更大一點，",
        "unit_id": 111431,
        "voice": "vo_adv_4010236_021"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n我們也來「夫唱婦隨」",
        "unit_id": 111431
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "一下吧♪",
        "unit_id": 111431
    }
]