[
    {
        "type": "background",
        "background": "502360"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望一直隱瞞著自己是戀味癖的事情。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻因為露易絲瑪莉開發的「解放真正自我的祕藥」的效果，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n導致戀味癖體質失控。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "望維持著對氣味敏感的狀態，開始了一日店長的工作──"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拜託了，",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你要跟我保持10公尺以上的距離喔。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不然的話，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我好像就會暴走。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要注意，",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "別在工作時暴走才行。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了舒緩緊張",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先深呼吸……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇啊啊啊……",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我忍不住了！！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗅嗅嗅……♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哈呼……♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "禁、",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_003"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "禁止傷風敗俗──！！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n快點分──開！！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……我問妳哦，",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "露易。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "已經直接叫名字了！？",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你說這是",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「解放真正自我的祕藥」對吧。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然我",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "確實是戀味癖沒錯……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但應該也沒有這麼嚴重啊。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……嗯，",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_007"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "這只是我的猜測，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n但看起來像是症狀比原來嚴重100倍左右。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "可能是太成功了導致效果太強了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那個",
        "unit_id": 132512,
        "voice": "vo_adv_5154002_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "叫做失敗吧。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "已經不只解放",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "而是增幅了耶。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那、",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個啊露易……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳可以幫我做出",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "恢復原狀的藥嗎！？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一直維持這樣的話，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我連偶像都很難繼續當下去……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我才不管呢，",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_010"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "本來就是妳擅自喝掉的啊？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "白白浪費人家的藥，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "真是的……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "關於這點我真的非常抱歉……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……唔，",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_012"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "等一下。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n店那邊怎麼這麼熱鬧？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "離開店還有一段時間吧……？",
        "unit_id": 132312
    },
    {
        "type": "background",
        "background": "502370"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "等等，",
        "unit_id": 132512,
        "voice": "vo_adv_5154002_013"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "怎麼回事",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "大排長龍耶。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "店鋪前面的路",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "人山人海的都擠到動不了了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "總之要先去整理排隊隊伍才行。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "露易去吧。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "是我去嗎！？",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來了這麼多的",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "客人啊……！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好，",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的事就之後再處理。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n打起精神來……！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "望望居然會來這種地方！",
        "unit_id": 1,
        "voice": "vo_adv_5154002_016"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n而且還是一日店長，不知道會做什麼？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "真期待～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "希望能趕快開店～",
        "unit_id": 1,
        "voice": "vo_adv_5154002_017"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n從看到宣傳單時開始",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "我就已經等不及了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "露易、",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "苑。",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n開店準備",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都做好了嗎？",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，我要開店囉！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家～♪",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我是阿爾克絲鍊金堂的",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一日店長望～！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n謝謝你們今天過來～♪",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "唔喔喔喔喔～～～！！",
        "unit_id": 1,
        "voice": "vo_adv_5154002_020"
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "\n望望～～～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "什麼，",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_021"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "好驚人的人數和熱情……！！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "今天會是望望親手給我們商品嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_5154002_022"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n太開心了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "那我要多買一點！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "……咦？",
        "unit_id": 1,
        "voice": "vo_adv_5154002_023"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "但是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "棚架上沒有商品……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n這裡是賣什麼的？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呵呵。",
        "unit_id": 132512,
        "voice": "vo_adv_5154002_024"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我們是阿爾克絲鍊金堂。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n不管是什麼商品，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n都能用露易的鍊金術做出來的店。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……原來如此！",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n無所不有的商店是這個意思啊！",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "咦，",
        "unit_id": 1,
        "voice": "vo_adv_5154002_026"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "什麼商品都可以……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n那、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "也能買到",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "獨一無二的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n望望周邊嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦……！？",
        "unit_id": 132212,
        "voice": "vo_adv_5154002_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那、",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那實在是有點……",
        "unit_id": 132212
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "有的喔。",
        "unit_id": 132512,
        "voice": "vo_adv_5154002_028"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那麼就，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "拜託妳了露易。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "哼……",
        "unit_id": 132312,
        "voice": "vo_adv_5154002_029"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我知道了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "等我一下。",
        "unit_id": 132312
