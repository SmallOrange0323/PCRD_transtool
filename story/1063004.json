    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "應該沒辦法上學，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "但是……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……咦。\n什、",
