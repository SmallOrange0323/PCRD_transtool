    {
        "type": "dialogue",
        "name": "？？？",
        "words": "唔……",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n雖、",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然會撞到你，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是因為我跑太快的錯……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你果然看了！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n什麼嘛，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼嘛，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小熊圖案的內褲有什麼不好的！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "糟糕了！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n比起這個，要快點走才行！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "轉學第一天就遲到一定會變成笑柄啊～！",
        "unit_id": 106331
