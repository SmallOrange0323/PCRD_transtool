    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家，",
        "unit_id": 101831,
        "voice": "vo_adv_1063004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "早安。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n今天有一位轉學生，我來介紹一下吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "亞里莎，",
        "unit_id": 101831,
        "voice": "vo_adv_1063004_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可以進來囉。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "大家好，初次見面！",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_018"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我叫作亞里莎！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n以後",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "還請大家多多指……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "欸，",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_019"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊──！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你是",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "剛才那個人！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101831,
        "voice": "vo_adv_1063004_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳認識{player}嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "亞里莎的座位，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n就安排在{player}的旁邊好了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "咦！？",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_021"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不、不是的！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我只是剛剛遇到這個人，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n被他看到內褲而已……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "內、",
        "unit_id": 101831,
        "voice": "vo_adv_1063004_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "內褲！？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，發生什麼事了！？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊，",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_023"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不過是我不好！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n因為我的關係，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n害{player}",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "得要看著我的裙子裡面……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "到、",
        "unit_id": 101831,
        "voice": "vo_adv_1063004_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "到底是發生什麼事？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你們兩個，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "給我到教職員室來！",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "510310"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……你們之後要小心一點哦。",
        "unit_id": 101831,
        "voice": "vo_adv_1063004_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n要早點出門，不要匆匆忙忙地來上學。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不、",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_026"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不好意思。",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n先告辭了……",
        "unit_id": 106331
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "唉，",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_027"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "轉學第一天就被罵了……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n都是你的錯啦！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "雖然有一半，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是我的錯……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊，",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_028"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "得快點去上課！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "下一堂是……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "體育課呢。",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n快走吧！",
        "unit_id": 106331
    },
    {
        "type": "still",
        "still": "106300401"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是排球啊。",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_029"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n好，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那麼，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我要發球囉──！",
        "unit_id": 106331
    },
    {
