    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "沒有去過學校……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n不過",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "感覺很有趣呢！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……這樣啊。",
