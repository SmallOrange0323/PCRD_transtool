        "voice": "vo_adv_1063004_007"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "什麼，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "這道光是！？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "好刺眼……！",
        "unit_id": 106311
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "讓開讓開──！",
        "unit_id": 1,
        "voice": "vo_adv_1063004_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n要遲到了啦～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 1,
        "voice": "vo_adv_1063004_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就是你！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "快讓開！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這樣下去的話會撞到……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好痛痛……",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對不起，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我沒能避開……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n有沒有受傷？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯……？",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你在看哪裡？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊──！",
        "unit_id": 106331,
        "voice": "vo_adv_1063004_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你看到",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的內褲了吧！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n變態！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n偷看少女的裙內是不行的哦！",
        "unit_id": 106331
