[
    {
        "type": "background",
        "background": "501230"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊～",
        "unit_id": 115911,
        "voice": "vo_adv_6061306_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "想不到魔物的公主",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "會這麼強悍，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且還是個戀愛中的少女。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "看來在魔物當中，也有各式各樣的傢伙呢。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那當然！",
        "unit_id": 115911,
        "voice": "vo_adv_6061306_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這次我略遜一籌，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "下次絕不會再讓她佔上風。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "希望下次可以在沒有麻煩事攪亂的情況下，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "盡情地跟她對戰。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說得也是。",
        "unit_id": 115911,
        "voice": "vo_adv_6061306_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖說人類和魔物的戀情或許會遇到種種困難，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但他們兩人，我想肯定不會有問題的。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一想到他們",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n順利發展戀情的樣子，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就覺得有點羨慕……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我什麼都沒說！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可以喔。",
        "unit_id": 115911,
        "voice": "vo_adv_6061306_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，困難在於那不是可以輕鬆前往的地方……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，不對，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一切順利的話，下次或許在宅邸就能遇見她吧。",
        "unit_id": 115911
    }
]