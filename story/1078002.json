[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來來～",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來到了「迷人的南國之旅」……☆",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "碧藍的大海！",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "潔白的沙灘！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耀眼的太陽！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……然後是",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不開心的小凱留！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喂喂～",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是怎麼了，小凱留？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開心一點啦！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n露出那種陰沉的表情，可是會被太陽公公給取笑的唷♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下猜您是肚子餓了吧，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟馬上就要中午了。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n組成【美食殿堂】展開活動之後，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n胃袋就會被強制撐大……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下最近也是，",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n說來很不好意思，肚子也經常咕嚕咕嚕叫的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為不確定海邊是否有可以用餐的地方，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以在下和主人一起做了分量十足的便當喔。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n昨晚因為太期待所以一直睡不著覺，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天早上還很早起，所以有點睡眠不足。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，最近很努力做料理喔。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【咲戀育幼院】的家事是輪流制的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以很多事情自然而然就變熟練了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "夫婦……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是和睦主從的共同作業呢！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃東西真是讓人期待♪",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在開始游泳前，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就先來填飽肚子吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是據書上所說，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在游泳前吃飯的話，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會因為太重而下沉，所以不太好的樣子……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……為什麼啊！？",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚇死人了！？",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別突然叫這麼大聲啦～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還以為心臟要停止了！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰管妳的心臟會怎麼樣啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n比起那個，這是什麼啊？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是說「迷人的南國旅行」嗎！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡，不就是瑪爾傑海岸嗎！",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本就是在本地啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「不曉得會是多棒的南國旅遊勝地呢」",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "虧我還這麼興奮，滿心期待的耶～！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可惡！",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，負責抽獎的花凜那傢伙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有說過政府機關財政困難吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來那就是伏筆啊！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "完全中她的計了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一等獎的豪華獎品，",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說得這麼好聽，結果用本地廉價旅行就打發掉了～！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且這裡就在附近，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算不用特地招待，隨便走路就能到了啊……！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳就是在意那個，所以才一臉不開心的樣子啊。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算是附近也沒什麼不好的啊～",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大海很漂亮喔？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花凜小姐她，並沒有說謊呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就位置來說，這裡是蘭德索爾的南邊，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也算是南國了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我記得住宿的地方也是免費的吧？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以比自費來海邊，還省下更多費用……",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以也沒有損失啊，",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "用不著這麼生氣吧～？",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是那種問題！",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是對被騙的事情感到生氣！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "與其說是被騙，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不如說是我們擅自期待，然後被人當傻瓜就是了！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就能顯示出",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐有多期待這次的旅行了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這反而讓在下",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有種欣慰的感覺。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難得來到海邊了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就這樣氣噗噗的度過，在下覺得太浪費了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓我們一起享受吧，",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n四天三夜……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然時間不長，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但還請您多多指教。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1078002_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只是能和大家在外住宿，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下感到期待。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……是啊，說得也是～",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算在那抱怨也於事無補。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就這樣子來看，",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我猜那個什麼免費的住宿設施，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也不會好到哪裡去吧？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大海就是大海啊，",
        "unit_id": 107811,
        "voice": "vo_adv_1078002_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這可是開心的假期哦！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就當做是傻瓜盡情玩得高興啦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的真是的真是的！",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 107511,
        "voice": "vo_adv_1078002_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，自暴自棄地朝大海跑去了。",
