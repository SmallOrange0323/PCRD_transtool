        "type": "dialogue",
        "name": "伊緒",
        "words": "是之前掉進魔物陷阱裡的那孩子，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n後來我們一起帶它回到森林了！",
