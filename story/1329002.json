        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……為了",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓他安心而說了大話，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但一直找不到呢……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n明明是熟悉的森林，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在卻感覺寬廣很多。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "去公會管理協會詢問線索的時候，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n應該要請多一點人來幫忙才對嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也想避免大家去搜索反而自己也遇難的情況……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "等一下，",
