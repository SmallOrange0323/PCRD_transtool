    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "事情發生在聖誕節不久前。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊緒和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n受到聖誕老人的委託正在幫忙分送禮物。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼……",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然受聖誕老人委託的那些禮物還有剩，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但這附近應該都分送完了？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總之辛苦你了，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n明明是我接下的工作，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你願意一起幫忙。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們一邊休息",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一邊確認清單上",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有沒有沒分送到的人吧。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果沒有收到禮物，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一定會很難過。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這麼說來……",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒有去到那戶人家呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看一下清單吧。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那戶人家的孩子想要的禮物是……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "「和爸爸媽媽一起過聖誕節」",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n上面寫著「無法準備」。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "再怎麼說聖誕老人也沒辦法準備這個「禮物」呢。",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……不過，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣下去會只有這孩子",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n度過沒禮物的聖誕節。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那太令人難過了。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……我說，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那孩子想要的禮物，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們能不能想辦法準備呢？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "畢竟那孩子想和雙親度過聖誕節，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n想到向聖誕老人拜託的程度了對吧？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我真的很想幫他實現。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，我就猜想，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果是{player}的話",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一定會答應的♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼就立刻，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "去找那孩子聽聽他怎麼說吧！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你好。",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我們是",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聖誕老人的幫手，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n正在分送禮物……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咦？",
        "unit_id": 111,
        "voice": "vo_adv_1329002_010"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "聖誕老人的幫手？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n那麼，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "你們會把爸爸和媽媽帶過來嗎……？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "太好了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我許下的願望，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "有成功傳達到啊！",
