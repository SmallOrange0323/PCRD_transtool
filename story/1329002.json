    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我有聽說，",
        "unit_id": 132912,
        "voice": "vo_adv_1329002_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n牠時常會受到這座森林附近村莊的居民照顧。",
