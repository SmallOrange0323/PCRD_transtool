        "voice": "vo_adv_1329002_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡我也去過。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n也有和你一起去過對吧。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那裡的話，",
        "unit_id": 132912
    },
