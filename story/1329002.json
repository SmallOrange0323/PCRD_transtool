        "voice": "vo_adv_1329002_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你的雙親是冒險者啊。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為委託而前往森林，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n到了該回來的日子",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "卻還沒回來",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗯、",
        "unit_id": 111,
        "voice": "vo_adv_1329002_014"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗯……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以我",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "因為擔心，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就寫信給聖誕老人了……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我不需要玩具，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "只希望爸爸和媽媽可以",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "平安回來。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我想想，",
        "unit_id": 111,
        "voice": "vo_adv_1329002_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "爸爸和媽媽在談論的時候",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我有偷偷看到",
