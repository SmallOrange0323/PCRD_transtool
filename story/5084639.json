    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "搞什麼，",
        "unit_id": 104311,
        "voice": "vo_adv_5084639_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那傢伙還在睡啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真拿他沒辦法。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "該不會又是因為幫助人，而被捲進麻煩事裡了吧？",
        "unit_id": 104311,
        "voice": "vo_adv_5084639_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖然我很中意那傢伙的這一點，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但還是要有個限度啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是那傢伙出了什麼事，明明會有很多人因此傷心的。",
        "unit_id": 104311,
        "voice": "vo_adv_5084639_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就連我也是會感到寂寞的呀……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不、",
        "unit_id": 104311,
        "voice": "vo_adv_5084639_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我、我的事無所謂啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "對啦，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我是想說讓優衣傷心可不好！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好，",
        "unit_id": 104311,
        "voice": "vo_adv_5084639_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "下次見到那傢伙，我要教訓他幾句。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要快點醒來啊。",
        "unit_id": 104311
    }
]