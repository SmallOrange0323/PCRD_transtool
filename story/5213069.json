[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總、",
        "unit_id": 103412,
        "voice": "vo_adv_5213069_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "覺得我好像發出了很不得了的聲音……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這就代表泡芙真的好吃到那種程度！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "穿過喉嚨的那股刺激感，",
        "unit_id": 103412,
        "voice": "vo_adv_5213069_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "簡直就像是在喝麥酒……！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而且，濃郁厚實的奶油又帶來確實的滿足感！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在氣泡的刺激之後，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "甜味緩緩滲入口中……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "會讓人上癮喔！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "勞動過後來上一份，",
        "unit_id": 103412,
        "voice": "vo_adv_5213069_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "說不定會徹底顛覆「總之先來杯生啤」的常識呢！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聚餐一開始就吃甜的很邪門歪道？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才沒那回事呢！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "勞工疲憊不堪的腦袋，",
        "unit_id": 103412,
        "voice": "vo_adv_5213069_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不管是什麼時候，都在渴求糖分和麥酒的啊！！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊～",
        "unit_id": 103412,
        "voice": "vo_adv_5213069_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺整個人都舒服起來了……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那個那個，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我可以再來一份嗎？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今天我已經",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不管什麼熱量，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也不管明天的身體狀況了～！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我現在就是想變得軟趴趴的～",
        "unit_id": 103412,
        "voice": "vo_adv_5213069_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n想要整個人暈呼呼的啦～！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "拜託嘛～！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿嘿嘿～♪",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯，",
        "unit_id": 126511,
        "voice": "vo_adv_5213069_006"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "請慢用。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n能讓妳高興成這樣，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "對做料理的人來說，已經是最大的滿足了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……不過，",
        "unit_id": 126511,
        "voice": "vo_adv_5213069_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "會讓人變得軟趴趴、",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "暈呼呼的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那種材料，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n其實我一樣都沒有使用……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "大概只是心理作用造成的結果吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "飲食這件事，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "果然真是深奧呢……",
        "unit_id": 126511
    }
]