        "words": "某一天，\n{player}與【美食殿堂】的人，\n共同在蘭德索爾中散步。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊嗚～……",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肚子好餓～、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子好餓～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子餓～、",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好餓～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是肚子餓得咕嚕咕嚕叫的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貪吃佩可～……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吵死了！",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要在碎碎念了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會生氣的喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也是肚子餓到心情不是很好的說？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留就算沒有肚子餓，",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不都也是常常生氣的樣子～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "根本就是愛生氣小公主～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰是愛生氣小公主！",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要用奇怪的方式叫我，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是想說我像公主一樣可愛嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然沒有說公主就一定可愛～……",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不要再到處亂叫了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣肚子反而會更餓喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也是～。",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n今天不知道怎麼了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到處都找不到地方吃飯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快隨便找一家店，",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去大吃一頓順便消除一下壓力。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎呀？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，貪吃佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}跟可蘿仔呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像沒在附近，",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道說……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟我們走失了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉呦？",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不妙呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿～！\n{player}！",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們在哪裡啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有聽到的話就回個聲吧～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像從那個方向",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像傳來{player}的聲音！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走吧，貪吃佩可，",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有種莫名的不祥預感……！",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐～！",
