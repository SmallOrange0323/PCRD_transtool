        "voice": "vo_adv_4002001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐～！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這裡啊！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_4002001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找到了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們這樣不可以喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼擅自到處亂走！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們可是很擔心的？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真、",
        "unit_id": 105913,
        "voice": "vo_adv_4002001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的很對不起。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也不知道發生了什麼事情……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是普通的走著。",
        "unit_id": 105913,
        "voice": "vo_adv_4002001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一回過神來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就來到了這個詭異的空間了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～？",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這個空間",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是什麼呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然很廣闊，",
        "unit_id": 106012,
        "voice": "vo_adv_4002001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，在蘭德索爾有這樣子的建築物嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～。",
        "unit_id": 105913,
        "voice": "vo_adv_4002001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺好像不小心進入了異世界一樣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底是哪裡呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個地方？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是『戰鬥競技場』……",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n受到太陽與星辰",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "祝福的人們，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n穿越時空互相競爭的鬥技場。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！？",
        "unit_id": 106011,
        "voice": "vo_adv_4002001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳是誰！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉。",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n禮貌上應該先報上姓名的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "我是米奈β。",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_025"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n是這個『戰鬥競技場』的管理人。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "米、",
        "unit_id": 105811,
        "voice": "vo_adv_4002001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "米奈……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "貝塔小姐？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "是的。",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_027"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n正式說起來，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "有個更長的稱號……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "不過為了方便，還是叫這樣就好。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "不過",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_028"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "不用太過於在意我，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n我只是像個沒有靈魂的人偶。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "只是遵從程式的指令，",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_029"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n默默的執行該做的事情而已。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "話雖如此。",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_030"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "既然你們到達了這個地方，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n代表你們已經具備了資格。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "如果可以的話，",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_031"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n不妨參加這裡舉辦的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "『鬥技大會』試看看呢？",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鬥、",
        "unit_id": 106011,
        "voice": "vo_adv_4002001_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『鬥技大會』？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是什麼東西，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "舉辦非官方的活動可是違反法律的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "已經有取得認可了。",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_033"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n妳看，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "這是蓋過國王認可的文件。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我看看。",
        "unit_id": 106011,
        "voice": "vo_adv_4002001_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是真的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這份公文真的沒有任何問題。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～、",
        "unit_id": 105811,
        "voice": "vo_adv_4002001_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是真的呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然同意的是好幾任以前的國王……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n連我都沒見過，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是好久好久以前的祖先。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼？",
        "unit_id": 105911,
        "voice": "vo_adv_4002001_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n妳說祖先是……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，沒有，",
        "unit_id": 105811,
        "voice": "vo_adv_4002001_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我什麼都沒有說……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總之，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像『鬥技大會』這個東西，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得沒有必要參加。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像只要有出場，",
        "unit_id": 105811,
        "voice": "vo_adv_4002001_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能夠獲得豪華獎品的樣子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "獎品的內容似乎沒有在書面上說明，",
        "unit_id": 105811,
        "voice": "vo_adv_4002001_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟可以得到什麼呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就個人來說",
        "unit_id": 105811,
        "voice": "vo_adv_4002001_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比較想要綜合水果籃，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或是一年份的白米。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "如果那就是您的願望的話，",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_041"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "也可以去準備喔。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "我是達成願望的系統殘渣，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n將會回應各種願望。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "如果會覺得有點詭異的，",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_042"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "可以想像只是單純的從事工作而已。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "只要付出一定程度的勞力，",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_043"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n就會給予報酬……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "差不多就這種感覺。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "不過，反正也不是強制參加，",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_044"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "當有想到，再過來參加就夠了。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n絕對不會有所虧損的。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "『戰鬥競技場』",
        "unit_id": 191111,
        "voice": "vo_adv_4002001_045"
    },
    {
        "type": "dialogue",
        "name": "米奈娃β",
        "words": "\n會一直衷心地等待各位參加的。",
        "unit_id": 191111
    }
]