    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "明明是盛夏卻令人不寒而慄呢……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨，",
