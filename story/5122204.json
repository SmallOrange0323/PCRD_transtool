        "voice": "vo_adv_5122204_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳可別被恐懼給吞噬了喔！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 126611,
        "voice": "vo_adv_5122204_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n明明就在喝，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻被吞噬……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "戳、",
        "unit_id": 126711,
        "voice": "vo_adv_5122204_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "戳到笑點了？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n優花梨！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "似似花她笑了耶！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……",
        "unit_id": 126811,
        "voice": "vo_adv_5122204_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可是，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我現在沒在喝的說。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃、似似花",
        "words": "咦咦咦……",
        "unit_id": 1,
        "voice": "vo_adv_5122204_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "討厭啦，那是什麼反應……",
        "unit_id": 126811,
        "voice": "vo_adv_5122204_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以喝嗎？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以的話我就喝下去來提振士氣囉？",
        "unit_id": 126811
