[
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕呃呃呃呃呃……",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "巴西利斯克給人的感覺",
        "unit_id": 6111,
        "voice": "vo_adv_5132323_000"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "變了呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "跟剛剛截然不同，似乎變得非常沉著，",
        "unit_id": 128011,
        "voice": "vo_adv_5132323_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但反而讓人毛骨悚然呢……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牠一定",
        "unit_id": 127911,
        "voice": "vo_adv_5132323_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是認可我們為敵人了吧。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是靠暴力踩踏就完事的蟲子，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而是必須認真狩獵的獵物。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "別開玩笑了吧，",
        "unit_id": 128011,
        "voice": "vo_adv_5132323_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明明已經強得可怕了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然還會變得更難對付……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的",
        "unit_id": 127911,
        "voice": "vo_adv_5132323_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很讓人困擾呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是與聖誕節最佳美食相襯的對手。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也懷著敬意當牠的對手，",
        "unit_id": 127911,
        "voice": "vo_adv_5132323_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後盡情",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "享用牠吧！",
        "unit_id": 127911
    }
]