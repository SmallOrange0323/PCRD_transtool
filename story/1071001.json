[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【王宮騎士團】的諸位！\n我現在很無聊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說點有趣的事來聽吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "能讓我感到愉悅的人我就褒獎他！",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但若讓我感到無趣就得懲罰！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "砍飛腦袋噴出血柱的話，",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正好可以保養雙眼呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈哈……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "……又開始了，",
        "unit_id": 712,
        "voice": "vo_adv_1071001_003"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "副團長又開始任性了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "……那個人明明也不年輕了，",
        "unit_id": 711,
        "voice": "vo_adv_1071001_004"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n為什麼每隔一段時間就會像個講不聽的孩子啊？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯嗯～？　",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們說什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我聽得不是很清楚啊～？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一板一眼的【王宮騎士團】，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也難得知道什麼笑話嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然如此，那就大聲說出來聽聽！",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n快點說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可沒什麼耐性！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "不……",
        "unit_id": 712,
        "voice": "vo_adv_1071001_007"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n什、",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "什麼事都沒有，副團長。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "明明離她挺遠的，為什麼還聽得到？",
        "unit_id": 711,
        "voice": "vo_adv_1071001_008"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "耳朵真是太靈了……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n上帝保佑上帝保佑，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n那位大人如果在附近的話，就注意別太多嘴吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們幾個，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼聚集在那種地方？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n難道有什麼有趣的東西嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓我看看，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼～嗯……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "哇！",
        "unit_id": 712,
        "voice": "vo_adv_1071001_010"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "請注意腳下！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n這裡是祕密結社【拉比林斯】那群傢伙的基地，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n所以地面並沒有怎麼整修過！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "嗯！",
        "unit_id": 711,
        "voice": "vo_adv_1071001_011"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n萬一，副團長跌倒傷到您寶貴的肌膚就不好了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "……呃唔！？",
        "unit_id": 711,
        "voice": "vo_adv_1071001_012"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n請、請問為何要踢我，副團長？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不喜歡顯而易見的客套話。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道你們認為我會踢到地板跌倒嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "到底該怎麼辦才好啊……",
        "unit_id": 712,
        "voice": "vo_adv_1071001_014"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n太、",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "太難應付了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "唔唔。",
        "unit_id": 711,
        "voice": "vo_adv_1071001_015"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n不愧是在【王宮騎士團】裡也出了名的問題人物。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼嗯……",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什～麼嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡也空蕩蕩的什麼都沒有啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真無趣。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "本想說能打發時間就好了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n才接下那什麼【拉比林斯】的掃蕩作戰……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但那群傢伙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎很擅長躲躲藏藏的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到處留下假的、",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n空蕩蕩的基地，也不知道成員到底躲到哪去了",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣的基地，",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算只建一座應該也需要龐大的資金與勞力才對。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但居然會用完就丟……",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "到底是何方神聖？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "身分不明反而更有趣呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哎呀？",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎有人被綁起來丟在地上呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "唉……",
        "unit_id": 712,
        "voice": "vo_adv_1071001_022"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "這傢伙，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士A",
        "words": "\n不曉得為何在這座【拉比林斯】的基地附近徘迴。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "在這種深山裡……",
        "unit_id": 711,
        "voice": "vo_adv_1071001_023"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "而且問他話也說不出什麼重點，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士B",
        "words": "\n因此我們猜想他可能是【拉比林斯】的同夥，\n就逮捕他並且綁起來了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔～喔～",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n做得很好，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要審問這傢伙，就能好好打發時間了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，我說你……",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有意識嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "稍微和我聊聊天吧♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵～",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "意外挺老實的嘛……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這種狀況下，還能不膽怯地直視我的眼睛做出回覆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n看來你挺有膽量的啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n什～麼嘛，死了啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真無趣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "部下們，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把這傢伙丟到山谷下。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對野獸來說是不錯的飼料吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是愛護動物的精神♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哦，出聲了啊。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的生殺大權現在掌握在我手裡，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n最好別壞了我的心情，乖乖聽話比較好唷？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總之。",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是哪來的什麼人？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在這種深山裡做什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071001_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慢著，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
