        "voice": "vo_adv_5031005_066"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "因為她說已經不需要了，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "暫時就先放在那裡吧！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n比起那個",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "得先處理落石。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "看來要弄到晚上了呢，",
