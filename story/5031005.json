    {
        "type": "dialogue",
        "name": "實況",
        "words": "巨大的東西正在跑過來……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n那是、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "那是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "轟隆隆隆隆隆隆隆隆隆隆隆隆隆！",
        "unit_id": 12711,
        "voice": "vo_adv_5031005_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有、",
        "unit_id": 103311,
        "voice": "vo_adv_5031005_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有個像山的東西、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在移動！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "追、",
        "unit_id": 100511,
        "voice": "vo_adv_5031005_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "追上來了！　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是魔物嗎！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "是山神大人啊啊啊啊啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5031005_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦！？　",
        "unit_id": 100511,
        "voice": "vo_adv_5031005_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "山神大人不是我嗎――",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這個地區自古流傳下來的競速賽之神，",
        "unit_id": 1,
        "voice": "vo_adv_5031005_043"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "就是這位山神大人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n據說見到祂",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "就能得到庇護，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n我也沒想到",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "竟然能夠親眼看到！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "看來是茉莉選手的吶喊，",
        "unit_id": 1,
        "voice": "vo_adv_5031005_044"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "還有",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "競速賽的熱情，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n讓祂誤以為我們在呼喚祂呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n也就顯示出",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這次的競速賽",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "到底有多麼激烈了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在是冷靜轉播的時候嗎！？",
        "unit_id": 190814,
        "voice": "vo_adv_5031005_045"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們是【公會管理協會】！　",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "情況危險，",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請立刻中止競速賽――",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！　",
        "unit_id": 12711,
        "voice": "vo_adv_5031005_046"
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！",
        "unit_id": 12711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……管理協會的姐姐！",
        "unit_id": 100511,
        "voice": "vo_adv_5031005_047"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這位山神大人",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有攻擊我們，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "祂大概只是想跑步而已！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "沒錯！　",
        "unit_id": 1,
        "voice": "vo_adv_5031005_048"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "跟茉莉選手說的一樣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n根據傳說，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "這位山神大人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "似乎只是在尋找",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n能夠一起比賽的好對手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "因此，",
        "unit_id": 1,
        "voice": "vo_adv_5031005_049"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "比賽繼續進行！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n究竟，人類",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "是否能夠贏過神明呢！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "競速賽即將迎來結局！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "事、",
        "unit_id": 190814,
        "voice": "vo_adv_5031005_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "事情會變成怎樣我可不管了──！",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！　",
        "unit_id": 12711,
        "voice": "vo_adv_5031005_051"
    },
    {
        "type": "dialogue",
        "name": "山神大人",
        "words": "轟隆！",
        "unit_id": 12711
    },
