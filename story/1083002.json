    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也、",
        "unit_id": 108311,
        "voice": "vo_adv_1083002_039"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也是呢！　",
        "unit_id": 108311
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看來{player}也很懂嘛！",
