    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對吧～！　",
        "unit_id": 108311,
        "voice": "vo_adv_1083002_040"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也是這麼想的呢～♪",
