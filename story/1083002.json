        "words": "可以拜倒在我的裙下唷！",
        "unit_id": 108311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小姑娘，妳好可愛唷～。",
        "unit_id": 1411,
        "voice": "vo_adv_1083002_036"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "簡直就像是魔法少女一樣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不是魔法少女，",
        "unit_id": 108311,
        "voice": "vo_adv_1083002_037"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是魔女！　",
