    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家",
        "unit_id": 100111,
        "voice": "vo_adv_9008004_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都聽得見嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這裡有滿～滿聽到賺到的好消息♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n「蘭德索爾時光」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要開始囉～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天負責主持節目的",
        "unit_id": 100311,
        "voice": "vo_adv_9008004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是我們【破曉之星】。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n請多指教。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼……",
        "unit_id": 100311,
        "voice": "vo_adv_9008004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "打招呼差不多就到這裡，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n接著就來進行大家都很在意的今日主題吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好～！",
        "unit_id": 100111,
        "voice": "vo_adv_9008004_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天的話題新聞",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "肯定就要選這個！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在蘭德索爾中心地區",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要舉辦跳蚤市場囉♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這活動我曾聽說過。",
        "unit_id": 100311,
        "voice": "vo_adv_9008004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "整個蘭德索爾中",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的知名物品和珍品都會",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n齊聚一堂的大規模市集吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對對對♪",
        "unit_id": 100111,
        "voice": "vo_adv_9008004_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "上次跳蚤市場出現的稀有商品，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是藏寶地圖",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和鼠耳。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "鼠耳……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "什麼啊？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n像我的耳朵這樣嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個鼠耳，",
        "unit_id": 100311,
        "voice": "vo_adv_9008004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽說是一位來自",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "東國鼠神宮的巫女",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n製造的特別商品。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能販售五花八門",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的東西，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不侷限於類別，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是跳蚤市場的有趣之處呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今年會出現什麼樣的商品呢……",
        "unit_id": 100213,
        "voice": "vo_adv_9008004_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓人不禁感到很在意呀。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n應該會有許多稀奇的珍品吧……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們要不要一起去逛逛？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是好主意！",
        "unit_id": 100111,
        "voice": "vo_adv_9008004_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那麼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "現在來做個調查！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果要在跳蚤市場買一樣商品，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n藏寶地圖和鼠耳，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家想選哪個呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦、",
        "unit_id": 100213,
        "voice": "vo_adv_9008004_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n藏寶地圖……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "鼠耳……？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔、",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔～我想想……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………可能會",
        "unit_id": 100213,
        "voice": "vo_adv_9008004_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩邊都想買吧？",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟我還想再跟",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "大家一起去冒險……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "可是，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也想看騎士先生戴上鼠耳的樣子……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚、",
        "unit_id": 100213,
        "voice": "vo_adv_9008004_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我這樣回答根本不有趣嘛！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩人應該",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也很煩惱該怎麼接話吧……",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊啊啊，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不──",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣！",
        "unit_id": 100111,
        "voice": "vo_adv_9008004_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我很能明白妳的心情啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n絕對絕對，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "絕～對",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "兩邊都要買對吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "決定了～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那就戴上鼠耳，拿著藏寶地圖，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家一起去冒險吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_9008004_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "合力一起冒險，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n才是我們【破曉之星】的作風。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "鼠耳也一起……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "令人有些難為情……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今、",
        "unit_id": 100213,
        "voice": "vo_adv_9008004_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "今年也來進行很多的冒險吧！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也歡迎",
        "unit_id": 100111,
        "voice": "vo_adv_9008004_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大家來信說說自己",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n想在跳蚤市場買什麼喔♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的「蘭德索爾時光」節目就到此結束！",
        "unit_id": 100111
    }
]