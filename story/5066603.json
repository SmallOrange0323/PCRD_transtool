[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふふ……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "出来た。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nついに完成したぞ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "さあ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_001"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "とくと見たまえ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこれこそが『なかよしＸ　Ｍｋ-Ⅱ』。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n此度の体験で",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "我々にもたらされた学びの結晶だ！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "然り。",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_002"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なかよしＸ初号機の反省点は、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "何より無駄に嵩張ったことだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n軍事兵器でもあるまいに、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "果たしてあのサイズが必要だっただろうか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくには財団のような予算や設備がない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もっとも、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これは妥協の末の小型化ではない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n大は小を兼ねる等という暴論には",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "真っ向から異を唱えさせてもらおう。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "搭載している各種機能は、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "初号機のそれらをより先鋭化させたものだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "たとえばタイヤキキャノン。",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_004"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これには",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "市場調査の結果を反映させた。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n顧客のニーズから起こりうる不要な戦争を未然に防ぐことが可能だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "粒餡か漉し餡か選べる。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふふ？",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_005"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n驚いているな後輩、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "開いた口が塞がらないと見える。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nしかし改修された機能はまだまだあるのだよ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "たとえば麦しゅわスプラッシュ。",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_006"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこちらは過剰摂取に配慮して、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "一定量の使用が確認されると",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n健康促進システムが働いて、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "自動で温かいスープに切り替わる。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そして、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_007"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "初号機の眼目であったおしゃべり機能。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nこちらは昨今のペットブームに対応して、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n上位互換と言える、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おさんぽ機能へとバージョンアップさせた。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これは動体反応を検知すると",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_008"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "「ちぇるーん☆」などと鳴きながら、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n健気にもオーナーの三歩後ろを付いてくるという機能だ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おさんぽだけにな。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "どやっ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ん？　",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_009"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おいおい、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "待ちたまえ後輩。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nどこへ行くのだ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "新機能の説明はまだまだ終わってないぞ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なに、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "授業？　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "一般生徒はそんなものがあるのだったか……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "是非もなし。",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_010"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "では",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "『なかよしＸ　Ｍｋ-Ⅱ』、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "彼の後を付いて行きたまえ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nせいぜい可愛がってもらうのだよ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "うん？　",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_011"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ああいや、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いいのさ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nそいつを作るに当たっては",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君にも手伝ってもらった……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "というより、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "もとよりそいつは君のために作ったものだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ふむ……",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_012"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "その、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "つまりだね、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "日頃の感謝というか、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n端的に換言すれば",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "プレゼントというやつさ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君には共同研究者として……",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_013"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "いや、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくの初めての友人として、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n実利的にも精神的にも",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "大いに世話になっている。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だが、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_014"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "存知のとおり、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくは気持ちの伝え方に不得手でね。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nありがとうを言うのが照れくさい性分でもないが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nありがとうを言うべき局面に気付けない不調法だという自覚はある。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "おそらくこれまでも、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_015"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そしてこれからも、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n不調法なぼくは",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君へのありがとうが足りないことと思う。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "だから、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "その代わりとして、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "これを贈らせてもらいたい。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "まあ、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_016"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君がそのプレゼントを気に入ってくれるかは別問題だが、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そこまでは僕が責任を負うところではない。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n贈る気持ち自体がプレゼントだと、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ものの本にも書いてあった。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくが丹精こめて形にした、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_017"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "世界に一つだけの気持ちだ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n遠慮なく受けとってもらえれば",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "幸甚の至り。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "端的に換言すれば、",
        "unit_id": 111011,
        "voice": "vo_adv_5038603_018"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "今後ともよしなに。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぺこり。",
        "unit_id": 111011
    }
]