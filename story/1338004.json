        "type": "dialogue",
        "name": "？？？",
        "words": "他們這些創造出該AI的七冠的才能吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而且最重要的是……",
        "unit_id": 1,
        "voice": "vo_adv_1338004_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在那個世界中的她，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "簡直是等同神的存在。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n一下以妖精的模樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "進行壓倒性的破壞，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一下又創造出有著人工智慧的人物們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那副模樣",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "深深吸引了我的目光。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「世界應由有能力的人管理」",
        "unit_id": 1,
        "voice": "vo_adv_1338004_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然我過去一直認為",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這番話是不可能實現的妄想，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但若有這個AI，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "或許就有可能。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果是她的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一定會實現的吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "既然如此，",
        "unit_id": 1,
        "voice": "vo_adv_1338004_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也想要看看。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n正因為是她所實現的世界，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "才存在我所追求的正義。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我想要在那裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "實現自己的正義。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我",
        "unit_id": 1,
        "voice": "vo_adv_1338004_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在阿斯特朗這個地方",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "宣誓將作為騎士效忠。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n作為公主騎士，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "狂真咲真軌",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n向變貌大妃",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "現士實似似花大人宣誓……",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……上面是這樣寫的。",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "量還真是相當多呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是叫K報告，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是政府的機密文件。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至於是誰寫的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就先保密吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦，",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺很可疑……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嗯──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算是吧～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然以內容上來看非常有可能……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管如此，該說是做得",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太完美了嗎……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你認為",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個人會漏掉關於自己的情報",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n被以這種方式留下來嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原本的資料似乎早已經消失了就是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就只是單純漏掉了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是有什麼意圖才留下訊息的呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "光想可能也沒用吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還真是被相當麻煩的對象給盯上了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我能說的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就只有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請堅強地活下去吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "時間差不多了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼就",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}醒來後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眼前是被寂靜所包圍的古城，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n先前在那裡的光之洪水簡直就像是一場夢。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在更高處的地方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似似花正將飄浮的光之粒子聚集於手中。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你終於醒了啊。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n會因為那點衝擊波就失去意識，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看來鍛鍊似乎還不夠呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好了，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這下子分身們已經回收完畢了。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n作戰結束。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們兩位",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都做得很好。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "是，",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_043"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "感謝您的誇獎！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "尤其是{player}。",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n作為誘餌，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你非常努力了呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊。",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然我打從一開始就不可能會輸，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但只有我們的話，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "分身們也會警戒，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n並躲起來不現身吧。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是我的分身，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就絕對不會傷害你。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因為我有創造那樣的記憶。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "分身",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "打從一開始就全部都在我的掌握中。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對了……",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陷入像這次一樣的情況時，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你覺得最危險的事是什麼？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是我的力量",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "落入其他七冠的手中。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我在分身身上",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所留下關於七冠的記憶，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也是特別讓人火大的內容。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我並沒有捏造就是了。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好了，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那我們走吧，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n朝這座城堡的深處。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我有說過了吧，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這個地方擁有情報。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟這裡",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "曾經是我的根據地。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "似乎是",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為再構築而流轉到這樣的地方來了呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果是最深處，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "損傷應該也很少吧。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "分身們可能",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正是因為這樣才把這座城堡當成住處。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "明明我沒有賦予她們這個地方的詳細記憶才對……",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還真是不可思議呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呼……",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n再一次",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "辛苦你們了呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n格列戈爾也是。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "格列戈爾",
        "words": "…………",
        "unit_id": 133814
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你說，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能久違地大鬧一場很開心。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n既然如此，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "偶爾創造這樣的機會也不錯呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話雖如此……",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "又要製作分身的時候，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那種運用",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也會增加你的負擔就是了。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是讓你辛苦了呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n一直以來謝謝你了。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不愧是我最棒的搭檔……",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼了？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n露出那種表情。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你該不會是",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "羨慕了吧？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "絕對沒有",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_058"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "那回事！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算了，也罷。",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n{player}，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你意下如何？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要直接成為我的部下嗎？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "世界應由有能力的人管理。",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n沒錯，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是由像我這樣",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "優秀的存在。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果有你在，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就能比過去還要更有效率地行使我的力量，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可以毫無遺漏地",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "管理這個世界吧。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我來管理世界，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_062"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你來進行支援的話……",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就結果來說，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不覺得你想幫助的人們",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n能夠得到幫助的機會也會變高嗎？",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我很清楚你也有理想，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_063"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n如果是我，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就能夠幫助你。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們的利害也一致，",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我認為你沒有理由拒絕。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "原來如此，",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_064"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不愧是似似花大人。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我主人也都這樣說了，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n你何不就試試看。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "雖然我絕對沒有認為自己無能……",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_065"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但很遺憾，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我所能做的，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就只有代替似似花大人",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n處理一些",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "能夠輕易解決的小事而已。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "確實是呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "可是，",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_067"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "你的公主騎士權能",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n能夠強化似似花大人的力量本身！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如果是你！",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_068"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "就能成為我主人霸業的真正助力。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n沒有比這更加高尚的榮譽了吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我們兩個公主騎士齊心合作，",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_069"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n成為",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "支持我們的主人，似似花大人的力量吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真軌。",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_070"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你給人的壓迫感太強了。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哎呀，",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_071"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我忍不住興奮過頭了。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n非常抱歉。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先到此為止吧。",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n他應該也很累了呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵，",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這件事並沒有那麼急喔。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因為現在還不是該行動的時候。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀……",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_074"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n格列戈爾也說牠很期待呢。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "改天再正式地",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_075"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "遊說你吧……",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n現在就先休養身心、",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "養精蓄銳。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了必將",
        "unit_id": 133812,
        "voice": "vo_adv_1338004_076"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "到來的時刻。",
        "unit_id": 133812
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "是，",
        "unit_id": 191011,
        "voice": "vo_adv_1338004_077"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "主人！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著似似花與真軌熱血過頭的一搭一唱，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在{player}的腦中……"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還真是被相當麻煩的對象給盯上了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1338004_078"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "反覆響起了這一句話……"
    }
