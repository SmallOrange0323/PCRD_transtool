[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茜里抓住了重新振作的契機，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次和{player}相約碰面。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n你來了呀。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "前陣子",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里才約你出來特訓，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n最後卻泡湯了，真的很抱歉。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然也算不上是補償……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥今天就和茜里約會吧！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會好好努力，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓哥哥也玩得很開心的♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒錯。",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n今天一定要讓哥哥玩得盡興……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一定要讓哥哥誇獎茜里很可愛！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說是這麼說……",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n究竟該怎麼做才好，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也沒有一個明確的答案……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "無法用言語完整表達出來，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但茜里好像掌握到能讓哥哥露出笑容的關鍵了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……難不成",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n直接問哥哥就好了嗎？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "盯……",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒事！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒什麼！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不對，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這麼做是不行的！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這是茜里自己的問題！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "總覺得",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "答案一定要是自己得出來的才行！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥是個溫柔的人，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n只要茜里開口拜託他，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "他肯定會願意回答，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但那樣就沒有意義了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔……",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "究竟該怎麼做才能讓哥哥帶著笑容，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n誇獎茜里很可愛呢……？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然茜里還沒有想到方法……",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但這樣下去什麼都不會改變，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "得先採取行動才行！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿，哥哥。",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "想去一個地方。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有人告訴我",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "城鎮外有個景色很美的地方，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不過有一點距離，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你願意跟茜里一起去嗎？",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "往這邊走。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就快到了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這前面有座湖，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那裡的景色──",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀啊……！",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "魔物突然冒出來了……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真是的～",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里難得可以和哥哥出來約會……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n還正在努力想讓哥哥誇獎自己很可愛的……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不要來妨礙茜里我們～！",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿～！",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我沒事。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n在牠發動攻擊之前，茜里就打倒牠了，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以毫髮無傷喔♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒那回事啦～♪",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里只是不希望有人妨礙茜里和哥哥的約會，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以才特別拼命。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n難不成……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "乾淨俐落地打倒魔物，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是不是做了很不可愛的事了……？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "怎麼辦……",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n難得想讓哥哥見識自己可愛的一面的……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這麼一來，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "形象都破滅了吧……？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……咦？",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "奇怪？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "什麼事讓你笑得這麼開心呀？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "什麼……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里變回平時那個茜里了",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就只是戰鬥而已，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒做什麼特別的事，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但哥哥看起來很高興，那就好了♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真的笑得很開心呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里一點也不成熟，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也沒有做什麼能讓哥哥怦然心動的事……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n到底什麼事讓他這麼高興呢？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里只是超級討厭有人來打擾",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里和哥哥相處的美好時光而已……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這一點",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_032"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "跟平時的茜里也沒有什麼差別呀──",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊……",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_033"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣啊……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n難道說……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥所說的",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_034"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "「茜里的風格」",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就是指「平時的茜里」呀。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥喜歡的",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n肯定就是",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "「平時的茜里」吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，",
        "unit_id": 100611,
        "voice": "vo_adv_1006012_036"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "卻拼命地想成為",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
