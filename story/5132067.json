[
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蕾琪塔為了討論事情而來到【美食殿堂】的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下──",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您在嗎──？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我是您親愛的忠臣",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾琪塔‧凱許──！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我剛好要出門一會，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請妳進去等我哦──！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n等一下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您要去哪裡啊──！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否有訪客──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "歡迎您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有事要找貪吃佩可小姐嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "小矮……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可可蘿小姐，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "日安。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我是有事要找陛下……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出門去買今晚火鍋宴會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要用的柚子醋了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為被吃火鍋沖昏了頭，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "滿腦子都只想著材料，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像直到剛剛才發現",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "柚子醋用完了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她很快就會回來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您入內等候。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然行程沒什麼空閒……",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是再跑一趟更浪費時間。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n沒辦法了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正好有這個機會，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就請妳款待我吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請交給在下。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管只是粗茶，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不嫌棄的話請用。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n由於外面很冷，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下將茶泡得比較熱，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請留意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說粗茶？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "難道這地方就只拿得出那種東西嗎。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n萬一妳讓陛下飲用那種回沖到沒味的廉價茶葉，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我可饒不了妳──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "（咕嚕。）",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……這是……！",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "儘管絕對算不上高級，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n卻是能夠感受到扎實技術與真心的一杯茶水……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "最重要的是，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n沖泡得較熱",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "的茶水暖意，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "擴散到了受寒的四肢百骸……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而這雖然是收到的禮物，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有茶點可以搭配。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n由於是【墨丘利財團】贈送的歲末禮品，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "味道絕對不差。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有在下精心製作的醃菜。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此外──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "記得克蕾琪塔小姐",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對食用魔物料理並不感到抗拒對吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請用這個──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐獵到的魔物製作的燻製品。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n稍後若能提供感想，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐也會感到開心才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對了，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是不是還沒吃過午飯呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是這樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這就去為您準備。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "趕緊準備",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "飯糰、拉麵與三明治以及義大利麵還有──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "先等一下可以嗎！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我吃不了那麼多啊",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是說到底要搬出多少食物啊這個家是食堂還是什麼來著",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊對喔這個公會叫做【美食殿堂】呢！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您就算要在下「等一下」也……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n先前",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "開口",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要在下「款待」的人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不就是克蕾琪塔小姐您嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是也該有個限度吧！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "況且我那句話，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就只是小小的玩笑話而已！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且要說的話，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "站在妳的立場，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明明就沒有理由",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n對不只是毫無關係，過去甚至和敵人沒兩樣的我",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n如此款待不是嗎……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……凱留小姐",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許會對此否定，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對克蕾琪塔小姐並沒有負面看法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反倒是由於這次聖誕節，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使在下對您抱持著感謝心意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不久前……",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經歷了痛苦的離別。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管貪吃佩可小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "表現出一副開朗的樣子……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但是她偶爾",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是會露出傷心的表情。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最近這陣子",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐打從心底很開心的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算只是暫時的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她能夠開心度日真是太好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以說真的",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很感謝您，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我又不是為了妳們才那麼做。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n一切都是為了陛下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "落到妳們身上",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只不過是類似於副產品的東西罷了。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這點在下很清楚，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使如此在下還是想",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對您致上謝意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……受不了，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓人不知道該說什麼才好。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "天真的小鬼頭就是這樣令人受不了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我回來了──！",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊──",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公會小屋裡頭真是暖和……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉讓妳久等了！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "歡迎回來，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請您不必在意。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我得到了",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可可蘿小姐的盛情款待。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼感覺",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "房間裡的氣氛很好呢。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "兩位聊了些什麼嗎？",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "倒、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "倒也沒那麼……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是在閒聊而已。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就只是夥伴間的閒話家常。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "夥、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "夥伴……！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來是這樣呀～",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只有妳們兩位享受，有點犯規哦。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也要加入！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下去重泡一壺茶。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不用了，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我也很希望能那樣。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我辦完事之後就得離開了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可不行。",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我希望克蕾琪塔小姐",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也能留下來",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n晚上和我們一起吃火鍋！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請、",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請等一下，陛下！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明明是【美食殿堂】難得的宴會，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n有我在的話不就全都毀了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的說法真奇怪。",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就只是夥伴們圍著吃火鍋而已，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼會毀了呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請不要用如此澄澈的眼神看著我！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是就算妳們不介意，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個小貓仔不知道會怎麼想……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這點可以放心。",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留頂多也只是",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘴上不留情，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可是她應該也很理解克蕾琪塔才是☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……希望真的是這樣。",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然這麼決定了，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在主人和凱留小姐回來之前",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n先做好煮火鍋的準備吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼，",
        "unit_id": 128011,
        "voice": "vo_adv_5132067_043"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "至少讓我幫忙。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "反正都用夥伴",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而不是客人稱呼我了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對吧。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好、",
        "unit_id": 127911,
        "voice": "vo_adv_5132067_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就麻煩妳了！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_5132067_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺會是場愉快的宴會呢。",
        "unit_id": 105913
    }
]