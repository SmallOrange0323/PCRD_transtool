    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管數度遭遇魔物襲擊，一行人仍順利地向上登塔。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好～",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直～！",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼，",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們爬了不少樓呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "魔物也越來越強了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要更加把勁才行～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "和嘉夜一起行動",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就什麼都不用擔心啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n照這個狀態應該能一直闖下去～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……我還是",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "忍不下去。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘉夜妳怎麼了？",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……我很清楚",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在不該說這些。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我有點忍不住了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香織，",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和我打一架吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "打架？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是不是做了什麼對不起嘉夜的事呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n如果是的話我向妳道歉……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊──",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打架這說法不好。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "過招，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我想和妳過過招！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊～",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是這個意思呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嚇我一跳～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果嘉夜會比較開心，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我不介意喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你覺得好嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們是來保護你的，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就交給你判斷吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊。",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並不是不把你的記憶的事放在心上，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但能給我一點時間嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "當然啦～",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那，請嘉夜手下留情～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝。",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我當然會留意，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但要是我打得太投入",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就抱歉囉！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿。",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈哈，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好厲害的刺拳～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔，",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那這招如何！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喝啊喝啊喝啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿唷、",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿、",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘿唷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真好玩～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嘖，",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "居然漫不經心地閃開了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就賞妳個強力一擊！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看招！",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "狂龍猛擊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇，",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這招好像會很痛～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就這樣──",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔！",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打擊的軌道被架開了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有破綻～！",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_022"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔……！",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "居然連那招也被化解掉了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n明明跟我一樣都是打擊型的卻是個難纏的對手。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好戲才要開始啦──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "魔物來了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘉夜，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先比到這裡吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可惡，",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "別來礙事！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "滾開！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔……",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這傢伙的身體",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打起來簡直像塊厚實的橡膠。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一擊解決不了的話，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就用連擊痛扁你！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唔哇！",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "混帳，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "完全不痛不癢……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們先撤！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "用物理攻擊無法撂倒這──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喝啊──！",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_029"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_7025003_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "實力果然和下面的魔物",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不一樣呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘉夜",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳沒事吧？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為什麼？",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_032"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明我的拳頭完全不管用，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n為什麼香織才出一招就把牠幹掉了？　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且剛才過招時",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我的招式也都被香織輕易避開了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n到底是什麼？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我跟香織之間",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到底有什麼不同啊！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……終究是因為珍視的事物、",
        "unit_id": 106511,
        "voice": "vo_adv_7025003_034"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "想守護的事物有差異嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n假設如此，",
        "unit_id": 106511
    },
    {
