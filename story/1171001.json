    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "鏘鏘～♪",
        "unit_id": 117111,
        "voice": "vo_adv_1171001_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼樣怎麼樣？",
        "unit_id": 117111,
        "voice": "vo_adv_1171001_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐穿了泳裝唷？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～",
        "unit_id": 117111,
        "voice": "vo_adv_1171001_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你一副「為什麼要換泳裝？」",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "的表情耶？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的……",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟還真是沒情調。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐和弟弟一起來海邊，",
        "unit_id": 117111,
        "voice": "vo_adv_1171001_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n無論如何都該換上泳裝才對嘛。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是這樣唷♪",
        "unit_id": 117111,
        "voice": "vo_adv_1171001_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼弟弟，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你知道你接下來該做什麼嗎？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯。",
        "unit_id": 117111,
        "voice": "vo_adv_1171001_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n……找房子？",
