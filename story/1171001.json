[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個夏日，靜流把{player}約出來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n說了這樣一段話。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要住的話，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然還是海邊好呢。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "與自然融為一體的小木屋，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n打開窗戶便是一望無際的蔚藍大海與白色沙灘。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "早上吹著令人心曠神怡的海風，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "晚上聽著海浪演奏的搖籃曲入眠……♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對吧？",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要住的話，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "絕對會選海邊小屋吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦？",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我沒說過嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我呀，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "正在找房子喔。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼啦，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為什麼",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要用這麼擔心的眼神看著姐姐？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不是因為我忘記了家在哪裡，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n或是被從家裡趕出來，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "又或是家爆炸消失了這類的原因唷？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我在蘭德索爾有固定的住所，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n只是也想在別的地方租棟房子。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也就是所謂的",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "休閒別墅？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "說起別墅",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就有種奢侈的感覺呢。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實是要當作",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "【拉比林斯】的第二據點，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在危急時刻",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "用來藏身",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "的避難所……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過不過，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "反正只要是公會成員都能自由使用嘛。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "稍微按照自己的喜好挑選",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也沒關係吧？　",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "然後就這樣順勢和弟弟",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一起住進去……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n欸嘿嘿。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以說啊弟弟！",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我今天把你找來，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是為了一起去挑房子唷♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇♪",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n弟弟",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "幹勁十足呢！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n呵呵，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們一起找出理想中的房子吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "放心吧弟弟♪",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那份工作",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐已經替你完成囉。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了和你一起去海邊非常努力呢！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "快誇我快誇我♪",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來吧，",
        "unit_id": 104914,
        "voice": "vo_adv_1171001_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "目標是理想美屋！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n出發",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "囉♪",
        "unit_id": 104914
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "靜流",
