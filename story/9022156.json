[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿～嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_9022156_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "打贏啦～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在嚐遍這世界的所有食材滋味之前，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還不能夠被吃掉喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是那隻魔物……",
        "unit_id": 105911,
        "voice": "vo_adv_9022156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在阿斯特賴亞大陸上也沒看過呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下以為我們應該算是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "見識相當廣闊了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這一帶雖然聽說可以開採到",
        "unit_id": 106011,
        "voice": "vo_adv_9022156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貴重的礦物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但因為有那種傢伙在，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才會危險到令人無法靠近深處啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這一點也要好好地報告給",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【公會管理協會】才行。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "靠著那嬌小，",
        "unit_id": 105911,
        "voice": "vo_adv_9022156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像鱗一樣的變異翅膀飛行……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有異常發達的肌肉，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鋼鐵般堅硬的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "爪與喙。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以鳥類而言",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來是有一點不自然的外型。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔……",
        "unit_id": 105811,
        "voice": "vo_adv_9022156_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肉應該也很硬的樣子……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要切的話大概會切壞整把菜刀。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是的……",
        "unit_id": 105911,
        "voice": "vo_adv_9022156_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡是神秘未知的島。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還不知道",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哪些東西能吃呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n搞不好還會像剛才一樣",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又被突然襲擊也說不定。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔……",
        "unit_id": 105811,
        "voice": "vo_adv_9022156_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿還真像個媽媽呢～",
        "unit_id": 105811
    }
]