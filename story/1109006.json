        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒在這裡",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是碰巧，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其實是——",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為我很閒，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_061"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就來玩學長了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "…………",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_062"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_063"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好意思，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我好像小小地弄錯助詞了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「玩」",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是來",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「跟」",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長玩了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "應該是這樣吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "反正意思是一樣的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_064"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "口頭禪又出現了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在工作",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在工作，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你每次都說同一句還真不膩……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你根本就打算讓那句流行起來吧？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你沒問題吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唉，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_065"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "算了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你要工作吧，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請繼續請繼續，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不用管我。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今天琪愛兒",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_066"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是以參觀工作的名義過來的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n學長只要",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "和平時一樣工作就行。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我會自己在後面看著你。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼？",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_067"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，不，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是啦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這不是跟蹤狂。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我說真的，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_068"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為我們學校禁止打工，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以我很憧憬那種",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "工作現場的氛圍呢～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "別看琪愛兒這樣，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_069"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其實我是很想早點出社會的那種人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然還沒決定志願，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過會考慮升學以外的路。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是這麼一回事，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_070"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "來，請繼續工作吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n請你認真地工作吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後，琪愛兒",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_071"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會注意不打擾到工作的學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就這樣子從暗地裡觀察。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個位置看得很清楚，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還能把身體藏得很好。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_072"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，不是哦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就說不是跟蹤狂了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這是參觀工作，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "才不是什麼跟蹤狂哦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是說，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_073"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你是不是有點太厚臉皮了？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我跟蹤學長有什麼樂趣啊？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n怎麼可能有那種怪人嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你沒問題吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……嗯？",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_074"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "奇怪，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_075"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才好像有人在……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，算了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "開始來參觀工作",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "吧～。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是就在{player}默認之下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n琪愛兒和步未將暫時繼續合法地跟蹤他。"
    }
]