[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從學院回家的路上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n琪愛兒閒來無事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n腳自然而然地就往蘭德索爾的老地方走去。"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是可愛的琪愛兒～♪",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n大家最愛的琪愛兒～♪",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我看看哦～？　",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像還沒來呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不過，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我也沒有特別指是誰會來就是囉。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好～",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "既然剛好有空，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就在這裡舉辦藍天欣賞會，等人來吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我也沒有特別在等誰來就是囉！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "看膩",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "藍天了呢……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼還～不來……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我並沒有特別指是誰會來就是了……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是今天要送的貨很多，很辛苦嗎……",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n沒辦法了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總之我再看一下藍天吧……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "…………都不來。",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "都不來耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那人到底想怎樣啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太扯了吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼我非得這樣等他不可啊？",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是說琪愛兒基本上是讓別人等我的類型耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，是怎樣，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "搞什麼，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "未免太扯了吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "………………不是，怎麼不來啊，喂！",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "未免太扯了吧，未免太扯了吧！",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真的有夠莫名其妙，那個人到底在做什麼！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n該不會是腦袋撞上史萊姆的角，橫死在路邊了吧！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "…………",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "該不會，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的發生什麼事了……？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不會吧，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼辦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "得去找他才行！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊？！",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那個包包和{player}學長平時背的一樣！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大概是同業的人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "去問問看那個人吧！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不好意思～！",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我有點事想問你～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "伊麗莎白牧場……？",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_015"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "是啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_016"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "是位於山丘上的牧場哦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n最近請他幫忙送這附近的貨，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n不過他原本負責的區域是那一邊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼嘛，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來是這樣啊。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這孩子真是讓人虛驚一場，真令人困擾呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我代替他道歉，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對不起啦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯～",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣啊……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼琪愛兒去散步，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "順道去一下那個牧場吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我不會打擾他工作哦？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只是稍微參觀工作而已。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "呃……",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_019"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "妳",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "是他的家人嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是不是。",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_020"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "那是",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_021"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "戀人嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦～",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_022"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼可能。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不覺得我們很不配嗎～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "尤其是臉。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "那不然……",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_023"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "妳是他的什麼人？　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "跟蹤狂嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啥、",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啥啊！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n攔住大家都喜歡、搶著要的超級美少女，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n竟然還說我是跟、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "跟蹤狂！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "因為",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_025"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "妳不是家人也不是戀人，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n還說妳在這裡堵他……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "而且，",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_026"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "等下還要特地追到山丘上不是嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "那不就是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "一般俗稱的跟蹤——",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是。",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_027"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我是去參觀工作。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "是嗎，",
        "unit_id": 1411,
        "voice": "vo_adv_1109006_028"
    },
    {
        "type": "dialogue",
        "name": "送貨員",
        "words": "不管怎麼想都是跟蹤——",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不是。",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_029"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是在打發時間。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是少女的心血來潮。",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "於是總算洗清我的冤罪，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n一邊來到了這個山丘上的【伊麗莎白牧場】。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "來到這裡除了參觀工作，",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_031"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有其他意思。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我以在蘭德索爾社會中表現活躍的獨立女性為目標，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "想趁現在參觀各種職業的工作情形。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "絕對不是什麼跟蹤狂。",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_032"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯？　",
        "unit_id": 110911,
        "voice": "vo_adv_1109006_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "從那間悠靜的簡易小屋出來的人影是……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噫，",
        "unit_id": 110911,
