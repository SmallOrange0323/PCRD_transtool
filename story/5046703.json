    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたし本当にどうしたんだろう。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nどのみち食べられるのに変わりはないじゃん。",
