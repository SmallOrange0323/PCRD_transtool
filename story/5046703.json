        "name": "リン",
        "words": "\nあたし",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なんでチーズに話しかけてるの？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "この子たちのために戦ってたから愛着湧いちゃった……？",
