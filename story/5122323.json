[
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "祕、",
        "unit_id": 126811,
        "voice": "vo_adv_5122323_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "祕密魔物又開始掉下來了！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而且這次……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還同時在大聲地暴露祕密耶～！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "好──",
        "unit_id": 6411,
        "voice": "vo_adv_5122323_001"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "既然如此！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n我就大聲暴露自己的祕密，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n讓那些傢伙的聲音",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "無法被聽見！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "咳咳。",
        "unit_id": 6411,
        "voice": "vo_adv_5122323_002"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我就老實說吧，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這個粗獷系的",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "銀飾品……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "是靠祕密廢棄服務賺來的",
        "unit_id": 6411,
        "voice": "vo_adv_5122323_003"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "分配金買的啦──！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "一夥",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5122323_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……秋乃，",
        "unit_id": 126611,
        "voice": "vo_adv_5122323_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n麻煩妳將多到堵塞的吐槽點整理一下。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "第一，",
        "unit_id": 126711,
        "voice": "vo_adv_5122323_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "事到如今那種事根本就不是祕密。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "第二，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說起來只要大聲就好，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n內容根本不需要是祕密。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就是說，",
        "unit_id": 126611,
        "voice": "vo_adv_5122323_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然吐槽點很多，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過就結果上沒有問題。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你繼續吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "──好呀！",
        "unit_id": 6411,
        "voice": "vo_adv_5122323_008"
    }
]