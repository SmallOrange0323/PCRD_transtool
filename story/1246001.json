    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年期間的某一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n美里與{player}接下祭司的請託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到神殿幫忙。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "新年快樂♪",
        "unit_id": 124611,
        "voice": "vo_adv_1246001_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n歡迎前來參拜～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "啊，美里。",
        "unit_id": 511,
        "voice": "vo_adv_1246001_001"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "接班的巫女已經到了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n妳幫忙到這裡就行了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n才剛過新年就請妳過來幫忙，真不好意思。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不，",
        "unit_id": 124611,
        "voice": "vo_adv_1246001_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請不用放在心上～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我正好送來要供奉在祭壇上的",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "精靈之森藥草，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n只是順手幫個小忙而已♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "再說，",
        "unit_id": 124611,
        "voice": "vo_adv_1246001_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "反而是我該說聲謝謝呢。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n謝謝偶然相遇的{player}，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n願意陪我一起留下來幫忙──",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵，",
        "unit_id": 124611,
        "voice": "vo_adv_1246001_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也是～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很好很好，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是個",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "乖孩子～",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "真的很謝謝",
        "unit_id": 511,
        "voice": "vo_adv_1246001_005"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "你們兩位的幫忙。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "……對了，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "若不嫌棄的話，在回去之前",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n很歡迎你們去正殿參拜一下喔。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯，",
        "unit_id": 124611,
        "voice": "vo_adv_1246001_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "樂意至極♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……啊，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你怕我在雪地滑倒，所以牽住我的手嗎？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你真體貼♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那麼，{player}，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們就手牽著手一起過去正殿吧～♪",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵，",
        "unit_id": 124611,
        "voice": "vo_adv_1246001_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不管什麼時候看，正殿總是這麼宏偉壯觀。",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，我們來進行新年的參拜吧──",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦……？",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇～～～",
        "unit_id": 111,
        "voice": "vo_adv_1246001_008"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我抽到大凶了～～～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我不要這個～～～！！",
