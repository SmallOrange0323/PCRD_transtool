        "words": "不要在這裡哭鬧……！",
        "unit_id": 411,
        "voice": "vo_adv_1246001_009"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n你這樣會給周遭人們帶來困擾，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我們快點回去吧……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我～不～要～～！",
        "unit_id": 111,
        "voice": "vo_adv_1246001_010"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我還要再抽一次～～！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我要抽到大吉才回家～～～！",
