    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯呵呵，",
        "unit_id": 124611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以我才會說很羨慕你啊～♪",
