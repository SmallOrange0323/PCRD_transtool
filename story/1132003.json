    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也很開心呀。",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_041"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我深信，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我和你之間的羈絆，",
