        "voice": "vo_adv_1132003_042"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是啊。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也是同樣的心情。",
