    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看來你也",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "稍微萌生了身為同路人的自覺了呢。",
