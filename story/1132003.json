        "voice": "vo_adv_1132003_038"
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "鑲有七夕雙星外型的寶石，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "\n即使兩人在此生分離，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "\n也會跨越時空，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "讓兩人",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "在來世重逢。」",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "跨越時空的",
