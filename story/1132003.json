        "name": "女神",
        "words": "活動闖關成功的獎品！",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "非常適合你們兩位，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女神",
        "words": "要好好珍惜喔♪",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對不起啊，",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_033"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因為我的誤解，讓你陪了我一整天……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n虧我還誇下海口……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……真的嗎？",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_034"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說的也是，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們一起吃了刨冰，",
