    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "再適合我們不過了！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯，",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_040"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒有錯。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n降臨在我們身上的",
