        "words": "打了西瓜，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n還一起玩了沙灘排球……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感覺暢快地享受了夏日時光呢。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這樣一想，",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_035"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "或許該慶幸我們一起做了這件事。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這也是",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們之間的羈絆，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對了，",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_036"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "小禮物裡面裝著什麼呀？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n難得拿到了，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不如就打開看看吧。",
        "unit_id": 113211
    },
    {
        "type": "still",
        "still": "113200301"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦，",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_037"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
