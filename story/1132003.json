        "voice": "vo_adv_1132003_048"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「熾炎戰鬼煉獄血盟暗黑團」的羈絆。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你要隨身攜帶，",
        "unit_id": 113211
    },
