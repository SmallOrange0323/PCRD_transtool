    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你深情款款地對我說那種話，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "很讓人害臊的啊……！　",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……看來我的判斷是正確的！",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_044"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然他們聲稱剛才的一切只是活動，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但那只不過是假象！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那肯定是設計來考驗我們之間的羈絆的！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來吧，",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_045"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們快戴戴看。",
