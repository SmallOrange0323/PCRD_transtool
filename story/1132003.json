        "voice": "vo_adv_1132003_046"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這個墜飾",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就是我們的羈絆之證。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "適、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "適合我嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是、",
        "unit_id": 113211,
        "voice": "vo_adv_1132003_047"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是嗎？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嘿嘿嘿……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n吉格魯特，",
