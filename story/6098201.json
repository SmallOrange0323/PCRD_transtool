[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ふむ、",
        "unit_id": 105913,
        "voice": "vo_adv_6056201_000"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ここの費用を削ればなんとか……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "っと、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "主さま。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n気づかずに申し訳ございません。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "【美食殿】の家計簿をつけておりまして……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "やはり",
        "unit_id": 105913,
        "voice": "vo_adv_6056201_001"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "思った以上に厳しいようです。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "しかし、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "この機会に",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "改めてお金の使い方を見直せるのは",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "良いことかと。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "こうして紙面に残すことで、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "気持ちも引き締まりますので。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "い、",
        "unit_id": 105913,
        "voice": "vo_adv_6056201_002"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "いきなりどうなされたのですかっ？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "……あ、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "なるほど。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "【リトルリリカル】の方々と遊んだ時の出費で\nございますね。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "その程度であれば",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "なにも問題ないので",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "ご安心ください。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "はい。",
        "unit_id": 105913,
        "voice": "vo_adv_6056201_003"
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "今は",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "一発逆転の方法が必要とはいえ……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n快適なギルド生活の基本は、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "まず家計からでございます。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "これからは",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "コッコロ",
        "words": "しっかり管理いたしますので。",
        "unit_id": 105913
    }
]