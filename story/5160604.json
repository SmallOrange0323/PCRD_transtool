    },
    {
        "type": "dialogue",
        "name": "妖魔人１",
        "words": "けけけ！　",
        "unit_id": 1,
        "voice": "vo_adv_5160604_005"
    },
    {
        "type": "dialogue",
        "name": "妖魔人１",
        "words": "この辺りじゃ見ねえ魔物だ、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人１",
        "words": "\n物好きな金持ちに高く売れそうだぜ。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "いや、",
        "unit_id": 1,
        "voice": "vo_adv_5160604_006"
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "それよりも食っちまおうぜ。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "\n丸々太ってて食べがいがあんぞ。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "やっぱりベスちゃんか！　",
        "unit_id": 133212,
        "voice": "vo_adv_5160604_007"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "貴様ら、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "その子から手を離せ！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "妖魔人１",
        "words": "あぁん？　",
        "unit_id": 1,
        "voice": "vo_adv_5160604_008"
    },
    {
        "type": "dialogue",
        "name": "妖魔人１",
        "words": "なんだこのガキャボエぇー！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "ひっ！　",
        "unit_id": 1,
        "voice": "vo_adv_5160604_009"
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "い、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "一撃で……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "こ、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "来いデブトカゲ！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "逃がさないわよ！　",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_010"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "メドゥシアナ！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "ひ、",
        "unit_id": 1,
        "voice": "vo_adv_5160604_011"
    },
    {
        "type": "dialogue",
        "name": "妖魔人２",
        "words": "ぎゃあああー！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふぅ、",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_012"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "危なかったわね。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アンタ大丈夫？　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ケガとかしてな──",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ベス",
        "words": "ぎゃぷぎゃぷ！",
        "unit_id": 8311,
        "voice": "vo_adv_5160604_013"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なに、",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_014"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "この子……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "マヌケっぽいけど愛嬌のある顔にもちもちボディ！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nか、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "かわいいじゃないの……",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "いたー！　",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_015"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "ベスちゃーん！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ベス",
        "words": "ぎゃうぴぃ！",
        "unit_id": 8311,
        "voice": "vo_adv_5160604_016"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "よかったー！　",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_017"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "ひとりにしちゃってごめんね……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "危なくさらわれそうになっていたんだ。",
        "unit_id": 133212,
        "voice": "vo_adv_5160604_018"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n祭りで人出も多い、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "より気を付けた方がいいな。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "あ、",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_019"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "モニカ！　",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "そっか、",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "モニカが助けてくれたんだね。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "\nそっちの子はモニカのおともだち？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "\nベスちゃんを助けてくれてありが、",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "と……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ど、",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_020"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "どうかしたの？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "アンタのおともだちのヘビ、",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_021"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "すっごくカッコいいのね！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "\n強そうで迫力のあるお顔が素敵だね！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふ、",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_022"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふーん、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なかなか見る目あるわね、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アンタ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nそう、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "メドゥシアナはとても強いのよ！　",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "すごく頑丈でブレスも吐けるし",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nおまけに何倍にも大きくなれるんだから！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "すごーい！　",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_023"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "でもベスちゃんも負けてないよ？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "\nベスちゃんはフルーツが大好きで火を吐けるし、",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "\nそれにそれにすっごくかわいいの！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "分かるわ。",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_024"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "そのピンクのもちもちボディ、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "とてもキュートよ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nねえ、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "その子撫でてもいいかしら。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "もちろん！　",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_025"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "ヴァンピィちゃんもアンタのヘビさん、",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "触ってもいい？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ええ、",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_026"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "いいわよ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "あ、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "そういえば自己紹介がまだだったわね。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nアタシはメドゥーサ、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ジオ・ゲヘナの貴族、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ゴルゴーン三姉妹の末妹よ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "そうなんだ！　",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_027"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "ヴァンピィちゃんも吸血鬼の真祖？　",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "っていうみたい。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふーん、",
        "unit_id": 133612,
        "voice": "vo_adv_5160604_028"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なんだか家柄もいいみたいね。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "気に入ったわ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nヴァンピィ、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "この後一緒に遊ばない？",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\nモニカに甘いものでも食べさせてもらおう！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "賛成！　",
        "unit_id": 122311,
        "voice": "vo_adv_5160604_029"
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "楽しくなってきたね、",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ヴァンピィ",
        "words": "ベスちゃん♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "ベス",
        "words": "ぎゃぷう！",
        "unit_id": 8311,
        "voice": "vo_adv_5160604_030"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いやはや、",
        "unit_id": 133212,
        "voice": "vo_adv_5160604_031"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ジオ・ゲヘナの大貴族と吸血鬼の真祖の揃い踏みか。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n世界がひっくり返りそうなとんでもない光景だが……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nまあ、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "この二人なら大丈夫か。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "和気あいあいとするメドゥーサとヴァンピィをよそに、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n一人苦笑いのモニカだった。"
    }
]