[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～可愛哦……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，【王宮騎士團】！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n聽到這名字，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳的臉色就變得很難看……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n難不成，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大姐姐妳是壞人嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "【王宮騎士團】，\n是為了消滅犯罪者及惡勢力而戰的",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "正義夥伴公會！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "聽到這名字之後會感到害怕，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就表示妳是壞人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個…，",
        "unit_id": 105913,
        "voice": "vo_adv_2006006_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問您有做了什麼犯法的事情嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有沒有，",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不是說過了嗎……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我被誣陷為『假冒公主的冒牌貨』，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在正遭到通緝呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然事實上完全相反呢～",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只是沒有人相信我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_2006006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對『冒牌貨』來說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想必『真正的』貪吃佩可小姐的存在很礙事呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此會對您發出通緝令，",
        "unit_id": 105913,
        "voice": "vo_adv_2006006_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓妳成為那些賞金獵人的目標",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是理所當然的呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳們在那邊碎碎念些什麼？",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我絕對不會放過犯罪者的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我要逮捕妳！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不對，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "首先要好好溝通！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　總之，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "請妳和我走一趟……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇，妳誤會了哦～？",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣很危險，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請不要拿著那把劍揮來揮去的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔嗯！",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　別想逃，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n給我乖乖地束手就擒……！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇？",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很不妙呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這孩子",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實力可不差！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然不至於會輸給她……",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是大意的話說不定也會受傷，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}你們快退下！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔嗯～？",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n妳想抵抗嗎，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n要是妳自首的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "罪刑可以輕一點……！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就說了～",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是誤解啦！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳再這麼調皮的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就要打妳屁股了哦？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳們在那裡做什麼……！？",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊，小智姐～！",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　妳來的正好，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n請妳快來幫忙我逮捕這群人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呃，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "發生什麼事了？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然我不太清楚事由，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但妳還只是個見習生，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可沒有逮捕權哦？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "危險的事情就交給大人處理，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳快退到後面！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚～，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳又把我當小孩子看！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就算我是小孩，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n熱愛正義的心，可不會輸給大人的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "總而言之，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳先暫時退到我身後！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就這樣看來，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這敵人可不容小覷呢……！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "憑妳是無法與對方抗衡的，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我來當她的對手！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是隸屬於【王宮騎士團】的\n騎士團員智！",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_025"
    },
    {
        "type": "still",
        "still": "200600601"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下來支援妳，",
        "unit_id": 105911,
        "voice": "vo_adv_2006006_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "二對一對妳不利！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～……",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果三個人的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該就有辦法解決這狀況了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是我們害這兩個人受傷的話，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就會真的變成犯罪者了哦。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我記得好像叫做",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「妨礙公務」的樣子。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以先冷靜一下嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的是誤會一場啦～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們不要打架好嗎！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和平相處是最棒的呢，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吶～吶～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這還真不像是壞人會說的話呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n而且實際上，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也感受不到妳的惡意。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "只是現在是陛下臥病在床的敏感時期，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要趁災禍之苗未滋長前就斷其之根！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "接下",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我這劍吧！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "喝啊啊……！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哇啊！？",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她是認真的，而且相當的強！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　很不妙呢！",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n看來妳對我的實力感到很驚訝，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這樣可是無法與【王宮騎士團】抗衡的哦！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抵抗是沒有意義的！",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "請妳乖乖地束手就擒！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷唷？",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明就沒做什麼壞事，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我才無法接受就這樣被妳們逮捕呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，【王宮騎士團】的人",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n稱之為陛下的就是那個『冒牌貨』吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "臥病在床",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又是怎麼一回事？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～。",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會是因為施放了戰略級大量破壞魔法的關係，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n導致魔力枯竭，所以暫時陷入昏睡狀態……之類的？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是他自作自受呢，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且如果他動不了了，這也是個好機會！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要把那些",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n屬於我的一切全奪回來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定要！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我不能在這種地方，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被妳們繩之以法！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喝啊啊～……☆",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哦哦？",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真是強大的破壞力呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "從出招方式看來太天真了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那種打架用的招式，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是不可能贏過經長久歷史",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "磨練而出的正統派劍術的！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "御久間流劍技，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳就親身體會它的厲害吧……！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔唔，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n外表看起來雖然是個冰山美人，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但意外是個熱血的人呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完、",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全沒有要聽我說話的意思。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再這樣下去我就要生氣了哦！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那一天為了美味的一餐而尋遍山林，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了狩獵魔物而學會的劍技，要用在實戰上了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的劍技，",
        "unit_id": 105811,
        "voice": "vo_adv_2006006_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可不會輸給那種虛有其表的書院劍法……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳還真敢說呢，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n事情稍微變得有趣起來了……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵呵，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真讓我熱血沸騰！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n抱歉！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "暫停一下！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那邊那個人，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_053"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你的名字該不會是{player}吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我想也是，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太好了太好了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我一直都好想要",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "見你呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我認錯人了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以讓我好好確認你的長相嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_056"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這距離伸出舌頭就能碰到你，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真讓人臉紅心跳呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你的臉也都紅了……♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯。",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_057"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n果然，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "和通緝令長的一模一樣。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你就是{player}對吧，為什麼一直裝傻呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？",
        "unit_id": 105911,
        "voice": "vo_adv_2006006_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您認識",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下的主人嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2006006_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也真是的……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n遇到的每個女孩子，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n幾乎全都認識您呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_060"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我和他是第一次見面，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n只是我身上帶著通緝令，所以才會認識他的長相。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣啊……",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_061"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n果然你就是\n{player}呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太好了，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_062"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我一直都好想見你。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不對，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我一直都在找你。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "抱歉，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_063"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然是我們先發起的戰鬥，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也沒什麼立場能夠說這種話……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但我希望能暫時休戰，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_064"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n彼此都收起劍來。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我有些話……，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "想和{player}說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～。",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然有點無法釋懷……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我們也",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不想看見有人受傷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果不用戰鬥就能解決的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想那樣也比較好。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳說有話想和{player}說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是什麼事？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【王宮騎士團】是",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個『冒牌貨』的直屬部下呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說實話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是連話都不太想和妳們說的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們還真是惹人厭呢。",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_069"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔嗯，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "『冒牌貨』啊……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真令人感興趣呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那件事情，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_070"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也希望妳能盡量告訴我。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我呢……",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_071"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n其實也不是一個嗜殺成性～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n的那種無禮的野蠻人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果能透過對話解決的話，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_072"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這樣也比較好。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳說對吧，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_073"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n啊，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄守則第十一條，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_074"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n暴力不能解決任何事情！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣啊。",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_075"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也希望能盡量當個「正義的夥伴」，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那就遵守這條守則吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "茉莉總是會讓我們",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_076"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n想起很重要的事情呢♪",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_077"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哎呀～，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "突然間稱讚我真是不知所措！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　好害羞喔～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_078"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n話說回來，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n一直站在這荒野上也不是個辦法…",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我想找個像咖啡廳那種可以好好聊天的地方，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_079"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n稍微休息一下呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔～",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_080"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，\n現在也不適合悠閒地坐著喝飲料聊天呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們現在，",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_081"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n正急著和牧場的人取得聯繫。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊啊，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_082"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這樣的話，我幫妳準備輛馬車吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_083"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "牧場的重建作業，\n好像還欠缺一些必須的物資……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以我要到城裡調度。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等我將那些東西送過去時，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_084"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也可以順便載妳們到牧場去。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣就能夠趁搭車的時候，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_085"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好好的聊一聊對吧。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_086"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以搭順風車的意思嗎。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像都是我一個人在做決定……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，你們覺得\n這樣ＯＫ嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_2006006_087"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有問題哦。",
        "unit_id": 105913,
        "voice": "vo_adv_2006006_088"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為徒步登山",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該會相當的辛苦，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此如果能搭馬車移動的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會很有幫助。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2006006_089"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您認為這樣子如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊哈哈，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_090"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n雖然搞不太清楚狀況，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n但就跟虎虎發生的事情一樣呢？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "爭執過後，就能互相理解，",
        "unit_id": 100511,
        "voice": "vo_adv_2006006_091"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n關係就變好了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "昨日的敵人是今天的朋友……☆",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊哈哈，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_092"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然在現實當中，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這種事情可沒那麼簡單就是了呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了實現自己的理想，",
        "unit_id": 103711,
        "voice": "vo_adv_2006006_093"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我認為努力也是不可或缺的哦。",
        "unit_id": 103711
    }
]