[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿茜作為【美食殿堂】的臨時成員順利完成各種委託。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她接到討伐魔物的委託，\n與{player}一同前往山中洞窟。"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "再過不久",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我就該返回吉歐‧提格尼亞了，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n能作為臨時成員的活動時間所剩不多。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "直到最後都要卯足全力完成委託喔～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我會好好努力達成委託，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n讓你看看",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我成長後的樣子！",
        "unit_id": 134511
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好了，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們到了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "如果是航空軀體的話，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一口氣就能從公會管理協會",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n飛到委託的目的地了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就照這個步調討伐魔物──",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不用擔心喔！",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我的手臂已經縮小，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "整體來說也減輕了重量♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我們就一鼓作氣地戰鬥吧！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "發現魔物了！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我會馬上打倒的！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n克蘿茜，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "出動──！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好痛～！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n洞窟裡太窄了，沒辦法好好飛行～！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我沒事喔～！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n雖然不如往常，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但我還是很強壯的！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你沒有受傷吧？",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "太好了，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "看來你沒事呢。",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "空中戰鬥似乎很困難……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "既然如此，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就重新調整一下，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "換成步行模式。",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然我現在強化了飛行能力，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但也是能好好走路的喔……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "唔。",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊、",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊、",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "地面凹凸不平，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "卡住了我的腳，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n要摔倒了……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "唔……",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "步行模式",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "失敗了～",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "既然這樣就用光束！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n採取遠距離砲戰～！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生對不起！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n頭頂上的鐘乳石要掉下來了！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n請趕快逃～～～！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯～",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "該怎麼辦呢？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我還以為航空軀體什麼事都做得到～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這樣下去",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "最後的委託會無法完成的～",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "航空軀體不適合在洞窟內戰鬥，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n令克蘿茜一行人陷入了意料之外的苦戰。"
    },
    {
        "type": "background",
        "background": "501710"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿茜與{player}決定暫時離開洞窟，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前去拜訪吉歐‧提格尼亞的波波爺爺。"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們回來了～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "哦哦，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_014"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "你們兩個都從蘭德索爾回來了啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "歡迎回來。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "好啦，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "老夫很想馬上聽你們分享旅行趣聞……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n但看來現在還不是時候啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那個，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我原本的身體",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "修理好了嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我在想可能要試著換回去一下……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "怎麼這麼突然？",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_016"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "空戰強化規格不適用嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "修理應該還滿順利的，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n讓老夫移動記憶元件看看吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呼，",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好久沒用這副軀體了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "有種懷念的感覺呢～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這是我很熟悉的重量。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝你，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "總之，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_018"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "先來做動作測試。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n試著輕輕做些動作就好。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "把手臂～",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "轉一轉～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n用腳蹦蹦跳跳♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "最後",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "用噴射靴咻～地起飛♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_020"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "效果絕佳呢！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n在妳外出期間老夫把每個角落都維護過了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用習慣的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "工具果然是最好的──",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯……",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "或許還是新的身體比較好！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "為什麼！？",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_022"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n……不，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "說起來，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "妳怎麼會突然說",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "想換軀體？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n難道妳對航空軀體不滿意嗎？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "……原來如此。",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_023"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n在洞窟這種狹窄的空間戰鬥，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "沒辦法發揮空戰強化規格的優勢啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n不能飛，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也不能走，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "武裝會派不上用場",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也是可想而知的。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯……",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_024"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "既然如此，就提升光束的威力吧！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n只要打穿牆壁，空間就會變寬了吧！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此～！",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "只要提升威力，攻擊整個洞窟的話，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n就不用讓騎士先生經歷危險了呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真不愧是波波爺爺！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不行嗎？",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那──",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我知道了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n只把腳換成原本的如何呢？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n還有",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "其中一隻手也是！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這麼一來，",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "除了光束以外還可以出拳，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "也可以控制力道！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n步行也會比較穩定吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "聽起來似乎是個好主意，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_028"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "但恐怕會嚴重失去平衡。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "整備和",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "換裝雖然容易，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n但要更換規格不同的配件",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "可是十分艱難的。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦咦～",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "辦不到嗎！？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "唔唔，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_030"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "身為技術人員，老夫很想說沒有不可能……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n但、",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "但目前真的沒辦法！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "妳的機體等級本來就超出老夫的技術力，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_031"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這樣整體會失去平衡，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "最糟的情況下",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "還可能會沒辦法運作！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "怎、",
        "unit_id": 126411,
        "voice": "vo_adv_1345003_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "怎麼會這樣～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的♪",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我正在迅速成長，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n說不定會有更能活用航空軀體的好主意！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "放棄換裝的隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蘿茜再次"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "造訪了波波爺爺的實驗室。"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不好意思打擾了～",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你在這裡嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呃，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "奇怪？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嘎哈哈！",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_035"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這是能貫穿洞窟岩石的超級鑽頭！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n以及任何險惡道路都能踏遍的盤旋腳！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "把這些",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_036"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "安裝在你的手腳上，就幾乎可說是無敵了！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n馬上就開始進行改造手術吧！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎、",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生！？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n你在做什麼──！？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "哦哦，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_038"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "是克蘿茜啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n好好感動吧！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "小伙子可是來接受改造手術的！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n他說想助妳一臂之力！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦咦～！？",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然很令人開心……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n可是",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "變成鑽頭手臂的話，不就很難擁抱了嗎！？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生還是維持自己原本的樣子就好了～！！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "為什麼要阻止他？",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_040"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "克蘿茜！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "小伙子想要力量！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "現在正是增強戰力的時候！！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可、",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可是……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "居民的聲音",
        "words": "喂──",
        "unit_id": 1,
        "voice": "vo_adv_1345003_042"
    },
    {
        "type": "dialogue",
        "name": "居民的聲音",
        "words": "波波爺爺！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "居民的聲音",
        "words": "克蘿茜！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "居民的聲音",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "居民的聲音",
        "words": "森林裡好像出現了魔物！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "居民的聲音",
        "words": "\n你們現在能馬上過去嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "什麼？",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_043"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "你說魔物！？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n可惡，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "改造手術先暫時中止！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n小伙子、",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "克蘿茜，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "能拜託你們嗎！？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我們走吧，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生！",
        "unit_id": 134511
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "找到了，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是魔物！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n它好像大鬧起來了呢～！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n趁還未造成損害前趕快行動吧，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "和洞窟一樣，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "有很多障礙物。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n光束似乎難以穿透，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n用航空軀體也很難行動……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不過不過，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一定沒問題的♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "麻煩你誘導它了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "趁騎士先生走在前方時，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n把推進器的輸出功率縮小……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n機動性調整得精細一點……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "姿勢穩定下來了！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "發射已經準備就緒！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "請你稍微退開！",
        "unit_id": 134512
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不行，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一邊閃避樹木飛行的話，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n可能會擊中騎士先生……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n準心會偏移",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是因為位置在改變……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我想想……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我知道了！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "拉開距離……",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_052"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "朝著目標筆直飛過去！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n看我的──！",
        "unit_id": 134512
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "太好了，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "命中了～！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n一邊筆直飛行的話，就能穩定下來了呢♪",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n……雖然目前只命中一發，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但我漸漸覺得沒問題了！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n胸口處",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就好像湧出了力量！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這跟我和騎士先生擁抱時感覺到的溫暖",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "非常相似♪",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這種感覺",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "說不定就是安心呢！",
        "unit_id": 134512
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "再來一次！",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我已經漸漸了解了喔。",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "並不是只有我自己要戰鬥，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n而是要和騎士先生一起互相協助……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這就是我的戰鬥方式……",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不，",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是生存方式！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的，",
        "unit_id": 134512,
        "voice": "vo_adv_1345003_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "交給我吧！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這樣就結束了！",
        "unit_id": 134512
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "看招──！",
        "unit_id": 134512
    },
    {
        "type": "background",
        "background": "501770"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "太好了～！",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_059"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "討伐成功了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿……",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "其實，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我從昨天就一直在思考。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n究竟該怎麼做，才能在不擅長的地點",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "更順利地戰鬥。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但是，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_061"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我無論如何都無法想像自己一個人順利戰鬥的樣子……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n就在那時，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我想起了用之前的軀體，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n和騎士先生一起戰鬥的時候！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "然後，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我就有一種能夠非常順利的感覺！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我真的成功討伐魔物了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "……看樣子",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_063"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "是老夫多操心了啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺！？",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_064"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n你都看到了嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "森林和洞窟一樣，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_065"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "都不適合使用空戰強化規格。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n老夫一半是擔心你們，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "一半是為了驗證，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n於是就偷偷跟著過來了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "看來是這樣。",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_066"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "是老夫這老狗想太多了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n……畢竟克蘿茜",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "似乎也找出屬於自己的答案了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿，",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一直以來都覺得，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n航空軀體無論什麼事都做得到。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我以為有所成長",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就表示什麼事都要了解，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n什麼困難都必須獨力克服。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但是，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "其實並不是這樣！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我現在",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "明白了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n原來根本不需要自己一個人辦到所有的事。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "和騎士先生一起",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_070"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "互相協助，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n一定比較適合我！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯。",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_071"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n……妳",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "成長得很出色！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n超乎老夫的想像啊。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "哎呀哎呀，",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_072"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "所謂的成長",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "究竟是機械人族本身",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就具備的功能，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n還是只有克蘿茜才擁有的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "某種特別之處……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n詳情老夫不是很清楚。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "看來似乎還很值得好好分析啊！",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_073"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n好了，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "那我們回去吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的！",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_074"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我會抱著把你送回去的，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我也會用揹帶",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "把波波爺爺載回去！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯。",
        "unit_id": 9212,
        "voice": "vo_adv_1345003_075"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "載我們時順便練習迴避機動吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n只進行直線機動會被敵人攻擊的。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n然後回去之後，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就重新開始進行小伙子的改造手術吧！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對喔對喔！",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_076"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我和騎士先生在蘭德索爾接受的委託還沒結束！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們去去就回，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "波波爺爺！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這次",
        "unit_id": 134511,
        "voice": "vo_adv_1345003_077"
    },
    {
