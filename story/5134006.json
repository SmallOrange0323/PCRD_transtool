[
    {
        "type": "background",
        "background": "500182"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}等人為了阻止隕石造成損害而奔走。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們各自都下定決心之際，展開了最後的作戰會議。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "抱歉，",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓各位久等了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我來報告",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這邊得到的結果。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為這樣，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以似乎很難讓居民去避難。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "墜落地點",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "倒是預估得差不多了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖說有人帶路，",
        "unit_id": 124711,
        "voice": "vo_adv_5134006_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但要東奔西跑真的是很累人……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過也因此",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "化解了年底的運動不足呢。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你們那邊如何？",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有找到應對碎片的辦法了嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯。",
        "unit_id": 128411,
        "voice": "vo_adv_5134006_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n使用我的「魔法」，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就能夠減緩碎片的速度了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n只要借助森神大人的力量，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想應該會有辦法的。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "想不到",
        "unit_id": 5413,
        "voice": "vo_adv_5134006_005"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "這個女孩",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "使用的並非魔法，而是叫超能力的東西。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n預知夢也一樣，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "如果是超出儂理解範圍的力量，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "那也能夠接受。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "不過也因此，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "令人擔心是否能夠確實強化……",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "作戰我已經明白了，",
        "unit_id": 128311,
        "voice": "vo_adv_5134006_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是絕對不能失敗哦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "萬一失敗了的話，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在那邊不知道在想些什麼的元凶",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n可是會造成超越那個霸什麼皇帝的擊殺人數啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "欸，",
        "unit_id": 5413,
        "voice": "vo_adv_5134006_007"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "不是，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "這是因為那個……",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "不管是下跪道歉還是什麼的儂都願意！！",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n就、",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "就拜託各位了～！！",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "用不著那麼做，",
        "unit_id": 128411,
        "voice": "vo_adv_5134006_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們也絕對會守護蘭德索爾的！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "老實說",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是有點害怕啦……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過各位，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "直到最後都請多擔待了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "喔～！",
        "unit_id": 1,
        "voice": "vo_adv_5134006_009"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "嗯？",
        "unit_id": 5413,
        "voice": "vo_adv_5134006_010"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "怎麼了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "你們必須到遠處去不是嗎？",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "原來如此，",
        "unit_id": 5413,
        "voice": "vo_adv_5134006_011"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "你的意見儂明白了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "那麼做確實有可能，",
        "unit_id": 5413,
        "voice": "vo_adv_5134006_012"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "而且成功率也會提高才是。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "不過儂無法保證",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "就是了。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "\n",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "都已經到這個地步，",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "那就竭盡全力吧。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看來你",
        "unit_id": 103813,
        "voice": "vo_adv_5134006_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經做出決定了呢。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "旁邊那位女孩",
        "unit_id": 5413,
        "voice": "vo_adv_5134006_014"
    },
    {
        "type": "dialogue",
        "name": "森神",
        "words": "似乎也有什麼想法呢。",
        "unit_id": 5413
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103813,
        "voice": "vo_adv_5134006_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然可能",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會惹姊姊生氣……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但是",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也決定了。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "森神大人，",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們也差不多該走了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n大家都已經出發囉。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "霞。",
        "unit_id": 103813,
        "voice": "vo_adv_5134006_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n方便聽我說句話嗎？",
        "unit_id": 103813
    },
    {
        "type": "background",
        "background": "501472"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "城裡那些人都沉迷於逛攤位啊……",
        "unit_id": 128311,
        "voice": "vo_adv_5134006_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是悠哉呢。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明巨大的隕石都快掉下來了。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟原本是值得慶賀的日子嘛。",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不過能否以值得慶賀的日子結束，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就得看我們的表現了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……好了，",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "進行最終確認吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖說依照初音畫的圖，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n能夠預測出隕石飛來的方位……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "其他的方位，",
        "unit_id": 124711,
        "voice": "vo_adv_5134006_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就由我和惠理子負責監視沒錯吧？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟無法保證一切都會照著預知夢的內容發展。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我會確實監視的。",
        "unit_id": 102711,
        "voice": "vo_adv_5134006_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這全都是為了守護",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那位大人與我的世界……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "拜託妳們了。",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "萬一",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "隕石從其他方位飛過來，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也請保持冷靜，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "打出信號來告知我們。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "了解。",
        "unit_id": 124711,
        "voice": "vo_adv_5134006_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們馬上就去分配的位置上。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n為了成功，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我們盡最大的努力吧。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我會待在祈梨身邊，",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "將發射光束的時機告訴她。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我想盡量",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "避免碎片擴散，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以妳一定要等我打出信號後，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再發射光束。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "希望妳盡快打出信號！",
        "unit_id": 128311,
        "voice": "vo_adv_5134006_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟要是在不妙的位置碎掉，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "連我都會遭殃的！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而初音",
        "unit_id": 128511,
        "voice": "vo_adv_5134006_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在看到光束擊中隕石後，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n請馬上使用魔法阻止碎片墜落。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……",
        "unit_id": 128411,
        "voice": "vo_adv_5134006_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
