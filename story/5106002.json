[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在牢房的一角，幾人交疊雙手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在進行互相鼓舞、提振士氣的儀式，然而──"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "大家一起努力，",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓聖誕節充滿幸福吧♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "好──！",
        "unit_id": 1,
        "voice": "vo_adv_5106002_001"
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "雖然和姊姊一樣是見習天使，",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_002"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "但因為我很優秀，所以不受物理侷限，",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n可以降臨到任何地方。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "……總言而之，",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_003"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n我的雙胞胎姊姊承蒙關照了。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哪裡哪裡……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳太客氣了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "45度的鞠躬……",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一看就很能幹，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她真的是拉菲的妹妹嗎？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "要說像的話，",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "確實是有點像，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但氛圍完全不一樣呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "嗯哼！",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_007"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n經常有人",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "說我們是「天壤之別」呢！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呃，那個……",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不是稱讚吧。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我們小時候經常在一起，",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_009"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n不過，艾米是見習生裡",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "最優秀的，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "所以最近幾乎",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "見不到面……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這麼說起來，",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_010"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "如果通過這次的升級考試，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n艾米就能拿到見習生徽章了！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "雖然我老是",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_011"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "卡在這一關。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "艾米肯定沒問題的！",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_012"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這次一定能",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "升級成「獨當一面的天使」",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "的！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "與其擔心我，",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_013"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "不如擔心一下自己吧。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "要不然",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我來協助妳",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "升級吧。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "艾米來幫我！？",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_014"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "可是……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我沒有問題的。",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_015"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不行啦！",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_016"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n艾米妳",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "就專注在自己的考試上吧！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這次我很有信心的！",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_017"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我和我的好夥伴弓箭……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "和這孩子",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "做了很多修行！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "況且，",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_018"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "依里她們也會幫我的，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "所以沒關係！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "啊，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "依里她們之前……",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我知道。",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_019"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "她們是阻止了妳的失控場面的恩人吧。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我都在天界看見了。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "咦！？",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_020"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳都看見了嗎！？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "……太、",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "太丟人了。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "現在還顧得上丟不丟人嗎。",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_021"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "這種事情有一就有二。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n就算拉菲是我的姊姊，",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我的等級也比妳高，",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n妳就老老實實地聽我的吧。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不要！",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_022"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n我想自己證明！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n證明我也是",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "貨真價實的幸福天使！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "唔唔唔～\n…",
        "unit_id": 1,
        "voice": "vo_adv_5106002_023"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "………",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哎呀，",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "兩個人都不肯讓步呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "什麼情況？",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n姊妹許久不見，一見面就吵架？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "……不，",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_026"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "我才不會",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "像小孩子一樣吵架。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "但是──",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "拉菲！",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_027"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n我們來比一比，",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "看誰能讓更多人感到幸福！",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_5106002_028"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "如果拉菲能贏過我的話，",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_029"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n我以後就懷著敬意",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "再用「姊姊」稱呼妳。",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "但",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "如果妳輸了……",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "妳就得吃掉",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_030"
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "\n",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "一整盤的青椒！！",
        "unit_id": 8911
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "比賽就算了，",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_031"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "但為什麼是青椒呀！？",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "艾米",
        "words": "單純想找碴而已。",
        "unit_id": 8911,
        "voice": "vo_adv_5106002_032"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "太過分了！！！！",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_033"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "但是，",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_034"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我好想再被可愛的艾米",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n喊一聲「姊姊」啊……！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "唔唔唔唔……",
        "unit_id": 5511,
        "voice": "vo_adv_5106002_035"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我明白了！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n我就接受",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "這場比賽吧！！！！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "唔唔唔～！\n……",
        "unit_id": 1,
        "voice": "vo_adv_5106002_036"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還說自己",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「不會像小孩子一樣吵架」，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但這就是",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "小孩子等級的可愛吵架呀？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_038"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們作為雙胞胎前輩，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n來讓拉菲和艾米和好吧？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然能不吵架當然是最好的……",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "總之，我們就先觀望，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "再從旁協助她們吧。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個，",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "純小姐，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有件事想請問妳。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n裝飾聖誕樹",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "需要取得許可嗎……？",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個嘛……",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我先知會地方自治會或警備兵吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n否則不了解情況的大人",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "恐怕會像我一樣上前勸阻的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "貴為團長",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_042"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還為我們想得這麼周全……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不愧是深受百姓歡迎的團長！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "別這麼說……",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n居民們的幸福",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也是我所期盼的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果有困難的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們可以隨時向我尋求幫助。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "彼此彼此啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這次你能把她們找來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是幫了大忙。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一定要讓我好好道個謝……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……對了。",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下次休假的時候，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再一起去吃個飯怎麼樣呀？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想不到能讓你這麼高興，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "幸好我有邀請你。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很期待呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我就先離開了，",
        "unit_id": 104711,
        "voice": "vo_adv_5106002_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果有什麼事",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就告訴外面的守衛吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "告辭。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝妳～♪",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_048"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_049"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n妳過來一下……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然她穿著鎧甲，",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_050"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但茜里看得出來！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "純小姐",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是一位很棒的大姐姐吧！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "他們還約好了要一起去吃飯，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是不是關係很好呀！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "…………",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_051"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n應該",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是吧……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我說得對吧！？",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_052"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……姊、",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "………………",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_053"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼～",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_054"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "原來他在純小姐的面前",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "會笑得像個小孩啊……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "在我面前的時候",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就滿",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "普通",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不過，",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_055"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "想想也是。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "畢竟我和他的關係",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是建立在遊戲上的，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "算不算得上是朋友都不好說……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_056"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還是忍不住期待了一下。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有某種特別的",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「連結」，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n只存在於",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們兩個之間。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對我來說，他是有點特別的。",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_057"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但對他來說……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我只不過是一大群人裡的其中一個……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只因為他願意主動接近我，",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_058"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我就……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "感覺",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都是我自己在一廂情願，太難為情了……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還是",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_059"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不約他了吧……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "他",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "朋友那麼多……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "搞不好都決定好要約誰了。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果只是要一起",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "玩遊戲，",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就算不約在聖誕節這天也沒關係嘛。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦～！？",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_060"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n妳剛才不還幹勁十足的嗎！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不管怎麼樣，",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_061"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現在要集中精力幫忙才行。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "去和拉菲她們討論一下接下來的事。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然對",
        "unit_id": 102212,
        "voice": "vo_adv_5106002_062"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里妳有點抱歉……",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳就和他一起等著吧。",
        "unit_id": 102212
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊……",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_063"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n放棄得也太早了吧～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唉～真拿她沒辦法。",
        "unit_id": 100611,
        "voice": "vo_adv_5106002_064"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這裡就讓茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "來助姊姊",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一臂之力吧！　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "目送著姊姊嬌小的背影逐漸遠去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茜里悄悄地下定了決心。"
    }
]