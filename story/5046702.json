[
    {
        "type": "background",
        "background": "500997"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ねずみを追い払うのにもだいぶ慣れてきたね。",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_000"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "それにしても、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なんでこんなにチーズを狙うのかな？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "チーズ以外にも食べ物はあるじゃん。",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_001"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nまっひ～には悪いけど、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ドングリとかくるみとかの方が",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nおいしいと思う。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "んー、",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_002"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "でもよく考えたらあたし、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "牧場のチーズを",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nきちんと味わったことないな。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "このチーズはお土産用だから",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_003"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "食べちゃダメだよね。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ん～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "でも",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "さっきから",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ドングリにはない",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "独特な匂いが食欲を刺激して……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なんて言うんだろう……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "生命の源みたいな感じで芳醇な……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "チーズもなかなか……",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_004"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いや！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いやいや！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nやっぱりドングリの方がいいよ！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "うん、",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "絶対ドングリの方がいい！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "ねずみ",
        "words": "ちゅ～！！"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "わっ！？　",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_005"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "また出た！！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "しかもさっきのねずみより大きい！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そんなにチーズが欲しいの？",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_006"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "余計にチーズのこと調べたくなっちゃったじゃん。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "さっさと追い払わせてもらうよ！",
        "unit_id": 102611,
        "voice": "vo_adv_5040702_007"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n覚悟してね！",
        "unit_id": 102611
    }
]