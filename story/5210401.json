[
    {
        "type": "background",
        "background": "502080"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "嗶、",
        "unit_id": 136212,
        "voice": "vo_adv_5210401_000"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "嗶咿……",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "這、",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "這樣就結束了？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n打倒了嗎？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不",
        "unit_id": 136011,
        "voice": "vo_adv_5210401_001"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "小拿，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "還沒結束。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n他會吸取別的蜘蛛的精氣，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "並再次甦醒過來……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "怎麼這樣！",
        "unit_id": 136212,
        "voice": "vo_adv_5210401_002"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "用那種像是「肚子餓了吃點心！」",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "一樣的理由復活，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n太狡猾了啦～！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 137411,
        "voice": "vo_adv_5210401_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "魔力和體力",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都看得出逐漸衰退。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我認為他已經不是能夠戰鬥的狀態了。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那、",
        "unit_id": 136011,
        "voice": "vo_adv_5210401_004"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "這樣就……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "審判長他，",
        "unit_id": 137411,
        "voice": "vo_adv_5210401_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "似乎有話想對阿剌克涅小姐說。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "直接和他對話，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "把被強加的有罪判決",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "駁回吧！",
        "unit_id": 137411
    }
]