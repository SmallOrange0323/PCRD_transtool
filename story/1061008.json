[
    {
        "type": "background",
        "background": "500840"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利脫離暈船狀態的矛依未和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有很長一段期間都在前往艾爾皮斯島的船上度過──"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔～！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就是艾爾皮斯島嗎！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n欸，{player}！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你快看那個！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有夠大的啊～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣的地方，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "會有那傢伙在確實也不意外了呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來都到了這一步，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我竟然還沒跟你解釋過嗎！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎是嗎……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說的那傢伙是蛇的魔星獸",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「瑟潘堤嘶」。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "牠照理說不會再次於阿斯特朗中現身。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但由於牠也跟這個世界一起",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被「再構築」，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以我……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我必須得去打倒那傢伙才行。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然我想你應該會完全聽不懂，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但那傢伙原本只存在於正式開服前的阿斯特朗裡。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在β測試版時……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還有辦法在阿斯特朗中自由使用力量，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n便曾經獨自和那傢伙對決。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "牠可是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "強得不得了啊……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "費盡一番功夫打倒牠後，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我試著調查牠的身軀，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n隨後便看見一把巨劍插在上面。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你心裡有底啦？",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是天樓霸斷劍。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n後來我得到允許可以繼續帶著它，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙便自那時開始就成了我的搭檔。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只不過因為當時的我",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "得花很大心力才能打倒瑟潘堤嘶，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n結果那傢伙最後就被冷凍了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "由於尚須進行調整，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "實裝一事就先暫緩，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "記得好像是這麼說的……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我還真沒想到留存下來的資料竟然會復活。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "簡單來說就是，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原本以為打倒的魔物復活了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且照理說",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原本要把牠調得更弱的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但因為沒有調整就被放置著，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結果直接以原本的資料再構築了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果放著不去處理那傢伙，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "整個世界都會變得很不妙。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n若牠在目前的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "阿斯特朗中開始大鬧，就糟了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這部分",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就交給身為好人的你處理吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n首先，我想一個人去和牠打看看。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就麻煩你在一旁",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "見證這一切吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……如果打我輸了，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再請大家來幫忙。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就是為此",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才會叫你一起來的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "像這種不應該出現於目前的世界、",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n屬於過往的存在，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就讓我來處理。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟我希望",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家都可以活在當下，放眼未來。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以──",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_016"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才的聲音……！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不會錯的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是那傢伙的聲音！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "是魔物……",
        "unit_id": 1411,
        "voice": "vo_adv_1061008_018"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "可惡！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "明明只差一點就抵達島嶼了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大叔！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙目前",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還在離海邊有點距離的地方！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以快趁現在",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "載我們去島上吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "喔、",
        "unit_id": 1411,
        "voice": "vo_adv_1061008_020"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "好！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我明白了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們上，{player}！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n待會戰鬥時你離遠點，否則會受傷喔！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500285"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大叔，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝謝你啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n接下來",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們會自己過去！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在我們回來前，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你千萬不能跑到船外面喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "……如果你們沒回來，我該怎麼辦啊！",
        "unit_id": 1411,
        "voice": "vo_adv_1061008_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算是死，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也會至少讓{player}成功回來的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到時候",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他就拜託你了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "好，",
        "unit_id": 1411,
        "voice": "vo_adv_1061008_025"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "交給我吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n……你們要小心啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "謝啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n好，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "出發吧！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "火速趕往魔物聲音所在方向，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和矛依未最後終於在"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n火山山麓看見了該魔物的身影。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的在……！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "牠還是老樣子很巨大啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真叫人懷念！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}，聽好了！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就算你再怎麼想幫我，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也絕對別靠近！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只會被捲進戰鬥中送掉小命而已！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你找到距離還算勉強安全的位置後，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
