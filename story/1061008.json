    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘖，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_062"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "勉強抵消攻擊就是極限了嗎……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在閃閃發光啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n喂，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你怎麼啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔哇！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_065"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你原本其實是這種模樣嗎。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這就是、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天光的……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來是這樣啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_066"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來你也很期待",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和我一起邁向的未來吧……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然如此！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_067"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就和我一起",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拯救世界吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍────！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_068"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這威力與剛才為止截然不同……！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_069"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n……那就再賞牠一記吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吃我的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最後一擊啦────！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！！！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_070"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "掰掰。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n等到確實經過調整後，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我再來陪你玩吧。",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不行了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全身都好痛……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_072"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我已經漣一步都走不動了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "麻煩你……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_073"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "帶我到在海邊的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大叔他們那裡……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我想",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他們應該很擔心才是……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}揹著用盡自己所有力量的矛依未，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n爬下了山並回到海邊。"
    },
    {
        "type": "background",
        "background": "500840"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天，在從艾爾皮斯島航行回本土陸地的船上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未正獨自一人望著大海。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唉……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_074"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有真的再次把牠打倒嗎……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "欸，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這應該是",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現實沒錯吧，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_075"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「獲得此劍之人啊。",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_076"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n當統御繁星者迷惘時，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "霸斷天樓，拯救世界吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當兇駭災厄從天而降時，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "霸斷天光，統御世界吧」……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼啊，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_077"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來你聽到啦。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才的是天樓霸斷劍的系統說明文……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我第一次拿起它時，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "腦海中就浮現了這段話。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼說，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_078"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有眼無珠……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這成語應該對吧。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n告訴我可以留著這把劍的傢伙，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n可能覺得這東西不過只是一個遊戲中的裝備而已。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但實際上，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_079"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這搞不好是這世界的神……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n米奈娃想要託付給某人的東西也說不定，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不禁有了這想法。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n她希望給予能拯救世界的英雄……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這把劍，讓其得以斬斷",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_080"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不同於阿斯特朗，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n且在天空另一邊的行星──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "地球所降下之災厄。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_081"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這東西，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n原本肯定不該由我得到。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "適合拿這傢伙的人，",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_082"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是擁有不輸給這把劍的光輝，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能大方地在太陽底下過活的耀眼傢伙。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是像{player}你們這樣的傢伙。",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_083"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我和尾狗刀不是你們那一邊的人。",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_084"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我們是生活在沒有光輝……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太陽照射不到，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有如不存在星星的夜空般的地方！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_085"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……或許確實是如此呢。",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_086"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你剛才",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說出了一句相當不錯的話喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說得也是……",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_087"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那些在看不見星星的夜空下生活的人們，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n大概會不曉得該往哪裡去才好呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……天樓霸斷劍！",
        "unit_id": 106113,
        "voice": "vo_adv_1061008_088"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你可還要繼續為我閃耀光輝啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就算是在一片漆黑的夜裡，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也要比星星更加光亮喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "矛依未帶著珍惜的神情，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n靜靜地看著散發出比以往更加強烈光芒的天樓霸斷劍。"
    }
]