[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有一天騎空團接到了一份工作，\n{player}就被吉塔叫了出來。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喂～！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這裡這裡～！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n今天",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就拜託你囉！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這一次的工作，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_001"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要去遠方的城鎮分送各種東西哦。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n只要在黃昏前到達城鎮就行了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n看這些東西的量，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "由我們兩個人背著應該就夠了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "也許途中會有什麼狀況，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n不過到時就一起努力吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "準備好的話就出發囉～！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "天氣真好呢。",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_003"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "看樣子應該不必擔心下雨了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……欸，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我有件事想要問你，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可以嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我在想你為什麼願意加入騎空團呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "連騎空艇也沒有，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "團員甚至只有我一個……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個時候我趁勢邀請你，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還以為會被拒絕呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "只要把騎空團以公會的名義向王國申請，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就能獲得支援，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n還會替我們介紹規模更大的工作。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "所以希望有一天，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我的騎空團能被承認是個公會……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過不久之前團員只有我，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "而且也沒有騎空艇，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "因此沒有人想加入騎空團……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就算這樣……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你還是加入了騎空團。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這讓我很在意，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是不是有什麼理由呢？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果有什麼緣由，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "希望你告訴我。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……可以嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "去遠方……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "為什麼？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你說記憶，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你的……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉塔在接下來的對話中，\n知道了{player}喪失了記憶。"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是這樣啊……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "願意對我說。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "買了騎空艇後，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果能在世界各地冒險，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n一定能夠在某個地方",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "找到你記憶的線索哦！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我也會一起找的，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "去找你的記憶！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "既然身為團長，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "團員有困難就得要幫上忙！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還有其他理由嗎？",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那是什麼……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有沒有人──！",
        "voice": "vo_adv_1057002_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幫幫我啊──！"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛才",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "從那邊傳來聲音……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "去看看吧！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "唉……",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_019"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "在這種誰也不會經過的地方……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n該怎麼辦……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你好。",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請問怎麼了嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "喔喔……！",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_021"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "太好了，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "終於有人經過了……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我原本在運送貨物，要去前方的城鎮，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "運氣不好遇到了魔物。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n受到驚嚇的馬，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "拋下馬車就逃掉了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "雖然拚了命趕走魔物，",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_022"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n不過這下馬車也動彈不得了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n整個就是無計可施……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "啊哈哈。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是這樣啊……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "欸，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們能不能幫助這個人呢？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那個……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "讓我們來幫你吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "真的嗎！？",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_025"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "但是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你們看起來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "不是也在工作的途中嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n這樣會給你們添麻煩……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "唔……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_026"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "確實是這樣沒錯……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "要是無視有困難的人，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n就不能成為獨當一面的騎空士了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我先回到蘭德索爾，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_027"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "借一匹馬再過來。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我回來之前他會保護你的，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請放心。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "騎空士……！",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_028"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "沒想到會在陸地上遇到騎空士呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "抱歉，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "就拜託你們了……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好的！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_029"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那麼我去去就回！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你也要小心點哦！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後過了不久，\n吉塔平安無事地從蘭德索爾帶了馬匹回來。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喂～！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_030"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我回來了～！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那個女孩回來了！",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_031"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "而且還帶著馬……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "讓你們久等了！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_032"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "總算有人願意出借馬匹，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n這種即使遇上魔物也不會逃跑的悍馬，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "實在是很難找到……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳還考慮到了那點嗎……！",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_033"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "謝謝！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "真是謝謝妳！！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不會，沒什麼……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_034"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你們這邊都沒事嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "魔物雖然沒有出現，",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_035"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n但他還是毫不怠慢地替我警戒呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "多虧了他，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "讓我能放心等妳回來喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是這樣啊……",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "太好了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "既然順利替你準備好馬匹，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們也該告辭……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "請等一下。",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_037"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你們預定要去哪裡？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想想，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_038"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "到高山的附近。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "得在日落前去那裡投遞貨物。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "如果是那裡，我正好會經過附近。",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_039"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "兩位，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "請上馬車吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我也一起把你們的貨物載過去吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可以嗎？",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_040"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "這一點小忙，",
        "unit_id": 1411,
        "voice": "vo_adv_1057002_041"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "比起你們為我做的算不了什麼！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "趕緊出發吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好的！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_042"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那就麻煩你了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……太好了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "果然幫助人就會有好報呢！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500211"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "辛苦你了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_043"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "今天很累人呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n能在日落前分送完成真是太好了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "而且還幫助了那個人！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "後來借到的馬也很會走山路，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_044"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "一下馬車就到了目的地，嚇了我一跳呢──",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……所有事情都平安完成，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真是太好了。",
        "unit_id": 105711
    },
    {
        "type": "still",
        "still": "105700201"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……這裡呢，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_045"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是我珍藏的地方哦。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n每當夕陽落下，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "在暗下來的夜空裡看到閃耀的星光時，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我都會這麼想……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如果乘坐騎空艇朝那顆星星飛去，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_046"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n能抵達什麼樣的地方呢……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_047"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "在遇到那個商人之前，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還記得我們的談話嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n你說你會加入騎空團，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "還有另外一個理由。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……能告訴我嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我的……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_048"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……謝謝！",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_049"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "竟然因為這個理由加入騎空團……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你真是一個",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "非常溫柔的人呢！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過真的好嗎……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_050"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我完全沒有能為了你……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "吶，這樣好了？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我把找回你的記憶當目標。",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_051"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n而你呢，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "則是幫我成為像父親一樣的騎空士。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "從今以後互相扶持、",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "互相幫助吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這麼一來，我想一定會像今天一樣，",
        "unit_id": 105711,
        "voice": "vo_adv_1057002_052"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "又會發生什麼好事的！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你也是……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "這麼想的對吧？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}面對在夕陽餘暉中微笑的吉塔，\n用力地點了點頭。"
    }
]