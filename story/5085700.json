[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙開始沉睡不醒後，",
        "unit_id": 106012,
        "voice": "vo_adv_5085700_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不曉得也經過多久了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "關於他的傳聞似乎已傳遍鎮上。",
        "unit_id": 106412,
        "voice": "vo_adv_5085700_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n走在路上，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "老是會被詢問到他的狀況。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想見主人、",
        "unit_id": 105913,
        "voice": "vo_adv_5085700_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至少看個一眼也好──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天也有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "許多這樣想的人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "預定前來探視。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來得快點把他給叫醒哪。",
        "unit_id": 106012,
        "voice": "vo_adv_5085700_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再這樣下去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想見他的人全部成群結隊跑來，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們的公會小屋恐怕會被擠爆啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我覺得",
        "unit_id": 106412,
        "voice": "vo_adv_5085700_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該沒有那麼誇張吧……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開玩笑啦，",
        "unit_id": 106012,
        "voice": "vo_adv_5085700_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "開玩笑。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從今天開始我們要認真採取對策，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n來把這個瞌睡蟲給叫醒！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105913,
        "voice": "vo_adv_5085700_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓主人醒過來……！",
        "unit_id": 105913
    }
]