    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135912,
        "voice": "vo_adv_2211001_059"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我說啊，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雪野。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "比方說──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n我會知道妳是什麼樣的人，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是因為我們認識很久了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不過，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "一般來說陌生人的本性，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不把他們逼到絕境是看不出來的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "嗚……",
        "unit_id": 135812,
        "voice": "vo_adv_2211001_060"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n那……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那麼，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "該怎麼做……？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "無論是好是壞，",
        "unit_id": 135912,
        "voice": "vo_adv_2211001_061"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n對於跑進自己地盤的人，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就要讓他們切身了解到──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "「惹到這群人可不是受點傷就可以解決的」",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這件事。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "嗚……",
        "unit_id": 135812,
        "voice": "vo_adv_2211001_062"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……",
        "unit_id": 135912,
        "voice": "vo_adv_2211001_063"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這陣子，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "總覺得情勢不太對勁。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不只是公主，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雪野──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n妳也要",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "稍微打起精神來才行。",
        "unit_id": 135912
    },
    {
        "type": "background",
        "background": "502410"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "……對、",
        "unit_id": 135812,
        "voice": "vo_adv_2211001_064"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對不起喔。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n直到抵達剎鬼她們那邊為止，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "都不能夠鬆綁呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不會讓妳們受傷的，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "忍、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "忍耐一下吧。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "真可惜。",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘖……！",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還想說這傢伙看起來很好說話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要她稍微鬆綁",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就馬上逃走的……！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "真、",
        "unit_id": 135812,
        "voice": "vo_adv_2211001_067"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "真的",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "很抱歉呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "啊，",
        "unit_id": 135812,
        "voice": "vo_adv_2211001_068"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對了。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳們",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "肚子餓了吧？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n從剛剛開始，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "肚子就一直在咕嚕咕嚕地叫……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "肚子扁扁。",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_069"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n被發現了。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "等、",
        "unit_id": 135812,
        "voice": "vo_adv_2211001_070"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "等一下喔。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n儂、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂現在去",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "拿一點食物過來。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "…………",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走掉了嗎。",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸普蕾西亞。",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_073"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還搞不清楚狀況。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過在我醒來之前，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有和雪野稍微聊過了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是什麼地方？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "吉歐‧尼布爾黑爾。",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_074"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n冥河。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n馬車裡面，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "的樣子。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……姑且是有成功抵達",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_075"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吉歐‧尼布爾黑爾嗎。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然和大家失散了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "糰──",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_076"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n擔心。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊！",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_077"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙受了傷……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不如說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "牠還活著嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會不會已經凍死，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是被魔物吃掉了？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "（嗅嗅）",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_078"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "目前，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "沒問題。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n就在，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "附近。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_079"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要趕快去救牠呢……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在我們",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被這輛馬車送去其他地方之前……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_080"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n逃跑。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說要逃跑……",
        "unit_id": 106012,
        "voice": "vo_adv_2211001_081"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那種事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果辦得到我也想啊……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要怎麼做？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為這個奇怪的繩子，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既用不了魔法，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "身體也無法動彈……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯──",
        "unit_id": 126112,
        "voice": "vo_adv_2211001_082"
    }
]