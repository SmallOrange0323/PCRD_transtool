[
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "看來妳們似乎相當珍惜彼此的樣子。",
        "unit_id": 13311,
        "voice": "vo_adv_5040321_000"
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "\n既然如此，這招如何。",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "半藏",
        "words": "喝！",
        "unit_id": 13311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "什麼什麼！？",
        "unit_id": 105211,
        "voice": "vo_adv_5040321_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n突然",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "冒出幾個和我們長得很像的傢伙耶！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "哈哈哈哈哈！　",
        "unit_id": 2511,
        "voice": "vo_adv_5040321_002"
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "這次妳們幾個真的玩完了！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "監察官",
        "words": "\n就好好後悔為什麼要反抗我吧！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們才不會因為這點小事就退讓。",
        "unit_id": 103811,
        "voice": "vo_adv_5040321_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要後悔的人",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是你才對！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且，",
        "unit_id": 112711,
        "voice": "vo_adv_5040321_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你有什麼好囂張的。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你什麼都沒做啊。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們可不會輸給一個",
        "unit_id": 112811,
        "voice": "vo_adv_5040321_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "連挺身站在前線都辦不到的傢伙！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n覺悟吧！",
        "unit_id": 112811
    }
]