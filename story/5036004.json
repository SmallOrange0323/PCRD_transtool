        "type": "dialogue",
        "name": "審查員",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "但妳們打算開演唱會對吧？",
        "unit_id": 611
    },
