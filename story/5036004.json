        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這還是世界首次同時把音樂",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n傳遞到各地的「演唱會現場直播」呢！",
