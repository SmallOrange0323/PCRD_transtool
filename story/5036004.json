        "type": "dialogue",
        "name": "審查員",
        "words": "那麼，",
        "unit_id": 611,
        "voice": "vo_adv_5036004_023"
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "妳們就用上這個音響盤吧。",
