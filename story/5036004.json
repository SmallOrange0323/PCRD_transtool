        "type": "dialogue",
        "name": "未央",
        "words": "如果沒有{player}的人望",
        "unit_id": 112611,
        "voice": "vo_adv_5036004_011"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n這些事",
        "unit_id": 112611
