    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "因為呀，",
        "unit_id": 112411,
        "voice": "vo_adv_5036004_048"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "明明不久之前的我們，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n光要在小鎮村民們面前唱歌",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n就害羞到不行呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可是現在……",
        "unit_id": 112411,
        "voice": "vo_adv_5036004_049"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我們卻竟是如此地期待，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n能讓擠滿會場的觀眾，甚至是位在遠方城鎮的觀眾們……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n都聽到我們的歌聲。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是啊。",
        "unit_id": 112511,
        "voice": "vo_adv_5036004_050"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n不過總覺得……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "在更久之前，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n我們似乎曾在更多更多人面前唱過歌。",
