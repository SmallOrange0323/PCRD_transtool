        "voice": "vo_adv_5036004_067"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "最近【美食殿堂】的大家",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "也讓我們大開眼界，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n因此吃到了好多很好吃的東西呢♪",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯——",
        "unit_id": 112511,
        "voice": "vo_adv_5036004_068"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n那，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要選什麼？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n如果說到最近吃的東西……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "格里芬的",
        "unit_id": 112611,
        "voice": "vo_adv_5036004_069"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "雞翅之類的……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "殺人蜂的",
        "unit_id": 112511,
        "voice": "vo_adv_5036004_070"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "熱炒蟲蛹之類的……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
