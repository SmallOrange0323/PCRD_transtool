        "voice": "vo_adv_5036004_051"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n真是這樣的話，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n或許我們本來是什麼超厲害的偶像也說不定呢♪",
