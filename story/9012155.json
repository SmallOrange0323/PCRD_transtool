[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個魔物，應該就是襲擊村莊糧倉的兇手了。",
        "unit_id": 106011,
        "voice": "vo_adv_9012155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來挺難搞的～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以村民們才沒辦法對付。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105911,
        "voice": "vo_adv_9012155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠正對貪吃佩可小姐那裝滿食物的包包，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n投以熱烈的視線呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【公會管理協會】都正式提出委託了，",
        "unit_id": 105911,
        "voice": "vo_adv_9012155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n肯定是幹了很多壞事吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "襲擊糧倉，",
        "unit_id": 105811,
        "voice": "vo_adv_9012155_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種壞事絕對不能饒恕！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所謂的美食，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是要用來跟大家一起分享，\n而不是用搶奪的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就讓我來告訴你這個道理！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且你……",
        "unit_id": 105811,
        "voice": "vo_adv_9012155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居然還敢覬覦我的食物……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼好像帶入了私人怨恨……",
        "unit_id": 106011,
        "voice": "vo_adv_9012155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來吧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該解決牠了！",
        "unit_id": 106011
    }
]