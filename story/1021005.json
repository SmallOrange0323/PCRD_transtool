[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今、今天要一個人看家……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽跟鈴莓姐，都因為工作而出門了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音也是每個星期",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "固定在這天好像有什麼事情，\n不知道跑去哪裡……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "其他人也都不在，我、我要……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n好好看守【咲戀育幼院】……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個是我的任務，絕對不讓給別人……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然這麼說，不過就是看家……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一直乖乖待在這裡也是挺閒的……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐已經做好三餐放著了，",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "家事的話，鈴莓姐也是全部做完了才出門……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n沒什麼特別需要打掃的地方呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然這麼說，但因為是看家，",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以也不可以跑到外面玩……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "早知道就準備些可以在室內打發時間的東西了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音就算在房間裡，",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也可以一個人玩得很開心的樣子……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很擅長打發時間呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得我，好像太閒了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "乾脆來看點書吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也被咲戀媽媽交代過，",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n藏書庫的書可以隨時都拿來看……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我記得，好像有看起來很有趣、頁數好多的長篇小說……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噫呀！？",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "什、什什、什什什……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n好像，有什麼聲音……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有、有奇怪的聲音……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好可怕……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我果然，沒辦法一個人看家……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚。",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，該不會是門鈴的聲音……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n應該是有人來了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個那個，這個時候該怎麼辦呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果有咲戀媽媽等人以外的陌生人來，",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我記得好像被交代過，不可以打開玄關的門……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，如果是郵件的話好像應該要領一下……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我就偷偷的，看一下外面的狀況吧……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果看起來不像是送郵件的人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就假裝沒人在就好了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、咦？",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n該不會是，{player}哥哥……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，我現在就開門……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為哥哥不是陌生人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以開門應該沒關係吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n歡、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "歡迎來到【咲戀育幼院】……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天來這裡，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有什麼事嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，咲戀媽媽她們現在出門了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果是送郵件過來的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n蓋章就由我負責……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥是被咲戀媽媽拜託，來看看我的狀況嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥認識咲戀媽媽嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我還以為哥哥是只我有才認識，",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只屬於我的哥哥……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，沒什麼……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃，既然這樣的話就請進吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻。",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我一個人覺得很無聊，哥哥要不要一起來玩呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥可以陪我一起打發時間的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我會很開心……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "耶～哥哥幹勁十足呢……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那要做什麼呢？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "大人都玩些什麼呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "應、應該不會玩玩具吧……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為不是小孩子了嘛，嗯……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不要摸我的頭嘛……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻。",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但是哥哥誇獎我，我好開心……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為我一個人有點不安，幸好哥哥來了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……我就先去準備茶水之類的東西唷……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥就請在那裡坐著休息……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我會好好招待哥哥的唷……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻嘻。因為我幾乎沒有什麼認識的人……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n能招待客人感覺很新鮮，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n心裡有點興奮呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚！？",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、哥哥為什麼要緊跟過來……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥就休、休息就好了唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，哥哥「得好好確認我的狀況才行」是嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥不用從這、這麼近的距離，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一直目不轉睛地盯著我也沒關係啦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、不要一直看著我嘛……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我很不習慣，被盯著看……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真是的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021005_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，真令人傷腦筋呢……♪",
        "unit_id": 102111
    }
]