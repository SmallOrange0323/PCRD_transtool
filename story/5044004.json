    {
        "type": "dialogue",
        "name": "織女",
        "words": "那個，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我該怎麼自稱，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "聽起來才會很帥氣呢……！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔姆，",
        "unit_id": 113211,
        "voice": "vo_adv_5044004_059"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "想口號也是個重要功課呢。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好吧！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就讓我",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "親自傳授妳一些祕訣吧！！",
        "unit_id": 113211
    },
    {
        "type": "background",
        "background": "501050"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "吾名為織女。",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_060"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "乃受「銀河」所引導，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "宿星之星姬！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦哦哦哦，",
        "unit_id": 113211,
        "voice": "vo_adv_5044004_061"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這不是很有氣勢嗎！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n妳有意願的話，",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我可以讓妳加入熾炎戰鬼煉獄血盟暗黑團喔！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "此話當真！？",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_062"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n沒想到",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我竟然擁有這樣的天賦……！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳果然是有",
        "unit_id": 113211,
        "voice": "vo_adv_5044004_063"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "「資質」的人啊。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我沒有看走眼！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "聽見內心的聲音後",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感覺如何啊？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "感覺非常好……",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_064"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "就像妳說的，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我的確覺得很悔恨！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n為牛郎對我視若無睹的",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "那個態度感到悔恨！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "杏奈大人。",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_065"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "在聽了妳的話之後我下定決心了。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n現在，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "就讓我們前往決戰之地吧！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "織女！",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_066"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n妳能停止哭泣真是太好了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "打起精神了嗎？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "是的，",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_067"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "流夏大人。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "多虧疾風之冥姬‧杏奈大人的一番話，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n讓我明白了我必須完成的使命。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……呃，",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_068"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "總之妳能恢復精神",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是太好了。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然說話方式好像有點奇怪……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我有一事想詢問各位。",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_069"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n請問各位有聽過「自我」所發出的",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "內心之聲嗎？",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_070"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": " 那是",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼意思──",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "當然聽過呀，",
        "unit_id": 113311,
        "voice": "vo_adv_5044004_071"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小織女！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n應該說在下我",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都快聽到膩了。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "人本來就該聽從內心的聲音嘛！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "原來如此。",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_072"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "真不愧是杏奈大人的同伴。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不過妳剛剛說的",
        "unit_id": 113211,
        "voice": "vo_adv_5044004_073"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是指什麼意思？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "意思是，",
        "unit_id": 113311,
        "voice": "vo_adv_5044004_074"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "發現想要的東西就一定要弄到手☆",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "方才",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_075"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "讓各位見到了我的醜態，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "真的非常抱歉。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "不過，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我已經被各位的話點醒了。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我",
        "unit_id": 4811,
        "voice": "vo_adv_5044004_076"
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "不能讓事情就這樣結束。",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n我要解決和牛郎之間的問題，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "讓七夕祭順利舉辦！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "\n",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "身為受「銀河」引導的宿星之星姬，",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "織女",
        "words": "我以此名義起誓！",
        "unit_id": 4811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼哼哼，",
        "unit_id": 113211,
        "voice": "vo_adv_5044004_077"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不錯不錯！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": " 就該有這種氣魄！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n身為疾風之冥姬的我",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也絕對不能輸給妳！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀～",
        "unit_id": 113311,
        "voice": "vo_adv_5044004_078"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這還真是個有趣的發展呢～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳看，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳是不是也覺得",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還好有把這件事交給我們呢？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……是啊，",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_079"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說得沒錯呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我說不定不知不覺中，",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_080"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一直把杏奈和七七香",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當成孩子看待了呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說實話，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我原本沒有期待妳們",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能想出什麼可行的辦法。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "人人各有所長……",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_081"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我竟然忘記了這麼理所當然的事，",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真慚愧啊。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來，",
        "unit_id": 113111,
        "voice": "vo_adv_5044004_082"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這次的騷動交給她們兩個解決比較好呢。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而我",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也會在我能力所及的範圍內提供幫助。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與在杏奈的活躍表現下振作起來的織女，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次為了解決問題而展開了行動。"
    }
]