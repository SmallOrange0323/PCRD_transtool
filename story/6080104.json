[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "しばらく会っていなかった間に",
        "unit_id": 113111,
        "voice": "vo_adv_6044104_000"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "何をしてたか聞きたい？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "別に、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そこまで面白い話はないと思うんだけどねぇ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "で、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "誰の話が聞きたいんだい？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アタシは",
        "unit_id": 113111,
        "voice": "vo_adv_6044104_001"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ファントムキャッツとやりあったくらいだね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "動きが素早くて捉えづらかったし、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "厄介な相手だったよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いつかまた会う機会があれば、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "正面からやりあってみたいもんだね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "相も変わらず魔導書を集め回ってたよ。",
        "unit_id": 113111,
        "voice": "vo_adv_6044104_002"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "変な魔法を開発するのは",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nいいんだけどさ、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "人を実験台にしようとするのは",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "勘弁してほしいよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "変身魔法とか言って",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "あの服装に変えられたときは……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いやなんでもない。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "アンナは、",
        "unit_id": 113111,
        "voice": "vo_adv_6044104_003"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "最近輪をかけて",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "魔法を放つ前の言葉が",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "長くなってる気が",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nするんだよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "時間が掛かりすぎて敵に避けられてるし、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ほどほどが",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\nありがたいんだけど……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "本人は満足そうだから、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そっとしてるよ。",
        "unit_id": 113111
    }
]