    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我聽說霞是在當偵探……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "請問那是在做些什麼樣的工作呢？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼樣的工作……",
        "unit_id": 101411,
        "voice": "vo_adv_5012600_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔嗯～",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "該怎麼說明才好呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會像剛才那樣子",
        "unit_id": 101411,
        "voice": "vo_adv_5012600_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "尾隨著助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後從其中獲得的情報",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來推理造成這次騷動的犯人……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個，",
        "unit_id": 104311,
        "voice": "vo_adv_5012600_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳叫做步未對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳從剛才就在盯著什麼看啊？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔欸！？",
        "unit_id": 105511,
        "voice": "vo_adv_5012600_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我我我、我並沒有在看什麼，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我不知道！！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 101411,
        "voice": "vo_adv_5012600_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之，妳對偵探有興趣對吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "步未。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 101411,
        "voice": "vo_adv_5012600_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "跟著我就行了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就來教妳什麼是偵探吧！",
        "unit_id": 101411
    }
]