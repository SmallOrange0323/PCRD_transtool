    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唉……",
        "unit_id": 122211,
        "voice": "vo_adv_6094103_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好累喔。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "露營比我想的還辛苦呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n從搭帳篷開始到砍柴，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後是生火，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "有好多事情要做。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果是習慣冒險的他……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是不是就不會覺得這些事情很棘手呢？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他會那麼說嗎？",
        "unit_id": 122211,
        "voice": "vo_adv_6094103_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他真的有許多很可靠的地方……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就算如此，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我一直扯後腿還是會讓人反感吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……好，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我就趁現在讓自己變能幹一點吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 122211,
        "voice": "vo_adv_6094103_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果是溫柔的他，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就會那麼說吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……那麼！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也不能總是沉浸在疲累中，要做出改變才行！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在下次造訪露營區之前好好學習就可以了吧？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在結果不錯就好！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才……",
        "unit_id": 122211,
        "voice": "vo_adv_6094103_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "才沒有那種事喔？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "大姐姐我怎麼可能會",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "笨手笨腳的呢！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……嚇！",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "明明就沒有人在，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我幹嘛用力澄清……？",
        "unit_id": 122211
    }
]