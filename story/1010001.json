[
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼、呼……♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼哈。",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n什麼呀？不要搖人家呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家正睡得正舒服呢～……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……呼哈、呼♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "早安♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n哪位呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n抱歉呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家常被說講的話很難懂。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可能聽起來讓人覺得有點奇怪，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過這是很久以前獸人王國使用的官方語言。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在現代已經",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒什麼人會這樣說話就是了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但也沒辦法，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為人家是公主～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n得要好好重視各項傳統♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "發生什麼事？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家沒辦法動。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡好暗，人家沒辦法看清楚。",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n現在是在馬車裡面嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n正在被送往某個地方的途中？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說起來……",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家該不會是被綁起來了吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n怎麼會這樣？繩子綁住身體好痛喔～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您也被綁住了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好可憐……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n為什麼會變成這麼奇怪的狀況呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您知道怎麼回事嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的猜測是～",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n壞人知道了人家是某個國家的公主，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n然後就來誘拐人家了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "或者是，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n某個女王想奪走人家的性命之類的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵。",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好像童話故事一樣～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家很憧憬這種事呢……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您也",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n跟人家一樣被綁起來的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也就是說您是某個國家的王子囉？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是說，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您是來拯救公主但被抓住的騎士呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是可憐……",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您為了救人家而冒死對抗，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "卻因為力不從心而被囚禁了起來。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家很高興您的這份心意……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不要緊的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在繪本裡面，不管發生什麼事，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n公主和王子",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都會克服所有的困難……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最後",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n會一起過著幸福快樂的日子。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可喜可賀，可喜可賀……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說呢，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n反正吉人自有天相。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n好像開始覺得很想睡……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可以讓人家稍微睡一下嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "晚安了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不要搖人家嘛～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "本來在馬車裡面",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就感覺很容易暈車了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n拜託呀，人家會想吐的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是看起來",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n您的長相就是個王子呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "應該只是您自己不知道而已，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n其實您是某個地方的王子吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家總覺得",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就是那樣呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔法師的第六感可是很準的～王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然咱們現在是",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像貨物一樣被運送的平凡少年少女……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但說不定其實咱們的存在有特別的意義呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們在上輩子……",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n說不定",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真的是公主和王子呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在只是",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n彼此都忘記了而已♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生、王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "轉到後面去一下。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n繩子那麼緊，應該很痛吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家用魔法來趕走王子先生的痛痛吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然人家",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不是那麼擅長復原魔法。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但還是能幫忙止痛的唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生說用魔法應該",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可以切斷繩子逃出去……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生真是聰明啊♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對耶～人家都沒想到。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n嗯，那樣子比較快解決問題。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是……",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家不太擅長控制魔法的強弱。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不只是繩子，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n搞不好會把王子先生整個人都吹飛喔？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那樣的話就太抱歉了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸，凡事都要挑戰一下？",
