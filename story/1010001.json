    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生說得真好，太帥氣了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好勇敢喔，人家會愛上王子先生的……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說不定",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生真的就是人家命中註定的王子……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n如果是命中註定的話，人家就放心了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在和人家成為伴侶之前，王子先生是不會死的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔法成功之後，",
        "unit_id": 101011,
        "voice": "vo_adv_1010001_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我們兩個人就能一起手牽手逃出去的♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣的話，",
