    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "將情感",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "和心聲傳達給我。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哦～",
        "unit_id": 102211,
        "voice": "vo_adv_5048007_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有人能監督妳了呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這樣一來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳就無法隨便亂用魔法囉。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "是的，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_032"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我會在這孩子的協助下，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n學會掌控我的力量！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "所以首先，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_033"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "要把我們感謝的心情",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "傳達給妳們兩位。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦，",
        "unit_id": 102211,
        "voice": "vo_adv_5048007_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "給我等等，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說是感謝，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為什麼要把弓箭對準我們？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說這個橋段，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "之前也發生過吧！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "現在的我已經和當時不一樣了……",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_035"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "大概！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這不是完全一樣嗎！",
        "unit_id": 102211,
        "voice": "vo_adv_5048007_036"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呀啊啊──！",
        "unit_id": 1,
        "voice": "vo_adv_5048007_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚嗚，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個循環要重複多少次啦……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "又變成這副模樣了！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "請放心，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_039"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我只是改變了衣服外觀而已。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n這孩子也說，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "魔法施展得很順利而感到開心呢。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "姑且算是能好好和它溝通了呢。",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不說這個了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳那突然對別人施魔法的壞習慣",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就不能改改嘛。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸嘿嘿，",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_041"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我倒是覺得有點高興呢。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為這套衣服",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "超級可愛呀♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "依里和茜里，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_042"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n妳們擁有著",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "不輸天使魔法的美好心靈。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "請兩位運用這份力量，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_043"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n讓蘭德索爾的大家",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "變得幸福起來吧！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "那麼，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_044"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我就先告辭了。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n真的很感謝",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "妳們的照顧。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦，",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_045"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳要走了嗎？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "騷動也解決了，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n不必這麼急著走吧……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "雖然我也很想和兩位多說些話，",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_046"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "但我不是來玩的，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "沒有時間慢慢來。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣啊……",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_047"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還會再見面吧？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "是的！",
        "unit_id": 5511,
        "voice": "vo_adv_5048007_048"
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我從兩位出色的表現中，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "得到了滿滿的勇氣。",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "\n下次見面時，",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "我一定會讓兩位",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "拉菲",
        "words": "見識到有所改變的我～！",
        "unit_id": 5511
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……走遠了呢。",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_049"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她出現得很突然，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n走得也很倉促耶。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "妳覺得呢？",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_050"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……這個嘛，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_051"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我已經受夠",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那種騷動了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但我姑且還欠了",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "替我實現心願的拉菲一份人情呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "心願，",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_052"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是指互換身體的事嗎？",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "與其說是互換身體，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_053"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n倒不如說是因為遇見了她，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我才能體驗許多事。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "在線下聚中說出自己真實的想法，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_054"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或是享受音樂節，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "以及為了解決街上的混亂，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "積極行動起來。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這些事情，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_055"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "若換作是以往的我，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "肯定辦不到呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才沒有那回事呢。",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_056"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊就算現在無法辦到，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但未來某一天",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也一定能夠成功的！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝謝妳。",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_057"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許茜里說的沒錯，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但是拉菲她，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "確實給了我",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "踏出那一步的勇氣呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還有啊，茜里，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_058"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我之所以能這麼努力，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n也是多虧了有茜里在身旁支持著我喔……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝謝妳。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊……",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_059"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我也是這麼想的。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這次事件也是，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我又再次了解到，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我之所以能是現在的我，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都是因為有姊姊在身邊。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以，",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_060"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊可以更有自信一點哦。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n然後在感到迷惘時，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可以多依靠我……",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "還有哥哥一點♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里就算了，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_061"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還要依靠你？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "能解決這次的騷動",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n也有你的功勞啦，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就一點點，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_062"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就多依賴你",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那麼一點點",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼、",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_063"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "隨你高興。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "比起這個，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_064"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我現在已經踏出一步了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還想要",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "再往前",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "踏出一步。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n成為天使的話，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "或許就能辦到了吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……當然，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_065"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也是有可能",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "辦不到就是了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊……",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_066"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我知道了。",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊要成為天使的話，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那茜里也要成為天使！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜、",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_067"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里？",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為什麼",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "連妳也……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為，",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_068"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊自己一個人變得更好，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我就會被丟下了嘛！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我也要成為",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_069"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不讓姊姊蒙羞的，",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "最棒的妹妹！",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……是呢，",
        "unit_id": 113811,
        "voice": "vo_adv_5048007_070"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們兩個一起努力吧。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因為，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們是──",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "最棒的",
        "unit_id": 113711,
        "voice": "vo_adv_5048007_071"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雙胞胎呀♪",
        "unit_id": 113711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依里和茜里手牽著手望著向晚的天空，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回味這漫長的一天。"
    }
]