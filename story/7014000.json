    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了尋找遺失的記憶的線索，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和美咲"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一同來到了露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們到了呢，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來這就是露娜之塔啊……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來吧，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "趕快護送我過去吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這不就是你的使命嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說笑的～。",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就算我這麼說，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就憑你應該也做不好吧。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就由我來教你要怎麼做。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你可要好好跟緊了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哼哼，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只要交給我就萬事大吉！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你可要仔細看清楚",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我大顯身手的模樣囉！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n那麼我們就馬上，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "前往塔中……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那裡是不是有人在？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n沒想到竟然會有人在這種地方……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊、",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來了來了！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n在這邊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是，",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "因為",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想預先來這裡探勘一下。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "剛剛才結束，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你來得正好呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實我已經不太記得當時約我來的情況了，",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n只是依稀記得集合的時間而已……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "既然",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "已經發下豪語說請放心交給我，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也不想讓人看到我散漫的樣子……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哼……",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "原來你還找了其他人啊。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你的意思是說光靠我一個人你不放心是吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀……",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳好，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我是優花梨。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n目前在【墨丘利財團】擔任會計。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n以前曾是聖騎士，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以在防守跟回復的部分我應該能幫得上忙。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸、",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是美咲。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "別看我外表這樣，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可是個成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳可不要小看我喔。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我知道了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我本來以為今天就只有我跟{player}兩人，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n美咲妳也同行讓我覺得很安心呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "今天要請妳多多指教囉。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那當然，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "交給我吧。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你們可要跟緊喔。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說這個人……",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "剛剛好像說自己叫做優花梨小姐……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且【墨丘利財團】",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是連我都聽過的\n有名公會呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不僅在那裡擔任會計",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還曾經是聖騎士……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身上的頭銜還真不得了……！　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對於初次見面的我也能夠很自然的做面子給我，這種沉穩的氣質……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "給人一種非常高雅的成熟女性的感覺呢……！　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然和伊緒不同類型……",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過這種不論什麼事情都能夠輕鬆解決的感覺，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真有點帥氣……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……？",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n怎麼了，美咲？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳怎麼一直盯著我的臉看……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "難不成我臉上有沾到什麼東西嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒、",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒事！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我只是覺得，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "同為",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟的淑女",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好像有什麼彼此互相吸引的地方……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總之，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天要請妳多多指教！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好的。",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那我們就趕快進到塔中看看吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "感覺很信任我呢，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是太好了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了不要辜負美咲對我的期待，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我今天也要好好加油！　",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來吧，",
        "unit_id": 105011,
        "voice": "vo_adv_7014000_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "趕快出發囉！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好的，",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我現在就過去！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "來，",
        "unit_id": 103411,
        "voice": "vo_adv_7014000_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "出發吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們要找到",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "{player}記憶的線索才行呢！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，美咲、優花梨還有{player}3人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前進露娜之塔開始了他們的探索之旅。"
    }
