    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，",
        "unit_id": 135111,
        "voice": "vo_adv_5206051_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒事，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "什麼都沒有。",
