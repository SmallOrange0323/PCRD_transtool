    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳有什麼好主意嗎？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n像是調查異變的魔法……",
