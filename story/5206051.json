        "voice": "vo_adv_5206051_007"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "虎嚥狼吞。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n醃章魚，",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "一口吞。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n金槍鮪，",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "新鮮生吞。",
        "unit_id": 135211
