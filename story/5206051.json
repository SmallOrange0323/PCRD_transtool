        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在比起泳裝，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個海灘的事情更重要呢。",
        "unit_id": 135111
    },
