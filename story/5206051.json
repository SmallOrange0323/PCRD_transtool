        "type": "dialogue",
        "name": "雪菲",
        "words": "然後，",
        "unit_id": 135111,
        "voice": "vo_adv_5206051_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然來到傳聞中",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「實現願望的海岸」，",
