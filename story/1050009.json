    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……哼。",
        "unit_id": 1,
        "voice": "vo_adv_1050009_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n原本以為能當作參考的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "結果聽了真令人失望。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_038"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼人！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "我無意偷聽。",
        "unit_id": 5411,
        "voice": "vo_adv_1050009_039"
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "\n我在這裡看書，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "是妳們自己走過來的。",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……長、",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_040"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "長得滿可愛的嘛。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過對第一次見面的人",
