    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "偶爾跟你約會也不錯！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你會帶我去時髦的地方對吧♪",
