        "voice": "vo_adv_1050009_041"
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "抱歉。",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "我無意找碴。",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "對了……",
