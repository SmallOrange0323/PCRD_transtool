    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "聽妳剛才說的話，",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "其他學校的女生",
        "words": "\n只要看雜誌就能成為成熟的淑女，這是真的嗎？",
