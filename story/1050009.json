        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我接下來要和媽媽一起去購物！！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "我待會也有事情……",
        "unit_id": 415,
        "voice": "vo_adv_1050009_048"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "所以，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "我看今天就散會好了。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "\n那麼，",
