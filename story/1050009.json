        "voice": "vo_adv_1050009_046"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是什麼話！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n妳想說我不是成熟的淑女嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "別、",
        "unit_id": 211,
        "voice": "vo_adv_1050009_047"
    },
    {
