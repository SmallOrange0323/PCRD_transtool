    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "每天都會去書店查看雜誌，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "\n跟店員交流資訊，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "很認真學習呢。",
