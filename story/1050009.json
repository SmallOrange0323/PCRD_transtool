    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒、",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒什麼！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟的淑女也有各種情況啦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n好了，別管我！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你真的打算走掉！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "淑女陷入沮喪了耶！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這時候溫柔的陪伴她，才是紳士的應對方式吧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "開玩笑的！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n也就是說，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是大人的策略！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好奸詐！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "大人果然很奸詐！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果你是紳士，請以更聰明的方式吸引淑女的注意！",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n總有些方法吧！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………不行嗎？",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也不是",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一直都跟朋友在一起。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要說的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那只是大家自己黏著我而已。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "直到不久之前……",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "她們也",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "非常高興地聽著我說話。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n如果沒發生那種事，現在也還會……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "別提這個了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總之，",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是作為獨立的成熟淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n主動選擇一人獨處的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………你有",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "意見嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟我一起……？",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也就是說，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是約會的邀請……？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好、",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n反正我今天碰巧",
