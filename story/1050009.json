    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……事情就是這樣，",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_051"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n聽到別人說我看起來不像成熟的淑女……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我有點沮喪。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我認為自己是",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_052"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但大家並不這樣認為嗎……？",
