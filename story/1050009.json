        "voice": "vo_adv_1050009_054"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不是前陣子伊緒分發的",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n「工作體驗學習」通知單嗎。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那張紙怎麼了？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……喔──",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_055"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總之，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你要我試著去有成熟淑女的職場",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "工作看看？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是這個主意！",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_056"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我決定採用了！",
