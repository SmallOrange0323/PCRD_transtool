        "type": "dialogue",
        "name": "美咲",
        "words": "時髦",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "又受歡迎，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n受到大家的尊敬這樣……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯、",
        "unit_id": 105011,
        "voice": "vo_adv_1050009_036"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯～",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想想……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
