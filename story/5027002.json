        "voice": "vo_adv_5027002_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "像她這樣的人，加入幫派實在太可惜了！",
