        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n真的是",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]各種大小事都受你關照……",
