[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和惠理子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了露娜之塔的入口前。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "小心腳邊哦。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n因為這附近",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "爬滿了樹根……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果您被勾到而絆倒的話……",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那我就得把那礙事的樹根",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "連整棵樹都砍掉才行。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來這就是露娜之塔……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就是您的記憶沉睡的地方呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您的記憶",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n惠理子我一定會幫您找回來的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "等找回所有的記憶之後，",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n在您身旁和您最親近的",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就是惠理子我。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "集您的寵愛於一身的人",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就會是我……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才沒有那種事情。",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您知道",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "街坊中是怎麼稱呼我的吧？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "『破壞者』……",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然是個不怎麼可愛的名字，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但這令人懼怕的稱呼可不只是裝飾哦……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我惠理子一定會",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "保護您的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也確實把",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在來路途中遇到的魔物\n全都解決的一乾二淨了，對吧？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這附近",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n只有您和我的氣息。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "敢來打擾您和我之間",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "獨處時光的不識相傢伙，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我會把他粉碎得稀巴爛……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來，走吧，",
        "unit_id": 102711,
        "voice": "vo_adv_7012000_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大人。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是{player}和惠理子走進了塔裡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是他們身後，還有另一個人影。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_7012000_012"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……原來這裡",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就是露娜之塔呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "據說裡面有著找回前輩記憶的線索……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "得記下才行。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩筆記。",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n今天的前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像要去探索露娜之塔。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了找回自己的記憶，",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "竟然要爬上如此高聳的巨塔。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩果然很帥氣呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "昨天外出買的",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "5個療傷藥和乾糧，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n好像就是為了這趟探索而準備的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩比平常還要早睡",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一定也是為了調適好身體狀況。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和前輩在一起的女性",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_018"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像是叫做惠理子。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "她非常地強大，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "戰鬥時也會一直顧慮著前輩。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是個美女，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "而且好像是個很溫柔的女性。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "欸嘿嘿。",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我最近開始記錄前輩的筆記了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只要有這個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "碰巧遇見前輩時，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就不愁沒有話題了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為我這個人",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_020"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總是會很緊張，沒辦法和前輩好好談話呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果能看著這個筆記說話，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一定能和前輩聊很多很多事情的。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊，",
        "unit_id": 105511,
        "voice": "vo_adv_7012000_021"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "糟糕！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n要跟丟前輩了。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也得快點進去才行……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "追在{player}和惠理子身後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n步未也走進了露娜之塔。"
    }
]