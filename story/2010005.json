[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時光飛逝，終於迎來了貪吃佩可救援作戰的實行日。\n蘭德索爾的街道上，如同預期舉辦著一場盛大的祭典。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管早有料想過了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是只能用恐怖來形容的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人山人海呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了避免走散，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把手牽起來吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不小心走失了可就糟糕了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了成功救出貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是最重要的一環。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不能有一絲絲的大意。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太過於緊張也不是好事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "舉止可疑反倒會變得過於顯眼，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會有被警備著的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【王宮騎士團】",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n給盯上的可能性。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盡可能的保持自然，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "表現出悠閒地享受著這場祭典",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的感覺吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果能以愉快的心情和主人一同享受這場祭典，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該有多麼幸福呀……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是打從心底這麼想的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過。",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這一切，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都只能等到救出了貪吃佩可小姐以後再說了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "祭典進行的日程，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貌似總共有五天……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萬事",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "皆大吉以後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該還有機會一同享受祭典吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到時候",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就和貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以的話",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也和凱留小姐一起……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想和【美食殿堂】的大家，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "充分地度過美好的時光呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是懷抱著這麼簡單的願望，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為並非什麼罪過才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請看那個攤販，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正在販賣著可麗餅。",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與在下等人一同行動的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【拉比林斯】的各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎說好了要相約於可麗餅的攤販處呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被通緝的各位",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了混淆追兵，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以才小心地不斷變換停留的位置……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法明確知道大家現在的所在位置就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抵達了可麗餅的攤販處後，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再說出暗號會合，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是預定好的流程。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在事前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "藉由在下的傳信鴉",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接收到了這樣的通知。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這方法稍顯繁複，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果弄個不好，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n很可能遲遲無法會合",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而浪費了時間，所以在下一直相當不安。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也很有可能，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "輕易地就被敵人看穿了在下等人的計畫也說不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此還是以不會使人起疑的程度，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n趕緊前往那個攤販吧……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "……。",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦呀？ ",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在攤販中販賣可麗餅的店員，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是曾照過面的『拉比林斯』成員……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的樣子？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟與那幾位，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也並非說是有多麼的熟稔呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n稍微無法確信就是呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n搞不好，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡是毫無關係的攤販也說不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以免萬一，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是說說看暗語吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蒜蒜",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "豬豬油油",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "增量……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可麗餅，可以幫在下做一份嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "啊，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_022"
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "太好了！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "好好地把暗號說出來了耶～♪",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "等你們很久囉！",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_023"
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "真是的……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "因為祭典的關係大家花錢都不手軟的啊？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "從一大早客人就絡繹不絕排得滿滿的唷！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "連個喘息的機會都沒有，就得要一直烤餅皮又放配菜的，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_024"
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "真的是忙翻天了啦～！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "不過，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_025"
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "在見到{player}了以後就又有精神了！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可麗餅店老闆",
        "words": "姐姐之力填充完畢～☆",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是『拉比林斯』的靜流小姐對嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與平時的打扮相去甚遠，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一瞬間認不出您來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哎唷，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可別講出人家的名字了唷？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們呀，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在可是被通緝了呢……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "噓～♪",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿。",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個打扮嚇了妳們一跳吧？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n稍微試著變裝了一下呢。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我的長相早就被敵人知道了。",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果還照著以前的打扮的話，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "馬上就出局了嘛。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實如您所說的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有變裝的必要也說不定呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很像秘密社團會做的事吧～♪",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "被我們保護起來叫真軌的那個人，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還記得嗎？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那個人很擅長變裝呢，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還教了我們各式各樣的技巧。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有就是，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "稍微借用了一點",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個叫似似花的人所開發的秘藥。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "用了那東西後，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "整個人的氛圍就會完全改變了喔。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在也用了一點，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以你們才沒辦法馬上認出我吧？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果被碰到的話，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "秘藥的效果就會消失了，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以盡量不要有什麼肢體接觸喔～",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然很想給{player}一個抱抱，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但姐姐還是拼了老命忍耐著唷。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "除了我以外，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其他【拉比林斯】的成員",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有諾維姆她們……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n大家也都變了裝",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "潛伏在祭典會場中的各個地方，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n等待行動開始的那一刻唷。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "發出信號的同時，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一齊朝『王宮』突擊是預定的計畫……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以{player}你們，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n在那之前要在攤販的後頭稍微休息一下也沒關係唷？",
        "unit_id": 104912
    },
    {
        "type": "still",
        "still": "201000501"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不好意思～",
        "unit_id": 111,
        "voice": "vo_adv_2010005_037"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我們要點可麗餅！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n草莓口味的！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊、",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_038"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "草莓口味對吧，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "交給我吧！",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唔嘻……",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_039"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還真是前所未見的大盛況呢～",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果會長能看到，應該會超開心的吧？",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913,
        "voice": "vo_adv_2010005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來貌似相當繁忙的模樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果只是靜靜等著也很無趣……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不介意的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能讓在下也來幫忙嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊～那就幫大忙了呀！",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_041"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是個乖孩子呢，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓姐姐來給妳獎勵吧～……",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好乖好乖♪",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵。",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_042"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可可蘿，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n一直以來盡心盡力照顧著{player}，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是謝謝妳了呢。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n之前的事我有聽說了，",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看到妳平安出院",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我就放心囉。",
        "unit_id": 104912
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然今天可能是相當辛苦的一天，",
        "unit_id": 104912,
        "voice": "vo_adv_2010005_043"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但大家還是一起加油吧♪",
        "unit_id": 104912
    },
    {
        "type": "still",
        "still": "end"
    }
