[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被初音叫來，\n一起來買東西。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "買了好多東西～",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你的幫忙喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，對了對了！",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "結帳的時候，我拿到了――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇！ 這、這道光是什麼！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好刺眼……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚……總覺得突然變得好想睡……",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n明明還沒使用……超能力……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你決定要買什麼了嗎？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我還在猶豫……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n發現好東西了！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就買這個――吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦……",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你、你、你怎麼了！？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抓住我的手……！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 你、你只是想拿一樣的商品……？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這樣啊，原來你也喜歡這個呢！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，怎麼辦？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這好像是最後一個了喔？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好――！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n既然這樣的話，就用猜拳決勝負吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "東西就給猜贏的人喔！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼，要開始囉――。",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "剪――刀，",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "石――頭……剪刀！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ 我、我輸了……！？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n虧我那麼想要――！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……但是，也沒辦法呢。",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n說要用猜拳決定的人是我……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你買沒關係喔。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦，什麼？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你以為我會使用超能力？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n……為了猜贏？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵呵呵，被你小看的話，我會很困擾喔。",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我是不會為了私欲而使用超能力的――！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n閃亮亮☆",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "歡迎光臨――！",
        "unit_id": 1,
        "voice": "vo_adv_1012004_015"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n憑購物收據，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n皆可抽――獎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你看你看！ 有抽獎！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "剛剛我們有買東西，所以應該可以抽獎喔。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "去看看吧――！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "您好，歡迎光臨！",
        "unit_id": 1,
        "voice": "vo_adv_1012004_017"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n我看看……這個金額可以抽2次喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "頭獎是雙人旅遊套票！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n旅行啊。好像很有趣呢～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你要一次就抽中喔！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "――是白色的呢。",
        "unit_id": 1,
        "voice": "vo_adv_1012004_019"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n送您安慰獎的面紙。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒有中……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，還有一次對吧。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 可以讓我轉嗎？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好――，我會努力的――☆",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "若是頭獎，就能和你去旅行啊～！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好棒～！ 好棒～！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ ",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但、但我不會用超能力的！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！ 不用，不用……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不用超能力……不用超能力……",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "只用一點點……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒、沒沒、沒那回事喔！？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼――，呼――……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不、不行！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "果然還是不行啊！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是……雙人旅遊套票……",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嗚，好想要啊～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嘿噫！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "顏色是……白色！",
        "unit_id": 1,
        "voice": "vo_adv_1012004_028"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n送您安慰獎的面紙。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚……沒有中～",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "510330"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "抽獎結果真是遺憾呢――。",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我想如果使用超能力的話，就能抽中了……",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但果然不能那樣耍詐對吧？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n別管那個了，我們繼續買東西――",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ 有了！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我一直在找這個托特包――。",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你看你看～！ 很可愛吧♪",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 你也一直在找這個？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，怎麼辦？ 這好像也是最後一個……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒辦法了！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好――！ 再次以猜拳決勝負吧！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "剪――刀，石――頭……布！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_035"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊……你出剪刀！？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_036"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "既、既然這樣的話！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n……嘿噫！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "顆顆顆……！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_037"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了――！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_038"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你出的拳變成石頭了喔！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n也就是說我贏了――！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？ 我使用了超能力，所以算犯規？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_039"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "被、被發現了？",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n欸嘿嘿～",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對不――起，無――論如何我都想要！",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_040"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n原諒我――！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為妹妹小栞曾說想要這個，",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_041"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我想送給她……",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但、但是不能耍詐呢。",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_042"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯，我知道了！",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這個包包就讓給你――",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 算我贏沒關係嗎！？",
        "unit_id": 101231,
        "voice": "vo_adv_1012004_043"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101231
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇――！ 謝謝――！",
        "unit_id": 101231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了♪",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說，初音意外地靠得住呢～",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她也有非常傻呼呼的地方，",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n比如不在意場所就睡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以我以為她也會一個勁地使用超能力……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是不為了自己而使用這點，",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可不是件容易做到的事喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為人通常都會臣服於誘惑嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是那孩子很固執，",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只會為別人而使用超能力呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這一點也許跟你很像呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n該說是比起自己，會忍不住以他人為優先嗎。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了不讓初音太過勉強自己，",
        "unit_id": 190011,
        "voice": "vo_adv_1012004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n請你要好好支持她喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要確實喔～！",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼～，睡得好飽――。",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_052"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我又睡在路上了……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，我今天沒有使用超能力啊――？？？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ 你也睡著了？",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_053"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n是喔――，為什麼呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，但是因為做了個有趣的夢，很棒呢。",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_054"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我夢到我和你在買東西！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對對，抽獎……呃，",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_055"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "為什麼你會知道！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……原來你也做了一樣的夢――。",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_056"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真是不可思議呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，既然要做一樣的夢，如果是更棒的夢就好了呢～！",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_057"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "例如確實中了獎之類的……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ 話說回來，剛剛買東西的時候，",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_058"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我拿到抽獎券了！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為在夢裡沒有抽中，所以這次一定要抽中好東西喔――！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、我當然不會使用超能力喔！",
        "unit_id": 101211,
        "voice": "vo_adv_1012004_059"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n只用一點點……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即使初音決定不為了自己使用超能力，\n每次卻都好像快要臣服於誘惑一般。"
    }
]