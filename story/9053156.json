        "voice": "vo_adv_9053156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "粉身碎骨了吧！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如此一來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就無法繼續妨礙我們了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011,
        "voice": "vo_adv_9053156_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然能復活，也太狡猾了吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這傢伙是不死之身嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這是……",
        "unit_id": 106411,
        "voice": "vo_adv_9053156_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "精靈的力量？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n魔物好像消失了……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦，",
        "unit_id": 105811,
        "voice": "vo_adv_9053156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開始下雨了？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈",
        "unit_id": 105911,
        "voice": "vo_adv_9053156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像順利取回力量了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這陣雨",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是掌管豐收的精靈",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所賜予的恩惠吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做得好！可蘿仔。",
        "unit_id": 106011,
        "voice": "vo_adv_9053156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這麼一來委託就完成了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106411,
        "voice": "vo_adv_9053156_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這種天氣下，要回村莊會很辛苦呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在雨停之前，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "先在這裡躲個雨比較好吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 105811,
        "voice": "vo_adv_9053156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們也來吃飯吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n食材也還有剩，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就來",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大展身手一番吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀……？",
        "unit_id": 105911,
        "voice": "vo_adv_9053156_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來這位精靈",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也想嚐嚐貪吃佩可小姐做的料理呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_9053156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那真是我的榮幸☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "精靈大人也請",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和大家一起",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "愉快地同桌用餐吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──看我的☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……給我等一下貪吃佩可，",
        "unit_id": 106011,
        "voice": "vo_adv_9053156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳剛剛",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "加了什麼進去？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "加了什麼……",
        "unit_id": 105811,
        "voice": "vo_adv_9053156_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為魚拿去供奉，已經沒有了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我拿魔物的肉來代替呀？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別回答得那麼理所當然！",
        "unit_id": 106011,
        "voice": "vo_adv_9053156_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳啊，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該不會打算讓精靈吃魔物吧！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "精靈之前不是生氣了嗎……",
        "unit_id": 106411,
        "voice": "vo_adv_9053156_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不要緊嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不……",
        "unit_id": 105911,
        "voice": "vo_adv_9053156_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對於貪吃佩可小姐的魔物料理，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n精靈也表示十分感興趣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸？",
        "unit_id": 106011,
        "voice": "vo_adv_9053156_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定是因為之前的",
        "unit_id": 105811,
        "voice": "vo_adv_9053156_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看起來不怎麼好吃吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這次",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是發揮了真本事喔～♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是、",
        "unit_id": 106411,
        "voice": "vo_adv_9053156_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是這樣嗎……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不被以往的文化與常識所束縛，",
        "unit_id": 105911,
        "voice": "vo_adv_9053156_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "透過食物與精靈交流……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對美食無止盡的研究精神，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深感敬佩。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，",
        "unit_id": 106011,
        "voice": "vo_adv_9053156_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被常識束縛著就好了吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話說，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別連對精靈也散布魔物料理的文化啦～～～！！！",
        "unit_id": 106011
    }
