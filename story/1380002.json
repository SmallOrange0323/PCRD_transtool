[
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾國際博覽會閉幕後又過了段時間……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在吉歐‧尼布爾黑爾的巨鯨城，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n薇歐莉特主辦的晚宴即將開始。"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生，",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "今天謝謝",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "您來幫忙。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就麻煩您",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "擔任我的護衛，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n同時協助晚宴進行了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "謝謝您的",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這份心意。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n格蕾斯的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我今天也交代她絕對要安靜休養。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "畢竟不能再讓她",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "繼續逞強了。",
        "unit_id": 133111
    },
    {
        "type": "background",
        "background": "502480"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……聽好了，",
        "unit_id": 133012,
        "voice": "vo_adv_1380002_002"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "騎士氏。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n在這此的晚宴",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "，要請你代替我，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n全力支援公主。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "睜大眼注意周遭，",
        "unit_id": 133012,
        "voice": "vo_adv_1380002_003"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "哪怕是多細微的事都不能放過。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n隨時跟公主一同行動，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "守在半徑一公尺的距離內，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n必要時，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "則以身相護。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "沒錯，",
        "unit_id": 133012,
        "voice": "vo_adv_1380002_004"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "若要打個比方，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "就像是支持妻子工作的主夫那樣盡心盡力──",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我、",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_005"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我說……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "格蕾斯！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n別向騎士先生",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "灌輸一些奇怪的事……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "開玩笑的，",
        "unit_id": 133012,
        "voice": "vo_adv_1380002_006"
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "大概有一半是。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "……總之，騎士氏，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我的份也麻煩你了。",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "\n",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "如果公主出了什麼事，",
        "unit_id": 133012
    },
    {
        "type": "dialogue",
        "name": "格蕾斯",
        "words": "我會化成怨靈找你算帳的。",
        "unit_id": 133012
    },
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "既跟黎薩的事之後，",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "前幾天的國際博覽會也是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n都是因為我不爭氣，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "才讓格蕾斯",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "又勉強自己。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "如今",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我掌握了黃泉鯨命的力量，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "所以希望",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "她能稍微休息一下。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "雖然",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "會麻煩到騎士先生……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生……",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_009"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還是跟平時",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一樣溫柔……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……唔……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "別、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "別誤會了，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "薇歐莉特。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n騎士先生是英雄，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "對所有人",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "都同樣溫柔……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……啊，",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_010"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "非",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "常抱歉。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我還沒說明今天晚宴的事吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這次儘可能地",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "多邀請了一些來賓。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我們吉歐‧尼布爾黑爾",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "各地都零星散布著小村莊，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n也很少",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "有機會",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "可以問候所有人民──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "──不對。",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_012"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "剛剛那是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "藉口",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吧。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "從過去直到最近為止……",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_013"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我都沒有身為公主的自覺，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n對「黃泉的餐桌」的貴族們言聽計從，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n無法",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "在大家面前抬頭挺胸……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是，",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_014"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我學會控制「怠惰」，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "並且",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "透過這次的國際博覽會，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "讓我得以",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "面對自身國家的驕傲。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "現在的我一定可以……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "所以。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我想",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_015"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "邀請各地的代表，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n希望能夠多少",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "與大家建立起信賴關係……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "因此，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "才舉辦了這場晚宴。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "謝謝您，",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_016"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那麼，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我們先逐桌",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "跟來賓打招呼吧──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "服務生？",
        "words": "……呵呵。",
        "unit_id": 1,
        "voice": "vo_adv_1380002_017"
    },
    {
        "type": "dialogue",
        "name": "服務生？",
        "words": "……護衛只有那個瘦巴巴的小子嗎。",
        "unit_id": 1,
        "voice": "vo_adv_1380002_018"
    },
    {
        "type": "dialogue",
        "name": "服務生？",
        "words": "\n守護騎士格蕾斯不在，真是幸運。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生？",
        "words": "\n……雖然沒有私人恩怨，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生？",
        "words": "但這畢竟是委託。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "殺手",
        "words": "去死吧，",
        "unit_id": 1,
        "voice": "vo_adv_1380002_019"
    },
    {
        "type": "dialogue",
        "name": "殺手",
        "words": "公主……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "殭屍來賓",
        "words": "什麼，",
        "unit_id": 1,
        "voice": "vo_adv_1380002_020"
    },
    {
        "type": "dialogue",
        "name": "殭屍來賓",
        "words": "這是冥海鯙魚嗎……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "殭屍來賓",
        "words": "\n我聽說因為牠有股獨特的腥味，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "殭屍來賓",
        "words": "所以難以下嚥啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呵呵，",
        "unit_id": 133111,
        "voice": "vo_adv_1380002_021"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這都是多虧了",
        "unit_id": 133111
    },
    {
