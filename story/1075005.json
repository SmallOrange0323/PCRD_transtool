[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夏天的某一天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n換上泳裝的貪吃佩可，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對著盛夏的太陽大喊。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "夏天！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大海！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n放假～！！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天的我是「微服出巡的公主」！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "工作的事情全都拋到腦後，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要好好",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "品味這個夏天♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這次",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然只有",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我一個人……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不可以想得太悲觀！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為不管怎麼說，這個暑假是──",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留她，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特別為我準備的獎勵☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且似似花小姐",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也爽快地答應",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "代理我處理事情。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不能浪費大家的好意，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定要盡全力享受這個夏天……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n昨天收到的預算申請書……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像還沒有看過。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷～！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我又去想工作的事情了！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在我就該眺望廣闊的大海，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "放空腦袋……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像有些文件期限到今天……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過小凱留說反正處理不完，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n回去之後再處理就行……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……呼。",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要放空腦袋…………",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很難耶。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "越是不去思考，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就越容易想到工作的事情……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "王宮少了我",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的沒問題嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……開玩笑的。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實不管思考多少次答案都一樣。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論我在不在，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要有大家在就沒問題。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "與霸瞳皇帝的戰鬥結束後，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我雖然登上了王座……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我這個公主……",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還只是個「裝飾」而已。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣心不在焉的，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次來度假根本沒有意義啊……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚇了我一跳！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n呃……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆{player}！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好久不見了♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽小可蘿說你今天要打工……",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是不是打工地點",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就在這附近呢？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說是打工請假後過來這裡的？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿♪",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也一樣！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也一直",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很想見{player}一面♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……你是不是，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從小凱留那邊",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "知道了我的事情？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果是這樣的話，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不好意思讓你擔心了。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒問題的！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿……",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你的臉靠這麼近",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會害羞啦☆",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有那麼嚴重嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀～？",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你在看哪呢？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我開",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "玩笑的♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有瘦得那麼明顯嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……其實",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留也說過一樣的話。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n結果她就把我趕出王宮，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "叫我休息一天。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你來看我",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真很開心。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛好有點多愁善感……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來陪我的話，可能會給你添麻煩哦。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿！",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你總是這麼溫柔♪",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好想馬上",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "緊緊抱住你哦！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼……",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "接受你的好意囉！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像我剛才說的一樣，",
        "unit_id": 107512,
        "voice": "vo_adv_1075005_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在幾乎沒什麼精神。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
