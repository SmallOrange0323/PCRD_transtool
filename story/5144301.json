[
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "多虧有鈴莓小姐，",
        "unit_id": 130711,
        "voice": "vo_adv_5144301_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們總算是打倒壞人了……",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是這麼大的魔物植物，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們該拿它怎麼辦才好！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別擔心，",
        "unit_id": 130811,
        "voice": "vo_adv_5144301_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏡華！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "它可能是因為肚子裡還充滿著泡泡，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以動作有點遲緩的樣子。",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "確實，",
        "unit_id": 130711,
        "voice": "vo_adv_5144301_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "它看起來好像還有點痛苦！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們就趁現在打倒它吧！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就是這股鬥志！",
        "unit_id": 130811,
        "voice": "vo_adv_5144301_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟這可是我們在大家的幫助下，",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n拚了命地準備的鮮花祭啊……！",
        "unit_id": 130811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我絕對",
        "unit_id": 130811,
        "voice": "vo_adv_5144301_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不會讓你攪局的～！",
        "unit_id": 130811
    }
]