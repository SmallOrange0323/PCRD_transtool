[
    {
        "type": "background",
        "background": "509011"
    },
    {
        "type": "background",
        "background": "510202"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "夜深人靜的，",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為何一個人在這裡，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "害妾身在空中看到時，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不加思索地就飛下來了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……？",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n難道說，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你在等妾身嗎？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我們應該沒有做過什麼約定吧……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔！",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你、",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你記得啊。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才會在這種地方",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等妾身偶然經過？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還真是走一步算一步呢……",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不對，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "以前和你在夜空中飛翔也是在這裡呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n對我們來說，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都留下了深刻的印象是嗎。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔，",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等妾身一下。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n難得成功偶然見面了，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為了符合這場面──",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──就這麼做吧。",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_005"
    },
    {
        "type": "background",
        "background": "510272"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了，",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡是其他人都看不到的",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只有我們兩人的地方。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妾身准許你",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "親手為妾身戴上那個禮物。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯，",
        "unit_id": 104431,
        "voice": "vo_adv_4010172_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身讚許你……♪",
        "unit_id": 104431
    }
]