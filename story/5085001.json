        "voice": "vo_adv_5085001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關聯嗎？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是啊……",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就是這次事件的開端。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──你的公主騎士之力，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經強過頭了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n才暫時把你的精神分離到「人工世界」，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n將力量與",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "心靈隔離開來。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "變強……",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該是",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好事沒錯吧……？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當然，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "變強是件好事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "前提是配合你自身的成長，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "經歷了許多冒險、",
