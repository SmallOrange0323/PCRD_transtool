    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然會讓他傷到自己嗎！？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不光是你。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那些承受這股力量的人也一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……連我們，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也會？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個甚至可能會對「那一側世界的命運」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "造成巨大影響。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不管怎樣……",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "力量再繼續增強下去的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的身體",
