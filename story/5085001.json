    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很快就會撐不住了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……破碎的資料",
