        "voice": "vo_adv_5085001_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都會走向相同的結局。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
