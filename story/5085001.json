        "voice": "vo_adv_5085001_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我完全沒預料到貪吃佩可會在這裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在我製作這個夢世界時，",
