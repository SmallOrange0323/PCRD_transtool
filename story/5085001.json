        "voice": "vo_adv_5085001_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在最近的數場大戰中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你原本的公主騎士力量歸還到你身上，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n此時",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又增加了名為「公主型態」的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "新力量。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "急速進化……",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經超越了成長。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太過強大的力量，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經到了會反噬自己的程度。",
