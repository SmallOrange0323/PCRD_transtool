    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然這麼嚴重……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有什麼",
