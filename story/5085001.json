[
    {
        "type": "background",
        "background": "510224"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與貪吃佩可在神秘的世界遇上了魔物。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人好不容易擊退了魔物後，再次開始調查這個充滿謎團的世界。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個魔物……",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從這裡出現了呢。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這像裂縫一樣的東西是什麼……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "它後面連接著蘭德索爾，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要跳進去就能回去了？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是啊。",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然想要賭一把",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "試試看……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但還是不要比較好。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萬一",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為這樣而和你分隔兩地，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會很困擾的。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那很危險的！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你還是一樣好奇心旺盛呢♪",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種時候還是謹慎一點比較好。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……真的要碰它的話就一起碰",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吧♪",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_5085001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聽得到嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_5085001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n喂！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是……",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聲音……？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n簡直像是，",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "直接傳到腦袋裡一樣……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聽得到",
        "unit_id": 1,
        "voice": "vo_adv_5085001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的聲音吧！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n太好了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "想不到",
        "unit_id": 1,
        "voice": "vo_adv_5085001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "連這邊都受到影響……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n連聲音也傳不過去，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太折騰人了吧，真是的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳該不會是……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "愛梅斯大人？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貪吃佩可。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n把你們關在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那種地方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把我們關",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "起來……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳知道這是什麼狀況嗎！？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡到底是哪裡！？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是我們之前看過的",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個地方嗎！？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然是相同的風景，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "卻是不同的地方。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那裡是",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從這傢伙的記憶中產生的夢之場所。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從他的",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "記憶……？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯。",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n從累積在這傢伙身上的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「記憶碎片」產生的，像夢一樣的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──是我為了讓妳看而做出來的",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「人工世界」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "愛梅斯大人，既然是妳做出來的世界，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳應該知道如何從這裡出去吧？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想回到蘭德索爾！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……對不起。",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還不能那麼做。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼……？",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓你們看這個「人工世界」",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是有理由的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……跟你有關喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "跟他有關……？",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你現在",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正處於非常危險的狀態。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n危險程度甚至不能一直讓你存在於蘭德索爾。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "！？",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你……",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不驚訝嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n該不會，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你有想到什麼！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才不是那樣！！",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是因為我沒辦法駕馭而已……！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等、",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你該不會……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那邊也",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以使用力量？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原來如此，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是跟魔物之間的戰鬥……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "魔物！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你那邊也出現魔物了嗎！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這可不妙了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "比想像中還要糟糕。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我問妳，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "貪吃佩可。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這傢伙的力量……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有沒有什麼",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "奇怪的地方？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我穿的衣服突然起了變化……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "湧出了比平常還要強大的力量……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我沒辦法",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好好地使用它。",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "心一橫用力攻擊之後，",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n反而產生了像是自己身體",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要壞掉一樣的",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "疼痛感……",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……這樣",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想不到",
