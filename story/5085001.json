        "voice": "vo_adv_5085001_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這邊也是……那邊也是，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n為了解決狀況而……",
