    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到了這裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n連貪吃佩可也一起",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "捲進來了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也是，",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "力量變強過頭的影響……",
