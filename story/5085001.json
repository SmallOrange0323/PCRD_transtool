        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "貪吃佩可？",
        "unit_id": 100231,
        "voice": "vo_adv_5085001_067"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳怎麼了嗎？",
        "unit_id": 100231
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀啊啊！？",
        "unit_id": 105831,
        "voice": "vo_adv_5085001_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n優、",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "優衣……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳什麼時候回來的！？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "優衣",
