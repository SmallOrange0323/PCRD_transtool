    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我",
        "unit_id": 121011,
        "voice": "vo_adv_5085001_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該怎麼做才好？",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要怎麼做",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才能救他！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說實在的，",
