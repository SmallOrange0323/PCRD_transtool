    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "越來越聽不見了……！",
        "unit_id": 121011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要使用……",
        "unit_id": 190011,
        "voice": "vo_adv_5085001_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "力量……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……已經",
