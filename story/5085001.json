        "voice": "vo_adv_5085001_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "消失了……？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可能是因為這樣，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以聽不到愛梅斯大人的聲音了吧。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這……",
        "unit_id": 105831,
        "voice": "vo_adv_5085001_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的衣服也變回原樣了！？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是魔物又出現的話……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果源頭是那個裂縫的話，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
