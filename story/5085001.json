        "voice": "vo_adv_5085001_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "戰鬥、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以及相遇，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你一直持續在成長。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "藉由連繫羈絆，",
