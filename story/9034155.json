[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！　",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們快看，小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這附近開了好多漂亮的花喔〜",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳竟然會對食物以外的東西有這麼大的反應，",
        "unit_id": 106011,
        "voice": "vo_adv_9034155_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真少見呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來妳對花有興趣嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_9034155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐也是妙齡的少女。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然也會有顆",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喜愛花卉的心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "天真！　",
        "unit_id": 106011,
        "voice": "vo_adv_9034155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳太天真了，可蘿仔！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別小看這傢伙的食慾。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她眼中看到的所有東西都會覺得是食物啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊～！　",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然這種花，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是豆子的花哦！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡結了很多的豆子耶☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105911,
        "voice": "vo_adv_9034155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看吧！",
        "unit_id": 106011,
        "voice": "vo_adv_9034155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙對食物的嗅覺，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連狗都會自嘆不如啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？　",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說小狗怎麼了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了，妳們兩個也一起吃吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豆子",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很好吃哦，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9034155_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您先吃完嘴裡的東西再說話吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "生吃野生動植物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定會吃壞肚子的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回去後在下會再煮過，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請先別吃了――",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇哇……！　",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "救、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "救救我！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106011,
        "voice": "vo_adv_9034155_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n什、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有藤蔓纏在她的身上了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9034155_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請看那邊！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這些藤蔓的源頭，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花的魔物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是、",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是因為我擅自吃了豆子，所以牠生氣了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105911,
        "voice": "vo_adv_9034155_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那恐怕是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "用漂亮的花來吸引獵物並捕獲牠們，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像食蟲植物那樣的生物吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來還有這種魔物呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "學到一課了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在是佩服的時候嗎！",
        "unit_id": 106011,
        "voice": "vo_adv_9034155_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最近這附近",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有很多開拓的冒險者會路過，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們把牠處理掉吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是說，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳要被這樣糾纏到什麼時候啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對、",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起，小凱留……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呣呣呣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿——！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼，",
        "unit_id": 105811,
        "voice": "vo_adv_9034155_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總算掙脫了☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好，妳們兩個",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也一起來大肆收割吧！",
        "unit_id": 105811
    }
]