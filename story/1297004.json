[
    {
        "type": "background",
        "background": "501892"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "──咕～",
        "unit_id": 51611,
        "voice": "vo_adv_1297004_000"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "呼嚕～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "涅妃‧涅羅等人在大江戶觀光的最後一天深夜。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在女生房間裡，是蜷曲起來熟睡的米亞"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與空蕩蕩的被窩。"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……躡",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "手、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "躡腳",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……",
        "unit_id": 129711
    },
    {
        "type": "background",
        "background": "501892"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面，男生房間──"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "打擾了。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n騎士閣下呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……嗯。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n嗯、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此般熟睡程度，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n看來即便碰觸臉頰亦不至轉醒。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "何等地",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "毫無防備……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "惹人憐愛的睡姿啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "曝露出此般天真無邪的模樣，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n可會被壞心史萊姆吞噬喔？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……原來如此、",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來如此。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此溫度……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "簡直令奴家想起幼時的默涅啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "啊啊──",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "非也。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此般結實肉體……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "果真",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃男子也。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n善哉、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "善哉……♪",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚是危險。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n連奴家都險些失態，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一時間",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "竟忘了本意。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好了，騎士閣下呀，",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_010"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "失禮了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家要進入沉睡的恁",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "心思動盪的夢境之中──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "510082"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──某天夜晚。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "晚安，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "騎士閣下呀。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n失禮了。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──呵呵喝。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n問奴家是誰可真是冷淡。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n奴家與恁",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可是親密無間的呢？",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──嗯。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n此般模樣有如為狐狸所迷惑一般啊。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n竟對此面容",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "與遣辭用句",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "毫無印象……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "稍待片刻。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "奴家對此技巧不甚嫻熟──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n恁似是回憶起了，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "奴家甚感欣喜。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "此次終歸只是",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一夜夢中的親密交談。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖說扮演初次相遇作為嬉戲",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "亦頗為愉快，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然而此事便暫且留待下回吧。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "容奴家重新介紹，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_017"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家亦名為禰羅。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "今夜在無須顧忌",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "偷窺狂──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "非也，偷窺蛇的場合，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n奴家會為騎士閣下解答疑問。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "亦即。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_018"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家將揭示",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家個人──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "所隱瞞之",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "部分事宜。",
        "unit_id": 129731
    },
    {
        "type": "still",
        "still": "129700401"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "好了，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_019"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "騎士閣下呀。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n為了潤喉，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家先敬恁一杯。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n其中並未摻有酒精，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "還請安心享用。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……呵呵。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_020"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n真是爽快的暢飲之姿呢。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "話說──",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_021"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "嗯。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家猜想，騎士閣下",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "似是十分在意奴家之樣貌。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "無甚大事。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_022"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "此身乃鐵之史萊姆，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "未曾有固定形態。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n千變萬化、",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "自由自在。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……更何況。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_023"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n奴家本體",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "之巨大，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "遠勝於此。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "因而此樣貌",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "與至今之樣貌，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "僅是五十步與百步之差。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "…",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_024"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "…正是如此。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n恁的慧眼",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "令奴家深受感動。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "無事，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_025"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "「非人」一類",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "並非稀奇之物，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n扎根於現世的",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "並非僅有人類。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "然而……",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_026"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "且不論天使或惡魔，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n於奴家這般古老且不解人情之存在，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n要理解恁們纖細至極、不言而喻的細微情感，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "著實困難。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "──「皇家裝備」",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_027"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "會協助這般拙笨的奴家，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n作為與恁們之間溝通橋梁般的道具。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "雖說這已偏離了",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "其原先的用途便是。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……呵呵。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_028"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n萬分抱歉，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家太拐彎抹角了。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "簡而言之，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_029"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家認為皇家裝備",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n乃與人之根源、",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "本能、",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "本性有關的道具。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "因而若接觸此道具，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_030"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n便是「非人」的奴家，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "亦能理解恁們的內心。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n並得以模仿",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "恁們之行為舉止。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……然而……",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_031"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n「嫉妒」之心境",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "於奴家而言極其難以理解。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n乃因人類所有之優點，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家能感受到的唯有可愛……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "雖非同母所生之幼兒，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_032"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n但既說",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "「血濃於水」，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n奴家與其",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "確為姊妹",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……不僅如此……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家模仿人形時之樣貌，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_033"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n便是基於其血親之枯骨而成。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……從前、",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_034"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "從前，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "某座南方島嶼上，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "有一安穩小國。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n長時持續著",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "日出而作、",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "日落而息的",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "簡樸生活。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "長久以來，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_035"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家之碎片",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n深埋於大地，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "幾經流轉，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "傳至該島國的貴族手中。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n因此，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家現在的面貌，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "乃因緣際會下",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "向已故女子借來的。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "時光飛逝。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_036"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n此事距寢亞誕生",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "近一世紀以前。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n高舉旭日旗的",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "士兵及其同夥，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "來到了該地。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "雖歷盡曲折，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_037"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "然而他們與島主等人建立情誼。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n於短暫逗留中，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "留下無數有形與無形之物。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n文字、",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "技術、",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "習俗……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "而語言，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "亦然……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……正是。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_038"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "昔日的奴家",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "尚如同路旁之石，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n僅能透過所見來模效，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n卻全然無有時間深入理解……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……呵呵。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_039"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n可真是",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "說了些無益的往事呢……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "哎呀，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_040"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "騎士閣下。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n恁的杯子空了呢。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "這可真是失禮了──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "那麼，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家再敬恁一杯。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "…………",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_041"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……請儘管問。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_042"
    },
    {
        "type": "still",
        "still": "129700402"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "──呵呵呵……",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_043"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "此等瑣事，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_044"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n騎士閣下",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "亦是已知曉了吧……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_045"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "乃「鐵之史萊姆」。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "──嗯。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_046"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n儘管宴會正酣……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n然而看來",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "亦到了……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "該結束之時了。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "那麼，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_047"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "騎士閣下呀。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n奴家與恁很快",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "便會在那邊的世界再相見──",
        "unit_id": 129731
    },
    {
        "type": "background",
        "background": "510082"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "…………",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_048"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "…………",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_049"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "唉呀。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_050"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n請稍待。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n再一次──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "──這可真是。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_051"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "夢境收尾的安排，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n貌似出了點差錯呢……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "真教人",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_052"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "發怵。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "正因如此，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "新穎的機關才令人頭疼。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……呵呵。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_053"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "如此一來，奴家與騎士閣下",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n將就此於夢境與現實之交錯中迎來終結。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "……或許",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "亦不失為一不錯之睡前故事……",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "唉呀，然而實在駭人。",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_054"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "若真如此，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家便必定會遭受到",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n仰慕騎士閣下的女子們那遠比岩漿之火更為炙熱的嫉妒。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "既",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_055"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "然如此──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "─",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_056"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "─吶。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "汝在的吧？",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n汝正於某處竊聽著吧？",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "並非窺伺之人，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "而是窺伺妖精啊。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "便交由汝負責",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_057"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "引導騎士閣下甦醒吧。",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n還望汝",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "鄭重、規矩地目送，",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "\n",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "否則──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "奴家便將汝之居所，",
        "unit_id": 129731,
        "voice": "vo_adv_1297004_058"
    },
    {
        "type": "dialogue",
        "name": "禰羅",
        "words": "自咱們頭上敲落吧──",
        "unit_id": 129731
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "501640"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "…………",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_059"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……不。",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_060"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……不──────",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_061"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不妙。",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_062"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n這下……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真的不妙啊，",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_063"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那個。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n太不妙了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "事到如今，",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_064"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我也還是不知道她的真實身分。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n太不妙了之乎者也……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊。",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_065"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n因為太不妙了，連語言程序都變得奇怪了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "真是的～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_066"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是啊。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "雖然是那樣，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "但那種東西是存在於現實中",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "的嗎。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n雖然我認為她的個性並不會在重要的事情上說謊……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "嗯～",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_067"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……就我而言，",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_068"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我的主張是有些事如果不知道，那維持現狀就好。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n而且，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我又是不冒險主義……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過該說總覺得",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_069"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "很在意嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n那種裝作猜謎出題般的感覺……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "被那樣一說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就想去稍微調查看看啊。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "喜歡謎題的話就會這樣呢，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那麼……",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_070"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "此次便先就此別過了。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……我要順便",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "去找一下",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我的詞彙量啦──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "啊。",
        "unit_id": 193211,
        "voice": "vo_adv_1297004_071"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n要是她有問起的話，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "還請你說我有誠懇細心地",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n款待你喔──",
        "unit_id": 193211
    },
    {
        "type": "background",
        "background": "501891"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──恁啊，",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_072"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁早。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_073"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "沒想到。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁問「為什麼」，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可真是冷淡。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "莫非",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_074"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下忘了？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "忘記恁昨夜",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "與奴家交換的枕邊密語。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……嗯……",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_075"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來如此，",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_076"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這便是「妨礙認知」之結果呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雖稍感寂寥……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但給予騎士閣下力量之人",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_077"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "與「妨礙認知」並無直接關聯。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n看來",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "似乎也並無惡意……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此次單單知曉此事，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便足矣了吧──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不成不成。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_078"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可沒道理低頭。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n因奴家",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "似是亦稍有些得意忘形了──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "咦～！",
        "unit_id": 51611,
        "voice": "vo_adv_1297004_079"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n我才想說皇女殿下不在，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "結果您為什麼會在這邊！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……真傷腦筋。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_080"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n一大早",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便如此吵鬧啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "區區小事。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_081"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n僅僅是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "早起之鳥兒有蟲吃罷了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "咦～？",
        "unit_id": 51611,
        "voice": "vo_adv_1297004_082"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n有蟲吃是什麼？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就只有您自己有，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "好狡猾喔～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_083"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若能獨占",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下惹人憐愛的睡顏……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n早起豈止有蟲吃，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "簡直如",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "美饌佳餚。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "真是的～",
        "unit_id": 51611,
        "voice": "vo_adv_1297004_084"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "您就是喜歡小孩子～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "……不，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "感覺騎士閣下先生",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "也不是那樣啊……？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_085"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "儘管奴家難以理解嫉妒之情，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n然若有人能獨占恁──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那或許",
        "unit_id": 129711,
        "voice": "vo_adv_1297004_086"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便足以令奴家感到嫉妒呢……♪",
        "unit_id": 129711
    }
]