[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊啊！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好痛痛痛痛……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我、我又跌倒了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是不幸中的大幸……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n採購的東西是{player}拿著呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不管我摔得多麼嚴重，買的東西也沒事♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n連{player}也跌倒了呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒事吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，你是因為要馬上扶住快跌倒的我……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n才失去平衡跌倒吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對、對不起，感覺因為我的冒失而連累你了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明、明明不用扶我也沒關係的。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我已經努力學會了安全跌倒的方法……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以即使跌倒，受的傷害也會減到最小♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，我努力的方針很奇怪？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也是呢～但是總比什麼都不做「來得好」吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "冒失是不治之症，就像詛咒一樣。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要克服它必須要長期奮戰……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想就算把事情搞砸，也不能給旁人添麻煩，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n或是讓他們擔心。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不說那個了，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}的膝蓋擦傷了喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請等一下，我現在用恢復魔法幫你治療喔♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為、為什麼你一臉害怕的走開……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不用擔心喔～不會像育幼院的牆壁一樣爆炸的喔？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯，不要動喔。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿噫，恢復健康吧……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n恢復魔法我還算拿手喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我很常跌倒受傷，所以很熟練了。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過要是一著急，還是會失敗。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還有其他地方會痛嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會幫你治療喔♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，因為你相當大力地撞到地面呢……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在哪裡呢？讓我看看你痛的地方。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果撞到頭的話，之後應該要仔細檢查比較好？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是我沒有那種技術……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之，先做緊急處理吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "即使你這麼說，我也……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是、是因為我太冒失了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n光是看著我就覺得很可憐，所以才心痛嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、我不要緊喔！",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我還算幸福！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要擔心♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿咻♪",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣就全部恢復了吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呼。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n使用魔法後就感到疲倦了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是，因為今天，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有{player}幫忙提東西……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我才能保有體力。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還很有精神喔♪",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n欸嘿嘿。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}真是親切的人呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你說這是我請你吃路邊攤的謝禮？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那是我前幾天給你添麻煩的賠禮喔～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "賠禮的謝禮，都要搞不清楚了呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣真的很棒呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好心有好報，或是互相給予溫柔的感覺。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果大家都像{player}一樣的話，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n世界就會和平呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦，{player}……東西去哪裡了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "你看起來兩手空空……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是掉在什麼地方了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}也和我一樣冒失呢～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真傷腦筋，到底掉在哪裡了呢？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想想，我想想？",
        "unit_id": 102511
    },
    {
        "type": "still",
        "still": "102500301"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像有什麼小東西在搬東西喔？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這……難道是排在廣場的地藏們？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說不定……",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這不是地藏，而是魔像呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "魔像是魔法師創造出的擬生物。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "它們應該是被主人遺棄，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而被丟在那個廣場吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "感覺這些魔像們，是不是在報答我",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n替它們擦亮身體……呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我讀過這樣的童話。",
        "unit_id": 102511
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大概是因為我替它們清理時觸碰到它們。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只是因為我體內的魔力轉移，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n使得休眠的魔像們重新活動而已。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以，那時我對{player}說，",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n「我希望你幫我提東西」時……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "它們只是誤以為這是對自己的命令才做的吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是……像童話中的地藏向我報恩～",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣的想法比較棒呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比較有夢想或是幸福的感覺。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_1025003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
