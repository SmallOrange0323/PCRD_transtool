[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……♪",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇……？",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，嚇了我一跳。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你好。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好久不見。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你還記得我嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的，我是栞。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很高興能再見到你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n請問你",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n來【伊麗莎白牧場】有什麼事嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原來你在兼差郵遞，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要送信之類的東西",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n來【伊麗莎白牧場】啊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你工作辛苦了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "然後你在回去的路上看到我，就出聲叫我了呢。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "【伊麗莎白牧場】位在山上，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n到這裡來應該很辛苦吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我偶爾也會為了買東西去山下的城鎮，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但是我每次去一趟回來大概都要睡個三天。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我的身體不太好。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天我的身體狀況還蠻好的喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我才像這樣邊在外面曬太陽，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一邊做【伊麗莎白牧場】的警備勤務。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體狀況真的很差時，是會無法走出病房的……",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以今天不要緊。我精神很好，請你不用擔心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我本來是所屬於負責蘭德索爾",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n城鎮警備的【哞哞自衛隊】。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "為了讓我休養，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n他們把我派來這座【伊麗莎白牧場】。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "寄住在這裡沒幫上什麼忙會讓我很不好意思，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我就幫同屬【哞哞自衛隊】、名叫鈴的女孩分擔工作，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們也會做一些……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "類似警衛的事。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在我也算是正在負責警衛喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你看，我還帶著弓箭。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只是【伊麗莎白牧場】非常平靜。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "每天都沒什麼特別變化或是災害……",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "魔物也不會穿過柵欄進到牧場裡來。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我就鬆懈地看起書來了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我這樣太疏忽大意了吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一直到你出聲叫我前，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我都沒發現你。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看來我必須更加認真戒備才行。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是真的沒什麼事的話，就會開始想睡覺呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈……總覺得很丟臉♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個啊，我在看以前",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n和你一起去買東西時所買的書。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很喜歡這位作者。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "【伊麗莎白牧場】位在山上，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我也很少能去城鎮……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我非常難取得想要的書。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也因此，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我都會花上很長的時間去看一本書。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……畢竟我是因為工作鬆懈而在看書，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你對我說「辛苦了」聽起來也像是在挖苦我。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈，真的覺得好丟臉♪",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哎呀。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你正在工作，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我還跟你聊這麼久真不好意思。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為【伊麗莎白牧場】裡，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n動物比人還要多。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家不知道是不是顧慮我的身體，都很小心謹慎地對待我……",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "生活上沒有刺激，我覺得好無聊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我很想念與人相處的生活，所以很高興能和你見面。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n謝謝你和我聊天。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是我不能再繼續依賴你了吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯嗯……",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你說你",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n還會持續兼差郵遞吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你還會不斷地",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n過來【伊麗莎白牧場】嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣我好開心。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你如果有看到我的話，請你要叫我一聲喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我要是身體狀況差就會躺在病房裡，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以你可能會很少見到我。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……你說要是我有想要的書的話，",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你可以趁送信來【伊麗莎白牧場】時，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n順道替我買過來嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然我很感謝你，但是我會覺得不好意思。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_030"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想要的書",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_031"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "非常的多……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是因為書很重，\n你要帶過來這邊應該會很辛苦吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你為什麼要對我這麼好？",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_032"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是出於同情嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你覺得我是一個可憐的女孩嗎……？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……你好像不是這麼想的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_033"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我看你的眼神就知道了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你真的是一個",
        "unit_id": 103811,
        "voice": "vo_adv_1038005_034"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n平常就很溫柔的人呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起，我懷疑你了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼我就接受你的好意……",
        "unit_id": 103811,
