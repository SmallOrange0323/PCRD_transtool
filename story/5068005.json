[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾四處奔走的碧一行人，終於找到了玩具王。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們開始詢問玩具王想和"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "所有小孩子成為朋友的目的。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成成成、",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成為朋友……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且對象是蘭德索爾的所有小孩子……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你只是在讓「玩具王二世」們四處搞破壞而已吧……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是說啊。",
        "unit_id": 116911,
        "voice": "vo_adv_5068005_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你襲擊了孩子們，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還想著要和他們當朋友……？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "襲擊……？",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_002"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "妳在說什麼啊？",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_003"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "是在和小孩子們玩！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n我們要締結一輩子的友誼，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "永遠玩在一起！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "小碧你們也看到了吧？",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_004"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n那些被送到工廠的",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "殘破不堪的玩具！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我當初",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_005"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "也是像那樣被丟棄的！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "所以才會被扔在倉庫的一角，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_006"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "長久以來飽受著孤獨！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩具王……",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你該不會認為",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自己是被丟棄的吧……？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "是啊，沒錯！！",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是這樣的……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你誤會了！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n玩具王你",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒有被丟棄！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你會被送到工廠，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是因為你的主人",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很愛惜你……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你的主人長大後，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n希望你能一輩子被孩子們疼愛，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "永遠當他們的玩伴……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才把你送去工廠修理，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想為你找到新的主人……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n玩具王你看到的那些",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "壞掉的玩具也都是如此……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請別再說自己是被丟棄的玩具了……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "住口住口住口！",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_015"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n誰會相信",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "那種話啊！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "玩具總有一天",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_016"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "會被丟棄！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n這就是玩具的命運！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "身為玩具必定的結局！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "「玩具王二世」們也將面臨相同下場……",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_017"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n我不想讓它們也體會這種悲傷……！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "所以，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_018"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我把力量分給了1000名同胞們，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n讓它們和我一樣能自由活動！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "這一切都是為了改變",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_019"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我和同胞們",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "注定被丟棄的命運！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼會……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "居然能將邊緣精神分給二世們……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩具王遠比我承受了",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "更巨大的孤獨……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "只要能讓孩子們一直陪我玩，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_021"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我們就能當永遠的朋友！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n這樣一來，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "蘭德索爾的所有小孩子就都是我的玩伴了！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "擁有意識、能夠自由行動的玩具就只有我一個！",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_022"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n換句話說，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我就是世界上",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "最棒的玩具！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "啊啊，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_023"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我現在能感覺到……",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "第二小隊正在和孩子們玩耍……",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n形同我手足的同胞們所感受到的友情，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "傳達到了我的身心靈！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "有1000名同胞，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_024"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "快樂程度便是1000倍──！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種事……",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種事一點都不快樂……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是啊，",
        "unit_id": 116911,
        "voice": "vo_adv_5068005_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "玩具王！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "孩子們和",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "他們的家長都正為此感到困擾！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n玩得開心的，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就只有你們自己而已！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "快停手吧！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "唔唔唔，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_027"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "吵死了──！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n身為人類的你們，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "怎麼可能理解玩具的孤獨！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "如果非要妨礙我的話……！",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_028"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n就算是找到我的小碧，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我也不會手下留情！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "所有小隊聽令！",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_029"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n「玩具王二世」們啊，",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "給我聽仔細了！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "我會",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_030"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "再次給你們力量！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n現在立即",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "集結至我身邊！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王二世等人",
        "words": "嘎嘎嘎！嘎嘎嘎！嘎嘎嘎！",
        "unit_id": 14913
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "連剛才回收的玩具",
        "unit_id": 116911,
        "voice": "vo_adv_5068005_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "都再次動起來了！？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這到底是怎麼回事！？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "1000名同胞啊！",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_032"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "\n現在正是我們成為",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "最強、",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "最大、",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "擁有最頂級性能的玩具之時！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "玩具王二世等人",
        "words": "嘎嘎嘎嘎嘎嘎！嘎嘎嘎嘎嘎嘎！嘎嘎嘎嘎嘎嘎！\n嘎嘎嘎嘎嘎嘎！嘎嘎嘎嘎嘎嘎！嘎嘎嘎嘎嘎嘎！\n嘎嘎嘎嘎嘎嘎！嘎嘎嘎嘎嘎嘎！嘎嘎嘎嘎嘎嘎！",
        "unit_id": 14913
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "──玩具王，",
        "unit_id": 14911,
        "voice": "vo_adv_5068005_033"
    },
    {
        "type": "dialogue",
        "name": "玩具王",
        "words": "1000隻大合體！",
        "unit_id": 14911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦～～！？",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n玩具王們都聚集過去，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變得越來越大了！？",
        "unit_id": 116711
    },
    {
        "type": "still",
        "still": "506800501"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "合體完成！",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_035"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "究極",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "機械玩具王！！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哇哇哇哇……！",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_036"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩具王們合體了～！？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這也太巨大了……！",
        "unit_id": 116911,
        "voice": "vo_adv_5068005_037"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n它們明明不具備合體功能……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "究竟是如何辦到的……！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "哼哈哈哈哈哈哈哈哈哈！",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_038"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "只要深愛著孩子們，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_039"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "玩具就是無所不能的！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "位於如燃燒般赤紅心臟深處的我，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_040"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n和1000隻玩具的軀體相接，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "向它們傳遞力量！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我能發揮出一次背起1000個小孩子的力量！",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_041"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n能同時背起1000人的玩具，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "僅此我一隻！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "說是要背起小孩子……",
        "unit_id": 116911,
        "voice": "vo_adv_5068005_042"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n它要是以這種狀態去見他們，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可就不光是讓人受點小傷而已了……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯……",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_043"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在的玩具王，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n誤解了「和小孩子玩」的意義。",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "這樣一來，我就是世界上擁有",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_044"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "最頂級性能的玩具了！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "從今以後我再也不會被孩子們厭棄，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_045"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "會是他們一輩子的玩伴！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我能擁有永遠不變的友情！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "換言之，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_046"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我就是孩子們",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "永遠的朋友了──！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "那麼，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_047"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我現在要去跟孩子們玩了，告辭！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n小碧你們，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "讓路吧！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "再會了！",
        "unit_id": 14912
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "碧、美冬",
        "words": "呀啊啊啊～～！？",
        "unit_id": 1,
        "voice": "vo_adv_5068005_048"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "鬼抓人、",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_049"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "踢罐子、",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "捉迷藏……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n啊啊，感覺每個都很有趣……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "好猶豫啊！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "不過……",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_050"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我擁有無限的時間。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我要和孩子們把所有遊戲都玩遍！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "哇哈哈哈哈！！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_051"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請等一下……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "唔……",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_052"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "還有事嗎？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我可是很忙的。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "小孩子們都在等我呢。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩具王！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你所認為的友情……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是什麼呢？",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "妳說什麼？",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_054"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然身為邊緣人的我沒什麼立場評論，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_055"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但我認為，玩具王所說的友情，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "並不怎麼美好……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "什麼……？",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_056"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_057"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "友情應該是要為彼此著想的！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_058"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你所認為的友情，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n只是單方面地把自己的想法",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "強加在孩子身上，支配著他們而已……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛才",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_059"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "回收「玩具王二世」時，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我看見蘭德索爾各處",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "都是放聲哭泣的小孩子……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在我看來，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_060"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n那不像是和朋友開心玩樂的畫面……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我還以為妳要說什麼呢……",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_061"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n那麼，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "換我問問妳。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "小碧……",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_062"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "對妳而言，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "「有我在喔好朋友號」",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "並不算是朋友吧？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n它應該只是你用來練習交朋友的道具。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "而且，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_063"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "妳會去玩具工廠打工，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n就是因為粗暴地對待它，把它弄壞了的緣故……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "妳之前曾這麼說過吧？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_064"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是這樣沒錯……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "然後，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_065"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "妳若交到了人類朋友，就不再需要練習的道具。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n這麼一來，",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "它就失去利用價值了。",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "這樣的妳，",
        "unit_id": 14912,
        "voice": "vo_adv_5068005_066"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "沒有資格和我們這種被粗暴對待……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n玩壞後便被丟棄的玩具，高談人類與玩具間的友情！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_067"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然正如你所說，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_068"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號是我製作出來，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n用來練習交朋友的對象……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但、",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_069"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自從開始打工以後，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就變得比之前",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "更加倍珍惜好朋友號了……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了改造它而努力工作的過程很有趣，",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_070"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "玩具好朋友被製造出來，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號的朋友圈擴大時，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我也打從心底為它感到開心……！",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是……",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_071"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "或許玩具王說得沒錯……",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好朋友號……",
        "unit_id": 116711,
        "voice": "vo_adv_5068005_072"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我一直以來都把你當成練習道具，",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只考慮了我自己，真的很抱歉……",
        "unit_id": 116711
    },
    {
