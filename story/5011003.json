        "voice": "vo_adv_5011003_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還有其他什麼症狀呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "例如身體很熱，",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然後感覺昏昏沉沉的？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "心跳如何呢？",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "盯著我看",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有沒有什麼特別的感覺？",
