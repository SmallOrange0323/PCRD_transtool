    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n有什麼不一樣的地方嗎？",
