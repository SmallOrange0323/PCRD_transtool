    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "現在馬上吃掉吧……！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我何曾做過\n危害{player}大人的事情呢？",
        "unit_id": 109011,
