        "voice": "vo_adv_5011003_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我真是的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難道是調和搞錯了嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "調、",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "調和？　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是什麼意思！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳沒在這個巧克力裡加入什麼東西吧！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我放了媚藥。",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "媚、",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "媚藥！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳別讓哥哥",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吃那種奇怪的東西啦！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那才不是奇怪的東西。",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "而且，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也沒放入對身體有危害的東西呀。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "才不是那種問題啦～！",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n想要強硬控制哥哥的心什麼的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那絕對不行！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼說控制，講得真難聽。",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這位大人注定會和我結為連理……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是我努力讓他只注意我一個人的結果。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳搞錯努力的方向了啦！",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀……",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們意見相左，\n就算繼續和妳說下去，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也不是辦法呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "話說回來……",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n今天也未對我動心呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我原本想著",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天絕對要讓他只愛我一個人的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所謂的愛，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難道對方未對妳動心",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就沒有意義了嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 109011,
        "voice": "vo_adv_5011003_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最喜歡哥哥了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以只是和他在一起，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就覺得很幸福了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為想在一起，所以我會付出行動，",
        "unit_id": 101112,
        "voice": "vo_adv_5011003_039"
    },
    {
