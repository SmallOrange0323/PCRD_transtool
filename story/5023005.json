        "voice": "vo_adv_5023005_033"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各、",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_034"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各位……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "妳們小小聲地在說些什麼？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "碧，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳放心。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸！？",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_036"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我會切嚕的幫妳順利解決。",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_037"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_038"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好……？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
