[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "放學後，大家接到碧的召集，\n{player}一行人聚集在教室裡。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "謝謝大家",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "特地來到這裡。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無所謂，",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我沒關係。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該說，我早就習慣了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感覺這五個人，",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n已經完全是「固定成員」的感覺了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "固定成員，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱垃圾回收場。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我認為這是",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不辱優妮們之名的活動。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "非常令人驕傲。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是啊……",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n發生了一件很糟糕的事情。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是公會名稱遭人擅自改掉了之類的事情嗎？",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還是公會名稱的品味變差了之類的事？",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "忍耐，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要忍耐。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不論在什麼時代，先驅總是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "會遭到很隨便的對待……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛剛特別講座結束後，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n老師所提到的",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "植物。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是的。",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實那個……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的很令人難以啟齒……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可能是我",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "帶來的曼德拉草。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣我就懂了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以校內的池水全部乾涸，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是那個曼德拉草搞的鬼囉。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這麼說起來，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n琪愛兒也有聽到朋友說",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像有什麼奇怪的東西在路上走著～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來是精靈之森的",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "曼德拉草……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從碧妳的證詞來推論，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那個一定是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一種叫做劇毒曼德拉草的變種吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳應該是誤以為它是普通的曼德拉草",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就把它帶來了？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這也不是妳的錯。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n據說就算在精靈之森裡",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它也是非常稀有的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "優妮好厲害！",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n精靈之森的植物，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n知道的人很少耶……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這種算是基礎知識，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還在常識的範圍裡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有沒有、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哈。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐，看妳得意的咧。",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一臉多誇我一點嘛的表情。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "劇毒曼德拉草……",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊！",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n啊～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我剛剛在想一點事情……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該說在回想事情？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過已經沒事了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們來捕捉它吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮",
        "words": "啊！？",
        "unit_id": 1,
        "voice": "vo_adv_5023005_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你們願意幫忙嗎……！？",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "應該說，",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳今天找我們來就是為了這個吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "當然可以，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我會去捉它的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克、",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "克蘿依……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我好高興……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "等等等一下，",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐妳怎麼了！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n要是平常的妳",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一定會說什麼",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "麻煩，好麻煩，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太麻煩了之類的話！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個三段變化怎麼回事。",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我才不會講那種話。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還是",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳今天身體不舒服？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那真的是很抱歉……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我不過是講句積極一點的話",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就要被妳們講成這樣嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真讓人心寒啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以？",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n克蘿依學姐會突然這樣",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是想起了什麼事情嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……算了，",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "告訴你們也沒關係。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n其實啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我在之前工作的……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不對",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是去過的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一間怪怪的店裡，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n曾經有聽說過。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "劇毒曼德拉草。",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n它在黑市裡",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "的價格是――",
