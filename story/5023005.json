        "voice": "vo_adv_5023005_040"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "大家，",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_041"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "竟願意為了我，真的很謝謝妳們……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我身為BB團員，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也要全力以赴……！",
        "unit_id": 110711
    },
    {
        "type": "background",
        "background": "500730"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們就這樣，",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_042"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "把校舍徹底地找了一遍。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後順著就到了外頭來了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n優妮學姐，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳還有沒有什麼冷知識可以分享的嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒，請妳不要隨便覺得我的知識是冷知識好嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想想……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n劇毒曼德拉草",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它的營養來源是空氣中的魔力，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n而完全成熟的個體，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不僅是根部",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它的果實和花都有毒。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒錯。",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不過，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "它的那個毒",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "卻是在各個領域都相當珍貴的東西。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "良藥苦口這句話",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "說得真好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過它",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "離開精靈之森之後成長速度可是鬼級的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不趕快找到它的話，可能會變得很麻煩……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "偏偏它又很狡猾，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會像昆蟲和魚一樣躲起來。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？　",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個倒是沒有記載在書裡面。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真有意思……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是精靈族間口耳相傳的情報嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "印象中好像也有聽過其他相關的東西。",
