    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為琪愛兒太可愛了所以沒辦法扮鬼，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不過克蘿依學姐她只要帶著嚴肅地表情站在暗處就會――",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不、",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_074"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是的……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這扇門的背後，",
        "unit_id": 110711
    },
