        "voice": "vo_adv_5023005_053"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有這招！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來如此……",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是這個。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼說起來守護森林的精靈族……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯？　",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_056"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼什麼什麼？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳們怎麼了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳們竟敢把琪愛兒排除在外，膽子不小嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我可是會哭的喔！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳們不要以為能夠贏過少女的眼淚！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我，",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_057"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可以跟植物和動物說話！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喔？　",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_058"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的假的？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的！",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_059"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n請等我一下！　",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我現在馬上問！",
        "unit_id": 110711
    },
    {
        "type": "background",
        "background": "500760"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……聖德蕾莎女學院裡",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_060"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒想到竟然有這種地方……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "唔，",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_061"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這裡的氣氛是怎麼回事……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "幾乎是個廢墟嘛，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱地下城。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小碧？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "逃走的曼德拉草，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真的在這種地方嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是、",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是的。",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "校舍裡的花朵說",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n看見它進到這個舊校舍裡面……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就算這麼說……",
