        "voice": "vo_adv_5023005_070"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……！",
        "unit_id": 110711,
        "voice": "vo_adv_5023005_071"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n各位，",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "妳們聽見了嗎！？",
