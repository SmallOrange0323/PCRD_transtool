        "voice": "vo_adv_5023005_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n到底是什麼啊～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "早知道打工的時候就該認真一點～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……克蘿依學姐，",
        "unit_id": 110911,
        "voice": "vo_adv_5023005_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們學校可是禁止打工的喔？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我就假裝我沒聽到。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為琪愛兒是個很會看臉色的可愛系女孩喔。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_050"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過植物竟然會有躲藏這樣的習性真令人意外……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這樣一來搜索就變得更加困難了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有沒有什麼計策可以突破現狀啊……",
