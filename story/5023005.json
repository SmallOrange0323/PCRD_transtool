        "voice": "vo_adv_5023005_075"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大禮堂？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "上面是這樣寫的……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
