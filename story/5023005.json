    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "捕捉到曼德拉草。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒、優妮、克蘿依",
        "words": "賭上好朋友社的名字！",
