        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你是能和花朵對話的那種人嗎。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n夢幻可愛系？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "總覺得好像有點……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_052"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟怎麼會突然講出這種童話般的話呢。",
