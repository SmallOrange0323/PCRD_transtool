        "voice": "vo_adv_5023005_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒。",
        "unit_id": 110811,
        "voice": "vo_adv_5023005_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳說的話就像刀一樣銳利。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "優妮學姐",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她的眼神都黯淡下來了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……不、",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_068"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "等等。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳們可別小看我擁有的情報量。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我可是筆記魔，",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_069"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n教職員們曾說過的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一些小小無謂的小事我都有一一記錄下來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "裡面可能有什麼能夠當作線索的東西，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "等我一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "？？？",
