        "words": "妳說舊校舍的大禮堂",
        "unit_id": 111011,
        "voice": "vo_adv_5023005_076"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我曾聽過學院的修女說過……",
