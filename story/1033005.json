[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "接著我就這麼說了，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "「伊麗莎白，妳可是牛呀？」",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很好，到抖包袱的地方都很完美的啦……！",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老是玩雙關語的話觀眾也會膩，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這次我要挑戰看看像搞笑短劇一樣的表演～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然還是利用反覆鋪墊或是故事發展來搞笑，",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才是最棒的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣比起短劇，更像是相聲的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還讓老哥陪我一起想哏，真不好意思啊……",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n謝謝♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。因為是在賣乳製品，",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n沒辦法用比較長的笑話或誇張的反應來搞笑的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要同時假裝跌跤～或是用摺扇打頭，很難的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我才會一邊賣商品，\n一邊說好笑的話說個不停。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣像單口相聲的方式才是最好的啦～",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是我的結論♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}最近也常常幫忙我的工作，",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n有時候也像搞笑搭檔一樣。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是{player}也不是總是都在吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以像單口相聲一樣，一個人也能表演的感覺比較好。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，沒錯。我的搞笑也",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n越來越有模有樣的啦～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這都是{player}，",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你的功勞哦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原本搞笑只是為了吸引客人，\n或是說一邊賣乳製品順便做的表演……",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但如果效果好的話，專心搞笑好像也行得通？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸嘿嘿。\n雖然還不到",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可以吸引客人並收門票的程度。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝啦，{player}。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不管是多無聊的哏，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n{player}都會露出笑容……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我建立起了自信，",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且更加喜歡搞笑了♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果沒有{player}，說不定我途中就放棄搞笑了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "畢竟只是賣乳製品的話，根本不需要說相聲。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n還會被同業當成怪胎。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但最近和{player}一起想的哏都很受歡迎。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這台搞笑攤車也引發了話題，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n客人就因此變多啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我的努力總算沒有白費。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n太開心啦……♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最近真的好幸福的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "每天都很充實，可以一直這樣下去就好啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "就是妳！\n站住，不准動！我們是【王宮騎士團】！",
        "unit_id": 711,
        "voice": "vo_adv_1033005_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇……",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n什、什麼事啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "妳就是真陽嗎？\n哼，跟通緝單上長得一樣……一定沒錯。",
        "unit_id": 711,
        "voice": "vo_adv_1033005_020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "跟我們走！\n妳要是抵抗，可是會吃苦頭喔？",
        "unit_id": 711,
        "voice": "vo_adv_1033005_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊、",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n為什麼啦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個，我有拿到乳製品之類的銷售許可……",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n有按照正確手續申請才銷售的喔？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "哼。那些我們都知道，問題不在那裡。",
        "unit_id": 711,
        "voice": "vo_adv_1033005_024"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n有問題到【王宮騎士團】的拘留所再說。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n總之閉嘴跟我們走。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，別這麼粗魯啊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我知道了，我會一起去的！",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不要再拉我啦，攤車會倒的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n牛奶瓶會打破，商品會浪費掉的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚嗚……",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不要那麼粗魯。要是浪費食物可是會被雷劈的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "喔……你這傢伙竟然拔劍了？",
        "unit_id": 711,
        "voice": "vo_adv_1033005_028"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n竟然敢和【王宮騎士團】對立，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n真不懂分寸！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚哇，不要把事情鬧大啊！",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}快住手，會受傷的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你、你的目標是我吧？",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n要帶我去哪都行，我不會逃也不會躲的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝老哥幫我扶住攤車，讓它不要倒下來！",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是浪費了牛們的牛奶，我就愧對老天爺了啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "不要囉哩八唆的了！",
        "unit_id": 711,
        "voice": "vo_adv_1033005_032"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n你這傢伙，和真陽是一夥的嗎？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "那你也一起走，要是抵抗的話就把你丟到牢房裡去！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "快住手啊～和{player}沒關係的啦！",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要走帶我走就好啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "哼。\n是妳自己說的，那就照妳的意思把妳帶走。",
        "unit_id": 711,
        "voice": "vo_adv_1033005_034"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "不知道是不是因為最近治安惡化，\n有許多人散佈誹謗國王陛下的諷刺畫，",
        "unit_id": 711,
        "voice": "vo_adv_1033005_035"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n或是帶有批評意味的歌曲……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "陛下非常地憤怒。",
        "unit_id": 711,
        "voice": "vo_adv_1033005_036"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n得要一口氣處罰這種人才行。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n妳這傢伙就是其中一人。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊？\n我才沒有說國王的壞話的啦！",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是誤會！\n搞笑是讓人幸福的東西。",
        "unit_id": 103311,
        "voice": "vo_adv_1033005_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我絕對不會表演那種讓人不愉快的哏！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "哼，",
        "unit_id": 711,
        "voice": "vo_adv_1033005_039"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "別吵了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n有問題到【王宮騎士團】的拘留所再說，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n給我過來！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "真是太愚蠢了……不應該沉溺在搞笑那種低俗的文化中，",
        "unit_id": 711,
        "voice": "vo_adv_1033005_040"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n為陛下努力揮汗工作就好了！",
