        "type": "dialogue",
        "name": "倭",
        "words": "喂～",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_042"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "貪吃公主手下的鎧甲團！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n要追我也是可以，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n但這裡還有一個，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "通緝犯喔──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘿！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "哇",
        "unit_id": 811,
        "voice": "vo_adv_1300001_043"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "啊啊啊啊！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n不、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "不要把我丟出去啊啊啊！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "嗯？",
        "unit_id": 712,
        "voice": "vo_adv_1300001_044"
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "這張臉……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "是假求助強盜的成員！？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "\n──逮捕了！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "怎麼這樣！",
        "unit_id": 811,
        "voice": "vo_adv_1300001_045"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈哈哈！",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_046"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……那麼，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我也趁這個機會閃人吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子你也別一直迷迷糊糊的。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_047"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n偶爾也要懷疑別人。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──再見了！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "怎麼了，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_048"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "連小子你也要追著我啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我是沒關係，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但你跟得上小偷逃跑的速度嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n來啊來啊，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來啊來啊♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……小子你，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_049"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "意外的很難纏呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "什麼？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你說什麼？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "有想跟我說的話？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "………………",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_050"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你的理解力真差。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我剛剛不是說過了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "才不是為了小子你呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你說什麼？",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_051"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你說我雖然說很討厭狡猾的小偷，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n但【蠻賊三姊妹】對格羅哥團做的事，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "也大同小異？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所以剛剛的解釋……",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_052"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不合邏輯？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n……小子……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你這傢伙……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你是在說",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_053"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我講的話沒有信用嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所以怎樣……",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_054"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n其實是我想幫你才出手幫忙的……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你是想這樣說嗎！",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_055"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n啊啊啊啊啊啊！？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "………………",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_056"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "………………",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_057"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哼──哈哈哈！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_058"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你啊…………",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "看起來迷迷糊糊的，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_059"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "卻蠻會說話的嘛。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哼。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_060"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "已經被拒絕兩次，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_061"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我本來打算要放棄了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但果然就這麼放過你還是太可惜了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……呵呵呵。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_062"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "俗話說事不過三，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對吧♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_063"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "沒錯。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就如你所說。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我是為了幫你，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "才搶走布巾包裹的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再怎麼說我都是做竊盜事業的。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_064"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "和商人不同，買賣不是我的本分。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我是喜歡拿走別人的東西，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但不喜歡賣人情。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想要的東西用自己的力量獲得就好。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_065"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我可沒有",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "即使拿人情當擋箭牌，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n也想要讓他人做的事。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……這個嘛，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_066"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我直到剛剛都是這麼想的……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但看來即使是我，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_067"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n也有憑自己的力量無法如願的事。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所以說現在，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_068"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n就讓我期待一下小子的報恩吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然這是把沒什麼勝算的賭注──",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──跟我來！",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_069"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n都是為了幫你",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "害得我被鎧甲團縮短距離了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n作為補償你就跟著我一天，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "幫我把風吧！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "然後也順便……",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_070"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n讓和若菜一樣不經事的你",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "累積一下社會經驗……♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被倭拉著手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "消失在蘭德索爾昏暗的巷弄中。"
    }
]