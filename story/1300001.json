[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天的蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}正在追逐"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拿著布巾包裹的倭。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我不要。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這世上哪有說還就還的盜賊啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你很拼命嘛。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_001"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n也就是說……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這個布巾包裹裡，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "放了相當高級的東西是嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那就讓我來好好鑑定看看♪",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘿",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "咻！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──哼！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──時間回到幾分鐘之前。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n事情的開端，是走在街上的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇到了一位老婆婆。"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嘿咻，",
        "unit_id": 611,
        "voice": "vo_adv_1300001_003"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嘿咻……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "啊，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "腰好痛啊……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呼……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1300001_004"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我還想說怎麼突然變輕了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "小哥要幫我拿嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這其實是我們家的傳家之寶，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "但實在是太重了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "真是幫了大忙，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "太謝謝你了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "但是重物都給你拿",
        "unit_id": 611,
        "voice": "vo_adv_1300001_005"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "太不好意思了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "小哥的劍",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "也是很重要的東西吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我幫你拿吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n要是碰撞傷到",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就不好了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼。",
        "unit_id": 1,
        "voice": "vo_adv_1300001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "傳家之寶嗎。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n聽到不錯的情報了呢♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……？",
        "unit_id": 611,
        "voice": "vo_adv_1300001_007"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n妳",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是誰？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我的名字不重要啦。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_008"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n就只是個盜賊而已。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "盜、",
        "unit_id": 611,
        "voice": "vo_adv_1300001_009"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "盜賊！？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n光、",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "光天化日之下",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "怎麼會出現在這裡……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那是我想說的。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_010"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n很不巧，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我也很喜歡拿走別人的東西呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──所以……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那個傳家之寶我就收下了！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哎呀嘿咻♪",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_011"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那麼，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再見啦！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊？",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_012"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "恕我拒絕。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "很不巧已經有人先跟我約好玩你追我跑了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你看看，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你的背後。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "找到了！",
        "unit_id": 712,
        "voice": "vo_adv_1300001_013"
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "倭在那邊！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "\n快追！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "士兵長",
        "words": "給我追──！",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我只是和沒教養的惡棍們打個招呼而已，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那群鎧甲團",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就變了個眼神追上來了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就這麼喜歡我嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "算了。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_015"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "被追也有被追的快樂，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這就是盜賊的天性啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我不要。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這世上哪有說還就還的盜賊啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你很拼命嘛。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "也就是說……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這個布巾包裹裡，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "放了相當高級的東西是嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那就讓我來好好鑑定看看♪",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_018"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘿",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "咻！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──哼！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──！！"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "倭將布包巾包裹丟向地面。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從裡面出現的是──一點也不適合被稱為傳家之寶的，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n垃圾堆。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_019"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我就知道是這樣。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子你被太多女生利用了啦。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_020"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不要愣在那邊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你看那邊的街道！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "倭的手指向的地方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有拿著沉重布包巾包裹的老人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和打算去幫助他的青年──"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不好意思呢。",
        "unit_id": 511,
        "voice": "vo_adv_1300001_021"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n讓你拿這麼重的東西。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "不會不會。",
        "unit_id": 311,
        "voice": "vo_adv_1300001_022"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "這是傳家之寶對吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n我幫你拿到目的地那邊。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "啊那麼，",
        "unit_id": 511,
        "voice": "vo_adv_1300001_023"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "小哥你的東西，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "就換我來拿著吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n這點程度的話我也拿得動。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那就麻煩你了。",
        "unit_id": 311,
        "voice": "vo_adv_1300001_024"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "嘿",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "咻",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "──",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "好咧……",
        "unit_id": 511,
        "voice": "vo_adv_1300001_025"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "（歪嘴笑）。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "──抱歉啦小哥。",
        "unit_id": 811,
        "voice": "vo_adv_1300001_026"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n這些東西我就收下了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "……",
        "unit_id": 311,
        "voice": "vo_adv_1300001_027"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "咦咦！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我的東西！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n裡面有我的錢包跟鑰匙……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "話說，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那傢伙根本不是老爺爺啊！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "咦，",
        "unit_id": 311,
        "voice": "vo_adv_1300001_028"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那這個傳家之寶是……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "──！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n哇啊啊啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "裡面就只有石頭啊──！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……就是這樣。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_029"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你懂了吧小子？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那群傢伙是熟練的盜賊集團。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_030"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n打算拿走你的劍的那傢伙也是用同樣的手法。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "最近流行起",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_031"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "叫做「假求助強盜」的手法。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "利用人的善意，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "直接奪走交給他拿著的東西。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所有傢伙都裝成老人的樣子，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_032"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "其實都是年輕的小偷。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "明明到處都有貼通緝令，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_033"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n沒想到還會有這麼多人上那種人的當啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "蘭德索爾真是個愚蠢的城鎮。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_034"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "勉強算是逃過一劫了呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n如果是很重要的東西，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "最好片刻不離地帶在身上。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……什麼？",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_035"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "別說傻話了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n為什麼我要幫你啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……看到那種狡猾的傢伙，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_036"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我就會很不爽。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想要的話就直接搶走就好不是嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不需要做出這種拐彎抹角的事情。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所以才不自覺的，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_037"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就想出手妨礙而已。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "很可惜，不是為了你。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "話說，",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_038"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n──那個狡猾的小偷，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "正在往這個方向逃呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這樣啊，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "【王宮騎士團】在追他……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "閃開！",
        "unit_id": 811,
        "voice": "vo_adv_1300001_039"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "別擋路！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n閃開閃開！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──嘿咻。",
        "unit_id": 130012,
        "voice": "vo_adv_1300001_040"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "哇哇！？",
        "unit_id": 811,
        "voice": "vo_adv_1300001_041"
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "唔哦哦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "──妳這傢伙……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "強盜",
        "words": "是故意絆倒我的吧！",
