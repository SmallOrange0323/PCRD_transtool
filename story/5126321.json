[
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇哇哇！",
        "unit_id": 127311,
        "voice": "vo_adv_5126321_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是什麼魔法！？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n難道阿爾杰什寶",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n其實是那種超不妙的魔物！？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有火、雷，",
        "unit_id": 127211,
        "voice": "vo_adv_5126321_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有冰跟風……！？",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼亂七八糟的魔力啊！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難怪能在傳說當中留名呢……！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鈴奈，",
        "unit_id": 127211,
        "voice": "vo_adv_5126321_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "小心那傢伙放出的魔法球！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是被打中可就不妙了！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 127311,
        "voice": "vo_adv_5126321_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "知道了凱留寶！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就算沒想好怎麼辦，還是先衝上去──！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，妳根本就沒有聽懂嘛！！",
        "unit_id": 127211,
        "voice": "vo_adv_5126321_004"
    }
]