[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "休假中的望約{player}\n一起出來散步。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "久違的休假！\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總算能好好放鬆了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天要痛快地玩喔！\n和{player}在一起的話，",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定會有個最棒的休假！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，不過要小心不能太過招搖。",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n被粉絲們發現的話，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "休假就會泡湯了呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？怎麼了？",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那邊有什麼――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇，這道光是什麼！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好、好刺眼……呀啊啊啊！！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，{player}！\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這邊這邊――！快過來――！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉喔，突然把你叫出來！",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有一份工作突然取消了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難得時間空了出來，\n下一份工作開始前，會想做點開心的事吧？",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以我才叫你來的！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然時間不是很充裕，\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就盡情地玩樂吧！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們要去哪？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "啊！你看！",
        "unit_id": 1131,
        "voice": "vo_adv_1029004_009"
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "\n那個電視牆上現在播著望望的節目喔！",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？會是什麼呢？之前錄製的歌唱節目嗎？",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是電影的廣告呢？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "節目司儀",
        "words": "「人氣偶像櫻井望的戀人曝光！？」",
        "unit_id": 1,
        "voice": "vo_adv_1029004_011"
    },
    {
        "type": "dialogue",
        "name": "節目司儀",
        "words": "\n本日發行的週刊雜誌，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "節目司儀",
        "words": "\n刊登了這個獨家消息……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個節目……",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在播放我的戀愛八卦！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唉～真是討厭！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種新聞都是胡說八道的！\n我只是在拍攝現場跟共同演出的人說話而已。",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "照片雖然看起來只有我們兩個人，",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但旁邊其實還有很多工作人員。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想一定很快就會有報導澄清這件事。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種八卦的報導",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不能相信喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n沒憑沒據的，都是在騙人。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果現在被拍到你和我在一起的照片，",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一定會被報導寫成「和普通人熱戀曝光！」？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那、那樣啊……？",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，感覺好害羞喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……哼，你會很困擾？",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然我能理解你的心情，但也不用那麼強烈地否定吧……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "反正我們只是在聊天而已，",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n應該不至於被拍到那樣子的照片――",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "喂，",
        "unit_id": 1031,
        "voice": "vo_adv_1029004_020"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "你們看，那不是望望嗎！？",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "哇！",
        "unit_id": 1231,
        "voice": "vo_adv_1029004_021"
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "真的耶！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "\n我是她的鐵粉～！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，不好了！",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被發現了！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎、",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼辦……！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n越來越多人靠過來了！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "欸，在她旁邊的人是誰啊？",
        "unit_id": 1031,
        "voice": "vo_adv_1029004_024"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n感覺不像是經紀人耶？",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "粉絲２",
        "words": "難道是……戀人！？",
        "unit_id": 1231,
        "voice": "vo_adv_1029004_025"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "什麼！？\n你說是望望的戀人！",
        "unit_id": 1031,
        "voice": "vo_adv_1029004_026"
    },
    {
        "type": "dialogue",
        "name": "粉絲１",
        "words": "\n那種事真令人羨……不可饒恕！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總之快逃跑吧！\n",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這種時候說什麼也沒用！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "快點，從這邊走就能逃掉了！",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n抓住我的手！",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼、",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n逃到這裡他們應該就不會再追來了吧。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一直牽著你的手……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且還硬拉著你跑……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但那也沒辦法啊。",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n當時只能選擇逃跑了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果報紙刊登那樣的新聞，\n我說不定就不能和你再見面了……",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我討厭那樣子。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！不好了！",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n下一份的工作時間到了！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結果完全沒玩到～！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉，我一定會再約你的！",
        "unit_id": 102931,
        "voice": "vo_adv_1029004_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以到時你要陪我玩喔！",
        "unit_id": 102931
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1029004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1029004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，望也真辛苦……",
        "unit_id": 190011,
        "voice": "vo_adv_1029004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大紅人想在外頭隨便走走都不行呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「那邊」當然不在話下，而「這邊」也是，\n因為望是大家的偶像，",
        "unit_id": 190011,
        "voice": "vo_adv_1029004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要小心點比較好呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望你要多加注意，",
        "unit_id": 190011,
        "voice": "vo_adv_1029004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不要做些奇怪的事情，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妨害到望的偶像活動喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那這次我就在這裡失陪了。",
        "unit_id": 190011,
        "voice": "vo_adv_1029004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？ 這裡是……？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我睡著了嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我好像做了個奇怪的夢……\n是什麼夢啊？",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我和你在一起的時候，\n你卻被粉絲們誤會成我的戀人……",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你也做了同樣的夢？",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔，真不可思議呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n會不會是什麼特別的夢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "比如說預知夢之類的――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "路人１",
        "words": "啊！是望望！",
        "unit_id": 411,
        "voice": "vo_adv_1029004_045"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "欸，她旁邊有個男人！？",
        "unit_id": 311,
        "voice": "vo_adv_1029004_046"
    },
    {
        "type": "dialogue",
        "name": "路人２",
        "words": "\n該不會是戀人吧！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！",
        "unit_id": 102911,
        "voice": "vo_adv_1029004_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "？\n真、真的是預知夢啊！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們快逃！",
        "unit_id": 102911
    },
    {
