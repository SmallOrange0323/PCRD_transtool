        "voice": "vo_adv_9072155_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好熱──！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難得感覺很涼爽啊──！",
