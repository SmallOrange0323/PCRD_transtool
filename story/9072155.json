    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好、",
        "unit_id": 106412,
        "voice": "vo_adv_9072155_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好熱……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼大家都要貼在我身上？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n像在玩擠饅頭遊戲一樣……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這當然",
        "unit_id": 105913,
        "voice": "vo_adv_9072155_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是為了不讓雪菲小姐迷路。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對不是因為，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐的翅膀跟尾巴冷得恰到好處，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貼在一起會非常舒服……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對不是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺就是",
        "unit_id": 106012,
        "voice": "vo_adv_9072155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不會融化的冰呢～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是沒有雪菲已經無法在吉歐‧格黑納活下去了啊～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣可不行呢……",
        "unit_id": 105812,
        "voice": "vo_adv_9072155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好想就這樣永～遠地、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "緊緊地～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……抱著小雪菲……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太沒有",
        "unit_id": 106412,
        "voice": "vo_adv_9072155_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "危機感了！",
