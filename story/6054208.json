    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像這樣肩併著肩逛街購物，",
        "unit_id": 114511,
        "voice": "vo_adv_6054208_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "坐在路邊長凳上閒聊，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還真是挺開心的。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是到時候，",
        "unit_id": 114511,
        "voice": "vo_adv_6054208_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "搞不好又要麻煩你提東西了。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……你說那樣也很開心？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還真符合你的個性呢。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過其實我也是。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要和你在一起，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不管做什麼都讓人感到開心。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啊。",
        "unit_id": 114511,
        "voice": "vo_adv_6054208_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這次幸虧有你，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才終於能放鬆一下。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n謝謝你。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "約會……",
        "unit_id": 114511,
        "voice": "vo_adv_6054208_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎唷，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你是在逗著我玩的吧？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不過，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啊。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反正我也喜歡",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟你獨處時無拘無束的感覺，",
