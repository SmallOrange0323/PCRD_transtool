    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──呼、",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哈……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n到頭來還是衰事不斷啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "累、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "累死我了～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105911,
        "voice": "vo_adv_4003018_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算還是將仙人掌拿到手了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然被哥布林吃掉了一半左右，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但數量還是不少。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿嘿～♪",
        "unit_id": 105811,
        "voice": "vo_adv_4003018_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有好多傳說中的仙人掌！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n直接豪邁地大口咬下去吃吃看吧♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來來來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲也來一個！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔、",
        "unit_id": 106411,
        "voice": "vo_adv_4003018_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我其實有點吃不下口耶……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那些哥布林",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一直在不遠處死盯著我們看……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎樣啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們已經吃得夠多了吧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哥布林！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你們的皮膚因為美肌效果都變得光滑剔透了不是嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那個，",
        "unit_id": 106411,
        "voice": "vo_adv_4003018_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "各位。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然這些仙人掌是我們好不容易才找到的……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但我覺得",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "全部帶走",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "實在是不太好。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳幹嘛突然這樣說？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是，",
        "unit_id": 106411,
        "voice": "vo_adv_4003018_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我有點在意一件事。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這附近的土地上",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n好像沒有其他可以吃的東西……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_4003018_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，外面是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寸草不生的沙漠地帶……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而這座遺跡之中除了仙人掌，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也沒有看到其他\n感覺可以食用的東西。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對我們而言是傳說中的仙人掌，",
        "unit_id": 106411,
        "voice": "vo_adv_4003018_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但對哥布林而言，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這或許也是牠們在這片土地上",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n少數可以穩定取得的食物。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔唔、",
        "unit_id": 105811,
        "voice": "vo_adv_4003018_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽妳這麼一說……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我不禁開始覺得哥布林好可憐了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子扁扁的悲傷之情",
        "unit_id": 105811,
        "voice": "vo_adv_4003018_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是再了解不過了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們把這些仙人掌",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "分享給大家吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "首先來吃和好的一口♪",
        "unit_id": 105811,
        "voice": "vo_adv_4003018_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來來來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起來……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊呣。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～甜～喔～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊啊，",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搞什麼！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "個個都像是餓死鬼投胎一樣！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們都先給我坐好，哥布林們！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也一樣！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105811,
        "voice": "vo_adv_4003018_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也要嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽好了。",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種仙人掌",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只要經過加工就會變成秘藥。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然這是你們唯一的食物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那就不該一口氣吃光光，而是要將它更有效地利用──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哥布林們",
        "unit_id": 105911,
        "voice": "vo_adv_4003018_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都跪坐著在專心聆聽呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來貪吃佩可小姐跟凱留小姐的心意",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠們接收到了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好、",
        "unit_id": 106411,
        "voice": "vo_adv_4003018_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好像是。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還有一些哥布林在膜拜凱留，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n莫非是",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "把她當成新的大王了……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──喂，那個誰，",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不能站起來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我才講到一半耶！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個盆栽",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是怎樣……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是要送給我們嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇，",
        "unit_id": 105811,
        "voice": "vo_adv_4003018_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好可愛的仙人掌喔～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種大小的話",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺沒什麼飽足感……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這不是",
        "unit_id": 106411,
        "voice": "vo_adv_4003018_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "仙人掌的植栽嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "牠們可能是想要我們",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "將它養大之後再食用吧。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105911,
        "voice": "vo_adv_4003018_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是好東西跟好朋友分享的意思呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要養大它應該需要不少時間……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不如我們只採集少量蜜汁",
        "unit_id": 105911,
        "voice": "vo_adv_4003018_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做成糖漿，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然後配鬆餅之類的來吃如何？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸～",
        "unit_id": 106011,
        "voice": "vo_adv_4003018_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不錯喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n正好我肚子也開始餓了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就來試做看看吧。",
        "unit_id": 106011
    },
    {
