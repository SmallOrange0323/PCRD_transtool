    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "只能靠我自己來做。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "再說，",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_047"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "像我這種",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "有前科的人說的話，\n沒有人會",
