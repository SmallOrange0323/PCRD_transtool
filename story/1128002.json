[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真陽和{player}順利參加完講習，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在回牧場的路上。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是獲益良多呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比起自己胡亂訓練，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "學習到正確知識後\n再加以實踐，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "效果完全不同的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "託講習的福，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我覺得我有稍微變強了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你呢？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這倒也是。",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這種技術能不用就不用。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "公會的大家可以開心生活",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才是最重要的。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有效率的重量訓練",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "和正確的運動姿勢",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n其實對我們酪農也有很大的幫助。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "技術不分好壞，重點是怎麼去使用。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊啊，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對了！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在回牧場前，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可以稍微繞個遠路嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "前面有一座農村，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我常常去那邊進貨稻種。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n都來到附近了，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我想順道去看看。",
        "unit_id": 112811
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "終於到了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不管什麼時候來",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這座村子都是這麼閒適，真棒──",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你夠了吧！",
        "unit_id": 1,
        "voice": "vo_adv_1128002_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "噫！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼了？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛才的聲音是？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這座村子和平到連吵架都十分罕見，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "竟然傳出了這種怒吼聲……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一定發生了",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什麼大事了啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說不定",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "馬上就需要運用講習的成果了……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們快去看看！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在那裡！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "農夫們都聚在一起。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n怎麼了！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不要使用暴力的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "嗯？",
        "unit_id": 511,
        "voice": "vo_adv_1128002_011"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "妳不是牧場的小妹妹嗎。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n妳這身打扮",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "是怎麼回事啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "新的搞笑哏嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這件事現在不重要啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比起這個，到底發生什麼事了啊？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我聽到一聲不尋常的大吼",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就飛奔過來了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "真傷腦筋啊……",
        "unit_id": 511,
        "voice": "vo_adv_1128002_014"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "被外人看到",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "丟臉的一幕了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n原因就出在這傢伙身上。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我沒看過他耶。",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是最近才搬來的居民嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "沒錯。",
        "unit_id": 511,
        "voice": "vo_adv_1128002_017"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "這傢伙以前是個不良分子。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n但最近洗心革面",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "開始務農了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也就是說，比起傷害他人，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "他選擇以生產每天的糧食為生。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這不是好事嗎，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有什麼問題嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "因為這傢伙",
        "unit_id": 511,
        "voice": "vo_adv_1128002_019"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "常常工作到一半就不知道跑到哪去了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n只會偷懶根本不認真工作。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫2",
        "words": "我曾經在晚上",
        "unit_id": 1411,
        "voice": "vo_adv_1128002_020"
    },
    {
        "type": "dialogue",
        "name": "農夫2",
        "words": "看到他跑到村子最外圍那裡去喔？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農夫2",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農夫2",
        "words": "他原本就是不良分子，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農夫2",
        "words": "會不會私底下跟壞蛋們在做什麼交易啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "農夫3",
        "words": "而且他還常常受傷，",
        "unit_id": 311,
        "voice": "vo_adv_1128002_021"
    },
    {
        "type": "dialogue",
        "name": "農夫3",
        "words": "真的很可疑耶。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_022"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "不管怎麼問，",
        "unit_id": 511,
        "voice": "vo_adv_1128002_023"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "他都像這樣一語不發。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n實在太傷腦筋就忍不住對他大吼了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫2",
        "words": "但他完全不否認，不就代表……",
        "unit_id": 1411,
        "voice": "vo_adv_1128002_024"
    },
    {
        "type": "dialogue",
        "name": "農夫3",
        "words": "讓這種傢伙留在村子裡太危險了吧？",
        "unit_id": 311,
        "voice": "vo_adv_1128002_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "快住手啦！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家都是同村的夥伴吧？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n怎麼可以說出這樣的話！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "可是啊，",
        "unit_id": 511,
        "voice": "vo_adv_1128002_027"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "小妹妹，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n事實上村裡的女人和小孩都很怕這傢伙。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "一旦出了什麼事就太遲了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……我知道了，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這邊就交給我和老哥的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n由第三者的我們來",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聽聽他的說法。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聽完之後再做判斷也不遲吧？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "……我知道了。",
        "unit_id": 511,
        "voice": "vo_adv_1128002_029"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "那麼就先交給你們了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……那麼，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然無意間說出了那樣的漂亮話，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但接下來該怎麼做呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這位小哥",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "從剛才開始就一句話都不說……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那不就只能靠我了嗎！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓我來說個珍藏已久的農村搞笑吧！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊～",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這位小哥還有村子裡的大家都先冷靜一下吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難得這裡種了這麼多好吃的作物，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n大家先吃點青菜再談談吧，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "多吃青菜人生才會精彩嘛～！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你笑得這麼開心也沒用啊……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "冷場的搞笑就不要再解釋了！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這樣最讓人難受了！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那我只好單刀直入地問了。",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n小哥你",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼要偷懶啊？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你討厭",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "務農嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……不是這樣。",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "終於願意開口了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那個，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可以的話，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能不能帶我們去你平常去的地方呢？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……往這走。",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_039"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就是這裡。",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_040"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這裡",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是村子的最外圍吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "的確，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這裡幾乎沒有人會來，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "很適合偷懶。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是離田這麼遠也太麻煩了吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_042"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只有這裡的牆毀損",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且做過了緊急處置。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣的話，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果有魔物來就危險了……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_043"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難道說，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小哥你是來確認牆壁的狀況的嗎！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……沒錯。",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_044"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我很習慣戰鬥了，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以我就獨自巡邏，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n把魔物趕跑。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來你是因為這樣才會受傷啊。",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_045"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果是這樣的話，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要老實跟大家說就好的啦。",
