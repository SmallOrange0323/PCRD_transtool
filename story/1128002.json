        "type": "dialogue",
        "name": "真陽",
        "words": "試著好好說清楚吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n現在的你應該做得到吧？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……嗯。",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_066"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "各位聽我說，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實我──",
        "unit_id": 1111
    },
    {
        "type": "background",
        "background": "500331"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "事情就是這樣。",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_067"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒辦法完全信任村子裡的大家、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n想靠自己來解決問題的小哥也需要檢討。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "……",
        "unit_id": 511,
        "voice": "vo_adv_1128002_068"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "不，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "在看見這副景象之後，也只能相信你了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n而且我們也單憑你曾經是個不良分子這點，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "就對你抱有成見。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "如果從一開始就被別人懷疑，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "就更難說出口了吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "真對不起。",
        "unit_id": 511,
        "voice": "vo_adv_1128002_069"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "也",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "謝謝你保護了村子。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_070"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒關係。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我也做了讓你們誤會的行為，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱歉。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "關於這件事啊，",
        "unit_id": 511,
        "voice": "vo_adv_1128002_071"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "以後可以繼續拜託你幫忙巡邏嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "還有，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "如果你願意的話，也請你教我們最基礎的戰鬥方法。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "再怎麼說也不能把危險的工作都推給你啊。",
        "unit_id": 511,
        "voice": "vo_adv_1128002_072"
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "\n往後",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "農夫1",
        "words": "大家一起努力守護這個村子吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……我知道了。",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_073"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這樣的話",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "也請你們教我蔬菜的種植方法。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我有想種的東西。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯嗯，",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_074"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是所謂的適才適所啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是一群好夥伴啊。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n務農是沒辦法單靠自己一個人的！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_075"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來事情也完美告一段落了，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這時候就讓我來展現個必殺搞笑段子──",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性、農夫1",
        "words": "那倒是不必了。",
        "unit_id": 1,
        "voice": "vo_adv_1128002_076"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦、",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_077"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦哦，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "立刻就團結一心了啊……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哎呀，",
        "unit_id": 1111,
        "voice": "vo_adv_1128002_078"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "對妳真的是",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "滿滿的謝意啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n謝謝妳，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我一定會",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "種出很好吃的蔬菜，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "到時候記得再來啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯！",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_079"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我很期待的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "替村民們建立起羈絆的真陽，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著滿臉笑容離開了村子。"
    }
]