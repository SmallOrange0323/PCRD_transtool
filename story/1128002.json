    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我在外面也常忍不住就想幫助別人。",
