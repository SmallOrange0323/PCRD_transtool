    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你一定要好好地讓村民們明白",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n你的專長以及你的努力。",
