    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你在說什麼啊。",
        "unit_id": 112811,
        "voice": "vo_adv_1128002_048"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n都還沒去說過不要擅自下定論好嗎。",
