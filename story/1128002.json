    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還真愛多管閒事啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n連像我這種剛認識的人妳都要照顧。",
