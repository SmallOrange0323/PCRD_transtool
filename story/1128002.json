        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "又或者是外表獨特的孩子，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家都有自己的專長",
