[
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是……",
        "unit_id": 122012,
        "voice": "vo_adv_5092204_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不知道是不是在呼應守護者的氣息，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n殘留在整座島嶼的意念",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "越來越強大了。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來如此，",
        "unit_id": 101411,
        "voice": "vo_adv_5092204_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n原生的魔物",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從剛剛開始就不斷在活化",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是這個原因啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "問題並不是只有這樣。",
        "unit_id": 122012,
        "voice": "vo_adv_5092204_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣下去",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "島嶼本身也會受到影響，",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n最壞的情況",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說不定會有崩壞的危險。",
        "unit_id": 122012
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那我們可不能悠哉下去呢。",
        "unit_id": 121912,
        "voice": "vo_adv_5092204_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "應該盡速",
        "unit_id": 121912
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓守護者停下來！",
        "unit_id": 121912
    }
