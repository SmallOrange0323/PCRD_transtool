        "type": "dialogue",
        "name": "早熟的少女",
        "words": "呵呵呵，",
        "unit_id": 211,
        "voice": "vo_adv_1290003_065"
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "那真是太好了──",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "哎呀？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "剛剛，好像看到入口有人影……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "那是……！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "我美麗的孫女啊。",
        "unit_id": 1,
        "voice": "vo_adv_1290003_066"
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "\n我來迎接妳了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "爺爺！",
        "unit_id": 211,
        "voice": "vo_adv_1290003_067"
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "我馬上過去！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "……",
        "unit_id": 211,
        "voice": "vo_adv_1290003_068"
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "大姐姐，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "祝妳的戀情能開花結果。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "再會！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "真是讓妳久等了呢。",
        "unit_id": 1,
        "voice": "vo_adv_1290003_069"
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "\n處理事情花了點時間……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "\n沒有讓妳感到寂寞吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "一點都不會！",
        "unit_id": 211,
        "voice": "vo_adv_1290003_070"
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "\n因為我，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "也和爺爺一樣",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "早熟的少女",
        "words": "在擔任愛的使者呀♪",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "呵呵呵，",
        "unit_id": 1,
        "voice": "vo_adv_1290003_071"
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "那還真是做了件很美好的事呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "就先去買個玫瑰吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "\n為了妳的行動，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女的祖父",
        "words": "和未來的戀人們……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個男人……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_072"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好像在哪個記錄中看過……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_073"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒事的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我沒有等很久。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不是喔。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_074"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只是個什麼都不知道的第三者。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_075"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒什麼。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n別在意。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_076"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我說，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n關於之後的行程……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我有幾個，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_077"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "想去看看的地方……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可以嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "其實，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "蘭德索爾有幾間",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我有興趣的店鋪。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……謝謝你們。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_078"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_079"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並不是被那孩子所說的話給影響了。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但騎士先生他，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "想要和我一起共度時間。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n也想創造出更多的回憶。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生他……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_080"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "正在看著，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我們的未來。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……那樣的話。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_081"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我也同樣地，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要向前邁進才行。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "想要了解騎士先生……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_082"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n就只能靠我們自己來創造。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……沒錯。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "創造更多，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我們兩人的回憶……",
        "unit_id": 129011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那麼……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_083"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我們走吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "跟我來，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_084"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呵呵。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，他們悠閒地度過了兩人時光……"
    }
