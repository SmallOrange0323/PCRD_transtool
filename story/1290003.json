[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天的蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和厄莉絲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正站在人山人海的鬧區一角。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人透過連接著「背面世界」出入口和蘭德索爾的轉移魔法陣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……人",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……真多呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和泰美斯銀嶺相比，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是吵雜了一點……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是沒有問題。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n相對的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這裡氣溫很暖和，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也有鋪設道路所以走起來很輕鬆。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…謝謝你，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這樣子關心我。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那麼……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我們，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就來散散步吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}的帶領下走在蘭德索爾街道上的厄莉絲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊回想著過去。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……蘭德索爾。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生在這個世界的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "活動據點。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我知道這座城鎮。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n因為早已看過了，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無數次記錄。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n像這樣走在街上……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是第一次。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也不能說，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我對此沒有任何想法……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "從我被幽禁的索爾之塔來看……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這裡實在是非常相近，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "同時卻又很遙遠的地方。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這座城鎮的各處，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都有著騎士先生的痕跡。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和我以外的某人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "加深羈絆的痕跡。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……以及。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我們重逢的痕跡。",
        "unit_id": 129011
    },
    {
        "type": "still",
        "still": "128900102"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……雖然和那時比起來，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "現在的情況變了很多……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但如果沒有那些變化的話。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n現在，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也不可能和騎士先生一起在這個地方。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為如果我的願望實現了。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這裡全部，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "都會被破壞並被火焰所吞噬。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這也是……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "事實。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣的事實，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我該怎麼接受才好……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n真令人煩惱。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_016"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……嗯。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_017"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "光是能近距離看到騎士先生高興的模樣，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_018"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我就覺得，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "很開心。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對現在的我來說，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_019"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣就已經足夠了。",
        "unit_id": 129011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接下來一段時間，{player}和厄莉絲愉快地散步著。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人為了吃東西順便休息一下，而前往了某間餐廳。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "………",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_020"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "抱歉，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_021"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n可以晚一點",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再點餐嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "謝謝。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_022"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_023"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "該選哪個好呢……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "之前，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_024"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生來這間店時點的品項……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n他看起來覺得很滿意的品項……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這些我都一清二楚。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是當然的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就選他點過的吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然時間上慢了，但還是想跟他分享我的感受。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……說是這麼說。",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_025"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n但我也不可能全部都點。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "必須選擇最合適的餐點才行。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "今天在這之後還會一起行動……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_026"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以要避開味道太重的。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還有",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "需要張大嘴巴才能吃的也不行。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "分量太多的，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也不要。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有可能會阻礙行動。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "說到底……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_027"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我的身體，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "到底需要多少的能量呢。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只要用充裕的魔力",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_028"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "稍微下點功夫，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就能夠忘掉飢渴。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而且，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "米奈娃幫我準備的修復裝置裡",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也充滿了能量。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……從以前到現在，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我都沒有感受過飢餓。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在不了解飢餓的情況下，",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_029"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只靠推測來採取行動會很危險。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這時候",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還是點杯飲料就好吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……但是，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "偏偏光飲料",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就有很多選項。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……這樣的話……",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_030"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…",
        "unit_id": 129011,
        "voice": "vo_adv_1290003_031"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…騎士先生有什麼推薦的嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我只要飲料就好……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n厄莉絲成功地進行了初次的點餐。"
    },
