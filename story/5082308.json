[
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，",
        "unit_id": 120811,
        "voice": "vo_adv_5082308_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "已經無處可逃了吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你跑我追的遊戲也到此為止了。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是的，",
        "unit_id": 120911,
        "voice": "vo_adv_5082308_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "給人多費這麼多力氣。",
        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你竊走的",
        "unit_id": 120711,
        "voice": "vo_adv_5082308_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不僅僅是食材而已，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那是大家期待的",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "年菜材料……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "代表著充滿笑容的新年呀。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 120811,
        "voice": "vo_adv_5082308_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "說得沒錯。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n講得很好嘛。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是這樣。",
        "unit_id": 120911,
        "voice": "vo_adv_5082308_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n納命來吧！",
        "unit_id": 120911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "將我們的新年，",
        "unit_id": 120711,
        "voice": "vo_adv_5082308_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還回來！",
        "unit_id": 120711
    }
]