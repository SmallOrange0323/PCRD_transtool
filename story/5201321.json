[
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "以四季為主題的能力，",
        "unit_id": 133811,
        "voice": "vo_adv_5201321_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是吧。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還真是花費心思製作出來的魔物呢。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為是真那用心特製的呀～",
        "unit_id": 133711,
        "voice": "vo_adv_5201321_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n當然不可能會放水的。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "強度的部分也格外精緻。",
        "unit_id": 133911,
        "voice": "vo_adv_5201321_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想起教授打算做多餘調整的時候",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n兩人之間那股一觸即發的氣氛了。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……教授這個人，",
        "unit_id": 133811,
        "voice": "vo_adv_5201321_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是喜歡調整戰鬥平衡呢。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但他的強度基準太奇怪，",
        "unit_id": 133711,
        "voice": "vo_adv_5201321_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "多半都會被重新調整就是了。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對，",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "回憶時間就到此為止，",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要趕快解決掉才行。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 133911,
        "voice": "vo_adv_5201321_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不需要妳們出手。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看我用壓倒性的力量制伏牠……！",
        "unit_id": 133911
    }
]