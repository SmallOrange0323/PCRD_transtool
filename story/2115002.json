    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "也沒辦法吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n最近一堆恐怖攻擊耶！？",
