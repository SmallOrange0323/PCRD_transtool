    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "喂，兄弟！",
        "unit_id": 811,
        "voice": "vo_adv_2115002_017"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "\n你為什麼事到如今突然在加油啊！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "啥！？",
        "unit_id": 911,
        "voice": "vo_adv_2115002_018"
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "\n你才是，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴２",
        "words": "你之前不是說\n現在的公主只是個吃閒飯的嗎！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "那、",
        "unit_id": 811,
        "voice": "vo_adv_2115002_019"
    },
    {
        "type": "dialogue",
        "name": "無賴１",
        "words": "那是……",
