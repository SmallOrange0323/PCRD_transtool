[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真步小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "該說是有著獨自的世界觀嗎，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她有一種堅決的美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒有人能夠模仿，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "宛如童話般的世界……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那是直接反映出了",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真步小姐",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既溫柔又溫暖的性格吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我要不要",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也來嘗試看看那童話般的風格呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n雖然一般人可能會無法駕馭，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我沒問題的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "童話般的我也會很美吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我下次",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "邀她一起喝茶看看吧♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真琴小姐的魅力",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是那不經修飾的狂野感吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明是很自然平常的姿態，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "卻又那麼合適，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真的很犯規呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "狂野可愛，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能不能確立這一個新的類別呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話雖如此，",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不太穿著其他類型的服裝很可惜呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她似乎並不討厭可愛的東西，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然如此就稍微坦率一點，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n去享受各種打扮吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就像我一樣♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得霞小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "最適合",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "充滿知性又酷酷的模樣，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n還有瀟灑的服裝呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是她堅定的信念，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓她顯得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n更加美麗吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這該說是毫無多餘，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "充滿邏輯的美嗎。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想想……",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為她的職業是偵探，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以增加一些進行跟蹤調查時，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n能派上用場的變裝種類如何呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不可以模仿我喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是模仿我美麗的樣子，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "馬上就會被人看穿啊♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "香織小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "像太陽一樣明亮，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管是什麼時候都會讓大家露出笑容呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是很朝氣蓬勃的美。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓我感覺到像是靈魂光輝的東西喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n她蓬鬆的耳朵跟尾巴",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也非常有魅力呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_5120071_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那個很苦的綠色蔬菜……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我有點難以相信",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那是她美麗與健康的秘訣啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然我為了美不惜付出努力，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但是我不想每天喝那個",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "綠色的蔬菜汁啊。",
        "unit_id": 126311
    }
]