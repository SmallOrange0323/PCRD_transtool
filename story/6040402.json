    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "表達感謝呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她的著眼點跟別人很不一樣呢。",
        "unit_id": 103811,
        "voice": "vo_adv_6040402_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為是很不可思議的組合反而會留下印象。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n非常適合",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "放在入口呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
