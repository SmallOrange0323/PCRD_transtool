[
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我都難得過來探望了，",
        "unit_id": 118011,
        "voice": "vo_adv_5084667_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你卻還是沉睡著嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的。",
        "unit_id": 118011,
        "voice": "vo_adv_5084667_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你的睡眠時間不會太長了一點嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會不會其實早就已經清醒了呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是只有你這樣倒還好，",
        "unit_id": 118011,
        "voice": "vo_adv_5084667_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但就連陛下都……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……這是否意味著，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下和你的存在相互吸引到那種程度呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "萬一",
        "unit_id": 118011,
        "voice": "vo_adv_5084667_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是如此，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那我要嚴──正地對你說。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……陛下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就拜託你了。",
        "unit_id": 118011
    }
]