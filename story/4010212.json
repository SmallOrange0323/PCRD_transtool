    {
        "type": "dialogue",
        "name": "靜流",
        "words": "歡迎回來～♪",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天去上學",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很辛苦吧♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "課堂上有沒有不懂的地方？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n之後和姐姐一起複習吧。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "？？？",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為是理所當然",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "才在這裡啊？？？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "迎接弟弟回家的姐姐。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這不是再正常不過的情景嗎♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "話說回來弟弟♪",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n現在是姐姐猜謎時間！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "──今天是",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼日子呢？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "噗噗──",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "答錯了♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "答案是，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「被親愛的弟弟慶祝生日的姐姐",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n感動的抱住弟弟之後用膝枕好～好地寵愛弟弟的日子」",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔♪",
        "unit_id": 104931
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是這樣",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要開始囉，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟與姐姐",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "命中注定的一天♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵，",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝你♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "明明來的有點強硬，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n卻連禮物都準備好了呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……弟弟真的是",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很棒的弟弟呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼，",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "接下來是抱抱時間！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "～行，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不要逃跑♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這種程度，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只是姊弟常有的肢體接觸喔？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……呵呵♪",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好溫暖～♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "再來是膝枕喔？",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n做好被姐姐寵愛的心理準備吧。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有弟弟在身邊的生日。",
        "unit_id": 104931,
        "voice": "vo_adv_4010212_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "非常幸福♪",
        "unit_id": 104931
    }
]