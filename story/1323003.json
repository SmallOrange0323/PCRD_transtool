    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被{player}看到羞恥的一面之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n露易絲瑪莉的情緒相當低落。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隔天早上──"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "哼！",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_000"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我復活了！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n一直垂頭喪氣的太浪費人生了！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "這種時候",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_001"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "反向思考就行了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n既然那種模樣都被他看到了，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n那就沒有什麼丟臉的事情",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "好害怕的！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "呵呵，",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_002"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "啊～",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "被看到太好了！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n被看到我做出他的會說話的魔像後，為此著迷的模樣！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "…………",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "嗚嗚嗚。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不、",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_003"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不行啊，不可以沮喪……！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n我已經沒有東西好失去的了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……我下定決心了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我今天",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_004"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "要跟他告白！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……！",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_005"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n早、",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "早安{player}！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "今天一天還請你多多指教！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "你還記得",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_006"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "今天要做什麼嗎？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "對，",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_007"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "沒錯。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "因為我才剛搬過來，也沒有什麼認識的人。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n而且",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "還是該",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "像這樣正式地……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "打聲招呼才行。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「我家的達令平常受你照顧了♪」",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_008"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「哦哦，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "真是登對的最佳情侶！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "好期待你們的婚禮啊～♪」",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「沒有啦，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "結婚典禮還早呢～",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "對吧，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "達令……」",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「咦，",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_009"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "達令？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "這個是用三個月酬勞買的",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "結婚戒指……？」",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「露易，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "請跟我結婚吧。」",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「唔！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "好的，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我很樂意……！」",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "呀～！",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_010"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n隨便說說的～！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我隨便說說的～！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "啊！",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_011"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不是的……！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n什、",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "什麼事都沒有……！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……今天就不會再是妄想了。",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_012"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n我要跟他的朋友們打招呼，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "成為大家公認的情侶！　",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "嗯！",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_013"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "根據我事前聽說的，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我們要去咲戀育幼院",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "跟牧場。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "精靈之森",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "和月光學院……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "以及其他許多地方。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n首先",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "會帶我去哪裡呢？",
        "unit_id": 132312
    },
    {
        "type": "background",
        "background": "502362"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當天晚上──"
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "露易！",
        "unit_id": 1511,
        "voice": "vo_adv_1323003_014"
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "露易，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "妳在嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "\n我是素材店的阿姨～！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "不好意思突然跑過來。",
        "unit_id": 1511,
        "voice": "vo_adv_1323003_015"
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "其實是我拿到了很稀有的素材。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "\n想說把這個給妳……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "────────────────────",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_016"
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "死掉了！！！",
        "unit_id": 1511,
        "voice": "vo_adv_1323003_017"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我還活著……",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_018"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "勉強算是。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "…………嗚嗚。",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_019"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n……完蛋了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "這次是",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_020"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "真",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "的完了……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n根本",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "就什麼",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "都還沒有開始啊……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "嗚嗚……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "嗚嗚嗚。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "到底發生什麼事了……！？",
        "unit_id": 1511,
        "voice": "vo_adv_1323003_021"
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "\n妳不是說今天要跟他約會，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "充滿了幹勁嗎。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……情敵。",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_022"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "情敵太多了……",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_023"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……這個",
        "unit_id": 132312,
        "voice": "vo_adv_1323003_024"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "是「能窺探人腦中的祕藥」。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "用講的太難受了，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "所以請妳自己看吧。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "店長阿姨",
        "words": "咦咦……",
        "unit_id": 1511,
        "voice": "vo_adv_1323003_025"
    },
    {
        "type": "background",
        "background": "501940"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
