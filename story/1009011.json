[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自從典禮上發生的事件以來，修特帕魯的煩惱增加了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n結果，她始終提不起勁，「冥風戰記」的寫作遲遲沒有進展。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔唔……",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "完全寫不下去，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就忍不住跑到外面來了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "最近",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的很和平呢……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "典禮之後，",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感覺【暮光流星群】的壞名聲",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也稍微減少了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是當時的那些貴族們",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "幫忙澄清了那些不好的傳言嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "英雄閣下、",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗎……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "世人果然還是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "比較喜歡",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那樣賢淑端莊的我吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然如此，",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "作為獎金獵人、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "作為「冥風戰記」的作者，\n這個名為疾風之冥姬的我，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是被人需要的嗎……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不行不行，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我到底在想些什麼啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我上次寫的，描述與永劫魔幻龍戰鬥的",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n「冥風戰記」的新篇章也差不多",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "要發售了吧……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好，",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "稍微",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "去店裡看一下吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "況且我也很在意",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "銷量如何……",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "修特帕魯來到了有販售「冥風戰記」的店裡。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "很好，",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在這裡應該能低調地",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "觀察情況……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "書是不是已經上架了呢……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呀啊！",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呃，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你怎麼會在這裡……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你來買東西？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說得也是……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我、",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我是來、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那個……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難、",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難以啟齒……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因為很在意自己的書賣得好不好就來了，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n總覺得這樣說",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "感覺好像很遜……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也是",
        "unit_id": 100911,
        "voice": "vo_adv_1009011_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "來買東西的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒錯沒錯就是這個，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就是這道光……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這道光芒",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難道是……！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "走在街上的{player}聽見了熟悉的聲音而停下了腳步。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "吾等乃飛舞於煉獄……",
        "unit_id": 1,
        "voice": "vo_adv_1009011_011"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "啊哈哈，",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_012"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "真不愧是閃光的吉格魯特，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n我就知道你能注意到我。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗯？",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_013"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "怎麼了？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n有什麼在意的事嗎？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "呼呼呼，",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_014"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這樣啊這樣啊。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你果然",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "很在意這個啊！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "沒錯！",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_015"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這正是",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "記載了我倆靈魂記憶的",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "「冥風戰記」！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "什麼？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你說這只不過是塊平板？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "哎，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你別先著急。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "我們是透過《阿斯特朗傳奇》再度相遇的。",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_016"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n那麼此份記憶",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "會漂浮於電腦之海也沒什麼好奇怪的。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "嗯，",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_017"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "也就是",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "電子的宇宙本源，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "電靈偏在記憶！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n用這個就能隨時隨地",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "把想到的……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不對，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "是能夠在想起來的時候，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "把記憶給記錄下來。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "恰好紀錄告一個段落時，",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_018"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n就看見了你。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "啊哈哈，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "這或許正是",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "所謂的命中註定啊。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "喔？",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_019"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "你果然想看嗎？",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "對吧對吧。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "啊……",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "不，",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "先等一下。",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "……我可不是",
        "unit_id": 100931,
        "voice": "vo_adv_1009011_020"
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "突然覺得害怕了，不是這樣的喔！",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "\n",
        "unit_id": 100931
    },
    {
        "type": "dialogue",
        "name": "杏奈",
        "words": "只是",
        "unit_id": 100931
    },
    {
