    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪和{player}順利通過了第一道測驗。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而當他們走到出口外時，在前方等著的卻是──"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡是……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "蘭德索爾？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n怎、",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼回事？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "被送回城鎮上了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是因為成功通過所以就把人送回來囉？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不過，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我並沒有特別感受到什麼",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "類似女神祝福的效果呀……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是一如往常很可愛的我。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但也就只有",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一如往常地可愛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "你、",
        "unit_id": 911,
        "voice": "vo_adv_1008010_003"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "你……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "竟有這種事……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我一見鍾情了……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大叔，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你突然說什麼呀？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "拜託了！",
        "unit_id": 911,
        "voice": "vo_adv_1008010_005"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "請和我一起走吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗚哇，嚇我一大跳！",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這該不會是在搭訕？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我還是第一次碰到如此直接又積極大膽",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "的搭訕呀。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說真的，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "光是存在著就如此美麗，也是件累人的事呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對不起唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然這麼說很抱歉，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但你完全不是我的菜，我得拒絕你。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "抬起頭來吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一個大叔下跪的光景，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想是沒有人想看的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "啊啊？",
        "unit_id": 911,
        "voice": "vo_adv_1008010_009"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "妳在說什麼啊？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我根本不是在跟妳說話，我是在問那邊的小兄弟。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "沒錯，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_010"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "小兄弟就是你啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我徹底",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "迷上你了！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "徹、",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "徹底迷上……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等等！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你不要隨便摸他啦！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "啊啊，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_012"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "這雙手……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "果然就如我所想的……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n這是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "最棒的勤勞工作者的手啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……呃？",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_013"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "不只是手，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_014"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "那眼神",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "透露出忠犬般的溫柔及強悍，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n並且",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "還蘊含著樸實真誠！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我就在尋找像你這樣的男人！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "拜託了！",
        "unit_id": 911,
        "voice": "vo_adv_1008010_015"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我們人手不足！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "請你務必要到我的船上來工作！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什、",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼呀……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來和你一起走是這個意思啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別嚇我啦，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是的……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過很抱歉，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們倆目前可是有事要忙。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n沒有空去幫大叔你的忙喔。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們再一次到聖域去吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明都被變成魔物了，卻沒得到祝福，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種事我可沒辦法接受喔。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我絕對不想",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為對方是女神，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就吃悶虧還不敢吭聲呢！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "原來如此，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_020"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我明白你們有該做的事情得去處理了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "不過呢，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我也不打算就這樣點點頭接受然後輕易作罷啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "欸，小兄弟，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_021"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "你那邊的公會，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "目前正處財政困難的狀況吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "別在意這種小事啦。",
        "unit_id": 911,
        "voice": "vo_adv_1008010_022"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我能夠開給你巨額酬勞喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "畢竟",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我們可是受到公會管理協會正式認可的公會！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "這可說是安心安全的",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "高薪工作，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "所以搶手得很啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "但如果是小兄弟你，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_023"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我願意和你簽長期合約！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "如何，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "機會僅限我現在主動跟你提的這一次，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "錯過不再！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等一下，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是在動搖什麼啦？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你都已經約好要陪可愛的我了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n當然不可以反悔！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "和誰先約好根本不重要。",
        "unit_id": 911,
        "voice": "vo_adv_1008010_025"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "是人當然都會選擇更有價值的那一邊吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那更無須猶豫了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "世上沒有任何事物比我的美還有價值。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n好啦，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們快點出發吧！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "妳才是，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_027"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我們男人之間的事不用妳插嘴！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "小兄弟，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "你要過來我這邊才對！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "抱歉抱歉。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "糟糕糟糕，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_029"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "差點就弄傷你寶貴的身體了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也有不對唷？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "誰叫你不好好拒絕這個人的請託。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "為什麼是以拒絕我為前提啊？",
        "unit_id": 911,
        "voice": "vo_adv_1008010_031"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "不過實際上，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "要選愛還是金錢，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "的確是個很棘手的問題。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "而且有時候還會",
        "unit_id": 911,
        "voice": "vo_adv_1008010_032"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "因為顧慮到對方，而無法說出真心話。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "這種時候──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "就讓他順從自己的心吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "魔導具？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "且讓我來說明！",
        "unit_id": 911,
        "voice": "vo_adv_1008010_034"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "這是「心動警報」！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n只要拿著它的人感到怦然心動，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n這個魔導具就會發光。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "其所散發出的光越強烈，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_035"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "代表心動程度越大！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……我大致理解它有什麼作用了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_036"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但你怎麼會有這種東西？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "這種事情怎樣都無所謂吧。",
        "unit_id": 911,
        "voice": "vo_adv_1008010_037"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我們就利用這個，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "來比一場吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "看誰能讓這小兄弟最為心動……",
        "unit_id": 911,
        "voice": "vo_adv_1008010_038"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "換句話說，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "能用誘人話語成功打動小兄弟的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "就能把他帶走！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_039"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再講下去也沒完沒了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要是一個弄不好，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "導致他不開心直接動用武力，就麻煩了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好吧，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_040"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就正面接受你的挑戰。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你可要好好感謝心胸比大海還寬廣的我呀。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "就這麼決定囉。",
        "unit_id": 911,
        "voice": "vo_adv_1008010_041"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "那首先，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "就由我先開始，來示範一下吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "小兄弟，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_042"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我並不是隨便什麼人才都好。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n正因為是你──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我才會",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "特別想要。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "喔，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_043"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "反應還可以嘛。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我說你呀，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_044"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會不會太好說話了？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別那麼簡單就心動啦！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那些話",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定是他每次挖角時都會說的固定台詞。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "哼，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_045"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "隨便妳怎麼說。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "好啦，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "接下來可輪到妳囉？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我知道啦……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_046"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那個呀，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是想和我一起走的對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果在這邊和我分開，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可就沒辦法看到可愛的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "變得更可愛的模樣囉？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是你，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_047"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我願意",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓你看看我的各種姿態唷？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看來你很知趣嘛。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "唔……！",
        "unit_id": 911,
        "voice": "vo_adv_1008010_049"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "竟然靠色誘這種狡猾的小花招……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "不過！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "看我的，咖咖咖……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那是……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_050"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "算盤……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "這我沒辦法講得太大聲啦，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_051"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "但如果你跟我一起走，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n每個月的酬勞──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我可以出到這個金額喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊！？",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如此美麗的我特地做出邀約，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟輸給了錢這種東西？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不可能！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "呵，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_053"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我看小兄弟是個明白事理的人，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n他知道報酬金額開得越高，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "代表開價者對自身的評價越高。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，真是的，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_054"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒辦法了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽好囉，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這次可是特別大放送喔？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是你，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和我一起",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "映照在同一面鏡子裡，我也可以接受……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "晚點在神殿自拍時，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也可以進來和我一起拍唷……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哼哼，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_055"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不愧是我。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這下可以直接算我贏了吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "喂喂喂，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_056"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "才這樣你就怦然心動啦……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "雖然我不想同意那傢伙，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "但小兄弟你真的太好說動啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "不過，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "很遺憾……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我接下來",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "才要拿出真本事呢！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "只要選擇我，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_057"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "就可以領到獎金喔？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "而且還是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "一‧",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "年‧",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "分……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "唔喔，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_058"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "有夠刺眼的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "但瞧瞧這驚人的光輝，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "看來",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "勝利是由我拿下啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎、",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_059"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼會……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "也不怪你啦。",
        "unit_id": 911,
        "voice": "vo_adv_1008010_060"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "畢竟小兄弟至今為止",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "都一直過著貧窮的生活嘛。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "不僅因為沒有地方睡，而跑去勞煩咲戀育幼院關照，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n而且公會目前",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "也花了很多錢在餐費上。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "小兄弟一直都為了生活和夥伴",
        "unit_id": 911,
        "voice": "vo_adv_1008010_061"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "拼命地努力勞動著，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "因此看到條件不錯的工作便忍不住心動，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "也是沒辦法的事。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "好啦，",
        "unit_id": 911,
        "voice": "vo_adv_1008010_062"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "小姑娘，妳打算怎麼辦？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "\n妳有辦法",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "讓這位小兄弟感到更加怦然心動嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_063"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "失去鬥志了嗎……",
        "unit_id": 911,
        "voice": "vo_adv_1008010_064"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "很好，小兄弟，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "我們就立刻來談談合約──",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}，好好看著我……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_065"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "怎麼可能！",
        "unit_id": 911,
        "voice": "vo_adv_1008010_066"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "只是抬下巴，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "就出現了讓警報幾乎要壞掉的強烈反應！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我呀，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_067"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "其實已經察覺到了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然不論何時",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我都很美麗，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但和你在一起的時候，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才是我最美麗的時刻。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果我想變得更加美麗，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你便是不可或缺的存在。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_068"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你要永遠待在我身邊唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗚哇，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_069"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "光芒耀眼到看不見前面了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "是我徹底敗給",
        "unit_id": 911,
        "voice": "vo_adv_1008010_070"
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "你們了……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "通過",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壯碩男子",
        "words": "測驗──！",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500404"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "奇怪……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_071"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡不是蘭德索爾……？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大叔也不見了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這麼說來，我們剛剛被光芒籠罩時，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那大叔",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有說了什麼通過測驗對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也就是說……",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_072"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "剛才發生的事全都是測驗內容，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我們是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "經歷了一場幻覺？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是啦，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_073"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "仔細一想，那個大叔明明說什麼",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一見鍾情，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但卻又太過於瞭解",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有關你的事情。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那種東西打從一開始就不存在。",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_074"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊哈哈，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "瞧你失望成那樣。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "世界上不可能",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有那麼好的工作啦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_075"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "加上這次是第二次了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "說到底我們是為什麼會通過測驗的呀？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要能前進，這點事根本無所謂啦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話說回來，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_076"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒想到我竟有必須引誘你心動的一天呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n雖說是別無他法才那麼做的，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但或許服務得有些過頭了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那當然。",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_077"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "畢竟我只要拿出真本事，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不管是誰，我都有辦法擄獲他的心。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只不過，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "目前我是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不打算把我的本事用在除了你之外的人身上啦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是的～",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_078"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都是因為做了不常做的事，害我好累。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話說，接著應該是要從這邊爬上去吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不想流汗，",
        "unit_id": 100811,
        "voice": "vo_adv_1008010_079"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且若因此害腳變粗，我會很傷腦筋的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以呀，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "現在是你背著我走",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "的好機會唷？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}♪",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪這麼說著，並露出甜甜的笑容。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n結果到最後都沒有弄清，雪剛才的發言究竟是不是別有深意。"
    }
]