[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n凱留在被強迫塞了幾乎都快搬不動的飯糰後，踏上了歸途。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但她走得相當緩慢，看起來像是有哪裡受了傷一樣。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎……",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天也一樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又只是普通地吃了飯就回來了啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的目的",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明就是監視兼暗殺。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟他們感情變好到底有什麼用啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的很開心、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很幸福，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好像所有東西都亮晶晶的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很耀眼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連自己真正的目的都看不清楚，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "差點忘得一乾二淨。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一直拖延下去也不是辦法，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明遲早就會結束的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算猶豫不決地留在那，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將這份關係持續下去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n能預見的也就只有地獄而已。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明我總有一天，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會背叛她們的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真討厭……",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼就只有我，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非得要過上這麼悽慘的人生呢？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳回來了呀，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_007"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n今天也很晚呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n非常抱歉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為了不讓【美食殿堂】那群人察覺，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "耗費了一點時間！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "……哼嗯？",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_009"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "【美食殿堂】呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "記得是以邊走邊吃為目的的公會？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真是蠢。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_010"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n明明就還有很多更有意義的時間利用方法。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不管何時那些俗人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "總是閒暇得令人稱羨呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』在並非是公務的時間，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會待在王座之廳還挺少見的呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "您在忙些什麼呢？",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有沒有我可以幫忙的地方呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳說妳？　",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_013"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可以幫忙我的事？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳以為自己是什麼身份呀？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "非常抱歉，陛下！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是我出言不遜了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這倒也無妨，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_015"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但妳也想想自己是什麼貨色吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我乃統御此世之神，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "而妳不過就是我心血來潮撿回來的小野貓。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n如果妳礙事的話，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "小心我一腳踩死妳唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我充分地明白自己是怎樣的貨色，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對此失言向您致上最深的歉意。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_017"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳身上",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "有食物的味道呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對不起！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和平常一樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我與【美食殿堂】的那些傢伙一起用餐了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但因為吃不太完的感覺，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以就把多的那一份帶回來了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖、",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然只是飯糰……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n『陛下』，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "您要吃嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n見您似乎都沒有什麼進食的跡象，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "令人有點擔心。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以說，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_020"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這畢竟就都只是架空的資料喔",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n不管是飽足感還是其他感覺全都是錯覺嘛，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吃東西根本就沒意義喔。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "而且原本",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我就對將異物攝取至體內，這被稱為進食之事相當厭惡。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是嗎……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n非常抱歉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我又說了些多餘的話。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這白飯，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的很好吃，因此也想讓『陛下』吃吃看……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以才會",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "捏了這麼多個飯糰。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來是白費了呢，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的結果，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不早就預料到了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我到底",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在幹什麼啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不論對",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼事似乎都一臉厭倦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且似乎總是有點不滿的您……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算是只有一點點，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也希望能讓您露出笑容啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對從前，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個沒有任何一件開心事的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總是低著頭到處發牢騷抱怨不滿的我，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n給予了希望的畢竟就是『陛下』啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_026"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我改變主意了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n飯糰，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就給我一個吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳要吃飯糰嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "嗯。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_028"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "因為妳感覺，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "比平時流露出多了一些幸福感呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以難得，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我也突然想要吃點東西看看了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是基於好奇的心血來潮唷，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_029"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "如果妳不怎麼想要進貢個飯糰的話",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "也無妨就是。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n實際上，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我也並沒有那麼餓呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒、",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有沒有！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請用請用！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n很好吃的唷，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我們自己收割下來後碾米做成的精米！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n然後經過用心的蒸煮，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再加進大份量的配料",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "捏得恰恰好的……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "在興奮個什麼勁啊……",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_031"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真是個怪孩子。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "好了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "趕緊拿來。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好的！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n請您",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "盡情享用～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "耶嘿嘿。",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n吃起來怎麼樣呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　很美味吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在用剛蒸好的白飯捏好後我就馬上回來了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還溫溫的唷！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "閉上妳的嘴。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_034"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n很吵唷，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "噫！",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n對不起，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我竟然這麼得寸進尺的……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "沒事。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_036"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "用餐是必須得安靜",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "並且獨自迅速完結之事，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n――",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我自小就被人這麼徹底的教育的。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以，在吃東西的時候有人在附近講話",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "便會讓人靜不下來呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也是一樣。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃飯的時候都是獨自一個人呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雙親因為工作的關係，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總是不在家嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以都在附近的餐廳，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "點個事前做好的東西然後緊張兮兮地吃完。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "當然陛下與我的情況是完全不一樣的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』單純因為是高貴之身，所以才會有那種類似家教禮法",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的東西才必須要那樣做的吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是呢。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_040"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我是在嚴格",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "卻沒意義的傳統與規則，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "像被嚴重拘束的家中養大的……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以那時，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "才會如此想要自由。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "曾想在那充斥著滿滿自己想要的東西，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_041"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "喜歡的東西的理想鄉中，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n充分地歌頌自己的人生唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "沒錯……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "最一開始，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就只是這樣而已呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呵呵。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_043"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我多嘴了呢，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "忘掉它。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "飯糰，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我就收下了唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "啊呣，",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_044"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這裡面放的是酸梅？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我不喜歡吃酸的東西呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那樣的話……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是放柴魚片的唷！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　您喜歡嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "放酸梅的那個請給我吃吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "『陛下』請用這邊這個！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "酸梅的飯糰，",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來吃……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嚼嚼♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真不成體統呢。",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_047"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n那可是我吃過的喔，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "把它扔掉吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦～？",
        "unit_id": 106012,
        "voice": "vo_adv_2012012_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　可是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣很浪費的嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該說是因為知道了把米種出來的辛苦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以一粒也不能夠浪費嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳在講什麼？",
        "unit_id": 106911,
        "voice": "vo_adv_2012012_049"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真的挺好吃的呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就說了吧",
