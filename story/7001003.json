[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯——",
        "unit_id": 104311,
        "voice": "vo_adv_7001003_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "魔物變得越來越強，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n雖然是有得到",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不錯的寶物……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但就是沒有線索啊。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_7001003_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "確實是沒有特別發現什麼",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n和騎士先生的記憶有關的東西呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞有什麼發現嗎。",
        "unit_id": 104311,
        "voice": "vo_adv_7001003_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n霞，妳有聽到嗎……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　霞跑到哪裡去了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哈啊、",
        "unit_id": 101411,
        "voice": "vo_adv_7001003_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哈啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這邊也盡是陡峭的階梯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n真是不敢恭維呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呼。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？　",
        "unit_id": 101411,
        "voice": "vo_adv_7001003_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼了嗎助手先生……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你要來幫忙拉我一把嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n謝謝你，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那我就不客氣了喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟我是專門動頭腦的呢……",
        "unit_id": 101411,
        "voice": "vo_adv_7001003_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你也知道的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我對自己的體力一向沒有什麼自信。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞，妳沒事吧。",
        "unit_id": 104311,
        "voice": "vo_adv_7001003_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n抱歉，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不知不覺就把距離給拉開了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真琴，",
        "unit_id": 101411,
        "voice": "vo_adv_7001003_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別在意。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n畢竟，妳要走在前方\n擔任探索的要務。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說，",
        "unit_id": 104311,
        "voice": "vo_adv_7001003_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞有什麼發現了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很遺憾什麼也沒有。",
        "unit_id": 101411,
        "voice": "vo_adv_7001003_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們繼續調查吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴，妳等一下啊……",
        "unit_id": 100211,
        "voice": "vo_adv_7001003_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哈啊、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哈啊。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "霞，真是對不起，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "丟下妳一個人的――",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊、",
        "unit_id": 100211,
        "voice": "vo_adv_7001003_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n霞、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "霞",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和騎士先生",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "，手",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "牽在一起了！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "欸？　",
        "unit_id": 101411,
        "voice": "vo_adv_7001003_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊啊！　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是啦，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這只是為了爬上階梯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被助手先生的手拉了一把而已喔！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n沒有其他意思！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是、",
        "unit_id": 100211,
        "voice": "vo_adv_7001003_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是嗎。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是這樣啊……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "霞這傢伙，",
        "unit_id": 104311,
        "voice": "vo_adv_7001003_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "豈不是比一個讀遍戀愛指南的優衣還更會撒嬌了嗎。\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是太小看妳了呢……",
        "unit_id": 104311
    }
]