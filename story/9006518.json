[
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有、",
        "unit_id": 101311,
        "voice": "vo_adv_9006518_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有兩具古代兵器！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是什麼外掛啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不愧是彌勒，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有夠卑鄙的～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "古代兵器？",
        "unit_id": 105811,
        "voice": "vo_adv_9006518_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼啊？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那是很久以前，",
        "unit_id": 105111,
        "voice": "vo_adv_9006518_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "人類為了對抗魔物所製造出的防衛兵器。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "它們應該只能靠古代語言來啟動，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n為何現在會動啊？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真奇怪……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哈～哈哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_9006518_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我想你們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "應該不可能有辦法理解的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "！",
        "unit_id": 100911,
        "voice": "vo_adv_9006518_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是誰！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "好久不見了，",
        "unit_id": 2511,
        "voice": "vo_adv_9006518_005"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "【暮光流星群】的各位！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n我是天選之人──",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n這世界的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "統治者！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_9006518_006"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "那是誰啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "啥！？",
        "unit_id": 2511,
        "voice": "vo_adv_9006518_007"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你、",
        "unit_id": 2511,
        "voice": "vo_adv_9006518_008"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "竟然把我給忘了！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n忘了我這個成功解讀",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "啟動古代兵器的古文書的天才！？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……",
        "unit_id": 105611,
        "voice": "vo_adv_9006518_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "抱歉，我真的沒印象……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "惠理子妳呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我對這沒興趣，",
        "unit_id": 102711,
        "voice": "vo_adv_9006518_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "覺得沒有必要花時間去回想。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "深月妳呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個嘛……",
        "unit_id": 105111,
        "voice": "vo_adv_9006518_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我對其中一具古代兵器",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很感興趣，所以還有點印象……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "七七香有印象嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我對那本古文書有印象～！",
        "unit_id": 101311,
        "voice": "vo_adv_9006518_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n因為是千里迢迢跑去買的♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼那時候沒有買到手啊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯……",
        "unit_id": 100911,
        "voice": "vo_adv_9006518_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我也只能想起我們不得不和古代兵器對戰，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n以及身陷嚴酷工作環境的片段……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "光只是想到這些……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "當時飽受壓榨的疲勞感好像又回來了……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊，",
        "unit_id": 105111,
        "voice": "vo_adv_9006518_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳是說肌肉痠痛吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n杏奈在打完工後，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n全身都痠痛到動彈不得呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "啊哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_9006518_015"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "什麼啊～！！",
        "unit_id": 2511,
        "voice": "vo_adv_9006518_016"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n看你們聊往事聊得欲罷不能，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "竟獨獨漏掉關於我的部分～！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "可惡……",
        "unit_id": 2511,
        "voice": "vo_adv_9006518_017"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "既然你們忘了那就算了！！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n因為我接下來",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "會在你們的記憶中",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "刻入恐懼……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我將以彌勒大人副手的身分",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "統治世界──！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "喀隆隆隆──！！"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "兩具古代兵器都動了起來！",
        "unit_id": 106411,
        "voice": "vo_adv_9006518_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看、",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來他真的很氣憤呢……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "連一點印象也沒有的害蟲就算生氣了，",
        "unit_id": 102711,
        "voice": "vo_adv_9006518_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也無須在意。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我們來徹底擊潰他吧……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻嘻♪",
        "unit_id": 102711
    }
]