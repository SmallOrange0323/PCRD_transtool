[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "麵包店",
        "words": "來喔來喔，",
        "unit_id": 611,
        "voice": "vo_adv_2105002_000"
    },
    {
        "type": "dialogue",
        "name": "麵包店",
        "words": "快來看看！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "麵包店",
        "words": "\n便宜好吃的麵包店，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "麵包店",
        "words": "本日開幕囉～！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "不管是豬肉牛肉，",
        "unit_id": 311,
        "voice": "vo_adv_2105002_001"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "雞肉羊肉甚至是兔肉！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n只要是肉，這裡什麼種類都有喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不好意思，",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可以給我那邊的肩胛肉",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "和橫隔肌嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還有牛腱肉和雞頸肉和砂囊也要……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "絞肉也好便宜！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也給我一些絞肉！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "謝謝惠顧！",
        "unit_id": 311,
        "voice": "vo_adv_2105002_003"
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "這些雞翅送妳，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "肉舖",
        "words": "帶回去大家一起吃吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哇，",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "謝謝你♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n沒想到都這麼便宜了，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還能額外拿到送的肉……！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哈哈哈～！",
        "unit_id": 103411,
        "voice": "vo_adv_2105002_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這麼好喝的麥酒，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "居然會便宜得像水一樣──！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好像在作夢一樣～♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗝♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "美冬～～！",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有優花梨！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n現在不是買東西的時候喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊！？",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我都忘了……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "本來打算讓妳們看看市場的情況，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但因為實在賣得太便宜了，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一時鬼迷心竅……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正如美冬的報告中所述……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n蘭德索爾的市場當中，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n似乎四處都出現了賣價異常便宜的新店家呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且這些商店",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "居然全都受到",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n名為【銀汞貿易】的公會所管控。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "至今為止，從來沒聽說過",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有這個公會啊……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸欸～",
        "unit_id": 103411,
        "voice": "vo_adv_2105002_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那邊那家店，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n好像也是新開的店喔～？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "【銀汞貿易】認證的",
        "unit_id": 4911,
        "voice": "vo_adv_2105002_011"
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "\n鯛魚燒小舖，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "本日開張大吉！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "\n便宜又好吃的鯛魚燒，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "只要僅僅10盧幣！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "來吧，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "吃吃看喔～！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼！？",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒賣10盧幣！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "騙人喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "反正肯定很難吃……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好好吃喵──！？",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "外皮又脆又有彈性，",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "高級紅豆餡直到魚尾巴都塞得滿滿的……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還烤得如此恰到好處！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這可是大事件喵～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "它好吃到連珠希都說到這個地步嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然如此，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該能排除掉",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n店家使用劣質材料，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "降低成本的可能性呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我的攤子",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然在味道方面不輸這家店……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但要是賣這個價格，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "生意根本做不下去喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "老闆！",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你價格賣這麼便宜，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "到底是怎麼獲得利潤的喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "哎呀──",
        "unit_id": 4911,
        "voice": "vo_adv_2105002_018"
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "幾乎是",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "沒有什麼利潤啦。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "不過，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "反正材料的部分",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "【銀汞貿易】會幫我們準備好……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "而且大叔我啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "想看大家",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "吃到美味的東西",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒店",
        "words": "露出開心的表情嘛！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "珠希、秋乃、美冬",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2105002_019"
    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "珠希、秋乃、美冬",
        "words": "唔～～～～～",
        "unit_id": 1,
        "voice": "vo_adv_2105002_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖然逛完了市場一圈……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n卻完全找不到任何一點",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "違反道德或法律的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "明確證據呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "本來只打算到處看看而已的……",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n卻因為實在太便宜了，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不小心就",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "買了太多東西……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚……",
        "unit_id": 103411,
        "voice": "vo_adv_2105002_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不小心就喝太多……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n現在才終於比較不醉了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然沒有抓到【銀汞貿易】的狐狸尾巴……",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但這個情況絕對絕對很奇怪喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我的尾巴",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一直在顫抖警戒著喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……是啊，",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不只是開幕特價，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n有些店已經持續賤價賣了半個月以上。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這對周圍的競爭店來說，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可是很吃不消的。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不正當低價賣出……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也就是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所謂的傾銷呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
