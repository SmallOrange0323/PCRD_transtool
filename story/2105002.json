    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_060"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不是這樣的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我只是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "稍微想了一下。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "的確……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_061"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "剛才和我們談話的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n【銀汞貿易】的那些人，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有在市場賣超低價的那些人……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "似乎都並不是壞人。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但我……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_062"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "說實在的，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我似乎仍對他們抱持著反感。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算撇除我們是競爭關係這點，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也是一樣反感。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為什麼？",
        "unit_id": 103411,
        "voice": "vo_adv_2105002_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我想想……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我所偏好的商人手法之中，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n有句話",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "叫做「三方皆好」。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所謂的三方，",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_065"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是指顧客、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "商人、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "以及社會。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對買家也好，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對賣家也好，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對市場也好──",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也就是「各自都有獲得滿足，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才能算是好的生意」這種思維。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "像【銀汞貿易】的那些人，",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_066"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那種為了滿足顧客",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而犧牲自己的經商方式……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "乍看之下或許是很了不起，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但長期看下來，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也是有在輾轉之下",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "使顧客方受損的可能性。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最重要的是！",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_067"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n他們居然以赤字為前提在做生意……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這對商人而言，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是很不應該的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就、",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_068"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是說啊喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那些傢伙的資金來源，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "背後一定有鬼喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "除了資金以外……",
        "unit_id": 103411,
        "voice": "vo_adv_2105002_069"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "他們這麼擴大事業，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n加開新的店家……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "想找到人力，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "應該也很困難吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "到底是用什麼方法辦到的呢……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不得了了────！！",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_070"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "美冬！？",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_071"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這次又怎麼了喵！？",
        "unit_id": 104611,
        "voice": "vo_adv_2105002_072"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "聽說【銀汞貿易】營運的加盟店……",
        "unit_id": 104811,
        "voice": "vo_adv_2105002_073"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "下次要同時新開一百家店舖！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦……",
        "unit_id": 103211,
        "voice": "vo_adv_2105002_074"
    },
    {
        "type": "dialogue",
        "name": "秋乃、優花梨、珠希",
        "words": "咦咦咦咦──！？",
        "unit_id": 1,
        "voice": "vo_adv_2105002_075"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "怎麼回事啊──！？",
        "unit_id": 103411,
        "voice": "vo_adv_2105002_076"
    }
]