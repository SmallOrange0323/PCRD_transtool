        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先讓客人",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "到外面去避難吧！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n幫幫我們吧！",
        "unit_id": 125212
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "喵啊啊啊……",
        "unit_id": 17311,
        "voice": "vo_adv_5114005_074"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n竟敢壞我好事……",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "竟然把客人趕出店外，",
        "unit_id": 17311,
        "voice": "vo_adv_5114005_075"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "真是豈有此理喵嗚嗚……！",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n既然如此，我就要",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "把你們全都趕出去喵！",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "我不指望你們了喵！",
        "unit_id": 17311,
        "voice": "vo_adv_5114005_076"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n從今天開始，",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "我要成為這家店的店長喵！",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "我要招來很多人，賺很多錢，讓這家店的客人絡繹不絕喵嗚！",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "女客人4",
        "words": "那隻招財貓",
        "unit_id": 1511,
        "voice": "vo_adv_5114005_077"
    },
    {
        "type": "dialogue",
        "name": "女客人4",
        "words": "是怎麼回事！？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女客人4",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女客人4",
        "words": "我可沒聽說這裡會有這種東西！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "男客人4",
        "words": "我們快逃吧！！",
        "unit_id": 1011,
        "voice": "vo_adv_5114005_078"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "正在排隊的客人們，",
        "unit_id": 125212,
        "voice": "vo_adv_5114005_079"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不好意思！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n今天",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咖啡廳",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "「Naschkatze」",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要臨時暫停營業！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "咦？",
        "unit_id": 411,
        "voice": "vo_adv_5114005_080"
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "我難得都來了耶？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對不起喵！",
        "unit_id": 125111,
        "voice": "vo_adv_5114005_081"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n您下次光臨時，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們會多送",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咖啡或是鯛魚燒給您的喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "知道了。",
        "unit_id": 411,
        "voice": "vo_adv_5114005_082"
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "我會再來的！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "但",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "店員小姐，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女客人5",
        "words": "妳們要小心別受傷囉！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "黑",
        "words": "喵～！",
        "unit_id": 1714,
        "voice": "vo_adv_5114005_083"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你",
        "unit_id": 125111,
        "voice": "vo_adv_5114005_084"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "能借我力量嗎喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好了，",
        "unit_id": 125211,
        "voice": "vo_adv_5114005_085"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你認命吧！",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n雖然我不太想使用粗暴的手段，",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但你既然不聽勸的話……",
        "unit_id": 125211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們只好用物理手段為你做職員教育訓練了喵～！",
        "unit_id": 125111,
        "voice": "vo_adv_5114005_086"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "正合我意喵！！",
        "unit_id": 17311,
        "voice": "vo_adv_5114005_087"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "我才要把你們",
        "unit_id": 17311,
        "voice": "vo_adv_5114005_088"
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n訓練成營業額與攬客至上主義的完美店員，",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "\n就讓我把你們",
        "unit_id": 17311
    },
    {
        "type": "dialogue",
        "name": "招財貓",
        "words": "打從骨子裡徹底教育一番吧喵～！",
        "unit_id": 17311
    }
]