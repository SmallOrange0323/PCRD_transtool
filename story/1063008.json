    {
        "type": "dialogue",
        "name": "旁白",
        "words": "打算用餐的{player}一走進餐廳，\n就遇到亞里莎出來迎接。"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "歡迎光臨──！",
        "unit_id": 106311,
        "voice": "vo_adv_1063008_000"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊，{player}！\n怎麼了嗎！？",
        "unit_id": 106311,
        "voice": "vo_adv_1063008_001"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "咦？",
        "unit_id": 106311,
        "voice": "vo_adv_1063008_002"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我嗎？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我在工作中哦！",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "耶嘿嘿……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "總覺得，太好了呢。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "其實啊，",
        "unit_id": 106311,
        "voice": "vo_adv_1063008_003"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "今天是我第一天上班。",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "所以，有點不安……",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "……不過，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "因為{player}來了──",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "──唔！？",
        "unit_id": 106311,
        "voice": "vo_adv_1063008_004"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n什，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "什麼？",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "難道是，",
        "unit_id": 106311
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那時候的……！",
        "unit_id": 106311
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "唉～",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_005"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "上班前好緊張啊……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "雖然是因為制服很可愛才選了這份打工，",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_006"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n不過我會不會不適合當服務生呢……？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n而且那還不是普通的咖啡廳……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "在前面的是{player}！",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_007"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "糟、糟糕了……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "雖然不想透漏自己在打工的事，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "不過當作沒看到也很奇怪……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "輕鬆地聊一下天，",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_008"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "然後快速地離開吧！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "{player}，真巧呢！",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_009"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n竟然來到車站前面，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是來買東西的嗎？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "在散步啊……",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_010"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "偶爾也要乖乖在家裡念書啦。",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n你不是說",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "之前的考試成績很危險嘛。",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我嗎？",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_011"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我是因為……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "等等要去打工。",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n我最近在前面不遠處的咖啡廳開始當服務生……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你、",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_012"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你問我是哪間店……？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "車站前的……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "在哪裡都沒差吧！？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1063008_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "亞里莎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊……",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_014"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "辛、辛苦您了！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "{player}，那個，這位是我打工時的前輩……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "你好～",
        "unit_id": 1,
        "voice": "vo_adv_1063008_015"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n你該不會是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "亞里莎的男朋友吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "男、",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_016"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "男朋友……！？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n不是那樣的！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "不是男朋友的話……",
        "unit_id": 1,
        "voice": "vo_adv_1063008_017"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "是主人嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "更不對了啦！",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_018"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "該怎麼說才好……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是朋、",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "朋友！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "咦？",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_019"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n那、",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "那個，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "就是……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "和你沒關係的事情啦！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是主人……",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_020"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "沒錯？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "什麼意思？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n{player}你",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "該不會是喜歡被用這種方式稱呼吧？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1063008_021"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "{player}你不知道嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n呵呵呵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n其實呢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "亞里莎和我的打工地點啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "是女僕咖啡廳哦♪",
        "unit_id": 1,
        "voice": "vo_adv_1063008_022"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊──！",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_023"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "因為太害羞了所以我才保密的說……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "不需要感到害羞！",
        "unit_id": 1,
        "voice": "vo_adv_1063008_024"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n亞里莎穿女僕裝的樣子",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "非常地可愛哦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "對了！",
        "unit_id": 1,
        "voice": "vo_adv_1063008_025"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "亞里莎，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n既然這麼剛好，\n不然請{player}陪妳一起上接待培訓課程如何？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "咦！？",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_026"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "　",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "亞里莎雖然做事很認真，",
        "unit_id": 1,
        "voice": "vo_adv_1063008_027"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n不過因為羞於接待客人，所以一直沒辦法進步呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "前、",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_028"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "前輩！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n{player}現在很忙，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "沒有那個時間啦！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "對吧，{player}！？",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊……",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_029"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "{player}你這個人，",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "還真是不會說謊呢……",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "\n",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "是說這種時候",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "你也察言觀色一下吧！",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "是這樣嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1063008_030"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n你在忙什麼呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "……明明有很多空閒時間，卻很忙嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1063008_031"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n哼哼～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "來協助亞里莎打工的時間總該有吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "就這麼決定了！",
        "unit_id": 1,
        "voice": "vo_adv_1063008_032"
    },
    {
        "type": "dialogue",
        "name": "服務生前輩",
        "words": "\n那麼，亞里莎、{player}，\n我們出發去店裡吧──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "為、為什麼會變成這樣～！？",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_033"
    },
    {
        "type": "still",
        "still": "106300801"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "歡迎回家，",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_034"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "主人～♪",
        "unit_id": 106331
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "啊～別嚇到啦！",
        "unit_id": 106331,
        "voice": "vo_adv_1063008_035"
    },
    {
        "type": "dialogue",
        "name": "亞里莎",
        "words": "我知道！",
        "unit_id": 106331
