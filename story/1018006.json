[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在散步的時候，\n整個城鎮突然變得騷動不已。"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "魔物出現了！",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_000"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n凶暴的魔物已經來到城鎮的附近了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "怎、",
        "unit_id": 511,
        "voice": "vo_adv_1018006_001"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "怎麼辦？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n可是置之不理的話，不知道牠會做出什麼事的喔！？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "只能擊退牠了！",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_002"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n大家同心協力的話，就能打倒吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "好！",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_003"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n大家",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "走吧！！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "牠就是凶暴的魔物！",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_004"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n大家快打倒牠！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "等等！",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這隻魔物並沒有敵意！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "為、為什麼妳會知道？",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_006"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n牠可是魔物耶！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n不知道什麼時候會攻擊過來！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "很危險啊，",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_007"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "快離開魔物旁邊！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要！",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n如果你們想攻擊牠的話，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我會全力阻止的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "喂、喂。",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_009"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "要怎麼辦啊？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "怎麼辦……",
        "unit_id": 511,
        "voice": "vo_adv_1018006_010"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n凶暴的魔物在這裡的話會很危險的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "只能打倒牠了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "雖然對不起那位小姐，",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_011"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "但她要干擾的話，我們也只能全力要她讓開了！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n上吧！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}！？",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_012"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "搞什麼，小毛頭！？",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_013"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n連你也要來亂嗎？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "什麼？",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_014"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n如果魔物有敵意的話，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n剛剛就會先襲擊在旁邊的小姐了……？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "的、的確聽起來是有道理……",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_015"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "可是魔物在城鎮附近的話很困擾！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "讓魔物遠離？",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_016"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "好。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n如果真的可以辦到的話，那就不擊退牠。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "對我們來說，",
        "unit_id": 1011,
        "voice": "vo_adv_1018006_017"
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "\n不用戰鬥就能解決的話",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "居民１",
        "words": "更好。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會把牠帶回森林！",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只要可以不讓這隻魔物受傷，我什麼都願意做！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "知道了。",
        "unit_id": 511,
        "voice": "vo_adv_1018006_019"
    },
    {
        "type": "dialogue",
        "name": "居民２",
        "words": "\n那這隻魔物就交給妳了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝！",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也謝謝你。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？你願意幫忙嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那我們一起走吧。",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼我要護著這隻魔物？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……牠呀，",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n之前掉入了魔物用的陷阱。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為那樣還受了傷……",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但就算是魔物，我也無法放著不管。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以解除了陷阱，幫牠治療。",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "結果好像跟我變得很親近。",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n今天也是為了要找我，才到城鎮來的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你看，現在牠不是也乖乖地跟上來了嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n牠其實是很溫柔的魔物。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……可是，你，",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼會相信我呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "或許我沒被襲擊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只是正好牠沒那麼做而已……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對吧？",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真厲害。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你果真有眼光。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，這麼信賴我呀。",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真開心～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為你相信我，",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓牠免於被擊退的危險。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你又救了我一次呢。",
        "unit_id": 101811,
        "voice": "vo_adv_1018006_033"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你喔。",
        "unit_id": 101811
    }
]