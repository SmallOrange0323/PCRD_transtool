[
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "still",
        "still": "500900601"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我閱讀了許多傳說典籍，四處尋找，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n總算找到封印霧奇之地。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是不管呼喚幾次都沒有回應，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n突然就被狂暴的霧奇攻擊了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後所有記憶都被奪走了……",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n結果，就變成大家看到的這副模樣。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一開始，我的行為像野獸一樣，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是因為我身為人類的記憶都被奪走的關係。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我完全照本能行動，餓了就吃，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n變得就像動物一樣。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為我對精靈之力有抵抗力，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n好不容易保護了自己的記憶，藏在內心深處……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過卻難以浮現，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n只能看著自己持續發狂。",
        "unit_id": 108411
    },
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在那之後……",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n噗吉不知道為什麼飛到我身體裡，有了他的幫助，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n才取回了些許的記憶……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但懂事之後的記憶都被奪走，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以行為就像嬰兒一樣。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，太丟臉了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈。",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒必要覺得丟臉啊，很可愛喔。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌平常總是既成熟又冷酷，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來小時候也是如此天真無邪呢♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請、請忘記吧！",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，霧奇，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你現在馬上刪除大家的記憶……！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不會忘記的唷。",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n和千歌的回憶，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "全部都是重要的寶物。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不對，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管對誰來說，回憶都是非常重要的呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不能讓人",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "隨意的操控。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然想要助{player}一臂之力～的心情",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也是可以理解。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是的……",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，真是的，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這一切實在是太丟臉了。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總、總之……",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是不對霧奇做點什麼，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我就會再次被奪走記憶困在內心深處。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後又會再",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "給各位添麻煩了吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請各位，打倒霧奇吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請把他趕得遠遠的，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "或是再封印起來也沒關係。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你們阻止",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_016"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "霧奇對我的惡意攻擊。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是我解開了他的封印，讓他覺醒的，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說這種話我也很過意不去。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是我不想忘記",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這一切。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對我而言，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和各位的回憶都是重要的寶物。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不會讓人奪走的，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就算只是一絲一毫。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是……",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然我也很想把折磨千歌的傢伙",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n揍飛到地平線另一端去。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我們不知道那個霧奇在哪裡啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "實在是束手無策啊。",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要去之前封印霧奇的地方，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就能見到他嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_020"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不需要特地去見他。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "霧奇牠",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就在這裡。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "牠一定是一面竊笑觀賞著我",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_021"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n失去記憶，醜態畢露的模樣吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我感覺得出來。",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我是唱喚士，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以感受得到精靈的氣息。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦，",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "牠就在這裡嗎……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n在、在哪裡……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　好可怕啊……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然我不清楚正確的地方，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n但霧奇是沒有實體的精靈，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只有依附於物質上時，才能和現世有連繫。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "他現在應該是",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_025"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "藏在什麼東西裡面。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請把他找出來，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "攻擊讓他現身。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "然後，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會拜託其他的精靈，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n請他們消滅霧奇的本尊。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不對。",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了不讓我這麼做，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n霧奇一定是躲在安全的物體裡。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "畢竟牠的本尊暴露出來會毫無防備的，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以牠一定用了什麼物體當作屏障。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦咦，",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以他現在躲在某樣東西裡囉？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是躲在我體內吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有沒有",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什麼東西和平常不太一樣的？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "被霧奇附身的話，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說不定顏色或形狀會改變……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～？",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　在這裡生活的小胡桃和小綾音，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}應該會知道吧？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個嘛～不確定耶？",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為加了聖誕節裝飾後，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n整體上都和平常不太一樣了……",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀……",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥過來了，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你知道霧奇藏在哪裡了嗎……？",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？　是、是我嗎？",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然我今天的確是……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n和平常不太一樣，可是……？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不、不在我體內啦！",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_035"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我是唱喚士，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是體內有精靈，我會感應到的！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以，{player}……咦？　你在聽嗎？",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n等一下，請不要亂摸我的身體！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊哈哈，啊哈哈哈哈……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好癢啊☆",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喂！",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　不可以啦，絕對不行！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\nYES偶像　NO摸摸……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你為什麼用那麼可怕的表情接近我……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你、你在懷疑我嗎？",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我、我和平常有哪裡不一樣嗎？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　像冒牌貨……？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀啊，",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥，請不要拉噗吉啦！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你在做什麼，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不可以欺負噗吉……！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……啊啊，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "難道說！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "明白了！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　是噗吉！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "噗吉，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "應該說霧奇在那個槌子裡！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為霧奇進去了，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以噗吉的心……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "靈魂？",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "之類的被彈出了槌子，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n然後碰巧進到在附近的我的體內！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "事情就是這樣子吧？",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　一切都說得通了！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們知道你在哪裡了，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "快點現身吧！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「記憶的大精靈霧奇」……！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "霧奇",
        "words": "――吼喔喔喔喔喔！"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀啊！？　討厭討厭討厭，槌子自己動起來了！",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_045"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "霧、霧奇真的在這裡面嗎……！？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦，",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_046"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要啊，綾音！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n請不要靠近我，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要打我啊……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是啦不是啦，",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_047"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是槌子自己動的！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚啊啊啊啊，快逃啊胡桃～！",
        "unit_id": 108611
    },
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥！？",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、哥哥保護了我……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚啊啊，對不起啊，哥哥！",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_049"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒事吧？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n打你的不是我，是霧奇……！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音，",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_050"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "快放開那個槌子！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　快逃～！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n妳那樣握著太靠近他了，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要是他找綾音當目標，妳會躲不掉的……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可、可是！",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我和噗吉都是在一起的？",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "……千歌小姐！",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_052"
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "\n抱歉，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "身體再借我一下！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "混帳！　",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_053"
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "我不知道你是大精靈還什麼鬼 ",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "\n不准嚇唬我的綾音啊啊啊啊！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚噫？",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_054"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好厲害，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "完全不像千歌，而是像猛獸一樣的動作……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "綾音！",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_055"
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "　那東西不是我，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "我在這裡啊！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "\n快放開那槌子，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "噗吉［千歌］",
        "words": "到這裡來！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好、好的！",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_056"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　噗吉！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我知道的，噗吉就在那裡！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為我們總是在一起，所以我知道，我感受得到！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉總是在我身邊，安慰我、守護著我！",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_057"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以想要傷害我和我重視的家人的這根槌子，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……才不是噗吉！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音！",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_058"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n把那個玩偶，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個槌子噗吉丟到這裡來……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好、好的？",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_059"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然不知道怎麼回事，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我會照胡桃說的去做的！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我是姊姊，",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_060"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以會聽你們的願望的！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n嘿咿……！",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝妳……！",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_061"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我就知道綾音妳總是",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這麼想的！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n真的很高興，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最喜歡這樣的綾音了！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嚇唬綾音的壞蛋，",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_062"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "快點離開……！",
        "unit_id": 108511
    },
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔喔，",
        "unit_id": 102913,
        "voice": "vo_adv_5009006_063"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "打得好！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "小胡桃用自己的槌子，\n打飛了小綾音的槌子！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "霧奇",
        "words": "――吼喔喔喔喔喔！"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……咦！？",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_064"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102911,
        "voice": "vo_adv_5009006_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個槌子裡面飄出了像是霧一樣的東西！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那就是「記憶的大精靈霧奇」的真身嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，不好了！",
        "unit_id": 102911,
        "voice": "vo_adv_5009006_066"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n霧奇往胡桃那裡飄去了，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她剛用盡全力打飛了槌子失去平衡……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會躲不掉的！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、咦咦……！？",
        "unit_id": 108511,
        "voice": "vo_adv_5009006_067"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚……！",
        "unit_id": 102911,
        "voice": "vo_adv_5009006_068"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　不行，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然很想幫忙，可是離太遠了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來不及……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……{player}！　時機正好！",
        "unit_id": 102911,
        "voice": "vo_adv_5009006_069"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不愧是男孩子，出乎意料的強壯呢！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n抱住了起身的小胡桃，並強化了我們！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。總是受到你的幫忙。",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_070"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n因為你總是那麼溫柔、",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "又可靠……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還這麼的令人憐愛，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "才想向你報恩的。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "事情變成這樣，",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_071"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "實在非常抱歉……",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "道歉等之後再說吧。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "霧奇衝破牆壁，好像往城鎮的方向去了。",
        "unit_id": 108411,
        "voice": "vo_adv_5009006_072"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們也要快點追上去才行。",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。{player}哥哥，",
        "unit_id": 108611,
        "voice": "vo_adv_5009006_073"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快點走吧！",
        "unit_id": 108611
    }
]