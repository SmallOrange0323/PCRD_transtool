[
    {
        "type": "dialogue",
        "name": "樂園守護者",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 17111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不會吧，",
        "unit_id": 124811,
        "voice": "vo_adv_5110323_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "它竟然還有這樣的力量？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n真是受夠了……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這的確很棘手。",
        "unit_id": 124911,
        "voice": "vo_adv_5110323_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我感受不到應有的恐懼，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這是為什麼啊？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想它應該也快到極限了，",
        "unit_id": 125014,
        "voice": "vo_adv_5110323_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該是這樣吧！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "它把殘存的力量",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全賭在最後的一戰！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果是這樣，只要我們撐過這一戰，",
        "unit_id": 125014,
        "voice": "vo_adv_5110323_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "勝利就是我們的了！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……我並沒有妳們兩位那麼熟悉戰鬥，所以不是很了解，",
        "unit_id": 124811,
        "voice": "vo_adv_5110323_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但妳們既然都這麼說了，我也這麼相信喔！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這股氣勢，",
        "unit_id": 125014,
        "voice": "vo_adv_5110323_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "望！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，我們一口氣解決掉它吧！",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們兩位",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟著我一起上吧！",
        "unit_id": 125014
    }
]