    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對初夢許的願",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是嗎……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算能夠夢見想做的夢，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但也不一定保證會實現吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種事最重要的就是心意吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "問題是……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "該許願要結婚呢，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是許願研究有進展呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就先試著自問自答看看吧……",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406601"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "深月，",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_003"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "妳仔細想想。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n人只要活在世上，就是孤獨的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "所以放棄結婚吧，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "妳應該要將自己奉獻給科學研究。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406602"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "不是那樣的深月，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_004"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "人生若只有研究可是會很空虛的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "妳想想看往後歲數增加時的事。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "只有自己一個人的飯桌，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_005"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "\n妳一定無法忍受的。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406603"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "別被蠱惑了。",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_006"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "只要透過研究",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_007"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "確立了新的醫療技術，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "肯定能拯救眾多生命，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "而且還能獲得財富與名聲喔。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406604"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "但卻沒有能分享那份喜悅的伴侶。",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_008"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "而且我其實",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_009"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "也不是為了財富跟名聲進行研究的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "這只是對著無法結婚的這個現實",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "所說的藉口而已。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406605"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "那不就是極度自罰",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_010"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "又主觀的想法嗎？",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406606"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "說得好像在人生中的幸福",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_011"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "就只有建立家庭而已，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n這種說法",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "否定了其他形式的多樣性喔。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406607"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "但是如果有機會結婚的話，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_012"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "\n妳",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "早就結婚了吧？",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406608"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "妳不覺得那種正確論點",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_013"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n只會撕裂自己的心靈而已嗎？",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406609"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "就算不自己撕裂自己的心靈，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_014"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "\n也早就因為定期收到熟人的結婚報告，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "而傷痕累累了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "明白的話就不要賭氣，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_015"
    },
    {
        "type": "dialogue",
        "name": "結婚派深月",
        "words": "\n乖乖許願結婚……",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "513406610"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "慢著。",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_016"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n那樣就下結論還太早了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "首先",
        "unit_id": 117511,
        "voice": "vo_adv_5134066_017"
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "要再次定義幸福的本質，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "\n之後",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "再依此",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "研究派深月",
        "words": "選擇結婚還是研究……",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "513406611"
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "結婚……",
        "unit_id": 1,
        "voice": "vo_adv_5134066_018"
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "研究……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "結婚……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "\n研究……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "結婚……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "研究……！\n結婚！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "研究！結婚！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "腦海中的深月們",
        "words": "研究！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "進行了腦內會議，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結果就整晚都沒睡……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n別說初夢了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "整個精疲力盡，全身無力……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這份迷惘",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也正是答案吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不管是研究還是結婚，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對我來說都是同等重要的事。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算只明白了這件事，",
        "unit_id": 105111,
        "voice": "vo_adv_5134066_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也是很有意義的吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這應該也會是度過這新的一年的參考呢♪",
        "unit_id": 105111
    }
]