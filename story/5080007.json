        "voice": "vo_adv_5080007_028"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我什麼都沒看到啊？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你要藏到什麼時候啊！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_029"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "在店裡就快出來，不會有事的！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "妖精",
        "words": "啾～",
        "unit_id": 15511,
        "voice": "vo_adv_5080007_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇～！",
        "unit_id": 211,
        "voice": "vo_adv_5080007_031"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這裡還有另一隻妖精呢！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "它也好可愛喔～",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不對！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "它才是這裡的妖精！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子是幽靈喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊哈哈！",
        "unit_id": 211,
        "voice": "vo_adv_5080007_033"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "幽靈是很可怕的！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n宮子看起來一點也不可怕啊？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "既然妳這麼說，",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_034"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就讓妳瞧瞧宮子的可怕！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家要把店裡的點心",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "全部吃光光喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "妖精",
        "words": "啾啾！",
        "unit_id": 15512,
        "voice": "vo_adv_5080007_035"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好痛！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_036"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家是開玩笑的啦！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子只吃布丁而已喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家才不會跟你一樣做那種事！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "妖精",
        "words": "啾～",
        "unit_id": 15511,
        "voice": "vo_adv_5080007_037"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呵呵，",
        "unit_id": 7912,
        "voice": "vo_adv_5080007_038"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "你也不會",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "再做那種事了吧。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "妖精",
        "words": "啾咿！",
        "unit_id": 15511,
        "voice": "vo_adv_5080007_039"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "就是這樣。",
        "unit_id": 7912,
        "voice": "vo_adv_5080007_040"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "點心正好剛出爐，",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n可以來幫我擺盤嗎？",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "妖精",
        "words": "啾咿啾咿！",
        "unit_id": 15511,
        "voice": "vo_adv_5080007_041"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "呼……",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_042"
    },
    {
        "type": "dialogue",
