    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節甜點大賽結束後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又過了一段時間的某天。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗨，",
        "unit_id": 119211,
        "voice": "vo_adv_5080007_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老婆婆！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "產地直送",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "印有伊麗莎白牧場標記的食材，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "幫妳送來囉！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "啊，",
        "unit_id": 7912,
        "voice": "vo_adv_5080007_001"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "謝謝妳，真陽。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天就是",
        "unit_id": 119211,
        "voice": "vo_adv_5080007_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "重新裝修後的開幕日了吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是啊，",
        "unit_id": 7912,
        "voice": "vo_adv_5080007_003"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "這一切全都",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "多虧大家給了我勇氣。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老婆婆所做的點心那麼美味，",
        "unit_id": 119211,
        "voice": "vo_adv_5080007_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n退休實在太可惜了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎沒看到宮子啊，",
        "unit_id": 119211,
        "voice": "vo_adv_5080007_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n她又在店裡吃布丁了嗎？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "宮子她啊……",
        "unit_id": 7912,
        "voice": "vo_adv_5080007_006"
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "快來買點心喲～",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好吃的甜點店",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "重新裝修後今天再度開幕喲～",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好吃的點心等著你來買喲～",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n請收下這張傳單喲～",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真是奇怪……",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子明明只是想吃布丁而已，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n為何非得",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "做這種事不可……",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子在比賽時已經很努力了喲！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算什麼事都不做，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "應該也可以吃好吃的布丁吧！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好痛！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "別打了啦！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n人家知道了啦！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要好好幫忙才可以吃布丁！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這傢伙怕宮子會偷懶，所以老是跟得緊緊的。",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "它好像把宮子誤認為妖精了喲。",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家已經跟它說過好幾次宮子是幽靈，它還是聽不懂。",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n實在有夠笨的喲。",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好痛！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為什麼說你笨就聽得懂～！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈，",
        "unit_id": 119311,
        "voice": "vo_adv_5080007_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是熱鬧～",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不要笑了，還不快來制止它！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n妳們是來做什麼的啊！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為聽說好吃的甜點店正在大肆宣傳，",
        "unit_id": 119311,
        "voice": "vo_adv_5080007_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們就來看一下情況囉♪",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "既然這樣，",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳們就拿著這張傳單去店裡吧！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n會給妳們一些折扣的喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "想不到，",
        "unit_id": 119311,
        "voice": "vo_adv_5080007_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳真的有好好在幫忙呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為了布丁，這也是沒辦法的事！",
        "unit_id": 119911,
        "voice": "vo_adv_5080007_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "話說回來，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳也來幫忙！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "客人增加了，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子的布丁才會增加喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是是，",
        "unit_id": 119311,
        "voice": "vo_adv_5080007_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我一開始就有這樣的打算。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也想助老婆婆一臂之力。",
        "unit_id": 119311
    },
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人發完傳單後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到店裡去……"
    },
    {
        "type": "dialogue",
