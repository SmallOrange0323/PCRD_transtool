[
    {
        "type": "dialogue",
        "name": "幼年巨蜥",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 133211,
        "voice": "vo_adv_5160321_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這就是最後的敵人了嗎。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n突然湧現出來襲擊我們讓我嚇了一跳啊。",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "就是說啊。",
        "unit_id": 133611,
        "voice": "vo_adv_5160321_001"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "蘭德索爾比我想像的還要危險呢……",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不，",
        "unit_id": 133511,
        "voice": "vo_adv_5160321_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這大概",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是那隻大蛇的影響吧？",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n爬蟲類的魔物可能是",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "被牠壓倒性的氣息嚇到，",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以變狂暴了。",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也就是說，",
        "unit_id": 133211,
        "voice": "vo_adv_5160321_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只要不打倒大蛇，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種事情會一直發生──",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "土蛇",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "幼年巨蜥",
        "words": "──咕哦哦哦哦哦！",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "才剛說完就成群結隊地來了！",
        "unit_id": 133611,
        "voice": "vo_adv_5160321_004"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "真是的～",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "有夠麻煩的啊！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我們也不能置之不理。",
        "unit_id": 133211,
        "voice": "vo_adv_5160321_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n兩位，",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "逐一打倒牠們吧！",
        "unit_id": 133211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "知道了，",
        "unit_id": 133511,
        "voice": "vo_adv_5160321_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為之後還要面對更棘手的，",
        "unit_id": 133511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以別把力氣用盡了喔！",
        "unit_id": 133511
    }
]