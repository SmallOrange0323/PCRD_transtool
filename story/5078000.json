[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的每一日總是祥和平靜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而在那日常生活的背後，卻有著想奪走人們愛與希望的黑暗，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以及守護人們脫離那抹黑暗的正義魔法少女存在。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就是這本♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然在少女漫畫裡",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "算是有點大膽的系列……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但讀了之後，會讓人不自覺沉迷其中呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n今天洗完澡後來看吧……♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是你！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你、",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你看到了……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼說呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒什麼啦。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n該說是上課要用的資料嗎……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "別管這件事了，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你在做什麼呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n作業已經寫完了嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果有不懂的地方",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "都可以問我哦？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣子啊。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然是在巡邏，真了不起♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然平常街上都很和平，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但偶爾會有奇怪的敵人出現呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "反逆獸……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是叫這名字嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我有聽說過只有魔法少女能夠擊敗牠們之類的……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呼，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好歹是蒙混過去了吧……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我看看，",
        "unit_id": 1,
        "voice": "vo_adv_5078000_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是什麼呀？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「教師與學生的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "禁斷之戀……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "被霸道系的男學生步步逼近……」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦、咦！？",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n怎麼會！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "他",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_011"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "強行把身為教師的我抱住，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "說了一句……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "「當我的專屬班導師吧」。",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "……唔哇，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "好大膽……！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什、",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "什麼！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這孩子是怎麼回事！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "話說，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不要唸出來啦～～～～～！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不、",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是這樣的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n老師",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "絕對沒有喜歡這種東西哦？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "話說，你啊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不能隨便突然",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "唸出別人的漫畫啦！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "嘿嘿，",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_014"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "抱歉抱歉。",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "才想說好不容易找到騎士大人了，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n結果看到了好像很有趣的漫畫，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "不小心就……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "騎士大人？",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……你認識牠？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "嘿嘿，",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_016"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "好久不見！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "騎士大人！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我又再度從魔法國度",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "跑來了♪",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "咦──",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_017"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "騎士大人你居然忘記了我的事！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n真拿你沒辦法。",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "那我重新",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "自我介紹吧。",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我是摩拉！",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_018"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "是來自魔法國度的",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "魔法生物！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "請多指教囉，",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_019"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "妳是……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是伊緒。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在月光學院當教師，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是他的班導師。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "……老師……",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_021"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "原來如此……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個，",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼啦，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "摩拉？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "剛才的少女漫畫不是那樣的哦？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的不是那樣哦？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "話說，",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_023"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "現在不是悠悠哉哉打招呼的時候了！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n騎士大人，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "有敵人！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "在蘭德索爾裡又",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "出現敵人的氣息了！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "想奪走人們愛與希望的敵人──",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_024"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "反逆獸！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "魔法國度……？",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n反逆獸……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你說的",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "該不會是……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "傳聞中的……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "沒錯！",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_026"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "能打倒反逆獸的人，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "只有那群孩子！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n至今與反逆獸屢次戰鬥，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n一路守護著蘭德索爾的和平的女孩子們──",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "──魔法少女們！",
        "unit_id": 4211,
        "voice": "vo_adv_5078000_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦咦！？",
        "unit_id": 101811,
        "voice": "vo_adv_5078000_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來真的存在呢，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "魔法少女……！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n雖然學院裡的學生們",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也有人曾說有看到過……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "摩拉",
