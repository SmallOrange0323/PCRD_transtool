[
    {
        "type": "background",
        "background": "500400"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "人家開動～了☆",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼！好～吃！",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哎呀辛苦總算有代價，比期待的還更好吃喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這個、呃……這是什麼肉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚼嚼。這就是剛才遇上的，",
        "unit_id": 105913,
        "voice": "vo_adv_4003002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那隻像是巨大魔物身上的肉喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這就是傳聞中的『貴重的食材』了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該就是了。",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那隻長得像魔物的似乎非常長壽，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n背上看起來像岩石的部分，好像累積了大量的營養呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那就是傳說中的，『雲海山脈』潛藏的珍貴食材……！",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能嘗到就是至高的幸福！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_4003002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好吃得臉頰都要掉下來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n入口即化的，微微回甘的肉……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們居然敢吃那種來歷不明的東西啊。",
        "unit_id": 106012,
        "voice": "vo_adv_4003002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳最好也吃一些。",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟不但爬過了山，還跟魔物戰鬥過了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "肚子應該餓了吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之後我們真的得下山、回到鎮上才行了。",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不先吃一點東西墊肚子，回程路上會暈倒喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_4003002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下同意貪吃佩可小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n空著肚子是不能戰鬥的，凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～，好是好啦……",
        "unit_id": 106012,
        "voice": "vo_adv_4003002_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n反正每次不管我怎麼拒絕都還是會被硬塞的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但真的有股很可口的氣味讓我胃口大開。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就吃這麼一口好了。",
        "unit_id": 106012,
        "voice": "vo_adv_4003002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要扛回難得發現的寶藏什麼的，也得恢復相當的體力。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對！",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請用請用，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……啊～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，很好吃吧？",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次的『雲海山脈』之外，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在各地祕境一樣也隱藏著各種美味！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "之後我們也一起把它們找出來吧！",
        "unit_id": 105812,
        "voice": "vo_adv_4003002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家一起，去吃遍全世界的美味．珍饈吧！",
        "unit_id": 105812
    }
]