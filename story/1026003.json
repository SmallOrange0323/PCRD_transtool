[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喂～{player}！",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這邊這邊♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "歡迎來到【伊麗莎白牧場】……☆",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那個表情，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎樣？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就算是我，也會有精神抖擻的日子哦，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n用不著擺出",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "「妳這傢伙是誰啊？」的表情吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀算了。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n比起那個，{player}……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天是來送信的對吧？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "有寄給我的包裹嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呵呵呵。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我用郵購買了",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一直很期待發售的遊戲，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n跟高級紅豆麵包禮盒組～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一個月份的薪水，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "全部一口氣用掉了哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然花了很多錢購物，但我並不後悔哦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "存起來也沒有用嘛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不如把錢痛快地花掉。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "牧場食衣住都一應俱全，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "幾乎也沒有支出。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把每天努力工作的成果……",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "送給自己當獎勵♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，你說我何時在工作了～？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的工作就是牧場的守衛，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因此光是在這一帶轉來轉去就是在工作了呦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "比起那個。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你是來配送郵購商品的對吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n快點給我。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我可是把印章也拿好，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "準備萬全在等著了呦？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "喔，是那個包裹？收件人姓名是鈴！",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n給我，我要蓋印章囉？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "蓋的真平整～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呵呵呵，太棒了！",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n盼望的遊戲以及紅豆麵包，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n終於拿到手了……♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，奇怪？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總覺得，包裹比想像中還輕？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n哎呀算了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你接下來有空嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要不要一起玩遊戲？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "牧場的大家好像比較喜歡在外面玩，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不太陪我一起玩遊戲呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我想要有人能夠陪我玩遊戲。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可以吧？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n現在的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n可以特別分你一塊剛到手的高級紅豆麵包一小角呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哇咿！",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真不愧是{player}，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很通情達理呢！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，我就邀請你來我房間吧。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然很凌亂，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但應該",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是有{player}可以坐下的空間才是……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那樣的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "首先要先整理一下房間。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "欸嘿嘿。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我其實一直有點嚮往呢，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n和同年紀的人一起玩什麼的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "牧場的大家，要不是年紀比我小，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不然就是比我年長。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "意外地也會有聊不來的時候呢～",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為大家不是太成熟就是太孩子氣了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n嗯，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "奇怪……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}你，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n應該跟我差不多年紀吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "順帶一提。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我是17歳。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，你以為應該年紀更小嗎？",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n啊啊……難怪總覺得你對我很溫柔，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n原來是把我當成小孩子看待了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我的身高的確很矮，或許看起來像小孩子也說不定……",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但因為我們年紀大概相同，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n憑著這點，希望你注意一下態度。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "把我當小孩子對待的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我會很難為情的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你不知道嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀，因為是比較罕見的興趣呢～",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這是最近慢慢普及的一種娛樂。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我啊，相當沉迷呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在稍微有點高價，被稱為硬體的魔法道具裡，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n插入叫做軟體的東西，就會出現浮在空中的畫面……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n遊戲就是，用手觸碰那個畫面然後遊玩的東西。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好難說明啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "實際操作看看啦，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我覺得不試試看是不會明白它的有趣之處的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我有各式各樣的遊戲呦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然我也是以少少的薪水湊著買的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以擁有的種類不多。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是會讓人沉迷其中，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n有趣到忍不住玩一整天呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也想讓{player}，",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n也喜歡上我喜歡的東西呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呵呵。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那麼，過來吧過來吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我來帶你到我的房間～♪",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "房間裡稍微有點凌亂，可別嚇到哦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026003_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔～嗯……早知道會這樣，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我應該事先更認真地收拾才對。",
        "unit_id": 102611
