[
    {
        "type": "background",
        "background": "500653"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "……哇啊～",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夜晚越來越深的大江戶。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪野與剎鬼兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正抬頭看著夜空。"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼，",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_001"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳有發現嗎？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在這裡，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "天空中有小小的光芒，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "一閃一閃亮著。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n儂一開始",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "還不是很清楚，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "但一直",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "看著",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就覺得……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "很漂亮，",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_002"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "令人著迷……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳看，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就像寒冷早晨裡凍結的冰",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "一樣閃閃發光──",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "感覺一伸手",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就能碰到，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "但卻又碰不到，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "這部分也有點像呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是啊。",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_003"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那就是",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所謂的星星吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "跟我們那只會降下遺灰的世界相當不一樣──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n是個截然不同",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "的地方呢。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對了，",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_004"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "小公主好像說",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "她也有看過。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在跟騎士一起去蘭德索爾的時候。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n這裡的人，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "好像一到晚上",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就會觀看星星，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "然後許願",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "的樣子。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在星星落下來的時候，",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_005"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "唸三遍願望，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就會",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "實現的樣子。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "……騎士他們，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "是不是也會",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "像這樣",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "許願呢？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "誰知道呢。",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_006"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "如果是騎士公他們，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "應該會靠自己來實現吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "畢竟他們是群有骨氣的傢伙。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "嗯……",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_007"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "也是。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "騎士他，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "一直",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "都很非常努力",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在加油著。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那麼，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼妳呢？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n有想過",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "希望實現的",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "願望嗎？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我嗎？",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_008"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我怎麼可能有……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不對。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要說一個都沒有那是騙人的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "咦、",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_009"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "咦！？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "是嗎……！？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "驚訝過頭了，妳這個傻瓜。",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_010"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "無論是誰，都會有內心迷惘的時候吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對、",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_011"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "對不起。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "因為剎鬼，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "總是那麼可靠。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n所以儂",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "有點意外……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "哈。",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n──那麼妳又是如何？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n只有妳在提問，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這說不通吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂、",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_013"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "其實，",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_014"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂原本以為，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂沒有",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "想要實現的願望。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "但是，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "現在──",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂……",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_015"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那個。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "想、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "想要",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "試著，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "去冒險……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "看看。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂至今，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "都一直待在吉歐‧尼布爾黑爾。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n對外面的世界，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不是很了解。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "想要跟小公主，",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_016"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "還有剎鬼一起。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "去各種地方……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n要是還能交到",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "像騎士或拿娜",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那樣的新朋友，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "會很開心。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "這樣，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "不行嗎？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不錯啊。",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_017"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我也對騎士公他們──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不對。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "對這裡的飯館",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "挺有興趣的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "只是啊。",
        "unit_id": 135912,
        "voice": "vo_adv_9012002_018"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n要趕在星星落下前唸三遍願望這種事，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n怎麼想",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "都不可能吧？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂、",
        "unit_id": 135812,
        "voice": "vo_adv_9012002_019"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "會加油的。",
        "unit_id": 135812
    },
