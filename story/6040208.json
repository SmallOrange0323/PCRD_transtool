        "words": "真陽的衣服，",
        "unit_id": 112711,
        "voice": "vo_adv_6040208_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明有著成熟韻味的要素，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但是被真陽穿上之後感覺卻非常健全……",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是個可怕的才能呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然真陽好像不太服氣，",
        "unit_id": 112711,
        "voice": "vo_adv_6040208_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過真的很適合她，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "她明明只要老實接受稱讚就好了說。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "畢竟人都有",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "適合跟不適合的事物嘛。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然真陽的確是最成熟的，",
        "unit_id": 112711,
        "voice": "vo_adv_6040208_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但不是指那種事啦。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是說",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你真的覺得她很成熟？",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果是這樣的話",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就去跟真陽說嘛。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "她一定會很高興的。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 112711,
        "voice": "vo_adv_6040208_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像可以理解。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你說是帥氣的衣服，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這麼說好像也沒錯呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過果然",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只要被真陽一穿，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就會變成可愛的衣服呢。",
        "unit_id": 112711
    }
