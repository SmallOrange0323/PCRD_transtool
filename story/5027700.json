[
    {
        "type": "background",
        "background": "500850"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【龍族巢穴】的3人再度前往位於艾爾皮斯島的叢林，\n向似龍生物所居住的遺跡前進。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喂～",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有人在嗎～？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快點出來吧～！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們帶了土產來喔～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "土產？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳帶了什麼過來？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我帶了糖果！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n牠一定會喜歡的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這麼說來，",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那傢伙第一次來襲擊的時候，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n有大量的巧克力從營地不見了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨。",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n牠在那裡觀察我們唷？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "趕快把牠拖出來吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等一下！嘉夜夜！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n牠之前被嘉夜夜打得很慘，所以很害怕妳。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒事沒事～",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一點都不可怕喔～……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "似龍生物",
        "words": "咕喔喔……",
        "unit_id": 12311,
        "voice": "vo_adv_5027700_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "過來這邊吧！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這裡有好吃的巧克力喔～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔！",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來了來了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n跟看起來一樣，對吃相當執著呢……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "馬上來問話吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯嗯……",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你說",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你很羨慕龍嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這傢伙……",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為很想變成龍才打扮成這樣。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來妳真的聽得懂牠在講什麼。",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只能懂大概的意思啦……",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "牠好像是說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "因為感覺到有龍的氣息，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n才會跑到我們的營地。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真的能溝通的樣子呢。",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "然後呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "遺跡的事情牠怎麼說？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……唔唔～",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然大概可以理解牠想說什麼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n但細節的部份，該說沒有講得很清楚嗎……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我聽不懂啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼意思啊？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是指雖然可以感受到牠想傳達的意思，",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但卻無法將其變成具體的語言，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看來是沒辦法問得太細了～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大妳也不知道牠在說什麼吧？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為什麼只有祈梨聽得懂呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然多少也有",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "波長合不合的問題～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但我想主要還是因為",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他們兩人的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "智商相近吧〜☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣啊……",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也就是說，這傢伙也很少根筋吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真可憐……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！？　",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳這話也太失禮了吧！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為啊，",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到頭來牠根本沒幫上忙對吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "特地跑來這裡第二次還是沒有收獲……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚嗚嗚！　",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等一下！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n牠才沒有幫不上忙呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了，",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要教牠就好啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要教牠說話的話就能問得出來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "做得到嗎？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這傢伙比看起來很笨耶？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "正好，",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳要不要用這個石板教教看〜？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n只要能慢慢把",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "物品的名稱跟概念教給牠，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n牠說不定就能",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟我們對話了喔〜",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是這個！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要用這個讓妳們知道，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的腦袋比嘉夜夜好多了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不不不，",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那怎麼可能啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然決定了，就先來取個名字。",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n讓我來當你的教母吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "似龍生物……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "似龍！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你的名字就叫做似龍！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "似龍",
        "words": "咕喔喔喔！",
        "unit_id": 12311,
        "voice": "vo_adv_5027700_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵，",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_031"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你也喜歡這個名字嗎……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "洗好脖子等著吧！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好好好，",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_032"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那妳就好好加油吧。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，祈梨開始熱心地教導似龍生物。\n時而嚴厲，時而熱情……但主要是用巧克力在引誘牠。\n這樣的教學持續了一段時間……"
    },
    {
        "type": "background",
        "background": "500850"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘿嘿、",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘿嘿嘿嘿嘿嘿嘿……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們能贏！　\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣就能贏！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜！　",
