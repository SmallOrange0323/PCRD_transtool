        "voice": "vo_adv_3003003_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嚇、嚇了我一跳……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳去哪裡了呢，綾音……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "經常外出呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯～",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個嘛，算是『例行公事』吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "（胡桃的父母現在是『失蹤』的狀態。",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我定期會跟爸爸媽媽見面這件事……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n跟她說不太好吧？）",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "（胡桃無法向爸爸媽媽撒嬌呢……？）",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎、怎麼了……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n無精打采的樣子……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒事，沒什麼。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比起這個，",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要好好地說『歡迎回來』♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯、嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n歡迎、回來……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘿嘿、綾音……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是『綾音』，",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是『綾音姐姐』？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我一直跟你說，",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我比你年長吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『嗯，嗯。",
        "unit_id": 2111,
        "voice": "vo_adv_3003003_012"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n你就叫我噗吉哥哥吧？』",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是那個，不太那個，",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n因為綾音沒有給人年長的感覺……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不是、那個，我會、努力……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很好，但是不要勉強喔。",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我是姐姐，不會說任性的話！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比起這個，胡桃在做什麼呢？",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像跟{player}哥哥一起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n坐在地上。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果是在玩的話，",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也讓我和噗吉加入吧♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那個，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天咲戀媽媽們因為工作不在家……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以，",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一直都是哥哥陪伴我玩……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呼嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n{player}哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在當胡桃的玩伴嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "給你獎勵吧，",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "摸頭摸頭～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊哈哈……",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n明明綾音年紀比較小，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n把哥哥當成小朋友了呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我才是【咲戀育幼院】的前輩嘛♪",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比起這個，你們在玩什麼？",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像用手讓娃娃在動，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是在玩扮家家酒嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個呢，扮家家酒……",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我是、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘿嘿、太太……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥是、丈夫……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "達、達令……♪",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天的料理是燉菜喔……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，啊～嗯……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，好像很有趣，我也要玩！",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可以吧，如果妨礙你們的話，我可以去別的地方～？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀，妨礙什麼的……",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，綾音想演誰呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯～？",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那，我要演媽媽！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉、演爸爸吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "（嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n雖然只是『扮家家酒』……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也想讓胡桃向父母撒嬌♪）",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那……",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我就演和爸爸搞外遇的情婦吧……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "變成了一個複雜的家庭！？",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到、到底是在哪裡學會，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n外遇這個詞彙的！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀嗯，",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n之前看過的書裡有寫……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為繪本已經全部看完了，",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是從咲戀媽媽的藏書借來的……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽……",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有會給小朋友不良影響的書……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊、那個……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不是的，是有名的經典文學……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不不、不是、奇怪的書喔……！",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "十分有趣喔，綾音、也要讀看看嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯～",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n看書會變得想睡，不要！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比起這個，來玩吧！",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "{player}哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n想演什麼呢？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小狗之類的，如何……？",
        "unit_id": 102111,
        "voice": "vo_adv_3003003_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n嘿嘿，哥哥～？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "伸手～……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我覺得，",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n胡桃有時會有天馬行空似的言行舉止……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "{player}哥哥，這樣好嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_3003003_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "被比自己年紀輕的女孩子，當作寵物照顧好嗎？",
        "unit_id": 102311
    },
    {
