        "voice": "vo_adv_1071007_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果克莉絲提娜我身邊，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
