[
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在克莉絲提娜徹底讓肉舖店主學到教訓的當天晚上──"
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "頭髮嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……噢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天就不用麻煩了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己弄乾吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這只不過是模擬演習，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們只是暫且過過看這種生活。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果開始習慣這樣過日子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們彼此都會很困擾吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……我的人生，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "充滿一個接一個的危險賭局。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算我在這之後，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "轉而成為一名家庭主婦……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也沒辦法逃離過往。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我打從一開始，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就不打算讓小子去替我償還，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "由我劍下產生的那些染上鏽色的恩怨。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……我不能把他給捲進來。",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呵。",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n連如此簡單的結論沒有設想到，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就在那邊說什麼模擬演習，還真是樂昏頭了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖說是因為誓約而建立起的關係，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我似乎有些亂了分寸哪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……我是怎麼搞的。",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──關於誓約，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我決定無限期進行保留。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以，模擬演習也到此為止。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然都這麼決定了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就也去跟小子談──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………唔！",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼回事？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "窗外",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有道好耀眼的光……？",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，給我等一下。",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很危險啊！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是的……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我剛才不是才說過不能衝到馬路上去嗎。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "知道了～♪",
        "unit_id": 231,
        "voice": "vo_adv_1071007_014"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊～",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "那是什麼那是什麼～！？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦～",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話才剛說完，就立刻當耳邊風嗎。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n非常好。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "站住，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說教時間到了！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別笑了，快來幫忙。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "照這樣下去，不管花多久時間，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "恐怕都找不到那野丫頭的父母啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是的……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我好不容易騰出工作上的空檔，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n來跟小子買新發售的遊戲啊。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結果卻碰上這個迷路少女，還真是倒楣。",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說要去找警察，她也不要，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只好由我們兩個來負責找她的父母了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我很不擅長和小孩相處。",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n通常小孩看到我靠近，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就會害怕得哭起來。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……雖然就算他們哭，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對我來說也是不痛不癢啦。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "的確。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她反倒還一副很享受跟我鬧著玩的樣子。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哼。",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就讓我見識一下她能維持多久吧♪",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂～",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那邊的野丫頭！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "敢惹克莉絲提娜姐姐生氣，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小心吃不完兜著走！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "呀啊──♪",
        "unit_id": 231,
        "voice": "vo_adv_1071007_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼哈哈哈哈☆",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n──給我站住！",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "欸，你看那邊",
        "unit_id": 1231,
        "voice": "vo_adv_1071007_025"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那三個人。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "他們看起來好快樂呢。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n不曉得是不是一家人？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "雖然爸爸看起來非常年輕啦……",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "應該是一家人吧。",
        "unit_id": 1031,
        "voice": "vo_adv_1071007_026"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哪天我們結婚，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "或許就會像那樣走在街上呢。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗯。",
        "unit_id": 1231,
        "voice": "vo_adv_1071007_027"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好期待那天到來呢～♪",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎是呢。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然很想吐槽",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "世上哪有這麼不像的一家人啦。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我原本從未想像過，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n像我這樣的人也會擁有家庭……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但如果能有像小子這樣的老公，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和這樣的小孩，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或許就……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "──呀",
        "unit_id": 231,
        "voice": "vo_adv_1071007_031"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我才警告過妳的！",
        "unit_id": 107131
    },
    {
        "type": "still",
        "still": "107100701"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把手給我吧。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳還好嗎？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……",
        "unit_id": 231,
        "voice": "vo_adv_1071007_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了？",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_035"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我……",
        "unit_id": 231,
        "voice": "vo_adv_1071007_036"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不是什麼乖孩子唷……？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是什麼意思？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "…………",
        "unit_id": 231,
        "voice": "vo_adv_1071007_038"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……我不是迷路。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "其實我……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是離家出走。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n意思是說，妳是憑自己的意志離開家的囉。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……因為，",
        "unit_id": 231,
        "voice": "vo_adv_1071007_040"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我是壞孩子。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我會把朋友弄哭……",
        "unit_id": 231,
        "voice": "vo_adv_1071007_041"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "或是跑到危險的地方玩……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n甚至還會對老師做一些讓他們很傷腦筋的惡作劇。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "明明我只是想做一些開心的事而已。",
        "unit_id": 231,
        "voice": "vo_adv_1071007_042"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "但每次我做開心的事……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "大人們就會嚇到，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "然後",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "罵我。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我老是讓爸爸和媽媽傷透腦筋，",
        "unit_id": 231,
        "voice": "vo_adv_1071007_043"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "害他們傷心。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n我是壞小孩。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "所以呀，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我決定不要再當",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "爸爸和媽媽的小孩了。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………原來是這樣。",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_045"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──似曾相似",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這下我總算是理解自己莫名地和這小孩",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很合得來的原因了。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……過於早熟的思考，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "甚至會拒絕接受本人的控制。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "由於過於優秀……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n由於太有行動力……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而導致沒人管得動的孩子……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是不被任何人所理解的",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "孤獨存在。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……………",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n未料最討厭懷舊的我，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然到現在還記得這件事啊……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我看，也無妨吧？",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然是這麼一回事，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就也不用勉強她回──",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你可別太小看小孩囉？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這孩子也是自己思考──",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……可是──",
        "unit_id": 231,
        "voice": "vo_adv_1071007_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，你要小心點。",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這種虛有其表的說教，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "恐怕會把這孩子逼得更緊喔？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為你自己",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也曾給周圍的人添過麻煩？",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果真的就此分開，",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "便絕對無法克服難關……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就算無法克服，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要大家待在一起，",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就一定……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以一起向前邁進……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "更何況──",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要分開",
        "unit_id": 107131,
        "voice": "vo_adv_1071007_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是很悲傷的事……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n大家",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都會難過的……？",
        "unit_id": 107131
    },
