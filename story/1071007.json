    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_079"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是夢",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "孩提時的夢……？",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_080"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不，不對……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子他也和我在一起──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_081"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的頭髮打結了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "噢，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_083"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為我沒有弄乾就睡著的關係吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_084"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……不，我改變主意了。",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_085"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然這麼說有點晚，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_086"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但還是……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想拜託你幫忙，可以嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼……",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_087"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "麻煩了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………嗯。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要分開",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_088"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是很悲傷的事……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要待在一起就一定……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以一起向前邁進……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你真的，",
        "unit_id": 107111,
        "voice": "vo_adv_1071007_089"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n很擅長",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把結解開呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "差點就要把「無限期保留誓約」說出口的克莉絲提娜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n如今悄悄地在內心打消了這念頭。"
    }
]