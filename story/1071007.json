        "voice": "vo_adv_1071007_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不像是我會有的想法哪。",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在能像這樣和小子待在一起的這件事，",
