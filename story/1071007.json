        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1071007_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為自己的存在，而傷害到重要的人。",
        "unit_id": 190011,
        "voice": "vo_adv_1071007_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n親眼目睹這個狀況，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "確實是件令人難受的事呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "照理說是好人家出身的克莉絲提娜，",
        "unit_id": 190011,
        "voice": "vo_adv_1071007_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會與家人分開，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並離開故鄉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最後輾轉之下隻身一人來到蘭德索爾，",
        "unit_id": 190011,
        "voice": "vo_adv_1071007_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或許這背後的理由和剛才提到那些",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不能說是毫無關係呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即使是那個克莉絲提娜，",
        "unit_id": 190011,
        "voice": "vo_adv_1071007_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是個",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有感情的一般人……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不會吧──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然多少讓人有這樣的訝異啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
