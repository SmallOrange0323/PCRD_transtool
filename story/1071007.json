        "voice": "vo_adv_1071007_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我得好好珍惜才行……",
        "unit_id": 107131
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
