[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在塔中前進的時候，流夏和妮諾興高采烈地聊天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n最後聊到彼此所屬公會的話題。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭的公會，",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我記得是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對了，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "焦糖吐司！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "聽說是非常～非常～有名的公會！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個聽起來很美味的公會名是怎麼回事。",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "正確名稱是【暮光流星群】喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘛，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要說有名也算是有名，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過應該是因為名聲太壞而出名的吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "畢竟是擁有",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "『破壞者』",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "『收藏家』",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "『獨眼惡魔』",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "『移動龍卷風』",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n可怕名號的傢伙所屬的公會啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒錯！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "武士大師",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可不是浪得虛名是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我只是順勢當上會長而已。",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那些傢伙雖然特立獨行，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但絕對不是壞人。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要好～好地勸說，",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "她們也會乖乖配合的唷？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "噫！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "剛剛",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一瞬間，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "突然背脊發冷……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳的公會又是如何呢？　",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "純白之翼的",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n公會長",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是位劍術高強的劍士？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我聽說過這個傳言。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是的，",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "莫妮卡雖然是個小孩，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但也是個非常英勇的軍人是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "實力應該和大姐頭不相上下。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然是小孩子，卻相當厲害是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小、",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小孩子擔任公會長？　",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且還是軍人！？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的沒問題嗎？　",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "從各種層面來說。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到、",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "到底是不是啊？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其他公會成員是什麼樣的人呢？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這個嘛，",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "空花是個被虐狂、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雪是自戀狂、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n步未則是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "跟蹤狂是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……給我稍等一下。",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一口氣聽見太多可疑的單字，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我的思緒變得好混亂。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……我問你，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "她說的是真的嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真希望你能告訴我那不是真的！",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正是！　",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "因為大家都是奇怪的人，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "害得莫妮卡",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一直都很辛苦。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一言難盡忍忍。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……喂喂，",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳絕對也算是怪人吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n幹麻表現出一副傷腦筋的模樣。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你啊，",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在我的同伴們面前也是這樣說吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你對女孩子真的很寬容呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天的事情，",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我想要告訴",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "公會的大家。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我要告訴步未",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和將軍一起登塔的事情，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還要告訴空花",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有感覺會欺負人的",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "魔物存在！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雪呢，",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那就",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "帶一點漂亮的東西回去送給她，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n至於莫妮卡嘛……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦……",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天是訓練日，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我完全忘記這件事了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n回去的話一定會被罵……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而且被關緊閉……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嘛，",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然她有點麻煩，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是我並不討厭喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有這孩子在的公會，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "應該不是什麼壞地方吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就說妳突然被將軍叫走就好了嘛。",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不然，我也可以去幫妳說話啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大、",
        "unit_id": 103011,
        "voice": "vo_adv_7011002_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大姐頭……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "謝謝妳的關心，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "感激不盡呀！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀哎呀，",
        "unit_id": 105611,
        "voice": "vo_adv_7011002_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來我也是個寬容的人呢。",
        "unit_id": 105611
    }
]