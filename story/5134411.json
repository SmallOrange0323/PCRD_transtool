[
    {
        "type": "background",
        "background": "500183"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 128311,
        "voice": "vo_adv_5134411_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n真是的，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個除夕到底是怎樣啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n感覺根本沒有休息到！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "與其說是真的很忙，",
        "unit_id": 128411,
        "voice": "vo_adv_5134411_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不如說是驚慌失措然後瘋狂睡覺呢～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我這輩子好像是第一次",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼拼命地在睡覺。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明內容上都是對的，",
        "unit_id": 128511,
        "voice": "vo_adv_5134411_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但聽起來卻好像是在胡言亂語一樣……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 128511,
        "voice": "vo_adv_5134411_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多虧了初音的努力，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n蘭德索爾才能夠得救。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請讓我再次跟妳道謝，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不會啦，",
        "unit_id": 128411,
        "voice": "vo_adv_5134411_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也不是只有我啊。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小霞跟祈梨",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還有各位，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n也都盡全力在幫我……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你也是",
        "unit_id": 128411,
        "voice": "vo_adv_5134411_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "直到最後都待在我身邊呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "非常地可靠喔，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "謝謝你♪",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊～",
        "unit_id": 128511,
        "voice": "vo_adv_5134411_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咳咳！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "過去的事就回顧到這邊，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們差不多該去逛攤販了吧？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 128311,
        "voice": "vo_adv_5134411_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對耶！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n【哞哞自衛隊】也有給我們報酬，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就用要把現在錢包裡的錢花光的氣勢，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去大吃特吃吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小初音",
        "unit_id": 128411,
        "voice": "vo_adv_5134411_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "想吃點熱熱的食物呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一直在很寒冷的地方走著，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺都要變成冰塊了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼",
        "unit_id": 128511,
        "voice": "vo_adv_5134411_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就去買個鯛魚燒好了。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生如果有什麼想吃的，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也儘管說出來吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "畢竟是值得慶祝的日子，",
        "unit_id": 128411,
        "voice": "vo_adv_5134411_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n大家就一起盡情地享受吧！",
        "unit_id": 128411
    }
]