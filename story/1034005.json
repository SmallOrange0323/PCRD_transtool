[
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到優花梨隸屬的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚，真困擾呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n只有我一個人努力的話，無法完成基本的工作量……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……？\n你竟",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然來公會，真難得。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，對不起！\n我今天有點忙……",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n就算想和你出去也沒辦法……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……莫非你是為了打工才來的？",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n啊啊",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "，真是幫了大忙！ 謝謝！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "其實，公會接到了大宗委託，",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以其他的成員全部都去處理了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "結果其他的委託變得人手不足……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但若是你的話就能夠信賴。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n謝謝你來！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我們一起努力工作吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在這裡喔。\n這次的工作，",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n是採集生長在這個森林的野生漿果。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這個漿果的香氣是它的特徵，所以能馬上就找到，\n但是數量非常多，因此人手不足……",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n啊，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你聞。飄來漿果的香氣了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哎呀，你真瞭解呢。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n呵呵，因為我的關係，你已經聞慣了吧？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這裡的漿果含有酒香呢。\n在它生長的地方會飄著這種香氣。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "稍微加工後也能製成飲品……\n",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但即使它看起來很美味，也不能偷摘來吃喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "要注意。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……什、什麼嘛，那種像是「輪得到妳來說嗎」的眼神……",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我沒問題的。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n雖然這的確是我非常喜歡的香氣…………",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咕。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……啊！？ 沒、沒問題啦！",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我工作的時候不會吃東西的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "請相信姐姐！\n那麼，我們努力去採集吧！",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_013"
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "唔呵呵。啊哈哈哈哈。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂，很好吃喔～。你也吃一個吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "又沒有關～係。你和我……你還未成年，",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以平時我們無法一起喝酒，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但若是吃漿果的話就口以喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我覺得這是件粉不得了的事喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以縮～喂，你也和我一起心情變好吧～！",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "一起做舒――服的事吧～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哼――，小氣――。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n算了――，姐姐要睡了。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n……呼嚕――，呼嚕――。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}平安無事地採集完漿果。\n當他正要叫醒優花梨而靠近她時――\n魔物突然出現了。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯呀……",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸嘿嘿，你……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}不顧熟睡中的優花梨，和魔物開始戰鬥。\n雖然一開始勢均力敵，\n但是{player}漸漸屈居下風。"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，趁{player}不備，\n魔物猛地擊出強烈的一擊。\n正當{player}有了會受到重傷的覺悟時！"
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯呀……\n不能",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "摸那裡～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼……呼……",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n你真",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "的好色喔，呵呵呵……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是，{player}已和魔物戰鬥到疲憊不堪。\n正當他覺得再繼續戰鬥下去會很危險的瞬間――"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯呀……\n不可以連我的份都喝惹～。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "恢復，恢復～……嗯呀嗯呀。",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_022"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500181"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯……",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯～！ 睡得好飽。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……哎呀，是你？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n為、為什麼你會在我旁邊……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦，莫非我在工作時……？",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n因為太舒服而睡著了……！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n讓你一個人工作……！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哇哇……對、對不起！ 真的很對不起！",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我總是受到你的幫忙，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n身為姐姐真是不及格呢！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……？\n你說我反而救了你，所以沒關係，",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是、是什麼意思？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "喂，",
        "unit_id": 103411,
        "voice": "vo_adv_1034005_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n為什麼在笑，喂，喂～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然優花梨完全不知道發生什麼事，\n但是兩人間的羈絆又加深了……"
    }
]