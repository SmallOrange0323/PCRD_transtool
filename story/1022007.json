[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依里找了{player}出來見面。"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呼……感覺心跳好快……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但、但是今天一定要和那傢伙道謝才行！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n他都幫了我那麼多次忙！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就簡簡單單地～輕輕地～咻地～",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說一句「謝謝！」",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還有「再見！」然後回去就可以了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯！簡簡單單！輕輕鬆鬆！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗚哇啊啊啊啊啊啊～～～～！！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "早早早、早安！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n在在在、在這裡碰到真巧啊～～～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……是我找你來的？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊、啊啊，對。對喔。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n抱、抱歉喔，找你出來～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸、欸……其實我有話想跟你說……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n那個……就是……其、其實……那個……謝……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝……謝……謝……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說到那個茜里啊",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊～～～～！討厭！我這個笨蛋！笨蛋！笨蛋～！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_009"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜、茜里和你，不是很要好嗎？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n身為姐姐，我想說應該問問看，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你們有沒有什麼問題……比較好。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……沒有什麼問題？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_011"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你在說什麼？明明就讓她叫你「哥哥」……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n老實說那聽了有點噁心。所以說男人就是這樣……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……不是你要求的？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n是茜里擅自那樣叫的？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n哼～這樣啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還以為是你的喜好呢。",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n所以想說我是不是也叫你「哥哥」會比較好……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，沒事沒事沒事！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那你不喜歡被叫什麼「哥哥」嗎？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "要不要我跟茜里說不要那麼叫你了？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？你覺得茜里就像妹妹一樣，所以不會討厭？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_015"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哼、哼……這樣啊……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_016"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n茜里、是、妹妹啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯～～～好複雜的感覺……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_017"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n聽到「茜里像妹妹一樣」，有種好像忌妒，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但又好像鬆了口氣的感覺……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？找你只有這件事情嗎？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、不是！真正想說的是！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸、欸……謝……謝……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說到那個新遊戲啊",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊～～！又失敗了～～！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_020"
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好，這次就用那個來比賽喔！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊！還有上次呀……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？時間已經很晚了回家比較好？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不、不好！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "竟然已經到這個時間了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你說再見……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等、等等！我、我、我還有想說的話……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "想說的話……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說不出口啊～果然今天也失敗了……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天也是……之前也是……之後也一定……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "之後也一定會失敗？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我不想……我不想……再失敗了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等、等等！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、我有一些話，",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n想要告訴你！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我有話得跟你說才行……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那、那個……就、就是……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我總是受到你的照顧……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "第一次遇到你的時候，我立刻逃跑，",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n明明我就是個怪傢伙，你還追上來，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然我嚇一跳，但同樣地也很開心……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "之後在危險時刻還讓你救了我……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_032"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你還跟我一起玩遊戲……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果像這樣和你一起做很多事情的話，",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n說不定我怕生的問題就能改善了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我是這麼想的。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然現在我能好好說話的對象只有你……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊！但是我覺得其實那樣也不錯……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我從沒想過會有這樣的心情，",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_035"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n自己也嚇一跳，但完全不會覺得討厭……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但我卻總是對你說些失禮的話……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_036"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因此想和你道歉，或是該說是道謝……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以……我……",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我喜……喜……！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "咦、咦？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我不是想對他說謝謝嗎……！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、我、我剛差點就要說什麼蠢話了～～～～！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "…………！！！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、我還是先回去了！再、再見！！！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_042"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！那、那個！那個！欸……！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_043"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不、不要問！不要問！不要問啦！",
        "unit_id": 102211,
        "voice": "vo_adv_1022007_044"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n最討厭你了～～～～～～～！！！",
        "unit_id": 102211
    }
]