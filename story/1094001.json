[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【公會管理協會】送來魔力探測器前，\n古蕾婭等人決定四處逛逛蘭德索爾。\n就在某天――"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "吶吶，{player}！",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_000"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n因為之前大家陪我去過我想去的地方了……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n今天可以帶我們去古蕾婭想去的地方嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "謝謝你！",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_001"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那麼，古蕾婭，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳想去哪裡？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我、",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_002"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我嗎……？　",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗯―……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我沒什麼特別想去的地方……",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_003"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "今天還是",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "去安想去的地方吧。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "在一旁陪著妳就很開心了。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "咦！？　",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_004"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "對、對不起，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我不是那個意思……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那個……",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_005"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "本來就不是那種",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "常外出的人。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "所以，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "雖然才說我沒什麼特別想去的地方……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但我……",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_006"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "其實是個",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "離群的人。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n在故鄉龍之國時，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "完全無法融入周遭的人……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n和朋友一起外出",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "之類的經驗",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "也完全沒有。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭……",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_007"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "即使來到馬納歷亞，",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_008"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "還是不太敢和大家互動……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n擔心因為我的外表和力量，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "是否會感到畏懼",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "因此而討厭我，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "而感到不安。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "所以，",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_009"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我總是待在音樂塔裡，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n一個人彈奏著鋼琴。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但是但是，",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_010"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "最近還滿常出來玩的不是嗎！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "之前，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們不是還在馬納歷亞的街上一起吃冰淇淋嗎，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳還記得吧！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "呵呵……",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_011"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗯。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "能夠和安一起出來玩，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我很開心唷。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我能感受到這份快樂的心情，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "都是因為安教會我的。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不過，",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_012"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "現在",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "光是陪著安",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n去想去的地方",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "就已經竭盡全力了……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "唔。",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_013"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "的確，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我好像老是拉著妳陪我到處跑……！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "因為陪著妳真的很開心，",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_014"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我完全不介意喔？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "只是，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "要說有沒有",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "想去哪裡玩，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我倒是還想不到……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "對不起。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這樣啊……",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_015"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那樣的話，",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_016"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們今天就不出門，悠閒地度過一天，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳覺得怎麼樣？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "咦？　",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_017"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "但是……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這樣好嗎？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_018"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "自從來到這個世界後，就一直到處遊玩，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n所以，偶爾度過這種悠閒的日子也沒什麼不好啊？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "然後，",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_019"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "悠閒途中如果古蕾婭想到要去哪裡的話，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n我們再",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "出發就好了！　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "覺得這樣如何？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "{player}、安……",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_020"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "謝謝。",
        "unit_id": 109411
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，安一行人決定在暫居的\n【咲戀育幼院】裡，悠悠哉哉地度過這天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，中午過後――"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊、{player}！",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_021"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n你有看到古蕾婭嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_022"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "對育幼院裡的書很感興趣，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n一不小心就埋頭閱讀了……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "原本在我身旁的古蕾婭，",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_023"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n一回過神來才發現不見人影。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "咦？　",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_024"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "要陪我一起找嗎……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "太好了，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "{player}，謝謝你！",
        "unit_id": 109211
    },
    {
        "type": "background",
        "background": "500351"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯―",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_025"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "並不在屋子裡呢。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n到底去哪裡了啊……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "該不會",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_026"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "跑到蘭德索爾的街上了……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭應該不會",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "自己一個人出去――",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "…………",
        "unit_id": 109411,
        "voice": "vo_adv_1094001_027"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊，",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_028"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭！　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "居然在那種地方！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "……總覺得",
        "unit_id": 109211,
        "voice": "vo_adv_1094001_029"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "有點鬼鬼祟祟的樣子。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "怎麼了……？　",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "總之，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "悄悄地",
        "unit_id": 109211
    },
    {
