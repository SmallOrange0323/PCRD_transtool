        "words": "你等我一下。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我先把這裡收好。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_066"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你在好奇我手上拿的東西嗎？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是聖誕花圈啦。",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_067"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n你看，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "緞帶和鈴鐺",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟馬蹄鐵很搭吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "前一陣子，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_068"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們不是在山裡的馬廄找到馬蹄鐵嗎？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我試著用那些馬蹄鐵",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_069"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "開發新的伴手禮，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n所以做了這個聖誕花圈啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "結果",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "作為牧場的紀念品，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大受好評呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "客人很喜歡",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_070"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "新的伴手禮，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "倉庫的修理費",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也算是有著落了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "意外發生的時候我還捏了一把冷汗……",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_071"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你看，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如今我這裡的動物也好，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "造訪牧場的客人也好，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家都很開心。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這都是",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_072"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我重要的家人帶給我的幸福吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的是",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太感激啦……♪",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嘿咻……",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_073"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n果然就是要掛在這裡",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才像樣呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這個聖誕花圈是幫我……",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_074"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不只是幫我……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是幫牧場裡重要的家人們……",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_075"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n還有",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "遠道而來的客人們，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n招來幸運的",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最佳聖誕花圈呢♪",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眺望裝飾在牧場玄關的聖誕花圈，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真陽露出滿足的微笑。"
    }
]