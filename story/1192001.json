[
    {
        "type": "background",
        "background": "500863"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在積雪的冬季牧場裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真陽一邊翻修設施，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一邊唸叨著。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔──",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然到處都有問題啊……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在降下大雪以前",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "必須都修好才行。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然靠我的雙手可以修復到某種程度啦，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但還是需要請專業的師傅，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n來進行大規模的整修吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "又不能小看費用……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還是我再來開發新商品",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呢？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛好有客人會來光顧，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也差不多到這個季節啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n開發聖誕節周邊商品應該還不錯吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "新商品……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "聖誕節的新商品",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來賣剩蛋？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n聖誕老人每年要包禮物",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也很惱人……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯嗯？",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛那句好像還不錯？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "節奏不錯還有諧音，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說不定可以用在新段子上耶。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣就不是開發商品，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而是開發新哏了啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊啊，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼辦……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你來玩啊？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不好意思",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等我一下啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我先把這裡的柵欄修好。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最近，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來牧場的遊客",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "慢慢變多了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家都是為了聖誕節，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "來買牛奶、",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n奶油之類的蛋糕材料。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "當然，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "客人變多我很開心，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只是相對的，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "設施的修繕和",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "道路的整理就很辛苦啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難得過來一趟，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我總不能讓大家受著傷回去吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剷雪、",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "翻修柵欄、",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "裝飾……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要做的事情多到跟山一樣高。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "即使是冬天也有一堆事要做的啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你東張西望地在看什麼啊？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那片雪景",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有那麼稀奇嗎？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對喔。",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在蘭德索爾，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n很少會積這麼厚的雪吧。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這對我來說很稀鬆平常，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "已經見怪不怪了啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我小時候",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "常坐著雪橇到處去玩呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真懷念……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你想看雪橇嗎？",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "去倉庫找一找應該會有。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不說了，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要趕緊工作啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我可沒時間悠哉地玩耍呢。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還得趕快剷雪才行。",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你要是小看雪可是會後悔的喔。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯沒錯，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雪的重量壓在建築物上，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n就會發出這種聲音……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊────！",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "倉、",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "倉倉、",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "倉庫！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那邊的倉庫垮了啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥！",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛可不是在搞笑喔！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在不是吐槽的時候啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "動物群",
        "words": "嘶嘶────────！！\n哞────────！！",
        "unit_id": 1,
        "voice": "vo_adv_1192001_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇！",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "剛剛的聲音嚇到正在放牧的動物啦！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n得趕快安撫牠們！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我要去追牠們啦！",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喂────！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等等我──！！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "動物群",
        "words": "嘶嘶────\n哞────",
        "unit_id": 1,
        "voice": "vo_adv_1192001_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "已經沒事了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只要待在這個馬廄裡就可以安心啦～",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我幾乎都抓回來了，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼好像還少了幾頭？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n都去哪裡了呢……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀……",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這裡的柵欄",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "居然壞啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n牠們趁著騷亂",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "從這裡跑到外面去了嗎……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不快點找到的話，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n很有可能會被魔物攻擊。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我得趕緊追上去──",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦，",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n你從剛剛就在翻瓦礫堆，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "到底在做什麼啊？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n離坍塌的倉庫那麼近很危險的。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這……",
        "unit_id": 119211,
        "voice": "vo_adv_1192001_030"
    },
    {
