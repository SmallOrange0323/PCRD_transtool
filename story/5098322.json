    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呼……",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n總算打敗",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們的冒牌貨了……",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯……",
        "unit_id": 122711,
        "voice": "vo_adv_5098322_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n太好了……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這樣就沒問題了",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "吧？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "小繆",
        "words": "繆繆！？",
        "unit_id": 8411,
        "voice": "vo_adv_5098322_002"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "小繆，",
        "unit_id": 122911,
        "voice": "vo_adv_5098322_003"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "怎麼了……",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哇哇！？",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n妳們看，",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "魔物們……！",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "接二連三地來……！",
        "unit_id": 122811,
        "voice": "vo_adv_5098322_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "才想說好不容易克服了自己的想法耶。",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "而且",
        "unit_id": 122911,
        "voice": "vo_adv_5098322_005"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "感覺很強呢……",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n好像和一般的魔物不同。",
        "unit_id": 122911
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "它們一定",
        "unit_id": 122711,
        "voice": "vo_adv_5098322_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是透過門獲得了力量。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……不過",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們沒問題的！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為我們沒有輸給自己的心靈！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "鏡華……",
        "unit_id": 122811,
        "voice": "vo_adv_5098322_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n嘿嘿，",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是啊！",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好──",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們上囉～！",
        "unit_id": 122811
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "上囉～！",
        "unit_id": 122911,
        "voice": "vo_adv_5098322_008"
    },
    {
