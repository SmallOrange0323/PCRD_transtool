    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102711,
        "voice": "vo_adv_5084626_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "怎麼會這樣呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您居然還沒醒來……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也許這是拆散您和我之間感情的邪惡陷阱，",
        "unit_id": 102711,
        "voice": "vo_adv_5084626_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但比起對於敵人的憎恨，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我更氣什麼都做不了的自己……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……莫非這是一場考驗，",
        "unit_id": 102711,
        "voice": "vo_adv_5084626_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就為了測試我的愛？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然不知道是哪個不長眼的人所為，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但這真是無聊的計謀呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好吧，",
        "unit_id": 102711,
        "voice": "vo_adv_5084626_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就讓您清楚地知道，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我的愛有多麼深沉吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻……",
        "unit_id": 102711
    }
]