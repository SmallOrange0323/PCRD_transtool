[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年不在的世界",
        "unit_id": 106812,
        "voice": "vo_adv_5084661_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還真是寂寞呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n讓我稍微……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是想起了和你相遇之前的時光。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……現在分明不是該感傷的時候。",
        "unit_id": 106812,
        "voice": "vo_adv_5084661_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但在我心中，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年所佔據的那份重量",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似乎不允許我這麼想。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……你正在",
        "unit_id": 106812,
        "voice": "vo_adv_5084661_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了回到這裡而努力著。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也必須盡心盡力，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做足所有我能做的事情。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我已經有頭緒了……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我會賭上我的一切幫你的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果是你，",
        "unit_id": 106812,
        "voice": "vo_adv_5084661_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一定能成功克服難關。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就像至今為止一樣，對吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……總是給你添麻煩了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是抱歉。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我相信你哦，",
        "unit_id": 106812,
        "voice": "vo_adv_5084661_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的公主騎士。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n願你得到",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "太陽與星辰的祝福。",
        "unit_id": 106812
    }
]