[
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "怎麼可能，",
        "unit_id": 11511,
        "voice": "vo_adv_5017322_000"
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "怎麼可能，",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "怎麼可能……",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "\n竟然將我……",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "將被魔女所寵愛",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "的我！！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "都已經被打成這樣了",
        "unit_id": 109811,
        "voice": "vo_adv_5017322_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n竟然還能動，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真的是讓人受不了。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就讓拉姆來給他致命一擊吧……",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……等等。",
        "unit_id": 109911,
        "voice": "vo_adv_5017322_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人？",
        "unit_id": 109711,
        "voice": "vo_adv_5017322_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……喂，",
        "unit_id": 109911,
        "voice": "vo_adv_5017322_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你就乖乖投降吧。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n現在",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還來得及。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n而且，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我總覺得……！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "那副模樣……",
        "unit_id": 11511,
        "voice": "vo_adv_5017322_005"
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "別用魔女的模樣",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "和我說話！！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 109711,
        "voice": "vo_adv_5017322_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請您快躲開！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……！？",
        "unit_id": 109911,
        "voice": "vo_adv_5017322_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "您沒事吧，",
        "unit_id": 109811,
        "voice": "vo_adv_5017322_008"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "愛蜜莉雅大人？",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯、",
        "unit_id": 109911,
        "voice": "vo_adv_5017322_009"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "喔～",
        "unit_id": 11511,
        "voice": "vo_adv_5017322_010"
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "魔女啊……",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "莎緹拉啊……！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "\n請給我",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "愛愛愛愛愛愛！！！！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "「不可視之手」竟然比之前還更加厲害了……",
        "unit_id": 109811,
        "voice": "vo_adv_5017322_011"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然不願意這樣想，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n但他應該是",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "將執念轉為力量了吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請您退下，",
        "unit_id": 109711,
        "voice": "vo_adv_5017322_012"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n那個大罪司教，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就由雷姆來……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "沒事的，",
        "unit_id": 109911,
        "voice": "vo_adv_5017322_013"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雷姆。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "讓我來吧……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這必須由我來處理。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n魔女…",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還有魔女教……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "身為王選的候選人……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我不能再讓",
        "unit_id": 109911,
        "voice": "vo_adv_5017322_014"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們世界的糾葛，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n危害到這個世界了！",
        "unit_id": 109911
    }
]