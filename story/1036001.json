[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎、怎麼辦……",
        "unit_id": 1,
        "voice": "vo_adv_1036001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那邊是城中央……所以這邊是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有什麼事嗎？您是哪位？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "學校有教過，不可以隨便和陌生人搭話。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "記得沒錯，好像說是可疑分子……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以你就是可疑分子呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聽朋友說，特別是那種會趁你單獨一人時，過來搭話的男人，",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n都叫做變態。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來，你……就是位變態先生呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請不要向我搭話，",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不然我要告訴老師了喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……為什麼還跟著我呢？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請不要再靠近了，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不然我要按響警報魔石了喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說，只是在擔心我……嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "才不需要變態先生來擔心我呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果不管怎樣都想要跟我說話的話，",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那就先請你證明自己不是可疑分子。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為、",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為什麼要開始脫防具！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟然會在外頭脫衣服，果然就是變態！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "既然沒有辦法證明，那一定就是可疑分子。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是奇怪的變態可疑分子。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟然，會有像你這樣的變態……",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n果然蘭德索爾是個可怕的地方呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "得要趕快回到家才行……",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "能往精靈之森的馬車轉運站是在，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n嗯……沒記錯，剛才是從這邊過來的所以……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……還、還有什麼事嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n不認得路，有什麼不行嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為我已經好久沒有離開過精靈之森了啊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我才不會告訴變態先生自己住在哪裡呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "恕我拒絕。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請、",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請別隨便把人當成迷路的小孩好嗎！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算是一個人我也能夠回得去！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……要把這張地圖給我嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "的確。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只要有了地圖，就算是只有我一個人應該也回得去。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然只有那麼一點點，但稍微對你改觀了呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n奇怪的變態可疑分子先生。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼，我得要回去了。再會。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然不會再遇見了。",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "太好了～",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n順利找到路出城了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "以防萬一還是再看地圖確認一次，",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "馬車轉運站的位置吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我看看，再來只要沿著這條路直走……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？魔、魔物？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎麼辦……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只有我一個人，怎麼和魔物戰鬥……",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、你是！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n為什麼，會出現在這？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……因為還是很擔心，所以就偷偷跟過來了？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "原、原來是這樣。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可是，就算是我們兩個人，也不一定能打倒……",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……咦？總之先攻擊看看？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是，我的魔法威力不足。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？可是，好奇怪？",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n感覺像是力量不斷的湧出來了一樣！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n難不成是你對我做了些什麼嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說、",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說得也是！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "比起說明理由，還是先攻擊魔物！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看、看招呀──！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "成、成功了哦！",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n魔物都被打倒了唷。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "多虧了有你的幫忙。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是我卻還叫你變態，真的非常對不起。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來你說不定是個好人呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我叫做鏡華。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}，非常謝謝你。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果不是你出手幫忙……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……等等，請稍等一下。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "仔細想想，偷偷在後頭跟了過來，怎麼看都很可疑呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036001_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "果然你……是一位變態對吧！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "直到了最後都沒有機會來洗清這份冤屈……"
    }
]