[
    {
        "type": "background",
        "background": "500540"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "開始聖誕約會的{player}和克莉絲提娜。\n兩人正站在雪山上面。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不覺得這映入眼簾的銀色世界",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是副絕景嗎，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "漫無目的地在城鎮裡閒晃實在是太無聊了。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在特別的日子裡，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "需要能讓內心顫抖的刺激吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這才是所謂的聖誕約會！",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吶，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你不這麼認為嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦！　",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "意思是，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要再更冒生命危險、更驚心動魄的地點比較好？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你也是順從自己欲望的人嘛☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好，交給我就好了哦！",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n對你不怕死的精神表示敬意，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就邀請你到能體驗極限狀態的約會地點吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼？",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你說接著換自己來帶路？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很有趣嘛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就讓我好好期待，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這小子的安排吧。",
        "unit_id": 111511
    },
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我還以為會去什麼刺激的地方，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡不是城鎮的郊外嗎。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "帶我到這麼寂寥的地方",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打算做什麼？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "姐姐妳看妳看！",
        "unit_id": 111,
        "voice": "vo_adv_1115002_007"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我會溜了，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我在",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "溜冰唷！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "很棒很棒！",
        "unit_id": 211,
        "voice": "vo_adv_1115002_008"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n我也馬上就過去唷！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯……",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "意外地聚集了很多人嘛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這種地方有什麼……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個是，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結冰的地面……？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還滿光滑的，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像鏡子一樣。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是說",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這裡是源於大自然的冰之舞台啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難怪聚集的人們會在上面溜冰，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "玩得很開心呢？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是小子你所知道的，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n最適合聖誕佳節的地方嗎。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是只有平常在城鎮裡閒晃的小子才知道的知識呢。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我很有興趣。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "怎麼樣啊這位漂亮的姐姐！",
        "unit_id": 1411,
        "voice": "vo_adv_1115002_014"
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "要不要穿上這個，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "溜看看？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喔。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來有出租溜冰用的鞋子啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "民眾也很會做生意嘛♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不放過商機的樣子，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真令人佩服。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我很欣賞，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就接受小子你的提案吧。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要租那雙鞋！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "好的，",
        "unit_id": 1411,
        "voice": "vo_adv_1115002_017"
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "謝謝惠顧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "\n這位小哥，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "要好好照顧漂亮的女朋友唷！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯小子，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要好好地照顧漂亮的克莉絲提娜唷♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還滿像個男人嘛。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我期待你能有讓人無法再叫你小子，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那般活躍的表現唷♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "眼神不錯嘛。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這下子也許，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不該稱呼你為小子了啊♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吶，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "剛才，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說了吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說要照顧我，這樣。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而且出乎意料的，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還很有自信。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但從剛剛我所看到的，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就只是一直在冰上重複跌倒的畫面。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一開始以為是為了讓我開心",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而努力的表現……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但現在看來",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不是在演戲吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且從一開始就沒站好了啊。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有這麼難嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "藉由這雙鞋底下的薄刀刃",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在冰上溜就好了吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種東西，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然沒練過――",
        "unit_id": 111511
    },
    {
        "type": "still",
        "still": "111500201"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――你看。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不是很簡單嘛♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想像有一條軸線，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n從這雙鞋裡的刀刃通到頭頂。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比起在被設下陷阱的險惡道路上戰鬥還要簡單多了。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無須掌握什麼訣竅。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "習慣之後，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "放低重心一邊加速――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一邊保持速度一邊轉身前進――",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順著這個動作一鼓作氣，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也可以用單腳做出旋轉。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳看妳看，",
        "unit_id": 111,
        "voice": "vo_adv_1115002_035"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n那個姐姐，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "溜得好厲害唷……！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好漂～亮！",
        "unit_id": 211,
        "voice": "vo_adv_1115002_036"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n好想溜得跟她一樣啊……！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被那樣閃亮亮的眼神注視的話，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就會不小心幹勁十足呢！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用你的雙眼看好了！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看我的",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大絕招！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "那個姐姐，",
        "unit_id": 1411,
        "voice": "vo_adv_1115002_039"
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "竟然在冰上跳起來了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "\n而且一邊轉――",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "租鞋店",
        "words": "還轉了4圈！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "落地成功☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這感覺還不賴，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓人興致高昂――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯？",
        "unit_id": 111511
    },
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唉呀？　",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有冰塊不平整的地方啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不行啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這個――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過還不到會跌倒的程度――",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子！？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼衝了過來！？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……啊啊，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結果還是跌倒了啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "多虧有你幫我當墊背所以沒事。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過話說回來還真是的，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你剛剛幫了倒忙啊。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然有點搖搖晃晃，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但也算是有平衡住啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "剛剛一瞬間，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你也成功地在冰上溜冰了啊？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看到我陷入危險，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以才能將做不到的事瞬間化為可能。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你如此拼命的來救我的這件事，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我心情不錯。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就稱讚你吧，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對了……",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難得你成功地溜了冰。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n趁著還沒忘記這個感覺，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就由我親自來教導你溜冰的方法吧♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把我的手……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "負責帶領的人應該是你呀。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在發什麼呆。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "快向我伸出手，{player}。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……很好。",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那麼一起，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在冰上玩耍吧♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "直到你會溜冰為止，",
        "unit_id": 111511,
        "voice": "vo_adv_1115002_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不會給你休息的時間唷……？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後就像克莉絲提娜說的，\n沒有休息的餘地不停教導{player}溜冰的方法。"
    }
]