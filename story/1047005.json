[
    {
        "type": "background",
        "background": "500122"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……咦，奇怪？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我，睡著了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不知道是什麼狀況。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這裡是，哪裡呢？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來似乎很眼熟……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊，是【咲戀育幼院】的建築物呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小咲戀要重建【咲戀育幼院】的時候，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有在提交的資料中附了照片。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為內部的裝潢變得很漂亮，讓我以為我看錯了，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以並沒有馬上發現。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "努力地進行打掃，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並且四處湊齊家具了吧……小咲戀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那孩子從以前開始，就是個努力的人呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【咲戀育幼院】以及，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們【王宮騎士團】……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n都是隸屬於【公主騎士】旗下的公會。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也有能夠互相合作的地方吧。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也想，為那孩子加油。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但現在，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為各公會之間的關係有點微妙……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以不太能公開行動呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦，少年？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼，會倒在床的旁邊？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒事嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還活著吧……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，似乎還有呼吸。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n太好了太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼了？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n身體不舒服嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那真是太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若是如此，你為何會倒在這裡呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你說明詳細經過，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嘛，老實說，不太好呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為身體不適，全身就像鉛一樣沉重……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然平常因為習慣而感覺不到鎧甲和頭盔的重量，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但現在卻像是快被它們壓垮了一樣呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話說，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我的事情怎樣都好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n比起這個，我不明白現在的狀況，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你能為我說明嗎……少年？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你在打工回來的路上，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n發現了倒在地上的我嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為不能放置不管，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以就把我送到了自己寄住的【咲戀育幼院】？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那還真是，受你照顧了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n果然，你是個溫柔的人呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n由於近來治安惡化，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以及【王宮騎士團】的人力不足……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還有制度的變化等等，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此除了像以往的守衛以外，也必須要做其他工作。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天也是……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在索爾之塔的周圍不知為何產生大量的魔物，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以進行了捕獲任務。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身分不明的，相當強大的魔物啊……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且並非討伐牠們，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而是受命得捕捉他們，因此相當費勁呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "由於人才缺乏，甚至得動員沒經驗的隊員，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了輔助他們，稍微逞強了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說來慚愧，我因此而受了傷。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是什麼嚴重的傷，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此只做了緊急處理。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過從這種感覺看來……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n似乎是那些魔物有毒，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或者傷口被細菌入侵。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我好像發燒了一樣，感到一陣頭暈。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n結果可能因此在回去的路上暈倒了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真難為情……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我是【王宮騎士團】的團長，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但主要的任務是守衛呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對於討伐魔物等等，我還不太習慣。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但這可不能當作藉口呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了守護大家的和平，我只得更加精進自己才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n難不成你會倒下，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是因為被我傳染了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或是我身上還殘留著魔物的毒性，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你因為觸碰到我而產生了相同的症狀？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若真是如此的話，實在非常抱歉。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓我看看吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "緊急處理的話我還是能應付的，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n感到疼痛或者不對勁的話請告訴我。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n把我送到這裡很費力，所以精疲力盡了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此才躺下來休息的嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你說，因為我佔據了床鋪，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以只能躺在地板上……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那真的是非常對不起呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n很重吧，我……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為一直在鍛鍊呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為渾身肌肉，所以體重比普通女孩子更重，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說起來，盔甲原本就有相當的重量了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我要趕快回家了喔。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，請你好好的睡在床上。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "受你照顧的恩情，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總有一天我一定會回報的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哇……",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎、怎麼了？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你別突然把臉靠過來，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說，既然身體不舒服，希望我可以安靜地休養……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年可以請小咲戀讓你睡在其他房間，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以沒問題？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說實話，能這麼做我會很感激。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "高燒讓我像是要沸騰一般，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n連像這樣說話都感到很痛苦呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那就恭敬不如從命，",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我就再稍微休息一會吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "痊癒之後，再重新向你道謝吧。",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_052"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……真的很謝謝你，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047005_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……哇？",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為、為什麼要把我的頭盔拿下……？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我、我的家訓規定，",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若被人看到真面目是不行的！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不要看，真丟人……！",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯。",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你覺得戴著頭盔入睡的話，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n會睡不好？",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話雖如此，",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_058"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n請不要突然把我的頭盔給脫下來……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然不擅言詞的我也沒有資格這樣說，",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_059"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但你可真是說明不足喔。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "算了。",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好像不是別有用心，",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也沒有悠哉地跟你吵吵鬧鬧的力氣……",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "以防萬一，我在頭盔下面戴著面具，",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_061"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也算守住最後一道防線了啊。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然是你的話，",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_062"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n感覺可以隨意地讓你看見我的真面目也無所謂。",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但真對不起呢。",
        "unit_id": 104713,
        "voice": "vo_adv_1047005_063"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n果然，還是很害羞…",
        "unit_id": 104713
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…",
        "unit_id": 104713
    }
]