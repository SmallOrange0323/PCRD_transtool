[
    {
        "type": "background",
        "background": "509012"
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長！",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "快一點快一點──！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不快點的話，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "海要跑掉了──！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長，",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真天真，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你太天真了哦。",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然海的確不會跑掉，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但快樂的時光一轉眼就會不見哦。",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "特別是──",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在生日這天來玩的時候！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之前我們兩個來的時候，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n忙著幫助別人，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幫著幫著一下子就到黃昏了。",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這一次，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會只看著學長你──",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛剛的當我沒說！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "忘了它吧。",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來吧，",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來玩吧來玩吧──！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要從什麼開始？",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為是難得的生日，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來把想做的事全都做一遍吧！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很好～",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "首先，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "先從長距離游泳開始──",
        "unit_id": 122431
    },
    {
        "type": "background",
        "background": "510251"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "──噗哈～！",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "玩得真痛快～",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "身體動不了了～",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿。",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為都沒遇到有困難的人，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以一直都只有我們兩個！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是因為夏天快結束了嗎？",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "整片海洋就像是",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只屬於我跟學長一樣……",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇哇，",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "仔細重新一想，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的只有我們兩個……！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一有自覺後，好像",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "突、",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "突然不好意思起來了。",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n學長的臉",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在夕陽照射下，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總覺得……",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊……",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個是",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "生日禮物？",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇啊，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好漂亮的手鍊……",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "夕陽的照射透了過去……",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝你，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "學長……",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿♪",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是的，",
        "unit_id": 122431,
        "voice": "vo_adv_4010198_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "前輩……！",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n被你這樣對待，",
        "unit_id": 122431
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我沒辦法直視前輩的臉了啦～！　",
        "unit_id": 122431
    }
]