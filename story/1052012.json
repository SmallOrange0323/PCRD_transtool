        "type": "dialogue",
        "name": "莉瑪",
        "words": "公主的樣子",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n一定就像妳這樣子吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "身穿這樣美麗的禮服，",
