    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n在正式演出前能夠",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "拿出自信冷靜演出，我也覺得太好了！",
