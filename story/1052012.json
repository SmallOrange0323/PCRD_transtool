    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都終於要正式演出了……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我是受到邪惡魔法師的詛咒，",
