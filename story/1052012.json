        "type": "dialogue",
        "name": "住戶",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "舞台劇上演的那天，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "我一定會來看的！",
