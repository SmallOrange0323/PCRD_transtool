        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我等妳來！",
