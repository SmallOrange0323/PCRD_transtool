        "voice": "vo_adv_1052012_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "變成魔物之姿的",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "公主。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在舞台上我會以這姿態演出到最後，",
