[
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "決定出演舞台劇的莉瑪，\n連日努力不懈地進行嚴厲又熱烈的練習。"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對不起！　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "麻煩讓我再來一次！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "不，",
        "unit_id": 1411,
        "voice": "vo_adv_1052012_001"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "先休息一下吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "要好好休息，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "轉換一下氣氛吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "辛苦了。",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝你",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "每天都這樣",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "陪在我身邊。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我都一直被罵，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你看著也覺得很沒意思吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你說沒這回事？　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算是為了願意這麼對我說的你，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我必須努力才行呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "我拿水來了喔，",
        "unit_id": 1511,
        "voice": "vo_adv_1052012_004"
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "莉瑪。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇～！　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝妳！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "莉瑪，",
        "unit_id": 1511,
        "voice": "vo_adv_1052012_006"
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "妳的表現越來越好了，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "保持這個步調繼續加油！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "那麼，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "我還有",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "別的工作先走了！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "除了你之外，",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還有其他",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那樣關心我的人在，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我不努力可不行呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算是導演，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也是為我好才責罵我的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其實我",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對被罵這件事",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還挺樂在其中的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我總是被人所畏懼，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以覺得很新鮮吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能夠盡全力，",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "然後被責罵、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "被鼓勵。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的讓我好開心。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "正因為如此，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我更應該要回應大家的期待呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會加油的，請好好看著我喔！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "就是那裡！",
        "unit_id": 411,
        "voice": "vo_adv_1052012_010"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "是這裡嗎！",
        "unit_id": 711,
        "voice": "vo_adv_1052012_011"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n那個把魔物帶到城鎮裡的劇團！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀！？　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎麼了怎麼了！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "魔、",
        "unit_id": 1511,
        "voice": "vo_adv_1052012_013"
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "魔物！？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "女性工作人員",
        "words": "\n在哪裡！？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "做什麼啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1052012_014"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "你這傢伙！　",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "怎麼突然間硬闖進來！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大、",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家冷靜下來！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "已經習慣這種事情了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是啊，",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "事情果然會變成這樣……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n至今事情都像奇蹟般順利進行，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但這也無可奈何呢……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就、",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就是說呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都已經到這地步了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我怎麼可以放棄呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "！？",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n對啊！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這裡才沒有什麼魔物呢！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "你們鬼鬼祟祟在說些什麼！",
        "unit_id": 711,
        "voice": "vo_adv_1052012_019"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "要是想反抗，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "我是不會客氣的！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "看來就算這樣你們也沒有要放棄啊。",
        "unit_id": 711,
        "voice": "vo_adv_1052012_020"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n要讓你們嚐點苦頭了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "展現練習的成果？　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是因為",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "魔物不會演戲嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也是呢！　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會盡全力去做的！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請你好好看著喔，{player}。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "做、",
        "unit_id": 711,
        "voice": "vo_adv_1052012_022"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "做什麼！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n不准妳再靠近了！！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是想殺的話，",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那就動手殺吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我也",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "和你同樣",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "留著鮮紅的血，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n你就用那雙眼好好確認吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我是人類！　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "即使被變成這個樣子，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我的血與心，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n也依然是個人類啊！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不如乾脆",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓我流著",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "青藍之血、擁有冰冷的心，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我就無須受到這樣的折磨了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "來吧，",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "用那把劍",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "割斷我的喉嚨吧！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那麼，",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在那之後",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你若是能有那麼一點後悔之心，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就能毫無疑問地",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "相信我是個人類了……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我、",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我做到了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我覺得這是我有史以來演得最好的一次！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但這次",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "說不定就會變成我最後一次演戲了……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "…………",
        "unit_id": 711,
        "voice": "vo_adv_1052012_029"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "實、",
        "unit_id": 711,
        "voice": "vo_adv_1052012_030"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "實在非常抱歉。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n看來是",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "我們誤會了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "住戶",
        "words": "因為妳那身玩偶裝實在過於真實了……",
        "unit_id": 411,
        "voice": "vo_adv_1052012_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？　",
        "unit_id": 105211,
        "voice": "vo_adv_1052012_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是嗎？　",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊哈哈……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我才是，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真對不起。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
