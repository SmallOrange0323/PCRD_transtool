        "type": "dialogue",
        "name": "苑",
        "words": "……跟彩羽交換身體已經差不多一年了。",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_012"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n我既不會腰痛，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "也不會肩膀重、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "手腳冰冷，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "或者莫名其妙偏頭痛。",
