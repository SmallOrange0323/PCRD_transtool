    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩名來自異國的少女"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到了蘭德索爾的房屋仲介處。"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……咦咦！？",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_000"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n你說房子不能租給我們，這是什麼意思！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "簽約金、押金、禮金。",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_001"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "還有第一筆房租我們都付得出來喔。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我們還算有一些存款的，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "雖然接下來的生活就必須省到極點了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "是啊……",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_002"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "而且",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我們也會好好賺錢的。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不要看我這樣，我可是天才鍊金術師，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "賺錢的方法要多少有多少……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "還順便自誇了一番。",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_003"
    },
    {
        "type": "dialogue",
        "name": "房屋仲介",
        "words": "鍊金術師……？",
        "unit_id": 2511,
        "voice": "vo_adv_3022001_004"
    },
    {
        "type": "dialogue",
        "name": "房屋仲介",
        "words": "聽起來好可疑。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "房屋仲介",
        "words": "\n說到底，租賃契約這東西",
        "unit_id": 2511
