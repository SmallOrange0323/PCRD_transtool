        "type": "dialogue",
        "name": "苑",
        "words": "咦？",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不對吧。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n要大人的話，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "你眼前不就有一位──",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……啊。",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "糟糕。",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_007"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n現在的我，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "根本是小孩子的身體……",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "可惡。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "喂，",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_008"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "苑妳在說什麼啊……！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "啊、",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "啊哈哈，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "抱歉打擾了～",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "房屋仲介",
        "words": "……小孩子的身體？",
        "unit_id": 2511,
        "voice": "vo_adv_3022001_009"
