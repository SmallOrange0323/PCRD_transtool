        "name": "露易絲瑪莉",
        "words": "百比零，是彩羽的錯！！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘖──！",
        "unit_id": 132412,
        "voice": "vo_adv_3022001_067"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "為什麼啊，不過就是小孩子的可愛胡鬧嘛。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n既然是大人，就該有大量啊～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "不是……",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_068"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "彩羽妳的外表是大人啊。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n所以妳那不是小孩子的可愛胡鬧，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "而是豐滿劍士的失控舉動了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "豐滿劍士的失控舉動？",
        "unit_id": 132412,
        "voice": "vo_adv_3022001_069"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哇～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這好像露易喜歡的那種，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n傷風敗俗小本本會有的標題～♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "什麼！！？",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_070"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "妳妳、",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "妳在說什麼呢！？！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n我對那種傷風敗俗的書，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "可是一點興趣都沒有喔！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……唉，",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_071"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "一切都結束了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n本來還對新生活感到興奮，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒想到竟然被打入大牢。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "期望與現實落差太大，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "耳鳴都要發作了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "不過精靈耳不會耳鳴就是了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "原來精靈的耳朵",
        "unit_id": 132412,
        "voice": "vo_adv_3022001_072"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不會耳鳴啊～？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒事，我隨便說說的。",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_073"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "總、",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_074"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "總之，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我們要先好好說明清楚，解開誤會！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n至少必須讓他們明白我們並沒有惡意……！",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "要是被問東問西的會很麻煩，",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_075"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "所以我是希望盡量隱瞞就好……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "但是這樣下去事情只會越來越糟糕不是嗎？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n所以只能說清楚了。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "告訴他們彩羽和苑的身心",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_076"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "彼此互換了，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n所以雖然彩羽的外表是大人，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "但實際上只是一個10歲的小女孩。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦……",
        "unit_id": 1,
        "voice": "vo_adv_3022001_077"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那是因為",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "鍊金術的藥",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "造成的嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……是啊。",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_078"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "那是能夠讓身心互換的",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "「禁忌祕藥」。",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n其實那種藥就算讓身體互換，幾十分鐘後就會換回來……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n但彩羽和苑",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "卻已經互換了快一年──",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "呃，妳是誰啊！？",
        "unit_id": 132312,
        "voice": "vo_adv_3022001_079"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_3022001_080"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我並不是有意偷聽的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "抱歉自我介紹晚了。",
        "unit_id": 118511,
        "voice": "vo_adv_3022001_081"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我是",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "公會管理協會的花凜。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "公會管理協會……？",
        "unit_id": 132512,
        "voice": "vo_adv_3022001_082"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哇……",
        "unit_id": 132412,
        "voice": "vo_adv_3022001_083"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這位綠色頭髮的大姐姐，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n感覺實力就跟惡魔一樣強喔……？",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵，",
        "unit_id": 118511,
        "voice": "vo_adv_3022001_084"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不用對我那麼防備。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我是站在各位這邊的喔♪",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "露易絲瑪莉、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "彩羽"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "還有苑，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n三人才剛來到蘭德索爾就被關入大牢。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她們多災多難的蘭德索爾生活就此展開。"
    }
]