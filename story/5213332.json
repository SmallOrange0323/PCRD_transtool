[
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "唔唔唔……",
        "unit_id": 20111,
        "voice": "vo_adv_5213332_000"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "真是為所欲為哈尼呢……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n不過不過，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "再這樣下去可不行哈尼！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n梅莉莎大人就由我來守護～！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "哈尼哈尼硬邦邦肉盾模式！",
        "unit_id": 20111,
        "voice": "vo_adv_5213332_001"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "呵呵，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "這裡可不會讓你們通過的哈尼～！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哈尼哈尼對不起！",
        "unit_id": 138312,
        "voice": "vo_adv_5213332_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n先請妳讓開一下喔～！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n呼啊～！！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦咦！？",
        "unit_id": 138312,
        "voice": "vo_adv_5213332_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全毫髮無傷耶！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的非常硬呢……！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唔──",
        "unit_id": 138212,
        "voice": "vo_adv_5213332_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「硬邦邦肉盾」這話，",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看來並非誇大其詞。",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n既如此，此番可施之計唯有一途。",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……裝作視而不吧。",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "原來如此。",
        "unit_id": 138111,
        "voice": "vo_adv_5213332_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只要無視那個，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n橫掃整個範圍，",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就能打到哈尼哈尼後方的敵人。",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n對吧？",
        "unit_id": 138111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "驚！！",
        "unit_id": 20111,
        "voice": "vo_adv_5213332_006"
    }
]