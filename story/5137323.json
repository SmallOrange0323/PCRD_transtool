        "voice": "vo_adv_5137323_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊……",
        "unit_id": 135514
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊啊啊……！！",
        "unit_id": 135514
    },
    {
        "type": "dialogue",
        "name": "埃拉、志那都",
        "words": "啊啊啊啊啊啊啊！！！",
        "unit_id": 1,
        "voice": "vo_adv_5137323_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……唔。",
        "unit_id": 128911,
        "voice": "vo_adv_5137323_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我感受到了……",
        "unit_id": 128911,
        "voice": "vo_adv_5137323_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n透過星素之力感受到了……",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她們兩個的悲痛……",
        "unit_id": 128811,
        "voice": "vo_adv_5137323_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "苦惱………",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "憤怒……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這還只是其中的一部分嗎……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……做個了結吧，",
        "unit_id": 128711,
        "voice": "vo_adv_5137323_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "各位。",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和……",
        "unit_id": 128911,
        "voice": "vo_adv_5137323_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 128811,
        "voice": "vo_adv_5137323_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做個了結吧。",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可不能讓精靈一直為所欲為下去。",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要把精靈",
        "unit_id": 128711,
        "voice": "vo_adv_5137323_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "從兩人身上趕出去……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後獲勝！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經不會──",
        "unit_id": 128711,
        "voice": "vo_adv_5137323_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n再讓她們兩個的笑容被奪走了！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "優衣、怜",
        "words": "嗯！\n好！",
        "unit_id": 1,
        "voice": "vo_adv_5137323_011"
    }
]