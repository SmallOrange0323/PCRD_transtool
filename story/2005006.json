[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被詭異的光芒給包圍，\n一瞬間失去了意識。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，眼睛睜開後……\n景色已經變得完全不同了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "群山都在腳下，人處在高空之中。\n{player}被重力所牽引，正在墜落。"
    },
    {
        "type": "still",
        "still": "200500601"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你還好嗎，{player}？　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有沒有受傷呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對不起唷，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還對你這樣公主抱。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話，我們的立場就反過來了呢～",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}還真是個不能放著不管的孩子♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很好很好♪",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你沒事就太好了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼啦～身體抖成這樣？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為很可怕嗎？　",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說的也是呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟是從那麼高的地方掉下來嘛♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係唷，",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就這樣好好地跟我撒嬌吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是男孩子，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一直逞強也是會累的嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n偶而也要放鬆一下，覺得",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "害怕或哭出來都可以。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會好好地安慰你，",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "幫你鼓勵打氣的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～乖、好～乖……♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等安心之後，",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要打起精神哦……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總有一天要換你來幫助我哦。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一直被公主給保護的王子，",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n果然",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是會有點遜呢",
        "unit_id": 105811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500215"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看到你們關係這麼好是很不錯……",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但可別掉以輕心。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有人正朝這邊接近。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才沒有掉以輕心呢～",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n畢竟有妳這樣的危險人物在身邊嘛。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳真是過獎了。",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她是誰？好像是從",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【拉比林斯】的祕密基地裡走了出來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n唔，感覺好像在什麼",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "地方見過的樣子？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔，",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基先停下來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": " \n那邊有人在，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "提高警覺！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "好。",
        "unit_id": 107311,
        "voice": "vo_adv_2005006_013"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n既然妳要我停下，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "那我就不往前走",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n現在",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我打算遵從妳的指示。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……請小心，",
        "unit_id": 107311,
        "voice": "vo_adv_2005006_014"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n好像不太尋常，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n有種",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "像野獸一樣的感覺。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼野獸啊。",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這說法也太跨張了吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n竟然這樣形容",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我這樣的美女……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這傢伙，",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呃……你是誰啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n突然忘記了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我本來對自己的記憶力還挺有自信的說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "唔。",
        "unit_id": 107311,
        "voice": "vo_adv_2005006_017"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n妳",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "認識我嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "抱歉，",
        "unit_id": 107311,
        "voice": "vo_adv_2005006_018"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "因為我的記憶有點混亂……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "妳認識她們嗎？",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n啊，克莉絲提娜！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳為什麼會在這裡！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……咦？　",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "知道我是誰啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": " \n看來我也變得很有名了呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就這樣子看來……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳也",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不記得我了嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不好意思，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我沒這種記憶呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": " \n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這位小姐，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們在哪裡見過面嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊……",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳不記得的話就算了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然這樣不太好，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但現在也沒什麼時間好好說明吧？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}！　\n{player}你也在啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這是什麼情形！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼，",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這玩笑一點也不好笑！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是我啊，我！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該、該不會你忘記我了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗚～你要好好記住啦！",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是矛依未！或是諾維姆！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太好了，你還記得我啊？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛那個，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是在開玩笑？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為記憶喪失了一些，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以對於新的事物的記憶力不錯吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟腦袋曾經清空了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n能一口氣裝進不少知識嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呀哈哈。",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然已經習慣被叫矛依未了，但加上個『",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "小』還是怪怪的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n感覺很不對勁！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你原本",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這樣的人嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總覺得～好像變成小朋友一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是記憶喪失的關係嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過算囉！",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n{player}，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也沒事呢……♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最後看到你的時候，狀況實在太糟了，",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以一直很擔心你唷～。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊。",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我想也是。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為你很溫柔嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，你不用擔心唷",
        "unit_id": 106112,
        "voice": "vo_adv_2005006_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然被叫做【拉比林斯】的一群人給囚禁了起來。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但現在",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被這位拉基拉基給救了出來唷♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "諾維姆，小聲一點。",
        "unit_id": 107311,
        "voice": "vo_adv_2005006_035"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "……請看正上方，有個很危險的東西在。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2005006_036"
    },
    {
        "type": "background",
        "background": "500215"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那是……",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n她怎麼會在王宮外面？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n而且",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那副不祥的模樣是？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個人是……！？",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_038"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呵呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_039"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n不只是『誓約女君』",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "克莉絲提娜，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n就連『跳躍王』",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "拉基尼卡東也在啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『晶』應該也在這附近才對，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_040"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n包含我在內，這裡都是『七冠』呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "還有諾維姆",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_041"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "和{player}……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這簡直就像是在開同學會一樣，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "都是一些令人懷念的面孔呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "雖然是自己策劃的，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_042"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但沒想到能這麼順利地將大家聚集在一起呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呵呵。",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_043"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n各位，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你們好啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我是尤絲蒂亞娜，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是這個世界的王哦。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜？",
        "unit_id": 105811,
        "voice": "vo_adv_2005006_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n竟然面不改色地說這種話，這次你可別想跑！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n快把我的一切，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還給我……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_045"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呵呵。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n妳為什麼會在這裡呢？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳的優先順序比較後面唷，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_046"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『公主大人』……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不過妳也蠻礙眼的，就順便把妳給解決掉好囉？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要是受到多餘的抵抗也很麻煩，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_047"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以我話先說在前頭。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n在這一帶的山裡，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n有我從王國中召集而來的魔法師們正在待命。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "他們在這裡設下了結界，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_048"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以沒人可以逃得掉。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n而且那個『跳躍王』，也還沒完全恢復狀況嘛……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就算想要妨礙我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "應該也無法突破那個結界唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這裡是蜘蛛的巢穴，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_049"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不對，應該說是流沙地獄……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "也不對，是你們的墳場。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你們幾個就在這裡手牽著手去死吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我要放出蓄積已久的龐大魔力，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_050"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "施展戰略級的攻擊魔法……♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "雖然這麼說你們可能無法理解，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_051"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這魔法應該可以說是媲美核子武器的威力呦。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你們幾個，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可是會死得連肉屑都不剩呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "會妨礙我完成霸業的傢伙們，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_052"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n就要在此一併掃蕩……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "啊～",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "事情能夠按照計畫進行，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真是令人愉悅啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "雖然很想幫你們頌個經，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_053"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但我",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "本身算是神道教的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n對這個世界的宗教",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "也完全不熟呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳在說什麼啊？　",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n感覺妳是想要把我",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n跟這裡的所有人全都殺掉似的……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是為了這目的，",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才把我派到這裡來的嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": " \n好把我引誘到這種境地，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順便解決掉？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下……",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，尤絲蒂亞娜，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n麻煩妳好好說明一下。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果能讓我聽得開心，我就幫妳拍手。",
        "unit_id": 107111,
        "voice": "vo_adv_2005006_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是很無聊的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就把妳給殺了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "殺我？",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_058"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不行哦，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "光憑你們這些人類……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n是無法弒神的。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_059"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要做為這個美麗新世界的神君臨大地。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "為了達到這個目的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你們幾個會很礙事。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以要來把你們給一網打盡。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "把『七冠』的一半，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_060"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n以及快要解開這世界謎底的【拉比林斯】……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n順便連",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『公主大人』也一起消滅掉。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "至於{player}嘛，想知道的事情也都問完了，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_061"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以已經沒用囉。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "反正我要施展魔法，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_062"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n就必須瞬間移動到這裡來……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以也把你給一併帶過來了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "啊～",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_063"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真是清爽啊。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這麼一來我的計畫，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "也能進行到下一個階段了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個計畫是什麼呢？",
        "unit_id": 1,
        "voice": "vo_adv_2005006_064"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": " \n跟我說一下嘛，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣讓人很在意耶～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，終於現身了啊。",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_065"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n『晶』……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不對，現在是【拉比林斯】的首領，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n記得是叫做拉比林斯達是吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯。",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我好不容易才建好的祕密基地，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n被妳給搞得亂七八糟了呢～",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟妳可是派了整支軍隊來，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n嚇了我一大跳唷。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呼，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我還以為我要死了。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過啊……",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『物件變更』可是我的看家本領，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以祕密通道當然也是準備好囉。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n靜流她們也是，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是運氣好一點，應該也逃了出去。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳應該跟她們一起逃跑的。",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_069"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n不過很在意這邊的狀況，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以才跑來吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "還是跟以前一樣，無法抵擋自己的好奇心。",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_070"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這就是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "妳最大的缺點唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯～",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然妳說話的口氣好像跟我是朋友一樣……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但妳",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是誰啊？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉啊～我忘了！",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為我實在很不擅長記住別人的長相啊～♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我啊，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可是很喜歡人類呢。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哼……",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_074"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就只有這一點，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不對，無論什麼事情",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我跟妳的意見總是完全不同呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "算了，",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_075"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n閒聊就到此為止。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "各位，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你們就在此消滅吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "在我那美麗新世界裡的登場人物",
        "unit_id": 106914,
        "voice": "vo_adv_2005006_076"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n只要有我一個人就夠了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你們所有人，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就要在這裡就玩完囉……♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一個人的人生要在何時結束，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_077"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不應該是由其他人來決定的哦。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "各位，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_078"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "該怎麼辦呢？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是繼續像個蠢蛋一樣張大著嘴巴發呆，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n大家都會被殺掉的唷。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然你們會覺得我這突然跑出來的人很莫名其妙，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_079"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但現在要不要合作一下？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要集合我們的力量，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_080"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n應該總有辦法順利活下來吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "順帶一提，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_081"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我現在還不想死。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為被人『託付了很重要的東西』。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那邊那位少年……{player}，\n我有東西想要交給你呢。",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_082"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個嘛，",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_083"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "等順利度過眼前難關之後……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n自我介紹跟其他事情就到時再說吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n現在得先想辦法撐過這波攻擊才行～。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……唉，真是的。",
        "unit_id": 106813,
        "voice": "vo_adv_2005006_084"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "無論什麼時候，人生都不簡單呢♪",
        "unit_id": 106813
    },
    {
        "type": "still",
        "still": "200099901"
    }
]