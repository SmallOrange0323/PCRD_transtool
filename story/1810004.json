[
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了對巨靈還以顏色，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和古蕾婭正在聽安的作戰計畫。"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "上次戰鬥後我有發現……",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_000"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "們至今為止面對的巨靈，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n都是只靠著巨大身體和肌肉",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "進行物理性的攻擊，對吧。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那個奇怪的巨靈一開始也是這樣……",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_001"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但是最後一擊",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "卻是透過魔法攻擊的。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "而且受到這一擊的時候……",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_002"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我感受到了古蕾婭和我的魔力。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "恐怕──",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那個巨靈，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_003"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "能將受到的魔法傷害轉換成自己的魔力，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n並將累積的魔力釋放出來……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我推測，它能使用反擊魔法。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "也就是說我們越使用魔法攻擊，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_004"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n巨靈就會變得更強！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "是不適合交由魔法師來對付的敵人呢……",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_005"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "這樣的話",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "不使用魔法的話比較好嗎？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我之前也是這麼想的……",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_006"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "不過在這個人幫我們強化的狀態下，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n兩個人一起全力攻擊時，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我明白了一件事。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那個時候，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_007"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們第一次對巨靈造成了傷害。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n明明在那之前不管用什麼魔法，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "都完全無法傷到它！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想巨靈當時立刻放出魔法反擊，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_008"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n也是因為它覺得繼續受到攻擊的話就不妙了。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "說不定",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_009"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "能將受到的魔法傷害進行轉換的量是有極限的喔！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "也就是說……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們一口氣使出來的魔力量如果高到它來不及轉換，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n應該就能打倒那個巨靈！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "嗯嗯……？",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_010"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "唔──嗯，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_011"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "也就是說……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "拿跟露一起玩的遊戲當作例子……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n如果用半吊子的攻擊就會被反擊打倒，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n那我們就得「一擊讓體力全滿的敵人徹底倒下！」",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這樣！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "光是要打倒普通的巨靈，",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_012"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我們就得全員應戰才會順利了……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "現在要做這種事，辦得到嗎……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "可以的！",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_013"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "不是用加法，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "而是用乘法的話！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳回想一下，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "之前上課時有學過一次「共鳴詠唱」……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "也就是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭和我要共同施展魔法！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "只是……",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_014"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "詠唱時會釋放大量的魔力呢。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "察覺到危險的巨靈可能會趁機襲擊我們，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "問題是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "在詠唱時，古蕾婭和我都無法動彈……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭、安",
        "words": "咦！？",
        "unit_id": 1,
        "voice": "vo_adv_1810004_015"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "雖然說魔導具的力量確實大幅增加你的能力了，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_016"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n但是……！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "獨自對抗巨靈，",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_017"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "還是很危險喔……！",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭、安",
        "words": "……？",
        "unit_id": 1,
        "voice": "vo_adv_1810004_018"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "那個，",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_019"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "雖然",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我們的確也會待在一起……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "…………",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_020"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我知道了。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "要是覺得危險的時候，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我們絕對會救你的。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭、安",
        "words": "嗯……！",
        "unit_id": 1,
        "voice": "vo_adv_1810004_021"
    },
    {
        "type": "dialogue",
        "name": "亞種巨靈",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 11212
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那個人正拚盡全力幫我們吸引巨靈的注意。",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_022"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n這段期間……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "準備好了嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "我隨時都可以開始。",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_023"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那麼，進來這個魔法陣裡。",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_024"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n然後牽起手……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "連結起魔力的導線。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_025"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "連結上了。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n配合好安的魔力波長了，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "接下來──",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "亞種巨靈",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 11212
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……！",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_026"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n那個人……！",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭，",
        "unit_id": 109211,
        "voice": "vo_adv_1810004_027"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "波長亂掉了。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "……總之現在",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "得集中在術式上才行。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_028"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "抱歉。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n但是……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "亞種巨靈",
        "words": "──嘎喔喔喔喔喔！\n──嘎喔喔喔喔喔！\n──嘎喔喔喔喔喔！！",
        "unit_id": 11212
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭、安",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_1810004_029"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "果然就算有魔導具輔助，",
        "unit_id": 109411,
        "voice": "vo_adv_1810004_030"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n這樣下去還是會……！",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "猛虎斬擊──！！！！",
        "unit_id": 1,
        "voice": "vo_adv_1810004_031"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "亞種巨靈",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 11212
    },
    {
        "type": "dialogue",
        "name": "安、古蕾婭",
        "words": "咦！？",
        "unit_id": 1,
        "voice": "vo_adv_1810004_032"
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "哈哈哈！！",
        "unit_id": 911,
        "voice": "vo_adv_1810004_033"
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "使出必殺技啦！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "喂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "小姐！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男隊長",
        "words": "麻煩妳趁現在幫小伙子治療囉！",
        "unit_id": 911
    },
    {
