[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "──嗚、",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚呀啊！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n團團團團長你、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為什麼、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會有那個東西……！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "歸還！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哇哇哇哇哇……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個那個那個",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變成樹！！！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……說的也是……",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "事已至此，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "逃避跟隱藏也沒有意義了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這的確",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是我在雜貨店購買的陶鍋……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚嗚。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看來我只好敞開腋下開誠布公了……",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請聽我說吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實最近，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的身邊",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "多了超乎我以往所能想像的眾多",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「朋友」……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一般的存在。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "於是得意忘形的我，",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在雜貨店看到這個陶鍋後，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就忍不住策劃了起來……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只有被選上的夥伴們才能舉辦的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個活動……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是「火鍋派對」！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "於是我得意洋洋地結完帳，",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "臉上帶著傻笑，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n使盡全身之力",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "將這款可輕鬆烹煮五人份的陶鍋扛回家。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然後我才察覺到一件事。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那就是我家",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒有「鍋墊」這個東西……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……對毫無火鍋派經驗的我來說，",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "根本不曉得竟然有鍋子以外的",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n必要物品！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我這種邊緣人",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "居然想舉辦「火鍋派對」，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n真是異想天開！！！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請大聲地恥笑我吧，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "更何況講到「火鍋」……",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "火鍋！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "火鍋料呢？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自由放！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n根本是做實驗啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是要陰沉到不行的我，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "把自己當試紙去測試嗎！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n………………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我辦不到！！！！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵，",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當我回過神的瞬間，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒想到意外地平心靜氣呢。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難道，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這就是所謂的頓悟嗎……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "事情就是這樣，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不自量力的我深切地反省自己，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "使用了祕密廢棄服務。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………咦？",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你說鍋墊，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不管是用報紙或是毛巾",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實都可以？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n火鍋料",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "只要參加者一起去購買，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "當場決定就好？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "任何人",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "都能舉辦火鍋派對……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長………………！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n…………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既然團長",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你都這麼說了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那就姑且、",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "保險起見、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "以防萬一，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了迎接數億年一次、像星星繞行般的幸運之日到來……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就在庭院地下深處挖個洞，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "把這口陶鍋埋起來保管吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……嘿嘿……",
        "unit_id": 104011,
        "voice": "vo_adv_5122061_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n看來",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我得去買",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "撈浮沫的勺子才行呢……",
        "unit_id": 104011
    }
]