[
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在雇主夫妻的帶領下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優衣和{player}來到了下個活動設施，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備進行檢測──"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「是優衣的功勞」……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生的那句話，",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "讓我好開心啊……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "忍著不要偷偷笑出來，",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n再試著努力做點我能做的事情吧！　",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……我本來是",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼想的……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但這個，",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "實在太……！　",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "下一個活動是這個！",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_005"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "鏘──！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個是",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "炒麵……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗎？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "這不是普通的炒麵喔。",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_007"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n我取名為",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "「愛的一心一意炒麵」。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "情侶要一起從兩端開始吃這個，",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_008"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "由一條細長麵條所構成的炒麵。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "這正是為了情侶們設計的午餐時間活動。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩、",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "兩人一起，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "從兩端開始……！？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這這這、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這到底是在想什麼啊……！？　",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因、",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為這個，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "吃到最後必定會",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n親、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "親親，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "親親親……！？",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真要說起來！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n要跟騎士先生這麼近距離面對面……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行！",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不行不行不行！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我絕對辦不到啦！　",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "優衣？",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_012"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n怎麼感覺妳盯著炒麵",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "在發呆？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……啊！",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不是的……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚嗚……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_015"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}的提案之下，\n一行人決定先小歇片刻──"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唉……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再這樣下去會重蹈剛才的覆轍……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那一定又會",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "給騎士先生添麻煩。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然很抱歉，",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但還是辭掉這份打工吧……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在就去找的話，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也許能找到替代的人選。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "既然這麼決定了，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就要讓造成的麻煩降到最少。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我得趕緊去告訴社長他們……！　",
        "unit_id": 122611
    },
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "社長他們",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的確是往這方向走了……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長的聲音",
        "words": "妳還在生什麼氣啊？",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_021"
    },
    {
        "type": "dialogue",
        "name": "專務的聲音",
        "words": "……「還」是什麼意思啊？",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_022"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_023"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "說到底這實在太老套了，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這種黏黏膩膩的",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "直白企畫。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n應該還有其他選擇吧？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我就是",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_024"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "想做這種類型的活動嘛。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……我說啊，話先說好喔。",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_025"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n你說「想辦場能讓情侶們玩得開心的活動」？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "我說那句話時，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "是因為那時才剛創業好嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "是15年前喔。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "因為結婚和開公司而浮躁的女人",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_026"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "所說的幼稚夢話，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n你居然到現在還",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "一直重視著。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n甚至擅自推進成企劃？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這決策錯得也太誇張了吧。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_027"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "呵呵，",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_028"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我無話可說。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我在蘭德索爾到處磕頭，",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_029"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n一路鞠躬哈腰地接著",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "跟打雜一樣的企畫。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "邊看著委託人的臉色，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "邊拚命讓它實現。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "要變得能以自己發想的企畫借到資金，",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_030"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "就花了15年啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "……終於啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "終於。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n我能走到這一步，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "也都是多虧了兼任專務的老婆大人。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "…………輪不到你說。",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……原來是這樣啊……",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這個活動是這兩人",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "15年來的……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "社長的聲音",
        "words": "話說回來，",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_033"
    },
    {
        "type": "dialogue",
        "name": "社長的聲音",
        "words": "{player}和優衣，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長的聲音",
        "words": "跟我們還真像啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……？　",
        "unit_id": 122611,
        "voice": "vo_adv_1226002_034"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……咦……",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_035"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "原來你也",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這麼覺得。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "真的跟年輕時的我們",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_036"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "一模一樣啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "看著他們，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "我就莫名覺得這企畫會成功。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "………………",
        "unit_id": 6511,
        "voice": "vo_adv_1226002_037"
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "……嗯，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "專務",
        "words": "這感覺我也不是不懂。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "哦？",
        "unit_id": 1411,
        "voice": "vo_adv_1226002_038"
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "奇怪？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
        "words": "什麼嘛，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "社長",
