[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吶，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然是有點久以後的事……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是如果生了小孩，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你想要為他做什麼？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們家",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在父親大人經商成功之前，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的沒什麼錢……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也幾乎沒有去哪裡玩，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n或是收過禮物。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "取而代之的，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是從小時候開始，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父親大人就會帶我去談生意，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起為了進貨遠行，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還有教我看帳本。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然跟普通家庭不一樣，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但現在我知道，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n那是父親大人",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "極盡全力的愛。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也想要像那樣，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為孩子做些自己能做到的事……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該說是很有你的作風嗎……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就像小孩子會有的想法呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我覺得跟你一起挑禮物，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也非常有趣喔。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會喜歡怎樣的東西、",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會因為什麼而開心……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像這樣做各種考慮。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果買得太多可不行，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以每次都要再三煩惱，精挑細選出最棒的禮物呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也會陪我一起對吧？",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "陪我選禮物。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "手工玩偶",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "或玩具都不錯呢♪",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也想送給流夏的小孩，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有育幼院的孩子們……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說的沒錯！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟你在一起的話，每天都像是冒險呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟你很像，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很會照顧人卻很莽撞，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然有點不諳世事而且有點呆呆的，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但一定會是非常溫柔的孩子呢。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "去各種地方，",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "體驗各種玩樂。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想每天肯定連感到無聊的時間都沒有。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那真的……",
        "unit_id": 127512,
        "voice": "vo_adv_5128074_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "非常令人期待呢！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n希望那樣的日子，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總有一天會到來就好。",
        "unit_id": 127512
    }
]