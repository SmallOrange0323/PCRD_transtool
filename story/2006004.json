[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得也是呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "本來是不打算害大家被我個人的事情波及，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以才刻意隱瞞的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但現在大家都已經被牽扯到這麼深了呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果這樣還默不作聲的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就太不誠實了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明白了。",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就讓我在能說的範圍內，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來和大家說明吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家可以繼續吃沒有關係，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽我說就好囉。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "200600401"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的本名是，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n「尤絲蒂亞娜‧F‧阿斯特賴亞」。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以統治這個蘭德索爾的王族",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "長女身分出生。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很常誇獎我呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然很開心，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但你突然用認真的表情誇我的話，會害我心跳不已。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很不妙呢……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起哦，你沒有聽清楚嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是尤絲蒂亞娜・馮・阿斯特賴亞哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是個很煩又有點難念的名字對吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我還小的時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n根本沒有辦法說出自己的全名哦～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果很難記的話，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就和以往一樣叫我貪吃佩可就可以囉。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "200600402"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n王族的長女，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不就是這個國家的公主……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "噫呀？",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這個那個…？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小、",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小女子的態度甚是無禮！\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還請公主網開一面……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊哈哈。",
        "unit_id": 102311,
        "voice": "vo_adv_2006004_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n鈴莓，妳在慌張什麼啊？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n真有趣～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不不不？",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這只能深感惶恐了吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在這個國家的傳統中，",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "公主會成為君主……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也就是說這位大人，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n未來會成為我國最偉大的人哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我竟然讓這位大人，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一大早就為我下廚煮飯……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳不需要這麼拘謹哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說穿了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也就只是一個很普通的女孩子而已。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果你們願意和以往一樣，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n把我當作四處流浪的貪吃佩可來對待的話，我會很開心的。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2006004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過貪吃佩可小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就這麼稱呼您囉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在下還是對這名字比較熟悉。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有個問題想問您，",
        "unit_id": 105913,
        "voice": "vo_adv_2006004_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼身分如此高貴的您，會在外面流浪呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該說……",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我家大小姐也曾任職於王宮中，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我也看過貴族的名簿。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因此如果是公主大人的話，",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n應該一眼就能認出來了才對。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在貴族名簿中，",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n記載了包含皇族在內，所有身分高貴人士的",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n面容照片及詳細的個人資料……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是，",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我卻沒有馬上注意到您是公主。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個…",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n您該不會，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n用魔法改變了長相了嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想，應該有這種高等魔法才對。",
        "unit_id": 102511,
        "voice": "vo_adv_2006004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然僅限於使用",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n保護重要人士之類的場合就是了……？\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是我本來的面貌哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但真要解釋的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還是有一些複雜的理由呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_2006004_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "等等唷？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n因為我們家也是貴族所以知道……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這個國家的國王陛下不是獸人嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "明明代代都在壓迫獸人，",
        "unit_id": 102311,
        "voice": "vo_adv_2006004_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "結果國王陛下自己也是獸人……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n當我聽到爸爸媽媽這麼說的時候，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就覺得好詭異唷～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為，",
        "unit_id": 102311,
        "voice": "vo_adv_2006004_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n他們明明是同一個種族，卻這樣差別待遇對吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就像在掐自己的脖子一樣，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好奇怪唷。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然爸爸和媽媽，",
        "unit_id": 102311,
        "voice": "vo_adv_2006004_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像對這件事情並不抱有任何疑問就是了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯。",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n很不可思議的是，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n似乎並沒有多少人對這件事抱有疑問。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想應該是被某種魔法所影響，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓大家都不去思考這種問題呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就直說了，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n現在被當作一國之主的那個人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是欺騙了王族的「冒牌貨」。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我被那個人奪走了名字、",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n地位、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以及所有一切的一切。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被奪走？",
        "unit_id": 105913,
        "voice": "vo_adv_2006004_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是什麼意思呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這種事情，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真的有辦法做到嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913,
        "voice": "vo_adv_2006004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下並不是在質疑",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐所說的話。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是理所當然的疑問。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連我自己，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都無法明白為什麼會變成這樣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從某天開始，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就突然變成這樣了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我依循王族的傳統，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n到全國各地進行武者修行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那是為了繼承王位，所必須完成的儀式。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n當我順利完成武者修行，回到王宮時，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家卻早就忘了我的事情。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不論是父親或母親，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n甚至是長年侍奉我的家臣及僕人都一樣……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就好像完全不認識我似的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "取代我的是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一個自稱是尤絲蒂亞娜的神秘人物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家都把她當作公主對待。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒錯哦，{player}。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個對我們施展戰略級大量破壞魔法、",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像是白色狐狸的獸人……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她就是從我這裡奪走了一切的",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n『冒牌公主』。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那傢伙，假扮成我……",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n進而取代了我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n扮演著公主，堂堂正正地君臨這國家之上。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我完全不清楚，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她的真實身份和目的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你和她說了些什麼對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n待會",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請告訴我你們說了些什麼。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那傢伙就是我們共通的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n最難對付的敵人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一開始",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我還以為是什麼很惡劣的玩笑。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又或者是，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為我的武者修行還不足，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因此大家還不願意承認我是公主什麼的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還是覺得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常奇怪。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太詭異了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種事情……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那時候，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我都開始懷疑不正常的人其實是自己了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n腦袋整個亂成了一團。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我的名字。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是父親和母親滿懷愛情，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n以異國的舊女神之名為我命名的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我依舊記得父親對我提起這件事情時，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那撫摸著我的頭的手掌的感覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也記得母親",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那溫柔的笑容……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這一切的一切，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n全都被奪走了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論是父親或母親，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有其他所有人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n全都忘了我……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甚至",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還說我是冒牌貨……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n叫來衛兵把我押出城外，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還對我發了通緝令。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很難受……",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我一直告訴自己這不是真的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只是一個玩笑、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一場惡夢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我多希望這些事沒發生過。",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然我也曾將這些事情和其他人說過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但依舊",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有一個人願意相信我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在被通緝的同時……",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我就順著習慣繼續進行著武者修行，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那是雙親還記得我的時候，叫我做的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我內心期待著「這次一定沒問題」，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後回到了蘭德索爾。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後在半路上，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就遇見了{player}和小可蘿。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的很開心，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n覺得很幸福……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以露出笑容聊天，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n圍在一起吃飯，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真的好久沒有這樣了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不做個了斷不行了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個冒牌的尤絲蒂亞娜，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n目標很明顯就是我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想，我這個『本尊』的存在，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對她來說想必相當礙眼吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以說，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在我害大家捲入這些危險的事情以前，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n得和各位道別了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正因為與你們一起度過的這些日子，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是如此的閃閃發光又幸福洋溢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我，",
        "unit_id": 105812,
        "voice": "vo_adv_2006004_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才不願意連你們都被奪走。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我沒辦法承受失去你們這種事情。",
        "unit_id": 105812
    }
]