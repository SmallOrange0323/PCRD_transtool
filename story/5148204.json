[
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然",
        "unit_id": 131611,
        "voice": "vo_adv_5148204_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "勉強修補好泳裝了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但是卻因此",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "完全跟丟失控史萊姆了呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對不起……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不會啦～",
        "unit_id": 131111,
        "voice": "vo_adv_5148204_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n追根究柢的話",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "應該可以算是我的錯吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "彼此都別在意啦，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小莉莉～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "應該是遇到的對手不好的關係啊～",
        "unit_id": 131211,
        "voice": "vo_adv_5148204_002"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "溶解衣服，",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "雖然是種看似在開玩笑的能力，",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n但是那是大多數女性的天敵啊～",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "其實",
        "unit_id": 131111,
        "voice": "vo_adv_5148204_003"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那也可以拿來做好事就是了──",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這就是所謂的無論什麼力量，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "都是要看用法吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那麼，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我們就重新打起精神去找吧～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "謝謝您們……",
        "unit_id": 131611,
        "voice": "vo_adv_5148204_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "涅婭小姐。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n能用溶解衣服的能力",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "來做的好事，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "到底是……？",
        "unit_id": 131611
    }
]