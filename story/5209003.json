        "type": "dialogue",
        "name": "剎鬼",
        "words": "對。",
        "unit_id": 135915,
        "voice": "vo_adv_5209003_002"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n跟你的力量",
