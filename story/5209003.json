        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "在送別會時，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我應該早就已經和騎士公建立起連結了。",
