        "type": "dialogue",
        "name": "雪野",
        "words": "原、",
        "unit_id": 135812,
        "voice": "vo_adv_5209003_008"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "原來如此……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "真高興又能見到妳。",
