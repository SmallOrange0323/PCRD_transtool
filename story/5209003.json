    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但是，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就在剛才雪野也能夠認知到我了。",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那時候雪野沒有，",
        "unit_id": 135915,
        "voice": "vo_adv_5209003_001"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "而現在卻有的東西。",
