    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "啊，",
        "unit_id": 135915
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然我也不討厭，",
