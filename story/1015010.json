[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在和美里一起冒險的最後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n取得了花的種子。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒錯沒錯。",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n把種子撒在那裡，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "輕輕蓋上一層土。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "然後",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要澆上足夠的水喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很好，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "做得很好。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "接下來就只要",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "等它發芽囉。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "以後要每天",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "幫它澆水，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不能忘記喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這個嘛，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我想想喔……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為精靈之森的",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "土壤非常肥沃，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是非常適合植物生長的環境，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以只要每天好好澆水，我想應該就沒問題了～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊。",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有一件事",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很重要喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這件事不僅是對花，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對任何事……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "每當你「培育某種事物」時，都是很重要的。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那就是─",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "─愛喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵。",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你還無法理解是嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過呢，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這點可不能忘記喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}你也嘗試帶著愛去照顧吧。",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那麼一來，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這朵花也一定會回應你的。",
        "unit_id": 101512
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天又是美好的一天呢～♪",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我要趁孩子們來之前準備好才行。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n玩具和繪本，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "早安。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你今天來得很早耶，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n以往都是在其他孩子到齊的時候來的啊……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……咦？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來澆水的？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你還真心急呢～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真可愛，你的頭髮睡到翹起來囉。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這麼急著要過來嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "早上要澆的水",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "平常都是由我統一澆的，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以你不用這麼辛苦也沒關係的……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過也好。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "既然都過來了，你也和我一起去吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對了，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你吃過早餐了嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n早餐如果沒有好好吃，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一整天都會沒有力氣的喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你就跟老師一起吃吧。",
        "unit_id": 101512
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "又隔一天。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你又早起過來了嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是努力呢。",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我想，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}的花一定也會很高興的。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天其實不用澆水喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為昨天晚上",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是有下雨嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果澆太多水，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n花朵的肚子",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也會變得鼓鼓的喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你如果吃得太飽，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "動作也會變得遲緩不是嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過既然你都來了，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可以請你幫老師的忙嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天因為地上濕濕的，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不能去外面玩，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以我打算改成",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "讓大家學唱歌。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我教孩子們唱歌的時候，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n如果{player}可以先開口唱出來，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那就太好了。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有些孩子很害羞，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我需要你當那些孩子的模範……♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "又過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你現在已經",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很會澆水了呢～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n小花都閃耀著光芒，好像很開心喔♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你在跟它們說話嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……看來你跟小碧問過讓它開花的訣竅了吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也來",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟它們說說話吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "各位小花～♪",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你們",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "要像孩子們那樣，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "健健康康地長大喔～♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那是什麼？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n顏色好奇怪的液體……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "朋友幫忙製作的營養劑？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有那種東西呀～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_031"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這個真的沒問題嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "顏色是深綠色，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好像還一直冒著泡泡……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──然而，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "花卻完全沒有發芽。"
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在那之後已經過了幾天了，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "卻還沒有發芽呢。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我覺得新芽應該差不多要冒出頭了才對呀……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……為什麼沒有發芽呢？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_034"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "精靈之森明明是",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "非常適合植物生長的環境……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就算要請小碧幫忙，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_035"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n現在還沒有發芽，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以也無法讓她聽小花的心聲。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "莫非，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_036"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是一種很難開花的植物嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n種在精靈之森無法開花嗎……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可是那孩子那麼努力，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣的話……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小花呀，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_037"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你聽我說。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那孩子每天都很努力，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我希望你可以回應他的努力……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_038"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你在啊！？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……早安。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你今天也很早來呢～！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……那個，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_039"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你會不會太勉強自己了？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你總是一大早就過來照顧這些花，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一直忙到很晚……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "…………",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_040"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……那個，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_041"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你是不是",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很焦急？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣啊……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_042"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "看來，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n小花遲遲不發芽這件事讓你很在意呢。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒問題的，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_043"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你不用擔心喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n新芽還沒有冒出來，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就證明了小花它現在很努力喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……所以，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_044"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "開心一點吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}你一直哭喪著臉，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n會讓小花也會不敢探出頭的。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……好嗎？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_045"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……！",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_046"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒有那回事……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_047"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "絕對不是那樣的。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你為了這棵小花，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_048"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "每天早早起床，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "到處找人請教、",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "找人幫忙，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "任何你做得到的事，你都盡力去做。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣的努力，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_049"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是再正確不過的事了。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "抱歉……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_050"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你一定很不安吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過請你一定要相信，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_051"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你的愛",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "絕對不會是錯的。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這孩子",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_052"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有很多事都不懂。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我不該隨口",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說什麼愛的……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "害他因為等不到發芽，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n就誤以為",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是自己的愛不夠，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為此感到不安。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對這孩子來說，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_053"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "「做自己」是最困難的事。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……但這卻是非常重要的事啊。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……我必須教導他。",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_054"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然難以用言語表達，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但只要是",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我能夠做到的……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你先暫時……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_055"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就這樣乖乖別動喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_056"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼樣？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣有沒有……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_057"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n或多或少",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感受到我的心意？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這就是……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_058"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "愛。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我希望你能綻放笑容，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_059"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "希望你能健康成長。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這種珍惜重視你的念頭，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就是你現在",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_060"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "努力帶給這棵小花的心意喔。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你有沒有……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_061"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感受到呢？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感受到我的愛……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_062"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_063"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是你的",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "力量……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不僅我感受到了，",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_064"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還穿過我的身體……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "擴散到森林裡……？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "多麼溫暖、",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_065"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "多麼溫柔的力量……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "森林好像很高興……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_066"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我從來沒有",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "見過這種事……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊……！",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_067"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你看！",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_068"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n花圃那邊……！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是啊……！",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_069"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這一定是因為",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你的愛傳達成功了……！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的是……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_070"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "太好了。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n呵呵呵呵呵……♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊──！",
        "unit_id": 5411,
        "voice": "vo_adv_1015010_071"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "美里老師",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "和大哥哥",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "在抱抱──！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊啊啊，",
        "unit_id": 5311,
        "voice": "vo_adv_1015010_072"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不行啦，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這種時候就要安靜地躲在旁邊啊～！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_073"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦！？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你們大家",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼會……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為美里老師妳不在，",
        "unit_id": 5411,
        "voice": "vo_adv_1015010_074"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所以我們就想說",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "會不會在這裡！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯，",
        "unit_id": 5311,
        "voice": "vo_adv_1015010_075"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我們大家就一起過來找妳～",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎、",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_076"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "已、",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "已經是這個時間了嗎！？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這、",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_077"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這個啊，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是你們以為的那樣喔！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這個是為了愛、",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就是……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇──！",
        "unit_id": 5411,
        "voice": "vo_adv_1015010_078"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n相親相愛──！！！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "美里老師，",
        "unit_id": 5311,
        "voice": "vo_adv_1015010_079"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "恭喜妳～！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊……",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_080"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀哎呀……！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這、",
        "unit_id": 101512,
        "voice": "vo_adv_1015010_081"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這下該怎麼辦才好？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "討厭，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你們都太早熟了啦……！",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "歡笑聲充滿了整座精靈之森。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n花圃裡新萌芽的生命似乎也開心地隨之搖擺。"
    }
