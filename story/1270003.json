[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "熱氣奔騰的被虐狂夏日慶典終於來到了最後高潮。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一路贏到這裡的空花，正準備挑戰決賽。"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "以強烈自尊彼此碰撞，",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_000"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n勝出至此的各位被虐狂！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "歡迎來到被虐狂夏日慶典的最後舞台！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生～♪",
        "unit_id": 127011,
        "voice": "vo_adv_1270003_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你有看到嗎～？",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！",
        "unit_id": 127011,
        "voice": "vo_adv_1270003_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在對空花打暗號……！",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n那是……",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要空花坐下嗎？",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎、",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼這樣，",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好害羞……！",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "最後舞台嗎……",
        "unit_id": 312,
        "voice": "vo_adv_1270003_003"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "我為什麼勝出了呢……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "我接下來",
        "unit_id": 413,
        "voice": "vo_adv_1270003_004"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "會遭受什麼樣的摧殘……？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "咕，",
        "unit_id": 6311,
        "voice": "vo_adv_1270003_005"
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "雖然我一度",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "因為那個叫空花的被虐狂",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "而失去信心，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "\n但被虐狂夏日慶典冠軍寶座，我是不會讓出的……！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "嗯，",
        "unit_id": 6511,
        "voice": "vo_adv_1270003_006"
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "是啊……！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "\n我可是為了參加這場慶典，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "\n而走出了精靈之森……！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "各位真不愧是眾多被虐狂當中",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_007"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "出類拔萃的被虐狂！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n大家對於最後舞台的鬥志",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "也非比尋常！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼接下來",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "我要開始進行最後舞台的說明了！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "最終決戰",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_008"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "是以這片大海為舞台的競賽！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n海的對面可以看見終點，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "最先抵達的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n將成為這場被虐狂夏日慶典的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "稱霸者！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？",
        "unit_id": 127011,
        "voice": "vo_adv_1270003_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是要比",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "游泳的速度嗎？",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "哎呀，",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_010"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "無須擔心。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "畢竟這個活動是",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "被虐狂夏日慶典！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "游泳速度快不快並不重要！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "對於不會游泳的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "我們將出借泳圈！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "可以用泳圈",
        "unit_id": 312,
        "voice": "vo_adv_1270003_011"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "也沒關係",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "嗎……？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "話說回來，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "游泳並不重要的意思是……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "該不會……",
        "unit_id": 413,
        "voice": "vo_adv_1270003_012"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "沒錯！",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_013"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n等待著各位的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "當然會是",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "被虐狂夏日慶典最艱難困苦的關卡！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "這附近的海域目前",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_014"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "經由主辦單位之手！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "──聚集了大量的魔物！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "參加者們",
        "words": "你們是笨蛋嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_1270003_015"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "敬請放心！",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_016"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n再次強調",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "被虐狂夏日慶典",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n是安心又安全、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "為被虐狂所舉辦的慶典！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "雖說是魔物，",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_017"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "但並非是兇惡的類型，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n牠們不會危害人類，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "僅僅是",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "有點刺激性的魔物！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "真想立刻去暴打那個主持人……！",
        "unit_id": 413,
        "voice": "vo_adv_1270003_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 127011,
        "voice": "vo_adv_1270003_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n有刺激性的魔物，",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "到底",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "會是什麼樣的刺激呢～？",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n真令人期待～♪",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為了能夠慢慢享受，",
        "unit_id": 127011,
        "voice": "vo_adv_1270003_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要用泳圈來游泳～♪",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼，",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_021"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n被虐狂夏日慶典最後舞台！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "請負責解說的虐待狂先生",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "跟我一起喊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "可惡，",
        "unit_id": 312,
        "voice": "vo_adv_1270003_022"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "只能上了！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n唔喔喔……",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "喔！？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n什、",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "什麼東西！？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "有東西，",
        "unit_id": 413,
        "voice": "vo_adv_1270003_023"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "纏到我身上……！？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "這是",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "章魚的腳……！？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那是",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_024"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "附近經營章魚燒店的老闆",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n借給我們的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "巨大章魚──章魚仔先生！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "啊啊～～",
        "unit_id": 1,
        "voice": "vo_adv_1270003_025"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "～～～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "真是太亂來了……！",
        "unit_id": 6311,
        "voice": "vo_adv_1270003_026"
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "但是，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "因為區區觸手就停下腳步，太愧對被虐狂之名了！",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "\n我可不會因為這種程度──",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "啊哇哇哇哇哇哇！？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "……這是",
        "unit_id": 6511,
        "voice": "vo_adv_1270003_027"
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "會放電的水母……！？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "\n他們怎麼會放這種魔物……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "哇啊！？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "\n什、",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "什麼……！？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "有好多魚",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "在戳我的腳……！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那是",
        "unit_id": 2511,
        "voice": "vo_adv_1270003_028"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "名叫舔舔魚，喜歡惡作劇的小魚！",
        "unit_id": 2511
    },
    {
