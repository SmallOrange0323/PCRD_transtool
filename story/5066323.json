        "voice": "vo_adv_5066323_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們也有",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一部分的責任呢……",
