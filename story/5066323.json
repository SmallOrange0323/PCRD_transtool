    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在的我，",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經和過去的我不一樣了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說得好，",
