    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哼，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真沒用的傢伙。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "出現的都是雜魚是因為還在低階層的關係嗎，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n還是說這塔就只有這點程度呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是精采～！",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘉夜的實力非常強大呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "照這樣子一口氣前進吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳不上前戰鬥嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n從剛剛就只是在後面跳舞聲援而已啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我聽人說過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳的實力很高強的吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "比起上前戰鬥",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我比較喜歡唱歌跳舞",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有享受美食之類的唷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喂喂，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "守護城鎮的公會這副德性真的沒問題嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n說起來妳跟著過來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是為了要守護他的嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈哈～",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴也常常",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "警告我太過鬆懈了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "並非只有上前戰鬥是守護的全部的唷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈？",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那是什麼意思啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在一堆魔物的塔裡",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "默默地持續戰鬥的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不只身體，連精神也會跟著疲倦對吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不保持平常心的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是非常危險的唷。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我要讓大家心情快樂起來",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才能保持平常心的唷～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要不忘記笑容與平常心",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不管怎樣的困難都能夠克服～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然可以了解所說的意思，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但我想說的不是那個啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我想要見識妳的實力啊！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我就知道你會這麼說～！",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說起來，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剛才看了嘉夜的戰鬥後，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我想到新的舞蹈了呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起唱歌跳舞一同歡樂吧～♪",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……抱歉",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "容我拒絕。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真是的，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來完全是看走眼了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n雖然看起來的確不是外行人，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但絲毫沒有半點緊張感",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也沒有戰鬥的意識。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是所謂的強者的從容嗎，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是單純什麼都沒在想？　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "同樣是武鬥派還稍微期待了一下的啊。",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還是專注在原本的目──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "休想得逞～",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喝啊～！",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……咦？",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼，",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是千鈞一髮呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒事吧？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒有受傷吧？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……呼。",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "剛才的真的很危險呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是那傢伙，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "比我還要早反應過來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且只用一擊就把魔物打倒了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那傢伙完全沒有胡鬧的意思。",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "全心全力",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "盡力在守護著他啊！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且剛剛那一擊，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "非常準確瞄準了弱點。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果能跟這種傢伙切磋的話……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "糟糕，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有點興奮起來了……！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_024"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香織啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能不能跟我──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_7025001_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剛才的騷動的關係",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "魔物們都注意到這邊了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘉夜，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "難得妳邀我一同跳舞，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但還是稍後再說吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我並不是想說那個……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "現在只要知道那傢伙的實力高強就足夠了。",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n互相切磋的機會",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在這之後多得是。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼迅速解決這些魔物吧。",
        "unit_id": 106511,
        "voice": "vo_adv_7025001_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這次不要只是看著，",
        "unit_id": 106511
    },
    {
