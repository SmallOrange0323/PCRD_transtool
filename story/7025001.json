    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "上吧上吧嘉～夜～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "別輸了呀別輸了呀",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嘉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
