    {
        "type": "dialogue",
        "name": "黑心商人",
        "words": "哼，",
        "unit_id": 2511,
        "voice": "vo_adv_1032009_034"
    },
    {
        "type": "dialogue",
        "name": "黑心商人",
        "words": "我只是把稀有的東西賣給想要它們的人而已。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "黑心商人",
        "words": "\n可沒做任何虧心事啊？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "黑心商人",
        "words": "我也是在做生意，",
