    },
    {
        "type": "dialogue",
        "name": "黑心商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "黑心商人",
        "words": "就算有點貴，但還是許多人想要購買。",
