    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我親自",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n仔細且嚴厲地",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "教導你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "上流社會的生活方式！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
