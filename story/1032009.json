[
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}站在布告欄面前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n尋找著新的打工去處。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "站在那裡的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不是{player}大人嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n果然沒錯！ ",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "竟然能和你在街上巧遇，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果然非常有緣呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我剛談完一筆生意正準備回去呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "回去後還是有",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "堆積如山的工作等著我就是了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最近公會運營得很順利，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "優花梨她們也忙得不可開交。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而我也是，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "像這樣一個人外出洽談生意的機會變多了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "每天都過得十分充實雖然很令人高興，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但果然還是想增加點人手呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話說回來，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你又是在這裡做什麼？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "打工？",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣啊，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以才會來這裡看公會管理協會的布告欄。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我剛才光顧著注意你，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都沒有意識到這件事，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是慚愧呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你有找到什麼好工作嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……看你的反應，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該是沒有呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊！",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你聽我說，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我想到一個好主意了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只要讓你成為我們【墨丘利財團】的職員，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不對，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "乾脆讓你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n成為我的管家就行了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "想要工作的你，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和需要人手的我。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣供給和需求",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雙方都能獲得滿足！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我真是的，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為什麼一開始沒有這麼做呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是你",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才好啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n擁有豐富的工作經驗和人脈、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "再加上",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "克服了失憶\n這樣的逆境，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你可是難能可貴的人才呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "醜話說在前頭，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這份工作",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "相當不簡單喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算對你而言",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也是如此。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而相對的，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我能保證給你的酬勞和待遇",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "絕對不會低。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你意下如何，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要不要為本小姐工作看看呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就這麼決定了！",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那麼首先，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們去裁縫店吧。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在就來幫你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "訂製一套管家服！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真不愧是紫藤家御用頂級裁縫店的作品。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你覺得",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "穿起來如何？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才沒有那回事呢。",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這毫無疑問",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是為你量身打造的訂製款，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而衣服就是要穿上才有價值，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不然就只是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一塊空有美麗外表的布而已。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會感到不自在",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是因為你還沒在管家這行做出成績。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今後你在我身邊做事，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "成為一流的管家時，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "肯定會覺得這套服裝就像身體的一部分一樣自在。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對吧對吧。",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n能明白這套服裝的價值，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真不愧",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是你呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵。",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "想到我們今後會以",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "主人和管家的身分一起走下去，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我的心中就充滿雀躍呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來馬上又有一筆生意要談。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們走吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼會這樣！",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們還有生意要談呢，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "路竟然被封起來了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好像是有強盜團在這附近作亂，",
        "unit_id": 1011,
        "voice": "vo_adv_1032009_020"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "騎士團正在現場處理。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這下在事情解決前只能乖乖等著了。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "今天的生意對象可是位大忙人，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要遲到一分鐘，這筆生意就會泡湯。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我可沒辦法等那麼久！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們就這樣無視阻礙前進吧！",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n錯過時機",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就會損失慘重！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喂喂！妳在做什麼！",
        "unit_id": 1011,
        "voice": "vo_adv_1032009_023"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n別幹傻事啊！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你錯了喔，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在最重要的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是要盡快到達目的地。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請你在一旁協助我，",
