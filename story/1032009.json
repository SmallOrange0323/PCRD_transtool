        "voice": "vo_adv_1032009_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "通報你的惡行了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你就乖乖束手就擒吧！",
