    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你泡的紅茶，",
        "unit_id": 103211,
        "voice": "vo_adv_1032009_044"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有待加強呢。",
