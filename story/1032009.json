    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼就再次",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
