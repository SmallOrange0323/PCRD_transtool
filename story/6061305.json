[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個名叫莉瑪的女孩子，",
        "unit_id": 115911,
        "voice": "vo_adv_6061305_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "外表雖是可愛的千金小姐，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n卻覺得她跟其他女孩子們好像有點不太一樣。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她到底是什麼人啊？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃，",
        "unit_id": 115911,
        "voice": "vo_adv_6061305_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這看了就知道……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算沒有一一說出口，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也明白那孩子很棒，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣就夠了。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "細微的事就不用去在意了，對吧。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，",
        "unit_id": 115911,
        "voice": "vo_adv_6061305_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很勤奮……？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "她不是千金小姐嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果真是這樣的話，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就可以理解她體力和身體能力的優異表現。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那孩子",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "吃了不少苦呢……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "希望她能夠順利出席",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "舞會。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你好像知道些什麼的樣子。",
        "unit_id": 115911,
        "voice": "vo_adv_6061305_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "放心吧，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我可不會不識相到追根究柢地",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "去探聽當事者不想說的事。",
        "unit_id": 115911
    }
]