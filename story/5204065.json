    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n真璃正在圖書館裡查詢東西。"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……{player}的星座是這個，",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_000"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "而我則是摩羯座，所以……",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "啊！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "兩人的契合度很完美！",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_001"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "結婚指數是90％！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n呵呵。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "不過，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "這是當然的吧，{player}♪",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………\n……？",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……{player}？",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n跟那位大人同名……",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一定是別人吧，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為那位大人已經有我了。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我跟{player}大人的姓名判斷，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "契合度是最好的呢。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n果然我跟{player}大人",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "命中注定要結為連理。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人、",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……嗯？",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_005"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n她說{player}大人，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "為什麼是叫我家達令的名字？",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "……算了，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "是別人吧，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "畢竟我才是他的伴侶♪　",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "…………\n……",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_006"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "啊，",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_007"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "這個品牌的新作品出了。",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n在跟{player}的約會中穿的話，",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n他會不會稱讚我呢♪",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "…………\n……",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這件針織品真好看呢，",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我來為{player}大人親手編織吧♪",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "啊，",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_010"
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "這本參考書真好懂──",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "\n跟{player}兩人一起單獨學習",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "吧！",
        "unit_id": 132331
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這道甜點",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n必須為{player}大人傾注愛意製作才行！",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "真璃",
        "words": "{player}！！",
        "unit_id": 132331,
        "voice": "vo_adv_5204065_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人！！",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_013"
    },
    {
        "type": "dialogue",
        "name": "真璃‧惠理子",
        "words": "「妳是誰啊！？」\n「妳是哪位！？」",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_014"
    },
    {
        "type": "dialogue",
        "name": "真璃‧惠理子",
        "words": "…………唔。",
        "unit_id": 102731,
        "voice": "vo_adv_5204065_015"
    },
    {
        "type": "dialogue",
        "name": "真璃‧惠理子",
        "words": "哼！",
        "unit_id": 1,
        "voice": "vo_adv_5204065_016"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "天坂‧露易絲‧真璃與倉石惠理子──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這就是被稱作一生宿敵的兩人的相遇。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……前世說不定也曾發生過這種事。"
    }
]