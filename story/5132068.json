[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "12月24日，克蕾琪塔與秘書一號在因為聖誕節而熱鬧非凡的餐廳中"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n面對面而坐。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_000"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您沒有食慾嗎？",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這可是難得的特級上等肉。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您不想吃的話就讓我──",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我當然要吃！",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不只擅自點了特級上等肉，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要是還把我的份搶走這我可不能忍！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "剛剛嘆那口氣是因為……",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我只是在思考陛下的事而已。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這麼一說，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "今天她應該和那名少年出去遊玩了吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n難道",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您在擔心陛下？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並不是那樣。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "事到如今自然無須描述陛下有多厲害，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而提起少年，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然令人不甘，但他比我更為深得陛下的信賴。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "而且他也絕不可能背叛那份信賴。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……妳這番話真的是很刺耳呢。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是啊，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對啦。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一點都沒錯。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那麼，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_008"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您為什麼要露出一副吃了塊滿是筋腱的硬肉般",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n那樣的不自在表情呢──",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真要說起來，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_009"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐對推進的活動未能滿意，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "也因此遭到古代遺物趁虛而入。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "雖然就結果來說得到了挽回名譽的機會，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "得以實現陛下",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n理想中的聖誕節，但要是走錯一步",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就會發生慘劇了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n真的非常辛苦呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……不要幫我簡單明瞭地做總結好嗎？",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "記憶像跑馬燈般甦醒，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n讓我的頭又開始痛了起來……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過妳說得沒錯。",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要是明天開幕的聖誕節活動無法順利進行，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下一定會自責的……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只要一這麼想，",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "胸口就感到難受……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……假如吃太多了，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_014"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我是可以幫您把肉吃掉。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才不是那樣！！",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我是為",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明天的活動",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n以及陛下擔心！！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "對了對了，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_016"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就是這副表情。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "比起小心翼翼地擔心，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n像這樣大聲嚷嚷",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "才像克蕾琪塔小姐的風格。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這次聖誕節，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_017"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我認為一定會成功。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n而萬一失敗了，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我也會和您一起",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "思考下一步該怎麼走。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "所以還請您",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "像往常一樣抬頭挺胸就可以了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "抱持著自信，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "和陛下及少年",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一起享受最棒的聖誕節吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我想，這麼做一定會是",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "邁向成功的捷徑。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳這個人",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還真是。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n總是",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一副彷彿掌握一切全都知曉的口吻呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那是當然。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_020"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "因為我是克蕾琪塔‧凱許的秘書嘛。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n適時提供輔助讓事情圓滿進行是我的職責。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……看來我",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有位很棒的秘書呢。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是啊，",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "畢竟一流的商人",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "絕不能沒有一流的秘書。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "也請您考慮一下改善我的待遇。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "個人的希望",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "差不多是這個數字……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是啊，",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳就是這樣的人呢！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎好啦，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "至少這次",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我會發獎金給妳的。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不愧是克蕾琪塔小姐。",
        "unit_id": 6111,
        "voice": "vo_adv_5132068_024"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "啊，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不好意思，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我想加點這個特選肉品套組，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n還有",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "特級海鮮拼盤。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "能請妳也稍微學習一下客氣嗎！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132068_025"
    }
]