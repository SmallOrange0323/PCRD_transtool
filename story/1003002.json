[
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被怜帶領著，\n來到人煙稀少的高山。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你連理由都不知道就跟來了？",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是的……該說你少根筋，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是膽識過人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒仔細說明你也跟來了，",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以我還以為你知道我們的目的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之前約定好了對吧？ 要鍛鍊你。",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以今天是為了你的修練而來。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天我來當你的對手喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為每次都找魔物當修練的對手太危險了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡的話很少有人來，",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n即使大肆揮劍，也不會造成困擾。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拿起你的劍！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n首先我想確實掌握你的實力，全力攻過來吧。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……慢著。",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你瞧不起我嗎？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才的攻擊，完全沒使出全力對吧？",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一旦到了我這種水準，",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n單憑劍的交鋒，就至少能知道對手有沒有使出全力。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從你的劍上面，完全感受不到氣勢……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為對手是人才放水的嗎？",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然你可能害怕傷到對手，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但你不要抱持著那樣的心態來挑戰我。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放心吧。因為以你現在的水準，",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n再怎麼努力，也擊不中我一下。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不使出全力的話，只是浪費時間。",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n想要我鍛鍊你的話，就相信我，全力攻過來吧！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，很好！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就是這樣！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接著換我進攻了！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是即使是你，也能勉強擋住的攻擊喔！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n來吧，仔細看我的動作！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "側邊！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "上面！接著",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是下面！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然有天份呢！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接著要再稍微提升速度囉！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……確實地全部擋下來了呢。",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這正是眼睛漸漸習慣的證據。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你成長的速度真令我驚訝。",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對我來說，也算是有指導的價值。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "繼續放馬過來！！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500211"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾個小時後――――"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還沒結束喔！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n盡量攻過來！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不要說喪氣的話！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n才正要――――",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有毅力！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼了？手腕沒出力喔？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，已經這麼晚了……！？",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。你的成長令我太開心了，不小心就拚過頭了……",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們休息一會吧。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒休息又持續戰鬥到這麼晚，",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我到底在做什麼啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你該不會，開始討厭……和我修行了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真令我驚訝。",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我以為你已經氣餒了呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼你能那麼想呢？",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，嘴巴倒是很甜。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……不過我很開心喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然至今我從沒想像過，",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n被誰來保護的自己。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才聽到你這句話的瞬間，",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我有一種很安心的感覺。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你……變強的話會保護我對吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那樣的話，你就讓我來保護吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "彼此保護對方的身後。",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你不認為這是很美妙的關係嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了能變成那樣的存在，我也不得不努力了呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003002_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n兩人一起變得更強吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為此，只能修練了！",
        "unit_id": 100312,
        "voice": "vo_adv_1003002_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，再度開始修練了！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人劍與劍的交鋒聲，\n直到深夜都還持續著。"
    }
]