[
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌留句不可思議的話後就昏迷過去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被送到【咲戀育幼院】的寢室。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "後來，一直沒有恢復意識的千歌，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n受到{player}等人辛勤地照顧……"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 104211,
        "voice": "vo_adv_5009001_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一直都沒醒過來呢，",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個人……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不、不會有事吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不曉得……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n她全身傷痕累累，讓人真擔心啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "該不會被魔物給攻擊了吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "在這種城裡嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我記得最近……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "常常有魔物闖進城鎮裡，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n鬧得不得安寧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比起那個。",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "她連衣服都這樣殘破，太可憐了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真想幫她換下來呢……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但是穿我們的衣服，尺寸又不合，",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我去借咲戀媽媽衣服過來吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽去工作不在家，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "晚一點再跟她說，她應該會諒解的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過在幫她換衣服之前，她全身都是泥濘，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我想先幫她擦一下……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我去裝一點水過來喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這個季節的水很冰，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n稍微煮一下，讓水變溫一點會比較好……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為綾音沒被允許用火，就由我去做吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔，",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為什麼胡桃可以做，我就不行啊？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我笨手笨腳嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也想幫點忙嘛。",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要是聽話的話，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該能收到聖誕老公公的禮物……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是我們外行人不能隨便亂動病人吧，",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是應該等鈴莓去找醫生回來比較好？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐……",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n從剛剛出門後，就一直沒有回來耶……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "外面好像開始下雪了，",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "她應該不會又滑倒了吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有可能……",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快到年末了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n醫生可能也很忙，所以要排隊等候吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "最近到處都發生案件和意外，",
        "unit_id": 102311,
        "voice": "vo_adv_5009001_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像也很多人受傷呢……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是不是腳步聲？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真的耶……",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說不定回來了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "打擾了～！",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌沒事嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拜託一定要平安啊……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚呀……！？",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嚇嚇嚇嚇死我了！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "差點以為我的心臟要跳出來了……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇！",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉哦？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們是【咲戀育幼院】的孩子們……對嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是她的……",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌的夥伴！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　我叫望！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們組了一個叫【慈樂之音】的\n偶像團體……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聽過嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、啊……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不知道……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔～嗯，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們的知名度還不夠啊……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然大朋友的粉絲快速增加中，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看來在年輕族群間的曝光率還不太夠呢？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總而言之。",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才接到{player}的連絡，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我就慌慌張張丟下工作，趕了過來……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌她沒事嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我……",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也不清楚……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n鈴莓姐先用了魔法做了簡單的治療，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n傷口之類的是癒合了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是不知道為什麼，她一直沒醒來……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～？",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　似乎給妳們添了很多麻煩呢，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請讓我代千歌向妳們道謝！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n感激不盡感激不盡，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "愛妳們喔～♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇哇……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要抱我……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈。",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "平常光是握手，對方就會很開心，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n被人拒絕倒還挺新鮮的……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開玩笑啦，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不是說這話的時候呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "實在是無法冷靜啊……",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n深呼吸，讓情緒穩定下來吧。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的。",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n千歌看起來很正經，是不會惹麻煩的乖孩子，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n偶爾也會出乎意料的失控呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以我才說了～",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺很危險不要去了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "什麼……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我說明一下喔。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這女孩――千歌是個叫做唱喚士的稀有能力者……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n和精靈締結契約後，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就能創造出各式各樣的奇蹟。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌是去尋找，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n在各處傳承中留下名號的『記憶的大精靈霧奇』。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n剛好我們的行程沒有安排，空了幾天下來。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是。",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "後來她就毫無音訊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一直行蹤不明。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們擔心得不得了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我和另一位夥伴紡希都是。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總之找到了千歌，算是鬆了口氣……",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過她沒有恢復意識真令人擔心啊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她到底怎麼了？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果沒猜錯。",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n感覺像是千歌找的那個叫霧奇的精靈",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n對她做了什麼呢……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過不管是精靈還是唱喚士，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我這個門外漢都不懂。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說起來，這個叫千歌的人……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n在昏迷之前喊了那個名字……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n她說「霧奇要來了」，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感覺非常的害怕……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～？",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個叫霧奇的是不是危險的魔物之類的，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n千歌被襲擊後就逃來這裡……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就算我們在一旁慌了手腳也於事無補吧……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不好意思，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以幫我照顧一下千歌嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想要",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先回事務所一趟報告現況。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果千歌醒過來，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "請跟她說工作我們會想辦法的，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n麻煩好好休養就好……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "受各位照顧的恩情，總有一天會回報的，{player}。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……連我自己",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "都覺得自己是不是有點無情。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是粉絲還在等著，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我不能因為私事而讓工作開天窗。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 104211,
        "voice": "vo_adv_5009001_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，千歌！",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了，妳醒來了！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的真是的真是的，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要這樣讓人擔心啦……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵。",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_045"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小望姐姐",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "把那個叫千歌的人抱得好緊。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然剛剛是說工作優先，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "果然不會放著夥伴不管呀……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚、唔……？",
        "unit_id": 104211,
        "voice": "vo_adv_5009001_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌？",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　妳怎麼了，哪裡痛嗎？　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳沒事吧！？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "客客客、客人裡面有沒有醫生啊～！？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請、",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_048"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請冷靜啊……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這樣搖晃她的話，會再昏過去的……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚嗚～？",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n可是千歌她總是會忍耐，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不管多痛多苦都不會說！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以要靠我們去觀察才行，",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而我又很遲鈍，沒辦法多為她著想……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對不起呀，千歌！　",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我應該要更認真阻止妳的，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不對，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我應該要幫千歌做妳想做的事才對！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為都是我，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "硬拉千歌當偶像的！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次該輪到我了吧！",
        "unit_id": 102913,
        "voice": "vo_adv_5009001_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然而我卻……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "耍帥的想說不插手私事，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n才是偶像的作風！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　嗚哇哇哇哇！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就、",
        "unit_id": 102111,
        "voice": "vo_adv_5009001_053"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就說了請妳冷靜一下啦！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳抱得那麼緊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "她會沒辦法呼吸的……！",
        "unit_id": 102111
    }
]