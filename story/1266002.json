    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好比說，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要讓我的分身像這樣子變化──",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "什、",
        "unit_id": 911,
        "voice": "vo_adv_1266002_043"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "什麼！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "人類",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "變成了飛空艇……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n怎麼可能有這種蠢事……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要坐上這個，",
