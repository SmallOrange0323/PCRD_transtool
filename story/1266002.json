[
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在豔陽高照的夏日午後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n似似花跟{player}來到位於大間海邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n十分有名的店家。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "總算到了呢。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這間",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是默默在美食家之間成為話題的店家啊。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "享受美食",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也算是",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很棒的夏日回憶。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n對於隸屬【美食殿堂】的你而言，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就更不用說了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我剛剛",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才吃過金槍鮪，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以就不點餐了……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但你正處在發育期，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該還吃得下吧？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這一餐由我請客，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你可以盡量點喜歡的東西。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不過我也很好奇味道如何，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就分我嘗一口吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "歡迎光臨。",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_004"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們的料理每一道都很好吃，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n但我最推薦的",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是烤玉米跟章魚燒。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不過，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "客人只要點自己喜歡的就好……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "咦，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳是……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這位粉色頭髮的大姐！",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_005"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n難不成",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳就是傳聞中，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那位願意聽任何祕密的人……！？",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……如果我說是，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那又怎麼樣？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "其實，",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_007"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我有一個想吐露的祕密……！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……唉。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我要到何時才能好好享受假期呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不過",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你就說來聽聽吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那個……",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_009"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖然有點難以啟齒……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n但我的哥哥",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是大間黑手黨的成員……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……大間黑手黨，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是嗎。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "簡單來說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是主要在大間近海一帶，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n靠非法捕魚來賺錢的一群人。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是的，",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_012"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳說的沒錯……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "自從數年前哥哥加入黑手黨後，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n就一直在幫他們非法捕魚。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我一直想阻止哥哥繼續做這種事，",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_013"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但卻無法找任何人商量……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我到底",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "該怎麼做才好……",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真是的，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我就知道你會這麼說。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然如此，那也不能放著不管呢。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真拿你沒轍，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就由我們來想辦法吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真、",
        "unit_id": 3311,
        "voice": "vo_adv_1266002_016"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "真的嗎？",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "謝謝你們！",
        "unit_id": 3311
    },
    {
        "type": "background",
        "background": "502010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才提到的大間黑手黨應該就在這附近……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……啊啊，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來就是對面那位男性呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "嘿嘿，",
        "unit_id": 911,
        "voice": "vo_adv_1266002_018"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "大豐收、大豐收",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "呀……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "要是能把這些鮑魚賣到蘭德索爾，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "就可以大賺一筆了說……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──飽和之光。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_019"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "嗚喔喔",
        "unit_id": 911,
        "voice": "vo_adv_1266002_020"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "喔喔喔！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再弱也該有個限度。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來或許根本不需要我親自出手。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……不過，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大間黑手黨還真是學不乖呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "明明我已經",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "把走私到蘭德索爾的管道給徹底封鎖了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "……妳、",
        "unit_id": 911,
        "voice": "vo_adv_1266002_023"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "妳封鎖了走私管道……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "難不成，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "那位貴族大叔被逮捕的原因……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是你想的那樣。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我參與了那起事件的幕後工作。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "之前，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在蘭德索爾的市場上，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n流通著大量來自大間的非法漁獲。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "其中有一位貴族，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "涉入了非法漁獲的交易。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他收下賄賂，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "下令放過非法漁獲的走私。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而我揭穿了這個祕密……",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就是",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那位貴族的貪污行為。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最終，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他被追究罪責，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並進了大牢裡。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "因為這個緣故，",
        "unit_id": 911,
        "voice": "vo_adv_1266002_028"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我們無法再走私非法漁獲到蘭德索爾……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "導致大間黑手黨的收入大減……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "遭受嚴重打擊……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "如今夥伴也變少了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "真的有夠慘。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "所以，",
        "unit_id": 911,
        "voice": "vo_adv_1266002_029"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我們決定要報仇！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……要報仇",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是嗎。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "是啊，",
        "unit_id": 911,
        "voice": "vo_adv_1266002_031"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "沒錯。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "……喂，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "妳知道對我們黑手黨而言，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "最重要的是什麼嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──是面子，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對吧？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "正是如此！",
        "unit_id": 911,
        "voice": "vo_adv_1266002_033"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "要是就這樣忍氣吞聲，那還算什麼黑手黨。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我也看不慣至今為止享受著走私漁獲好處的蘭德索爾人，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n擺出一副完全事不關己的樣子。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "要問錢從哪來？",
        "unit_id": 911,
        "voice": "vo_adv_1266002_034"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我們從你們身上賺了大把的錢，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "現在還剩很多呢！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我的夥伴",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "現在，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "正用那筆錢包下一台飛空艇。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "……看來你們猜不到",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我們打算做什麼呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "我想也是呢！",
        "unit_id": 911,
        "voice": "vo_adv_1266002_035"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "不過我就特別告訴你們吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n我們要使用飛空艇，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "從蘭德索爾的上方空投魔物跟詛咒道具！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "從空中進攻的話，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "【王宮騎士團】也無法阻擋！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……要是放著不管，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "肯定會造成巨大的損害呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你們打算在什麼時候",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "執行這項襲擊計畫？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "馬上就要執行了，",
        "unit_id": 911,
        "voice": "vo_adv_1266002_037"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "所以我才會跟你們說。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n因為不管你們怎麼做，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "都不可能阻止這項計畫！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……他是這樣說的。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你打算怎麼做？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這就是你的決定嗎。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼我就助你一臂之力吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "哈，",
        "unit_id": 911,
        "voice": "vo_adv_1266002_040"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "你們想做什麼都是沒用的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "\n想想這裡離蘭德索爾有多遠吧，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "你們絕對趕不上的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這可未必。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "希望你不要太小看我呢。",
