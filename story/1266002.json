    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們就早點解決那愚蠢的計畫，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在那之後就來好好享受假期吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──啊啊，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對了對了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "姑且還是跟你說一下。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你的弟弟他說，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "希望你不要再繼續非法捕魚了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他似乎每天都很擔心你。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他也不需要再擔心了呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然我出手了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你們的組織就會在今天瓦解。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼一來，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也就無法繼續從事非法捕魚了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "妳、",
        "unit_id": 911,
        "voice": "vo_adv_1266002_047"
    },
    {
        "type": "dialogue",
        "name": "大間黑手黨",
        "words": "妳這個怪物……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就當作你在稱讚我吧。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與其在這邊繼續嘴上逞強，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還不如趕快準備去找新的工作。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就出發吧，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "去拯救蘭德索爾。",
        "unit_id": 126611
    },
    {
        "type": "background",
        "background": "501150"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然是很小型的飛空艇，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但搭乘起來還蠻舒服的吧？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在追上黑手黨之前，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你就好好享受這趟天空之旅吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……雖然我很想這麼說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但碰上了一點問題。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在風勢不夠，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "導致飛行速度不如預期。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣下去有可能無法趕上襲擊計畫。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "到時候",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就會變成單純的空中遊覽呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也不介意就是。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……風勢變強了呢。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你用公主騎士的力量，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "強化了在大氣中掌管風的精靈嗎。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在的速度不錯，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這樣應該可以追上大間黑手黨。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看來你已經能夠活用自己的能力了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "值得讚賞。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……可以看見黑手黨的飛空艇了。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然蘭德索爾已經近在眼前，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但總算是勉強趕上了呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然光靠我一個人就綽綽有餘了，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但為了能夠瞬間解決對方，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是準備幫手吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯──",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是我……",
        "unit_id": 107011,
        "voice": "vo_adv_1266002_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有我。",
        "unit_id": 115011,
        "voice": "vo_adv_1266002_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒有比我更可靠的幫手了吧？",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……已經追上對方的飛空艇，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要跳過去了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "黑手黨1",
        "words": "嗚哇，",
        "unit_id": 1,
        "voice": "vo_adv_1266002_061"
    },
    {
        "type": "dialogue",
        "name": "黑手黨1",
        "words": "你們",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黑手黨1",
        "words": "是誰啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黑手黨1",
        "words": "\n難道不知道我們是大間黑手黨嗎……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "閉上嘴。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_062"
    },
    {
        "type": "background",
        "background": "501150"
    },
    {
        "type": "dialogue",
        "name": "黑手黨1",
        "words": "哇啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_1266002_063"
    },
    {
        "type": "dialogue",
        "name": "黑手黨2",
        "words": "可惡，",
        "unit_id": 1,
        "voice": "vo_adv_1266002_064"
    },
    {
        "type": "dialogue",
        "name": "黑手黨2",
        "words": "兄弟們！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黑手黨2",
        "words": "快點給我打趴他們！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "黑手黨2",
        "words": "\n就算叫出魔物也無所謂！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真受不了……",
        "unit_id": 107011,
        "voice": "vo_adv_1266002_065"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "希望至少能稍微取悅我呢。",
        "unit_id": 115011,
        "voice": "vo_adv_1266002_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，請幫我們強化吧。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_067"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……就讓你們體會一下，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_068"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n七冠的恐怖之處吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而後似似花與分身協力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在轉眼之間便壓制了大間黑手黨的飛空艇。"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "──感謝你們",
        "unit_id": 711,
        "voice": "vo_adv_1266002_069"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "協助逮捕大間黑手黨。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n要是他們的計畫真的執行了，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "蘭德索爾不知道會變成什麼樣子。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "我們已經著手處理",
        "unit_id": 711,
        "voice": "vo_adv_1266002_070"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "魔物跟詛咒道具，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "還請你們放心。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n那麼，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "請容我先行告辭。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "多虧了我才能拯救蘭德索爾呢。",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_071"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過對方比想像的還弱，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓我有點掃興就是了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……總之，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼一來，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "終於能好好享受假期──",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗚……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──感覺，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_074"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有點頭暈……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……回想起來，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_075"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n原本是為了消除繁忙工作的疲勞，才規劃了這次假期……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "結果別說休息了，",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_076"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "除了島鯨，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再加上這次的事件，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我一直都在忙著處理事情呢……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以現在……",
        "unit_id": 126611,
        "voice": "vo_adv_1266002_077"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才會覺得累了……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似似花突然倒下。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}為了幫助似似花，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便以公主抱的方式將她抱起，急忙送到醫院去。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": " "
    }
]