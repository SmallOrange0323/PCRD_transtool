[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "初音，",
        "unit_id": 101511,
        "voice": "vo_adv_5046101_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我有話想和妳說。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在這個夏天，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "會暫時離開森林～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦──！",
        "unit_id": 101211,
        "voice": "vo_adv_5046101_001"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "美里老師不在的話，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我有點擔心能不能做好【森林守衛】的工作……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀～",
        "unit_id": 101511,
        "voice": "vo_adv_5046101_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "初音妳一定沒問題的。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老師完全不用操心。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n所以，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我才能很放心的外出唷～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_5046101_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那就太好了──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "話說美里老師，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳外出是因為有什麼事嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難道是去放暑假？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_5046101_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是這樣的唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是因為",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有學校拜託我去擔任特約講師～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦──！",
        "unit_id": 101211,
        "voice": "vo_adv_5046101_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不愧是美里老師！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n妳要去哪個學校呢──？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "詳細的事情我也還不清楚，",
        "unit_id": 101511,
        "voice": "vo_adv_5046101_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過聽說是在海邊附近喲。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不知道會是個什麼樣的地方呢……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我現在就開始感到期待了呢～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好好哦──！",
        "unit_id": 101211,
        "voice": "vo_adv_5046101_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也想去海邊──！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然待在森林裡安安靜靜的也很好，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是說到夏天，果然就是要去海邊呀。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真想盡情地玩耍一番吶──",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀……",
        "unit_id": 101511,
        "voice": "vo_adv_5046101_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我可不是去玩樂的唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "機會難得，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果工作告一段落的話，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也歡迎初音妳大駕光臨哦～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了──！",
        "unit_id": 101211,
        "voice": "vo_adv_5046101_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n謝謝妳，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "美里老師！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我會卯起勁工作的！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵。",
        "unit_id": 101511,
        "voice": "vo_adv_5046101_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n會有什麼樣的際遇等待著我呢？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真希望可以成為一個美好的夏天～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "初音、美里",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5046101_011"
    },
    {
        "type": "dialogue",
        "name": "初音、美里",
        "words": "《美里的夏日聲援！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "初音、美里",
        "words": "　追夢的盛夏棒球隊》！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501100"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來吧各位～",
        "unit_id": 113511,
        "voice": "vo_adv_5046101_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "朝著夢想，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "開球～！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "社員們",
        "words": "喔！！",
        "unit_id": 1,
        "voice": "vo_adv_5046101_013"
    }
]