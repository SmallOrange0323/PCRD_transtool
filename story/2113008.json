[
    {
        "type": "background",
        "background": "501204"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "…………\n……",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_000"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……嗯。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_001"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "不知我有多久",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_002"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "沒像這樣進入認知的世界了。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n讓分離出來的靈魂",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "直接感受到只存在一時的微風……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請、",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您……",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是精靈族長老的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "塔雷爾‧達爾‧佐拉……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而是棗──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "是的。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_005"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n好久不見了，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "可蘿。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "話雖如此，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_006"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n對現在的妳來說",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "或許並無真實感吧。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n看來身為「長老」的另一個我，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "是個很稱職的父親呢。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能擁有兩位好父親……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的十分幸福。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃，",
        "unit_id": 105812,
        "voice": "vo_adv_2113008_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱歉",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "打斷你們說話……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 106012,
        "voice": "vo_adv_2113008_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我搞不太清楚狀況，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那傢伙──",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n他就是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔真正的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "父親嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "是的。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_010"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n雖說現況有些異樣，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "但初次見面，各位幸會。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "並且……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "就是你吧，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_011"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "模索路晶的……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n拉比林斯達的公主騎士。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他也是在下的主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n父親大人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……嗯。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_013"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "雖仍處在",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_014"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "萌芽階段──",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n但你有一雙好眼神。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "那是潛藏著可能性之人的眼神。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_015"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "原來如此，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n也難怪晶會選上你，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我女兒會侍奉你。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "本來，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_016"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我是該與你促膝長談。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n看清你是否有那個資質，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "值得我將女兒託付給你……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……父親大人？",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……",
        "unit_id": 106012,
        "voice": "vo_adv_2113008_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n伯父，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你是魔力耗盡……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經不只是這個程度了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你的身體是不是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快消失了啊……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "無可奈何，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_019"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我似乎太操勞這臨時的容器了。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "如此不穩定的連線，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "最多只能再維持630秒左右吧。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所、",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n父親大人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "馬上就要消失了嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "別擔心。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_021"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n這並不表示我們會永生別離。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n等「禁錮」結束，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "就能在另一側重逢了。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是……",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……大家，",
        "unit_id": 101512,
        "voice": "vo_adv_2113008_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我們讓可可蘿",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "和她父親，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n兩個人獨處一下吧。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……好。",
        "unit_id": 105812,
        "voice": "vo_adv_2113008_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n走吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……？",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_025"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n怎麼了？",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……他是個優秀的少年。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_026"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我很期待",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "能和他在「那一側」碰面啊。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……那個，",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "假如……",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「禁錮」結束了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "回到現實後……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在所處的這個世界",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "……",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_030"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "可蘿啊，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n妳",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "是愛著這個世界的吧。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是當然的。",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n包括主人在內……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是身處這個世界，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才能認識這麼多善良的人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "就如妳所擔心的，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_032"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "現實這一側，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "眾人對這個世界──",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "《阿斯特朗傳奇》的",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "批評聲量很高。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "身為開發者的我們七冠、",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_033"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "「WISDOM」、",
