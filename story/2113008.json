        "type": "dialogue",
        "name": "可可蘿",
        "words": "或是「那一側」",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都絕不會改變。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "這樣啊。",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_071"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n妳的答案恐怕將會",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "讓妳邁向嚴苛的考驗……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "然而克服艱難困苦，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_072"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "靈魂才得以磨練，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "加以成長。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n人類面臨著身為動物已停止進化，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "未來",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "將被造物超越的宿命，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n對這樣的我們而言，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "克服困難，才是唯一得以前行的道路。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我的女兒啊，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_073"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n妳就試著去",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "克服這個考驗吧。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──是。",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_074"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下一定會克服的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "回答得好，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_075"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "接著……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "剛才也說了，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_076"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我無法在這個世界久留。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n雖然站在開發者",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "和父親的立場上，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "我很想再多給予協助……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "不過我就在現實世界，",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "保護其他七冠",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "和你們的身體吧。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人……",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_077"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "好了，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_078"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "快走吧。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n這個角色",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "不久後就要消滅了。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n我不想讓你們",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "看見那個景象。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……好的……",
        "unit_id": 105913,
        "voice": "vo_adv_2113008_079"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "啊，",
        "unit_id": 107211,
        "voice": "vo_adv_2113008_080"
    },
    {
        "type": "dialogue",
        "name": "佐拉",
        "words": "\n在最後──",
        "unit_id": 107211
    }
]