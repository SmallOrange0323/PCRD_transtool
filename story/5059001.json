[
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "忽然出現的黑色精靈之力，使得可可蘿的存在即將消失。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在重視的眾人逐漸淡忘自己時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿選擇獨自離開蘭德索爾，踏上旅程。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算、",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抵達了呢。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……真是奇妙。",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明離開的時間並沒有過多久。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣一看，",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺卻相當懷念。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "首先，",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得這麼說一句。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下回來了。",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈族之村──",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的故鄉。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是這座祭祀精靈",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並與其共存",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的村莊……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許有線索釐清",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下目前所遇到的狀況。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像是無法順利叫出精靈的事，",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有那隻在下不記得",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "曾操控過的黑色精靈。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以及……",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下重視的人們",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n逐漸淡忘",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的事……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關於",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "黑色精靈的狀況，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就先來問問村裡的長老，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是在下的父親吧……！",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……只是",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有個問題……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哎呀？",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_012"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "您是……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那、",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "您是冒險者嗎？",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_014"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n歡迎來到",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "精靈族之村。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是、",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幸會。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她果然",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不記得",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下呢。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明從前，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有跟她打過好幾次招呼的……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下很清楚",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人所說的「存在會消失」",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是什麼意思……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過還是不免感到落寞。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……您怎麼了？",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒什麼……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您不要介意。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能是長途跋涉而有點疲倦了。",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不說那個，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方便請教一下嗎？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "好的，",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_020"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "什麼事？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問村子的長老在嗎？",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有事情想求教……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊……",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_022"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "長老",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "是嗎……？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "很抱歉，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "長老目前",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不在村子裡。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n他到外頭去進行",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "精靈的相關研究了……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……這樣嗎……",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真遺憾……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那個，",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_024"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "您到這兒來的路上……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一路安好嗎？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "路上？",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n呃，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有特別的狀況……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那真是太好了。",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_026"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n村子",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "附近正好有危險的──",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 14411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這道",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽來像吼叫聲的是……！？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……請您從這裡，",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "看看的森林深處。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那、",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎……？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來非常巨大……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "黑色精靈",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼會在",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這時出現……！？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "黑色精靈",
        "words": "……！"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼回事……？",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是被那隻巨大精靈的叫聲……",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給引出來的……！？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚……！",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳咳，",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳咳……！",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "忽然……",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "渾身、",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無力……？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道、",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經……？　",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就此消失嗎……？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n消失之後也絲毫不會、",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "成為任何人的回憶……？",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、",
        "unit_id": 105914,
        "voice": "vo_adv_5059001_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105914
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "您、您沒事吧！？",
        "unit_id": 6511,
        "voice": "vo_adv_5059001_036"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有沒有人呀！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n快來人呀！",
        "unit_id": 6511
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同時，在蘭德索爾的鎮上。"
    },
    {
