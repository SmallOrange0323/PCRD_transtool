        "voice": "vo_adv_5059001_088"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以妳昨天",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才會緊緊黏著我睡呢♪",
