    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥！？",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_097"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在講什麼東西，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我哪有害怕啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不說那個，{player}，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你把手伸出來一下。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我來握住你的手，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "免得你走丟了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_098"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幹、幹麼",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然這樣啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難不成",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你以為我怕了嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就是你多管閒事了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過我還是會給你握啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總而言之，",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_099"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我一點都不覺得害怕──",
