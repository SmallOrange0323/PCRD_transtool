        "voice": "vo_adv_5059001_069"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n是這樣的，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這幾天",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我收到報告說，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n蘭德索爾近郊的精靈形跡可疑……",
