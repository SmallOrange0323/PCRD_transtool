    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什咪！？",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_089"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那、那怎麼可能！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只是我的睡相很差而已啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我哪可能因為害怕就要黏著妳睡呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳不用介意啦，",
        "unit_id": 105811,
        "voice": "vo_adv_5059001_090"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那先不提，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們的糧食所剩無幾了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在省吃儉用的情況下",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會餓到肚子咕嚕咕嚕叫，也是無可奈何的事。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……再不趕快抵達目的地，",
        "unit_id": 105811,
        "voice": "vo_adv_5059001_091"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們就得在這附近籌措糧食了呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說要在附近籌措……",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_092"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我總覺得有不好的預感。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、我們加快腳步吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該就快到了吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──叫精靈族之村",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_093"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的地方！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "理論上沒錯──",
