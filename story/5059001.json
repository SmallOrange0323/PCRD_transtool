        "type": "dialogue",
        "name": "花凜",
        "words": "據調查結果表示，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在遠離蘭德索爾的地方",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n似乎有一股不尋常的……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "異樣的精靈反應。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "簡單說",
        "unit_id": 106012,
        "voice": "vo_adv_5059001_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是不合常理的奇怪精靈啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那玩意兒",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是精靈形跡可疑的原因嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "目前只知道",
        "unit_id": 190811,
        "voice": "vo_adv_5059001_073"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "兩者之間應該有某種關聯……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n而我們想確認實際情況。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這起異變",
        "unit_id": 190811,
        "voice": "vo_adv_5059001_074"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也讓蘭德索爾周遭的魔物，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n有了不同以往的行動。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "由於【王宮騎士團】需要固守防禦以保衛城鎮，",
        "unit_id": 190811,
        "voice": "vo_adv_5059001_075"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因此我想拜託厲害的公會",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "調查那隻異常的精靈。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以才找上",
        "unit_id": 106012,
        "voice": "vo_adv_5059001_076"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟我們平時就有在進行調查或討伐，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正是恰好的人選呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105812,
        "voice": "vo_adv_5059001_077"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n花凜小姐很信任我們喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我倒覺得只是很好使喚罷了。",
        "unit_id": 106012,
        "voice": "vo_adv_5059001_078"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過算啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就跑一趟吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛好我整天都覺得悶悶不樂，",
        "unit_id": 106012,
        "voice": "vo_adv_5059001_079"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n正好能解解悶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝各位一直以來的協助。",
        "unit_id": 190811,
        "voice": "vo_adv_5059001_080"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就萬事拜託了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因為路程有些遙遠，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我這邊備妥了地圖。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "了解☆",
        "unit_id": 105812,
        "voice": "vo_adv_5059001_081"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們做好準備",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再動身！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照這個距離看來，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得預備許多便當才行呢☆",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──過了幾天後。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106011,
        "voice": "vo_adv_5059001_082"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還沒到嗎？",
