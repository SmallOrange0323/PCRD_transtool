[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "充滿熱帶風情的晴朗天氣是很不錯～",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但穿著泳裝",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺會全身都曬黑呢……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我說你，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有做什麼防曬的",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對策嗎？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是的～",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "既然會感到不安，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就要好好防範啊！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咦，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你問我有沒有做？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "反正",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算曬黑，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也只會",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n提升七七香的魅力罷了，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以我覺得無所謂呢！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我懂！",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然常有人說「陽光是肌膚的天敵」，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這點很讓人擔心，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但在小麥色肌膚上留下泳裝曬痕的美少女，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是教人興奮呢，",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喲呵呵呵！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 113311,
        "voice": "vo_adv_6044203_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在來這村子前就塗好了？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "已經沒效了啦！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n既然如此，就輪到新魔法上場了！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "防曬魔法～欸、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇啊這個是",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n日光浴的魔法！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "光、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "光好刺眼！？",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的眼睛！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的眼睛──！！",
        "unit_id": 113311
    }
]