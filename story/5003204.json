    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得有種不妙的感覺―",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大家要小心啊―",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊嗚……",
        "unit_id": 101011,
        "voice": "vo_adv_5003204_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "找不到前往",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不可思議之國的大門呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104412,
        "voice": "vo_adv_5003204_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對妾身來說，空氣還挺舒服的！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好像還有深處！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身也變得更輕鬆了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　走囉，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們幾個！",
