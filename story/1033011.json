        "type": "dialogue",
        "name": "真陽",
        "words": "不，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是老哥帶我來的店。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n一定會是間很棒的店沒、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "錯……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "的啦！？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這、",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_054"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這本筆記本，",
        "unit_id": 103332
