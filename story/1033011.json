        "name": "真陽",
        "words": "「夫婦」吧。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n畢竟我跟老哥看起來",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "又不像那樣的感覺，",
