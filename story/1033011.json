        "type": "dialogue",
        "name": "真陽",
        "words": "我是年齡比較大的太太～",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_047"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "之類的，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n老哥總是對我很溫柔～",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "之類的……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "慢著，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這樣會變成別種節目啦！",
        "unit_id": 103332
    },
