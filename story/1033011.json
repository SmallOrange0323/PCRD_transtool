    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有點獨特啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n對不上的人就會不太喜歡呢。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒考慮老哥的興趣就把你抓來看，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真抱歉。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你說哏是真的很有趣？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那為什麼你是那個臉啊？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你是在意表演前",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我被捉弄的事啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒事啦～",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那就是現場表演的醍醐味啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果我看起來很沮喪，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那是因為",
