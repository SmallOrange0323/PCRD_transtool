        "voice": "vo_adv_1033011_044"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n可是",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牠不會明確地說出答案嘛。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
