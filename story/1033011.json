    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你在說什麼啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只要有一百頭牛",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就會有一百種花紋啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好、",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_055"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好厲害……",
        "unit_id": 103332
    },
    {
