[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在街上遇到了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n緊緊握著錢的真陽。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦～老哥呀，",
        "unit_id": 103311,
        "voice": "vo_adv_1033011_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好久不見啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "之前請你陪我表演搞笑，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的謝啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103311,
        "voice": "vo_adv_1033011_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你說這個啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個啦，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個時候收到的出演費啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好歹也是我身為搞笑藝人賺到的第一筆錢嘛。",
        "unit_id": 103311,
        "voice": "vo_adv_1033011_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "想說買個什麼可以當作紀念的東西，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就到街上來了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只是一直想不到要買什麼呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對了，",
        "unit_id": 103311,
        "voice": "vo_adv_1033011_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥也陪我……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n又是這搞不懂是什麼的光！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "到底是怎樣啦～～～！",
        "unit_id": 103311
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "果然可以近距離看專業的人表演搞笑就是棒。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是我老家那邊也會常常有人去辦就好了，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只是",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "以鄉下來說果然很難啦……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的是超厲害的啦……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個善用停頓的方式……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不愧是在各個大賽所向披靡的組合呢……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇！？",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n居然會在這種地方遇到你，真巧啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難不成老哥",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是來看搞笑表演會的嗎？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看樣子",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "只是來買東西而已啊。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真可惜啊，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "居然沒看到",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那麼厲害的東西……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天有電視上也很紅的搞笑藝人",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在這裡辦表演啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我就是來看那個的。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有下午場嘛！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼樣，老哥？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要不要",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟我一起看啊？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n超級有趣的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥果然很懂嘛！",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然我也很想讓伊麗莎白看看，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n可是也不能把牛帶到這種地方來啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果願意連伊麗莎白的份一起學習就太好啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "當然！",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "才不是我這種人比的上的！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不是啦，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我當然也有",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在追求我理想中的搞笑喔。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "專業的果然就是厲害。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這一點就",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "請老哥直接親眼去看看吧。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總之絕對不會無聊的啦，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "跟我來吧。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等一下搞笑藝人就要登場了！",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現場表演的搞笑可是超厲害的喔，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你就好好期待吧！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "大家好～",
        "unit_id": 1,
        "voice": "vo_adv_1033011_016"
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n非常感謝今天也有這麼多人聚集在這裡～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n啊～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "感謝這麼熱烈的掌聲。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "哎呀～",
        "unit_id": 1,
        "voice": "vo_adv_1033011_017"
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "沒想到居然會有這麼多人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "願意跑來看我們這小小藝人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "\n真的是非常感謝～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "在各位觀眾當中，",
        "unit_id": 1,
        "voice": "vo_adv_1033011_018"
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "有沒有人看過我們的呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n麻煩舉個手～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有！",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我有！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "喔～",
        "unit_id": 1,
        "voice": "vo_adv_1033011_020"
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "這位活力充沛的小妹妹，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "謝謝妳呀～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "咦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "咦咦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "\n妳早上也有來看對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1033011_021"
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "難怪有看過嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n嗯？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "旁邊的男生是哥哥嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n早上沒有看到你呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "不行喔～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "怎麼放著小孩子一個人行動呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小、",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "小孩子！？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不對啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我才是年紀比較大的姐姐啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "啊哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1033011_023"
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "賭氣裝大人的樣子真可愛呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n我們不怎麼受小孩子歡迎，所以很高興喔～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所、",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以說……！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚……",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是在這邊糾纏太久的話，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "場面會冷掉吧……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就想個簡單的笑料來回應……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "今後",
        "unit_id": 1,
        "voice": "vo_adv_1033011_026"
    },
    {
        "type": "dialogue",
        "name": "諧星2",
        "words": "也請為我們加油喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "當然！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這是當然的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "是說，",
        "unit_id": 1,
        "voice": "vo_adv_1033011_028"
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "我一直覺得想要成為",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "諧星1",
        "words": "\n能夠讓這麼可愛的女生為我們加油的搞笑藝人……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "已經開始在鋪哏了……",
