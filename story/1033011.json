        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只是想著老哥的事，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "自然而然就……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸！？",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_049"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什麼事都沒有不用在意！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n話、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "話說回來，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥可以再陪我一下嗎？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我現在用的記哏手帳",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_050"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都寫滿了，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n想買一本新的再回家。",
        "unit_id": 103332
    },
