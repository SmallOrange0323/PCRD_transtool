    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "怎麼樣，老哥？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "開心嗎？",
