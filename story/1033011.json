        "name": "真陽",
        "words": "那個啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為想回個有趣的哏，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "結果什麼都想不到。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要怎麼說明我跟老哥的關係呢？",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這問題一直在我腦袋裡轉來轉去的。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "應變能力果然很重要啊。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n對了，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥的話會怎麼回？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n講來讓我參考看看嘛。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是很保守的回答呢。",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比起什麼都沒回，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "立刻回說是朋友，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n應該比較好吧。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是一時想不到好哏，",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_040"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就簡單回答再期待對方接哏。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是正確解答吧。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦～",
        "unit_id": 103332,
        "voice": "vo_adv_1033011_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是要順著搞笑藝人的話嗎！",
        "unit_id": 103332
