        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是能在那時候立刻回答的話……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
