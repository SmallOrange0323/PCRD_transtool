    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想來",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便覺親近熟稔多了吧？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
