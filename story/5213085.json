    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我能感覺到，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "潛藏在體內的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "漆黑魔力正在高漲……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一口咬下，",
        "unit_id": 100911,
        "voice": "vo_adv_5213085_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "肉汁像血潮般湧出……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "停駐於舌尖之上的，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "並非地獄的業火……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "而是，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "溫柔火焰的加持。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "交織在一起的辣味與鮮味，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "正是禁忌的饗宴！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "炸物的外皮，",
        "unit_id": 100911,
        "voice": "vo_adv_5213085_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也是酥酥脆脆的，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "非常",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好吃……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是引人墮入暴食深淵的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "黃金鎧甲！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不愧是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "冠以煉獄之名的主人……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這等手腕，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "完全配得上成為我的盟友！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5213085_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n真是始料未及，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此稱讚實在愧不敢當。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這本只是為了",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "讓年幼孩童們亦方便食用而特意調製。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "咦……",
        "unit_id": 100911,
        "voice": "vo_adv_5213085_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "年、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "年幼孩童……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是。",
        "unit_id": 129711,
        "voice": "vo_adv_5213085_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若借恁們之言以述……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
