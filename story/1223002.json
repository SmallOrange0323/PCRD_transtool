        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真祖的血緣關係者，會如寶物般被藏匿起來，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在血族的守護下生活。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……公主殿下離家出走，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "應該會引起大騷動才是。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "離家出走？",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_037"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒有離家出走唷──？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "說起來班比，",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_038"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n根本不曉得自己",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "為什麼會在外面……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……那是什麼意思？",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_039"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯……",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_040"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比呀，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "原本是在家和貝斯一起沉睡的。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "但貝斯硬把班比叫起來……",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_041"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "那時班比已經",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "在不認識的叔叔們的馬車上了。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然、",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然後呢！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因為貝斯說「一定要逃走」，",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_043"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以班比跟貝斯就偷偷溜出馬車了唷。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "本來想直接回家的……",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_044"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可是班比",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不認得路……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "於是貝斯就說了「去鎮上吧」，",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_045"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n牠說「只要到那裡，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "一定能找到願意幫忙的人」。",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "然後班比就在城鎮入口處和貝斯走散了……",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_046"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "正在找牠時就遇見了僕從♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "………咦？",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_047"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你們兩個",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "怎麼了？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳、",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳這笨蛋！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳啊，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是被綁架了，竟然還這麼悠哉！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妳沒被怎麼樣吧？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "被怎麼樣……？",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_049"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "完全沒有唷！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n畢竟班比可是最強的～♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……現在不是跟這孩子爭論的時候了。",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_050"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身還是",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也來幫忙找貝斯吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n找到牠後，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳就找到自己的領地回去。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯！",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_051"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n謝謝妳，",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "伊莉亞！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "找到貝斯後，",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_052"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比就請你們兩人喝湯！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比會煮得很好喝的，要期待唷！",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿嘿～♪",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂、",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_053"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳在向那傢伙撒什麼嬌啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n都說了他是妾身的眷屬了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不對唷──",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_054"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n是班比的僕從才對唷？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是妾身的眷屬！！！！",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_055"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從喜歡什麼樣的湯？",
        "unit_id": 122311,
        "voice": "vo_adv_1223002_056"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比呀……",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "稍微聽一下長輩的話啊──！！",
        "unit_id": 104412,
        "voice": "vo_adv_1223002_057"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而班比依舊我行我素，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n伊莉亞最後讓了步，大大地嘆了口氣。"
    }
]