    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "勝利～！",
        "unit_id": 109911,
        "voice": "vo_adv_5152101_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "好，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "今天的廣播體操到此結束。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "和育幼院孩子們每天做體操",
        "unit_id": 109711,
        "voice": "vo_adv_5152101_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n也變成日常行程了呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "大家都是乖孩子，",
        "unit_id": 109911,
        "voice": "vo_adv_5152101_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "能夠變成朋友真是令人高興啊。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過，這樣子沒問題嗎……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n自從我們來到這個世界，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "已經過了很長的時間……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這也沒有辦法。",
        "unit_id": 109811,
        "voice": "vo_adv_5152101_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n畢竟要回去原本世界的方法，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就只有靠碧翠絲大人的「機遇門」。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "對不起。",
        "unit_id": 109711,
        "voice": "vo_adv_5152101_004"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雖然我有在尋找",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "除了等待碧翠絲大人以外，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n還有沒有其他回去宅邸的方法……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不，",
        "unit_id": 109911,
        "voice": "vo_adv_5152101_005"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這並不是雷姆的錯。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "都是我一心急著想要早點回去的關係……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對不起。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "──那麼，",
        "unit_id": 2711,
        "voice": "vo_adv_5152101_006"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我們去海邊吧！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「昴！？」\n「昴！」\n「巴魯斯。」",
        "unit_id": 1,
        "voice": "vo_adv_5152101_007"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "一般都說如果遇到自己無法排解的不安，",
        "unit_id": 2711,
        "voice": "vo_adv_5152101_008"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n去看看遼闊的大海",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "就會海闊天空了，",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "愛蜜莉雅醬！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "那麼就出發吧！",
        "unit_id": 2711,
        "voice": "vo_adv_5152101_009"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "大海正在呼喚我們啊！",
        "unit_id": 2711
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "下一回，",
        "unit_id": 1,
        "voice": "vo_adv_5152101_010"
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「Re:從零開始享受的異世界夏日」",
        "unit_id": 1
