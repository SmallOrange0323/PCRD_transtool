[
    {
        "type": "still",
        "still": "520306201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203062_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜大解密」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "古代兵器",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢仔細地講解給大家聽喔。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306202"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203062_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型克蘿茜的頭。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n如果用帥氣一點的詞表現，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就是頭部元件。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這裡放了很～多重要的東西。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "像是擁有廣角視野的視覺系統",
        "unit_id": 9212,
        "voice": "vo_adv_5203062_002"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "以及高感度麥克風，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n還有能夠在瞬間處理無數資料的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "超高速處理器等等。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n不管是眼、耳還是腦，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "性能都是一流的，老夫能掛保證喔。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134511,
        "voice": "vo_adv_5203062_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "話說回來",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我一直覺得很不可思議。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n明明我的眼睛只長在前面，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n巨型克蘿茜卻能夠看到身後！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "那是多虧了搭載在全身四處的副攝影機。",
        "unit_id": 9212,
        "voice": "vo_adv_5203062_004"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n看起來像雙眼的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "只是主攝影機，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n就算在戰鬥中故障了，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也有其他攝影機能夠彌補喔！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 134511,
        "voice": "vo_adv_5203062_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就是「只不過是主攝影機被毀掉而已～！」",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "的情境對吧！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n七七香有說過♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可以的話還是不要被破壞比較好喔！？",
        "unit_id": 134612,
        "voice": "vo_adv_5203062_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為我也會使用弓箭，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以知道視野是越廣越好。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這麼多攝影機，",
        "unit_id": 9212,
        "voice": "vo_adv_5203062_007"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "其實也是為了",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "胸部和腰部的飛彈。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n不過",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "遠距離武器只有飛彈的話，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "會有點不安呢。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這樣的話，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就從眼睛",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "發射光束好了。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦，",
        "unit_id": 134612,
        "voice": "vo_adv_5203062_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼輕易地就決定新武器了嗎！？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一般來說，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不是都會仔細地考慮過嗎……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "本來就有照明功能了，",
        "unit_id": 9212,
        "voice": "vo_adv_5203062_009"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n照明用的光和光束",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "也沒差多少吧，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "大概。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "很好，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "走囉克蘿茜！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "跟老夫來！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好的～！",
        "unit_id": 134511,
        "voice": "vo_adv_5203062_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "碧也可以一起來嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n瞄準就拜託碧了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊好的，",
        "unit_id": 134612,
        "voice": "vo_adv_5203062_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我知道了……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n……對著敵人從眼睛發射光束的克蘿茜小姐，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n感覺畫面會變得很詭異……",
        "unit_id": 134612
    },
    {
        "type": "still",
        "still": "end"
    }
]