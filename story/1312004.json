    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "唉呀──",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_015"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "鏈條好像斷了呢。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n雖然它可能已經算是撐很久了。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "呵呵。",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_016"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n騎士同學你啊，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "還真是個好孩子呢──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "不過不過。",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_017"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n要是做了那種事，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我們馬──上就會被追兵",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "給抓住的喔──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "或者",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "是會碰上警察也說不定。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "嗯～",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_018"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "大概？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "就",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "算入口不同，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "去到的地方",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n終究是牢籠裡",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "或實驗室吧──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "這個，",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_019"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "應該就是所謂的一丘之貉吧？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "雖然",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我沒有看過貉就是了。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "就像我之前說的。",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_020"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n因為我",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "是非常罕見的超能力少女……",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n在各種地方之間",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "都非常搶手呢──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "……真的是",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_021"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "麻煩得很啊。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "不過這些都是因為出身或命運那些的，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n所以也無可奈何呢──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "不過，",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_022"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "至少現在……",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我希望不要",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "被那麼多的手給抓住。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "不如說，",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_023"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我會自己去……",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "拉誰的手？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "就像這樣★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "──抱緊♥",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_024"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "呵呵。",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_025"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n很令人心跳加速吧──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "騎士同學★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我的擁抱",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "有那麼舒服嗎？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "真是的～",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_026"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n都是因為你太習慣女孩子了。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "總之，",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_027"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "去找下一輛腳踏車吧。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "畢竟徒步無法移動太遠呢──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "啊。",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_028"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n騎士同學的那個表情。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "是「再去用誰的腳踏車有點不太好～」",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "的感覺呢？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "事到如今要是在意就輸了喔──",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_029"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我是很想這麼說啦",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n……不過，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "騎士同學是個好孩子嘛──",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "然而卻因為被我牽連，",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_030"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "讓你做了很多壞事。",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
