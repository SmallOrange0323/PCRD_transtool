    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "可惡！",
        "unit_id": 331,
        "voice": "vo_adv_1312004_000"
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "\n那些傢伙",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "跑哪去了……！",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "應該還沒走遠才對！",
        "unit_id": 8031,
        "voice": "vo_adv_1312004_001"
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "\n快搜！",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "……呼、",
        "unit_id": 331,
        "voice": "vo_adv_1312004_002"
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "呼……",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "\n",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "跟丟了呢，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "班長……",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "…………",
        "unit_id": 8031,
        "voice": "vo_adv_1312004_003"
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "沒有來自其他班的發現報告，",
        "unit_id": 331,
        "voice": "vo_adv_1312004_004"
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "機器也沒有反應……",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "\n",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "要是她使用瞬間傳送，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "就能鎖定出大致的位置了……",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "……可惡。",
        "unit_id": 8031,
        "voice": "vo_adv_1312004_005"
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "\n淨是給人添亂。",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "……不過，",
        "unit_id": 331,
        "voice": "vo_adv_1312004_006"
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "還真厲害呢。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "\n明明有這麼多人",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "追了好幾天，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "\n在幾乎不使用超能力的情況下，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "兩個小鬼竟然能持續逃跑……",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "……少在那邊感嘆了，",
        "unit_id": 8031,
        "voice": "vo_adv_1312004_007"
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "\n給我再更有危機意識一點，",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "蠢貨。",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "\n上頭平時",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "就已經夠煩躁了啊……",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "萬一Ｍ３號被其他組織帶走，",
        "unit_id": 8031,
        "voice": "vo_adv_1312004_008"
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "\n或是在某處力竭而亡，",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "\n",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣上司",
        "words": "我們可是會被宰掉的……！",
        "unit_id": 8031
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "咿",
        "unit_id": 331,
        "voice": "vo_adv_1312004_009"
    },
    {
        "type": "dialogue",
        "name": "黑衣男",
        "words": "咿咿……！",
        "unit_id": 331
    },
    {
        "type": "still",
        "still": "118200401"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "騎士同學～",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_010"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "你沒事吧～？",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被神祕組織追趕的少女流魅空，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與被她牽連的少年{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人手牽著手，持續逃亡之旅。"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "呵呵，",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_011"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "請加油～★",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "要是抵達了對面",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "能隱約看見的橋那裡，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "我們就交換吧♪",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "換你緊──",
        "unit_id": 118231,
        "voice": "vo_adv_1312004_012"
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "緊",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "靠著我，",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n把臉貼在我",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "都是汗的背上♪",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "\n",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "像",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "這",
        "unit_id": 118231
    },
    {
        "type": "dialogue",
        "name": "魅空",
        "words": "樣★",
        "unit_id": 118231
    },
