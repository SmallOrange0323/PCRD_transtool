        "voice": "vo_adv_2115099_058"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……這樣的景色，",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_059"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n並不如我想像般的",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
