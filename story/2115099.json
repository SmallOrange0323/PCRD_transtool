        "name": "美空",
        "words": "嗯──",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_033"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "其實沒有你說的那麼難喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n模索路晶小姐",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "現在也無法出來招搖的樣子，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而現士實似似花小姐，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "則是在被洗腦的時候透漏了底牌喔？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……喔……？",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "晶她們現在是這個狀態啊。",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而像妳這樣的傢伙則是大搖大擺地在路上走著。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n在我睡著的這段期間……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "外頭",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "變得相當有趣呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳叫作",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "美空？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳應該",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不會打算問完問題後",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就要送我回牢籠裡吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不會★",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_037"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我也沒有特別要緊的事……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以接下來，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你要做什麼都隨你高興囉？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "厄莉絲大人──",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_038"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這個世界的管理者也已經出現了，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n而蘭德索爾的城鎮現在變得一團糟。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n或者是，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "你想和騎士同學他們再來一戰，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之類的──？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是呢……",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我肚子也餓了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n總而言之，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "先來用餐吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_040"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊哈哈。",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_041"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n現在攤販和食堂",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "可能都沒有營業喔──",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "…………",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_042"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……！",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_043"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哼。",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "明明腦袋裡都裝著糖果點心，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n卻累積了比預想中的……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還要上等的魔力呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n雖說要滿足我的胃",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還遠遠不夠……♪",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……唔、",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_045"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "唔唔！……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……唔……",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_046"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呼……",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_047"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "謝謝招待。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖說要不留情面地把妳榨取殆盡",
        "unit_id": 106914,
        "voice": "vo_adv_2115099_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "簡直易如反掌，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n但當作感謝妳幫助我脫離牢籠……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我就",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "饒了妳一命吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──數小時之後……"
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "嗯……",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_049"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "真是的，",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_050"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "好過分啊……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n把我的魔力幾乎吸空了……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……本來霸瞳皇帝",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_051"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會殺死我的機率估計也只有一半。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n結果，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我還是存活下來了啊……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……唉……",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_052"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "算了……",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_053"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就這樣。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n如果最終決戰",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "能稍微變得有趣就好了……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……外面",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_054"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "現在變成怎麼樣了呢？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n道具……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "似乎可以用。",
        "unit_id": 192011
    },
    {
        "type": "background",
