    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "甚至連天空也在燃燒。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "完全",
        "unit_id": 192011,
        "voice": "vo_adv_2115099_057"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就是末日景象。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n世界走向毀壞",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "的模樣。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n我之前",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "想看到的",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這個模樣……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……但是……",
