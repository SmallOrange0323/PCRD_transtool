        "voice": "vo_adv_1088001_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也是！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也是很期待能和騎士先生",
