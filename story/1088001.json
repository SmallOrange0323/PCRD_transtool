        "voice": "vo_adv_1088001_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n害得我比平時更加在意他了呢……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "明明連正月都能和騎士先生在一塊，",
