    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討伐魔物",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
