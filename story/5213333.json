[
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "尤絲蒂亞娜……",
        "unit_id": 20013,
        "voice": "vo_adv_5213333_000"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "這傢伙，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n就算被打成這樣也還不倒下……！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n明明已經傷痕累累、",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "搖搖欲墜了，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "可是即使如此……！！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我無法想像……",
        "unit_id": 20013,
        "voice": "vo_adv_5213333_001"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "她倒下的樣子……！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿……",
        "unit_id": 138312,
        "voice": "vo_adv_5213333_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果只有我一個人，早就已經倒下了喔。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……是我",
        "unit_id": 138312,
        "voice": "vo_adv_5213333_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "誤會了。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使不使用皇家裝備，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也一直都有從大家身上獲得力量呢。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「連結的心意」──",
        "unit_id": 138312,
        "voice": "vo_adv_5213333_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所化作的力量。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼……",
        "unit_id": 138312,
        "voice": "vo_adv_5213333_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "梅莉莎小姐。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓我們做個了斷吧。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "……正合我意。",
        "unit_id": 20013,
        "voice": "vo_adv_5213333_006"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n因為最後贏的人，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "會是我……！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「「喝啊啊啊啊～！！」」",
        "unit_id": 1,
        "voice": "vo_adv_5213333_007"
    }
]