[
    {
        "type": "background",
        "background": "501031"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "夏日假期也要結束了嗎。",
        "unit_id": 2713,
        "voice": "vo_adv_5152411_000"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "發生了好多事啊。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n對我而言過於刺激的泳裝愛蜜莉雅醬也超讚的……",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不對等等！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "不准回想！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "會想起羞恥不堪的回憶啊！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴？",
        "unit_id": 131911,
        "voice": "vo_adv_5152411_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你怎麼了嗎？",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n整個臉紅通通的。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "反正",
        "unit_id": 109812,
        "voice": "vo_adv_5152411_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "肯定是又想起自己像個小嬰兒向愛蜜莉雅大人撒嬌的回憶了吧。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n真是下流。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昴。",
        "unit_id": 132112,
        "voice": "vo_adv_5152411_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n如果你不介意的話，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "也可以跟雷姆撒嬌喔？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "休想用甜蜜誘惑來扭曲我的癖好！",
        "unit_id": 2713,
        "voice": "vo_adv_5152411_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "照顧小孩子的事就交給我！",
        "unit_id": 131911,
        "voice": "vo_adv_5152411_005"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這是個好機會，可以來嘗試我跟大家學到的東西。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "連愛蜜莉雅醬都這樣！",
        "unit_id": 2713,
        "voice": "vo_adv_5152411_006"
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "真的",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "拜託放過我吧！",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "\n喂姊姊，",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "妳那帶有責備之意的眼神是什麼意思啊。",
        "unit_id": 2713
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哎呀抱歉。",
        "unit_id": 109812,
        "voice": "vo_adv_5152411_007"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n我本來是打算用蔑視的眼神看你，",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "看來還不夠輕蔑呢。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "昴",
        "words": "我在意的點不是那個啊！？",
        "unit_id": 2713,
        "voice": "vo_adv_5152411_008"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "哎呀，",
        "unit_id": 2612,
        "voice": "vo_adv_5152411_009"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "大家都很開心的樣子，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "海邊也挺不賴的嘛♪",
        "unit_id": 2612
    }
]