[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伴隨著讓人暢快的疲憊感，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n平安結束舞台劇的紡希正在稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n結束了……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是舞台劇……",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n有種和唱歌跳舞不同的",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n興奮感呢……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然也發生了預料之外的事情，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但我應該有卯足全力，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "打造出了很棒的舞台劇才是。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的演技……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如何呢……？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算你那樣誇獎我，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也沒什麼好處喔？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說！",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n最後那個是怎樣啊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "既然你要上台演戲的話，就先跟我說聲你會上台啊！",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我真的嚇了一跳耶！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在那一瞬間，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可是眼前一片空白喔！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯沒錯，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是這種感覺……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "眼前又一片空白……？",
        "unit_id": 113911
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "想說可以為學習設計帶來幫助，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就到城裡來了……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但明明是萬聖節，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卻沒什麼在變裝的人耶……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是因為現在還是白天嗎？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個人",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有變裝！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n黑披風和燕尾服……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吸血鬼嗎？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "等等～！",
        "unit_id": 231,
        "voice": "vo_adv_1139004_011"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "是吸血鬼～！",
        "unit_id": 131,
        "voice": "vo_adv_1139004_012"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n這是你的弱點，十字架喔～！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個吸血鬼還真是丟臉耶……",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他這不是被小孩子追著到處跑嗎？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是說……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我好像有在哪裡見過啊，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個人……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n應該說，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不會錯的……！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你這是在",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "做什麼啊！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種事情我用看的就知道了。",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我在意的是，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你為什麼要打扮成吸血鬼，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n又被小孩子追著跑！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一般來說不是要反過來嗎？",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_017"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "因為我們",
        "unit_id": 131,
        "voice": "vo_adv_1139004_018"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "明明跟這個大哥哥說了不給糖就搗蛋，",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n他卻沒有給我們糖果～！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "所以我們",
        "unit_id": 231,
        "voice": "vo_adv_1139004_019"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "正在對他惡作劇～！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……原來如此。",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呵呵，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你這樣根本就是在被小孩子耍著玩不是嗎？騎士先生。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明打扮成這樣，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n卻沒有威嚴，也不恐怖呢！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "來吧，大哥哥！",
        "unit_id": 231,
        "voice": "vo_adv_1139004_022"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n這次換大哥哥來追我們囉！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "要數完十秒再開始喔～！",
        "unit_id": 131,
        "voice": "vo_adv_1139004_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是天真無邪呢。",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也和他們差不多……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你和小孩子一起玩時，完全沒有格格不入的感覺耶。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說一起玩……",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是指扮演吸血鬼嗎？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "找我一起玩？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我才不要咧，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這麼",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幼稚的事情……！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "咦～！",
        "unit_id": 131,
        "voice": "vo_adv_1139004_026"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n大姐姐也來玩嘛～！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "因為大哥哥",
        "unit_id": 231,
        "voice": "vo_adv_1139004_027"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n明明是吸血鬼，卻不怎麼可怕啊！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說示範……",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是指扮演吸血鬼嗎？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是你看嘛……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也沒有變裝的衣服啊。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你說這附近有服裝出租店？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生的服裝也是跟那裡借來的啊。",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，但是，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就、",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算你用那麼可憐的眼神看我……！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "受不了～～～",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真拿你沒辦法！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我知道了啦！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我示範就是了，",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣總行了吧！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你們等我一下，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我去換衣服！",
        "unit_id": 105431
    },
    {
        "type": "still",
        "still": "113900401"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "──給、",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給我血～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇～！",
        "unit_id": 131,
        "voice": "vo_adv_1139004_035"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "呀～！",
        "unit_id": 231,
        "voice": "vo_adv_1139004_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我為什麼要做這種事情～～～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這一切全都是",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生造成的……！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "成、",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "成為我的奴僕吧～～～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳比大哥哥",
        "unit_id": 131,
        "voice": "vo_adv_1139004_039"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "演得更好呢！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗯，",
        "unit_id": 231,
        "voice": "vo_adv_1139004_040"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "雖然妳好像還有點不好意思！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……這些小孩子",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是怎樣啊？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種事情我知道啦！",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是說，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你在那邊一臉了不起地給什麼建議啊！？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊！？",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這是在挑我毛病嗎！？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難道說你是在挑我毛病嗎！？",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不會再放過你了！",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我絕對要抓住你，",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "把你五花大綁起來！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇啊！？",
        "unit_id": 131,
        "voice": "vo_adv_1139004_045"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大姐姐變得更有魄力了！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好厲害好厲害～！",
        "unit_id": 231,
        "voice": "vo_adv_1139004_046"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "她的演技好逼真喔！",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給我站住～！",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n騎士先生～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼、",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼、",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭～～～！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "結果我還是被騎士先生耍得團團轉的啊！",
        "unit_id": 105431
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我一定會逮到你的～～～！",
        "unit_id": 105431,
        "voice": "vo_adv_1139004_049"
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是精采的全力奔馳呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過在這之後，你還是有被抓到，",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓吸血鬼對你做了很～可怕的事情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你想看到那一段嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話又說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然嘴上會抱怨，但還是願意陪你玩，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "紡希真是個好孩子呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她在個性上有些帶刺的部分，",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但你不能只注意到那一點，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因此害怕她喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但事到如今",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不需要我來跟你提醒這件事了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那今天",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就到此為止囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了不被吸血鬼攻擊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要早點睡喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那就再見囉。",
        "unit_id": 190011,
        "voice": "vo_adv_1139004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n萬聖節快樂♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定會、",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "逮到你……？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "奇怪？",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "睡著了嗎！？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊～",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是那個吧……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n舉辦慈樂之音的演唱會時也是，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在使盡全力後",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我好像也像昏過去似地在休息室睡著……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "原來",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我剛才有那麼緊張啊……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生也睡著了嗎？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生是也有上台。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但你沒做什麼會累成這樣的事情吧？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……算了。",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n畢竟你這次很努力，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n或許也累積了不少疲勞吧。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我現在才能跟你坦白，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但其實在決定我也要演戲時，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我有懷疑過自己能不能辦得到。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "實際試試看後，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我發現演戲這件事很開心……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而藉由練習演戲，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這件事也變得更加有趣……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我有接下這份工作，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是太好了。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是沒有騎士先生在，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我搞不好就會拒絕這份工作。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以說，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n呃……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你、",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你別說話，安靜聽我說！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你這個人很急性子耶！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……呃，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我這不是又發脾氣了嗎！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭……",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我明明不是想發脾氣的……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為什麼在面對騎士先生時……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就會……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……變得這麼情緒化呢？",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的臉很燙，",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "心好像也在怦怦跳。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總覺得這比上台時還要更緊張……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……你聽好了，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要仔細地聽我說喔。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為我只會說一次！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……謝謝你。",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_073"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n謝謝你",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "讓我踏出嶄新的一步。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多虧騎士先生……",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我總覺得好像開拓出了",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一條全新的道路。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "順帶一提，",
        "unit_id": 113911,
        "voice": "vo_adv_1139004_075"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你別得意忘形了！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你嚇到我這件事還是讓我很生氣！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "話音剛落的紡希，臉上帶著神清氣爽的笑容，"
    },
    {
