[
    {
        "type": "background",
        "background": "500995"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "牛群被徵收後過了幾天。【伊麗莎白牧場】的眾人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正勤奮地為牧場溫泉開張做準備。"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真陽～",
        "unit_id": 105211,
        "voice": "vo_adv_5040002_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我把妳要的木材",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "搬過來囉～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "先放在那邊吧。",
        "unit_id": 103311,
        "voice": "vo_adv_5040002_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n細部的加工由我來處理，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪妳儘管搬過來吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "明白了♪",
        "unit_id": 105211,
        "voice": "vo_adv_5040002_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽。",
        "unit_id": 103811,
        "voice": "vo_adv_5040002_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我想把溫泉的休息區",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "做成這樣，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以試著畫了一張圖，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳覺得這樣如何？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～",
        "unit_id": 103311,
        "voice": "vo_adv_5040002_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在那裡放張可以躺的床呀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這的確比只放幾張椅子還要來得好啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真不愧是栞栞，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳很了解那些為了治病而來泡溫泉的人的想法耶。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟，我的經驗就只能應用在這種地方。",
        "unit_id": 103811,
        "voice": "vo_adv_5040002_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果要再做一張床，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n真陽的工作量又會增加了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳不用擔心我的啦。",
        "unit_id": 103311,
        "voice": "vo_adv_5040002_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牛隻會被扣押，本來就是我的問題，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n栞栞願意來幫我，就已經很感謝了……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真陽，",
        "unit_id": 103811,
        "voice": "vo_adv_5040002_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這件事我們說好不可以再提囉。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們幾個都是自願來幫忙的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "栞栞……",
        "unit_id": 103311,
        "voice": "vo_adv_5040002_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的很謝謝妳！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我一定要做出一個",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能讓大家開心的溫泉啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好！　",
        "unit_id": 103811,
        "voice": "vo_adv_5040002_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我相信",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴他們現在，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一定也在努力地發傳單。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我也不能輸給他們。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯。",
        "unit_id": 103311,
        "voice": "vo_adv_5040002_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n連那個愛偷懶的鈴鈴都那麼努力的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們也要加油才行！",
        "unit_id": 103311
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好麻煩。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的好麻煩。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好麻煩啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要啊。",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我要發傳單啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是麻煩的事情就是麻煩嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也知道這是小栞拼命努力做出來的傳單，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以要很用心地發給大家才行。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可是，這真的很不像我會做的事啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的嗎？　",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就拜託你……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我還沒有墮落成那樣啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果我真的打算都丟給你一個人做，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我就不會到這裡來了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說得也是呢。",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n畢竟是小栞努力做出來的傳單嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以要很珍惜、很珍惜地把它當作回憶保存起來……",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，\n怎麼可能這麼做啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你在說什麼啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉～",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道了啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然覺得好像有種被你牽著鼻子走的感覺，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "反正我會做啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我做就行了吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總之，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先把傳單投進信箱裡吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼……",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好累……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你平常都在做這種工作吧……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我對你有點刮目相看了呢……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總算發完一輪了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那回牧場去吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "已經結束了啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n整個鎮上都已經發過了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們的工作就到此為止了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我真的很努力呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "…………",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我知道啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "城鎮以外的地方，也要發傳單才行是吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "打起精神出發吧～！",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_024"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不對，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我好歹也是真的",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "想要努力去做的說？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "為什麼非得被你帶到這種毫無人跡的森林裡不可啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來這裡之前，我可是很認真地在發傳單的說，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n但森林裡又沒什麼人？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你說捷徑，",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是指前面有什麼嗎……？",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "500351"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這裡",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是哪裡啊……？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊～哥哥！",
        "unit_id": 211,
        "voice": "vo_adv_5040002_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "歡迎！　",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "你是來找我們玩的嗎？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "還是要找咲戀媽媽？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咲戀媽媽……？　",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "原來這裡是咲戀育幼院啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n之前伊麗莎白牧場毀損的時候，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n受到了他們許多幫助呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "伊麗莎白牧場！？",
        "unit_id": 111,
        "voice": "vo_adv_5040002_032"
    },
