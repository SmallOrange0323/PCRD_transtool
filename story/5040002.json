        "name": "鈴",
        "words": "謝謝妳。",
        "unit_id": 102611,
        "voice": "vo_adv_5040002_061"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼再見了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我們兩個",
