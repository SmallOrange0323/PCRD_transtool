    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在順利解決了有關洋館的怪奇事件後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n霞的偵探事務所生意漸入佳境。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}今天也一如往常地以助手身分，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n協助著事務所的各項業務。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呼……",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣就行了，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好！",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這次也平安地",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解決事件了！",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我來泡吧。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n偶爾也讓我表達一下感謝之意。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個…………",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒、",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒什麼……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……不……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "果然……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也不是真的沒什麼。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我一直想找個機會問你。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有件事我很在意──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該說覺得很不可思議。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不太合邏輯的事情。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生平時，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該也是個大忙人吧？",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n既然如此，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼還會這麼頻繁地",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來到這間事務所呢？",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "難道說──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是因為想見到我嗎？",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──這種話怎麼可能問得出口啊！！　",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……那個，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "難道，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是你手頭上缺錢嗎？",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是、",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是嗎……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是……抱歉，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我問了很奇怪的事情。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n如果有我能幫得上忙的地方，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請別客氣儘管找我商量。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我會盡可能地為你通融的……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "～～唔！",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不不！",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的！",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生你就是這點讓人受不了！",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n該說是你用詞太過直白，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是那個，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太容易引人誤會了啦。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "萬、",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "萬一有人誤會了……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解讀成別的意思該怎麼辦。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你以後要多加注意呀！",
        "unit_id": 137412
    },
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "…………",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……是說，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "水不知道燒開了沒……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總是很率直呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "正因為太過率直，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有時反而會令人難以理解……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就算是名偵探，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也對這個謎題束手無策。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生他到底──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──實際上對我，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是怎麼想的呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉……",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要是這世上，有個能映照出真相的鏡子，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就好了……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……不對，",
        "unit_id": 137411,
        "voice": "vo_adv_1374004_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這不是有嗎！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就在這裡！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這根法杖的前端！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……如果用這個，",
        "unit_id": 137411,
        "voice": "vo_adv_1374004_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偷偷地映照助手先生的話……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不、",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不不不！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在想什麼啊！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n窺探他人的內心，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "作為一名修女這是絕對不該有的念頭！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "冷靜一點。",
        "unit_id": 137411,
        "voice": "vo_adv_1374004_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這種時候……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對了，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要祈禱！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "閉上眼睛……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "默唸……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n邪惡的心靈啊，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "退散吧……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "快點消失吧……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 137411,
        "voice": "vo_adv_1374004_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偷瞄。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個嘛，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多少還是想知道呢……",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這是，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒錯，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n為了讓偵探與助手之間的職場關係，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能圓滿維持下去所必要的──",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇啊啊！",
        "unit_id": 137411,
        "voice": "vo_adv_1374004_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒、",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒什麼，只是想說把這根法杖和鏡子收起來──",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 137411
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在陣雨落下的公園，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正與放學途中的霞一起躲雨。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呼……",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n好大的一場陣雨……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "前陣子剛出的，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「真相事件簿」新刊的話題。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n能和學長",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聊這些真的太好了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……啊，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是的。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我還以為會再下一陣子，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n沒想到停得挺快的呢……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有點驚險呢……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嘿嘿。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "…………",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在放學回家的路上，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一起遇到了陣雨，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "兩個人待在一起，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "共同躲雨的時間。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我凝視著學長望著雨景的側臉，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那段時光。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "究竟過了多久呢。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺轉眼間就結束了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長因為雨很快就停了，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而為我感到高興。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n為了想早點回家的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因為我說了，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是雨能快點停就好了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我一直在想，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是雨永遠不要停就好了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在彷彿被雨之面紗包圍、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只有我們兩個人的世界裡，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n永遠地，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聊著天、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "歡笑著──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說起來，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在笑著的人，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好像只有我呢。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一直在說話的……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也只有我而已……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對、",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對了！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個小道具，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很有趣對吧。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n「真實之鏡」。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n連隱藏的真實想法都能看穿，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然說只是某種戲法──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……好的。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長總是很溫柔。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是那部小說裡出現的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「真實之鏡」真的存在的話──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──要是真的存在。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我一定會因為害怕，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而不敢窺視吧。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呃……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……現在，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是握住學長那隻、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "溫柔的手的話──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就會結束了。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們兩人的時光。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n今天也依然，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在毫無進展的情況下宣告結束。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所謂的有進展，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就代表著逐漸接近我所不想看見──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "又或說是我所畏懼的真相。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果像推理小說那樣，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "將真相徹底解開的話……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n如果將學長的心意……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽得清清楚楚的話……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "到那個時候會宣告終結的，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是我的故事。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是由我，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "擅自編織、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "擅自夢想、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n並擅自勾勒出幸福結局的──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我的、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只屬於我一個人的故事。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那本身就會宣告終結。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是正朝著那樣的結局，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "翻動著書頁的嗎。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……不、",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不對。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這並不是推理小說。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是活在，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "名為現實的這個世界裡。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n根本不需要像按順序翻頁那樣，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "做著循規蹈矩的事情。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不管是理由，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是道理，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我都不需要了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我要──",
        "unit_id": 101431
    },
    {
        "type": "still",
        "still": "137400401"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個！",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能不能再陪我，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "多聊一下呢！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我原本是想早點回家的。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比起那個──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……感覺快要移開視線了。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果一直逃避的話，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是不會改變的吧。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了與學長的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「後續」……！　",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我、",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想跟學長聊天。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我想跟學長，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "繼續那段美好的對話。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我想……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "繼續下去……！",
        "unit_id": 101431
    },
    {
        "type": "still",
        "still": "137400402"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……！",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n學長……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也是……？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "意思是……",
        "unit_id": 101431
    },
    {
        "type": "still",
        "still": "137400403"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……！",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我也是……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也覺得很開心！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "非常地……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……啊啊……",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長他──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "果然，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很溫柔呢。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n說不定實際上，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只是為了配合我，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才這麼說的。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不需要任何藉口。",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_053"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不需要加上任何道理。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n只因為我想待在一起。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n僅僅因為那樣的理由，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就能與學長共度的日子……！　",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_054"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n再坐一下下，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "繼續我們兩人的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讀書心得會吧。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n對了對了，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於「真實之鏡」的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那段後續──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於「真相，",
        "unit_id": 101431,
        "voice": "vo_adv_1374004_055"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是靠我們自己用雙手去創造的」，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那段故事。",
        "unit_id": 101431
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我敬虔的信徒啊。",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n向著超級可愛的戀愛女神──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "愛梅斯大人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "獻上祈禱吧～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "首先是──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "挺厲害的嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "霞。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看到那副惹人憐愛的模樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連我都忍不住想為她加油了呢♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她是個很不可思議的孩子呢～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在那邊跟這邊的印象竟然差這麼多。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你一定也很清楚才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就算那孩子是在演繹",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她心目中理想的模樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不能說那全部都是謊言",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想要成為",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "理想中自己的這份心情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n以及就這樣維持現狀喜歡著你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的這份心意。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那兩者，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也許都是她的真相──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也說不定呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是說。",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真相或許不是只有一個，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的意思喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說不定總有一天，會由你來揭開這個謎底呢？",
        "unit_id": 190011,
        "voice": "vo_adv_1374004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "助手先生♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500951"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……唔……",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_063"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇啊！",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我真是的，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "竟然抓著助手先生的袖子就睡著了……",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是嗎，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_064"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是想用鏡子窺探助手先生的內心，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n結果就那樣睡著了嗎。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然最後還是沒能窺探到助手先生的內心，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_065"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是這樣就好了。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_066"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在經歷了這次的種種事件後，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我有了一些感悟。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所謂的真相，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並非是一味地去窮追不捨的東西，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是這麼想的。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你還記得嗎。",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_067"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那天的幽靈騷動──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n起初，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我原本打算用強硬手段排除那個男人的幽靈。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_068"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那時候，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一隻不知從哪闖進來的貓妨礙了我。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n多虧如此，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我才能喘口氣，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "重新找回自我。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在想，那或許，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是小霧也說不定。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我覺得，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_069"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧其實還留在我身邊，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n一直守護著我。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了在真正重要的時刻，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不讓我推理出錯。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在我的心中，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_070"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧一直在這裡，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偶爾還會跟我聊聊天。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是真的喔。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也就是說，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這代表小霧是真的「存在」的。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這一點，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_071"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "和小霧是否以實體存在於此，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是完全不同的兩回事。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果是助手先生的話",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_072"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一定能明白的吧。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然，",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_073"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是真相的信奉者。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這一點，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "往後也絕對不會改變。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但現在，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我覺得沒必要急著去揭開真相，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是這麼想的。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並非是赤裸裸的事實──",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_074"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "僅僅是，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一份希望如此的心情。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n人們所期盼、",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所祈禱之物──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以及由此在心中萌生之物──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "將其稱為真相。",
        "unit_id": 137412,
        "voice": "vo_adv_1374004_075"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這樣的定義，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不錯吧。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有時候嘛。",
        "unit_id": 137412
    }
]