    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以的話，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_054"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我也不想辜負大家的期待呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_055"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我玩得實在不是很好……",
