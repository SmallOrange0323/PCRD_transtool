    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "三、四！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n奮鬥吧～",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉……",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n今天的訓練還是很辛苦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "趁著在街上巡邏的時候，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還要大聲報數慢跑……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n真是老派的作法，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然在道館修練的時候就已經習慣了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是看著同齡的女孩子們，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在街上打扮得漂漂亮亮",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在逛街的樣子。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我常常忍不住問自己：",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這樣真的好嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我是不是在浪費寶貴的青春呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這也是我自己選的道路啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "偶爾也會……",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n思考自己失去了什麼，而非獲得了什麼，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n然後變得垂頭喪氣的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唉……",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不行了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不知道是不是因為一直跑步太累了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n連思考都變得好負面。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "明鏡止水。",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n得讓自己",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "集中振作。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……嗯？",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_009"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "怎麼啦，",
        "unit_id": 711,
        "voice": "vo_adv_1037004_010"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "新來的！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n看來妳還有餘力東張西望嘛！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "這麼有精神的話，",
        "unit_id": 711,
        "voice": "vo_adv_1037004_011"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n就再去鎮上沿著外圍跑個三圈如何？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "噫呀？",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_012"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "對不起！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我只是有一瞬間",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "恍神了！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "啊，",
        "unit_id": 711,
        "voice": "vo_adv_1037004_013"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "別跑！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "\n妳要去哪裡，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士團員",
        "words": "智團員……！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "非常抱歉！",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_014"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n等一下",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看是要追加三圈還是十圈我都跑！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗚……",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_015"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "到底是怎麼了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最近很不順利呢。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "本來我是想說耍些小聰明，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_016"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當個聽話的乖孩子，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n受到上層喜好，在【王宮騎士團】出人頭地的說。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "算了。",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_017"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是說現在我比較在意，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n倒在那邊的那個人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那是，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_018"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}對吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為什麼",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會倒在那種地方睡覺啊 ？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "睡午覺？",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_019"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "看起來也不太像呢……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是被壞人",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "或是闖進城市裡的魔物們襲擊了嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為之前對{player}說了奇怪的話……",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_020"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以現在看到他會覺得很害羞就是了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "現在不是說這種話的時候吧，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_021"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n畢竟可能是緊急狀況啊。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}！\n那個，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_022"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你怎麼了？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒事吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯……？",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_023"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n看起來",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像只是單純地在睡覺罷了？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這是怎麼回事？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_024"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼說來……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n在關於{player}的資料裡，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n好像有寫著注意事項的樣子。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "上面好像寫到，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_025"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n{player}似乎跟某種超自然的存在有所關聯。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}偶爾會因為受到某人的干涉，",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_026"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n突然失去意識……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "之類的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "唔！？",
        "unit_id": 103711,
        "voice": "vo_adv_1037004_027"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n咦，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這個亮光是……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "什麼？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太亮了，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "眼睛完全張不開！",
        "unit_id": 103711
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗯？",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_028"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "嗨嗨，{player}！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n居然在這種地方遇見你，真是巧合啊！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "黑白猜！",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_029"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n男生女生",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "配♪",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哈哈哈。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_030"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n是我贏了！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}還是一樣",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "很不會應付偷襲呢♪",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_031"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為我贏了，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以輸掉的{player}，今天一整天……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n都要對我言聽計從，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣沒問題吧？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哈哈哈。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_032"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}你真遲鈍呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我可是劍術道場的小孩。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_033"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n無論是什麼比賽，我都會認真看待唷。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且會拼了命呢。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_034"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為對御久間流來說，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "失敗就代表死亡。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "即使只是黑白猜，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_035"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但比賽就是比賽。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n比賽的結果對我來說",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有很深的意義。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以獲得勝利的我，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_036"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n可說是有資格獲得輸家，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n也就是{player}你的生殺大權。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當然。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_037"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如果是我輸的話，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我也打算對{player}言聽計從唷。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "無論是多麼害羞的要求，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_038"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我都會照做的。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但是很可惜，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "贏的人是我。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "所以{player}，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_039"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n有義務聽從我的任何命令。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n如何，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還有什麼問題嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "很好很好。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不愧是{player}，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "反應很不錯。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……但是你這樣完全不吐槽我，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還是會覺得有點寂寞啦。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "話說回來。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_042"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我不會做出什麼太困難的要求，所以放心吧，\n{player}。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我們能在這裡相遇也算是一種緣份。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_043"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就請你",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來陪我玩個遊戲吧。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_044"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我記得你好像還滿會玩遊戲的嘛。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我常常",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "會如此感嘆，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "啊，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "無論是什麼樣的人，神明都會賜予才能呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而對於{player}來說，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是指遊戲。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真的是遊戲的天才呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我是",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "打從心底這麼想的。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……我絕對不是故意捧{player}，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n讓你覺得自己很厲害的唷。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_048"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你看，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有看見那邊那台遊戲機吧？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那是用最近",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "很流行的射擊遊戲進行改編的機台……",
