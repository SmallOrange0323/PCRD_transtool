    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "感謝緣份讓我跟{player}相遇，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這可不是平常說的那種玩笑話唷。",
        "unit_id": 103731
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是如同夢境一般的情景唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很快就會忘記的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是依照你與和你有緣的女孩的記憶，",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n來重新建構的夢境……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這麼說有點怪，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但你可以想成是自費拍攝的電影之類的東西唷。",
