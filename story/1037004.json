        "voice": "vo_adv_1037004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還在心中的更深處……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在我們還無法碰觸到那部份，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只能讓你看到這些非常普通的日常生活片段。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說說而已～",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟對現在的你說太多也沒用呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……但凡事都要",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小心點哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為小智隸屬的那個",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "【王宮騎士團】……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像隱約",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "察覺到我的存在了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我現在可以說是無防備狀態，",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以要是被盯上可就糟了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果可以，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n請小心不要讓別人知道我跟你的關係喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然等你醒來之後，",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n應該不會記得這些事情吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但還是得",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託你一下囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "麻煩你了，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_1037004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就算是面對小智，",
        "unit_id": 190011
    },
    {
