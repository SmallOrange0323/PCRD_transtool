        "voice": "vo_adv_1037004_050"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "用那把刀唰唰唰地砍倒……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我跟學校的朋友約好，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_051"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n之後要來玩這個遊戲。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過朋友總覺得",
