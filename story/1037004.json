    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "最令人驚訝的是，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_049"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n要用刀型控制器來玩呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "將出現在畫面上的壞忍者跟武士，",
