        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}，\n可以麻煩你在旁邊看我玩，給我一些意見嗎？",
