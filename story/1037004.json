    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可以的話，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_056"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我想練到能夠零失誤的過到最後一關呢。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "當然，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_057"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也可以陪我一起玩唷。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "畢竟只有一個人反覆一直玩的話，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "也是蠻累的……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "因為基本上，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_058"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我是不喜歡寂寞的那種人嘛。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_059"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n你OK嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "太感謝了",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "{player}你人真好！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "哎呀，",
        "unit_id": 103731,
        "voice": "vo_adv_1037004_060"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能有個好前輩真是太好了！",
