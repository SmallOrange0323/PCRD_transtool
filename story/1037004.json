        "voice": "vo_adv_1037004_052"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我是在劍術道場長大的，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n所以應該很強……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我覺得，",
