[
    {
        "type": "background",
        "background": "500159"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個叫半藏的人，",
        "unit_id": 103811,
        "voice": "vo_adv_6040401_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "居然對真陽這麼粗暴，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真是不可原諒。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且還穿著很奇特的服裝，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "他到底是什麼人啊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "意思是",
        "unit_id": 103811,
        "voice": "vo_adv_6040401_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "他有那種興趣嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣就不能",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說那是奇怪的打扮了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過我還是覺得粗暴是不好的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很帥氣",
        "unit_id": 103811,
        "voice": "vo_adv_6040401_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這樣嗎……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "每個人的品味都不一樣呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果你也想穿那種衣服的話，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我不會否定你的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你連打扮像那樣的人都認識嗎？",
        "unit_id": 103811,
        "voice": "vo_adv_6040401_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那應該是個好孩子吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種衣服就不是只有\n壞人才會穿的衣服了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謎團更深了呢……",
        "unit_id": 103811
    }
]