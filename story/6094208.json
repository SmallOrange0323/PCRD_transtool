        "voice": "vo_adv_6050208_000"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "子どもたちにお菓子をねだられたよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "あいにく持ち合わせがなくていたずらされてしまったけど、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ハロウィンだと思えば",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "楽しいものだね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "え？　",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_001"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "キ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "キミも？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "い、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "いや、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "さすがにキミからいたずらされるのは恥ずかしいな……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "冗談？　",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "なるほど、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "今のがイタズラだったのか。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "一本取られたよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "わっ、",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_002"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "こんなにたくさん？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "これだけあれば",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "さっきの子どもたちに渡せそうだ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n一緒に渡しに行こう。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "きっと喜んでもらえるよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "いや、",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_003"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "楽しそうな子どもたちを見ていると",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "こちらまで",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n明るくなれるというだけで……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "キミ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ひょっとして今",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\nいたずらしようとしていた？",
        "unit_id": 114011
    }
]