    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也許我應該再研究一下比較好。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了能夠更得心應手，",
