    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而已……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是煩惱錢的問題",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就用魔物料理當年菜來解決怎麼樣？",
