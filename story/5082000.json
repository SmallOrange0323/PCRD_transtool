[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即將邁入年底，蘭德索爾瀰漫著一股雀躍的氣氛，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在【美食殿堂】這裡也不例外。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣一來大掃除就完成了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您也辛苦了。",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一整年累積的髒污",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也都清理乾淨了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣一來就能以清爽的心情迎接新年了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "平時看不見的",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "櫃子後方與床底下",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也都一乾二淨了呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這就是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大掃除……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們公會啊",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對這種每年的例行公事就是會特別花時間呢～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲是第一次在【美食殿堂】跨年，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以會驚訝也很正常。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來確實是第一次！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自然而然地就接受了您的幫忙，",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以在下完全沒注意到……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我已經問過城鎮中的人們，",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有了大概的知識。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "總覺得一次拋出太多問題，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n給大家添麻煩不太好……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪會添麻煩！",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們不是好朋友嗎！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確如此。",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只是大掃除的事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下等人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鉅細靡遺地告訴您吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲第一次在【美食殿堂】過的新年……",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們會讓它變成最棒的回憶！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請交給我們來辦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊哈哈……",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們真是的。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要造成雪菲困擾哦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一點也不困擾哦。",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能聽到妳們這樣說，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我真的很高興。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲，",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳實在太老實了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可像這樣",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說出看似有好處的事時，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真正目的八成都與食物有關……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "接下來要開年菜派對喲！",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "年菜……",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是指年節料理嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是在新年時團圓",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起吃的料理。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看吧？",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n話題馬上就跑到食物去了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟這樣才像",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留妳會反對嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不是反對啦……",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，去年的事",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們都沒有忘記吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "去年的事……",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是大間的金槍鮪對吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在格外美味。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊……",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是很好吃沒錯，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我要講的不是那個！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是錢的事！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "費用！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成本！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是當時尾牙上不要那樣揮霍",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就根本不必去大間了不是嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且大老遠跑去就算了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還被那個該死的眼鏡女當傭人使喚。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不正是因為那樣才能與大間的各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n度過了美好的新年嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "每次都太過亂來了啦～！",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今年要按照計畫走才行。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可以吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然小凱留都這麼說了，",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我會稍微注意的♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是稍微而已，給我好好注意！！",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……算了，",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正最後也圓滿收場了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟大間的魚貝類都非常棒嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "年菜的材料也",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在大間買一買好了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n又不是不認識的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一次買很多說不定他們會算得更便宜！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之前的新年中享用的",
        "unit_id": 105913,
        "voice": "vo_adv_5082000_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "公會競速賽慶功宴料理，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也加了新年該有的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吉祥裝飾，實在賞心悅目。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說起來，",
        "unit_id": 105812,
        "voice": "vo_adv_5082000_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一講到年菜",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就想到發源地在東國，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "乾脆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們大家一起去東國",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大採購吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以我說不要只憑一時興起就浪費錢啦！",
        "unit_id": 106012,
        "voice": "vo_adv_5082000_033"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵……",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_034"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有，",
        "unit_id": 106412,
        "voice": "vo_adv_5082000_035"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒什麼事。",
