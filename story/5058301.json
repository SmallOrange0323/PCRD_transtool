[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留、小可蘿，",
        "unit_id": 105811,
        "voice": "vo_adv_5058301_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳們看！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊有魔物！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來非～常好吃呢☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼！",
        "unit_id": 106011,
        "voice": "vo_adv_5058301_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物看起來非常好吃呢！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對吧！！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要一看到魔物就立刻想像牠的味道啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一般",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不應該都是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來很難對付、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要多加小心",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之類的嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肉質看起來",
        "unit_id": 105911,
        "voice": "vo_adv_5058301_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確很硬，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很難對付的樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "料理的時候",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小心一點，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不要切到手指了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說啊，",
        "unit_id": 106011,
        "voice": "vo_adv_5058301_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我不是在討論肉的硬度唷！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是在說戰鬥……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿嘿，",
        "unit_id": 105811,
        "voice": "vo_adv_5058301_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了烹調美味的料理，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n【美食殿堂】的大家團結一心了呢♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_5058301_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n今天",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們【美食殿堂】也是",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "團結一心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的心是被強迫團結的吧！？",
        "unit_id": 106011,
        "voice": "vo_adv_5058301_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可沒有想要",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃什麼魔物啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "透過我們的羈絆，",
        "unit_id": 105811,
        "voice": "vo_adv_5058301_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天也取得美味的料理吧☆",
        "unit_id": 105811
    }
]